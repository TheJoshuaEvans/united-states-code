  "summaries": [
    {
      "actionDate": "2026-06-08",
      "actionDesc": "Passed Senate",
      "text": "<p>This resolution designates June 2026 as National Post-Traumatic Stress Awareness Month and&nbsp;June 27, 2026, as National Post-Traumatic Stress Awareness Day.</p><p>The resolution supports (1) the education of members of the Armed Forces, veterans, their families, and the public about post-traumatic stress; and (2) efforts by the Department of Veterans Affairs and the Department of Defense to foster cultural change around the issue of post-traumatic stress.</p><p>The resolution also encourages the leadership of the Armed Forces to support treatment of members of the Armed Forces who suffer from post-traumatic stress.</p>",
      "updateDate": "2026-07-16T23:53:22Z",
      "versionCode": "55"
    }
  ]
