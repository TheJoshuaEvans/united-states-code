    {
      "actionDate": "2026-03-16",
      "actionDesc": "Reported to House",
      "text": "<p>This concurrent resolution authorizes the National Fraternal Order of Police to sponsor two public events on Capitol grounds: the 45th Annual National Peace Officers Memorial Service (on&nbsp;May 15, 2026) and the National Honor Guard and Pipe Band Exhibition (on May 14, 2026). The concurrent resolution also authorizes the Speaker of the House and the Committee on Rules and Administration of the Senate to&nbsp;jointly designate alternate dates.&nbsp;</p>",
      "updateDate": "2026-03-19T19:26:21Z",
      "versionCode": "07"
    }
