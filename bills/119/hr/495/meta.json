    {
      "actionDate": "2025-01-16",
      "actionDesc": "Introduced in House",
      "text": "<p><strong>Subterranean Border Defense Act</strong></p><p>This bill requires recurring annual reporting by U.S. Customs and Border Protection (CBP) on the implementation of a strategic plan to counter illicit cross-border tunnel operations. Currently,&nbsp;CBP is only required to report once no later than one year after the plan's development.&nbsp;</p>",
      "updateDate": "2025-03-05T16:27:15Z",
      "versionCode": "00"
    }
