  "summaries": [
    {
      "actionDate": "2025-07-23",
      "actionDesc": "Introduced in House",
      "text": "<p><strong>Bill to Outlaw Wounding of Official Working Animals Act or the BOWOW Act</strong></p><p>This bill establishes that a&nbsp;non-U.S. national (<em>alien</em> under federal law) convicted of, or who admits to having committed, an offense related to harming animals used in law enforcement is inadmissible and deportable.</p>",
      "updateDate": "2026-02-27T19:58:49Z",
      "versionCode": "00"
    }
