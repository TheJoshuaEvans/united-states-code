  "summaries": [
    {
      "actionDate": "2025-09-02",
      "actionDesc": "Introduced in House",
      "text": "<p>This bill reauthorizes through FY2026 the Small Business Innovation Research (SBIR) program, the Small Business Technology Transfer (STTR) program, and related pilot programs.</p><p>The SBIR and STTR programs are administered by various federal agencies and provide competitive awards for domestic small businesses to conduct research and development projects that have the potential for commercialization.</p>",
      "updateDate": "2025-09-11T14:33:56Z",
      "versionCode": "00"
    }
