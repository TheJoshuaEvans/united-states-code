    {
      "actionDate": "2026-03-25",
      "actionDesc": "Reported to House",
      "text": "<p><strong>Restoring the Secondary Trading Market Act</strong></p><p>This bill prohibits states from banning, limiting, or imposing conditions upon off-exchange secondary trading of securities.&nbsp; This prohibition applies if the issuer of those securities provides public information on the issuer's financial status in accordance with federal regulations.</p>",
      "updateDate": "2026-04-17T20:12:08Z",
      "versionCode": "07"
    }
  ]
