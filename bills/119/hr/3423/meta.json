  "summaries": [
    {
      "actionDate": "2025-05-15",
      "actionDesc": "Introduced in House",
      "text": "<p><strong>Facility for Runway Operations and Safe Transportation Act or the FROST Act</strong></p><p>This bill allows airport sponsors to use funds from Airport Improvement Program (AIP) grants for storage facilities for aircraft deicing equipment and fluids.</p><p>Under current law, airports may use&nbsp;AIP funds for structures and equipment that are used to deice&nbsp;aircraft, but not for the associated storage facilities.</p>",
      "updateDate": "2025-09-08T14:14:27Z",
      "versionCode": "00"
    }
