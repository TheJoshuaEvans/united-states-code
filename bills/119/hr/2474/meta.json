    {
      "actionDate": "2025-03-27",
      "actionDesc": "Introduced in House",
      "text": "<p><strong>Expanding Appalachia\u2019s Broadband Access Act</strong></p><p>This bill requires the Government Accountability Office to study and report to Congress on the Appalachian Regional Commission\u2019s capability to incorporate low-orbit satellites in broadband projects. Specifically, the study must review and analyze the capacity and cost-effectiveness of using satellite broadband service for business purposes and economic development.&nbsp;</p>",
      "updateDate": "2025-05-23T18:04:30Z",
      "versionCode": "00"
    }
