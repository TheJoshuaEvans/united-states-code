    {
      "actionDate": "2025-03-21",
      "actionDesc": "Introduced in House",
      "text": "<p><strong>National Strategy for School Security Act of 2025</strong></p><p>This bill requires the Department of Homeland Security (DHS) to develop a national strategy to secure elementary and secondary schools from acts of terrorism. DHS must submit this strategy to Congress, annually update the strategy (if appropriate) through 2033, and provide annual briefings to Congress on those updates.</p>",
      "updateDate": "2025-09-03T19:17:15Z",
      "versionCode": "00"
    }
