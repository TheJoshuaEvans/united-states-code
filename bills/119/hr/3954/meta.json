  "summaries": [
    {
      "actionDate": "2025-06-12",
      "actionDesc": "Introduced in House",
      "text": "<p><strong>Improving Access to Medicare Coverage Act of </strong><strong>2025</strong></p><p>This bill deems an individual receiving outpatient observation services in a hospital as an inpatient for purposes of satisfying the three-day inpatient hospital-stay requirement&nbsp;with respect to&nbsp;Medicare coverage of skilled nursing facility (SNF) services. (Generally, individuals must have been an inpatient at a hospital for at least three days in order to qualify for SNF services. An individual's time spent under observation at a hospital for purposes of determining whether the individual should be admitted does not count towards this requirement.)</p>",
      "updateDate": "2025-07-25T16:12:43Z",
      "versionCode": "00"
    }
  ]
}