  "summaries": [
    {
      "actionDate": "2026-07-02",
      "actionDesc": "Reported to House",
      "text": "<p>This bill reauthorizes through FY2030 activities of the Centers for Disease Control and Prevention to address vector-borne diseases (e.g., diseases spread by bites from ticks or mosquitoes). These activities include (1) a national strategy, (2) grants for regional centers of excellence, and (3) cooperative agreements with state, local, and tribal health departments&nbsp;to increase capacity for preventing and responding to vector-borne diseases.</p>",
      "updateDate": "2026-07-16T21:39:21Z",
      "versionCode": "07"
    }
  ]
