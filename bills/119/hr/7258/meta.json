  "summaries": [
    {
      "actionDate": "2026-05-11",
      "actionDesc": "Reported to House",
      "text": "<p><strong>Energy Emergency Leadership Act</strong></p><p>This bill expands the list of functions that the Secretary of Energy must assign to assistant secretaries under the Department of Energy Organization Act to include energy emergency and energy security functions, such as responsibilities with respect to energy infrastructure and cybersecurity.</p><p>The Department of Energy must ensure that such functions are performed in coordination with relevant federal agencies.</p>",
      "updateDate": "2026-06-25T12:16:35Z",
      "versionCode": "07"
    }
