    {
      "actionDate": "2025-01-16",
      "actionDesc": "Introduced in House",
      "text": "<p><strong>Miccosukee Reserved Area Amendments Act</strong></p><p>This bill expands the Miccosukee Reserved Area to include a portion of Everglades National Park in Florida that is known as Osceola Camp. The Department of the Interior, in consultation with the Miccosukee Tribe of Indians, must take appropriate actions to protect structures within the Osceola Camp from flooding.</p>",
      "updateDate": "2025-03-05T19:05:58Z",
      "versionCode": "00"
    }
