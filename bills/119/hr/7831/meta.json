  "summaries": [
    {
      "actionDate": "2026-05-20",
      "actionDesc": "Reported to House",
      "text": "<p><strong>License to Drill Act</strong></p><p>This bill extends through FY2037 the Bureau of Land Management\u2019s (BLM\u2019s) authority to collect oil and gas permit processing fees. For each new permit application, BLM collects a fee that is transferred to the BLM Permit Processing Improvement Fund.&nbsp;(Under current law, the fees are authorized through FY2026.)</p>",
      "updateDate": "2026-05-29T12:54:10Z",
      "versionCode": "07"
    }
  ]
