  "summaries": [
    {
      "actionDate": "2025-03-18",
      "actionDesc": "Introduced in House",
      "text": "<p><strong>Access to Small Business Investor Capital Act </strong></p><p>This bill allows a registered investment company to exclude from the calculation of acquired fund fees and expenses those incurred indirectly from investment in a business development company. <em>Acquired fund fees and expenses</em> is a required line item on a fund's fee schedule that provides the operating expenses of the fund.</p>",
      "updateDate": "2025-06-18T18:12:58Z",
      "versionCode": "00"
    }
  ]
