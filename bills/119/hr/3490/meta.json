    {
      "actionDate": "2025-05-19",
      "actionDesc": "Introduced in House",
      "text": "<p><strong>Esophageal Cancer Awareness Act</strong></p><p>This bill requires the Government Accountability Office to report to Congress on (1) the impact of esophageal cancer-related health care spending under the Federal Employees Health Benefits Program (FEHBP) for federal employees and retirees diagnosed with esophageal cancer, and (2) how often FEHBP participants with a high risk of esophageal cancer undergo screenings according to established guidelines.&nbsp;</p>",
      "updateDate": "2025-05-30T21:32:03Z",
      "versionCode": "00"
    }
  ]
