  "summaries": [
    {
      "actionDate": "2025-06-25",
      "actionDesc": "Reported to House",
      "text": "<p><strong>Increasing Investor Opportunities Act </strong></p><p>This bill allows a closed-end fund\u2014a portfolio of pooled assets with a limited number of shares traded on an exchange\u2014to increase its investment in private investment funds.&nbsp;Specifically, the Securities and Exchange Commission is prohibited from limiting the sale or listing of securities of a closed-end fund that invests in private investment funds. This bill also apples to a closed-end company treated as a business development company.&nbsp;&nbsp;</p>",
      "updateDate": "2025-09-02T21:04:40Z",
      "versionCode": "07"
    }
  ]
