  "summaries": [
    {
      "actionDate": "2025-01-09",
      "actionDesc": "Introduced in House",
      "text": "<p>This bill renames a trail and a park within Paterson Great Falls National Historical Park located&nbsp;in Paterson, New Jersey, in honor of Congressman Bill&nbsp;Pascrell, Jr. Specifically, it renames the Great Falls Scenic Overlook Trail Bridge as the Bill&nbsp;Pascrell, Jr. Scenic Overlook Trail Bridge. It also renames Overlook Park as Bill Pascrell, Jr. Overlook Park.</p>",
      "updateDate": "2025-05-08T18:52:44Z",
