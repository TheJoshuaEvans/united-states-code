  "summaries": [
    {
      "actionDate": "2025-04-17",
      "actionDesc": "Introduced in House",
      "text": "<p><strong>Veterans'&nbsp;Transition to Trucking Act of 2025</strong></p><p>This bill authorizes the Department of Veterans Affairs (VA) to act as a state approving agency to approve multi-state apprenticeship programs (i.e., non-federal apprenticeship programs operating in more than one state) for purposes of VA educational assistance benefits. (State approving agencies are designated by states to provide, among other duties, approval of courses of education for purposes of VA education benefits.)</p>",
      "updateDate": "2025-07-08T16:57:13Z",
      "versionCode": "00"
    }
  ]
