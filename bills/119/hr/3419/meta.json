  "summaries": [
    {
      "actionDate": "2025-10-03",
      "actionDesc": "Reported to House",
      "text": "<p>This bill reauthorizes through FY2030&nbsp;grant programs to support telehealth networks and telehealth resource centers, which are administered by the Office for the Advancement of Telehealth within the Health Resources and Services Administration. These programs provide grants to health care providers and related entities to establish telehealth networks that expand access to and improve the quality of health care services and information in rural and medically underserved areas and for medically underserved populations.</p>",
      "updateDate": "2026-04-03T19:06:29Z",
      "versionCode": "07"
    }
