  "summaries": [
    {
      "actionDate": "2025-02-27",
      "actionDesc": "Introduced in House",
      "text": "<p><strong>Veterans Scam And Fraud Evasion Act of 2025 or the VSAFE Act of 2025</strong></p><p>This bill establishes a Veterans Scam and Fraud Evasion Officer within the Department of Veterans Affairs (VA) to be responsible for fraud and scam prevention, reporting, and incident response plans at the VA.</p><p>The bill also extends certain loan fee rates through June 23, 2034, under the VA's home loan program.</p>",
      "updateDate": "2025-04-08T16:04:16Z",
      "versionCode": "00"
    }
