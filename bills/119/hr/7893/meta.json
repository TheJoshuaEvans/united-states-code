  "summaries": [
    {
      "actionDate": "2026-07-02",
      "actionDesc": "Reported to House",
      "text": "<p><strong>FAFSA Verification Efficiency Act</strong></p><p>This bill requires the Department of Education (ED) to verify the Social Security number (SSN) and citizenship status of any individual who is required to provide information to ED for&nbsp;federal student aid.&nbsp;</p><p>Currently, ED must work with the Social Security Administration (SSA) to verify the SSN of a student who is applying for federal student aid. This bill expands the requirement so that ED must work with the SSA to verify the SSN and citizenship status of any individual who is required to provide information to ED on the Free Application for Federal Student Aid (FAFSA) form, including contributors. A contributor refers to anyone (the student, the student\u2019s spouse, the student's biological or adoptive parent, or a parent\u2019s spouse) who is required to provide information on the FAFSA form.</p>",
      "updateDate": "2026-07-13T19:26:24Z",
      "versionCode": "07"
    }
  ]
