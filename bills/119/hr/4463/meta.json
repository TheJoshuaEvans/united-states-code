  "summaries": [
    {
      "actionDate": "2026-04-02",
      "actionDesc": "Reported to House",
      "text": "<p>This bill revises tribal membership requirements for the Catawba Indian Nation (a tribe in South Carolina).</p><p>The&nbsp;Catawba Indian Tribe of South Carolina Land Claims Settlement Act of 1993 explicitly restricted the tribe\u2019s future membership to lineal descendants of people on the final base membership roll who maintained continuous political relations with the tribe. This bill removes these membership criteria and allows the tribe to determine its membership. (The tribe uses three base membership rolls and anyone who wants to be enrolled&nbsp;must prove lineal descent from someone listed on one of these base membership rolls.)</p>",
      "updateDate": "2026-05-28T20:43:19Z",
      "versionCode": "07"
    }
  ]
