  "summaries": [
    {
      "actionDate": "2025-02-24",
      "actionDesc": "Introduced in House",
      "text": "<p><strong>No Rogue Rulings Act or NORRA</strong></p><p>This bill limits the authority of federal district courts to issue injunctions.</p><p>Specifically, it prohibits a district court from issuing an injunction unless the injunction applies only to the parties of the particular case before the court. </p>",
      "updateDate": "2025-03-28T19:33:21Z",
      "versionCode": "00"
    }
