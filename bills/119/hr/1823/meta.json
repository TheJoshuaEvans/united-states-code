    {
      "actionDate": "2025-03-04",
      "actionDesc": "Introduced in House",
      "text": "<p>This bill requires the Government Accountability Office (GAO) to review and report on the circumstances and causes of the shortfall in funding of the Veterans Benefits Administration for FY2024 and the expected shortfall in funding of the Veterans Health Administration in FY2025. The Department of Veterans Affairs must submit such GAO report to Congress.</p>",
      "updateDate": "2025-05-14T13:42:06Z",
      "versionCode": "00"
    },
    {
      "actionDate": "2026-01-20",
      "actionDesc": "Public Law",
      "text": "<p><strong>VA Budget Shortfall Accountability Act</strong></p><p>This act requires the Government Accountability Office (GAO) to review and report on the circumstances and causes of the shortfall in funding of the Veterans Benefits Administration for FY2024 and the expected shortfall in funding of the Veterans Health Administration in FY2025. The Department of Veterans Affairs must submit such GAO report to Congress.&nbsp;For each of the five fiscal years following the date of enactment of this act, GAO must conduct subsequent reviews and reports regarding the funding of the VA.</p>",
      "updateDate": "2026-04-10T13:11:46Z",
      "versionCode": "49"
    }
  ]
