  "summaries": [
    {
      "actionDate": "2025-04-10",
      "actionDesc": "Introduced in House",
      "text": "<p><strong>FDA Modernization Act 3.0</strong></p><p>This bill requires the Food and Drug Administration (FDA) to publish an interim final rule implementing a provision of the Consolidated Appropriations Act of 2023 that authorized the use of certain alternatives to animal testing to support investigational use of a new drug.&nbsp;</p><p>The rule must replace references to animal tests, data, studies, models, and research with references to nonclinical tests, data, studies, models, and research throughout the FDA\u2019s regulations governing investigational new drug applications.&nbsp;</p><p>The rule must be published within one year of the bill\u2019s enactment, and must take immediate effect as an interim final rule.&nbsp;</p>",
      "updateDate": "2026-07-15T15:39:12Z",
      "versionCode": "00"
    }
  ]
}