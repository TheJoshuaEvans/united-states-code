  "summaries": [
    {
      "actionDate": "2025-12-09",
      "actionDesc": "Introduced in Senate",
      "text": "<p><strong>Accelerating the Growth of Rural Innovation and Tourism Opportunities to Uphold Rural Industries and Sustainable Marketplaces Act or the AGRITOURISM Act</strong></p><p>This bill directs the Department of Agriculture to designate an&nbsp;Agritourism Advisor within the&nbsp;Office of the Under Secretary for Rural Development. The advisor must encourage and promote&nbsp;agritourism activities and businesses in each state and on land under the jurisdiction of Indian tribes.</p><p>Under the bill, agritourism&nbsp;activities and agritourism businesses include educational experiences,&nbsp;outdoor recreation,&nbsp;entertainment and special events,&nbsp;direct sales, and accommodations.</p>",
      "updateDate": "2026-04-08T14:00:03Z",
      "versionCode": "00"
    }
  ]
