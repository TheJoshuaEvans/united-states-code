  "summaries": [
    {
      "actionDate": "2025-02-05",
      "actionDesc": "Introduced in Senate",
      "text": "<p><strong>Retirement Fairness for Charities and Educational Institutions Act of 2025</strong><em></em></p><p>This bill allows 403(b) retirement plans (i.e., retirement plans designed for certain employees of public schools, charities, and churches) to invest in collective investment trusts, which are a group of pooled investment assets held by a bank or trust company, and in insurance company separate accounts.</p>",
      "updateDate": "2025-08-19T15:08:50Z",
      "versionCode": "00"
    }
  ]
