{"tag":"section","attrib":{"id":"id9c4a93c7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378"},"text":null,"children":[{"tag":"num","attrib":{"value":"1378"},"text":"§ 1378.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of data on other detained aliens","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c4a93c8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall regularly collect data on a nationwide basis on aliens being detained in the United States by the Immigration and Naturalization Service other than the aliens described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1377"},"text":"section 1377 of this title","children":[],"tail":", including the following information:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c4a93c9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of detainees who are criminal aliens and the number of detainees who are noncriminal aliens who are not seeking asylum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4a93ca-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An identification of the ages, gender, and countries of origin of detainees within each category described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4a93cb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The types of facilities, whether facilities of the Immigration and Naturalization Service or other Federal, State, or local facilities, in which each of the categories of detainees described in paragraph (1) are held.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c4a93cc-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Length of detention, transfers, and dispositions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to detainees who are criminal aliens and detainees who are noncriminal aliens who are not seeking asylum, the Attorney General shall also collect data concerning—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c4a93cd-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and frequency of transfers between detention facilities for each category of detainee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4a93ce-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average length of detention of each category of detainee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4a93cf-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each category of detainee, the number of detainees who have been detained for the same length of time, in 3-month increments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4a93d0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each category of detainee, the rate of release from detention for each district of the Immigration and Naturalization Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4a93d1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each category of detainee, the disposition of detention, including whether detention ended due to deportation, release on parole, or any other release.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c4a93d2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal aliens","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to criminal aliens, the Attorney General shall also collect data concerning—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c4a93d3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of criminal aliens apprehended under the immigration laws and not detained by the Attorney General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4a93d4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of crimes committed by criminal aliens after the decision was made not to detain them, to the extent this information can be derived by cross-checking the list of criminal aliens not detained with other databases accessible to the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c4a93d5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":", and not later than October 1 of each year thereafter, the Attorney General shall submit to the Committee on the Judiciary of each House of Congress a report setting forth the data collected under subsections (a), (b), and (c) for the fiscal year ending September 30 of that year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c4a93d6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Copies of the data collected under subsections (a), (b), and (c) shall be made available to members of the public upon request pursuant to such regulations as the Attorney General shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c4a93d7-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/h/tIX/s904"},"text":"Pub. L. 105–277, div. A, § 101(h) [title IX, § 904]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-480"},"text":"112 Stat. 2681–480","children":[],"tail":", 2681–542.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c4a93d8-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c4a93d9-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c4a93da-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Haitian Refugee Immigration Fairness Act of 1998, and also as part of the Treasury and General Government Appropriations Act, 1999, and the Omnibus Consolidated and Emergency Supplemental Appropriations Act, 1999, and not as part of the Immigration and Nationality Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c4a93db-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c4a93dc-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
