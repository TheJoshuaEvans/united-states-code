{"tag":"section","attrib":{"id":"id9c2e0b72-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1287"},"text":null,"children":[{"tag":"num","attrib":{"value":"1287"},"text":"§ 1287.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alien crewmen brought into the United States with intent to evade immigration laws; penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person, including the owner, agent, consignee, master, or commanding officer of any vessel or aircraft arriving in the United States from any place outside thereof, who shall knowingly sign on the vessel’s articles, or bring to the United States as one of the crew of such vessel or aircraft, any alien, with intent to permit or assist such alien to enter or land in the United States in violation of law, or who shall falsely and knowingly represent to a consular officer at the time of application for visa, or to the immigration officer at the port of arrival in the United States, that such alien is a bona fide member of the crew employed in any capacity regularly required for normal operation and services aboard such vessel or aircraft, shall be liable to a penalty not exceeding $10,000 for each such violation, for which sum such vessel or aircraft shall be liable and may be seized and proceeded against by way of libel in any district court of the United States having jurisdiction of the offense.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9c2e0b73-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title II, ch. 6, § 257, "},{"tag":"ref","attrib":{"href":"/us/stat/66/223"},"text":"66 Stat. 223","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/tV/s543/a/7"},"text":"Pub. L. 101–649, title V, § 543(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5058"},"text":"104 Stat. 5058","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c2e0b74-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c2e0b75-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c2e0b76-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649"},"text":"Pub. L. 101–649","children":[],"tail":" substituted “$10,000” for “$5,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c2e0b77-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c2e0b78-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649"},"text":"Pub. L. 101–649","children":[],"tail":" applicable to actions taken after "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/s543/c"},"text":"section 543(c) of Pub. L. 101–649","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1221"},"text":"section 1221 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c2e0b79-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
