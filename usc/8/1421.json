{"tag":"section","attrib":{"id":"id9c4d059d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421"},"text":null,"children":[{"tag":"num","attrib":{"value":"1421"},"text":"§ 1421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Naturalization authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c4d059e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority in Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sole authority to naturalize persons as citizens of the United States is conferred upon the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c4d059f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court authority to administer oaths","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c4d05a0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1448/c"},"text":"section 1448(c) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c4d05a1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), each applicant for naturalization may choose to have the oath of allegiance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1448/a"},"text":"section 1448(a) of this title","children":[],"tail":" administered by the Attorney General or by an eligible court described in paragraph (5). Each such eligible court shall have authority to administer such oath of allegiance to persons residing within the jurisdiction of the court."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4d05a2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible court described in paragraph (5) that wishes to have exclusive authority to administer the oath of allegiance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1448/a"},"text":"section 1448(a) of this title","children":[],"tail":" to persons residing within the jurisdiction of the court during the period described in paragraph (3)(A)(i) shall notify the Attorney General of such wish and, subject to this subsection, shall have such exclusive authority with respect to such persons during such period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4d05a3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c4d05a4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a court exercising authority under paragraph (1), in accordance with procedures established by the Attorney General—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c4d05a5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant for naturalization shall notify the Attorney General of the intent to be naturalized before the court, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c4d05a6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Attorney General—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id9c4d05a7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall forward to the court (not later than 10 days after the date of approval of an application for naturalization in the case of a court which has provided notice under paragraph (1)(B)) such information as may be necessary to administer the oath of allegiance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1448/a"},"text":"section 1448(a) of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id9c4d05a8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall promptly forward to the court a certificate of naturalization (prepared by the Attorney General).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4d05a9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment of individuals in the case of exclusive authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an eligible court has provided notice under paragraph (1)(B), the Attorney General shall inform each person (residing within the jurisdiction of the court), at the time of the approval of the person’s application for naturalization, of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c4d05aa-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the court’s exclusive authority to administer the oath of allegiance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1448/a"},"text":"section 1448(a) of this title","children":[],"tail":" to such a person during the period specified in paragraph (3)(A)(i), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c4d05ab-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date or dates (if any) under paragraph (3)(B) on which the court has scheduled oath administration ceremonies.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If more than one eligible court in an area has provided notice under paragraph (1)(B), the Attorney General shall permit the person, at the time of the approval, to choose the court to which the information will be forwarded for administration of the oath of allegiance under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4d05ac-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of exclusive authority","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c4d05ad-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited period and advance notice required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The exclusive authority of a court to administer the oath of allegiance under paragraph (1)(B) shall apply with respect to a person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c4d05ae-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only during the 45-day period beginning on the date on which the Attorney General certifies to the court that an applicant is eligible for naturalization, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c4d05af-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only if the court has notified the Attorney General, prior to the date of certification of eligibility, of the day or days (during such 45-day period) on which the court has scheduled oath administration ceremonies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4d05b0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (C), the Attorney General shall not administer the oath of allegiance to a person under subsection (a) during the period in which exclusive authority to administer the oath of allegiance may be exercised by an eligible court under this subsection with respect to that person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4d05b1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of exclusive authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the previous provisions of this paragraph, a court may waive exclusive authority to administer the oath of allegiance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1448/a"},"text":"section 1448(a) of this title","children":[],"tail":" to a person under this subsection if the Attorney General has not provided the court with the certification described in subparagraph (A)(i) within a reasonable time before the date scheduled by the court for oath administration ceremonies. Upon notification of a court’s waiver of jurisdiction, the Attorney General shall promptly notify the applicant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4d05b2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of certificates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall provide for the issuance of certificates of naturalization at the time of administration of the oath of allegiance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4d05b3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible courts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “eligible court” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c4d05b4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a district court of the United States in any State, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4d05b5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any court of record in any State having a seal, a clerk, and jurisdiction in actions in law or equity, or law and equity, in which the amount in controversy is unlimited.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c4d05b6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person whose application for naturalization under this subchapter is denied, after a hearing before an immigration officer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1447/a"},"text":"section 1447(a) of this title","children":[],"tail":", may seek review of such denial before the United States district court for the district in which such person resides in accordance with chapter 7 of title 5. Such review shall be de novo, and the court shall make its own findings of fact and conclusions of law and shall, at the request of the petitioner, conduct a hearing de novo on the application."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c4d05b7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1421/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sole procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person may only be naturalized as a citizen of the United States in the manner and under the conditions prescribed in this subchapter and not otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c4d05b8-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title III, ch. 2, § 310, "},{"tag":"ref","attrib":{"href":"/us/stat/66/239"},"text":"66 Stat. 239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/508/s25"},"text":"Pub. L. 85–508, § 25","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-07"},"text":"July 7, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/351"},"text":"72 Stat. 351","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/3/s20/c"},"text":"Pub. L. 86–3, § 20(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-03-18"},"text":"Mar. 18, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/13"},"text":"73 Stat. 13","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/301/s17"},"text":"Pub. L. 87–301, § 17","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-26"},"text":"Sept. 26, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/656"},"text":"75 Stat. 656","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/525/s9/s"},"text":"Pub. L. 100–525, § 9(s)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2621"},"text":"102 Stat. 2621","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/tIV/s401/a"},"text":"Pub. L. 101–649, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5038"},"text":"104 Stat. 5038","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/232/tI/s102/a"},"text":"Pub. L. 102–232, title I, § 102(a)","children":[],"tail":", title III, § 305(a), "},{"tag":"date","attrib":{"date":"1991-12-12"},"text":"Dec. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1734"},"text":"105 Stat. 1734","children":[],"tail":", 1749; "},{"tag":"ref","attrib":{"href":"/us/pl/103/416/tII/s219/u"},"text":"Pub. L. 103–416, title II, § 219(u)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4318"},"text":"108 Stat. 4318","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c4d05b9-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c4d05ba-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c4d05bb-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/416"},"text":"Pub. L. 103–416","children":[],"tail":" substituted “district court” for “District Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/232/s102/a"},"text":"Pub. L. 102–232, § 102(a)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “An applicant for naturalization may choose to have the oath of allegiance under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1448/a"},"text":"section 1448(a) of this title","children":[],"tail":" administered by the Attorney General or by any district court of the United States for any State or by any court of record in any State having a seal, a clerk, and jurisdiction in actions in law or equity, or law and equity, in which the amount in controversy is unlimited. The jurisdiction of all courts in this subsection specified to administer the oath of allegiance shall extend only to persons resident within the respective jurisdiction of such courts.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/232/s305/a"},"text":"Pub. L. 102–232, § 305(a)","children":[],"tail":", substituted “district court” for “District Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649"},"text":"Pub. L. 101–649","children":[],"tail":" amended section generally, substituting provisions authorizing Attorney General to naturalize persons as citizens, for provisions granting certain courts exclusive jurisdiction to naturalize."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/525"},"text":"Pub. L. 100–525","children":[],"tail":" struck out subsec. (e) which read as follows: “Notwithstanding the provisions of section 405(a), any petition for naturalization filed on or after "},{"tag":"date","attrib":{"date":"1961-09-26"},"text":"September 26, 1961","children":[],"tail":", shall be heard and determined in accordance with the requirements of this subchapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1961—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/301"},"text":"Pub. L. 87–301","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/3"},"text":"Pub. L. 86–3","children":[],"tail":" struck out provisions which conferred jurisdiction on District Court for Territory of Hawaii. See "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s91"},"text":"section 91 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, and notes thereunder."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/508"},"text":"Pub. L. 85–508","children":[],"tail":" struck out provisions which conferred jurisdiction on District Court for Territory of Alaska. See "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s81A"},"text":"section 81A of Title 28","children":[],"tail":", which established a United States District Court for the State of Alaska."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c4d05bc-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c4d05bd-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/416"},"text":"Pub. L. 103–416","children":[],"tail":" effective as if included in the enactment of the Immigration Act of 1990, "},{"tag":"ref","attrib":{"href":"/us/pl/101/649"},"text":"Pub. L. 101–649","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/416/s219/dd"},"text":"section 219(dd) of Pub. L. 103–416","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c4d05be-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/232/tI/s102/c"},"text":"Pub. L. 102–232, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-12"},"text":"Dec. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1736"},"text":"105 Stat. 1736","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/232/tI/s102/c"},"text":"“The amendments made by this title [amending this section and sections 1448, 1450, and 1455 of this title] shall take effect 30 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1991-12-12"},"text":"Dec. 12, 1991","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/232/s305/a"},"text":"section 305(a) of Pub. L. 102–232","children":[],"tail":" effective as if included in the enactment of the Immigration Act of 1990, "},{"tag":"ref","attrib":{"href":"/us/pl/101/649"},"text":"Pub. L. 101–649","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/232/s310/1"},"text":"section 310(1) of Pub. L. 102–232","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c4d05bf-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment; Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649/tIV/s408"},"text":"Pub. L. 101–649, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5047"},"text":"104 Stat. 5047","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/232/tIII/s305/n"},"text":"Pub. L. 102–232, title III, § 305(n)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-12"},"text":"Dec. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1750"},"text":"105 Stat. 1750","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/232/tIII/s305/n"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No new court petitions after effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No court shall have jurisdiction, under section 310(a) of the Immigration and Nationality Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1421/a"},"text":"8 U.S.C. 1421(a)","children":[],"tail":"], to naturalize a person unless a petition for naturalization with respect to that person has been filed with the court before "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of current court petitions.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuation of current rules","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (B), any petition for naturalization which may be pending in a court on ","children":[{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":", shall be heard and determined in accordance with the requirements of law in effect when the petition was filed."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Permitting withdrawal and consideration of application under new rules","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of any petition for naturalization which may be pending in any court on ","children":[{"tag":"date","attrib":{"date":"1992-01-01"},"text":"January 1, 1992","children":[],"tail":", the petitioner may withdraw such petition and have the petitioner’s application for naturalization considered under the amendments made by this title [amending this section, sections 1101, 1423, 1424, 1426 to 1430, 1433, 1435 to 1440, 1441 to 1451, and 1455 of this title, and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1429"},"text":"section 1429 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1459"},"text":"section 1459 of this title","children":[],"tail":"], but only if the petition is withdrawn not later than 3 months after the effective date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this section, the amendments made by this title are effective as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interim, Final Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General shall prescribe regulations (on an interim, final basis or otherwise) to implement the amendments made by this title on a timely basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuing Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments to section 339 of the Immigration and Nationality Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1450"},"text":"8 U.S.C. 1450","children":[],"tail":"] (relating to functions and duties of clerks) shall not apply to functions and duties respecting petitions filed before "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Savings Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing contained in this title [amending this section, sections 1101, 1423, 1424, 1426 to 1430, 1433, 1435 to 1440, 1441 to 1451, and 1455 of this title, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1429"},"text":"section 1429 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1459"},"text":"section 1459 of this title","children":[],"tail":", and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1440"},"text":"section 1440 of this title","children":[],"tail":"], unless otherwise specifically provided, shall be construed to affect the validity of any declaration of intention, petition for naturalization, certificate of naturalization, certification of citizenship, or other document or proceeding which is valid as of the effective date; or to affect any prosecution, suit, action, or proceedings, civil or criminal, brought, or any status, condition, right in process of acquisition, act, thing, liability, obligation, or matter, civil or criminal, done or existing, as of the effective date."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As to all such prosecutions, suits, actions, proceedings, statutes, conditions, rights, acts, things, liabilities, obligations, or matters, the provisions of law repealed by this title are, unless otherwise specifically provided, hereby continued in force and effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Service in Armed Forces of Foreign Country","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by section 404 [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1426"},"text":"section 1426 of this title","children":[],"tail":"] (relating to treatment of service in armed forces of a foreign country) shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":"] and shall apply to exemptions from training or service obtained before, on, or after such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filipino War Veterans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 405 [enacting provisions formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1440"},"text":"section 1440 of this title","children":[],"tail":"] (relating to naturalization of natives of the Philippines through active-duty service under United States command during World War II) shall become effective on "},{"tag":"date","attrib":{"date":"1991-05-01"},"text":"May 1, 1991","children":[],"tail":", without regard to whether regulations to implement such section have been issued by such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c4d05c0-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id9c4d05c1-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c4d05c2-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Admission of Alaska and Hawaii to Statehood","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Alaska was admitted into the Union on ","children":[{"tag":"date","attrib":{"date":"1959-01-03"},"text":"Jan. 3, 1959","children":[],"tail":", on issuance of Proc. No. 3269, "},{"tag":"date","attrib":{"date":"1959-01-03"},"text":"Jan. 3, 1959","children":[],"tail":", 24 F.R. 81, 73 Stat. c16, and Hawaii was admitted into the Union on "},{"tag":"date","attrib":{"date":"1959-08-21"},"text":"Aug. 21, 1959","children":[],"tail":", on issuance of Proc. No. 3309, "},{"tag":"date","attrib":{"date":"1959-08-21"},"text":"Aug. 21, 1959","children":[],"tail":", 24 F.R. 6868, 73 Stat. c74. For Alaska Statehood Law, see "},{"tag":"ref","attrib":{"href":"/us/pl/85/508"},"text":"Pub. L. 85–508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-07"},"text":"July 7, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/339"},"text":"72 Stat. 339","children":[],"tail":", set out as a note preceding former "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s21"},"text":"section 21 of Title 48","children":[],"tail":", Territories and Insular Possessions. For Hawaii Statehood Law, see "},{"tag":"ref","attrib":{"href":"/us/pl/86/3"},"text":"Pub. L. 86–3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-03-18"},"text":"Mar. 18, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/4"},"text":"73 Stat. 4","children":[],"tail":", set out as a note preceding former "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s491"},"text":"section 491 of Title 48","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
