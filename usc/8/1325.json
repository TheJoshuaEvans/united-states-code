{"tag":"section","attrib":{"id":"id9c39f292-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1325"},"text":null,"children":[{"tag":"num","attrib":{"value":"1325"},"text":"§ 1325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improper entry by alien","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c39f293-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1325/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improper time or place; avoidance of examination or inspection; misrepresentation and concealment of facts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any alien who (1) enters or attempts to enter the United States at any time or place other than as designated by immigration officers, or (2) eludes examination or inspection by immigration officers, or (3) attempts to enter or obtains entry to the United States by a willfully false or misleading representation or the willful concealment of a material fact, shall, for the first commission of any such offense, be fined under title 18 or imprisoned not more than 6 months, or both, and, for a subsequent commission of any such offense, be fined under title 18, or imprisoned not more than 2 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c39f294-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1325/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improper time or place; civil penalties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any alien who is apprehended while entering (or attempting to enter) the United States at a time or place other than as designated by immigration officers shall be subject to a civil penalty of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c39f295-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1325/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least $50 and not more than $250 for each such entry (or attempted entry); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c39f296-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1325/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" twice the amount specified in paragraph (1) in the case of an alien who has been previously subject to a civil penalty under this subsection.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Civil penalties under this subsection are in addition to, and not in lieu of, any criminal or other civil penalties that may be imposed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c39f297-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1325/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marriage fraud","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual who knowingly enters into a marriage for the purpose of evading any provision of the immigration laws shall be imprisoned for not more than 5 years, or fined not more than $250,000, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c39f298-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1325/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immigration-related entrepreneurship fraud","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual who knowingly establishes a commercial enterprise for the purpose of evading any provision of the immigration laws shall be imprisoned for not more than 5 years, fined in accordance with title 18, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c39f299-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title II, ch. 8, § 275, "},{"tag":"ref","attrib":{"href":"/us/stat/66/229"},"text":"66 Stat. 229","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/639/s2/d"},"text":"Pub. L. 99–639, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3542"},"text":"100 Stat. 3542","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/tI/s121/b/3"},"text":"Pub. L. 101–649, title I, § 121(b)(3)","children":[],"tail":", title V, § 543(b)(2), "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4994"},"text":"104 Stat. 4994","children":[],"tail":", 5059; "},{"tag":"ref","attrib":{"href":"/us/pl/102/232/tIII/s306/c/3"},"text":"Pub. L. 102–232, title III, § 306(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-12"},"text":"Dec. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1752"},"text":"105 Stat. 1752","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tI/s105/a"},"text":"Pub. L. 104–208, div. C, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-556"},"text":"110 Stat. 3009–556","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c39f29a-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c39f29b-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c39f29c-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" added subsec. (b) and redesignated former subsecs. (b) and (c) as (c) and (d), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/232"},"text":"Pub. L. 102–232","children":[],"tail":" substituted “fined under title 18” for “fined not more than $2,000 (or, if greater, the amount provided under title 18)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649/s543/b/2"},"text":"Pub. L. 101–649, § 543(b)(2)","children":[],"tail":", inserted “or attempts to enter” after “(1) enters” and “attempts to enter or” after “or (3)”, and substituted “shall, for the first commission of any such offense, be fined not more than $2,000 (or, if greater, the amount provided under title 18) or imprisoned not more than 6 months, or both, and, for a subsequent commission of any such offense, be fined under title 18, or imprisoned not more than 2 years” for “shall, for the first commission of any such offenses, be guilty of a misdemeanor and upon conviction thereof be punished by imprisonment for not more than six months, or by a fine of not more than $500, or by both, and for a subsequent commission of any such offenses shall be guilty of a felony and upon conviction thereof shall be punished by imprisonment for not more than two years, or by a fine of not more than $1,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649/s121/b/3"},"text":"Pub. L. 101–649, § 121(b)(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/639"},"text":"Pub. L. 99–639","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c39f29d-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c39f29e-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tI/s105/b"},"text":"Pub. L. 104–208, div. C, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-556"},"text":"110 Stat. 3009–556","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/208/dC/tI/s105/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply to illegal entries or attempts to enter occurring on or after the first day of the sixth month beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c39f29f-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/232"},"text":"Pub. L. 102–232","children":[],"tail":" effective as if included in the enactment of the Immigration Act of 1990, "},{"tag":"ref","attrib":{"href":"/us/pl/101/649"},"text":"Pub. L. 101–649","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/232/s310/1"},"text":"section 310(1) of Pub. L. 102–232","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c39f2a0-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649/s121/b/3"},"text":"section 121(b)(3) of Pub. L. 101–649","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"Oct. 1, 1991","children":[],"tail":", and applicable beginning with fiscal year 1992, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/s161/a"},"text":"section 161(a) of Pub. L. 101–649","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649/s543/b/2"},"text":"section 543(b)(2) of Pub. L. 101–649","children":[],"tail":" applicable to actions taken after "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/s543/c"},"text":"section 543(c) of Pub. L. 101–649","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1221"},"text":"section 1221 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c39f2a1-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
