{"tag":"section","attrib":{"id":"id9c6e7022-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1646"},"text":null,"children":[{"tag":"num","attrib":{"value":"1646"},"text":"§ 1646.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Derivative eligibility for benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, an alien who under the provisions of this chapter is ineligible for benefits under the food stamp program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1612/a/3/B"},"text":"section 1612(a)(3)(B) of this title","children":[],"tail":") shall not be eligible for such benefits because the alien receives benefits under the supplemental security income program (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1612/a/3/A"},"text":"section 1612(a)(3)(A) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9c6e7023-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIV/s436"},"text":"Pub. L. 104–193, title IV, § 436","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV/s5305/a"},"text":"Pub. L. 105–33, title V, § 5305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/601"},"text":"111 Stat. 601","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c6e7024-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c6e7025-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","