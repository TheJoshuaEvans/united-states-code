{"tag":"section","attrib":{"id":"id9c69b54d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1614"},"text":null,"children":[{"tag":"num","attrib":{"value":"1614"},"text":"§ 1614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification and information reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each Federal agency that administers a program to which section 1611, 1612, or 1613 of this title applies shall, directly or through the States, post information and provide general notification to the public and to program recipients of the changes regarding eligibility for any such program pursuant to this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9c69b54e-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIV/s404/a"},"text":"Pub. L. 104–193, title IV, § 404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2267"},"text":"110 Stat. 2267","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c69b54f-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c69b550-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c69b551-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this subtitle”, meaning subtitle A of title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2261"},"text":"110 Stat. 2261","children":[],"tail":", which enacted this subchapter and sections 611a and 1437y of Title 42, The Public Health and Welfare, and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1383"},"text":"section 1383 of Title 42","children":[],"tail":". For complete classification of this subtitle to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
