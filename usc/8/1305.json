{"tag":"section","attrib":{"id":"id9c2e0c06-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1305"},"text":null,"children":[{"tag":"num","attrib":{"value":"1305"},"text":"§ 1305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notices of change of address","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c2e0c07-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of change","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each alien required to be registered under this subchapter who is within the United States shall notify the Attorney General in writing of each change of address and new address within ten days from the date of such change and furnish with such notice such additional information as the Attorney General may require by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c2e0c08-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current address of natives of any one or more foreign states","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may in his discretion, upon ten days notice, require the natives of any one or more foreign states, or any class or group thereof, who are within the United States and who are required to be registered under this subchapter, to notify the Attorney General of their current addresses and furnish such additional information as the Attorney General may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c2e0c09-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to parent or legal guardian","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an alien for whom a parent or legal guardian is required to apply for registration, the notice required by this section shall be given to such parent or legal guardian.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c2e0c0a-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title II, ch. 7, § 265, "},{"tag":"ref","attrib":{"href":"/us/stat/66/225"},"text":"66 Stat. 225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/116/s11"},"text":"Pub. L. 97–116, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1617"},"text":"95 Stat. 1617","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/525/s9"},"text":"Pub. L. 100–525, § 9","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2620"},"text":"102 Stat. 2620","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c307c0b-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c307c0c-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c307c0d-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/525"},"text":"Pub. L. 100–525","children":[],"tail":" inserted “Notices of change of address” as section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/116"},"text":"Pub. L. 97–116","children":[],"tail":" amended section generally and in adding subsection designations struck out the annual registration requirement for permanent resident aliens and the registration requirement for those aliens in a lawful temporary residence who were to notify the Attorney General in writing of an address every three months while residing in the United States and inserted provision authorizing the Attorney General, in his discretion and upon ten days notice, to require the natives of any one or more foreign states who are in the United States and required to be registered under this subchapter, to notify the Attorney General of their current addresses and furnish such additional information as required."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c307c0e-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c307c0f-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/116"},"text":"Pub. L. 97–116","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/116/s21/a"},"text":"section 21(a) of Pub. L. 97–116","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c307c10-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
