{"tag":"section","attrib":{"id":"id9c6bfeba-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1632"},"text":null,"children":[{"tag":"num","attrib":{"value":"1632"},"text":"§ 1632.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for States to provide for attribution of sponsors income and resources to the alien with respect to State programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c6bfebb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1632/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Optional application to State programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), in determining the eligibility and the amount of benefits of an alien for any State public benefits, the State or political subdivision that offers the benefits is authorized to provide that the income and resources of the alien shall be deemed to include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c6bfebc-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1632/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the income and resources of any individual who executed an affidavit of support pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1183a"},"text":"section 1183a of this title","children":[],"tail":" (as added by section 423 and as amended by section 551(a) of the Illegal Immigration Reform and Immigrant Responsibility Act of 1996) on behalf of such alien, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bfebd-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1632/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the income and resources of the spouse (if any) of the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c6bfebe-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1632/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply with respect to the following State public benefits:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c6bfebf-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1632/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistance described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1621/b/1"},"text":"section 1621(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bfec0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1632/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Short-term, non-cash, in-kind emergency disaster relief.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bfec1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1632/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programs comparable to assistance or benefits under the Richard B. Russell National School Lunch Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bfec2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1632/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programs comparable to assistance or benefits under the Child Nutrition Act of 1966 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"42 U.S.C. 1771","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bfec3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1632/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public health assistance for immunizations with respect to immunizable diseases and for testing and treatment of symptoms of communicable diseases whether or not such symptoms are caused by a communicable disease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bfec4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1632/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments for foster care and adoption assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bfec5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1632/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programs, services, or assistance (such as soup kitchens, crisis counseling and intervention, and short-term shelter) specified by the Attorney General of a State, after consultation with appropriate agencies and departments, which (A) deliver in-kind services at the community level, including through public or private nonprofit agencies; (B) do not condition the provision of assistance, the amount of assistance provided, or the cost of assistance provided on the individual recipient’s income or resources; and (C) are necessary for the protection of life or safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c6bfec6-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIV/s422"},"text":"Pub. L. 104–193, title IV, § 422","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2271"},"text":"110 Stat. 2271","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tV/s551/b/1"},"text":"Pub. L. 104–208, div. C, title V, § 551(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-679"},"text":"110 Stat. 3009–679","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV/s5581/b/2"},"text":"Pub. L. 105–33, title V, § 5581(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/643"},"text":"111 Stat. 643","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tVII/s752/b/6"},"text":"Pub. L. 106–78, title VII, § 752(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1169"},"text":"113 Stat. 1169","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c6bfec7-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c6bfec8-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c6bfec9-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1183a"},"text":"Section 1183a of this title","children":[],"tail":" (as added by section 423 and as amended by section 551(a) of the Illegal Immigration Reform and Immigrant Responsibility Act of 1996), referred to in subsec. (a)(1), is "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1183a"},"text":"section 1183a of this title","children":[],"tail":" as added by "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/s423"},"text":"section 423 of Pub. L. 104–193","children":[],"tail":" and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/s551/a"},"text":"section 551(a) of div. C of Pub. L. 104–208","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Richard B. Russell National School Lunch Act, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281"},"text":"act June 4, 1946, ch. 281","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/230"},"text":"60 Stat. 230","children":[],"tail":", which is classified generally to chapter 13 (§ 1751 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Child Nutrition Act of 1966, referred to in subsec. (b)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642"},"text":"Pub. L. 89–642","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-11"},"text":"Oct. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/885"},"text":"80 Stat. 885","children":[],"tail":", which is classified generally to chapter 13A (§ 1771 et seq.) of Title 42. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"section 1771 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c6bfeca-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/78"},"text":"Pub. L. 106–78","children":[],"tail":" substituted “Richard B. Russell National School Lunch Act” for “National School Lunch Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" struck out “(as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1622/c"},"text":"section 1622(c) of this title","children":[],"tail":")” after “public benefits” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" inserted “and as amended by section 551(a) of the Illegal Immigration Reform and Immigrant Responsibility Act of 1996” after “section 423”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c6bfecb-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c6bfecc-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"