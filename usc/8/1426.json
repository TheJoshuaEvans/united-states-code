{"tag":"section","attrib":{"id":"id9c4f75f8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1426"},"text":null,"children":[{"tag":"num","attrib":{"value":"1426"},"text":"§ 1426.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citizenship denied alien relieved of service in Armed Forces because of alienage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c4f75f9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1426/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permanent ineligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of section 405(b) ","children":[{"tag":"ref","attrib":{"idref":"fn002094"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002094"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" but subject to subsection (c), any alien who applies or has applied for exemption or discharge from training or service in the Armed Forces or in the National Security Training Corps of the United States on the ground that he is an alien, and is or was relieved or discharged from such training or service on such ground, shall be permanently ineligible to become a citizen of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c4f75fa-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1426/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conclusiveness of records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The records of the Selective Service System or of the Department of Defense shall be conclusive as to whether an alien was relieved or discharged from such liability for training or service because he was an alien.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c4f75fb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1426/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service in armed forces of foreign country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An alien shall not be ineligible for citizenship under this section or otherwise because of an exemption from training or service in the Armed Forces of the United States pursuant to the exercise of rights under a treaty, if before the time of the exercise of such rights the alien served in the Armed Forces of a foreign country of which the alien was a national.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c4f75fc-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title III, ch. 2, § 315, "},{"tag":"ref","attrib":{"href":"/us/stat/66/242"},"text":"66 Stat. 242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/525/s9/v"},"text":"Pub. L. 100–525, § 9(v)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2621"},"text":"102 Stat. 2621","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/tIV/s404"},"text":"Pub. L. 101–649, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5039"},"text":"104 Stat. 5039","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c4f75fd-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c4f75fe-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c4f75ff-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 405(b), referred to in subsec. (a), is section 405(b) of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477/tIV"},"text":"act June 27, 1952, ch. 477, title IV","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/280"},"text":"66 Stat. 280","children":[],"tail":", which is set out as a Savings Clause note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c4f7600-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649/s404/1"},"text":"Pub. L. 101–649, § 404(1)","children":[],"tail":", inserted “but subject to subsection (c)” after “section 405(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649/s404/2"},"text":"Pub. L. 101–649, § 404(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/525"},"text":"Pub. L. 100–525","children":[],"tail":" substituted “Department of Defense” for “National Military Establishment”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c4f7601-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c4f7602-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649"},"text":"Pub. L. 101–649","children":[],"tail":" applicable to exemptions from training or service obtained before, on, or after "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/s408/e"},"text":"section 408(e) of Pub. L. 101–649","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1421"},"text":"section 1421 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
