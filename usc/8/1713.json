{"tag":"section","attrib":{"id":"id9c6e707c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1713"},"text":null,"children":[{"tag":"num","attrib":{"value":"1713"},"text":"§ 1713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Machine-readable visa fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c6e707d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c6e707e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fee amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The machine-readable visa fee charged by the Department of State shall be the higher of $65 or the cost of the machine-readable visa service, as determined by the Secretary of State after conducting a study of the cost of such service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c6e707f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1713/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surcharge","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department of State is authorized to charge a surcharge of $10, in addition to the machine-readable visa fee, for issuing a machine-readable visa in a nonmachine-readable passport.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c6e7080-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1713/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of collected fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, amounts collected as fees described in this section shall be deposited in the Consular and Border Security Programs account to recover costs of providing consular services. Amounts so credited shall be available, until expended, for the same purposes as the appropriation to which credited.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c6e7081-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/173/tI/s103"},"text":"Pub. L. 107–173, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/547"},"text":"116 Stat. 547","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/31/dJ/tVII/s7081/b"},"text":"Pub. L. 115–31, div. J, title VII, § 7081(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/716"},"text":"131 Stat. 716","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c6e7082-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c6e7083-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c6e7084-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/173/s103"},"text":"section 103 of Pub. L. 107–173","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/107/173/s103"},"text":"section 103 of Pub. L. 107–173","children":[],"tail":" amended provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1351"},"text":"section 1351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c6e7085-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31"},"text":"Pub. L. 115–31","children":[],"tail":" substituted “deposited in the Consular and Border Security Programs account” for “credited as an offsetting collection to any appropriation for the Department of State”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
