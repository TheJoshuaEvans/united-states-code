{"tag":"section","attrib":{"id":"id9c163db8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229"},"text":null,"children":[{"tag":"num","attrib":{"value":"1229"},"text":"§ 1229.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiation of removal proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c163db9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to appear","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c163dba-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In removal proceedings under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1229a"},"text":"section 1229a of this title","children":[],"tail":", written notice (in this section referred to as a “notice to appear”) shall be given in person to the alien (or, if personal service is not practicable, through service by mail to the alien or to the alien’s counsel of record, if any) specifying the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c163dbb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The nature of the proceedings against the alien.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c163dbc-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The legal authority under which the proceedings are conducted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c163dbd-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The acts or conduct alleged to be in violation of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c163dbe-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The charges against the alien and the statutory provisions alleged to have been violated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c163dbf-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The alien may be represented by counsel and the alien will be provided (i) a period of time to secure counsel under subsection (b)(1) and (ii) a current list of counsel prepared under subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c163dc0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c163dc1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirement that the alien must immediately provide (or have provided) the Attorney General with a written record of an address and telephone number (if any) at which the alien may be contacted respecting proceedings under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1229a"},"text":"section 1229a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c163dc2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirement that the alien must provide the Attorney General immediately with a written record of any change of the alien’s address or telephone number.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c163dc3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a/1/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The consequences under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1229a/b/5"},"text":"section 1229a(b)(5) of this title","children":[],"tail":" of failure to provide address and telephone information pursuant to this subparagraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c163dc4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c163dc5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a/1/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The time and place at which the proceedings will be held.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c163dc6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a/1/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The consequences under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1229a/b/5"},"text":"section 1229a(b)(5) of this title","children":[],"tail":" of the failure, except under exceptional circumstances, to appear at such proceedings."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c163dc7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of change in time or place of proceedings","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c163dc8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In removal proceedings under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1229a"},"text":"section 1229a of this title","children":[],"tail":", in the case of any change or postponement in the time and place of such proceedings, subject to subparagraph (B) a written notice shall be given in person to the alien (or, if personal service is not practicable, through service by mail to the alien or to the alien’s counsel of record, if any) specifying—"}],"tail":null},{"tag":"clause","attrib":{"id":"id9c163dc9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the new time or place of the proceedings, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c163dca-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consequences under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1229a/b/5"},"text":"section 1229a(b)(5) of this title","children":[],"tail":" of failing, except under exceptional circumstances, to attend such proceedings."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c163dcb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an alien not in detention, a written notice shall not be required under this paragraph if the alien has failed to provide the address required under paragraph (1)(F).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c163dcc-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Central address files","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall create a system to record and preserve on a timely basis notices of addresses and telephone numbers (and changes) provided under paragraph (1)(F).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c163dcd-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securing of counsel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c163dce-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order that an alien be permitted the opportunity to secure counsel before the first hearing date in proceedings under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1229a"},"text":"section 1229a of this title","children":[],"tail":", the hearing date shall not be scheduled earlier than 10 days after the service of the notice to appear, unless the alien requests in writing an earlier hearing date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c163dcf-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current lists of counsel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall provide for lists (updated not less often than quarterly) of persons who have indicated their availability to represent pro bono aliens in proceedings under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1229a"},"text":"section 1229a of this title","children":[],"tail":". Such lists shall be provided under subsection (a)(1)(E) and otherwise made generally available."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c163dd0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection may be construed to prevent the Attorney General from proceeding against an alien pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1229a"},"text":"section 1229a of this title","children":[],"tail":" if the time period described in paragraph (1) has elapsed and the alien has failed to secure counsel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c163dd1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service by mail","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Service by mail under this section shall be sufficient if there is proof of attempted delivery to the last address provided by the alien in accordance with subsection (a)(1)(F).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c163dd2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prompt initiation of removal","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c163dd3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an alien who is convicted of an offense which makes the alien deportable, the Attorney General shall begin any removal proceeding as expeditiously as possible after the date of the conviction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c163dd4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subsection shall be construed to create any substantive or procedural right or benefit that is legally enforceable by any party against the United States or its agencies or officers or any other person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c163dd5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of compliance with restrictions on disclosure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c163dd6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In cases where an enforcement action leading to a removal proceeding was taken against an alien at any of the locations specified in paragraph (2), the Notice to Appear shall include a statement that the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1367"},"text":"section 1367 of this title","children":[],"tail":" have been complied with."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c163dd7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Locations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The locations specified in this paragraph are as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c163dd8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At a domestic violence shelter, a rape crisis center, supervised visitation center, family justice center, a victim services, or victim services provider, or a community-based organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c163dd9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1229/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At a courthouse (or in connection with that appearance of the alien at a courthouse) if the alien is appearing in connection with a protection order case, child custody case, or other civil or criminal case relating to domestic violence, sexual assault, trafficking, or stalking in which the alien has been battered or subject to extreme cruelty or if the alien is described in subparagraph (T) or (U) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/15"},"text":"section 1101(a)(15) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c163dda-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title II, ch. 4, § 239, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII/s304/a/3"},"text":"Pub. L. 104–208, div. C, title III, § 304(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-587"},"text":"110 Stat. 3009–587","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tVIII/s825/c/1"},"text":"Pub. L. 109–162, title VIII, § 825(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3065"},"text":"119 Stat. 3065","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/271/s6/d"},"text":"Pub. L. 109–271, § 6(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/763"},"text":"120 Stat. 763","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c163ddb-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c163ddc-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id9c163ddd-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1229, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477/tII"},"text":"act June 27, 1952, ch. 477, title II","children":[],"tail":", ch. 4, § 239, "},{"tag":"ref","attrib":{"href":"/us/stat/66/203"},"text":"66 Stat. 203","children":[],"tail":", as amended, which related to designation of ports of entry for aliens arriving by aircraft, was renumbered section 234 of act "},{"tag":"date","attrib":{"date":"1952-06-27"},"text":"June 27, 1952","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII/s304/a/1"},"text":"Pub. L. 104–208, div. C, title III, § 304(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-587"},"text":"110 Stat. 3009–587","children":[],"tail":", and was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1224"},"text":"section 1224 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c163dde-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/271"},"text":"Pub. L. 109–271","children":[],"tail":" substituted “(U)” for “(V)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c163ddf-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/tVIII/s825/c/2"},"text":"Pub. L. 109–162, title VIII, § 825(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3065"},"text":"119 Stat. 3065","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/162/tVIII/s825/c/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall take effect on the date that is 30 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":"] and shall apply to apprehensions occurring on or after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c163de0-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id9c163de1-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective, with certain transitional provisions, on the first day of the first month beginning more than 180 days after ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s309"},"text":"section 309 of Pub. L. 104–208","children":[],"tail":", set out as an Effective Date of 1996 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c163de2-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c163de3-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Consideration of Military Service in Removal Determinations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s570B/b"},"text":"Pub. L. 116–92, div. A, title V, § 570B(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1399"},"text":"133 Stat. 1399","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tV/s570B/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With regards to an individual, an immigration officer shall take into consideration evidence of military service by that individual in determining whether—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to issue to that individual a notice to appear in removal proceedings, an administrative order of removal, or a reinstatement of a final removal order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to execute a final order of removal regarding that individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘evidence of service’ means evidence that an individual served as a member of the Armed Forces, and the characterization of each period of service of that individual in the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘immigration officer’ has the meaning given that term in section 101 of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":" et seq.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
