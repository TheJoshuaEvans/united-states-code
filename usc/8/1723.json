{"tag":"section","attrib":{"id":"id9c70b9e1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1723"},"text":null,"children":[{"tag":"num","attrib":{"value":"1723"},"text":"§ 1723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission on Interoperable Data Sharing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c70b9e2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1723/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2001-10-26"},"text":"October 26, 2001","children":[],"tail":", the President shall establish a Commission on Interoperable Data Sharing (in this section referred to as the “Commission”). The purposes of the Commission shall be to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c70b9e3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1723/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor the protections described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1721/c/3"},"text":"section 1721(c)(3) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70b9e4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1723/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide oversight of the interoperable electronic data system described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1722"},"text":"section 1722 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70b9e5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1723/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to Congress annually on the Commission’s findings and recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70b9e6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1723/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall consist of nine members, who shall be appointed by the President, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c70b9e7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1723/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member, who shall serve as Chair of the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70b9e8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1723/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Eight members, who shall be appointed from a list of nominees jointly provided by the Speaker of the House of Representatives, the Minority Leader of the House of Representatives, the Majority Leader of the Senate, and the Minority Leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70b9e9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1723/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall consider recommendations regarding the following issues:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c70b9ea-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1723/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adequate protection of privacy concerns inherent in the design, implementation, or operation of the interoperable electronic data system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70b9eb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1723/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Timely adoption of security innovations, consistent with generally accepted security standards, to protect the integrity and confidentiality of information to prevent the risks of accidental or unauthorized loss, access, destruction, use modification, or disclosure of information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70b9ec-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1723/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The adequacy of mechanisms to permit the timely correction of errors in data maintained by the interoperable data system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70b9ed-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1723/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other protections against unauthorized use of data to guard against the misuse of the interoperable data system or the data maintained by the system, including recommendations for modifications to existing laws and regulations to sanction misuse of the system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70b9ee-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1723/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Commission such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c70b9ef-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/173/tII/s203"},"text":"Pub. L. 107–173, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/551"},"text":"116 Stat. 551","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
