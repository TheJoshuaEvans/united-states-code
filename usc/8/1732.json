{"tag":"section","attrib":{"id":"id9c70ba0d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1732"},"text":null,"children":[{"tag":"num","attrib":{"value":"1732"},"text":"§ 1732.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Machine-readable, tamper-resistant entry and exit documents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c70ba0e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1732/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c70ba0f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1732/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", the Attorney General, the Secretary of State, and the National Institute of Standards and Technology (NIST), acting jointly, shall submit to the appropriate committees of Congress a comprehensive report assessing the actions that will be necessary, and the considerations to be taken into account, to achieve fully, not later than "},{"tag":"date","attrib":{"date":"2004-10-26"},"text":"October 26, 2004","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c70ba10-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1732/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation of the requirements of subsections (b) and (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c70ba11-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1732/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deployment of the equipment and software to allow biometric comparison and authentication of the documents described in subsections (b) and (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70ba12-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1732/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estimates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the assessment required by paragraph (1), the report required by that paragraph shall include an estimate of the costs to be incurred, and the personnel, man-hours, and other support required, by the Department of Justice, the Department of State, and NIST to achieve the objectives of subparagraphs (A) and (B) of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70ba13-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1732/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c70ba14-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1732/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2004-10-26"},"text":"October 26, 2004","children":[],"tail":", the Attorney General and the Secretary of State shall issue to aliens only machine-readable, tamper-resistant visas and other travel and entry documents that use biometric identifiers. The Attorney General and the Secretary of State shall jointly establish document authentication standards and biometric identifiers standards to be employed on such visas and other travel and entry documents from among those biometric identifiers recognized by domestic and international standards organizations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70ba15-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1732/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Readers and scanners at ports of entry","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c70ba16-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1732/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2005-10-26"},"text":"October 26, 2005","children":[],"tail":", the Attorney General, in consultation with the Secretary of State, shall install at all ports of entry of the United States equipment and software to allow biometric comparison and authentication of all United States visas and other travel and entry documents issued to aliens, and passports issued pursuant to subsection (c)(1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c70ba17-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1732/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of readers and scanners","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General, in consultation with the Secretary of State, shall utilize biometric data readers and scanners that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c70ba18-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1732/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" domestic and international standards organizations determine to be highly accurate when used to verify identity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c70ba19-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1732/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can read the biometric identifiers utilized under subsections (b)(1) and (c)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c70ba1a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1732/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can authenticate the document presented to verify identity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70ba1b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1732/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of technology standard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The systems employed to implement paragraphs (1) and (2) shall utilize the technology standard established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1379"},"text":"section 1379 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70ba1c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1732/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dO/tII/s202/c"},"text":"Pub. L. 114–113, div. O, title II, § 202(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2989"},"text":"129 Stat. 2989","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70ba1d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1732/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this section, including reimbursement to international and domestic standards organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c70ba1e-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/173/tIII/s303"},"text":"Pub. L. 107–173, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/553"},"text":"116 Stat. 553","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/299/s1"},"text":"Pub. L. 108–299, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1100"},"text":"118 Stat. 1100","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dO/tII/s202/c"},"text":"Pub. L. 114–113, div. O, title II, § 202(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2989"},"text":"129 Stat. 2989","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c70ba1f-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c70ba20-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c70ba21-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":" struck out subsec. (c), which related to technology standard for visa waiver participants."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsecs. (b)(2)(A), (c)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/299"},"text":"Pub. L. 108–299","children":[],"tail":" substituted “2005” for “2004”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c70ba22-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c70ba23-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
