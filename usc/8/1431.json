{"tag":"section","attrib":{"id":"id9c51c02e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1431"},"text":null,"children":[{"tag":"num","attrib":{"value":"1431"},"text":"§ 1431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Children born outside the United States and lawfully admitted for permanent residence; conditions under which citizenship automatically acquired","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c51c02f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1431/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A child born outside of the United States automatically becomes a citizen of the United States when all of the following conditions have been fulfilled:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c51c030-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1431/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least one parent of the child is a citizen of the United States, whether by birth or naturalization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c51c031-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1431/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The child is under the age of eighteen years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c51c032-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1431/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The child is residing in the United States in the legal and physical custody of the citizen parent pursuant to a lawful admission for permanent residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c51c033-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1431/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":" Subsection (a) shall apply to a child adopted by a United States citizen parent if the child satisfies the requirements applicable to adopted children under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/b/1"},"text":"section 1101(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c51c034-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1431/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Children of military and Federal Government personnel residing abroad","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a)(3) is deemed satisfied in the case of a child who is lawfully admitted for permanent residence in the United States if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c51c035-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1431/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the child is residing in the legal and physical custody of a citizen parent who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c51c036-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1431/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stationed and residing abroad as an employee of the Government of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c51c037-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1431/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" residing abroad in marital union with an employee of the Government of the United States who is stationed abroad; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c51c038-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1431/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the child is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c51c039-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1431/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" residing in the legal and physical custody of a citizen parent who is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c51c03a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1431/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stationed and residing abroad as a member of the Armed Forces of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c51c03b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1431/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized to accompany and reside abroad with a member of the Armed Forces of the United States pursuant to the member’s official orders, and is so accompanying and residing abroad with the member in marital union; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c51c03c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1431/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized to accompany such member and reside abroad with the member pursuant to the member’s official orders, and is so accompanying and residing with the member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c51c03d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1431/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Name and birth date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":" A Certificate of Citizenship or other Federal document issued or requested to be amended under this section shall reflect the child’s name and date of birth as indicated on a State court order, birth certificate, certificate of foreign birth, certificate of birth abroad, or similar State vital records document issued by the child’s State of residence in the United States after the child has been adopted or readopted in that State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c51c03e-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title III, ch. 2, § 320, "},{"tag":"ref","attrib":{"href":"/us/stat/66/245"},"text":"66 Stat. 245","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/417/s4"},"text":"Pub. L. 95–417, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-05"},"text":"Oct. 5, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/917"},"text":"92 Stat. 917","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/116/s18/m"},"text":"Pub. L. 97–116, § 18(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1620"},"text":"95 Stat. 1620","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/653/s14"},"text":"Pub. L. 99–653, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3657"},"text":"100 Stat. 3657","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/525"},"text":"Pub. L. 100–525","children":[],"tail":", §§ 8("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), 9(w), "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2618"},"text":"102 Stat. 2618","children":[],"tail":", 2621; "},{"tag":"ref","attrib":{"href":"/us/pl/106/395/tI/s101/a"},"text":"Pub. L. 106–395, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1631"},"text":"114 Stat. 1631","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/74/s2"},"text":"Pub. L. 113–74, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-16"},"text":"Jan. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1212"},"text":"127 Stat. 1212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/133/s2/a"},"text":"Pub. L. 116–133, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-26"},"text":"Mar. 26, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/274"},"text":"134 Stat. 274","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c51c03f-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c51c040-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c51c041-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/133/s2/a/1"},"text":"Pub. L. 116–133, § 2(a)(1)","children":[],"tail":", substituted “Children born outside the united states and lawfully admitted for permanent residence; conditions under which citizenship automatically acquired” for “Children born outside the United States and residing permanently in the United States; conditions under which citizenship automatically acquired; determinations of name and birth date” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/133/s2/a/2"},"text":"Pub. L. 116–133, § 2(a)(2)","children":[],"tail":", (3), added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/74"},"text":"Pub. L. 113–74","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/395"},"text":"Pub. L. 106–395","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) A child born outside of the United States, one of whose parents at the time of the child’s birth was an alien and the other of whose parents then was and never thereafter ceased to be a citizen of the United States, shall, if such alien parent is naturalized, become a citizen of the United States, when—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) such naturalization takes place while such child is unmarried and under the age of eighteen years; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) such child is residing in the United States pursuant to a lawful admission for permanent residence at the time of naturalization or thereafter and begins to reside permanently in the United States while under the age of eighteen years.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) Subsection (a) of this section shall apply to an adopted child only if the child is residing in the United States at the time of naturalization of such adoptive parent, in the custody of his adoptive parents, pursuant to a lawful admission for permanent residence.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/525/s8"},"text":"Pub. L. 100–525, § 8","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), repealed "},{"tag":"ref","attrib":{"href":"/us/pl/99/653/s14"},"text":"Pub. L. 99–653, § 14","children":[],"tail":". See 1986 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/525/s9/w"},"text":"Pub. L. 100–525, § 9(w)","children":[],"tail":", substituted “Subsection (a)” for “Subsection (a)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/653/s14"},"text":"Pub. L. 99–653, § 14","children":[],"tail":", which inserted “unmarried and” after “such child is”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/100/525/s8"},"text":"Pub. L. 100–525, § 8","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/116"},"text":"Pub. L. 97–116","children":[],"tail":" substituted “an adopted child only if the child” for “a child adopted while under the age of sixteen years who”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/417"},"text":"Pub. L. 95–417","children":[],"tail":" substituted in pars. (1) and (2) “eighteen years” for “sixteen years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/417"},"text":"Pub. L. 95–417","children":[],"tail":" substituted provisions making subsec. (a)(1) of this section applicable to adopted children for provisions making subsec. (a) of this section inapplicable to adopted children."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c51c042-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c51c043-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/395/tI/s104"},"text":"Pub. L. 106–395, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1633"},"text":"114 Stat. 1633","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/395/tI/s104"},"text":"“The amendments made by this title [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1433"},"text":"section 1433 of this title","children":[],"tail":" and repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1432"},"text":"section 1432 of this title","children":[],"tail":"] shall take effect 120 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":"] and shall apply to individuals who satisfy the requirements of section 320 or 322 of the Immigration and Nationality Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1431"},"text":"8 U.S.C. 1431","children":[],"tail":", 1433], as in effect on such effective date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c51c044-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 8(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of "},{"tag":"ref","attrib":{"href":"/us/pl/100/525"},"text":"Pub. L. 100–525","children":[],"tail":" effective as if included in the enactment of the Immigration and Nationality Act Amendments of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/653"},"text":"Pub. L. 99–653","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/232/s309/b/15"},"text":"section 309(b)(15) of Pub. L. 102–232","children":[],"tail":", set out as an Effective and Termination Dates of 1988 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c51c045-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/116"},"text":"Pub. L. 97–116","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/116/s21/a"},"text":"section 21(a) of Pub. L. 97–116","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
