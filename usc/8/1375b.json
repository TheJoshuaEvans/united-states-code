{"tag":"section","attrib":{"id":"id9c484a3a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1375b"},"text":"§ 1375b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protections for domestic workers and other nonimmigrants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c484a3b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information pamphlet and video for consular waiting rooms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c484a3c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, in consultation with the Secretary of Homeland Security, the Attorney General, and the Secretary of Labor, shall develop an information pamphlet and video on legal rights and resources for aliens applying for employment- or education-based nonimmigrant visas. The video shall be distributed and shown in consular waiting rooms in embassies and consulates appropriate to the circumstances that are determined to have the greatest concentration of employment or education-based non-immigrant visa applicants, and where sufficient video facilities exist in waiting or other rooms where applicants wait or convene. The Secretary of State is authorized to augment video facilities in such consulates or embassies in order to fulfill the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c484a3d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the information pamphlet under paragraph (1), the Secretary of State shall consult with nongovernmental organizations with expertise on the legal rights of workers and victims of severe forms of trafficking in persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c484a3e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information pamphlet and video developed under subsection (a) shall include information concerning items such as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c484a3f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nonimmigrant visa application processes, including information about the portability of employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c484a40-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the legal rights of employment or education-based nonimmigrant visa holders under Federal immigration, labor, and employment law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c484a41-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the illegality of slavery, peonage, trafficking in persons, sexual assault, extortion, blackmail, and worker exploitation in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c484a42-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the legal rights of immigrant victims of trafficking in persons and worker exploitation, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c484a43-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right of access to immigrant and labor rights groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c484a44-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right to seek redress in United States courts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c484a45-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right to report abuse without retaliation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c484a46-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right of the nonimmigrant to relinquish possession of his or her passport to his or her employer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c484a47-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirement of an employment contract between the employer and the nonimmigrant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c484a48-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of the rights and protections included in the contract described in subparagraph (E); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c484a49-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information about nongovernmental organizations that provide services for victims of trafficking in persons and worker exploitation, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c484a4a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" anti-trafficking in persons telephone hotlines operated by the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c484a4b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Operation Rescue and Restore hotline; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c484a4c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a general description of the types of victims services available for individuals subject to trafficking in persons or worker exploitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c484a4d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Translation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c484a4e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To best serve the language groups having the greatest concentration of employment-based nonimmigrant visas, the Secretary of State shall translate the information pamphlet and produce or dub the video developed under subsection (a) into all relevant foreign languages, to be determined by the Secretary based on the languages spoken by the greatest concentrations of employment- or education-based nonimmigrant visa applicants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c484a4f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every 2 years, the Secretary of State, in consultation with the Attorney General and the Secretary of Homeland Security, shall determine the specific languages into which the information pamphlet will be translated and the video produced or dubbed based on the languages spoken by the greatest concentrations of employment- or education-based nonimmigrant visa applicants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c484a50-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability and distribution","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c484a51-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Posting on Federal websites","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information pamphlet and video developed under subsection (a) shall be posted on the websites of the Department of State, the Department of Homeland Security, the Department of Justice, the Department of Labor, and all United States consular posts processing applications for employment- or education-based nonimmigrant visas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c484a52-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information pamphlet and video developed under subsection (a) shall be made available to any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c484a53-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" government agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c484a54-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nongovernmental advocacy organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c484a55-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign labor broker doing business in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c484a56-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for pamphlet development and distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2008-12-23"},"text":"December 23, 2008","children":[],"tail":", the Secretary of State shall distribute and make available the information pamphlet developed under subsection (a) in all the languages referred to in subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c484a57-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for video development and distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2013-03-07"},"text":"March 7, 2013","children":[],"tail":", the Secretary of State shall make available the video developed under subsection (a) produced or dubbed in all the languages referred to in subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c484a58-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of consular officers of the Department of State","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c484a59-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interviews","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A consular officer conducting an interview of an alien for an employment-based nonimmigrant visa shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c484a5a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c484a5b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" confirm that the alien has received, read, and understood the contents of the pamphlet described in subsections (a) and (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c484a5c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the alien has not received, read, or understood the contents of the pamphlet described in subsections (a) and (b), distribute and orally disclose to the alien the information described in paragraphs (2) and (3) in a language that the alien understands; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c484a5d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer to answer any questions the alien may have regarding the contents of the pamphlet described in subsections (a) and (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c484a5e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The consular officer shall disclose to the alien—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c484a5f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the legal rights of employment-based nonimmigrants under Federal immigration, labor, and employment laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c484a60-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the illegality of slavery, peonage, trafficking in persons, sexual assault, extortion, blackmail, and worker exploitation in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c484a61-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the legal rights of immigrant victims of trafficking in persons, worker exploitation, and other related crimes, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c484a62-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right of access to immigrant and labor rights groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c484a63-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right to seek redress in United States courts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c484a64-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/e/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right to report abuse without retaliation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c484a65-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Victim services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the disclosure requirement under this subsection, the consular officer shall disclose to the alien the availability of services for victims of human trafficking and worker exploitation in the United States, including victim services complaint hotlines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c484a66-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c484a67-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment- or education-based nonimmigrant visa","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “employment- or education-based nonimmigrant visa” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c484a68-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonimmigrant visa issued under subparagraph (A)(iii), (G)(v), (H), or (J) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/15"},"text":"section 1101(a)(15) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c484a69-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any nonimmigrant visa issued to a personal or domestic servant who is accompanying or following to join an employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c484a6a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Severe forms of trafficking in persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “severe forms of trafficking in persons” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"section 7102 of title 22","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c484a6b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c484a6c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1375b/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abusing and exploiting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “abusing and exploiting” means any conduct which would constitute a violation of section 1466A, 1589, 1591, 1592, 2251, or 2251A of title 18.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c484a6d-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457/tII/s202"},"text":"Pub. L. 110–457, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5055"},"text":"122 Stat. 5055","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tXII/s1206"},"text":"Pub. L. 113–4, title XII, § 1206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/140"},"text":"127 Stat. 140","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c484a6e-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c484a6f-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c484a70-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the William Wilberforce Trafficking Victims Protection Reauthorization Act of 2008, and not as part of the Immigration and Nationality Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c484a71-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s1206/1/A"},"text":"Pub. L. 113–4, § 1206(1)(A)","children":[],"tail":", inserted “and video for consular waiting rooms” after “Information pamphlet” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s1206/1/B"},"text":"Pub. L. 113–4, § 1206(1)(B)","children":[],"tail":", inserted “and video” after “information pamphlet” and inserted at end “The video shall be distributed and shown in consular waiting rooms in embassies and consulates appropriate to the circumstances that are determined to have the greatest concentration of employment or education-based non-immigrant visa applicants, and where sufficient video facilities exist in waiting or other rooms where applicants wait or convene. The Secretary of State is authorized to augment video facilities in such consulates or embassies in order to fulfill the purposes of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s1206/2"},"text":"Pub. L. 113–4, § 1206(2)","children":[],"tail":", inserted “and video” after “information pamphlet” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s1206/3/A"},"text":"Pub. L. 113–4, § 1206(3)(A)","children":[],"tail":", inserted “and produce or dub the video” after “information pamphlet”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s1206/3/B"},"text":"Pub. L. 113–4, § 1206(3)(B)","children":[],"tail":", inserted “and the video produced or dubbed” after “translated”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s1206/4/A"},"text":"Pub. L. 113–4, § 1206(4)(A)","children":[],"tail":", inserted “and video” after “information pamphlet”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s1206/4/B"},"text":"Pub. L. 113–4, § 1206(4)(B)","children":[],"tail":", inserted “and video” after “information pamphlet” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s1206/4/C"},"text":"Pub. L. 113–4, § 1206(4)(C)","children":[],"tail":", added par. (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
