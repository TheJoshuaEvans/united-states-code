{"tag":"section","attrib":{"id":"id9c62893c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533"},"text":null,"children":[{"tag":"num","attrib":{"value":"1533"},"text":"§ 1533.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal court procedure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c62893d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c62893e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case in which the Attorney General has classified information that an alien is an alien terrorist, the Attorney General may seek removal of the alien under this subchapter by filing an application with the removal court that contains—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c62893f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of the attorney in the Department of Justice making the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c628940-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification by the Attorney General or the Deputy Attorney General that the application satisfies the criteria and requirements of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c628941-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of the alien for whom authorization for the removal proceeding is sought; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c628942-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a statement of the facts and circumstances relied on by the Department of Justice to establish probable cause that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c628943-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alien is an alien terrorist;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c628944-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alien is physically present in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c628945-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/a/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to such alien, removal under subchapter II would pose a risk to the national security of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c628946-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application under this section shall be submitted ex parte and in camera, and shall be filed under seal with the removal court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c628947-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to dismiss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may dismiss a removal action under this subchapter at any stage of the proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c628948-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c628949-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis for decision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether to grant an application under this section, a single judge of the removal court may consider, ex parte and in camera, in addition to the information contained in the application—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c62894a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other information, including classified information, presented under oath or affirmation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c62894b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" testimony received in any hearing on the application, of which a verbatim record shall be kept.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c62894c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of order","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The judge shall issue an order granting the application, if the judge finds that there is probable cause to believe that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c62894d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alien who is the subject of the application has been correctly identified and is an alien terrorist present in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c62894e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" removal under subchapter II would pose a risk to the national security of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c62894f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the judge denies the order requested in the application, the judge shall prepare a written statement of the reasons for the denial, taking all necessary precautions not to disclose any classified information contained in the Government’s application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c628950-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1533/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an order is issued under this section granting an application, the rights of the alien regarding removal and expulsion shall be governed solely by this subchapter, and except as they are specifically referenced in this subchapter, no other provisions of this chapter shall be applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c628951-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title V, § 503, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tIV/s401/a"},"text":"Pub. L. 104–132, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1259"},"text":"110 Stat. 1259","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c628952-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c628953-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c628954-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d), was in the original, “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":", known as the Immigration and Nationality Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c628955-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c628956-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
