{"tag":"section","attrib":{"id":"id9c4a93b6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1377a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1377a"},"text":"§ 1377a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on aliens determined to have credible or reasonable fear of persecution or torture","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c4a93b7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1377a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Semimonthly updates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", and updated semimonthly thereafter, the Director of U.S. Citizenship and Immigration Services shall make available, on a publicly accessible website in a downloadable, searchable, and sortable format, a report containing not less than the previous twelve months of semimonthly data on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c4a93b8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1377a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of aliens determined to have a credible or reasonable fear of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c4a93b9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1377a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persecution, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1225/b/1/B/v"},"text":"section 1225(b)(1)(B)(v) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"i