{"tag":"section","attrib":{"id":"id9c4d0579-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1408"},"text":null,"children":[{"tag":"num","attrib":{"value":"1408"},"text":"§ 1408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nationals but not citizens of the United States at birth","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Unless otherwise provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1401"},"text":"section 1401 of this title","children":[],"tail":", the following shall be nationals, but not citizens, of the United States at birth:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c4d057a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1408/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person born in an outlying possession of the United States on or after the date of formal acquisition of such possession;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4d057b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1408/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person born outside the United States and its outlying possessions of parents both of whom are nationals, but not citizens, of the United States, and have had a residence in the United States, or one of its outlying possessions prior to the birth of such person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4d057c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1408/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person of unknown parentage found in an outlying possession of the United States while under the age of five years, until shown, prior to his attaining the age of twenty-one years, not to have been born in such outlying possession; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4d057d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1408/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person born outside the United States and its outlying possessions of parents one of whom is an alien, and the other a national, but not a citizen, of the United States who, prior to the birth of such person, was physically present in the United States or its outlying possessions for a period or periods totaling not less than seven years in any continuous period of ten years—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c4d057e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1408/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during which the national parent was not outside the United States or its outlying possessions for a continuous period of more than one year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4d057f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1408/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least five years of which were after attaining the age of fourteen years.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The proviso of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1401/g"},"text":"section 1401(g) of this title","children":[],"tail":" shall apply to the national parent under this paragraph in the same manner as it applies to the citizen parent under that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c4d0580-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title III, ch. 1, § 308, "},{"tag":"ref","attrib":{"href":"/us/stat/66/238"},"text":"66 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/396/s15/a"},"text":"Pub. L. 99–396, § 15(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/842"},"text":"100 Stat. 842","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/525/s3/2"},"text":"Pub. L. 100–525, § 3(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2614"},"text":"102 Stat. 2614","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c4d0581-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c4d0582-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c4d0583-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/525"},"text":"Pub. L. 100–525","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/396"},"text":"Pub. L. 99–396","children":[],"tail":". See 1986 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/396"},"text":"Pub. L. 99–396","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/525"},"text":"Pub. L. 100–525","children":[],"tail":", added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c4d0584-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c4d0585-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/525/s3"},"text":"Pub. L. 100–525, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2614"},"text":"102 Stat. 2614","children":[],"tail":", provided that the amendment made by section 3 is effective as if included in the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/99/396"},"text":"Pub. L. 99–396","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c4d0586-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/396/s15/b"},"text":"Pub. L. 99–396, § 15(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/843"},"text":"100 Stat. 843","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/396/s15/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendment made by subsection (a) [amending this section] shall apply to persons born before, on, or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":"]. In the case of a person born before the date of the enactment of this Act—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of a national of the United States shall not be considered to be conferred upon the person until the date the person establishes to the satisfaction of the Secretary of State that the person meets the requirements of section 308(4) of the Immigration and Nationality Act [par. (4) of this section], and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person shall not be eligible to vote in any general election in American Samoa earlier than ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
