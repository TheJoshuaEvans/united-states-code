{"tag":"section","attrib":{"id":"id9c45d913-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1368"},"text":null,"children":[{"tag":"num","attrib":{"value":"1368"},"text":"§ 1368.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in INS detention facilities; report on detention space","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c45d914-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1368/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in detention facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Attorney General shall provide for an increase in the detention facilities of the Immigration and Naturalization Service to at least 9,000 beds before the end of fiscal year 1997.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c45d915-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1368/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on detention space","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c45d916-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1368/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":", and every 6 months thereafter, the Attorney General shall submit a report to the Committees on the Judiciary of the House of Representatives and of the Senate estimating the amount of detention space that will be required, during the fiscal year in which the report is submitted and the succeeding fiscal year, to detain—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c45d917-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1368/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all aliens subject to detention under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1226/c"},"text":"section 1226(c) of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1231/a"},"text":"section 1231(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c45d918-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1368/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all inadmissible or deportable aliens subject to proceedings under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1228"},"text":"section 1228 of this title","children":[],"tail":" or section 1225(b)(2)(A) or 1229a of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c45d919-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1368/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other inadmissible or deportable aliens in accordance with the priorities established by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c45d91a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1368/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estimate of number of aliens released into the community","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c45d91b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1368/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal aliens","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c45d91c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1368/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The first report submitted under paragraph (1) shall include an estimate of the number of criminal aliens who, in each of the 3 fiscal years concluded prior to the date of the report—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id9c45d91d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1368/b/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were released from detention facilities of the Immigration and Naturalization Service (whether operated directly by the Service or through contract with other persons or agencies); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id9c45d91e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1368/b/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were not taken into custody or detention by the Service upon completion of their incarceration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c45d91f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1368/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aliens convicted of aggravated felonies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The estimate under clause (i) shall estimate separately, with respect to each year described in such clause, the number of criminal aliens described in such clause who were convicted of an aggravated felony.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c45d920-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1368/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" All inadmissible or deportable aliens","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The first report submitted under paragraph (1) shall also estimate the number of inadmissible or deportable aliens who were released into the community due to a lack of detention facilities in each of the 3 fiscal years concluded prior to the date of the report notwithstanding circumstances that the Attorney General believed justified detention (for example, a significant probability that the released alien would not appear, as agreed, at subsequent exclusion or deportation proceedings).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c45d921-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1368/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report under paragraph (1) following the first such report shall include the estimates under subparagraphs (A) and (B), made with respect to the 6-month period immediately preceding the date of the submission of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c45d922-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII"},"text":"Pub. L. 104–208, div. C, title III","children":[],"tail":", §§ 308(g)(10)(G), 386, "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-625"},"text":"110 Stat. 3009–625","children":[],"tail":", 3009–653.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c45d923-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c45d924-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c45d925-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Illegal Immigration Reform and Immigrant Responsibility Act of 1996, and also as part of the Omnibus Consolidated Appropriations Act, 1997, and not as part of the Immigration and Nationality Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c45d926-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s308/g/10/G"},"text":"Pub. L. 104–208, § 308(g)(10)(G)","children":[],"tail":", substituted “inadmissible” for “excludable” in pars. (1)(B), (C) and (2)(B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c45d927-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c45d928-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s308/g/10/G"},"text":"section 308(g)(10)(G) of Pub. L. 104–208","children":[],"tail":" effective, with certain transitional provisions, on the first day of the first month beginning more than 180 days after "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s309"},"text":"section 309 of Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c45d929-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
