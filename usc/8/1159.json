{"tag":"section","attrib":{"id":"id9bdd0595-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1159"},"text":null,"children":[{"tag":"num","attrib":{"value":"1159"},"text":"§ 1159.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of status of refugees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9bdd0596-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1159/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection and examination by Department of Homeland Security","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9bdd0597-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1159/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any alien who has been admitted to the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1157"},"text":"section 1157 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9bdd0598-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1159/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose admission has not been terminated by the Secretary of Homeland Security or the Attorney General pursuant to such regulations as the Secretary of Homeland Security or the Attorney General may prescribe,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9bdd0599-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1159/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has been physically present in the United States for at least one year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9bdd059a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1159/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has not acquired permanent resident status,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall, at the end of such year period, return or be returned to the custody of the Department of Homeland Security for inspection and examination for admission to the United States as an immigrant in accordance with the provisions of sections 1225, 1229a, and 1231 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9bdd059b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1159/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any alien who is found upon inspection and examination by an immigration officer pursuant to paragraph (1) or after a hearing before an immigration judge to be admissible (except as otherwise provided under subsection (c)) as an immigrant under this chapter at the time of the alien’s inspection and examination shall, notwithstanding any numerical limitation specified in this chapter, be regarded as lawfully admitted to the United States for permanent residence as of the date of such alien’s arrival into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9bdd059c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1159/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Homeland Security or the Attorney General, in the Secretary’s or the Attorney General’s discretion and under such regulations as the Secretary or the Attorney General may prescribe, may adjust to the status of an alien lawfully admitted for permanent residence the status of any alien granted asylum who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9bdd059d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1159/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applies for such adjustment,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9bdd059e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1159/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been physically present in the United States for at least one year after being granted asylum,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9bdd059f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1159/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continues to be a refugee within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/42/A"},"text":"section 1101(a)(42)(A) of this title","children":[],"tail":" or a spouse or child of such a refugee,"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9bdd05a0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1159/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not firmly resettled in any foreign country, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9bdd05a1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1159/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is admissible (except as otherwise provided under subsection (c)) as an immigrant under this chapter at the time of examination for adjustment of such alien.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Upon approval of an application under this subsection, the Secretary of Homeland Security or the Attorney General shall establish a record of the alien’s admission for lawful permanent residence as of the date one year before the date of the approval of the application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9bdd05a2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1159/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with section 1182","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of paragraphs (4), (5), and (7)(A) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182/a"},"text":"section 1182(a) of this title","children":[],"tail":" shall not be applicable to any alien seeking adjustment of status under this section, and the Secretary of Homeland Security or the Attorney General may waive any other provision of such section (other than paragraph (2)(C) or subparagraph (A), (B), (C), or (E) of paragraph (3)) with respect to such an alien for humanitarian purposes, to assure family unity, or when it is otherwise in the public interest."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9bdd05a3-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title II, ch. 1, § 209, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/212/tII/s201/b"},"text":"Pub. L. 96–212, title II, § 201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-17"},"text":"Mar. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/105"},"text":"94 Stat. 105","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/tI/s104/a/1"},"text":"Pub. L. 101–649, title I, § 104(a)(1)","children":[],"tail":", title VI, § 603(a)(4), "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4985"},"text":"104 Stat. 4985","children":[],"tail":", 5082; "},{"tag":"ref","attrib":{"href":"/us/pl/102/232/tIII/s307"},"text":"Pub. L. 102–232, title III, § 307","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1), "},{"tag":"date","attrib":{"date":"1991-12-12"},"text":"Dec. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1756"},"text":"105 Stat. 1756","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII"},"text":"Pub. L. 104–208, div. C, title III","children":[],"tail":", §§ 308(g)(3)(A), (4)(A), 371(b)(2), "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-622"},"text":"110 Stat. 3009–622","children":[],"tail":", 3009–645; "},{"tag":"ref","attrib":{"href":"/us/pl/109/13/dB/tI/s101/g/1"},"text":"Pub. L. 109–13, div. B, title I, § 101(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-05-11"},"text":"May 11, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/305"},"text":"119 Stat. 305","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9bdd05a4-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9bdd05a5-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9bdd05a6-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(2) and (b)(5), was in the original, “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":", known as the Immigration and Nationality Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9bdd05a7-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/13/s101/g/1/A/i"},"text":"Pub. L. 109–13, § 101(g)(1)(A)(i)","children":[],"tail":", substituted “Department of Homeland Security” for “Service” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/13/s101/g/1/A/ii"},"text":"Pub. L. 109–13, § 101(g)(1)(A)(ii)","children":[],"tail":", substituted “Secretary of Homeland Security or the Attorney General” for “Attorney General” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/13/s101/g/1/B/ii"},"text":"Pub. L. 109–13, § 101(g)(1)(B)(ii)","children":[],"tail":", substituted “Secretary of Homeland Security or the Attorney General” for “Attorney General” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/13/s101/g/1/B/i"},"text":"Pub. L. 109–13, § 101(g)(1)(B)(i)","children":[],"tail":", added introductory provisions and struck out former introductory provisions which read as follows: “Not more than 10,000 of the refugee admissions authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1157/a"},"text":"section 1157(a) of this title","children":[],"tail":" in any fiscal year may be made available by the Attorney General, in the Attorney General’s discretion and under such regulations as the Attorney General may prescribe, to adjust to the status of an alien lawfully admitted for permanent residence the status of any alien granted asylum who—”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/13/s101/g/1/C"},"text":"Pub. L. 109–13, § 101(g)(1)(C)","children":[],"tail":", substituted “Secretary of Homeland Security or the Attorney General” for “Attorney General”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s308/g/3/A"},"text":"Pub. L. 104–208, § 308(g)(3)(A)","children":[],"tail":", (4)(A), substituted “1229a” for “1226” and “1231” for “1227” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s371/b/2"},"text":"Pub. L. 104–208, § 371(b)(2)","children":[],"tail":", substituted “an immigration judge” for “a special inquiry officer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/232"},"text":"Pub. L. 102–232","children":[],"tail":" substituted “subparagraph (A)” for “subparagraphs (A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649/s104/a/1"},"text":"Pub. L. 101–649, § 104(a)(1)","children":[],"tail":", substituted “10,000” for “five thousand”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649/s603/a/4"},"text":"Pub. L. 101–649, § 603(a)(4)","children":[],"tail":", substituted “(4), (5), and (7)(A)” for “(14), (15), (20), (21), (25), and (32)” and “(other than paragraph (2)(C) or subparagraphs (A), (B), (C), or (E) of paragraph (3))” for “(other than paragraph (27), (29), or (33) and other than so much of paragraph (23) as relates to trafficking in narcotics)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9bdd05a8-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9bdd05a9-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 308(g)(3)(A), (4)(A) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" effective, with certain transitional provisions, on the first day of the first month beginning more than 180 days after "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s309"},"text":"section 309 of Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s371/b/2"},"text":"section 371(b)(2) of Pub. L. 104–208","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s371/d/1"},"text":"section 371(d)(1) of Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9bdd05aa-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/232/tIII/s307"},"text":"Pub. L. 102–232, title III, § 307","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1991-12-12"},"text":"Dec. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1756"},"text":"105 Stat. 1756","children":[],"tail":", provided that the amendment made by section 307("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") is effective as if included in section 603(a) of the Immigration Act of 1990, "},{"tag":"ref","attrib":{"href":"/us/pl/101/649"},"text":"Pub. L. 101–649","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9bdd05ab-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649/tI/s104/a/2"},"text":"Pub. L. 101–649, title I, § 104(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4985"},"text":"104 Stat. 4985","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/649/tI/s104/a/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall apply to fiscal years beginning with fiscal year 1991 and the President is authorized, without the need for appropriate consultation, to increase the refugee determination previously made under section 207 of the Immigration and Nationality Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1157"},"text":"8 U.S.C. 1157","children":[],"tail":"] for fiscal year 1991 in order to make such amendment effective for such fiscal year.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649/s603/a/4"},"text":"section 603(a)(4) of Pub. L. 101–649","children":[],"tail":" applicable to individuals entering United States on or after "},{"tag":"date","attrib":{"date":"1991-06-01"},"text":"June 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/s601/e/1"},"text":"section 601(e)(1) of Pub. L. 101–649","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id9bdd05ac-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective, except as otherwise provided, ","children":[{"tag":"date","attrib":{"date":"1980-03-17"},"text":"Mar. 17, 1980","children":[],"tail":", and applicable to fiscal years beginning with the fiscal year beginning "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/212/s204"},"text":"section 204 of Pub. L. 96–212","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9bdd05ad-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9bdd05ae-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Waiver of Numerical Limitation for Certain Current Asylees; Adjustment of Certain Former Asylees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649/tI/s104/c"},"text":"Pub. L. 101–649, title I, § 104(c)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4985"},"text":"104 Stat. 4985","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tVI/s604/b/2"},"text":"Pub. L. 104–208, div. C, title VI, § 604(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-694"},"text":"110 Stat. 3009–694","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/208/dC/tVI/s604/b/2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver of Numerical Limitation for Certain Current Asylees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The numerical limitation on the number of aliens whose status may be adjusted under section 209(b) of the Immigration and Nationality Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1159/b"},"text":"8 U.S.C. 1159(b)","children":[],"tail":"] shall not apply to an alien described in subsection (d) or to an alien who has applied for adjustment of status under such section on or before "},{"tag":"date","attrib":{"date":"1990-06-01"},"text":"June 1, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjustment of Certain Former Asylees.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), the provisions of section 209(b) of the Immigration and Nationality Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1159/b"},"text":"8 U.S.C. 1159(b)","children":[],"tail":"] shall also apply to an alien—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who was granted asylum before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":"] (regardless of whether or not such asylum has been terminated under section 208 of the Immigration and Nationality Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1158"},"text":"8 U.S.C. 1158","children":[],"tail":"]),"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is no longer a refugee because of a change in circumstances in a foreign state, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who was (or would be) qualified for adjustment of status under section 209(b) of the Immigration and Nationality Act as of the date of the enactment of this Act but for paragraphs (2) and (3) thereof and but for any numerical limitation under such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of per country limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The number of aliens who are natives of any foreign state who may adjust status pursuant to paragraph (1) in any fiscal year shall not exceed the difference between the per country limitation established under section 202(a) of the Immigration and Nationality Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1152/a"},"text":"8 U.S.C. 1152(a)","children":[],"tail":"] and the number of aliens who are chargeable to that foreign state in the fiscal year under section 202 of such Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Section 104(c), (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649"},"text":"Pub. L. 101–649","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", and (unless otherwise provided) applicable to fiscal year 1991, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/s161/b"},"text":"section 161(b) of Pub. L. 101–649","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
