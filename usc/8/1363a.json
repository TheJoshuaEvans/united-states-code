{"tag":"section","attrib":{"id":"id9c411e1e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1363a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1363a"},"text":"§ 1363a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Undercover investigation authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c411e1f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1363a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any undercover investigative operation of the Service which is necessary for the detection and prosecution of crimes against the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c411e20-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1363a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" sums appropriated for the Service may be used for leasing space within the United States and the territories and possessions of the United States without regard to the following provisions of law:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c411e21-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1363a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1341/a"},"text":"section 1341(a) of title 31","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c411e22-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1363a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 6301(a) and (b)(1) to (3) of title 41,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c411e23-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1363a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 45 of title 41,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c411e24-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1363a/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s8141"},"text":"section 8141 of title 40","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c411e25-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1363a/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 3324(a) and (b) of title 31,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c411e26-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1363a/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6306"},"text":"section 6306 of title 41","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c411e27-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1363a/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3901"},"text":"section 3901 of title 41","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c411e28-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1363a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sums appropriated for the Service may be used to establish or to acquire proprietary corporations or business entities as part of an undercover operation, and to operate such corporations or business entities on a commercial basis, without regard to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9102"},"text":"section 9102 of title 31","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c411e29-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1363a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sums appropriated for the Service, and the proceeds from the undercover operation, may be deposited in banks or other financial institutions without regard to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s648"},"text":"section 648 of title 18","children":[],"tail":" and of "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302/a"},"text":"section 3302(a) of title 31","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c411e2a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1363a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proceeds from the undercover operation may be used to offset necessary and reasonable expenses incurred in such operation without regard to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302/b"},"text":"section 3302(b) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The authority set forth in this subsection may be exercised only upon written certification of the Commissioner, in consultation with the Deputy Attorney General, that any action authorized by paragraph (1), (2), (3), or (4) is necessary for the conduct of the undercover operation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c411e2b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1363a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of proceeds no longer required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the proceeds from an undercover investigative operation, carried out under paragraphs (3) and (4) of subsection (a), are no longer necessary for the conduct of the operation, the proceeds or the balance of the proceeds remaining at the time shall be deposited into the Treasury of the United States as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c411e2c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1363a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of certain corporations and business entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a corporation or business entity established or acquired as part of an undercover operation under paragraph (2) of subsection (a) with a net value of over $50,000 is to be liquidated, sold, or otherwise disposed of, the Service, as much in advance as the Commissioner or Commissioner’s designee determines practicable, shall report the circumstances to the Attorney General, the Director of the Office of Management and Budget, and the Comptroller General. The proceeds of the liquidation, sale, or other disposition, after obligations are met, shall be deposited in the Treasury of the United States as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c411e2d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1363a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Service shall conduct detailed financial audits of closed undercover operations on a quarterly basis and shall report the results of the audits in writing to the Deputy Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c411e2e-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title II, ch. 9, § 294, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tII/s205/a"},"text":"Pub. L. 104–208, div. C, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-567"},"text":"110 Stat. 3009–567","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c411e2f-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c411e30-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c411e31-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attr