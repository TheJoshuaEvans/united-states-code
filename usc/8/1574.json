{"tag":"section","attrib":{"id":"id9c64d34a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574"},"text":null,"children":[{"tag":"num","attrib":{"value":"1574"},"text":"§ 1574.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c64d34b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Backlog elimination plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c64d34c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2000-10-17"},"text":"October 17, 2000","children":[],"tail":", the Attorney General shall submit a report to the Committees on the Judiciary and Appropriations of the Senate and the House of Representatives concerning—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c64d34d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the backlogs in immigration benefit applications in existence as of ","children":[{"tag":"date","attrib":{"date":"2000-10-17"},"text":"October 17, 2000","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c64d34e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General’s plan for eliminating such backlogs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c64d34f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c64d350-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assessment of the data systems used in adjudicating and reporting on the status of immigration benefit applications, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c64d351-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the adequacy of existing computer hardware, computer software, and other mechanisms to comply with the adjudications and reporting requirements of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c64d352-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for implementing improvements to existing data systems to accomplish the purpose of this subchapter, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1571/a"},"text":"section 1571(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c64d353-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the quality controls to be put into force to ensure timely, fair, accurate, and complete processing and adjudication of such applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c64d354-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the elements specified in subsection (b)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c64d355-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the amount of appropriated funds that would be necessary in order to eliminate the backlogs in each category of immigration benefit applications described in subsection (b)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c64d356-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed plan on how the Attorney General will use any funds in the Immigration Services and Infrastructure Improvements Account to comply with the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c64d357-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c64d358-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning 90 days after the end of the first fiscal year for which any appropriation authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1573/b"},"text":"section 1573(b) of this title","children":[],"tail":" is made, and 90 days after the end of each fiscal year thereafter, the Attorney General shall submit a report to the Committees on the Judiciary and Appropriations of the Senate and the House of Representatives concerning the status of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c64d359-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Immigration Services and Infrastructure Improvements Account including any unobligated balances of appropriations in the Account; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c64d35a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General’s efforts to eliminate backlogs in any immigration benefit application described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c64d35b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c64d35c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" State-by-State data on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c64d35d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of naturalization cases adjudicated in each quarter of each fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c64d35e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average processing time for naturalization applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c64d35f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of naturalization applications pending for up to 6 months, 12 months, 18 months, 24 months, 36 months, and 48 months or more;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c64d360-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimated processing times adjudicating newly submitted naturalization applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c64d361-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the appropriate processing times for naturalization applications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c64d362-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the additional resources and process changes needed to eliminate the backlog for naturalization adjudications;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c64d363-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the status of applications or, where applicable, petitions described in subparagraph (C), by Immigration and Naturalization Service district, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c64d364-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of cases adjudicated in each quarter of each fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c64d365-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average processing time for such applications or petitions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c64d366-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/2/B/iii"},"text":null,"children":