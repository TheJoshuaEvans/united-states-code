":[],"tail":null},{"tag":"content","attrib":{},"text":" applications for adjustments of status to that of an alien lawfully admitted for permanent residence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c64d36c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" petitions for nonimmigrant visas under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1184"},"text":"section 1184 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c64d36d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" petitions filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1154"},"text":"section 1154 of this title","children":[],"tail":" to classify aliens as immediate relatives or preference immigrants under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1153"},"text":"section 1153 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c64d36e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applications for asylum under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1158"},"text":"section 1158 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c64d36f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" registrations for Temporary Protected Status under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1254a"},"text":"section 1254a of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c64d370-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/2/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the additional resources and process changes needed to eliminate the backlog for such processing and adjudications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c64d371-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1574/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Absence of appropriated funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event that no funds are appropriated subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1573/b"},"text":"section 1573(b) of this title","children":[],"tail":" in the fiscal year in which this Act is enacted, the Attorney General shall submit a report to Congress not later than 90 days after the end of such fiscal year, and each fiscal year thereafter, containing the elements described in paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c64d372-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/313/tII/s205"},"text":"Pub. L. 106–313, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1263"},"text":"114 Stat. 1263","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c64d373-