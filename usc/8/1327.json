{"tag":"section","attrib":{"id":"id9c39f2bb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1327"},"text":null,"children":[{"tag":"num","attrib":{"value":"1327"},"text":"§ 1327.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aiding or assisting certain aliens to enter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person who knowingly aids or assists any alien inadmissible under section 1182(a)(2) (insofar as an alien inadmissible under such section has been convicted of an aggravated felony) or 1182(a)(3) (other than subparagraph (E) thereof) of this title to enter the United States, or who connives or conspires with any person or persons to allow, procure, or permit any such alien to enter the United States, shall be fined under title 18, or imprisoned not more than 10 years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9c39f2bc-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title II, ch. 8, § 277, "},{"tag":"ref","attrib":{"href":"/us/stat/66/229"},"text":"66 Stat. 229","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7346/a"},"text":"Pub. L. 100–690, title VII, § 7346(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4471"},"text":"102 Stat. 4471","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/tV/s543/b/4"},"text":"Pub. L. 101–649, title V, § 543(b)(4)","children":[],"tail":", title VI, § 603(a)(16), "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5059"},"text":"104 Stat. 5059","children":[],"tail":", 5084; "},{"tag":"ref","attrib":{