{"tag":"section","attrib":{"id":"id9c1fb344-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253"},"text":null,"children":[{"tag":"num","attrib":{"value":"1253"},"text":"§ 1253.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties related to removal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c1fb345-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for failure to depart","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c1fb346-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any alien against whom a final order of removal is outstanding by reason of being a member of any of the classes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1227/a"},"text":"section 1227(a) of this title","children":[],"tail":", who—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c1fb347-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully fails or refuses to depart from the United States within a period of 90 days from the date of the final order of removal under administrative processes, or if judicial review is had, then from the date of the final order of the court,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c1fb348-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully fails or refuses to make timely application in good faith for travel or other documents necessary to the alien’s departure,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c1fb349-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" connives or conspires, or takes any other action, designed to prevent or hamper or with the purpose of preventing or hampering the alien’s departure pursuant to such, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c1fb34a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully fails or refuses to present himself or herself for removal at the time and place required by the Attorney General pursuant to such order,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under title 18, or imprisoned not more than four years (or 10 years if the alien is a member of any of the classes described in paragraph (1)(E), (2), (3), or (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1227/a"},"text":"section 1227(a) of this title","children":[],"tail":"), or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c1fb34b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is not a violation of paragraph (1) to take any proper steps for the purpose of securing cancellation of or exemption from such order of removal or for the purpose of securing the alien’s release from incarceration or custody.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c1fb34c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The court may for good cause suspend the sentence of an alien under this subsection and order the alien’s release under such conditions as the court may prescribe. In determining whether good cause has been shown to justify releasing the alien, the court shall take into account such factors as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c1fb34d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the age, health, and period of detention of the alien;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c1fb34e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of the alien’s release upon the national security and public peace or safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c1fb34f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the likelihood of the alien’s resuming or following a course of conduct which made or would make the alien deportable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c1fb350-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the character of the efforts made by such alien himself and by representatives of the country or countries to which the alien’s removal is directed to expedite the alien’s departure from the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c1fb351-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reason for the inability of the Government of the United States to secure passports, other travel documents, or removal facilities from the country or countries to which the alien has been ordered removed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c1fb352-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligibility of the alien for discretionary relief under the immigration laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c1fb353-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Willful failure to comply with terms of release under supervision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An alien who shall willfully fail to comply with regulations or requirements issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1231/a/3"},"text":"section 1231(a)(3) of this title","children":[],"tail":" or knowingly give false information in response to an inquiry under such section shall be fined not more than $1,000 or imprisoned for not more than one year, or both."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c1fb354-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties relating to vessels and aircraft","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c1fb355-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c1fb356-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to carry out certain orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Attorney General is satisfied that a person has violated subsection (d) or (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1231"},"text":"section 1231 of this title","children":[],"tail":", the person shall pay to the Commissioner the sum of $2,000 for each violation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c1fb357-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to remove alien stowaways","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Attorney General is satisfied that a person has failed to remove an alien stowaway as required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1231/d/2"},"text":"section 1231(d)(2) of this title","children":[],"tail":", the person shall pay to the Commissioner the sum of $5,000 for each alien stowaway not removed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c1fb358-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No compromise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may not compromise the amount of such penalty under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c1fb359-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clearing vessels and aircraft","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c1fb35a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clearance before decision on liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vessel or aircraft may be granted clearance before a decision on liability is made under paragraph (1) only if a bond approved by the Attorney General or an amount sufficient to pay the civil penalty is deposited with the Commissioner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c1fb35b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on clearance while penalty unpaid","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vessel or aircraft may not be granted clearance if a civil penalty imposed under paragraph (1) is not paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c1fb35c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discontinuing granting visas to nationals of country denying or delaying accepting alien","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On being notified by the Attorney General that the government of a foreign country denies or unreasonably delays accepting an alien who is a citizen, subject, national, or resident of that country after the Attorney General asks whether the government will accept the alien under this section, the Secretary of State shall order consular officers in that foreign country to discontinue granting immigrant visas or nonimmigrant visas, or both, to citizens, subjects, nationals, and residents of that country until the Attorney General notifies the Secretary that the country has accepted the alien.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c1fb35d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1253/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by attorney general of a State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The attorney general of a State, or other authorized State officer, alleging a violation of the requirement to discontinue granting visas to citizens, subjects, nationals, and residents as described in subsection (d) that harms such State or its residents shall have standing to bring an action against the Secretary of State on behalf of such State or the residents of such State in an appropriate district court of the United States to obtain appropriate injunctive relief. The court shall advance on the docket and expedite the disposition of a civil action filed under this subsection to the greatest extent practicable. For purposes of this subsection, a State or its residents shall be considered to have been harmed if the State or its residents experience harm, including financial harm in excess of $100.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c1fb35e-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title II, ch. 5, § 243, "},{"tag":"ref","attrib":{"href":"/us/stat/66/212"},"text":"66 Stat. 212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/236/s11/f"},"text":"Pub. L. 89–236, § 11(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-03"},"text":"Oct. 3, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/918"},"text":"79 Stat. 918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/549/tI/s104"},"text":"Pub. L. 95–549, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-30"},"text":"Oct. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2066"},"text":"92 Stat. 2066","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/212/tII/s203/e"},"text":"Pub. L. 96–212, title II, § 203(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-17"},"text":"Mar. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/107"},"text":"94 Stat. 107","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/116/s18/i"},"text":"Pub. L. 97–116, § 18(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1620"},"text":"95 Stat. 1620","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/tV/s515/a/2"},"text":"Pub. L. 101–649, title V, § 515(a)(2)","children":[],"tail":", title VI, § 603(b)(3), "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5053"},"text":"104 Stat. 5053","children":[],"tail":", 5085; "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tIV/s413/a"},"text":"Pub. L. 104–132, title IV, § 413(a)","children":[],"tail":", (f), "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1269"},"text":"110 Stat. 1269","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII/s307/a"},"text":"Pub. L. 104–208, div. C, title III, § 307(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-612"},"text":"110 Stat. 3009–612","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/1/s3/c"},"text":"Pub. L. 119–1, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-29"},"text":"Jan. 29, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/4"},"text":"139 Stat. 4","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c1fb35f-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c1fb360-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c1fb361-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/1"},"text":"Pub. L. 119–1","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) to (h) relating to countries to which aliens were to be deported."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s413/a"},"text":"Pub. L. 104–132, § 413(a)","children":[],"tail":", inserted at end “For purposes of subparagraph (D), an alien who is described in "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1251/a/4/B"},"text":"section 1251(a)(4)(B) of this title","children":[],"tail":" shall be considered to be an alien for whom there are reasonable grounds for regarding as a danger to the security of the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s413/f"},"text":"Pub. L. 104–132, § 413(f)","children":[],"tail":", added par. (3) which read as follows: “Notwithstanding any other provision of law, paragraph (1) shall apply to any alien if the Attorney General determines, in the discretion of the Attorney General, that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) such alien’s life or freedom would be threatened, in the country to which such alien would be deported or returned, on account of race, religion, nationality, membership in a particular social group, or political opinion; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the application of paragraph (1) to such alien is necessary to ensure compliance with the 1967 United Nations Protocol Relating to the Status of Refugees.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (h)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649/s603/b/3"},"text":"Pub. L. 101–649, § 603(b)(3)","children":[],"tail":", substituted “1251(a)(4)(D)” for “1251(a)(19)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649/s515/a/2"},"text":"Pub. L. 101–649, § 515(a)(2)","children":[],"tail":", inserted sentence at end relating to aliens who have been convicted of aggravated felonies."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/116"},"text":"Pub. L. 97–116","children":[],"tail":" inserted a comma after “subject” in fourth sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/212"},"text":"Pub. L. 96–212","children":[],"tail":" substituted provisions relating to deportation or return of an alien where the Attorney General determines that the return would threaten the life or freedom of the alien on account of race, religion, nationality, membership in a particular social group, or political opinion, for provisions relating to withholding of deportation for any necessary period of time where the Attorney General decides the alien would be subject to persecution on account of race, religion, or political opinion."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/549"},"text":"Pub. L. 95–549","children":[],"tail":" inserted “(other than an alien described in "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1251/a"},"text":"section 1251(a) of this title","children":[],"tail":")” before “within the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/236"},"text":"Pub. L. 89–236","children":[],"tail":" substituted “persecution on account of race, religion, or political opinion” for “physical persecution”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c1fb362-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c1fb363-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" effective, with certain transitional provisions, on the first day of the first month beginning more than 180 days after "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s309"},"text":"section 309 of Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/tIV/s413/g"},"text":"Pub. L. 104–132, title IV, § 413(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"h