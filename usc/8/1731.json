{"tag":"section","attrib":{"id":"id9c70b9ff-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1731"},"text":null,"children":[{"tag":"num","attrib":{"value":"1731"},"text":"§ 1731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of an integrated entry and exit data system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c70ba00-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1731/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the integrated entry and exit data system for the ports of entry, as required by the Immigration and Naturalization Service Data Management Improvement Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/215"},"text":"Public Law 106–215","children":[],"tail":"), the Attorney General and the Secretary of State shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c70ba01-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1731/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement, fund, and use a technology standard under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1379"},"text":"section 1379 of this title","children":[],"tail":" at United States ports of entry and at consular posts abroad;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70ba02-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1731/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a database containing the arrival and departure data from machine-readable visas, passports, and other travel and entry documents possessed by aliens; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70ba03-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1731/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make interoperable all security databases relevant to making determinations of admissibility under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182"},"text":"section 1182 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70ba04-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1731/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In implementing the provisions of subsection (a), the Immigration and Naturalization Service and the Department of State shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c70ba05-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1731/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize technologies that facilitate the lawful and efficient cross-border movement of commerce and persons without compromising the safety and security of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70ba06-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1731/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider implementing the North American National Security Program described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1751"},"text":"section 1751 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c70ba07-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/173/tIII/s302"},"text":"Pub. L. 107–173, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/552"},"text":"116 Stat. 552","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c70ba08-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c70ba09-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c70ba0a-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Immigration and Naturalization Service Data Management Improvement Act of 2000, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/215"},"text":"Pub. L. 106–215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-15"},"text":"June 15, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/337"},"text":"114 Stat. 337","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1365a"},"text":"section 1365a of this title","children":[],"tail":" and enacted provisions set out as notes under sections 1101 and 1365a of this title. For complete classification of this Act to the Code, see Short Title of 2000 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c70ba0b-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c70ba0c-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
