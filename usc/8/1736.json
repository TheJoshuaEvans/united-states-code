{"tag":"section","attrib":{"id":"id9c70ba49-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1736"},"text":null,"children":[{"tag":"num","attrib":{"value":"1736"},"text":"§ 1736.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Check of lookout databases","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Prior to the admission of an alien under the visa waiver program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1187"},"text":"section 1187 of this title","children":[],"tail":", the Immigration and Naturalization Service shall determine that the applicant for admission does not appear in any of the appropriate lookout databases available to immigration inspectors at the time the alien seeks admission to the United States."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9c70ba4a-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/173/tIII/s307/b"},"text":"Pub. L. 107–173, title III, § 307(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/556"},"text":"116 Stat. 556","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c70ba4b-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c70ba4c-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c70ba4d-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
