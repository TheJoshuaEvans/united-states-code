{"tag":"section","attrib":{"id":"id9c4a93dd-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1378a"},"text":"§ 1378a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on aliens detained","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 7 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", and updated semimonthly thereafter, the Director of U.S. Immigration and Customs Enforcement shall make available a report, on a publicly accessible website in a downloadable, searchable, and sortable format, with not less than the previous twelve months of semimonthly data as of the last date of each such reporting period; on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c4a93de-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" aliens detained by such agency, including data disaggregated by single adults and members of family units on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c4a93df-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average fiscal year-to-date daily populations of aliens detained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93e0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the daily count of aliens detained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93e1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fiscal year-to-date total for book-ins;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93e2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average lengths of stay, including average post-determination length of stay in the case of detainees described in subparagraph (F);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93e3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number transferred to the custody of U.S. Immigration and Customs Enforcement by U.S. Customs and Border Protection after being—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c4a93e4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deemed inadmissible at a port of entry or after being apprehended within 14 days of entering the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c4a93e5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrested by U.S. Immigration and Customs Enforcement;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93e6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number determined to have a credible or reasonable fear of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c4a93e7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persecution, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1225/b/1/B/v"},"text":"section 1225(b)(1)(B)(v) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c4a93e8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" torture, as defined in section 208.30 of title 8, Code of Federal Regulations (as in effect on ","children":[{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93e9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number who have been issued a Notice to Appear pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1229"},"text":"section 1229 of this title","children":[],"tail":", disaggregated by single adults and members of family units; "},{"tag":"ref","attrib":{"idref":"fn002093"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002093"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Additional Reporting Requirements note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4a93ea-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total number of enrollees in the Alternatives to Detention program and the average length of participation, disaggregated by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c4a93eb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" single adults and family heads of household;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93ec-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participants in the family case management program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93ed-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" level of supervision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93ee-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location of supervision, by field office;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4a93ef-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each facility where aliens are detained by U.S. Immigration and Customs Enforcement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c4a93f0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the address;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93f1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the field offices that assign detainees to the facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93f2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the detailed facility type, as defined in the integrated decision support system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93f3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gender of aliens detained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93f4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average daily population of detainees within each detainee classification level, as defined in the integrated decision support system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93f5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average daily population of individuals within each threat level, as defined in the integrated decision support system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93f6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average daily population within each criminality category, as defined in the integrated decision support system, disaggregated by gender;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93f7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average length of stay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93f8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average daily population of individuals whose detention is classified as mandatory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93f9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the performance standards to which the facility is held;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93fa-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the two most recent inspections, the entity that performed each inspection, and a detailed summary of the results of such inspections; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4a93fb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/3/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the guaranteed minimum detention capacity, if applicable; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4a93fc-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1378a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of releases from custody, by condition of release, and total number of removals, disaggregated by adult facilities and family facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c4a93fd-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/93/dD/tII/s218"},"text":"Pub. L. 116–93, div. D, title II, § 218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2514"},"text":"133 Stat. 2514","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c4a93fe-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c4a93ff-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c4a9400-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of Homeland Security Appropriations Act, 2020, and also as part of the Consolidated Appropriations Act, 2020, and not as part of the Immigration and Nationality Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id9c4a9401-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/6/dA/tII/s226"},"text":"Pub. L. 116–6, div. A, title II, § 226","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-02-15"},"text":"Feb. 15, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/27"},"text":"133 Stat. 27","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c4a9402-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c4a9403-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Additional Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47/dC/tII/s215"},"text":"Pub. L. 118–47, div. C, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-23"},"text":"Mar. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/604"},"text":"138 Stat. 604","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/47/dC/tII/s215"},"text":"“The reports required to be submitted under section 216 of the Department of Homeland Security Appropriations Act, 2021 (division F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Public Law 116–260","children":[],"tail":") [set out below] shall continue to be submitted semimonthly and each matter required to be included in such reports by such section 216 shall apply in the same manner and to the same extent during the period described in such section 216.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dF/tII/s216"},"text":"Pub. L. 117–328, div. F, title II, § 216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4736"},"text":"136 Stat. 4736","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dF/tII/s217"},"text":"Pub. L. 117–103, div. F, title II, § 217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/323"},"text":"136 Stat. 323","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dF/tII/s216"},"text":"Pub. L. 116–260, div. F, title II, § 216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1457"},"text":"134 Stat. 1457","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dF/tII/s216"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The reports required to be submitted under section 218 of the Department of Homeland Security Appropriations Act, 2020 (division D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/93"},"text":"Public Law 116–93","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1378a"},"text":"8 U.S.C. 1378a","children":[],"tail":"] shall continue to be submitted with respect to the period beginning 15 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":"] and semimonthly thereafter, and each matter required to be included in such report by such section 218 shall apply in the same manner and to the same extent during the period described in this section, except that for purposes of reports submitted with respect to such period described, the following additional requirements shall be treated as being included as subparagraphs (H) through (J) of paragraph (1) of such section 218—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average lengths of stay, including average post-determination length of stay in the case of detainees described in subparagraph (F), for individuals who remain in detention as of the last date of each such reporting period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number who have been in detention, disaggregated by the number of detainees described in subparagraph (F), for each of the following—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" over 2 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from over 1 year to 2 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from over 6 months to 1 year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for less than 6 months; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals described in section 115.5 of title 28, Code of Federal Regulations, including the use and duration of solitary confinement for such person.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
