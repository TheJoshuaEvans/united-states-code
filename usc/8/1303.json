{"tag":"section","attrib":{"id":"id9c2e0beb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1303"},"text":null,"children":[{"tag":"num","attrib":{"value":"1303"},"text":"§ 1303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration of special groups","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c2e0bec-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the provisions of sections 1301 and 1302 of this title, the Attorney General is authorized to prescribe special regulations and forms for the registration and fingerprinting of (1) alien crewmen, (2) holders of border-crossing identification cards, (3) aliens confined in institutions within the United States, (4) aliens under order of removal, (5) aliens who are or have been on criminal probation or criminal parole within the United States, and (6) aliens of any other class not lawfully admitted to the United States for permanent residence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c2e0bed-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1302"},"text":"section 1302 of this title","children":[],"tail":" and of this section shall not be applicable to any alien who is in the United States as a nonimmigrant under section 1101(a)(15)(A) or (a)(15)(G) of this title until the alien ceases to be entitled to such a nonimmigrant status."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c2e0bee-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 