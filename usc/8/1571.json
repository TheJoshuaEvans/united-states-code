{"tag":"section","attrib":{"id":"id9c64d326-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1571"},"text":null,"children":[{"tag":"num","attrib":{"value":"1571"},"text":"§ 1571.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c64d327-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1571/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this subchapter are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c64d328-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1571/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the Immigration and Naturalization Service with the mechanisms it needs to eliminate the current backlog in the processing of immigration benefit applications within 1 year after ","children":[{"tag":"date","attrib":{"date":"2000-10-17"},"text":"October 17, 2000","children":[],"tail":", and to maintain the elimination of the backlog in future years; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c64d329-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1571/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for regular congressional oversight of the performance of the Immigration and Naturalization Service in eliminating the backlog and processing delays in immigration benefits adjudications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c64d32a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1571/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that the processing of an immigration benefit application should be completed not later than 180 days after the initial filing of the application, except that a petition for a nonimmigrant visa under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1184/c"},"text":"section 1184(c) of this title","children":[],"tail":" should be processed not later than 30 days after the filing of the petition."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c64d32b-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/313/tII/s202"},"text":"Pub. L. 106–313, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1262"},"text":"114 Stat. 1262","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c64d32c-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c64d32d-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id9c64d32e-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/313"},"text":"Pub. L. 106–313","children":[],"tail":", which enacted this subchapter, as the “Immigration Services and Infrastructure Improvements Act of 2000”, see "},{"tag":"ref","attrib":{"href":"/us/pl/106/313/s201"},"text":"section 201 of Pub. L. 106–313","children":[],"tail":", set out as a Short Title of 2000 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c64d32f-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
