{"tag":"section","attrib":{"id":"id9c51c086-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1437"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437"},"text":"§ 1437.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resident Philippine citizens excepted from certain requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person who (1) was a citizen of the Commonwealth of the Philippines on ","children":[{"tag":"date","attrib":{"date":"1946-07-02"},"text":"July 2, 1946","children":[],"tail":", (2) entered the United States prior to "},{"tag":"date","attrib":{"date":"1934-05-01"},"text":"May 1, 1934","children":[],"tail":", and (3) has, since such entry, resided continuously in the United States shall be regarded as having been lawfully admitted to the United States for permanent residence for the purpose of applying for naturalization under this subchapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9c51c087-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title III, ch. 2, § 326, "},{"tag":"ref","attrib":{"href":"/us/stat/66/248"},"text":"66 Stat. 248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/tIV/s407/c/9"},"text":"Pub. L. 101–649, title IV, § 407(c)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5041"},"text":"104 Stat. 5041","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c51c088-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c51c089-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"childr