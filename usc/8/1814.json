{"tag":"section","attrib":{"id":"id9c77e5b2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1814"},"text":null,"children":[{"tag":"num","attrib":{"value":"1814"},"text":"§ 1814.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fee for aliens ordered removed in absentia","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c77e5b3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1814/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As partial reimbursement for the cost of arresting an alien described in this section, the Secretary of Homeland Security, except as provided in subsection (c), shall require the payment of a fee, equal to the amount specified in subsection (b) on any alien who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c77e5b4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1814/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is ordered removed in absentia pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1229a/b/5"},"text":"section 1229a(b)(5) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c77e5b5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1814/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subsequently arrested by U.S. Immigration and Customs Enforcement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c77e5b6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1814/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount specified","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c77e5b7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1814/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For fiscal year 2025, the amount specified in this section shall be the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c77e5b8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1814/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c77e5b9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1814/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount as the Secretary of Homeland Security may establish, by rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c77e5ba-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1814/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual adjustments for inflation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During fiscal year 2026, and during each subsequent fiscal year, the amount specified in this section shall be equal to the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c77e5bb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1814/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the fee required under this subsection for the most recently concluded fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c77e5bc-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1814/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product resulting from the multiplication of the amount referred to in subparagraph (A) by the percentage (if any) by which the Consumer Price Index for All Urban Consumers for the month of July preceding the date on which such adjustment takes effect exceeds the Consumer Price Index for All Urban Consumers for the same month of the preceding calendar year, rounded to the next lowest multiple of $10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c77e5bd-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1814/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fee described in this section shall not apply to any alien who was ordered removed in absentia if such order was rescinded pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1229a/b/5/C"},"text":"section 1229a(b)(5)(C) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c77e5be-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1814/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of removal in absentia fees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During each fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c77e5bf-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1814/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 50 percent of the fees collected pursuant to this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c77e5c0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1814/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be credited to U.S. Immigration and Customs Enforcement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c77e5c1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1814/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be deposited into the Detention and Removal Office Fee Account; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c77e5c2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1814/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be retained and expended by U.S. Immigration and Customs Enforcement without further appropriation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c77e5c3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1814/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts collected pursuant to this section that are not credited to U.S. Immigration and Customs Enforcement pursuant to paragraph (1) shall be deposited into the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c77e5c4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1814/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No fee waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees required to be paid under this section shall not be waived or reduced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c77e5c5-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tX/s100016"},"text":"Pub. L. 119–21, title X, § 100016","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/384"},"text":"139 Stat. 384","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
