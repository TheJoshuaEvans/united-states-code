{"tag":"section","attrib":{"id":"id9c732b4e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1802"},"text":null,"children":[{"tag":"num","attrib":{"value":"1802"},"text":"§ 1802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asylum fee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c732b4f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1802/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other fee authorized by law, the Secretary of Homeland Security or the Attorney General, as applicable, shall require the payment of a fee, equal to the amount specified in this section, by any alien who files an application for asylum under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1158"},"text":"section 1158 of this title","children":[],"tail":" at the time such application is filed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c732b50-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1802/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During fiscal year 2025, the amount specified in this section shall be the greater of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c732b51-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1802/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732b52-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1802/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount as the Secretary or the Attorney General, as applicable, may establish, by rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c732b53-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1802/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual adjustments for inflation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During fiscal year 2026, and during each subsequent fiscal year, the amount specified in this section shall be equal to the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c732b54-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1802/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the fee required under this section for the most recently concluded fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732b55-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1802/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product resulting from the multiplication of the amount referred to in paragraph (1) by the percentage (if any) by which the Consumer Price Index for All Urban Consumers for the month of July preceding the date on which such adjustment takes effect exceeds the Consumer Price Index for All Urban Consumers for the same month of the preceding calendar year, rounded to the next lowest multiple of $10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c732b56-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1802/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of asylum fee proceeds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During each fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c732b57-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1802/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 50 percent of the fees received from aliens filing applications with the Attorney General—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c732b58-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1802/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be credited to the Executive Office for Immigration Review; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732b59-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1802/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be retained and expended without further appropriation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732b5a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1802/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 50 percent of fees received from aliens filing applications with the Secretary of Homeland Security—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c732b5b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1802/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be credited to U.S. Citizenship and Immigration Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732b5c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1802/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be deposited into the Immigration Examinations Fee Account established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1356/m"},"text":"section 1356(m) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732b5d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1802/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be retained and expended without further appropriation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732b5e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1802/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts received in fees required under this section that were not credited to the Executive Office for Immigration Review pursuant to paragraph (1) or to U.S. Citizenship and Immigration Services pursuant to paragraph (2) shall be deposited into the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c732b5f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1802/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No fee waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees required to be paid under this section shall not be waived or reduced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c732b60-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tX/s100002"},"text":"Pub. L. 119–21, title X, § 100002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/364"},"text":"139 Stat. 364","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
