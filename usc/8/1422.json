{"tag":"section","attrib":{"id":"id9c4d05c3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1422"},"text":null,"children":[{"tag":"num","attrib":{"value":"1422"},"text":"§ 1422.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for naturalization","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The right of a person to become a naturalized citizen of the United States shall not be denied or abridged because of race or sex or because such person is married.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9c4d05c4-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title III, ch. 2, § 311, "},{"tag":"ref","attrib":{"href":"/us/stat/66/239"},"text":"66 Stat. 239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/525/s9/t"},"text":"Pub. L. 100–525, § 9(t)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2621"},"text":"102 Stat. 2621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c4d05c5-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c4d05c6-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c4d05c7-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/525"},"text":"Pub. L. 100–525","children":[],"tail":" struck out at end “Notwithstanding section 405(b) of this Act, this section shall apply to any person whose petition for naturalization shall hereafter be filed, or shall have been pending on the effective date of this chapter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
