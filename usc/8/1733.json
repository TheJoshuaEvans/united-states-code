{"tag":"section","attrib":{"id":"id9c70ba24-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1733"},"text":null,"children":[{"tag":"num","attrib":{"value":"1733"},"text":"§ 1733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terrorist lookout committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c70ba25-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1733/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall require a terrorist lookout committee to be maintained within each United States mission to a foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70ba26-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1733/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of each committee established under subsection (a) shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c70ba27-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1733/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to utilize the cooperative resources of all elements of the United States mission in the country in which the consular post is located to identify known or potential terrorists and to develop information on those individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70ba28-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1733/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that such information is routinely and consistently brought to the attention of appropriate United States officials for use in administering the immigration laws of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70ba29-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1733/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that the names of known and suspected terrorists are entered into the appropriate lookout databases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70ba2a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1733/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition; chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish rules governing the composition of such committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70ba2b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1733/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each committee established under subsection (a) shall meet at least monthly to share information pertaining to the committee’s purpose as described in subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70ba2c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1733/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic reports to the Secretary of State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each committee established under subsection (a) shall submit monthly reports to the Secretary of State describing the committee’s activities, whether or not information on known or suspected terrorists was developed during the month.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70ba2d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1733/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/dJ/tVII/s7034/i"},"text":"Pub. L. 113–235, div. J, title VII, § 7034(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2624"},"text":"128 Stat. 2624","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70ba2e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1733/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to implement this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c70ba2f-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/173/tIII/s304"},"text":"Pub. L. 107–173, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/554"},"text":"116 Stat. 554","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dJ/tVII/s7034/i"},"text":"Pub. L. 113–235, div. J, title VII, § 7034(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2624"},"text":"128 Stat. 2624","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c70ba30-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c70ba31-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c70ba32-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" struck out subsec. (f). Text read as follows: “The Secretary of State shall submit a report on a quarterly basis to the appropriate committees of Congress on the status of the committees established under subsection (a) of this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
