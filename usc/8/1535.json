{"tag":"section","attrib":{"id":"id9c628999-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535"},"text":null,"children":[{"tag":"num","attrib":{"value":"1535"},"text":"§ 1535.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c62899a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeal of denial of application for removal proceedings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c62899b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may seek a review of the denial of an order sought in an application filed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1533"},"text":"section 1533 of this title","children":[],"tail":". The appeal shall be filed in the United States Court of Appeals for the District of Columbia Circuit by notice of appeal filed not later than 20 days after the date of such denial."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c62899c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record on appeal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The entire record of the proceeding shall be transmitted to the Court of Appeals under seal, and the Court of Appeals shall hear the matter ex parte.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c62899d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard of review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Court of Appeals shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c62899e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review questions of law de novo; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c62899f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set aside a finding of fact only if such finding was clearly erroneous.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c6289a0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeal of determination regarding summary of classified information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c6289a1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States may take an interlocutory appeal to the United States Court of Appeals for the District of Columbia Circuit of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c6289a2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any determination by the judge pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1534/e/3"},"text":"section 1534(e)(3) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c6289a3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the refusal of the court to make the findings permitted by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1534/e/3"},"text":"section 1534(e)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6289a4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any interlocutory appeal taken pursuant to this subsection, the entire record, including any proposed order of the judge, any classified information and the summary of evidence, shall be transmitted to the Court of Appeals. The classified information shall be transmitted under seal. A verbatim record of such appeal shall be kept under seal in the event of any other judicial review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c6289a5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeal of decision in hearing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c6289a6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the decision of the judge after a removal hearing may be appealed by either the alien or the Attorney General to the United States Court of Appeals for the District of Columbia Circuit by notice of appeal filed not later than 20 days after the date on which the order is issued. The order shall not be enforced during the pendency of an appeal under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6289a7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automatic appeals in cases of permanent resident aliens in which no summary provided","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c6289a8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless the alien waives the right to a review under this paragraph, in any case involving an alien lawfully admitted for permanent residence who is denied a written summary of classified information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1534/e/3"},"text":"section 1534(e)(3) of this title","children":[],"tail":" and with respect to which the procedures described in "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1534/e/3/F"},"text":"section 1534(e)(3)(F) of this title","children":[],"tail":" apply, any order issued by the judge shall be reviewed by the Court of Appeals for the District of Columbia Circuit."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c6289a9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of special attorney","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any issue relating to classified information that arises in such review, the alien shall be represented only by the special attorney designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1534/e/3/F/i"},"text":"section 1534(e)(3)(F)(i) of this title","children":[],"tail":" on behalf of the alien."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6289aa-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmittal of record","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In an appeal or review to the Court of Appeals pursuant to this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c6289ab-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entire record shall be transmitted to the Court of Appeals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c6289ac-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information received in camera and ex parte, and any portion of the order that would reveal the substance or source of such information, shall be transmitted under seal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6289ad-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited appellate proceeding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In an appeal or review to the Court of Appeals under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c6289ae-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appeal or review shall be heard as expeditiously as practicable and the court may dispense with full briefing and hear the matter solely on the record of the judge of the removal court and on such briefs or motions as the court may require to be filed by the parties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c6289af-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Court of Appeals shall issue an opinion not later than 60 days after the date of the issuance of the final order of the district court;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c6289b0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the court shall review all questions of law de novo; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c6289b1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a finding of fact shall be accorded deference by the reviewing court and shall not be set aside unless such finding was clearly erroneous, except that in the case of a review under paragraph (2) in which an alien lawfully admitted for permanent residence was denied a written summary of classified information under section 1534(c)(3) ","children":[{"tag":"ref","attrib":{"idref":"fn002100"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002100"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “1534(e)(3)”."}],"tail":" of this title, the Court of Appeals shall review questions of fact de novo."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c6289b2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certiorari","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Following a decision by the Court of Appeals pursuant to subsection (c), the alien or the Attorney General may petition the Supreme Court for a writ of certiorari. In any such case, any information transmitted to the Court of Appeals under seal shall, if such information is also submitted to the Supreme Court, be transmitted under seal. Any order of removal shall not be stayed pending disposition of a writ of certiorari, except as provided by the Court of Appeals or a Justice of the Supreme Court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c6289b3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeal of detention order","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c6289b4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sections 3145 through 3148 of title 18 pertaining to review and appeal of a release or detention order, penalties for failure to appear, penalties for an offense committed while on release, and sanctions for violation of a release condition shall apply to an alien to whom ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1537/b/1"},"text":"section 1537(b)(1) of this title","children":[],"tail":" applies. In applying the previous sentence—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c6289b5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of section 3145 of such title an appeal shall be taken to the United States Court of Appeals for the District of Columbia Circuit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c6289b6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of section 3146 of such title the alien shall be considered released in connection with a charge of an offense punishable by life imprisonment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6289b7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1535/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No review of continued detention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The determinations and actions of the Attorney General pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1537/b/2/C"},"text":"section 1537(b)(2)(C) of this title","children":[],"tail":" shall not be subject to judicial review, including application for a writ of habeas corpus, except for a claim by the alien that continued detention violates the alien’s rights under the Constitution. Jurisdiction over any such challenge shall lie exclusively in the United States Court of Appeals for the District of Columbia Circuit."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c6289b8-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title V, § 505, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tIV/s401/a"},"text":"Pub. L. 104–132, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1263"},"text":"110 Stat. 1263","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII/s354/a/3"},"text":"Pub. L. 104–208, div. C, title III, § 354(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-642"},"text":"110 Stat. 3009–642","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c6289b9-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c6289ba-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c6289bb-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s354/a/3/A"},"text":"Pub. L. 104–208, § 354(a)(3)(A)","children":[],"tail":", substituted “Subject to paragraph (2), the decision” for “The decision”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s354/a/3/D"},"text":"Pub. L. 104–208, § 354(a)(3)(D)","children":[],"tail":", added par. (2). Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s354/a/3/C"},"text":"Pub. L. 104–208, § 354(a)(3)(C)","children":[],"tail":", redesignated par. (2) as (3). Former par. (3) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s354/a/3/B"},"text":"Pub. L. 104–208, § 354(a)(3)(B)","children":[],"tail":", inserted before period at end “, except that in the case of a review under paragraph (2) in which an alien lawfully admitted for permanent residence was denied a written summary of classified information under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1534/c/3"},"text":"section 1534(c)(3) of this title","children":[],"tail":", the Court of Appeals shall review questions of fact de novo”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s354/a/3/C"},"text":"Pub. L. 104–208, § 354(a)(3)(C)","children":[],"tail":", redesignated par. (3) as (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c6289bc-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c6289bd-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" effective as if included in the enactment of subtitle A of title IV of the Antiterrorism and Effective Death Penalty Act of 1996, "},{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s358"},"text":"section 358 of Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182"},"text":"section 1182 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c6289be-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c6289bf-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Order of Removal Deemed To Include Order of Exclusion and Deportation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For purposes of carrying out this chapter, any reference in law to an order of removal is deemed to include a reference to an order of exclusion and deportation or an order of deportation, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s309/d/2"},"text":"section 309(d)(2) of Pub. L. 104–208","children":[],"tail":", set out in an Effective Date of 1996 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
