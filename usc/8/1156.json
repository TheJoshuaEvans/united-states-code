{"tag":"section","attrib":{"id":"id9bd82303-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1156"},"text":null,"children":[{"tag":"num","attrib":{"value":"1156"},"text":"§ 1156.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unused immigrant visas","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If an immigrant having an immigrant visa is denied admission to the United States and removed, or does not apply for admission before the expiration of the validity of his visa, or if an alien having an immigrant visa issued to him as a preference immigrant is found not to be a preference immigrant, an immigrant visa or a preference immigrant visa, as the case may be, may be issued in lieu thereof to another qualified alien.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9bd82304-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title II, ch. 1, § 206, "},{"tag":"ref","attrib":{"href":"/us/stat/66/181"},"text":"66 Stat. 181","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/236/s6"},"text":"Pub. L. 89–236, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-03"},"text":"Oct. 3, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/916"},"text":"79 Stat. 916","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII/s308/d/4/D"},"text":"Pub. L. 104–208, div. C, title III, § 308(d)(4)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-618"},"text":"110 Stat. 3009–618","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9bd82305-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9bd82306-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9bd82307-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" substituted “denied admission to the United States and removed” for “excluded from admission to the United States and deported”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/236"},"text":"Pub. L. 89–236","children":[],"tail":" substituted provisions allowing immigrant visas or preference immigrant visas to be issued to another qualified alien in lieu of immigrants excluded or deported, immigrants failing to apply for admission, or immigrants found not to be preference immigrants, for provisions relating to revocation of approval of petitions which, with minor amendments, were transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1155"},"text":"section 1155 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9bd82308-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9bd82309-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"tex