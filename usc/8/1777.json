{"tag":"section","attrib":{"id":"id9c732af8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777"},"text":null,"children":[{"tag":"num","attrib":{"value":"1777"},"text":"§ 1777.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Human Smuggling and Trafficking Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c732af9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a Human Smuggling and Trafficking Center (referred to in this section as the “Center”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c732afa-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, the Secretary of Homeland Security, and the Attorney General shall operate the Center in accordance with the Memorandum of Understanding entitled, “Human Smuggling and Trafficking Center (HSTC), Charter”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c732afb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to such other responsibilities as the President may assign, the Center shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c732afc-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the focal point for interagency efforts to integrate and disseminate intelligence and information related to terrorist travel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732afd-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a clearinghouse with respect to all relevant information from all Federal Government agencies in support of the United States strategy to prevent separate, but related, issues of clandestine terrorist travel and facilitation of migrant smuggling and trafficking of persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732afe-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure cooperation among all relevant policy, law enforcement, diplomatic, and intelligence agencies of the Federal Government to improve effectiveness and to convert all information available to the Federal Government relating to clandestine terrorist travel and facilitation, migrant smuggling, and trafficking of persons into tactical, operational, and strategic intelligence that can be used to combat such illegal activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732aff-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to Congress, on an annual basis, a strategic assessment regarding vulnerabilities in the United States and foreign travel system that may be exploited by international terrorists, human smugglers and traffickers, and their facilitators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c732b00-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Homeland Security shall nominate an official of the Government of the United States to serve as the Director of the Center, in accordance with the requirements of the memorandum of understanding entitled the “Human Smuggling and Trafficking Center (HSTC) Charter”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c732b01-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staffing of the Center","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c732b02-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Homeland Security, in cooperation with heads of other relevant agencies and departments, shall ensure that the Center is staffed with not fewer than 40 full-time equivalent positions, including, as appropriate, detailees from the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c732b03-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Agencies and offices within the Department of Homeland Security, including the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c732b04-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Intelligence and Analysis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b05-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Transportation Security Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b06-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States Citizenship and Immigration Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b07-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States Customs and Border Protection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b08-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b09-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States Immigration and Customs Enforcement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732b0a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Other departments, agencies, or entities, including the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c732b0b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Central Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b0c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b0d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b0e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Counterterrorism Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b0f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Security Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b10-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b11-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b12-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/1/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other relevant agency or department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732b13-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expertise of detailees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Homeland Security, in cooperation with the head of each agency, department, or other entity referred to in paragraph (1), shall ensure that the detailees provided to the Center under such paragraph include an adequate number of personnel who are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c732b14-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence analysts or special agents with demonstrated experience related to human smuggling, trafficking in persons, or terrorist travel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732b15-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" personnel with experience in the areas of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c732b16-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consular affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b17-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counterterrorism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b18-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criminal law enforcement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b19-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b1a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevention and detection of document fraud;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b1b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" border inspection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b1c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immigration enforcement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b1d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" human trafficking and combating severe forms of trafficking in persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732b1e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced personnel management","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c732b1f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentives for service in certain positions","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c732b20-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Homeland Security, and the heads of other relevant agencies, shall prescribe regulations or promulgate personnel policies to provide incentives for service on the staff of the Center, particularly for serving terms of at least two years duration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b21-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forms of incentives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Incentives under clause (i) may include financial incentives, bonuses, and such other awards and incentives as the Secretary and the heads of other relevant agencies,","children":[{"tag":"ref","attrib":{"idref":"fn002116"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002116"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" consider appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732b22-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced promotion for service at the Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary of Homeland Security, and the heads of other relevant agencies, shall ensure that personnel who are assigned or detailed to service at the Center shall be considered for promotion at rates equivalent to or better than similarly situated personnel of such agencies who are not so assigned or detailed, except that this subparagraph shall not apply in the case of personnel who are subject to the provisions of the Foreign Service Act of 1980 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"22 U.S.C. 3901","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c732b23-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative support and funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Homeland Security shall provide to the Center the administrative support and funding required for its maintenance, including funding for personnel, leasing of office space, supplies, equipment, technology, training, and travel expenses necessary for the Center to carry out its functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c732b24-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c732b25-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2004-12-17"},"text":"December 17, 2004","children":[],"tail":", the President shall transmit to Congress a report regarding the implementation of this section, including a description of the staffing and resource needs of the Center."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732b26-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Follow-up report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":", the President shall transmit to Congress a report regarding the operation of the Center and the activities carried out by the Center, including a description of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c732b27-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the roles and responsibilities of each agency or department that is participating in the Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732b28-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mechanisms used to share information among each such agency or department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732b29-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the personnel provided to the Center by each such agency or department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732b2a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of information and reports being disseminated by the Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732b2b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/g/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any efforts by the Center to create a centralized Federal Government database to store information related to unlawful travel of foreign nationals, including a description of any such database and of the manner in which information utilized in such a database would be collected, stored, and shared;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732b2c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/g/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how each agency and department shall utilize its resources to ensure that the Center uses intelligence to focus and drive its efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732b2d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/g/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to consolidate networked systems for the Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732b2e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/g/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mechanisms for the sharing of homeland security information from the Center to the Office of Intelligence and Analysis, including how such sharing shall be consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s485/b"},"text":"section 485(b) of title 6","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732b2f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/g/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of participating personnel in the Center to freely access necessary databases and share information regarding issues related to human smuggling, trafficking in persons, and terrorist travel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732b30-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/g/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the assignment of personnel to the Center is incorporated into the civil service career path of such personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732b31-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/g/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperation and coordination efforts, including any memorandums of understanding, among participating agencies and departments regarding issues related to human smuggling, trafficking in persons, and terrorist travel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c732b32-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to the NCTC","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of its mission to combat terrorist travel, the Center shall work to support the efforts of the National Counterterrorism Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c732b33-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1777/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with the Office of Intelligence and Analysis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Intelligence and Analysis, in coordination with the Center, shall submit to relevant State, local, and tribal law enforcement agencies periodic reports regarding terrorist threats related to human smuggling, human trafficking, and terrorist travel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c732b34-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVII/s7202"},"text":"Pub. L. 108–458, title VII, § 7202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3813"},"text":"118 Stat. 3813","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tVII/s721/a"},"text":"Pub. L. 110–53, title VII, § 721(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/346-348"},"text":"121 Stat. 346–348","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c732b35-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c732b36-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c732b37-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Service Act of 1980, referred to in subsec. (e)(3)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465"},"text":"Pub. L. 96–465","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2071"},"text":"94 Stat. 2071","children":[],"tail":", which is classified principally to chapter 52 (§ 3901 et seq.) of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c732b38-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Intelligence Reform and Terrorism Prevention Act of 2004, and also as part of the 9/11 Commission Implementation Act of 2004, and not as part of the Enhanced Border Security and Visa Entry Reform Act of 2002 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c732b39-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s721/a/1"},"text":"Pub. L. 110–53, § 721(a)(1)","children":[],"tail":", substituted “integrate and disseminate intelligence and information related to” for “address”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s721/a/3"},"text":"Pub. L. 110–53, § 721(a)(3)","children":[],"tail":", added subsecs. (d) to (f). Former subsecs. (d) and (e) redesignated (g) and (h), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s721/b"},"text":"Pub. L. 110–53, § 721(b)","children":[],"tail":", reenacted heading without change and amended text of subsec. (g) generally. Prior to amendment, text read as follows: “Not later than 180 days after "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"December 17, 2004","children":[],"tail":", the President shall transmit to Congress a report regarding the implementation of this section, including a description of the staffing and resource needs of the Center.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s721/a/2"},"text":"Pub. L. 110–53, § 721(a)(2)","children":[],"tail":", redesignated subsec. (d) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s721/a/2"},"text":"Pub. L. 110–53, § 721(a)(2)","children":[],"tail":", redesignated subsec. (e) as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s721/c"},"text":"Pub. L. 110–53, § 721(c)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id9c732b3a-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id9c732b3b-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For assignment of functions of President under subsec. (g) of this section, see section 1 of Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", 70 F.R. 48633, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
