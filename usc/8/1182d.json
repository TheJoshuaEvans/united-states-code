{"tag":"section","attrib":{"id":"id9bf71c94-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1182d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1182d"},"text":"§ 1182d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of visas to confiscators of American property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9bf71c95-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1182d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of visas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6091"},"text":"section 6091 of title 22","children":[],"tail":", and subject to subsection (b), the Secretary of State may deny the issuance of a visa to any alien who—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9bf71c96-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1182d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through the abuse of position, including a governmental or political party position, converts or has converted for personal gain real property that has been confiscated or expropriated, a claim to which is owned by a national of the United States, or who is complicit in such a conversion; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9bf71c97-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1182d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" induces any of the actions or omissions described in paragraph (1) by any person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9bf71c98-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1182d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9bf71c99-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1182d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any country established by international mandate through the United Nations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9bf71c9a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1182d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any territory recognized by the United States Government to be in dispute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9bf71c9b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1182d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"October 21, 1998","children":[],"tail":", and every 12 months thereafter, the Secretary of State shall submit to the Speaker of the House of Representatives and to the chairman of the Committee on Foreign Relations of the Senate a report, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9bf71c9c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1182d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of aliens who have been denied a visa under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9bf71c9d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1182d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of aliens who could have been denied a visa under subsection (a) but were issued a visa and an explanation as to why each such visa was issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9bf71c9e-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. B, title XXII, § 2225, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-819"},"text":"112 Stat. 2681–819","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9bf71c9f-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9bf71ca0-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9bf71ca1-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Foreign Relations Authorization Act, Fiscal Years 1998 and 1999, and also as part of the Foreign Affairs Reform and Restructuring Act of 1998, and the Omnibus Consolidated and Emergency Supplemental Appropriations Act, 1999, and not as part of the Immigration and Nationality Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
