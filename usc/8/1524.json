 $14,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/605/s2/b/3"},"text":"Pub. L. 99–605, § 2(b)(3)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/363/s2"},"text":"Pub. L. 97–363, § 2","children":[],"tail":", substituted provisions with regard to fiscal 1983 authorizing appropriation of sums necessary to carry out provisions of this chapter, authorizing appropriations of $100,000,000 for services to refugees under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1522/c"},"text":"section 1522(c) of this title","children":[],"tail":", and authorizing appropriations of $14,000,000 for the purpose of carrying out "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1522/b/5"},"text":"section 1522(b)(5) of this title","children":[],"tail":", for provisions with regard to fiscal 1980 and each of the two succeeding fiscal years authorizing appropriation of sums necessary for initial resettlement assistance, cash and medical assistance, and child welfare services under subsecs. (b)(1), (3), (4), (d)(2), and (e) of "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1522"},"text":"section 1522 of this title","children":[],"tail":", and authorizing appropriations of $200,000,000 for other programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c60180c-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c60180d-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":nu