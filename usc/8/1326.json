{"tag":"section","attrib":{"id":"id9c39f2a2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1326"},"text":null,"children":[{"tag":"num","attrib":{"value":"1326"},"text":"§ 1326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reentry of removed aliens","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c39f2a3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1326/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), any alien who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c39f2a4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1326/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been denied admission, excluded, deported, or removed or has departed the United States while an order of exclusion, deportation, or removal is outstanding, and thereafter","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c39f2a5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1326/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enters, attempts to enter, or is at any time found in, the United States, unless (A) prior to his reembarkation at a place outside the United States or his application for admission from foreign contiguous territory, the Attorney General has expressly consented to such alien’s reapplying for admission; or (B) with respect to an alien previously denied admission and removed, unless such alien shall establish that he was not required to obtain such advance consent under this chapter or any prior Act,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under title 18, or imprisoned not more than 2 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c39f2a6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1326/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties for reentry of certain removed aliens","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (a), in the case of any alien described in such subsection—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c39f2a7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1326/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose removal was subsequent to a conviction for commission of three or more misdemeanors involving drugs, crimes against the person, or both, or a felony (other than an aggravated felony), such alien shall be fined under title 18, imprisoned not more than 10 years, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c39f2a8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1326/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose removal was subsequent to a conviction for commission of an aggravated felony, such alien shall be fined under such title, imprisoned not more than 20 years, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c39f2a9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1326/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has been excluded from the United States pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1225/c"},"text":"section 1225(c) of this title","children":[],"tail":" because the alien was excludable under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182/a/3/B"},"text":"section 1182(a)(3)(B) of this title","children":[],"tail":" or who has been removed from the United States pursuant to the provisions of subchapter V, and who thereafter, without the permission of the Attorney General, enters the United States, or attempts to do so, shall be fined under title 18 and imprisoned for a period of 10 years, which sentence shall not run concurrently with any other sentence."},{"tag":"ref","attrib":{"idref":"fn002070"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002070"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":" or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c39f2aa-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1326/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who was removed from the United States pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1231/a/4/B"},"text":"section 1231(a)(4)(B) of this title","children":[],"tail":" who thereafter, without the permission of the Attorney General, enters, attempts to enter, or is at any time found in, the United States (unless the Attorney General has expressly consented to such alien’s reentry) shall be fined under title 18, imprisoned for not more than 10 years, or both."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For the purposes of this subsection, the term “removal” includes any agreement in which an alien stipulates to removal during (or not during) a criminal trial under either Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c39f2ab-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1326/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reentry of alien deported prior to completion of term of imprisonment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any alien deported pursuant to section 1252(h)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002071"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002071"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of this title who enters, attempts to enter, or is at any time found in, the United States (unless the Attorney General has expressly consented to such alien’s reentry) shall be incarcerated for the remainder of the sentence of imprisonment which was pending at the time of deportation without any reduction for parole or supervised release. Such alien shall be subject to such other penalties relating to the reentry of deported aliens as may be available under this section or any other provision of law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c39f2ac-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1326/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on collateral attack on underlying deportation order","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a criminal proceeding under this section, an alien may not challenge the validity of the deportation order described in subsection (a)(1) or subsection (b) unless the alien demonstrates that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c39f2ad-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1326/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alien exhausted any administrative remedies that may have been available to seek relief against the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c39f2ae-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1326/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deportation proceedings at which the order was issued improperly deprived the alien of the opportunity for judicial review; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c39f2af-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1326/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entry of the order was fundamentally unfair.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c39f2b0-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title II, ch. 8, § 276, "},{"tag":"ref","attrib":{"href":"/us/stat/66/229"},"text":"66 Stat. 229","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7345/a"},"text":"Pub. L. 100–690, title VII, § 7345(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4471"},"text":"102 Stat. 4471","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/tV/s543/b/3"},"text":"Pub. L. 101–649, title V, § 543(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5059"},"text":"104 Stat. 5059","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXIII/s130001/b"},"text":"Pub. L. 103–322, title XIII, § 130001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2023"},"text":"108 Stat. 2023","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tIV"},"text":"Pub. L. 104–132, title IV","children":[],"tail":", §§ 401(c), 438(b), 441(a), "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1267"},"text":"110 Stat. 1267","children":[],"tail":", 1276, 1279; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII"},"text":"Pub. L. 104–208, div. C, title III","children":[],"tail":", §§ 305(b), 308(d)(4)(J), (e)(1)(K), (14)(A), 324(a), (b), "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-606"},"text":"110 Stat. 3009–606","children":[],"tail":", 3009–618 to 3009–620, 3009–629.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c39f2b1-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c39f2b2-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c39f2b3-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(2), was in the original a reference to this Act, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":", known as the Immigration and Nationality Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1252"},"text":"Section 1252 of this title","children":[],"tail":", referred to in subsec. (c), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII/s306/a/2"},"text":"Pub. L. 104–208, div. C, title III, § 306(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-607"},"text":"110 Stat. 3009–607","children":[],"tail":", and, as so amended, does not contain a subsec. (h). For provisions similar to those formerly contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1252/h/2"},"text":"section 1252(h)(2) of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1231/a/4"},"text":"section 1231(a)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c39f2b4-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s308/e/14/A"},"text":"Pub. L. 104–208, § 308(e)(14)(A)","children":[],"tail":", amended section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s308/d/4/J/i"},"text":"Pub. L. 104–208, § 308(d)(4)(J)(i)","children":[],"tail":", substituted “denied admission, excluded, deported, or removed” for “arrested and deported, has been excluded and deported,” and “exclusion, deportation, or removal” for “exclusion or deportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s324/a"},"text":"Pub. L. 104–208, § 324(a)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “has been arrested and deported or excluded and deported, and thereafter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s308/d/4/J/ii"},"text":"Pub. L. 104–208, § 308(d)(4)(J)(ii)","children":[],"tail":", substituted “denied admission and removed” for “excluded and deported”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s324/b"},"text":"Pub. L. 104–208, § 324(b)","children":[],"tail":", inserted “(or not during)” after “during” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s308/e/1/K"},"text":"Pub. L. 104–208, § 308(e)(1)(K)","children":[],"tail":", substituted “removal” for “deportation” wherever appearing in pars. (1) and (2) and in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s305/b/1"},"text":"Pub. L. 104–208, § 305(b)(1)","children":[],"tail":", struck out “or” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s305/b/2"},"text":"Pub. L. 104–208, § 305(b)(2)","children":[],"tail":", inserted “or” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s401/c"},"text":"Pub. L. 104–132, § 401(c)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s305/b/3"},"text":"Pub. L. 104–208, § 305(b)(3)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s438/b"},"text":"Pub. L. 104–132, § 438(b)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s441/a"},"text":"Pub. L. 104–132, § 441(a)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", in par. (1), inserted “three or more misdemeanors involving drugs, crimes against the person, or both, or” after “commission of” and substituted “10” for “5”, in par. (2), substituted “20” for “15”, and added concluding sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649"},"text":"Pub. L. 101–649","children":[],"tail":" substituted “shall be fined under title 18, or imprisoned not more than 2 years” for “shall be guilty of a felony, and upon conviction thereof, be punished by imprisonment of not more than two years, or by a fine of not more than $1,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" designated existing provisions as subsec. (a), substituted “Subject to subsection (b), any alien” for “Any alien”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c39f2b5-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c39f2b6-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by sections 305(b) and 308(d)(4)(J), (e)(1)(K), (14)(A) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" effective, with certain transitional provisions, on the first day of the first month beginning more than 180 days after "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s309"},"text":"section 309 of Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII/s324/c"},"text":"Pub. L. 104–208, div. C, title III, § 324(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-629"},"text":"110 Stat. 3009–629","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/208/dC/tIII/s324/c"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to departures that occurred before, on, or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":"], but only with respect to entries (and attempted entries) occurring on or after such date.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/tIV/s401/f"},"text":"Pub. L. 104–132, title IV, § 401(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1268"},"text":"110 Stat. 1268","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/132/tIV/s401/f"},"text":"“The amendments made by this section [enacting sections 1531 to 1537 of this title and amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1105a"},"text":"section 1105a of this title","children":[],"tail":"] shall take effect on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":"] and shall apply to all aliens without regard to the date of entry or attempted entry into the United States.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/tIV/s441/b"},"text":"Pub. L. 104–132, title IV, § 441(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1279"},"text":"110 Stat. 1279","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/132/tIV/s441/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to criminal proceedings initiated after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c39f2b7-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","child