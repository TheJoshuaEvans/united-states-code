{"tag":"section","attrib":{"id":"id9c45d939-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1370"},"text":null,"children":[{"tag":"num","attrib":{"value":"1370"},"text":"§ 1370.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of States and localities for emergency ambulance services","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the Attorney General shall fully reimburse States and political subdivisions of States for costs incurred by such a State or subdivision for emergency ambulance services provided to any alien who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c45d93a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1370/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is injured while crossing a land or sea border of the United States without inspection or at any time or place other than as designated by the Attorney General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c45d93b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1370/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is under the custody of the State or subdivision pursuant to a transfer, request, or other action by a Federal authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c45d93c-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tV/s563"},"text":"Pub. L. 104–208, div. C, title V, § 563","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-683"},"text":"110 Stat. 3009–683","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c45d93d-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c45d93e-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c45d93f-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Illegal Immigration Reform and Immigrant Responsibility Act of 1996, and also as part of the Omnibus Consolidated Appropriations Act, 1997, and not as part of the Immigration and Nationality Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c45d940-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c45d941-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
