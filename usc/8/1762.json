{"tag":"section","attrib":{"id":"id9c732a9b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1762"},"text":null,"children":[{"tag":"num","attrib":{"value":"1762"},"text":"§ 1762.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of institutions and other entities authorized to enroll or sponsor certain nonimmigrants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c732a9c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1762/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic review of compliance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than two years after ","children":[{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", and every two years thereafter, the Commissioner of Immigration and Naturalization, in consultation with the Secretary of Education, shall conduct a review of the institutions certified to receive nonimmigrants under section 1101(a)(15)(F), (M), or (J) of this title. Each review shall determine whether the institutions are in compliance with—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c732a9d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1762/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recordkeeping and reporting requirements to receive nonimmigrants under section 1101(a)(15)(F), (M), or (J) of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732a9e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1762/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recordkeeping and reporting requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1372"},"text":"section 1372 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c732a9f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1762/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic review of sponsors of exchange visitors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c732aa0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1762/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for reviews","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than two years after ","children":[{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", and every two years thereafter, the Secretary of State shall conduct a review of the entities designated to sponsor exchange visitor program participants under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/15/J"},"text":"section 1101(a)(15)(J) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732aa1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1762/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the basis of reviews of entities under paragraph (1), the Secretary shall determine whether the entities are in compliance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c732aa2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1762/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recordkeeping and reporting requirements to receive nonimmigrant exchange visitor program participants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/15/J"},"text":"section 1101(a)(15)(J) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732aa3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1762/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recordkeeping and reporting requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1372"},"text":"section 1372 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c732aa4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1762/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of material failure to comply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Material failure of an institution or other entity to comply with the recordkeeping and reporting requirements to receive nonimmigrant students or exchange visitor program participants under section 1101(a)(15)(F), (M), or (J) of this title, or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1372"},"text":"section 1372 of this title","children":[],"tail":", shall result in the suspension for at least one year or termination, at the election of the Commissioner of Immigration and Naturalization, of the institution’s approval to receive such students, or result in the suspension for at least one year or termination, at the election of the Secretary of State, of the other entity’s designation to sponsor exchange visitor program participants, as the case may be."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c732aa5-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/173/tV/s502"},"text":"Pub. L. 107–173, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/563"},"text":"116 Stat. 563","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c732aa6-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c732aa7-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c732aa8-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
