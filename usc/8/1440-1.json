{"tag":"section","attrib":{"id":"id9c5430c9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1440–1"},"text":"§ 1440–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Posthumous citizenship through death while on active-duty service in armed forces during World War I, World War II, the Korean hostilities, the Vietnam hostilities, or in other periods of military hostilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c5430ca-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitting granting of posthumous citizenship","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subchapter, the Secretary of Homeland Security shall provide, in accordance with this section, for the granting of posthumous citizenship at the time of death to a person described in subsection (b) if the Secretary of Homeland Security approves an application for that posthumous citizenship under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c5430cb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncitizens eligible for posthumous citizenship","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person referred to in subsection (a) is a person who, while an alien or a noncitizen national of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c5430cc-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served honorably in an active-duty status in the military, air, or naval forces of the United States during any period described in the first sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1440/a"},"text":"section 1440(a) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c5430cd-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" died as a result of injury or disease incurred in or aggravated by that service, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c5430ce-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfied the requirements of clause (1) or (2) of the first sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1440/a"},"text":"section 1440(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The executive department under which the person so served shall determine whether the person satisfied the requirements of paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c5430cf-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for posthumous citizenship","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c5430d0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A request for the granting of posthumous citizenship to a person described in subsection (b) may be filed on behalf of that person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c5430d1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon locating the next-of-kin, and if so requested by the next-of-kin, by the Secretary of Defense or the Secretary’s designee with the Bureau of Citizenship and Immigration Services in the Department of Homeland Security immediately upon the death of that person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c5430d2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the next-of-kin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c5430d3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Bureau of Citizenship and Immigration Services shall approve a request for posthumous citizenship filed by the next-of-kin in accordance with paragraph (1)(B) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c5430d4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the request is filed not later than 2 years after—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c5430d5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440–1/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2003-11-24"},"text":"November 24, 2003","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c5430d6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440–1/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the person’s death;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"whichever date is later;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c5430d7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the request is accompanied by a duly authenticated certificate from the executive department under which the person served which states that the person satisfied the requirements of paragraphs (1) and (2) of subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c5430d8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440–1/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director finds that the person satisfied the requirement of subsection (b)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c5430d9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documentation of posthumous citizenship","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Director of the Bureau of Citizenship and Immigration Services approves the request referred to in subsection (c), the Director shall send to the next-of-kin of the person who is granted citizenship, a suitable document which states that the United States considers the person to have been a citizen of the United States at the time of the person’s death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c5430da-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title III, ch. 2, § 329A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/249/s2/a"},"text":"Pub. L. 101–249, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-03-06"},"text":"Mar. 6, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/94"},"text":"104 Stat. 94","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11030/b"},"text":"Pub. L. 107–273, div. C, title I, § 11030(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1836"},"text":"116 Stat. 1836","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tXVII"},"text":"Pub. L. 108–136, div. A, title XVII","children":[],"tail":", §§ 1703(g), 1704, "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1695"},"text":"117 Stat. 1695","children":[],"tail":", 1696.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c5430db-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c5430dc-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c5430dd-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2003-11-24"},"text":"November 24, 2003","children":[],"tail":", referred to in subsec. (c)(2)(A)(i), was in the original “the date of enactment of this section”, which was translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":", which enacted subsec. (c) of this section, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c5430de-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1703/g/2"},"text":"Pub. L. 108–136, § 1703(g)(2)","children":[],"tail":", substituted “Secretary of Homeland Security” for “Attorney General” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1704/1"},"text":"Pub. L. 108–136, § 1704(1)","children":[],"tail":", added heading and text of subsec. (c) and struck out former subsec. (c) which related to procedures for approval by the Attorney General of a request for the granting of posthumous citizenship."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1704/2"},"text":"Pub. L. 108–136, § 1704(2)","children":[],"tail":", added heading and text of subsec. (d) and struck out former subsec. (d) which read as follows: “If the Attorney General approves such a request to grant a person posthumous citizenship, the Attorney General shall send to the individual who filed the request a suitable document which states that the United States considers the person to have been a citizen of the United States at the time of the person’s death.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1703/g/1"},"text":"Pub. L. 108–136, § 1703(g)(1)","children":[],"tail":", struck out heading and text of subsec. (e). Text read as follows: “Nothing in this section or "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1430/d"},"text":"section 1430(d) of this title","children":[],"tail":" shall be construed as providing for any benefits under this chapter for any spouse, son, daughter, or other relative of a person granted posthumous citizenship under this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"November 2, 2002","children":[],"tail":",” for “"},{"tag":"date","attrib":{"date":"1990-03-06"},"text":"March 6, 1990","children":[],"tail":",”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c5430df-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c5430e0-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" effective as if enacted "},{"tag":"date","attrib":{"date":"2001-09-11"},"text":"Sept. 11, 2001","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1705"},"text":"section 1705 of Pub. L. 108–136","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1439"},"text":"section 1439 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
