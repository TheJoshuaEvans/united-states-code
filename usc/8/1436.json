{"tag":"section","attrib":{"id":"id9c51c081-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1436"},"text":null,"children":[{"tag":"num","attrib":{"value":"1436"},"text":"§ 1436.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nationals but not citizens; residence within outlying possessions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A person not a citizen who owes permanent allegiance to the United States, and who is otherwise qualified, may, if he becomes a resident of any State, be naturalized upon compliance with the applicable requirements of this subchapter, except that in applications for naturalization filed under the provisions of this section residence and physical presence within the United States within the meaning of this subchapter shall include residence and physical presence within any of the outlying possessions of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9c51c082-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title III, ch. 2, § 325, "},{"tag":"ref","attrib":{"href":"/us/stat/66/248"},"text":"66 Stat. 248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/tIV/s407/c/8"},"text":"Pub. L. 101–649, title IV, § 407(c)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5041"},"text":"104 Stat. 5041","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c51c083-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c51c084-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c51c085-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649"},"text":"Pub. L. 101–649","children":[],"tail":" substituted “applications” for “petitions”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
