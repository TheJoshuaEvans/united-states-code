{"tag":"section","attrib":{"id":"id9c4d0587-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1409"},"text":null,"children":[{"tag":"num","attrib":{"value":"1409"},"text":"§ 1409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Children born out of wedlock","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c4d0588-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1409/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provisions of paragraphs (c), (d), (e), and (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1401"},"text":"section 1401 of this title","children":[],"tail":", and of paragraph (2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1408"},"text":"section 1408 of this title","children":[],"tail":", shall apply as of the date of birth to a person born out of wedlock if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c4d0589-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1409/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a blood relationship between the person and the father is established by clear and convincing evidence,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4d058a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1409/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the father had the nationality of the United States at the time of the person’s birth,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4d058b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1409/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the father (unless deceased) has agreed in writing to provide financial support for the person until the person reaches the age of 18 years, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4d058c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1409/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" while the person is under the age of 18 years—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c4d058d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1409/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person is legitimated under the law of the person’s residence or domicile,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4d058e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1409/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the father acknowledges paternity of the person in writing under oath, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c4d058f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1409/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the paternity of the person is established by adjudication of a competent court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c4d0590-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1409/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in section 405 of this Act, the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1401/g"},"text":"section 1401(g) of this title","children":[],"tail":" shall apply to a child born out of wedlock on or after "},{"tag":"date","attrib":{"date":"1941-01-13"},"text":"January 13, 1941","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1952-12-24"},"text":"December 24, 1952","children":[],"tail":", as of the date of birth, if the paternity of such child is established at any time while such child is under the age of twenty-one years by legitimation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c4d0591-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1409/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the provision of subsection (a) of this section, a person born, after ","children":[{"tag":"date","attrib":{"date":"1952-12-23"},"text":"December 23, 1952","children":[],"tail":", outside the United States and out of wedlock shall be held to have acquired at birth the nationality status of his mother, if the mother had the nationality of the United States at the time of such person’s birth, and if the mother had previously been physically present in the United States or one of its outlying possessions for a continuous period of one year."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c4d0592-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title III, ch. 1, § 309, "},{"tag":"ref","attrib":{"href":"/us/stat/66/238"},"text":"66 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/116/s18"},"text":"Pub. L. 97–116, § 18","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1620"},"text":"95 Stat. 1620","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/653/s13"},"text":"Pub. L. 99–653, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3657"},"text":"100 Stat. 3657","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/525"},"text":"Pub. L. 100–525","children":[],"tail":", §§ 8(k), 9(r), "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2617"},"text":"102 Stat. 2617","children":[],"tail":", 2621.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c4d0593-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c4d0594-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c4d0595-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 405 of this Act, referred to in subsec. (b), is section 405 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477/tIV"},"text":"act June 27, 1952, ch. 477, title IV","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/280"},"text":"66 Stat. 280","children":[],"tail":", which is set out as a Savings Clause note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"constitutionality","id":"id9c4d0596-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Constitutionality","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For information regarding constitutionality of certain provisions of this section, see note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1401"},"text":"section 1401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c4d0597-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/525/s8/k"},"text":"Pub. L. 100–525, § 8(k)","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/653"},"text":"Pub. L. 99–653","children":[],"tail":". See 1986 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/525/s9/r/1"},"text":"Pub. L. 100–525, § 9(r)(1)","children":[],"tail":", substituted “before "},{"tag":"date","attrib":{"date":"1952-12-24"},"text":"December 24, 1952","children":[],"tail":"” for “prior to the effective date of this chapter” and “at any time” for “before or after the effective date of this chapter and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/525/s9/r/2"},"text":"Pub. L. 100–525, § 9(r)(2)","children":[],"tail":", substituted “after "},{"tag":"date","attrib":{"date":"1952-12-23"},"text":"December 23, 1952","children":[],"tail":"” for “on or after the effective date of this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/653"},"text":"Pub. L. 99–653","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/525/s8/k"},"text":"Pub. L. 100–525, § 8(k)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “The provisions of paragraphs (c), (d), (e), and (g) of "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1401"},"text":"section 1401 of this title","children":[],"tail":", and of paragraph (2) of section 1408, of this title shall apply as of the date of birth to a child born out of wedlock on or after the effective date of this chapter, if the paternity of such child is established while such child is under the age of twenty-one years by legitimation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/116/s18"},"text":"Pub. L. 97–116, § 18","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1), substituted “(c), (d), (e), and (g) of section 1401” for “(3) to (5) and (7) of section 1401(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/116/s18"},"text":"Pub. L. 97–116, § 18","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), substituted “section 1401(g)” for “section 1401(a)(7)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c4d0598-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c4d0599-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/525/s8/k"},"text":"section 8(k) of Pub. L. 100–525","children":[],"tail":" effective as if included in the enactment of the Immigration and Nationality Act Amendments of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/653"},"text":"Pub. L. 99–653","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/232/s309/b/15"},"text":"section 309(b)(15) of Pub. L. 102–232","children":[],"tail":", set out as an Effective and Termination Dates of 1988 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c4d059a-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/653/s23/e"},"text":"Pub. L. 99–653, § 23(e)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/100/525/s8/r"},"text":"Pub. L. 100–525, § 8(r)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2619"},"text":"102 Stat. 2619","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/525/s8/r"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2)(B), the new section 309(a) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1409/a"},"text":"8 U.S.C. 1409(a)","children":[],"tail":"] (as defined in paragraph (4)(A)) shall apply to persons who have not attained 18 years of age as of the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The old section 309(a) shall apply—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any individual who has attained 18 years of age as of the date of the enactment of this Act, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual with respect to whom paternity was established by legitimation before such date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual who is at least 15 years of age, but under 18 years of age, as of the date of the enactment of this Act, may elect to have the old section 309(a) apply to the individual instead of the new section 309(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘new section 309(a)’ means section 309(a) of the Immigration and Nationality Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1409/a"},"text":"8 U.S.C. 1409(a)","children":[],"tail":"], as amended by section 13 of this Act ["},{"tag":"ref","attrib":{"href":"/us/pl/99/653/s13"},"text":"section 13 of Pub. L. 99–653","children":[],"tail":"] and as in effect after the date of the enactment of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘old section 309(a)’ means section 309(a) of the Immigration and Nationality Act, as in effect before the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c4d059b-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/116"},"text":"Pub. L. 97–116","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/116/s21/a"},"text":"section 21(a) of Pub. L. 97–116","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
