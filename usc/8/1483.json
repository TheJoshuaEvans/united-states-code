{"tag":"section","attrib":{"id":"id9c5b5d13-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1483"},"text":null,"children":[{"tag":"num","attrib":{"value":"1483"},"text":"§ 1483.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on loss of nationality","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c5b5d14-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1483/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraphs (6) and (7) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1481/a"},"text":"section 1481(a) of this title","children":[],"tail":", no national of the United States can lose United States nationality under this chapter while within the United States or any of its outlying possessions, but loss of nationality shall result from the performance within the United States or any of its outlying possessions of any of the acts or the fulfillment of any of the conditions specified in this Part if and when the national thereafter takes up a residence outside the United States and its outlying possessions."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c5b5d15-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1483/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A national who within six months after attaining the age of eighteen years asserts his claim to United States nationality, in such manner as the Secretary of State shall by regulation prescribe, shall not be deemed to have lost United States nationality by the commission, prior to his eighteenth birthday, of any of the acts specified in paragraphs (3) and (5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1481/a"},"text":"section 1481(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c5b5d16-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title III, ch. 3, § 351, "},{"tag":"ref","attrib":{"href":"/us/stat/66/269"},"text":"66 Stat. 269","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/116/s18/r"},"text":"Pub. L. 97–116, § 18(r)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1621"},"text":"95 Stat. 1621","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/653/s20"},"text":"Pub. L. 99–653, § 20","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3658"},"text":"100 Stat. 3658","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/525/s8"},"text":"Pub. L. 100–525, § 8","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2618"},"text":"102 Stat. 2618","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/416/tI/s105/a"},"text":"Pub. L. 103–416, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4308"},"text":"108 Stat. 4308","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tVI/s671/b/3"},"text":"Pub. L. 104–208, div. C, title VI, § 671(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-721"},"text":"110 Stat. 3009–721","children":[