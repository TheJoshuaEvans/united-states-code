{"tag":"section","attrib":{"id":"id9c732b61-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803"},"text":null,"children":[{"tag":"num","attrib":{"value":"1803"},"text":"§ 1803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment authorization document fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c732b62-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asylum applicants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c732b63-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other fee authorized by law, the Secretary of Homeland Security shall require the payment of a fee, equal to the amount specified in this subsection, by any alien who files an initial application for employment authorization under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1158/d/2"},"text":"section 1158(d)(2) of this title","children":[],"tail":" at the time such initial employment authorization application is filed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732b64-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During fiscal year 2025, the amount specified in this subsection shall be the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c732b65-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $550; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732b66-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount as the Secretary of Homeland Security may establish, by rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732b67-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual adjustments for inflation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During fiscal year 2026, and during each subsequent fiscal year, the amount specified in this section shall be equal to the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c732b68-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the fee required under this section for the most recently concluded fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732b69-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product resulting from the multiplication of the amount referred to in subparagraph (A) by the percentage (if any) by which the Consumer Price Index for All Urban Consumers for the month of July preceding the date on which such adjustment takes effect exceeds the Consumer Price Index for All Urban Consumers for the same month of the preceding calendar year, rounded to the next lowest multiple of $10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732b6a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of employment authorization document fees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During each fiscal year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c732b6b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 25 percent of the fees collected pursuant to this subsection—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c732b6c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be credited to U.S. Citizenship and Immigration Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b6d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be deposited into the Immigration Examinations Fee Account established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1356/m"},"text":"section 1356(m) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732b6e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be retained and expended by U.S. Citizenship and Immigration Services without further appropriation, provided that not less than 50 percent is used to detect and prevent immigration benefit fraud; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732b6f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts collected pursuant to this subsection that are not credited to U.S. Citizenship and Immigration Services pursuant to subparagraph (A) shall be deposited into the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732b70-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No fee waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees required to be paid under this subsection shall not be waived or reduced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c732b71-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parolees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c732b72-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other fee authorized by law, the Secretary of Homeland Security shall require the payment of a fee, equal to the amount specified in this subsection, by any alien paroled into the United States for any initial application for employment authorization at the time such initial application is filed. Each initial employment authorization shall be valid for a period of 1 year or for the duration of the alien’s parole, whichever is shorter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759b73-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During fiscal year 2025, the amount specified in this subsection shall be the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c759b74-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $550; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c759b75-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount as the Secretary of Homeland Security may establish, by rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759b76-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual adjustments for inflation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During fiscal year 2026, and during each subsequent fiscal year, the amount specified in this subsection shall be equal to the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c759b77-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the fee required under this subsection for the most recently concluded fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c759b78-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product resulting from the multiplication of the amount referred to in subparagraph (A) by the percentage (if any) by which the Consumer Price Index for All Urban Consumers for the month of July preceding the date on which such adjustment takes effect exceeds the Consumer Price Index for All Urban Consumers for the same month of the preceding calendar year, rounded to the next lowest multiple of $10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759b79-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of parolee employment authorization application fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All of the fees collected pursuant to this subsection shall be deposited into the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759b7a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No fee waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees required to be paid under this subsection shall not be waived or reduced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c759b7b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary protected status","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c759b7c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other fee authorized by law, the Secretary of Homeland Security shall require the payment of a fee, equal to the amount specified in this subsection, by any alien who files an initial application for employment authorization under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1254a/a/1/B"},"text":"section 1254a(a)(1)(B) of this title","children":[],"tail":" at the time such initial application is filed. Each initial employment authorization shall be valid for a period of 1 year, or for the duration of the alien’s temporary protected status, whichever is shorter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759b7d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During fiscal year 2025, the amount specified in this subsection shall be the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c759b7e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $550; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c759b7f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount as the Secretary of Homeland Security may establish, by rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759b80-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual adjustments for inflation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During fiscal year 2026, and during each subsequent fiscal year, the amount specified in this subsection shall be equal to the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c759b81-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the fee required under this subsection for the most recently concluded fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c759b82-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product resulting from the multiplication of the amount referred to in subparagraph (A) by the percentage (if any) by which the Consumer Price Index for All Urban Consumers for the month of July preceding the date on which such adjustment takes effect exceeds the Consumer Price Index for All Urban Consumers for the same month of the preceding calendar year, rounded to the next lowest multiple of $10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759b83-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of employment authorization application fees collected from aliens granted temporary protected status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All of the fees collected pursuant to this subsection shall be deposited into the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759b84-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1803/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No fee waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees required to be paid under this subsection shall not be waived or reduced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c759b85-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tX/s100003"},"text":"Pub. L. 119–21, title X, § 100003","children":[],"tail":", "},{"tag":"date","attrib":