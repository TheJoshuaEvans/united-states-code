{"tag":"section","attrib":{"id":"id9c77e5a1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1813"},"text":null,"children":[{"tag":"num","attrib":{"value":"1813"},"text":"§ 1813.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic Visa Update System fee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c77e5a2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1813/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other fee authorized by law, the Secretary of Homeland Security shall require the payment of a fee, in the amount specified in subsection (b), by any alien subject to the Electronic Visa Update System at the time of such alien’s enrollment in such system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c77e5a3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1813/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount specified","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c77e5a4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1813/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For fiscal year 2025, the amount specified in this subsection shall be the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c77e5a5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1813/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $30; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c77e5a6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1813/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount as the Secretary of Homeland Security may establish, by rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c77e5a7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1813/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual adjustments for inflation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During fiscal year 2026 and each subsequent fiscal year, the amount specified in this subsection shall be equal to the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c77e5a8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1813/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the fee required under this subsection during the most recently concluded fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c77e5a9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1813/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product resulting from the multiplication of the amount referred to in subparagraph (A) by the percentage (if any) by which the Consumer Price Index for All Urban Consumers for the month of July preceding the date on which such adjustment takes effect exceeds the Consumer Price Index for All Urban Consumers for the same month of the preceding calendar year, rounded to the next lowest multiple of $0.25.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c77e5aa-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1813/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of Electronic Visa Update System fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c77e5ab-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1813/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c77e5ac-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1813/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remaining fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the fees collected pursuant to this section, an amount equal to $5 multiplied by the number of payments collected pursuant to this section shall be deposited to the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c77e5ad-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1813/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No fee waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees required to be paid under this section shall not be waived or reduced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c77e5ae-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tX/s100015"},"text":"Pub. L. 119–21, title X, § 100015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/382"},"text":"139 Stat. 382","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c77e5af-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c77e5b0-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c77e5b1-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s100015"},"text":"section 100015 of Pub. L. 119–21","children":[],"tail":". Subsec. (c)(1) of "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/s100015"},"text":"section 100015 of Pub. L. 119–21","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1356"},"text":"section 1356 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
