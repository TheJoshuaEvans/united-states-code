{"tag":"section","attrib":{"id":"id9bc0553a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1102"},"text":null,"children":[{"tag":"num","attrib":{"value":"1102"},"text":"§ 1102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diplomatic and semidiplomatic immunities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this chapter, for so long as they continue in the nonimmigrant classes enumerated in this section, the provisions of this chapter relating to ineligibility to receive visas and the removal of aliens shall not be construed to apply to nonimmigrants—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9bc0553b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the class described in paragraph (15)(A)(i) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a"},"text":"section 1101(a) of this title","children":[],"tail":", except those provisions relating to reasonable requirements of passports and visas as a means of identification and documentation necessary to establish their qualifications under such paragraph (15)(A)(i), and, under such rules and regulations as the President may deem to be necessary, the provisions of subparagraphs (A) through (C) of "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182/a/3"},"text":"section 1182(a)(3) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9bc0553c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the class described in paragraph (15)(G)(i) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a"},"text":"section 1101(a) of this title","children":[],"tail":", except those provisions relating to reasonable requirements of passports and visas as a means of identification and documentation necessary to establish their qualifications under such paragraph (15)(G)(i), and the provisions of subparagraphs (A) through (C) of "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182/a/3"},"text":"section 1182(a)(3) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9bc0553d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the classes described in paragraphs (15)(A)(ii), (15)(G)(ii), (15)(G)(iii), or (15)(G)(iv) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a"},"text":"section 1101(a) of this title","children":[],"tail":", except those provisions relating to reasonable requirements of passports and visas as a means of identification and documentation necessary to establish their qualifications under such paragraphs, and the provisions of subparagraphs (A) through (C) of "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182/a/3"},"text":"section 1182(a)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9bc0553e-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title I, § 102, "},{"tag":"ref","attrib":{"href":"/us/stat/66/173"},"text":"66 Stat. 173","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/525/s9/b"},"text":"Pub. L. 100–525, § 9(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2619"},"text":"102 Stat. 2619","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/