-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649"},"text":"Pub. L. 101–649","children":[],"tail":" applicable to individuals entering United States on or after "},{"tag":"date","attrib":{"date":"1991-06-01"},"text":"June 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/s601/e/1"},"text":"section 601(e)(1) of Pub. L. 101–649","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9bc05547-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Denial of Visas to Certain Representatives to United Nations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/246/tIV/s407"},"text":"Pub. L. 101–246, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/67"},"text":"104 Stat. 67","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/100/s1"},"text":"Pub. L. 113–100, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-04-18"},"text":"Apr. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1145"},"text":"128 Stat. 1145","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/100/s1"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall use his authority, including the authorities contained in section 6 of the United Nations Headquarters Agreement Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/80/357"},"text":"Public Law 80–357","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/act/1947-08-04/ch482"},"text":"Aug. 4, 1947, ch. 482","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s287"},"text":"22 U.S.C. 287","children":[],"tail":"], to deny any individual’s admission to the United States as a representative to the United Nations if the President determines that such individual—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been found to have been engaged in espionage activities or a terrorist activity (as defined in section 212(a)(3)(B)(iii) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182/a/3/B/iii"},"text":"8 U.S.C. 1182(a)(3)(B)(iii)","children":[],"tail":")) directed against the United States or its allies; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may pose a threat to United States national security interests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President may waive the provisions of subsection (a) if the President determines, and so notifies the Congress, that such a waiver is in the national security interests of the United States.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
