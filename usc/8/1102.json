and Nationality Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9bc05542-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" substituted “removal” for “exclusion or deportation” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Pars. (1) to (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/232"},"text":"Pub. L. 102–232","children":[],"tail":" substituted “subparagraphs (A) through (C) of "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182/a/3"},"text":"section 1182(a)(3) of this title","children":[],"tail":"” for “paragraph (3) (other than subparagraph (E)) of "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182/a"},"text":"section 1182(a) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Pars. (1) to (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649"},"text":"Pub. L. 101–649","children":[],"tail":" substituted “(3) (other than subparagraph (E))” for “(27)” in pars. (1) and (2), and “paragraph (3) (other than subparagraph (E))” for “paragraphs (27) and (29)” in par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/525"},"text":"Pub. L. 100–525","children":[],"tail":" substituted “documentation” for “documentaion”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9bc05543-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"