{"tag":"section","attrib":{"id":"id9c64d2f2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1552"},"text":null,"children":[{"tag":"num","attrib":{"value":"1552"},"text":"§ 1552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner of Immigration and Naturalization; office","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The office of the Commissioner of Immigration and Naturalization is created and established, and the President, by and with the advice and consent of the Senate, is authorized and directed to appoint such officer. The Attorney General shall provide him with a suitable, furnished office in the city of Washington, and with such books of record and facilities for the discharge of the duties of his office as may be necessary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9c64d2f3-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1891-03-03/ch551/s7"},"text":"Mar. 3, 1891, ch. 551, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/1085"},"text":"26 Stat. 1085","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1895-03-02/ch177/s1"},"text":"Mar. 2, 1895, ch. 177, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/780"},"text":"28 Stat. 780","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1904-04-28"},"text":"Apr. 28, 1904","children":[],"tail":", Pub. R. 33, "},{"tag":"ref","attrib":{"href":"/us/stat/33/591"},"text":"33 Stat. 591","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch141/s3"},"text":"Mar. 4, 1913, ch. 141, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/737"},"text":"37 Stat. 737","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1917-02-05/ch29/s23"},"text":"Feb. 5, 1917, ch. 29, § 23","children":[],"tail":", "},{"tag":"ref","a