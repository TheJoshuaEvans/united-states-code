{"tag":"section","attrib":{"id":"id9c1af8b8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1230"},"text":null,"children":[{"tag":"num","attrib":{"value":"1230"},"text":"§ 1230.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records of admission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c1af8b9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1230/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall cause to be filed, as a record of admission of each immigrant, the immigrant visa required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1201/e"},"text":"section 1201(e) of this title","children":[],"tail":" to be surrendered at the port of entry by the arriving alien to an immigration officer."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c1af8ba-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1230/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall cause to be filed such record of the admission into the United States of each immigrant admitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1181/b"},"text":"section 1181(b) of this title","children":[],"tail":" and of each nonimmigrant as the Attorney General deems necessary for the enforcement of the immigration laws."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c1af8bb-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title II, ch. 4, § 240C, formerly § 240, "},{"tag":"ref","attrib":{"href":"/us/stat/66/204"},"text":"66 Stat. 204","children":[],"tail":"; renumbered § 240C and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII"},"text":"Pub. L. 104–208, div. C, title III","children":[],"tail":", §§ 304(a)(2), 308(f)(1)(K), "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-587"},"text":"110 Stat. 3009–587","children":[],"tail":", 3009–621.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c1af8bc-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c1af8bd-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c1af8be-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s308/f/1/K"},"text":"Pub. L. 104–208, § 308(f)(1)(K)","children":[],"tail":", substituted “admission” for “entry”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c1af8bf-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c1af8c0-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" effective, with certain transitional provisions, on the first day of the first month beginning more than 180 days after "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s309"},"text":"section 309 of Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c1af8c1-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
