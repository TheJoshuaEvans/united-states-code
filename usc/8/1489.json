{"tag":"section","attrib":{"id":"id9c5b5d29-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1489"},"text":null,"children":[{"tag":"num","attrib":{"value":"1489"},"text":"§ 1489.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of treaties; exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be applied in contravention of the provisions of any treaty or convention to which the United States is a party and which has been ratified by the Senate before ","children":[{"tag":"date","attrib":{"date":"1952-12-25"},"text":"December 25, 1952","children":[],"tail":": "},{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That no woman who was a national of the United States shall be deemed to have lost her nationality solely by reason of her marriage to an alien on or after "},{"tag":"date","attrib":{"date":"1922-09-22"},"text":"September 22, 1922","children":[],"tail":", or to an alien racially ineligible to citizenship on or after "},{"tag":"date","attrib":{"date":"1931-03-03"},"text":"March 3, 1931","children":[],"tail":", or, in the case of a woman who was a United States citizen at birth, through residence abroad following such marriage, notwithstanding the provisions of any existing treaty or convention."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9c5b5d2a-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title III, ch. 3, § 357, "},{"tag":"ref","attrib":{"href":"/us/stat/66/272"},"text":"66 Stat. 272","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/525/s9/ii"},"text":"Pub. L. 100–525, § 9(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2622"},"text":"102 Stat. 2622","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c5b5d2b-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c5b5d2c-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c5b5d2d-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/525"},"text":"Pub. L. 100–525","children":[],"tail":" substituted “before "},{"tag":"date","attrib":{"date":"1952-12-25"},"text":"December 25, 1952","children":[],"tail":"” for “upon the effective date of this subchapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
