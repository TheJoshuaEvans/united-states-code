{"tag":"section","attrib":{"id":"id9c70ba57-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1738"},"text":null,"children":[{"tag":"num","attrib":{"value":"1738"},"text":"§ 1738.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification documents for certain newly admitted aliens","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", the Attorney General shall ensure that, immediately upon the arrival in the United States of an individual admitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1157"},"text":"section 1157 of this title","children":[],"tail":", or immediately upon an alien being granted asylum under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1158"},"text":"section 1158 of this title","children":[],"tail":", the alien will be issued an employment authorization document. Such document shall, at a minimum, contain the fingerprint and photograph of such alien."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9c70ba58-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/173/tIII/s309"},"text":"Pub. L. 107–173, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/556"},"text":"116 Stat. 556","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c70ba59-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c70ba5a-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c70ba5b-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
