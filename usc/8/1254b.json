{"tag":"section","attrib":{"id":"id9c2224dd-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1254b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1254b"},"text":"§ 1254b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of fees under temporary protected status program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c2224de-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1254b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to collection of registration fees described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1254a/c/1/B"},"text":"section 1254a(c)(1)(B) of this title","children":[],"tail":", fees for fingerprinting services, biometric services, and other necessary services may be collected when administering the program described in "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1254a"},"text":"section 1254a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c2224df-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1254b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) shall be construed to apply for fiscal year 1998 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c2224e0-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/83/tV/s549"},"text":"Pub. L. 111–83, title V, § 549","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2177"},"text":"123 Stat. 2177","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c2224e1-3a6f-11f1-ace3-bb5201d4c7c7"},"text