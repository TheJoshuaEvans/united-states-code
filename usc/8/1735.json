{"tag":"section","attrib":{"id":"id9c70ba3b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1735"},"text":null,"children":[{"tag":"num","attrib":{"value":"1735"},"text":"§ 1735.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on issuance of visas to nonimmigrants from countries that are state sponsors of international terrorism","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c70ba3c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1735/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No nonimmigrant visa under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/15"},"text":"section 1101(a)(15) of this title","children":[],"tail":" shall be issued to any alien from a country that is a state sponsor of international terrorism unless the Secretary of State determines, in consultation with the Attorney General and the heads of other appropriate United States agencies, that such alien does not pose a threat to the safety or national security of the United States. In making a determination under this subsection, the Secretary of State shall apply standards developed by the Secretary of State, in consultation with the Attorney General and the heads of other appropriate United States agencies, that are applicable to the nationals of such states."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70ba3d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1735/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State sponsor of international terrorism defined","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c70ba3e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1735/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “state sponsor of international terrorism” means any country the government of which has been determined by the Secretary of State under any of the laws specified in paragraph (2) to have repeatedly provided support for acts of international terrorism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70ba3f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1735/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laws under which determinations were made","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The laws specified in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c70ba40-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1735/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4605/j/1/A"},"text":"Section 4605(j)(1)(A) of title 50","children":[],"tail":" (or successor statute)."},{"tag":"ref","attrib":{"idref":"fn002115"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002115"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c70ba41-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1735/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":nu