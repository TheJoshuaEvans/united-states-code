{"tag":"section","attrib":{"id":"id9c58eb89-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1450"},"text":null,"children":[{"tag":"num","attrib":{"value":"1450"},"text":"§ 1450.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions and duties of clerks and records of declarations of intention and applications for naturalization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c58eb8a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1450/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The clerk of each court that administers oaths of allegiance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1448"},"text":"section 1448 of this title","children":[],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c58eb8b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1450/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deliver to each person administered the oath of allegiance by the court pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1448/a"},"text":"section 1448(a) of this title","children":[],"tail":" the certificate of naturalization prepared by the Attorney General pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1421/b/2/A/ii"},"text":"section 1421(b)(2)(A)(ii) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c58eb8c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1450/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forward to the Attorney General a list of applicants actually taking the oath at each scheduled ceremony and information concerning each person to whom such an oath is administered by the court, within 30 days after the close of the month in which the oath was administered,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c58eb8d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1450/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forward to the Attorney General certified copies of such other proceedings and orders instituted in or issued out of the court affecting or relating to the naturalization of persons as may be required from time to time by the Attorney General, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c58eb8e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1450/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for all blank certificates of naturalization received by them from time to time from the Attorney General and shall account to the Attorney General for them whenever required to do so.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"No certificate of naturalization received by any clerk of court which may be defaced or injured in such manner as to prevent its use as herein provided shall in any case be destroyed, but such certificates shall be returned to the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c58eb8f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1450/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each district office of the Service in the United States shall maintain, in chronological order, indexed, and consecutively numbered, as part of its permanent records, all declarations of intention and applications for naturalization filed with the office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c58eb90-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title III, ch. 2, § 339, "},{"tag":"ref","attrib":{"href":"/us/stat/66/259"},"text":"66 Stat. 259","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/tIV/s407/d/17"},"text":"Pub. L. 101–649, title IV, § 407(d)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5045"},"text":"104 Stat. 5045","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/232/tI/s102/b/1"},"text":"Pub. L. 102–232, title I, § 102(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-12"},"text":"Dec. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1735"},"text":"105 Stat. 1735","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c58eb91-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c58eb92-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c58eb93-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/232/s102/b/1/F"},"text":"Pub. L. 102–232, § 102(b)(1)(F)","children":[],"tail":", inserted sentence at end relating to return of defaced or injured certificates of naturalization to Attorney General."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/232/s102/b/1/A"},"text":"Pub. L. 102–232, § 102(b)(1)(A)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “issue to each person to whom such an oath is administered a document evidencing that such an oath was administered,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/232/s102/b/1/B"},"text":"Pub. L. 102–232, § 102(b)(1)(B)","children":[],"tail":", inserted “a list of applicants actually taking the oath at each scheduled ceremony and” after “Attorney General”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/232/s102/b/1/C"},"text":"Pub. L. 102–232, § 102(b)(1)(C)","children":[],"tail":"–(E), added par. (4), redesignated former par. (4) as (3) and substituted “, and” for period at end, and struck out former par. (3) which directed clerk to make and keep on file evidence for each document issued."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649"},"text":"Pub. L. 101–649","children":[],"tail":" amended section generally, substituting provisions relating to functions and duties of clerks and records of declarations of intention and applications for naturalization, for provisions relating to functions and duties of clerks of naturalization courts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c58eb94-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c58eb95-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/232"},"text":"Pub. L. 102–232","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"1991-12-12"},"text":"Dec. 12, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/232/s102/c"},"text":"section 102(c) of Pub. L. 102–232","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1421"},"text":"section 1421 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c58eb96-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/649"},"text":"Pub. L. 101–649","children":[],"tail":" not applicable to functions and duties respecting petitions filed before "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"Oct. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/s408/c"},"text":"section 408(c) of Pub. L. 101–649","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1421"},"text":"section 1421 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c58eb97-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
