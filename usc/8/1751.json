{"tag":"section","attrib":{"id":"id9c70ba5d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1751"},"text":null,"children":[{"tag":"num","attrib":{"value":"1751"},"text":"§ 1751.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of the feasibility of a North American National Security Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c70ba5e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1751/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall conduct a study of the feasibility of establishing a North American National Security Program to enhance the mutual security and safety of the United States, Canada, and Mexico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70ba5f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1751/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the study required by subsection (a), the President shall consider the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c70ba60-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1751/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preclearance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The feasibility of establishing a program enabling foreign national travelers to the United States to submit voluntarily to a preclearance procedure established by the Department of State and the Immigration and Naturalization Service to determine whether such travelers are admissible to the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182"},"text":"section 1182 of this title","children":[],"tail":". Consideration shall be given to the feasibility of expanding the preclearance program to include the preclearance both of foreign nationals traveling to Canada and foreign nationals traveling to Mexico."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70ba61-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1751/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preinspection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The feasibility of expanding preinspection facilities at foreign airports as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1225a"},"text":"section 1225a of this title","children":[],"tail":". Consideration shall be given to the feasibility of expanding preinspections to foreign nationals on air flights destined for Canada and Mexico, and the cross training and funding of inspectors from Canada and Mexico."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70ba62-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1751/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A determination of the measures necessary to ensure that the conditions required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1225a/a/5"},"text":"section 1225a(a)(5) of this title","children":[],"tail":" are satisfied, including consultation with experts recognized for their expertise regarding the conditions required by that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70ba63-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1751/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", the President shall submit to the appropriate committees of Congress a report setting forth the findings of the study conducted under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70ba64-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1751/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c70ba65-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/173/tIV/s401"},"text":"Pub. L. 107–173, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/557"},"text":"116 Stat. 557","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c70ba66-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c70ba67-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c70ba68-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
