{"tag":"section","attrib":{"id":"id9c69b552-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1615"},"text":null,"children":[{"tag":"num","attrib":{"value":"1615"},"text":"§ 1615.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements relating to provision of benefits based on citizenship, alienage, or immigration status under the Richard B. Russell National School Lunch Act, the Child Nutrition Act of 1966, and certain other Acts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c69b553-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1615/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School lunch and breakfast programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this Act, an individual who is eligible to receive free public education benefits under State or local law shall not be ineligible to receive benefits provided under the school lunch program under the Richard B. Russell National School Lunch Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.) or the school breakfast program under section 4 of the Child Nutrition Act of 1966 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1773"},"text":"42 U.S.C. 1773","children":[],"tail":") on the basis of citizenship, alienage, or immigration status."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c69b554-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1615/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c69b555-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1615/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this Act shall prohibit or require a State to provide to an individual who is not a citizen or a qualified alien, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1641/b"},"text":"section 1641(b) of this title","children":[],"tail":", benefits under programs established under the provisions of law described in paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c69b556-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1615/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions of law described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of law described in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c69b557-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1615/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programs (other than the school lunch program and the school breakfast program) under the Richard B. Russell National School Lunch Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.) and the Child Nutrition Act of 1966 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"42 U.S.C. 1771","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c69b558-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1615/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 4 of the Agriculture and Consumer Protection Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s612c"},"text":"7 U.S.C. 612c","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c69b559-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1615/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Emergency Food Assistance Act of 1983 [7 U.S.C 7501 et seq.].","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c69b55a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1615/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The food distribution program on Indian reservations established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2013/b"},"text":"section 2013(b) of title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c69b55b-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/tVII/s742"},"text":"Pub. L. 104–193, title VII, § 742","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2307"},"text":"110 Stat. 2307","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tVII/s752/b/6"},"text":"Pub. L. 106–78, title VII, § 752(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1169"},"text":"113 Stat. 1169","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c69b55c-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c69b55d-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c69b55e-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (a) and (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2105"},"text":"110 Stat. 2105","children":[],"tail":", known as the “Personal Responsibility and Work Opportunity Reconciliation Act of 1996”. For complete classification of this Act to the Code, see Short Title of 1996 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":", The Public Health and Welfare, and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Richard B. Russell National School Lunch Act, referred to in subsecs. (a) and (b)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281"},"text":"act June 4, 1946, ch. 281","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/230"},"text":"60 Stat. 230","children":[],"tail":", which is classified generally to chapter 13 (§ 1751 et seq.) of Title 42. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Child Nutrition Act of 1966, referred to in subsec. (b)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642"},"text":"Pub. L. 89–642","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-11"},"text":"Oct. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/885"},"text":"80 Stat. 885","children":[],"tail":", which is classified generally to chapter 13A (§ 1771 et seq.) of Title 42. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"section 1771 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4 of the Agriculture and Consumer Protection Act of 1973, referred to in subsec. (b)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/86/s4"},"text":"section 4 of Pub. L. 93–86","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s612c"},"text":"section 612c of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Emergency Food Assistance Act of 1983, referred to in subsec. (b)(2)(C), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/8"},"text":"Pub. L. 98–8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-03-24"},"text":"Mar. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/35"},"text":"97 Stat. 35","children":[],"tail":", which is classified generally to chapter 102 (§ 7501 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7501"},"text":"section 7501 of Title 7","children":[],"tail":", and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c69b55f-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of title VII of the Personal Responsibility and Work Opportunity Reconciliation Act of 1996, and not as part of title IV of that Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c69b560-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/78"},"text":"Pub. L. 106–78","children":[],"tail":" substituted “Richard B. Russell National School Lunch Act” for “National School Lunch Act” in section catchline and in two places in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
