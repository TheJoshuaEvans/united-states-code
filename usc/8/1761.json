{"tag":"section","attrib":{"id":"id9c732a84-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1761"},"text":null,"children":[{"tag":"num","attrib":{"value":"1761"},"text":"§ 1761.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign student monitoring program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c732a85-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1761/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c732a86-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1761/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information required of the visa applicant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to the issuance of a visa under subparagraph (F), subparagraph (M), or, with respect to an alien seeking to attend an approved institution of higher education, subparagraph (J) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/15"},"text":"section 1101(a)(15) of this title","children":[],"tail":", each alien applying for such visa shall provide to a consular officer the following information:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c732a87-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1761/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The alien’s address in the country of origin.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732a88-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1761/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The names and addresses of the alien’s spouse, children, parents, and siblings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732a89-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1761/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The names of contacts of the alien in the alien’s country of residence who could verify information about the alien.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732a8a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1761/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Previous work history, if any, including the names and addresses of employers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c732a8b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1761/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transitional program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c732a8c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1761/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", and until such time as the system described in "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1372"},"text":"section 1372 of this title","children":[],"tail":" is fully implemented, the following requirements shall apply:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c732a8d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1761/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on issuance of visas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A visa may not be issued to an alien under subparagraph (F), subparagraph (M), or, with respect to an alien seeking to attend an approved institution of higher education, subparagraph (J) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/15"},"text":"section 1101(a)(15) of this title","children":[],"tail":", unless—"}],"tail":null},{"tag":"clause","attrib":{"id":"id9c732a8e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1761/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of State has received from an approved institution of higher education or other approved educational institution electronic evidence of documentation of the alien’s acceptance at that institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c732a8f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1761/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consular officer has adequately reviewed the applicant’s visa record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732a90-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1761/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification upon visa issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the issuance of a visa under section 1101(a)(15)(F) or (M) of this title to an alien, the Secretary of State shall transmit to the Immigration and Naturalization Service a notification of the issuance of that visa.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732a91-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1761/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification upon admission of alien","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Immigration and Naturalization Service shall notify the approved institution of higher education or other approved educational institution that an alien accepted for such institution or program has been admitted to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c732a92-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1761/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of failure of enrollment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the deadline for registering for classes for an academic term, the approved institution of higher education or other approved educational institution shall inform the Immigration and Naturalization Service through data-sharing arrangements of any failure of any alien described in subparagraph (C) to enroll or to commence participation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732a93-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1761/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to submit list of approved institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", the Attorney General shall provide the Secretary of State with a list of all approved institutions of higher education and other approved educational institutions that are authorized to receive nonimmigrants under section 1101(a)(15)(F) or (M) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732a94-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1761/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c732a95-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/173/tV/s501"},"text":"Pub. L. 107–173, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/560"},"text":"116 Stat. 560","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c732a96-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c732a97-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c732a98-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/173/s501"},"text":"section 501 of Pub. L. 107–173","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/107/173/s501"},"text":"section 501 of Pub. L. 107–173","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1372"},"text":"section 1372 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c732a99-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c732a9a-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
