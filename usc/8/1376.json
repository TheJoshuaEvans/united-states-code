{"tag":"section","attrib":{"id":"id9c4a9399-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1376"},"text":null,"children":[{"tag":"num","attrib":{"value":"1376"},"text":"§ 1376.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data on nonimmigrant overstay rates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c4a939a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1376/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the date that is 180 days after ","children":[{"tag":"date","attrib":{"date":"1998-04-27"},"text":"April 27, 1998","children":[],"tail":", the Attorney General shall implement a program to collect data, for each fiscal year, regarding the total number of aliens within each of the classes of nonimmigrant aliens described in "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/15"},"text":"section 1101(a)(15) of this title","children":[],"tail":" whose authorized period of stay in the United States terminated during the previous fiscal year, but who remained in the United States notwithstanding such termination."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c4a939b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1376/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1999-06-30"},"text":"June 30, 1999","children":[],"tail":", and not later than June 30 of each year thereafter, the Attorney General shall submit an annual report to the Congress providing numerical estimates, for each country for the preceding fiscal year, of the number of aliens from the country who are described in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c4a939c-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/173/s2"},"text":"Pub. L. 105–173, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-04-27"},"text":"Apr. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/56"},"text":"112 Stat. 56","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c4a939d-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c4a939e-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c4a939f-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Immigration and Nationality Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c4a93a0-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c4a93a1-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
