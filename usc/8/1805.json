{"tag":"section","attrib":{"id":"id9c759bb4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1805"},"text":null,"children":[{"tag":"num","attrib":{"value":"1805"},"text":"§ 1805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special immigrant juvenile fee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c759bb5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1805/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other fee authorized by law, the Secretary of Homeland Security shall require the payment of a fee, equal to the amount specified in this section, by any alien, parent, or legal guardian of an alien applying for special immigrant juvenile status under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/27/J"},"text":"section 1101(a)(27)(J) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c759bb6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1805/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For fiscal year 2025, the amount specified in this section shall be the greater of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c759bb7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1805/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759bb8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1805/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount as the Secretary of Homeland Security may establish, by rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c759bb9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1805/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual adjustments for inflation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During fiscal year 2026, and during each subsequent fiscal year, the amount specified in this section shall be equal to the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c759bba-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1805/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the fee required under this subsection for the most recently concluded fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759bbb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1805/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product resulting from the multiplication of the amount referred to in paragraph (1) by the percentage (if any) by which the Consumer Price Index for All Urban Consumers for the month of July preceding the date on which such adjustment takes effect exceeds the Consumer Price Index for All Urban Consumers for the same month of the preceding calendar year, rounded to the next lowest multiple of $10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c759bbc-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1805/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of special immigrant juvenile fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All of the fees collected pursuant to this section shall be deposited into the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c759bbd-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tX/s100005"},"text":"Pub. L. 119–21, title X, § 100005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/368"},"text":"139 Stat. 368","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
