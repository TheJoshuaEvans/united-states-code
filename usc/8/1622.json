{"tag":"section","attrib":{"id":"id9c69b57e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1622"},"text":null,"children":[{"tag":"num","attrib":{"value":"1622"},"text":"§ 1622.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State authority to limit eligibility of qualified aliens for State public benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c69b57f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1622/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law and except as provided in subsection (b), a State is authorized to determine the eligibility for any State public benefits of an alien who is a qualified alien (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1641"},"text":"section 1641 of this title","children":[],"tail":"), a nonimmigrant under the Immigration and Nationality Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":" et seq.], or an alien who is paroled into the United States under section 212(d)(5) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182/d/5"},"text":"8 U.S.C. 1182(d)(5)","children":[],"tail":"] for less than one year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c69b580-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1622/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Qualified aliens under this subsection shall be eligible for any State public benefits.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c69b581-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1622/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time-limited exception for refugees and asylees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c69b582-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1622/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An alien who is admitted to the United States as a refugee under section 207 of the Immigration and Nationality Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1157"},"text":"8 U.S.C. 1157","children":[],"tail":"] until 5 years after the date of an alien’s entry into the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c69b583-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1622/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An alien who is granted asylum under section 208 of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1158"},"text":"8 U.S.C. 1158","children":[],"tail":"] until 5 years after the date of such grant of asylum."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c69b584-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1622/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An alien whose deportation is being withheld under section 243(h) of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1253"},"text":"8 U.S.C. 1253","children":[],"tail":"] (as in effect immediately before the effective date of section 307 of division C of "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Public Law 104–208","children":[],"tail":") or section 241(b)(3) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1231/b/3"},"text":"8 U.S.C. 1231(b)(3)","children":[],"tail":"] (as amended by section 305(a) of division C of "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Public Law 104–208","children":[],"tail":") until 5 years after such withholding."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c69b585-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1622/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An alien who is a Cuban and Haitian entrant as defined in section 501(e) of the Refugee Education Assistance Act of 1980 until 5 years after the alien is granted such status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c69b586-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1622/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An alien admitted to the United States as an Amerasian immigrant as described in section 1612(a)(2)(A)(i)(V) ","children":[{"tag":"ref","attrib":{"idref":"fn002106"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002106"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c69b587-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1622/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain permanent resident aliens","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An alien who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c69b588-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1622/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is lawfully admitted to the United States for permanent residence under the Immigration and Nationality Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c69b589-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1622/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c69b58a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1622/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has worked 40 qualifying quarters of coverage as defined under title II of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s401"},"text":"42 U.S.C. 401","children":[],"tail":" et seq.] or can be credited with such qualifying quarters as provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1645"},"text":"section 1645 of this title","children":[],"tail":", and (ii) in the case of any such qualifying quarter creditable for any period beginning after "},{"tag":"date","attrib":{"date":"1996-12-31"},"text":"December 31, 1996","children":[],"tail":", did not receive any Federal means-tested public benefit (as provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1613"},"text":"section 1613 of this title","children":[],"tail":") during any such period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c69b58b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1622/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veteran and active duty exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An alien who is lawfully residing in any State and is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c69b58c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1622/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a veteran (as defined in section 101, 1101, or 1301, or as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s107"},"text":"section 107 of title 38","children":[],"tail":") with a discharge characterized as an honorable discharge and not on account of alienage and who fulfills the minimum active-duty service requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5303A/d"},"text":"section 5303A(d) of title 38","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c69b58d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1622/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on active duty (other than active duty for training) in the Armed Forces of the United States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c69b58e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1622/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the spouse or unmarried dependent child of an individual described in subparagraph (A) or (B) or the unremarried surviving spouse of an individual described in clause (i) or (ii) ","children":[{"tag":"ref","attrib":{"idref":"fn002107"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002107"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “subparagraph (A) or (B)”."}],"tail":" who is deceased if the marriage fulfills the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1304"},"text":"section 1304 of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c69b58f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1622/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition for those currently receiving benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An alien who on ","children":[{"tag":"date","attrib":{"date":"1996-08-22"},"text":"August 22, 1996","children":[],"tail":", is lawfully residing in any State and is receiving benefits on "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"August 22, 1996","children":[],"tail":", shall continue to be eligible to receive such benefits until "},{"tag":"date","attrib":{"date":"1997-01-01"},"text":"January 1, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c69b590-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIV/s412"},"text":"Pub. L. 104–193, title IV, § 412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2269"},"text":"110 Stat. 2269","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV"},"text":"Pub. L. 105–33, title V","children":[],"tail":", §§ 5302(c)(2), 5306(d), 5562, 5563, 5581(b)(3), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/599"},"text":"111 Stat. 599","children":[],"tail":", 602, 638, 643.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c69b591-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c69b592-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c69b593-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Immigration and Nationality Act, referred to in subsecs. (a) and (b)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":", which is classified principally to chapter 12 (§ 1101 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 243 of such Act, referred to in subsec. (b)(1)(C), is section 243 of act ","children":[{"tag":"date","attrib":{"date":"1952-06-27"},"text":"June 27, 1952","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1253"},"text":"section 1253 of this title","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1253"},"text":"Section 1253 of this title","children":[],"tail":" was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII/s307/a"},"text":"Pub. L. 104–208, div. C, title III, § 307(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-612"},"text":"110 Stat. 3009–612","children":[],"tail":", and, as so amended, no longer contains a subsec. (h). For effective date of "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s307"},"text":"section 307 of Pub. L. 104–208","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s309"},"text":"section 309 of Pub. L. 104–208","children":[],"tail":", set out as an Effective Date of 1996 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 501(e) of the Refugee Education Assistance Act of 1980, referred to in subsec. (b)(1)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/422/s501/e"},"text":"section 501(e) of Pub. L. 96–422","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1522"},"text":"section 1522 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1612/a/2/A/i/V"},"text":"Section 1612(a)(2)(A)(i)(V) of this title","children":[],"tail":", referred to in subsec. (b)(1)(E), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1612/a/2/A/v"},"text":"section 1612(a)(2)(A)(v) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tV/s503/2"},"text":"Pub. L. 105–185, title V, § 503(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/578"},"text":"112 Stat. 578","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (b)(2)(B)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title II of the Act is classified generally to subchapter II (§ 401 et seq.) of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c6bfe84-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5581/b/3"},"text":"Pub. L. 105–33, § 5581(b)(3)","children":[],"tail":", substituted “withholding” for “with-holding”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5562"},"text":"Pub. L. 105–33, § 5562","children":[],"tail":", substituted “section 243(h) of such Act (as in effect immediately before the effective date of section 307 of division C of "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Public Law 104–208","children":[],"tail":") or section 241(b)(3) of such Act (as amended by section 305(a) of division C of "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Public Law 104–208","children":[],"tail":")” for “section 243(h) of such Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5302/c/2"},"text":"Pub. L. 105–33, § 5302(c)(2)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5306/d"},"text":"Pub. L. 105–33, § 5306(d)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5563/c"},"text":"Pub. L. 105–33, § 5563(c)","children":[],"tail":", inserted “, 1101, or 1301, or as described in section 107” after “section 101”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5563/a"},"text":"Pub. L. 105–33, § 5563(a)","children":[],"tail":", inserted “and who fulfills the minimum active-duty service requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5303A/d"},"text":"section 5303A(d) of title 38","children":[],"tail":"” after “alienage”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5563/b"},"text":"Pub. L. 105–33, § 5563(b)","children":[],"tail":", inserted before period at end “or the unremarried surviving spouse of an individual described in clause (i) or (ii) who is deceased if the marriage fulfills the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1304"},"text":"section 1304 of title 38","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c6bfe85-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c6bfe86-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by sections 5302(c)(2) and 5306(d) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" effective, except as otherwise provided, as if included in the enactment of title IV of the Personal Responsibility and Work Opportunity Reconciliation Act of 1996, "},{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5308"},"text":"section 5308 of Pub. L. 105–33","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1612"},"text":"section 1612 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by sections 5562, 5563, and 5581(b)(3) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" effective as if included in the enactment of title IV of the Personal Responsibility and Work Opportunity Reconciliation Act of 1996, "},{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5582"},"text":"section 5582 of Pub. L. 105–33","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1367"},"text":"section 1367 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
