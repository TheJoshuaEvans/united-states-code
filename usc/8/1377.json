{"tag":"section","attrib":{"id":"id9c4a93a2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1377"},"text":null,"children":[{"tag":"num","attrib":{"value":"1377"},"text":"§ 1377.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of data on detained asylum seekers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c4a93a3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1377/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall regularly collect data on a nation-wide ","children":[{"tag":"ref","attrib":{"idref":"fn002092"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002092"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “nationwide”."}],"tail":" basis with respect to asylum seekers in detention in the United States, including the following information:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c4a93a4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1377/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of detainees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4a93a5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1377/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An identification of the countries of origin of the detainees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4a93a6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1377/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The percentage of each gender within the total number of detainees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4a93a7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1377/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of detainees listed by each year of age of the detainees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4a93a8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1377/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The location of each detainee by detention facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4a93a9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1377/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to each facility where detainees are held, whether the facility is also used to detain criminals and whether any of the detainees are held in the same cells as criminals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4a93aa-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1377/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number and frequency of the transfers of detainees between detention facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4a93ab-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1377/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average length of detention and the number of detainees by category of the length of detention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4a93ac-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1377/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rate of release from detention of detainees for each district of the Immigration and Naturalization Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c4a93ad-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1377/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the disposition of cases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c4a93ae-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1377/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":", and not later than October 1 of each year thereafter, the Attorney General shall submit to the Committee on the Judiciary of each House of Congress a report setting forth the data collected under subsection (a) for the fiscal year ending September 30 of that year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c4a93af-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1377/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Copies of the data collected under subsection (a) shall be made available to members of the public upon request pursuant to such regulations as the Attorney General shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c4a93b0-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/h/tIX/s903"},"text":"Pub. L. 105–277, div. A, § 101(h) [title IX, § 903]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-480"},"text":"112 Stat. 2681–480","children":[],"tail":", 2681–541.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c4a93b1-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c4a93b2-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c4a93b3-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Haitian Refugee Immigration Fairness Act of 1998, and also as part of the Treasury and General Government Appropriations Act, 1999, and the Omnibus Consolidated and Emergency Supplemental Appropriations Act, 1999, and not as part of the Immigration and Nationality Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c4a93b4-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[