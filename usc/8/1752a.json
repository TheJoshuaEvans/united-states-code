{"tag":"section","attrib":{"id":"id9c70ba6e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1752a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1752a"},"text":"§ 1752a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model ports-of-entry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c70ba6f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1752a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Homeland Security shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c70ba70-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1752a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a model ports-of-entry program for the purpose of providing a more efficient and welcoming international arrival process in order to facilitate and promote business and tourist travel to the United States, while also improving security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70ba71-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1752a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement the program initially at the 20 United States international airports that have the highest number of foreign visitors arriving annually as of ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70ba72-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1752a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c70ba73-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1752a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhanced queue management in the Federal Inspection Services area leading up to primary inspection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70ba74-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1752a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance for foreign travelers once they have been admitted to the United States, in consultation, as appropriate, with relevant governmental and nongovernmental entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70ba75-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1752a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" instructional videos, in English and such other languages as the Secretary determines appropriate, in the Federal Inspection Services area that explain the United States inspection process and feature national, regional, or local welcome videos.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70ba76-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1752a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional Customs and Border Protection officers for high-volume ports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, not later than the end of fiscal year 2008 the Secretary of Homeland Security shall employ not fewer than an additional 200 Customs and Border Protection officers over the number of such positions for which funds were appropriated for the proceeding fiscal year to address staff shortages at the 20 United States international airports that have the highest number of foreign visitors arriving annually as of ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c732a77-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tVII/s725"},"text":"Pub. L. 110–53, title VII, § 725","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/350"},"text":"121 Stat. 350","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c732a78-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c732a79-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c732a7a-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Implementing Recommendations of the 9/11 Commission Act of 2007 and not as part of the Enhanced Border Security and Visa Entry Reform Act of 2002 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
