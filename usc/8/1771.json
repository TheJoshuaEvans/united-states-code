{"tag":"section","attrib":{"id":"id9c732aaa-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1771"},"text":null,"children":[{"tag":"num","attrib":{"value":"1771"},"text":"§ 1771.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General Accounting Office study","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c732aab-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1771/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c732aac-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1771/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the United States shall conduct a study to determine the feasibility and utility of implementing a requirement that each nonimmigrant alien in the United States submit to the Commissioner of Immigration and Naturalization each year a current address and, where applicable, the name and address of an employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732aad-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1771/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonimmigrant alien defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In paragraph (1), the term “nonimmigrant alien” means an alien described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/15"},"text":"section 1101(a)(15) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c732aae-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1771/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", the Comptroller General shall submit to Congress a report on the results of the study under subsection (a). The report shall include the Comptroller General’s findings, together with any recommendations that the Comptroller General considers appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c732aaf-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/173/tVI/s602"},"text":"Pub. L. 107–173, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/564"},"text":"116 Stat. 564","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c732ab0-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c732ab1-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id9c732ab2-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"General Accounting Office redesignated Government Accountability Office by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8"},"text":"section 8 of Pub. L. 108–271","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s702"},"text":"section 702 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c732ab3-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
