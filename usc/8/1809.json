{"tag":"section","attrib":{"id":"id9c759beb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1809"},"text":null,"children":[{"tag":"num","attrib":{"value":"1809"},"text":"§ 1809.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fee relating to renewal and extension of employment authorization for parolees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c759bec-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1809/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other fee authorized by law, the Secretary of Homeland Security shall require the payment of a fee, equal to the amount specified in subsection (b), for any parolee who seeks a renewal or extension of employment authorization based on a grant of parole. The employment authorization for each alien paroled into the United States, or any renewal or extension of such parole, shall be valid for a period of 1 year or for the duration of the alien’s parole, whichever is shorter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c759bed-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1809/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount specified","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c759bee-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1809/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For fiscal year 2025, the amount specified in this subsection shall be the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c759bef-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1809/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $275; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c759bf0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1809/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount as the Secretary of Homeland Security may establish, by rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759bf1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1809/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual adjustments for inflation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During fiscal year 2026, and during each subsequent fiscal year, the amount specified in this section shall be equal to the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c759bf2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1809/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the fee required under this subsection for the most recently concluded fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c759bf3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1809/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product resulting from the multiplication of the amount referred to in subparagraph (A) by the percentage (if any) by which the Consumer Price Index for All Urban Consumers for the month of July preceding the date on which such adjustment takes effect exceeds the Consumer Price Index for All Urban Consumers for the same month of the preceding calendar year, rounded to the next lowest multiple of $10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c759bf4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1809/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of fees relating to renewal and extension of employment authorization for parolees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During each fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c759bf5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1809/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 25 percent of the fees collected pursuant to this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c759bf6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1809/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be credited to U.S. Citizenship and Immigration Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c759bf7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1809/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be deposited into the Immigration Examinations Fee Account established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1356/m"},"text":"section 1356(m) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c759bf8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1809/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be retained and expended by U.S. Citizenship and Immigration Services without further appropriation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759bf9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1809/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts collected pursuant to this section that are not credited to U.S. Citizenship and Immigration Services pursuant to subparagraph (A) shall be deposited into the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c759bfa-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1809/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No fee waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees required to be paid under this section shall not be waived or reduced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c759bfb-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tX/s100010"},"text":"Pub. L. 119–21, title X, § 100010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/372"},"text":"139 Stat. 372","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
