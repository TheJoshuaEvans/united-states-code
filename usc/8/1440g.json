{"tag":"section","attrib":{"id":"id9c543103-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1440g"},"text":"§ 1440g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of information on military naturalization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c543104-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the effective date of any modification to a regulation related to naturalization under section 1439 or 1440 of this title, the Secretary of Homeland Security shall make appropriate updates to the Internet sites maintained by the Secretary to reflect such modification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c543105-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1440g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that the Secretary of Homeland Security, not later than 180 days after each effective date described in subsection (a), should make necessary updates to the appropriate application forms of the Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c543106-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/251/s3"},"text":"Pub. L. 110–251, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-26"},"text":"June 26, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2320"},"text":"122 Stat. 2320","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c543107-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c543108-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c543109-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Kendell Frederick Citizenship Assistance Act, and not as part of the Immigration and Nationality Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
