{"tag":"section","attrib":{"id":"id9c411e4b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1365"},"text":null,"children":[{"tag":"num","attrib":{"value":"1365"},"text":"§ 1365.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of States for costs of incarcerating illegal aliens and certain Cuban nationals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c411e4c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1365/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the amounts provided in advance in appropriation Acts, the Attorney General shall reimburse a State for the costs incurred by the State for the imprisonment of any illegal alien or Cuban national who is convicted of a felony by such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c411e4d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1365/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Illegal aliens convicted of a felony","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An illegal alien referred to in subsection (a) is any alien who is any alien convicted of a felony who is in the United States unlawfully and—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c411e4e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1365/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose most recent entry into the United States was without inspection, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c411e4f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1365/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whose most recent admission to the United States was as a nonimmigrant and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c411e50-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1365/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose period of authorized stay as a nonimmigrant expired, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c411e51-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1365/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose unlawful status was known to the Government,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"before the date of the commission of the crime for which the alien is convicted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c411e52-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1365/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marielito Cubans convicted of a felony","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Marielito Cuban convicted of a felony referred to in subsection (a) is a national of Cuba who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c411e53-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1365/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was allowed by the Attorney General to come to the United States in 1980,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c411e54-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1365/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after such arrival committed any violation of State or local law for which a term of imprisonment was imposed, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c411e55-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1365/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at the time of such arrival and at the time of such violation was not an alien lawfully admitted to the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c411e56-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1365/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for permanent or temporary residence, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c411e57-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1365/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the terms of an immigrant visa or a nonimmigrant visa issued,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"under the laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c411e58-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1365/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c411e59-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1365/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “State” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/36"},"text":"section 1101(a)(36) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c411e5a-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/603/tV/s501"},"text":"Pub. L. 99–603, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-06"},"text":"Nov. 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3443"},"text":"100 Stat. 3443","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c411e5b-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c411e5c-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c411e5d-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Immigration Reform and Control Act of 1986, and not as part of the Immigration and Nationality Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c411e5e-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c411e5f-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/317/tVIII"},"text":"Pub. L. 103–317, title VIII","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-26"},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1778"},"text":"108 Stat. 1778","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/317/tVIII"},"text":"“That the Attorney General shall promulgate regulations to (a) prescribe requirements for program participation eligibility for States, (b) require verification by States of the eligible incarcerated population data with the Immigration and Naturalization Service, (c) prescribe a formula for distributing assistance to eligible States, and (d) award assistance to eligible States”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
