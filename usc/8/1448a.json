{"tag":"section","attrib":{"id":"id9c56a289-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1448a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1448a"},"text":"§ 1448a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Address to newly naturalized citizens","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Either at the time of the rendition of the decree of naturalization or at such other time as the judge may fix, the judge or someone designated by him shall address the newly naturalized citizen upon the form and genius of our Government and the privileges and responsibilities of citizenship; it being the intent and purpose of this section to enlist the aid of the judiciary, in cooperation with civil and educational authorities, and patriotic organizations in a continuous effort to dignify and emphasize the significance of citizenship.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9c56a28a-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-02-29/ch49/s2"},"text":"Feb. 29, 1952, ch. 49, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/10"},"text":"66 Stat. 10","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c56a28b-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c56a28c-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c56a28d-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Immigration and Nationality Act which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was previously classified to section 154 of former Title 36, Patriotic Societies and Observances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id9c56a28e-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Similar provisions were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-05-03/ch183/s2"},"text":"act May 3, 1940, ch. 183, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/178"},"text":"54 Stat. 178","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s727a"},"text":"section 727a of this title","children":[],"tail":" prior to repeal by act "},{"tag":"date","attrib":{"date":"1952-02-29"},"text":"Feb. 29, 1952","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
