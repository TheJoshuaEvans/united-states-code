{"tag":"section","attrib":{"id":"id9c77e5c6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1815"},"text":null,"children":[{"tag":"num","attrib":{"value":"1815"},"text":"§ 1815.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inadmissible alien apprehension fee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c77e5c7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1815/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other fee authorized by law, the Secretary of Homeland Security shall require the payment of a fee, equal to the amount specified in subsection (b), by any inadmissible alien at the time such alien is apprehended between ports of entry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c77e5c8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1815/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount specified","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c77e5c9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1815/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For fiscal year 2025, the amount specified in this section shall be the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c77e5ca-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1815/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c77e5cb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1815/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount as the Secretary of Homeland Security may establish, by rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c77e5cc-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1815/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual adjustments for inflation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During fiscal year 2026, and during each subsequent fiscal year, the amount specified in this section shall be equal to the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c77e5cd-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1815/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the fee required under this subsection for the most recently concluded fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c77e5ce-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1815/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product resulting from the multiplication of the amount referred to in subparagraph (A) by the percentage (if any) by which the Consumer Price Index for All Urban Consumers for the month of July preceding the date on which such adjustment takes effect exceeds the Consumer Price Index for All Urban Consumers for the same month of the preceding calendar year, rounded to the next lowest multiple of $10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c77e5cf-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1815/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of inadmissible alien apprehension fees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During each fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c77e5d0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1815/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 50 percent of the fees collected pursuant to this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c77e5d1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1815/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be credited to U.S. Immigration and Customs Enforcement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c77e5d2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1815/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be deposited into the Detention and Removal Office Fee Account; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c77e5d3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1815/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be retained and expended by U.S. Immigration and Customs Enforcement without further appropriation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c77e5d4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1815/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts collected pursuant to this section that are not credited to U.S. Immigration and Customs Enforcement pursuant to paragraph (1) shall be deposited into the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c77e5d5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1815/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of inadmissible alien apprehension fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All of the fees collected pursuant to this section shall be deposited into the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c77e5d6-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tX/s100017"},"text":"Pub. L. 119–21, title X, § 100017","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/384"},"text":"139 Stat. 384","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
