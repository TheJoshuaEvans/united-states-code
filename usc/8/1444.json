{"tag":"section","attrib":{"id":"id9c56a239-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1444"},"text":null,"children":[{"tag":"num","attrib":{"value":"1444"},"text":"§ 1444.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Photographs; number","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c56a23a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1444/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three identical photographs of the applicant shall be signed by and furnished by each applicant for naturalization or citizenship. One of such photographs shall be affixed by the Attorney General to the original certificate of naturalization issued to the naturalized citizen and one to the duplicate certificate of naturalization required to be forwarded to the Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c56a23b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1444/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Three identical photographs of the applicant shall be furnished by each applicant for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c56a23c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1444/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a record of lawful admission for permanent residence to be made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1259"},"text":"section 1259 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c56a23d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1444/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certificate of derivative citizenship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c56a23e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1444/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certificate of naturalization or of citizenship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c56a23f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1444/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a special certificate of naturalization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c56a240-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1444/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certificate of naturalization or of citizenship, in lieu of one lost, mutilated, or destroyed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c56a241-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1444/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a new certificate of citizenship in the new name of any naturalized citizen who, subsequent to naturalization, has had his name changed by order of a court of competent jurisdiction or by marriage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c56a242-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1444/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a declaration of intention.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"One such photograph shall be affixed to each such certificate issued by the Attorney General and one shall be affixed to the copy of such certificate retained by the Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c56a243-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title III, ch. 2, § 333, "},{"tag":"ref","attrib":{"href":"/us/stat/66/253"},"text":"66 Stat. 253","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/tIV/s407/c/14"},"text":"Pub. L. 101–649, title IV, § 407(c)(14)","children":[],"tail":", (d)(11), "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5041"},"text":"104 Stat. 5041","children":[],"tail":", 5042; "},{"tag":"ref","attrib":{"href":"/us/pl/103/416/tII/s219/w"},"text":"Pub. L. 103–416, title II, § 219(w)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4318"},"text":"108 Stat. 4318","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c56a244-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c56a245-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c56a246-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"