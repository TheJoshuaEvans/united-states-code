{"tag":"section","attrib":{"id":"id9c5b5d27-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1488"},"text":null,"children":[{"tag":"num","attrib":{"value":"1488"},"text":"§ 1488.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nationality lost solely from performance of acts or fulfillment of conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The loss of nationality under this part shall result solely from the performance by a national of the acts or fulfillment of the conditions specified in this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9c5b5d28-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title III, ch. 3, § 356, "},{"tag":"ref","attrib":{"href":"/us/stat/66/272"},"text":"66 Stat. 272","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
