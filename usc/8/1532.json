{"tag":"section","attrib":{"id":"id9c601825-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1532"},"text":null,"children":[{"tag":"num","attrib":{"value":"1532"},"text":"§ 1532.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of removal court","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c601826-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1532/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of judges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Justice of the United States shall publicly designate 5 district court judges from 5 of the United States judicial circuits who shall constitute a court that shall have jurisdiction to conduct all removal proceedings. The Chief Justice may, in the Chief Justice’s discretion, designate the same judges under this section as are designated pursuant to section 103(a) of the Foreign Intelligence Surveillance Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1803/a"},"text":"50 U.S.C. 1803(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c601827-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1532/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each judge designated under subsection (a) shall serve for a term of 5 years and shall be eligible for redesignation, except that of the members first designated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c601828-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1532/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall serve for a term of 1 year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c601829-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1532/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall serve for a term of 2 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c60182a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1532/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall serve for a term of 3 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c60182b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1532/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall serve for a term of 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c60182c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1532/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief judge","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c60182d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1532/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Justice shall publicly designate one of the judges of the removal court to be the chief judge of the removal court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c60182e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1532/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The chief judge shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c60182f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1532/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promulgate rules to facilitate the functioning of the removal court; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c601830-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1532/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assign the consideration of cases to the various judges on the removal court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c601831-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1532/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expeditious and confidential nature of proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of section 103(c) of the Foreign Intelligence Surveillance Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1803/c"},"text":"50 U.S.C. 1803(c)","children":[],"tail":") shall apply to removal proceedings in the same manner as they apply to proceedings under that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"50 U.S.C. 1801","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c601832-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1532/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of panel of special attorneys","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The removal court shall provide for the designation of a panel of attorneys each of whom—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c601833-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1532/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a security clearance which affords the attorney access to classified information, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c601834-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1532/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has agreed to represent permanent resident aliens with respect to classified information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1534/e/3"},"text":"section 1534(e)(3) of this title","children":[],"tail":" in accordance with (and subject to the penalties under) this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c601835-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title V, § 502, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tIV/s401/a"},"text":"Pub. L. 104–132, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1259"},"text":"110 Stat. 1259","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII/s354/a/4"},"text":"Pub. L. 104–208, div. C, title III, § 354(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-643"},"text":"110 Stat. 3009–643","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c601836-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c601837-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c601838-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Intelligence Surveillance Act of 1978, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511"},"text":"Pub. L. 95–511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1783"},"text":"92 Stat. 1783","children":[],"tail":", which is classified principally to chapter 36 (§ 1801 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c601839-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c60183a-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c60183b-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" effective as if included in the enactment of subtitle A of title IV of the Antiterrorism and Effective Death Penalty Act of 1996, "},{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s358"},"text":"section 358 of Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182"},"text":"section 1182 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
