{"tag":"section","attrib":{"id":"id9c70b9f0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1724"},"text":null,"children":[{"tag":"num","attrib":{"value":"1724"},"text":"§ 1724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel management authorities for positions involved in the development and implementation of the interoperable electronic data system (“Chimera system”)","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c70b9f1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law relating to position classification or employee pay or performance, the Attorney General may hire and fix the compensation of necessary scientific, technical, engineering, and other analytical personnel for the purpose of the development and implementation of the interoperable electronic data system described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1722/a/2"},"text":"section 1722(a)(2) of this title","children":[],"tail":" (also known as the “Chimera system”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70b9f2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on rate of pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided by law, no employee compensated under subsection (a) may be paid at a rate in excess of the rate payable for a position at level III of the Executive Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70b9f3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1724/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on total calendar year payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Total payments to employees under any system established under this section shall be subject to the limitation on payments to employees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5307"},"text":"section 5307 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70b9f4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1724/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operating plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", the Attorney General shall submit to the Committee on Appropriations, the Committee on the Judiciary, the Select Committee on Intelligence, and the Committee on Foreign Relations of the Senate and the Committee on Appropriations, the Committee on the Judiciary, the Permanent Select Committee on Intelligence, and the Committee on International Relations of the House of Representatives an operating plan—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c70b9f5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1724/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the Attorney General’s intended use of the authority under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70b9f6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1724/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying any provisions of title 5 being waived for purposes of the development and implementation of the Chimera system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70b9f7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1724/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of this section shall terminate upon the implementation of the Chimera system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c70b9f8-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/173/tII/s204"},"text":"Pub. L. 107–173, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/551"},"text":"116 Stat. 551","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c70b9f9-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c70b9fa-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c70b9fb-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Level III of the Executive Schedule, referred to in subsec. (b), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c70b9fc-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id9c70b9fd-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on International Relations of House of Representatives changed to Committee on Foreign Affairs of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
