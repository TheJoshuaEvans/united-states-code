{"tag":"section","attrib":{"id":"id9c6bfecf-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641"},"text":null,"children":[{"tag":"num","attrib":{"value":"1641"},"text":"§ 1641.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c6bfed0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this chapter, the terms used in this chapter have the same meaning given such terms in section 101(a) of the Immigration and Nationality Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a"},"text":"8 U.S.C. 1101(a)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c6bfed1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified alien","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the term “qualified alien” means an alien who, at the time the alien applies for, receives, or attempts to receive a Federal public benefit, is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c6bfed2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an alien who is lawfully admitted for permanent residence under the Immigration and Nationality Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":" et seq.],"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bfed3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an alien who is granted asylum under section 208 of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1158"},"text":"8 U.S.C. 1158","children":[],"tail":"],"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bfed4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a refugee who is admitted to the United States under section 207 of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1157"},"text":"8 U.S.C. 1157","children":[],"tail":"],"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bfed5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an alien who is paroled into the United States under section 212(d)(5) of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182/d/5"},"text":"8 U.S.C. 1182(d)(5)","children":[],"tail":"] for a period of at least 1 year,"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bfed6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an alien whose deportation is being withheld under section 243(h) of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1253"},"text":"8 U.S.C. 1253","children":[],"tail":"] (as in effect immediately before the effective date of section 307 of division C of "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Public Law 104–208","children":[],"tail":") or section 241(b)(3) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1231/b/3"},"text":"8 U.S.C. 1231(b)(3)","children":[],"tail":"] (as amended by section 305(a) of division C of "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Public Law 104–208","children":[],"tail":"),"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bfed7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an alien who is granted conditional entry pursuant to section 203(a)(7) of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1153/a/7"},"text":"8 U.S.C. 1153(a)(7)","children":[],"tail":"] as in effect prior to "},{"tag":"date","attrib":{"date":"1980-04-01"},"text":"April 1, 1980","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bfed8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an alien who is a Cuban and Haitian entrant (as defined in section 501(e) of the Refugee Education Assistance Act of 1980), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bfed9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who lawfully resides in the United States in accordance with a Compact of Free Association referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1612/b/2/G"},"text":"section 1612(b)(2)(G) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c6bfeda-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain battered aliens as qualified aliens","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the term “qualified alien” includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c6bfedb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an alien who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c6bfedc-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been battered or subjected to extreme cruelty in the United States by a spouse or a parent, or by a member of the spouse or parent’s family residing in the same household as the alien and the spouse or parent consented to, or acquiesced in, such battery or cruelty, but only if (in the opinion of the agency providing such benefits) there is a substantial connection between such battery or cruelty and the need for the benefits to be provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c6bfedd-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has been approved or has a petition pending which sets forth a prima facie case for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c6bfede-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" status as a spouse or a child of a United States citizen pursuant to clause (ii), (iii), or (iv) of section 204(a)(1)(A) of the Immigration and Nationality Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1154/a/1/A/ii"},"text":"8 U.S.C. 1154(a)(1)(A)(ii)","children":[],"tail":", (iii), (iv)],"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c6bfedf-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classification pursuant to clause (ii) or (iii) of section 204(a)(1)(B) of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1154/a/1/B/ii"},"text":"8 U.S.C. 1154(a)(1)(B)(ii)","children":[],"tail":", (iii)],"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c6bfee0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspension of deportation under section 244(a)(3) of the Immigration and Nationality Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1254/a/3"},"text":"8 U.S.C. 1254(a)(3)","children":[],"tail":"] (as in effect before the title III–A effective date in section 309 of the Illegal Immigration Reform and Immigrant Responsibility Act of 1996)."},{"tag":"ref","attrib":{"idref":"fn002109"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002109"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a comma."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c6bfee1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" status as a spouse or child of a United States citizen pursuant to clause (i) of section 204(a)(1)(A) of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1154/a/1/A/i"},"text":"8 U.S.C. 1154(a)(1)(A)(i)","children":[],"tail":"], or classification pursuant to clause (i) of section 204(a)(1)(B) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1154/a/1/B/i"},"text":"8 U.S.C. 1154(a)(1)(B)(i)","children":[],"tail":"]; "},{"tag":"ref","attrib":{"idref":"fn002110"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002110"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The semicolon probably should be “, or”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c6bfee2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/c/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cancellation of removal pursuant to section 240A(b)(2) of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1229b/b/2"},"text":"8 U.S.C. 1229b(b)(2)","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bfee3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an alien—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c6bfee4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose child has been battered or subjected to extreme cruelty in the United States by a spouse or a parent of the alien (without the active participation of the alien in the battery or cruelty), or by a member of the spouse or parent’s family residing in the same household as the alien and the spouse or parent consented or acquiesced to such battery or cruelty, and the alien did not actively participate in such battery or cruelty, but only if (in the opinion of the agency providing such benefits) there is a substantial connection between such battery or cruelty and the need for the benefits to be provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c6bfee5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who meets the requirement of subparagraph (B) of paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bfee6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an alien child who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c6bfee7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resides in the same household as a parent who has been battered or subjected to extreme cruelty in the United States by that parent’s spouse or by a member of the spouse’s family residing in the same household as the parent and the spouse consented or acquiesced to such battery or cruelty, but only if (in the opinion of the agency providing such benefits) there is a substantial connection between such battery or cruelty and the need for the benefits to be provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c6bfee8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who meets the requirement of subparagraph (B) of paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bfee9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1641/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an alien who has been granted nonimmigrant status under section 101(a)(15)(T) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/15/T"},"text":"8 U.S.C. 1101(a)(15)(T)","children":[],"tail":") or who has a pending application that sets forth a prima facie case for eligibility for such nonimmigrant status."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This subsection shall not apply to an alien during any period in which the individual responsible for such battery or cruelty resides in the same household or family eligibility unit as the individual subjected to such battery or cruelty.","children":[],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"After consultation with the Secretaries of Health and Human Services, Agriculture, and Housing and Urban Development, the Commissioner of Social Security, and with the heads of such Federal agencies administering benefits as the Attorney General considers appropriate, the Attorney General shall issue guidance (in the Attorney General’s sole and unreviewable discretion) for purposes of this subsection and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1631/f"},"text":"section 1631(f) of this title","children":[],"tail":", concerning the meaning of the terms “battery” and “extreme cruelty”, and the standards and methods to be used for determining whether a substantial connection exists between battery or cruelty suffered and an individual’s need for benefits under a specific Federal, State, or local program."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c6bfeea-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIV/s431"},"text":"Pub. L. 104–193, title IV, § 431","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2274"},"text":"110 Stat. 2274","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII/s308/g/8/E"},"text":"Pub. L. 104–208, div. C, title III, § 308(g)(8)(E)","children":[],"tail":", title V, § 501, "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-624"},"text":"110 Stat. 3009–624","children":[],"tail":", 3009–670; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV"},"text":"Pub. L. 105–33, title V","children":[],"tail":", §§ 5302(c)(3), 5562, 5571(a)–(c), 5581(b)(6), (7), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/599"},"text":"111 Stat. 599","children":[],"tail":", 638, 640, 643; "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/dB/tV/s1508"},"text":"Pub. L. 106–386, div. B, title V, § 1508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1530"},"text":"114 Stat. 1530","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/457/tII/s211/a"},"text":"Pub. L. 110–457, title II, § 211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5063"},"text":"122 Stat. 5063","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dCC/tII/s208/c"},"text":"Pub. L. 116–260, div. CC, title II, § 208(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2985"},"text":"134 Stat. 2985","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/42/dG/tII/s209/f/3"},"text":"Pub. L. 118–42, div. G, title II, § 209(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-09"},"text":"Mar. 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/445"},"text":"138 Stat. 445","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c6bfeeb-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c6bfeec-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c6bfeed-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title” meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2260"},"text":"110 Stat. 2260","children":[],"tail":", which enacted this chapter, "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1183a"},"text":"section 1183a of this title","children":[],"tail":", and sections 611a and 1437y of Title 42, The Public Health and Welfare, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1383"},"text":"section 1383 of this title","children":[],"tail":", sections 32 and 6213 of Title 26, Internal Revenue Code, and sections 1436a and 1471 of Title 42, and enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1183a"},"text":"section 1183a of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s32"},"text":"section 32 of Title 26","children":[],"tail":". For complete classification of title IV to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Immigration and Nationality Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":", which is classified principally to chapter 12 (§ 1101 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 243 of such Act, referred to in subsec. (b)(5), is section 243 of act ","children":[{"tag":"date","attrib":{"date":"1952-06-27"},"text":"June 27, 1952","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1253"},"text":"section 1253 of this title","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1253"},"text":"Section 1253 of this title","children":[],"tail":" was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII/s307/a"},"text":"Pub. L. 104–208, div. C, title III, § 307(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-612"},"text":"110 Stat. 3009–612","children":[],"tail":", and, as so amended, no longer contains a subsec. (h). For effective date of "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s307"},"text":"section 307 of Pub. L. 104–208","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s309"},"text":"section 309 of Pub. L. 104–208","children":[],"tail":", set out as an Effective Date of 1996 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 203(a)(7) of such Act as in effect prior to ","children":[{"tag":"date","attrib":{"date":"1980-04-01"},"text":"April 1, 1980","children":[],"tail":", referred to in subsec. (b)(6), means section 203(a)(7) of act "},{"tag":"date","attrib":{"date":"1952-06-27"},"text":"June 27, 1952","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1153/a/7"},"text":"section 1153(a)(7) of this title","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1153/a/7"},"text":"Section 1153(a)(7) of this title","children":[],"tail":" was repealed and section 1153(a)(8) was redesignated section 1153(a)(7) by "},{"tag":"ref","attrib":{"href":"/us/pl/96/212/tII/s203/c/3"},"text":"Pub. L. 96–212, title II, § 203(c)(3)","children":[],"tail":", (6), "},{"tag":"date","attrib":{"date":"1980-03-17"},"text":"Mar. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/107"},"text":"94 Stat. 107","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1980-04-01"},"text":"Apr. 1, 1980","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 501(e) of the Refugee Education Assistance Act of 1980, referred to in subsec. (b)(7), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/422/s501/e"},"text":"section 501(e) of Pub. L. 96–422","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1522"},"text":"section 1522 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 309 of the Illegal Immigration Reform and Immigrant Responsibility Act of 1996, referred to in subsec. (c)(1)(B)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII/s309"},"text":"section 309 of title III of div. C of Pub. L. 104–208","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c6bfeee-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42"},"text":"Pub. L. 118–42","children":[],"tail":" struck out “, but only with respect to the designated Federal program defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1612/b/3/C"},"text":"section 1612(b)(3)(C) of this title","children":[],"tail":" (relating to the Medicaid program)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457"},"text":"Pub. L. 110–457","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(1)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386"},"text":"Pub. L. 106–386","children":[],"tail":" amended cl. (iii) generally. Prior to amendment, cl. (iii) read as follows: “cancellation of removal under section 240A of such Act (as in effect prior to "},{"tag":"date","attrib":{"date":"1997-04-01"},"text":"April 1, 1997","children":[],"tail":"),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5562"},"text":"Pub. L. 105–33, § 5562","children":[],"tail":", substituted “section 243(h) of such Act (as in effect immediately before the effective date of section 307 of division C of "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Public Law 104–208","children":[],"tail":") or section 241(b)(3) of such Act (as amended by section 305(a) of division C of "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Public Law 104–208","children":[],"tail":")” for “section 243(h) of such Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5302/c/3"},"text":"Pub. L. 105–33, § 5302(c)(3)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5571/b"},"text":"Pub. L. 105–33, § 5571(b)","children":[],"tail":", inserted at end “After consultation with the Secretaries of Health and Human Services, Agriculture, and Housing and Urban Development, the Commissioner of Social Security, and with the heads of such Federal agencies administering benefits as the Attorney General considers appropriate, the Attorney General shall issue guidance (in the Attorney General’s sole and unreviewable discretion) for purposes of this subsection and "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1631/f"},"text":"section 1631(f) of this title","children":[],"tail":", concerning the meaning of the terms ‘battery’ and ‘extreme cruelty’, and the standards and methods to be used for determining whether a substantial connection exists between battery or cruelty suffered and an individual’s need for benefits under a specific Federal, State, or local program.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5571/a"},"text":"Pub. L. 105–33, § 5571(a)","children":[],"tail":", substituted “agency providing such benefits)” for “Attorney General, which opinion is not subject to review by any court)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5581/b/7/A"},"text":"Pub. L. 105–33, § 5581(b)(7)(A)","children":[],"tail":", substituted “(as in effect prior to "},{"tag":"date","attrib":{"date":"1997-04-01"},"text":"April 1, 1997","children":[],"tail":"),” for “, or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B)(v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5581/b/7/B"},"text":"Pub. L. 105–33, § 5581(b)(7)(B)","children":[],"tail":", added cl. (v)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5571/a"},"text":"Pub. L. 105–33, § 5571(a)","children":[],"tail":", substituted “agency providing such benefits)” for “Attorney General, which opinion is not subject to review by any court)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5581/b/6"},"text":"Pub. L. 105–33, § 5581(b)(6)","children":[],"tail":", substituted “subparagraph (B) of paragraph (1)” for “clause (ii) of subparagraph (A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5571/c"},"text":"Pub. L. 105–33, § 5571(c)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s501"},"text":"Pub. L. 104–208, § 501","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{