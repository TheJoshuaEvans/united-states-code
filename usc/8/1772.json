{"tag":"section","attrib":{"id":"id9c732ab4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1772"},"text":null,"children":[{"tag":"num","attrib":{"value":"1772"},"text":"§ 1772.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International cooperation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c732ab5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1772/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International electronic data system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State and the Commissioner of Immigration and Naturalization, in consultation with the Assistant to the President for Homeland Security, shall jointly conduct a study of the alternative approaches (including the costs of, and procedures necessary for, each alternative approach) for encouraging or requiring Canada, Mexico, and countries treated as visa waiver program countries under section 217 of the Immigration and Nationality Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1187"},"text":"8 U.S.C. 1187","children":[],"tail":"] to develop an intergovernmental network of interoperable electronic data systems that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c732ab6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1772/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitates real-time access to that country’s law enforcement and intelligence information that is needed by the Department of State and the Immigration and Naturalization Service to screen visa applicants and applicants for admission into the United States to identify aliens who are inadmissible or deportable under the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732ab7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1772/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is interoperable with the electronic data system implemented under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1722"},"text":"section 1722 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c732ab8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1772/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs in accordance with implementation of the technology standard referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1722/a"},"text":"section 1722(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c732ab9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1772/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", the Secretary of State and the Attorney General shall submit to the appropriate committees of Congress a report setting forth the findings of the study conducted under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c732aba-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/173/tVI/s603"},"text":"Pub. L. 107–173, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/564"},"text":"116 Stat. 564","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c732abb-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c732abc-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c732abd-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Immigration and Nationality Act, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":", which is classified principally to chapter 12 (§ 1101 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c732abe-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c732abf-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
