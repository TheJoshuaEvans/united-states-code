{"tag":"section","attrib":{"id":"id9c759bcf-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1807"},"text":null,"children":[{"tag":"num","attrib":{"value":"1807"},"text":"§ 1807.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form I–94 fee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c759bd0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1807/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fee authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other fee authorized by law, the Secretary of Homeland Security shall require the payment of a fee, equal to the amount specified in subsection (b), by any alien who submits an application for a Form I–94 Arrival/Departure Record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c759bd1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1807/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount specified","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c759bd2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1807/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For fiscal year 2025, the amount specified in this section shall be the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c759bd3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1807/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $24; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c759bd4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1807/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount as the Secretary of Homeland Security may establish, by rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759bd5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1807/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual adjustments for inflation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During fiscal year 2026, and during each subsequent fiscal year, the amount specified in this section shall be equal to the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c759bd6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1807/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the fee required under this subsection for the most recently concluded fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c759bd7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1807/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product resulting from the multiplication of the amount referred to in subparagraph (A) by the percentage (if any) by which the Consumer Price Index for All Urban Consumers for the month of July preceding the date on which such adjustment takes effect exceeds the Consumer Price Index for All Urban Consumers for the same month of the preceding calendar year, rounded down to the nearest dollar.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c759bd8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1807/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of Form I–94 fees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During each fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c759bd9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1807/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 20 percent of the fees collected pursuant to this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c759bda-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1807/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be deposited into the Land Border Inspection Fee Account in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1356/q/2"},"text":"section 1356(q)(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c759bdb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1807/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made available to U.S. Customs and Border Protection to retain and spend without further appropriation for the purpose of processing Form I–94; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759bdc-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1807/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts not deposited into the Land Border Inspection Fee Account pursuant to paragraph (1)(A) shall be deposited in the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c759bdd-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1807/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No fee waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees required to be paid under this section shall not be waived or reduced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c759bde-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tX/s100008"},"text":"Pub. L. 119–21, title X, § 100008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/370"},"text":"139 Stat. 370","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
