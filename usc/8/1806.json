{"tag":"section","attrib":{"id":"id9c759bbe-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1806"},"text":null,"children":[{"tag":"num","attrib":{"value":"1806"},"text":"§ 1806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visa integrity fee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c759bbf-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1806/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visa integrity fee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c759bc0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1806/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other fee authorized by law, the Secretary of Homeland Security shall require the payment of a fee, equal to the amount specified in this subsection, by any alien issued a nonimmigrant visa at the time of such issuance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759bc1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1806/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For fiscal year 2025, the amount specified in this section shall be the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c759bc2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1806/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c759bc3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1806/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount as the Secretary of Homeland Security may establish, by rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759bc4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1806/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual adjustments for inflation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During fiscal year 2026, and during each subsequent fiscal year, the amount specified in this section shall be equal to the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c759bc5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1806/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the fee required under this subsection for the most recently concluded fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c759bc6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1806/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product resulting from the multiplication of the amount referred to in subparagraph (A) by the percentage (if any) by which the Consumer Price Index for All Urban Consumers for the month of July preceding the date on which such adjustment takes effect exceeds the Consumer Price Index for All Urban Consumers for the same month of the preceding calendar year, rounded down to the nearest dollar.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759bc7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1806/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of visa integrity fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All of the fees collected pursuant to this section that are not reimbursed pursuant to subsection (b) shall be deposited into the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759bc8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1806/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No fee waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees required to be paid under this subsection shall not be waived or reduced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c759bc9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1806/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fee reimbursement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Homeland Security may provide a reimbursement to an alien of the fee required under subsection (a) for the issuance of a nonimmigrant visa after the expiration of such nonimmigrant visa’s period of validity if such alien demonstrates that he or she—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c759bca-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1806/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after admission to the United States pursuant to such nonimmigrant visa, complied with all conditions of such nonimmigrant visa, including the condition that an alien shall not accept unauthorized employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759bcb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1806/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c759bcc-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1806/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not sought to extend his or her period of admission during such period of validity and departed the United States not later than 5 days after the last day of such period; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c759bcd-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1806/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during such period of validity, was granted an extension of such nonimmigrant status or an adjustment to the status of a lawful permanent resident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c759bce-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tX/s100007"},"text":"Pub. L. 119–21, title X, § 100007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/370"},"text":"139 Stat. 370","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
