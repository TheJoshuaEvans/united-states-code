{"tag":"section","attrib":{"id":"id9c628957-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534"},"text":null,"children":[{"tag":"num","attrib":{"value":"1534"},"text":"§ 1534.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal hearing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c628958-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c628959-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expeditious hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which an application for an order is approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1533/c/2"},"text":"section 1533(c)(2) of this title","children":[],"tail":", a removal hearing shall be conducted under this section as expeditiously as practicable for the purpose of determining whether the alien to whom the order pertains should be removed from the United States on the grounds that the alien is an alien terrorist."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c62895a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The removal hearing shall be open to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c62895b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An alien who is the subject of a removal hearing under this subchapter shall be given reasonable notice of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c62895c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the charges against the alien, including a general account of the basis for the charges; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c62895d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time and place at which the hearing will be held.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c62895e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights in hearing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c62895f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of counsel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The alien shall have a right to be present at such hearing and to be represented by counsel. Any alien financially unable to obtain counsel shall be entitled to have counsel assigned to represent the alien. Such counsel shall be appointed by the judge pursuant to the plan for furnishing representation for any person financially unable to obtain adequate representation for the district in which the hearing is conducted, as provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3006A"},"text":"section 3006A of title 18","children":[],"tail":". All provisions of that section shall apply and, for purposes of determining the maximum amount of compensation, the matter shall be treated as if a felony was charged."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c628960-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Introduction of evidence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the limitations in subsection (e), the alien shall have a reasonable opportunity to introduce evidence on the alien’s own behalf.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c628961-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination of witnesses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the limitations in subsection (e), the alien shall have a reasonable opportunity to examine the evidence against the alien and to cross-examine any witness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c628962-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A verbatim record of the proceedings and of all testimony and evidence offered or produced at such a hearing shall be kept.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c628963-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal decision based on evidence at hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The decision of the judge regarding removal shall be based only on that evidence introduced at the removal hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c628964-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpoenas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c628965-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At any time prior to the conclusion of the removal hearing, either the alien or the Department of Justice may request the judge to issue a subpoena for the presence of a named witness (which subpoena may also command the person to whom it is directed to produce books, papers, documents, or other objects designated therein) upon a satisfactory showing that the presence of the witness is necessary for the determination of any material matter. Such a request may be made ex parte except that the judge shall inform the Department of Justice of any request for a subpoena by the alien for a witness or material if compliance with such a subpoena would reveal classified evidence or the source of that evidence. The Department of Justice shall be given a reasonable opportunity to oppose the issuance of such a subpoena.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c628966-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment for attendance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an application for a subpoena by the alien also makes a showing that the alien is financially unable to pay for the attendance of a witness so requested, the court may order the costs incurred by the process and the fees of the witness so subpoenaed to be paid from funds appropriated for the enforcement of subchapter II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c628967-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nationwide service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A subpoena under this subsection may be served anywhere in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c628968-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Witness fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A witness subpoenaed under this subsection shall receive the same fees and expenses as a witness subpoenaed in connection with a civil proceeding in a court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c628969-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No access to classified information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection is intended to allow an alien to have access to classified information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c62896a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discovery","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c62896b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c62896c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government is authorized to use in a removal proceedings ","children":[{"tag":"ref","attrib":{"idref":"fn002097"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002097"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “proceeding”."}],"tail":" the fruits of electronic surveillance and unconsented physical searches authorized under the Foreign Intelligence Surveillance Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"50 U.S.C. 1801","children":[],"tail":" et seq.) without regard to subsections (c), (e), (f), (g), and (h) of section 106 of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1806/c"},"text":"50 U.S.C. 1806(c)","children":[],"tail":", (e), (f), (g), (h)] and discovery of information derived pursuant to such Act, or otherwise collected for national security purposes, shall not be authorized if disclosure would present a risk to the national security of the United States;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c62896d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an alien subject to removal under this subchapter shall not be entitled to suppress evidence that the alien alleges was unlawfully obtained; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c62896e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3504"},"text":"section 3504 of title 18","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1806/c"},"text":"section 1806(c) of title 50","children":[],"tail":" shall not apply if the Attorney General determines that public disclosure would pose a risk to the national security of the United States because it would disclose classified information or otherwise threaten the integrity of a pending investigation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c62896f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protective orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall prevent the United States from seeking protective orders and from asserting privileges ordinarily available to the United States to protect against the disclosure of classified information, including the invocation of the military and State secrets privileges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c628970-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of classified information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c628971-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The judge shall examine, ex parte and in camera, any evidence for which the Attorney General determines that public disclosure would pose a risk to the national security of the United States or to the security of any individual because it would disclose classified information and neither the alien nor the public shall be informed of such evidence or its sources other than through reference to the summary provided pursuant to this paragraph. Notwithstanding the previous sentence, the Department of Justice may, in its discretion and, in the case of classified information, after coordination with the originating agency, elect to introduce such evidence in open session.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c628972-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to such information, the Government shall submit to the removal court an unclassified summary of the specific evidence that does not pose that risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c628973-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 15 days after submission, the judge shall approve the summary if the judge finds that it is sufficient to enable the alien to prepare a defense. The Government shall deliver to the alien a copy of the unclassified summary approved under this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c628974-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c628975-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an unclassified summary is not approved by the removal court under subparagraph (C), the Government shall be afforded 15 days to correct the deficiencies identified by the court and submit a revised unclassified summary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c628976-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revised summary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the revised unclassified summary is not approved by the court within 15 days of its submission pursuant to subparagraph (C), the removal hearing shall be terminated unless the judge makes the findings under clause (iii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c628977-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The findings described in this clause are, with respect to an alien, that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id9c628978-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3/D/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the continued presence of the alien in the United States would likely cause serious and irreparable harm to the national security or death or serious bodily injury to any person, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id9c628979-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3/D/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of the summary would likely cause serious and irreparable harm to the national security or death or serious bodily injury to any person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c62897a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of hearing without summary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a judge makes the findings described in subparagraph (D)(iii)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c62897b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the alien involved is an alien lawfully admitted for permanent residence, the procedures described in subparagraph (F) shall apply; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c62897c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in all cases the special removal hearing shall continue, the Department of Justice shall cause to be delivered to the alien a statement that no summary is possible, and the classified information submitted in camera and ex parte may be used pursuant to this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c62897d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special procedures for access and challenges to classified information by special attorneys in case of lawful permanent aliens","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c62897e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The procedures described in this subparagraph are that the judge (under rules of the removal court) shall designate a special attorney to assist the alien—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id9c62897f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3/F/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by reviewing in camera the classified information on behalf of the alien, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id9c628980-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3/F/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by challenging through an in camera proceeding the veracity of the evidence contained in the classified information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c628981-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on disclosure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A special attorney receiving classified information under clause (i)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id9c628982-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3/F/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not disclose the information to the alien or to any other attorney representing the alien, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id9c628983-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/e/3/F/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who discloses such information in violation of subclause (I) shall be subject to a fine under title 18, imprisoned for not less than 10 years nor more than 25 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c628984-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arguments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Following the receipt of evidence, the Government and the alien shall be given fair opportunity to present argument as to whether the evidence is sufficient to justify the removal of the alien. The Government shall open the argument. The alien shall be permitted to reply. The Government shall then be permitted to reply in rebuttal. The judge may allow any part of the argument that refers to evidence received in camera and ex parte to be heard in camera and ex parte.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c628985-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Burden of proof","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the hearing, it is the Government’s burden to prove, by the preponderance of the evidence, that the alien is subject to removal because the alien is an alien terrorist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c628986-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of evidence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Rules of Evidence shall not apply in a removal hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c628987-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of deportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the judge, after considering the evidence on the record as a whole, finds that the Government has met its burden, the judge shall order the alien removed and detained pending removal from the United States. If the alien was released pending the removal hearing, the judge shall order the Attorney General to take the alien into custody.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c628988-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the time of issuing a decision as to whether the alien shall be removed, the judge shall prepare a written order containing a statement of facts found and conclusions of law. Any portion of the order that would reveal the substance or source of information received in camera and ex parte pursuant to subsection (e) shall not be made available to the alien or the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c628989-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No right to ancillary relief","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At no time shall the judge consider or provide for relief from removal based on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c62898a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" asylum under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1158"},"text":"section 1158 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c62898b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by ","children":[{"tag":"ref","attrib":{"idref":"fn002098"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002098"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The word “by” probably should not appear."}],"tail":" withholding of removal under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1231/b/3"},"text":"section 1231(b)(3) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c62898c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/k/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cancellation of removal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1229b"},"text":"section 1229b of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c62898d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/k/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" voluntary departure under section 1254a(e) ","children":[{"tag":"ref","attrib":{"idref":"fn002099"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002099"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" See References in Text note below."}],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c62898e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/k/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjustment of status under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1255"},"text":"section 1255 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c62898f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/k/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" registry under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1259"},"text":"section 1259 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c628990-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1534/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on terrorist removal proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 months from ","children":[{"tag":"date","attrib":{"date":"2001-12-28"},"text":"December 28, 2001","children":[],"tail":", the Attorney General shall submit to Congress a report concerning the effect and efficacy of alien terrorist removal proceedings, including the reasons why proceedings pursuant to this section have not been used by the Attorney General in the past and the effect on the use of these proceedings after the enactment of the USA PATRIOT Act of 2001 ("},{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Public Law 107–56","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c628991-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title V, § 504, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tIV/s401/a"},"text":"Pub. L. 104–132, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1260"},"text":"110 Stat. 1260","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII"},"text":"Pub. L. 104–208, div. C, title III","children":[],"tail":", §§ 308(g)(7)(B), (8)(B), 354(a)(1), (2), (b), 357, "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-623"},"text":"110 Stat. 3009–623","children":[],"tail":", 3009–624, 3009–641 to 3009–644; "},{"tag":"ref","attrib":{"href":"/us/pl/107/108/tIII/s313"},"text":"Pub. L. 107–108, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1401"},"text":"115 Stat. 1401","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c628992-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c628993-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c628994-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Intelligence Surveillance Act of 1978, referred to in subsec. (e)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511"},"text":"Pub. L. 95–511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1783"},"text":"92 Stat. 1783","children":[],"tail":", which is classified principally to chapter 36 (§ 1801 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Rules of Evidence, referred to in subsec. (h), are set out in the Appendix to Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1254a/e"},"text":"Section 1254a(e) of this title","children":[],"tail":", referred to in subsec. (k)(4), was in the original a reference to “section 244(e)”, meaning section 244(e) of act "},{"tag":"date","attrib":{"date":"1952-06-27"},"text":"June 27, 1952","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1254/e"},"text":"section 1254(e) of this title","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII/s308/b/7"},"text":"Pub. L. 104–208, div. C, title III, § 308(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-615"},"text":"110 Stat. 3009–615","children":[],"tail":", repealed section 244 and renumbered section 244A as section 244, which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1254a"},"text":"section 1254a of this title","children":[],"tail":". For provisions relating to voluntary departure, see "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1229c"},"text":"section 1229c of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The USA PATRIOT Act of 2001, referred to in subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), is "},{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/272"},"text":"115 Stat. 272","children":[],"tail":", known as the Uniting and Strengthening America by Providing Appropriate Tools Required to Intercept and Obstruct Terrorism Act of 2001 or the USA PATRIOT Act. For complete classification of this Act to the Code, see Short Title of 2001 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1"},"text":"section 1 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c628995-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/107/108"},"text":"Pub. L. 107–108","children":[],"tail":" added subsec. ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s354/b/1/A/ii"},"text":"Pub. L. 104–208, § 354(b)(1)(A)(ii)","children":[],"tail":", substituted “pursuant to such Act” for “pursuant to the Foreign Intelligence Surveillance Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"50 U.S.C. 1801","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s354/b/1/A/i"},"text":"Pub. L. 104–208, § 354(b)(1)(A)(i)","children":[],"tail":", inserted “the Government is authorized to use in a removal proceedings the fruits of electronic surveillance and unconsented physical searches authorized under the Foreign Intelligence Surveillance Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"50 U.S.C. 1801","children":[],"tail":" et seq.) without regard to subsections (c), (e), (f), (g), and (h) of section 106 of that Act and” before “discovery of information”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s354/b/1/B"},"text":"Pub. L. 104–208, § 354(b)(1)(B)","children":[],"tail":", substituted “and neither the alien nor the public shall be informed of such evidence or its sources other than through reference to the summary provided pursuant to this paragraph. Notwithstanding the previous sentence, the Department of Justice may, in its discretion and, in the case of classified information, after coordination with the originating agency, elect to introduce such evidence in open session.” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3)(D)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s354/a/1/A"},"text":"Pub. L. 104–208, § 354(a)(1)(A)","children":[],"tail":", inserted “unless the judge makes the findings under clause (iii)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3)(D)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s354/a/1/B"},"text":"Pub. L. 104–208, § 354(a)(1)(B)","children":[],"tail":", added cl. (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3)(E), (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s354/a/2"},"text":"Pub. L. 104–208, § 354(a)(2)","children":[],"tail":", added subpars. (E) and (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s354/b/2"},"text":"Pub. L. 104–208, § 354(b)(2)","children":[],"tail":", inserted at end “The judge may allow any part of the argument that refers to evidence received in camera and ex parte to be heard in camera and ex parte.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s354/b/3"},"text":"Pub. L. 104–208, § 354(b)(3)","children":[],"tail":", inserted at end “Any portion of the order that would reveal the substance 