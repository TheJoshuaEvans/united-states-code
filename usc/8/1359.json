{"tag":"section","attrib":{"id":"id9c411df3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1359"},"text":null,"children":[{"tag":"num","attrib":{"value":"1359"},"text":"§ 1359.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to American Indians born in Canada","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to affect the right of American Indians born in Canada to pass the borders of the United States, but such right shall extend only to persons who possess at least 50 per centum of blood of the American Indian race.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9c411df4-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title II, ch. 9, § 289, "},{"tag":"ref","attrib":{"href":"/us/stat/66/234"},"text":"66 Stat. 234","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
