{"tag":"section","attrib":{"id":"id9c6289c0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1536"},"text":null,"children":[{"tag":"num","attrib":{"value":"1536"},"text":"§ 1536.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Custody and release pending removal hearing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c6289c1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1536/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Upon filing application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c6289c2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1536/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraphs (2) and (3), the Attorney General may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c6289c3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1536/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into custody any alien with respect to whom an application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1533"},"text":"section 1533 of this title","children":[],"tail":" has been filed; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c6289c4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1536/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain such an alien in custody in accordance with the procedures authorized by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6289c5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1536/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for permanent resident aliens","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c6289c6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1536/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release hearing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An alien lawfully admitted for permanent residence shall be entitled to a release hearing before the judge assigned to hear the removal hearing. Such an alien shall be detained pending the removal hearing, unless the alien demonstrates to the court that the alien—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9c6289c7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1536/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a person lawfully admitted for permanent residence in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c6289c8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1536/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if released upon such terms and conditions as the court may prescribe (including the posting of any monetary amount), is not likely to flee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9c6289c9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1536/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not endanger national security, or the safety of any person or the community, if released.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c6289ca-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1536/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information considered","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The judge may consider classified information submitted in camera and ex parte in making a determination whether to release an alien pending the removal hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6289cb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1536/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release if order denied and no review sought","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c6289cc-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1536/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), if a judge of the removal court denies the order sought in an application filed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1533"},"text":"section 1533 of this title","children":[],"tail":", and the Attorney General does not seek review of such denial, the alien shall be released from custody."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c6289cd-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1536/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of regular procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not prevent the arrest and detention of the alien pursuant to subchapter II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c6289ce-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1536/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditional release if order denied and review sought","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c6289cf-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1536/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a judge of the removal court denies the order sought in an application filed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1533"},"text":"section 1533 of this title","children":[],"tail":" and the Attorney General seeks review of such denial, the judge shall release the alien from custody subject to the least restrictive condition, or combination of conditions, of release described in section 3142(b) and clauses (i) through (xiv) of "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3142/c/1/B"},"text":"section 3142(c)(1)(B) of title 18","children":[],"tail":" that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c6289d0-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1536/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will reasonably assure the appearance of the alien at any future proceeding pursuant to this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c6289d1-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1536/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not endanger the safety of any other person or the community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6289d2-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1536/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No release for certain aliens","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the judge finds no such condition or combination of conditions, as described in paragraph (1), the alien shall remain in custody until the completion of any appeal authorized by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c6289d3-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title V, § 506, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tIV/s401/a"},"text":"Pub. L. 104–132, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1265"},"text":"110 Stat. 1265","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c6289d4-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c6289d5-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c6289d6-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
