{"tag":"section","attrib":{"id":"id9c6bfe95-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1625"},"text":null,"children":[{"tag":"num","attrib":{"value":"1625"},"text":"§ 1625.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for verification of eligibility for State and local public benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A State or political subdivision of a State is authorized to require an applicant for State and local public benefits (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1621/c"},"text":"section 1621(c) of this title","children":[],"tail":") to provide proof of eligibility."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9c6bfe96-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIV/s413"},"text":"Pub. L. 104–193, title IV, § 413","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV/s5307/a"},"text":"Pub. L. 105–33, title V, § 5307(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/602"},"text":"111 Stat. 602","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c6bfe97-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c6bfe98-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id9c6bfe99-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{