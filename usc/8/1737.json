{"tag":"section","attrib":{"id":"id9c70ba4e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1737"},"text":null,"children":[{"tag":"num","attrib":{"value":"1737"},"text":"§ 1737.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tracking system for stolen passports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c70ba4f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1737/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entering stolen passport identification numbers in the interoperable data system","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c70ba50-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1737/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning with implementation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1722"},"text":"section 1722 of this title","children":[],"tail":" of the law enforcement and intelligence data system, not later than 72 hours after receiving notification of the loss or theft of a United States or foreign passport, the Attorney General and the Secretary of State, as appropriate, shall enter into such system the corresponding identification number for the lost or stolen passport."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c70ba51-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1737/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entry of information on previously lost or stolen passports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, the Attorney General, in consultation with the Secretary of State, shall enter into such system the corresponding identification numbers for the United States and foreign passports lost or stolen prior to the implementation of such system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c70ba52-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1737/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until such time as the law enforcement and intelligence data system described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1722"},"text":"section 1722 of this title","children":[],"tail":" is fully implemented, the Attorney General shall enter the data described in subsection (a) into an existing data system being used to determine the admissibility or deportability of aliens."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c70ba53-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/173/tIII/s308"},"text":"Pub. L. 107–173, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/556"},"text":"116 Stat. 556","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c70ba54-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c70ba55-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c70ba56-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
