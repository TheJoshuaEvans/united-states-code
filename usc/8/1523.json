{"tag":"section","attrib":{"id":"id9c6017f3-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1523"},"text":null,"children":[{"tag":"num","attrib":{"value":"1523"},"text":"§ 1523.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c6017f4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1523/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall submit a report on activities under this subchapter to the Committees on the Judiciary of the House of Representatives and of the Senate not later than the January 31 following the end of each fiscal year, beginning with fiscal year 1980.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c6017f5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1523/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each such report shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c6017f6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1523/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an updated profile of the employment and labor force statistics for refugees who have entered the United States within the five-fiscal-year period immediately preceding the fiscal year within which the report is to be made and for refugees who entered earlier and who have shown themselves to be significantly and disproportionately dependent on welfare, as well as a description of the extent to which refugees received the forms of assistance or services under this subchapter during that period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6017f7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1523/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the geographic location of refugees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6017f8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1523/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the results of the monitoring and evaluation conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1522/a/7"},"text":"section 1522(a)(7) of this title","children":[],"tail":" during the period for which the report is submitted;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6017f9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1523/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of (A) the activities, expenditures, and policies of the Office under this subchapter and of the activities of States, voluntary agencies, and sponsors, and (B) the Director’s plans for improvement of refugee resettlement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6017fa-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1523/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluations of the extent to which (A) the services provided under this subchapter are assisting refugees in achieving economic self-sufficiency, achieving ability in English, and achieving employment commensurate with their skills and abilities, and (B) any fraud, abuse, or mismanagement has been reported in the provisions of services or assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6017fb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1523/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any assistance provided by the Director pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1522/e/5"},"text":"section 1522(e)(5) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6017fc-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1523/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the location and status of unaccompanied refugee children admitted to the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6017fd-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1523/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the information compiled and evaluation made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1522/a/8"},"text":"section 1522(a)(8) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c6017fe-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title IV, ch. 2, § 413, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/212/tIII/s311/a/2"},"text":"Pub. L. 96–212, title III, § 311(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-17"},"text":"Mar. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/115"},"text":"94 Stat. 115","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"hre