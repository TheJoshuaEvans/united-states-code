{"tag":"section","attrib":{"id":"id9c759bfc-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1810"},"text":null,"children":[{"tag":"num","attrib":{"value":"1810"},"text":"§ 1810.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fee relating to renewal or extension of employment authorization for asylum applicants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c759bfd-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1810/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other fee authorized by law, the Secretary of Homeland Security shall require the payment of a fee of not less than $275 by any alien who has applied for asylum for each renewal or extension of employment authorization based on such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c759bfe-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1810/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each initial employment authorization, or renewal or extension of such authorization, shall terminate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c759bff-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1810/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately following the denial of an asylum application by an asylum officer, unless the case is referred to an immigration judge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759c00-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1810/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the date that is 30 days after the date on which an immigration judge denies an asylum application, unless the alien makes a timely appeal to the Board of Immigration Appeals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759c01-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1810/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately following the denial by the Board of Immigration Appeals of an appeal of a denial of an asylum application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c759c02-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1810/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of fees relating to renewal and extension of employment authorization for asylum applicants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During each fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c759c03-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1810/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 25 percent of the fees collected pursuant to this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9c759c04-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1810/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be credited to U.S. Citizenship and Immigration Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c759c05-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1810/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be deposited into the Immigration Examinations Fee Account established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1356/m"},"text":"section 1356(m) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9c759c06-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1810/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be retained and expended by U.S. Citizenship and Immigration Services without further appropriation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c759c07-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1810/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts collected pursuant to this section that are not credited to U.S. Citizenship and Immigration Services pursuant to subparagraph (A) shall be deposited into the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c759c08-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1810/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No fee waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees required to be paid under this section shall not be waived or reduced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c759c09-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tX/s100011"},"text":"Pub. L. 119–21, title X, § 100011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/372"},"text":"139 Stat. 372","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
