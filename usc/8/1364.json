{"tag":"section","attrib":{"id":"id9c411e37-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1364"},"text":null,"children":[{"tag":"num","attrib":{"value":"1364"},"text":"§ 1364.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Triennial comprehensive report on immigration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c411e38-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1364/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Triennial report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall transmit to the Congress, not later than ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":", and not later than January 1 of every third year thereafter, a comprehensive immigration-impact report."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c411e39-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1364/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Details in each report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c411e3a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1364/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and classification of aliens admitted (whether as immediate relatives, special immigrants, refugees, or under the preferences classifications, or as nonimmigrants), paroled, or granted asylum, during the relevant period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c411e3b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1364/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reasonable estimate of the number of aliens who entered the United States during the period without visas or who became deportable during the period under section 237 of the Immigration and Nationality Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1227"},"text":"8 U.S.C. 1227","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c411e3c-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1364/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the impact of admissions and other entries of immigrants, refugees, asylees, and parolees into the United States during the period on the economy, labor and housing markets, the educational system, social services, foreign policy, environmental quality and resources, the rate, size, and distribution of population growth in the United States, and the impact on specific States and local units of government of high rates of immigration resettlement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c411e3d-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1364/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" History and projections","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information (referred to in subsection (b)) contained in each report shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c411e3e-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1364/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described for the preceding three-year period, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c411e3f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1364/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projected for the succeeding five-year period, based on reasonable estimates substantiated by the best available evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c411e40-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1364/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President also may include in such report any appropriate recommendations on changes in numerical limitations or other policies under title II of the Immigration and Nationality Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1151"},"text":"8 U.S.C. 1151","children":[],"tail":" et seq.] bearing on the admission and entry of such aliens to the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c411e41-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/603/tIV/s401"},"text":"Pub. L. 99–603, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-06"},"text":"Nov. 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3440"},"text":"100 Stat. 3440","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII/s308/g/1"},"text":"Pub. L. 104–208, div. C, title III, § 308(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-622"},"text":"110 Stat. 3009–622","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c411e42-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c411e43-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c411e44-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Immigration and Nationality Act, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":". Title II of the Act is classified principally to subchapter II (§ 1151 et seq.) of this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c411e45-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Immigration Reform and Control Act of 1986, and not as part of the Immigration and Nationality Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c411e46-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" substituted “section 237” for “section 241”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c411e47-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c411e48-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" effective, with certain transitional provisions, on the first day of the first month beginning more than 180 days after "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s309"},"text":"section 309 of Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id9c411e49-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"id9c411e4a-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 12789. Delegation of Reporting Functions Under the Immigration Reform and Control Act of 1986","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12789, ","children":[{"tag":"date","attrib":{"date":"1992-02-10"},"text":"Feb. 10, 1992","children":[],"tail":", 57 F.R. 5225, as amended by Ex. Ord. No. 13286, § 32, "},{"tag":"date","attrib":{"date":"2003-02-28"},"text":"Feb. 28, 2003","children":[],"tail":", 68 F.R. 10625, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and laws of the United States of America, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, and title IV of the Immigration Reform and Control Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/603"},"text":"Public Law 99–603","children":[],"tail":" (“Reform Act”) [title IV of "},{"tag":"ref","attrib":{"href":"/us/pl/99/603"},"text":"Pub. L. 99–603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-06"},"text":"Nov. 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3440"},"text":"100 Stat. 3440","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1364"},"text":"section 1364 of this title","children":[],"tail":" and provisions set out as notes under sections 1101, 1187, 1188, 1255a, and 1324a of this title], it is hereby ordered as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. The Secretary of Homeland Security shall: (a) perform, in coordination with the Secretary of Labor, the functions vested in the President by section 401 of the Reform Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1364"},"text":"8 U.S.C. 1364","children":[],"tail":");"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) perform, except for the functions in section 402(3)(A), the functions vested in the President by section 402 of the Reform Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1324a"},"text":"8 U.S.C. 1324a","children":[],"tail":" note); and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) perform, insofar as they relate to the initial report described in section 404(b), the functions vested in the President by section 404 of the Reform Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1255a"},"text":"8 U.S.C. 1255a","children":[],"tail":" note)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 2. The Secretary of Labor shall: (a) perform the functions vested in the President by section 402(3)(A) of the Reform Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1324a"},"text":"8 U.S.C. 1324a","children":[],"tail":" note);"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) perform the functions vested in the President by section 403 of the Reform Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1188"},"text":"8 U.S.C. 1188","children":[],"tail":" note); and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) perform, insofar as they relate to the second report described in section 404(c), the functions vested in the President by section 404 of the Reform Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1255a"},"text":"8 U.S.C. 1255a","children":[],"tail":" note)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 3. The functions delegated by sections 1 and 2 of this order shall be performed in accordance with the procedures set forth in OMB Circular A–19."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 4. This order shall be effective immediately."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"George Bush.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
