{"tag":"section","attrib":{"id":"id9c6bfe87-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1623"},"text":null,"children":[{"tag":"num","attrib":{"value":"1623"},"text":"§ 1623.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on eligibility for preferential treatment of aliens not lawfully present on basis of residence for higher education benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c6bfe88-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1623/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, an alien who is not lawfully present in the United States shall not be eligible on the basis of residence within a State (or a political subdivision) for any postsecondary education benefit unless a citizen or national of the United States is eligible for such a benefit (in no less an amount, duration, and scope) without regard to whether the citizen or national is such a resident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c6bfe89-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1623/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to benefits provided on or after ","children":[{"tag":"date","attrib":{"date":"1998-07-01"},"text":"July 1, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c6bfe8a-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tV/s505"},"text":"Pub. L. 104–208, div. C, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-672"},"text":"110 Stat. 3009–672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c6bfe8b-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c6bfe8c-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c6bfe8d-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Illegal Immigration Reform and Immigrant Responsibility Act of 1996, and as part of the Omnibus Consolidated Appropriations Act, 1997, and not as part of title IV of the Personal Responsibility and Work Opportunity Reconciliation Act of 1996 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
