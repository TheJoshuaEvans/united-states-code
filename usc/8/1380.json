{"tag":"section","attrib":{"id":"id9c4a9414-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1380"},"text":null,"children":[{"tag":"num","attrib":{"value":"1380"},"text":"§ 1380.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of statistics by the Department of Homeland Security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c4a9415-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1380/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department of Homeland Security shall maintain statistics regarding petitions filed, approved, extended, and amended with respect to nonimmigrants described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/15/L"},"text":"section 1101(a)(15)(L) of this title","children":[],"tail":", including the number of such nonimmigrants who are classified on the basis of specialized knowledge and the number of nonimmigrants who are classified on the basis of specialized knowledge in order to work primarily at offsite locations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c4a9416-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1380/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall apply to petitions filed on or after the effective date of this subtitle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c4a9417-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dJ/tIV/s414"},"text":"Pub. L. 108–447, div. J, title IV, § 414","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3352"},"text":"118 Stat. 3352","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c4a9418-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c4a9419-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c4a941a-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subtitle, referred to in subsec. (b), means subtitle A (§§ 411–417) of title IV of div. J of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":". For the effective date of subtitle A, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/s417"},"text":"section 417 of Pub. L. 108–447","children":[],"tail":", set out as an Effective Date of 2004 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1184"},"text":"section 1184 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9c4a941b-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the L–1 Visa (Intracompany Transferee) Reform Act of 2004, and also as part of the L–1 Visa and H–1B Visa Reform Act and the Consolidated Appropriations Act, 2005, and not as part of the Immigration and Nationality Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c4a941c-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id9c4a941d-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/s417"},"text":"section 417 of Pub. L. 108–447","children":[],"tail":", set out as an Effective Date of 2004 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1184"},"text":"section 1184 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
