{"tag":"section","attrib":{"id":"id9c411e0f-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1362"},"text":null,"children":[{"tag":"num","attrib":{"value":"1362"},"text":"§ 1362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to counsel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In any removal proceedings before an immigration judge and in any appeal proceedings before the Attorney General from any such removal proceedings, the person concerned shall have the privilege of being represented (at no expense to the Government) by such counsel, authorized to practice in such proceedings, as he shall choose.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9c411e10-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title II, ch. 9, § 292, "},{"tag":"ref","attrib":{"href":"/us/stat/66/235"},"text":"66 Stat. 235","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII"},"text":"Pub. L. 104–208, div. C, title III","children":[],"tail":", §§ 308(d)(4)(O), 371(b)(9), "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-619"},"text":"110 Stat. 3009–619","children":[],"tail":", 3009–645.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c411e11-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c411e12-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c411e13-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"childr