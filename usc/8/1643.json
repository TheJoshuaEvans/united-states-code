{"tag":"section","attrib":{"id":"id9c6bff03-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1643"},"text":null,"children":[{"tag":"num","attrib":{"value":"1643"},"text":"§ 1643.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statutory construction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c6bff04-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1643/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c6bff05-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1643/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this chapter may be construed as an entitlement or a determination of an individual’s eligibility or fulfillment of the requisite requirements for any Federal, State, or local governmental program, assistance, or benefits. For purposes of this chapter, eligibility relates only to the general issue of eligibility or ineligibility on the basis of alienage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bff06-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1643/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this chapter may be construed as addressing alien eligibility for a basic public education as determined by the Supreme Court of the United States under Plyler v. Doe (457 U.S. 202)(1982).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c6bff07-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1643/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefit eligibility limitations applicable only with respect to aliens present in United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this chapter, the limitations on eligibility for benefits under this chapter shall not apply to eligibility for benefits of aliens who are not residing, or present, in the United States with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c6bff08-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1643/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wages, pensions, annuities, and other earned payments to which an alien is entitled resulting from employment by, or on behalf of, a Federal, State, or local government agency which was not prohibited during the period of such employment or service under section 274A [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1324a"},"text":"8 U.S.C. 1324a","children":[],"tail":"] or other applicable provision of the Immigration and Nationality Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":" et seq.]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bff09-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1643/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefits under laws administered by the Secretary of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c6bff0a-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1643/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Not applicable to foreign assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter does not apply to any Federal, State, or local governmental program, assistance, or benefits provided to an alien under any program of foreign assistance as determined by the Secretary of State in consultation with the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c6bff0b-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1643/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Severability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter or the application of such provision to any person or circumstance is held to be unconstitutional, the remainder of this chapter and the application of the provisions of such to any person or circumstance shall not be affected thereby.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c6bff0c-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIV/s433"},"text":"Pub. L. 104–193, title IV, § 433","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2275"},"text":"110 Stat. 2275","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV/s5574"},"text":"Pub. L. 105–33, title V, § 5574","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/642"},"text":"111 Stat. 642","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c6bff0d-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c6bff0e-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c6bff0f-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title” meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2260"},"text":"110 Stat. 2260","children":[],"tail":", which enacted this chapter, "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1183a"},"text":"section 1183a of this title","children":[],"tail":", and sections 611a and 1437y of Title 42, The Public Health and Welfare, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1383"},"text":"section 1383 of this title","children":[],"tail":", sections 32 and 6213 of Title 26, Internal Revenue Code, and sections 1436a and 1471 of Title 42, and enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1183a"},"text":"section 1183a of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s32"},"text":"section 32 of Title 26","children":[],"tail":". For complete classification of title IV to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Immigration and Nationality Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":", which is classified principally to chapter 12 (§ 1101 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c6bff10-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" added subsec. (b) and redesignated former subsecs. (b) and (c) as (c) and (d), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c6bff11-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c6bff12-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" effective as if included in the enactment of title IV of the Personal Responsibility and Work Opportunity Reconciliation Act of 1996, "},{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5582"},"text":"section 5582 of Pub. L. 105–33","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1367"},"text":"section 1367 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
