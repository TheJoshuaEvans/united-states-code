{"tag":"section","attrib":{"id":"id9c6bfef4-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1642"},"text":null,"children":[{"tag":"num","attrib":{"value":"1642"},"text":"§ 1642.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification of eligibility for Federal public benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c6bfef5-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1642/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9c6bfef6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1642/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1996-08-22"},"text":"August 22, 1996","children":[],"tail":", the Attorney General of the United States, after consultation with the Secretary of Health and Human Services, shall promulgate regulations requiring verification that a person applying for a Federal public benefit (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1611/c"},"text":"section 1611(c) of this title","children":[],"tail":"), to which the limitation under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1611"},"text":"section 1611 of this title","children":[],"tail":" applies, is a qualified alien and is eligible to receive such benefit. Such regulations shall, to the extent feasible, require that information requested and exchanged be similar in form and manner to information requested and exchanged under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–7"},"text":"section 1320b–7 of title 42","children":[],"tail":". Not later than 90 days after "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"August 5, 1997","children":[],"tail":", the Attorney General of the United States, after consultation with the Secretary of Health and Human Services, shall issue interim verification guidance."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bfef7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1642/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1996-08-22"},"text":"August 22, 1996","children":[],"tail":", the Attorney General, in consultation with the Secretary of Health and Human Services, shall also establish procedures for a person applying for a Federal public benefit (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1611/c"},"text":"section 1611(c) of this title","children":[],"tail":") to provide proof of citizenship in a fair and nondiscriminatory manner."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9c6bfef8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1642/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"August 5, 1997","children":[],"tail":", the Attorney General shall promulgate regulations which set forth the procedures by which a State or local government can verify whether an alien applying for a State or local public benefit is a qualified alien, a nonimmigrant under the Immigration and Nationality Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":" et seq.], or an alien paroled into the United States under section 212(d)(5) of the Immigration and Nationality Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182/d/5"},"text":"8 U.S.C. 1182(d)(5)","children":[],"tail":"] for less than 1 year, for purposes of determining whether the alien is ineligible for benefits under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1621"},"text":"section 1621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c6bfef9-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1642/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 24 months after the date the regulations described in subsection (a) are adopted, a State that administers a program that provides a Federal public benefit shall have in effect a verification system that complies with the regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c6bfefa-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1642/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out the purpose of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c6bfefb-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1642/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No verification requirement for nonprofit charitable organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (a), a nonprofit charitable organization, in providing any Federal public benefit (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1611/c"},"text":"section 1611(c) of this title","children":[],"tail":") or any State or local public benefit (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1621/c"},"text":"section 1621(c) of this title","children":[],"tail":"), is not required under this chapter to determine, verify, or otherwise require proof of eligibility of any applicant for such benefits."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c6bfefc-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIV/s432"},"text":"Pub. L. 104–193, title IV, § 432","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2274"},"text":"110 Stat. 2274","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tV"},"text":"Pub. L. 104–208, div. C, title V","children":[],"tail":", §§ 504, 508, "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-672"},"text":"110 Stat. 3009–672","children":[],"tail":", 3009–673; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV/s5572/a"},"text":"Pub. L. 105–33, title V, § 5572(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/641"},"text":"111 Stat. 641","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c6bfefd-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c6bfefe-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c6bfeff-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Immigration and Nationality Act, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":", which is classified principally to chapter 12 (§ 1101 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d), was in the original “this title” meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2260"},"text":"110 Stat. 2260","children":[],"tail":", which enacted this chapter, "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1183a"},"text":"section 1183a of this title","children":[],"tail":", and sections 611a and 1437y of Title 42, The Public Health and Welfare, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1383"},"text":"section 1383 of this title","children":[],"tail":", sections 32 and 6213 of Title 26, Internal Revenue Code, and sections 1436a and 1471 of Title 42, and enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1183a"},"text":"section 1183a of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s32"},"text":"section 32 of Title 26","children":[],"tail":". For complete classification of title IV to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9c6bff00-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5572/a/1"},"text":"Pub. L. 105–33, § 5572(a)(1)","children":[],"tail":", inserted at end “Not later than 90 days after "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"August 5, 1997","children":[],"tail":", the Attorney General of the United States, after consultation with the Secretary of Health and Human Services, shall issue interim verification guidance.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5572/a/2"},"text":"Pub. L. 105–33, § 5572(a)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s504"},"text":"Pub. L. 104–208, § 504","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s508"},"text":"Pub. L. 104–208, § 508","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c6bff01-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9c6bff02-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" effective as if included in the enactment of title IV of the Personal Responsibility and Work Opportunity Reconciliation Act of 1996, "},{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5582"},"text":"section 5582 of Pub. L. 105–33","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1367"},"text":"section 1367 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
