"text":"Pub. L. 89–236","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/236/s20"},"text":"section 20 of Pub. L. 89–236","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1151"},"text":"section 1151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
