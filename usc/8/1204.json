{"tag":"section","attrib":{"id":"id9c0f1216-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1204"},"text":null,"children":[{"tag":"num","attrib":{"value":"1204"},"text":"§ 1204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immediate relative and special immigrant visas","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A consular officer may, subject to the limitations provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1201"},"text":"section 1201 of this title","children":[],"tail":", issue an immigrant visa to a special immigrant or immediate relative as such upon satisfactory proof, under regulations prescribed under this chapter, that the applicant is entitled to special immigrant or immediate relative status."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9c0f1217-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title II, ch. 3, § 224, "},{"tag":"ref","attrib":{"href":"/us/stat/66/195"},"text":"66 Stat. 195","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/236/s11/d"},"text":"Pub. L. 89–236, § 11(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-03"},"text":"Oct. 3, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/918"},"text":"79 Stat. 918","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c0f1218-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9c0f1219-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9c0f121a-3