{"tag":"section","attrib":{"id":"id9c39f2f6-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1352"},"text":null,"children":[{"tag":"num","attrib":{"value":"1352"},"text":"§ 1352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing of reentry permits and blank forms of manifest and crew lists; sale to public","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9c39f2f7-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1352/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reentry permits issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1203"},"text":"section 1203 of this title","children":[],"tail":" shall be printed on distinctive safety paper and shall be prepared and issued under regulations prescribed by the Attorney General."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c39f2f8-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1352/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Government Publishing Office is authorized to print for sale to the public by the Superintendent of Documents, upon prepayment, copies of blank forms of manifests and crew lists and such other forms as may be prescribed and authorized by the Attorney General to be sold pursuant to the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c39f2f9-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title II, ch. 9, § 282, "},{"tag":"ref","attrib":{"href":"/us/stat/66/231"},"text":"66 Stat. 231","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/d"},"text":"Pub. L. 113–235, div. H, title I, § 1301(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9c39f2fa-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9c39f2fb-3a6f-11f1-ace3-bb5201d4c7c7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id9c39f2fc-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Director of the Government Publishing Office” substituted for “Public Printer” in subsec. (b) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/d"},"text":"section 1301(d) of Pub. L. 113–235","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9c39f2fd-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
