{"tag":"section","attrib":{"id":"id9c4d0554-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1403"},"text":null,"children":[{"tag":"num","attrib":{"value":"1403"},"text":"§ 1403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons born in the Canal Zone or Republic of Panama on or after ","children":[{"tag":"date","attrib":{"date":"1904-02-26"},"text":"February 26, 1904","children":[],"tail":null}],"tail":null},{"tag":"subsection","attrib":{"id":"id9c4d0555-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person born in the Canal Zone on or after ","children":[{"tag":"date","attrib":{"date":"1904-02-26"},"text":"February 26, 1904","children":[],"tail":", and whether before or after the effective date of this chapter, whose father or mother or both at the time of the birth of such person was or is a citizen of the United States, is declared to be a citizen of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9c4d0556-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person born in the Republic of Panama on or after ","children":[{"tag":"date","attrib":{"date":"1904-02-26"},"text":"February 26, 1904","children":[],"tail":", and whether before or after the effective date of this chapter, whose father or mother or both at the time of the birth of such person was or is a citizen of the United States employed by the Government of the United States or by the Panama Railroad Company, or its successor in title, is declared to be a citizen of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9c4d0557-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","