{"tag":"section","attrib":{"id":"id9c4d0552-3a6f-11f1-ace3-bb5201d4c7c7","identifier":"/us/usc/t8/s1402"},"text":null,"children":[{"tag":"num","attrib":{"value":"1402"},"text":"§ 1402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons born in Puerto Rico on or after ","children":[{"tag":"date","attrib":{"date":"1899-04-11"},"text":"April 11, 1899","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All persons born in Puerto Rico on or after ","children":[{"tag":"date","attrib":{"date":"1899-04-11"},"text":"April 11, 1899","children":[],"tail":", and prior to "},{"tag":"date","attrib":{"date":"1941-01-13"},"text":"January 13, 1941","children":[],"tail":", subject to the jurisdiction of the United States, residing on "},{"tag":"date","attrib":{"date":"1941-01-13"},"text":"January 13, 1941","children":[],"tail":", in Puerto Rico or other territory over which the United States exercises rights of sovereignty and not citizens of the United States under any other Act, are declared to be citizens of the United States as of "},{"tag":"date","attrib":{"date":"1941-01-13"},"text":"January 13, 1941","children":[],"tail":". All persons born in Puerto Rico on or after "},{"tag":"date","attrib":{"date":"1941-01-13"},"text":"January 13, 1941","children":[],"tail":", and subject to the jurisdiction of the United States, are citizens of the United States at birth."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9c4d0553-3a6f-11f1-ace3-bb5201d4c7c7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title III, ch. 1, § 302, "},{"tag":"ref","attrib":{"href":"/us/stat/66/236"},"text":"66 Stat. 236","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
