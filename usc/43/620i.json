{"tag":"section","attrib":{"id":"idca021c6d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s620i"},"text":null,"children":[{"tag":"num","attrib":{"value":"620i"},"text":"§ 620i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures; units excepted from soil survey and land classification requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Expenditures for the Flaming Gorge, Glen Canyon, Wayne N. Aspinall, and Navajo initial units of the Colorado River storage project may be made without regard to the soil survey and land classification requirements of section 390a ","children":[{"tag":"ref","attrib":{"idref":"fn002047"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002047"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca021c6e-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-04-11/ch203/s10"},"text":"Apr. 11, 1956, ch. 203, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/110"},"text":"70 Stat. 110","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/375/s7"},"text":"Pub. L. 96–375, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1507"},"text":"94 Stat. 1507","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca021c6f-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca021c70-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca021c71-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390a"},"text":"Section 390a of this title","children":[],"tail":", referred to in text, was in the original a reference to the Interior Department Appropriation Act, 1954. The soil survey and land classification requirements of that Act ("},{"tag":"ref","attrib":{"href":"/us/act/1953-07-31/ch298"},"text":"act July 31, 1953, ch. 298","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/261"},"text":"67 Stat. 261","children":[],"tail":", 266) were classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s390a"},"text":"section 390a of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/362/tIX/s901/e/2"},"text":"Pub. L. 105–362, title IX, § 901(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-10"},"text":"Nov. 10, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3289"},"text":"112 Stat. 3289","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca021c72-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/375"},"text":"Pub. L. 96–375","children":[],"tail":" substituted “Wayne N. Aspinall” for “Curecanti”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
