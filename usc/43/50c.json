{"tag":"section","attrib":{"id":"idc9aea5ac-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s50c"},"text":null,"children":[{"tag":"num","attrib":{"value":"50c"},"text":"§ 50c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of costs incidental to utilization of services of volunteers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Appropriations herein and on and after ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":", made shall be available for paying costs incidental to the utilization of services contributed by individuals who serve without compensation as volunteers in aid of work of the United States Geological Survey, and that within appropriations herein and on and after "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":", provided, United States Geological Survey officials may authorize either direct procurement of or reimbursement for expenses incidental to the effective use of volunteers such as, but not limited to, training, transportation, lodging, subsistence, equipment, and supplies: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That provision for such expenses or services is in accord with volunteer or cooperative agreements made with such individuals, private organizations, educational institutions, or State or local government."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9aea5ad-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/g/tI"},"text":"Pub. L. 100–202, § 101(g) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-213"},"text":"101 Stat. 1329–213","children":[],"tail":", 1329–224; "},{"tag":"ref","attrib":{"href":"/us/pl/102/154/tI"},"text":"Pub. L. 102–154, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-13"},"text":"Nov. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1000"},"text":"105 Stat. 1000","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9aea5ae-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9aea5af-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9aea5b0-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Appropriations herein, referred to in text, probably means appropriations under the headings “","children":[{"tag":"inline","attrib":{},"text":"Geological Survey”, “surveys, investigations, and research","children":[],"tail":"” and “"},{"tag":"inline","attrib":{},"text":"administrative provisions","children":[],"tail":"”, of the annual Department of the Interior and Related Agencies Appropriations Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9aea5b1-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idc9aea5b2-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States Geological Survey” substituted in text for “Geological Survey” pursuant to provision of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/154"},"text":"Pub. L. 102–154","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s31"},"text":"section 31 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
