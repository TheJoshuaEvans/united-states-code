{"tag":"section","attrib":{"id":"idc9d28179-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–21"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–21"},"text":"§ 390h–21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inland Empire regional water recycling project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d2817a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–21/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the Inland Empire Utilities Agency, may participate in the design, planning, and construction of the Inland Empire regional water recycling project described in the report submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390h–4/c"},"text":"section 390h–4(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d2817b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–21/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of the project described in subsection (a) shall not exceed 25 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d2817c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–21/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided by the Secretary shall not be used for operation and maintenance of the project described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d2817d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–21/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section, $20,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d2817e-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s16"},"text":"Pub. L. 102–575, title XVI, § 16","children":[],"tail":"——, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dC/tII/s210"},"text":"Pub. L. 110–161, div. C, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1954"},"text":"121 Stat. 1954","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d2817f-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d28180-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9d28181-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section “16——” of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575"},"text":"Pub. L. 102–575","children":[],"tail":". Two other sections “16——” of "},{"tag":"ref","attrib":{"href":"/us/pl/102/575"},"text":"Pub. L. 102–575","children":[],"tail":" have been enacted and are classified to sections 390h–22 and 390h–23 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
