{"tag":"section","attrib":{"id":"idca17a027-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s956"},"text":null,"children":[{"tag":"num","attrib":{"value":"956"},"text":"§ 956.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of way for tramroads, canals, or reservoirs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized and empowered, under general regulations to be fixed by him, to permit the use of the right of way through the public lands of the United States, not within the limits of any national forest, park, military or Indian reservation, for tramroads, canals, or reservoirs to the extent of the ground occupied by the water of the canals and reservoirs and fifty feet on each side of the marginal limits thereof, or fifty feet on each side of the center line of the tramroad, by any citizen or any association of citizens of the United States engaged in the business of mining or quarrying or of cutting timber and manufacturing lumber or for the purposes of furnishing water for domestic, public, and other beneficial uses.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca17a028-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-21/ch37/s1"},"text":"Jan. 21, 1895, ch. 37, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/635"},"text":"28 Stat. 635","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1898-05-11/ch292/s1"},"text":"May 11, 1898, ch. 292, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/404"},"text":"30 Stat. 404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"Mar. 4, 1907, ch. 2907","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1269"},"text":"34 Stat. 1269","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca17a029-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca17a02a-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca17a02b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal; Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579/tVII/s706/a"},"text":"Pub. L. 94–579, title VII, § 706(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2793"},"text":"90 Stat. 2793","children":[],"tail":", effective on and after "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", insofar as applicable to the issuance of rights-of-way over, upon, under, and through the public lands and lands in the National Forest System. Such repeal not to be construed as terminating any valid lease, permit, patent, etc., existing on "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/579/s701"},"text":"section 701 of Pub. L. 94–579","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
