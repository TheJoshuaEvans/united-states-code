{"tag":"section","attrib":{"id":"idca5a4e89-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1628"},"text":null,"children":[{"tag":"num","attrib":{"value":"1628"},"text":"§ 1628.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignments by Regional Corporations of rights to receive payments from Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca5a4e8a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1628/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition by Secretary; scope of recognition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3727"},"text":"section 3727 of title 31","children":[],"tail":", the Secretary is authorized to recognize validly executed assignments made by Regional Corporations of their rights to receive payments from the Alaska Native Fund. Such assignments shall only be recognized to the extent that the Regional Corporation involved is not required to distribute funds pursuant to subsection (j) or (m) of "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1606"},"text":"section 1606 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca5a4e8b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1628/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonrecognition by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not recognize any assignment under this section which does not provide that the United States reserves the right to assert against the assignee and successors of the assignee, any setoff or counterclaim which the United States has against the assignor Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca5a4e8c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1628/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims against Secretary by stockholders of Regional or Village Corporation for recognition of assignment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No stockholder of any Regional or Village Corporation shall have any claim against the Secretary or the United States as the result of any assignment duly recognized by the Secretary pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca5a4e8d-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203/s31"},"text":"Pub. L. 92–203, § 31","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/178/s4"},"text":"Pub. L. 95–178, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-15"},"text":"Nov. 15, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1370"},"text":"91 Stat. 1370","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca5a4e8e-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca5a4e8f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca5a4e90-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3727"},"text":"section 3727 of title 31","children":[],"tail":"” substituted for “section 3477 of the Revised Statutes, as amended ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s203"},"text":"31 U.S.C. 203","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
