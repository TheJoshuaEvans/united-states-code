{"tag":"section","attrib":{"id":"idc9c42964-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s364f"},"text":null,"children":[{"tag":"num","attrib":{"value":"364f"},"text":"§ 364f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to naming of offices or establishments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed as applying to the naming of the offices or establishments of any Federal agency.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9c42965-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-25/ch330/s7"},"text":"July 25, 1947, ch. 330, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/457"},"text":"61 Stat. 457","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
