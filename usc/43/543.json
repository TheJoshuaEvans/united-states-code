{"tag":"section","attrib":{"id":"idc9ef0968-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s543"},"text":null,"children":[{"tag":"num","attrib":{"value":"543"},"text":"§ 543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificate of final payment and release of lien","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon full and final payment being made of all amounts due on account of the building and betterment charges to the United States or its successors in control of the project, the United States or its successors, as the case may be, shall issue upon request a certificate certifying that payment of the building and betterment charges in full has been made and that the lien upon the land has been so far satisfied and is no longer of any force or effect except the lien for annual charges for operation and maintenance.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9ef0969-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1912-08-09/ch278/s3"},"text":"Aug. 9, 1912, ch. 278, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/266"},"text":"37 Stat. 266","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9ef096a-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9ef096b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9ef096c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section comprises part of section 3 of act ","children":[{"tag":"date","attrib":{"date":"1912-08-09"},"text":"Aug. 9, 1912","children":[],"tail":". Remainder of section 3 is set out as "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s544"},"text":"section 544 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
