{"tag":"section","attrib":{"id":"idca8c827b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2246"},"text":null,"children":[{"tag":"num","attrib":{"value":"2246"},"text":"§ 2246.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be included as part of the President’s annual budget submittal to the Congress a detailed report on past and proposed expenditures and accomplishments under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca8c827c-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/250/tIII/s306"},"text":"Pub. L. 102–250, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-05"},"text":"Mar. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/59"},"text":"106 Stat. 59","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
