{"tag":"section","attrib":{"id":"idc9a9ea86-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31d"},"text":null,"children":[{"tag":"num","attrib":{"value":"31d"},"text":"§ 31d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9a9ea87-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9a9ea88-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be established a 11-member geologic mapping advisory committee to advise the Director on planning and implementation of the geologic mapping program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a9ea89-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members ex officio","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal agency members shall include the Administrator of the Environmental Protection Agency or a designee, the Secretary of the Interior or a designee from a land management agency of the Department of the Interior, the Secretary of Energy or a designee, and the Secretary of Agriculture or a designee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a9ea8a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointed members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In consultation with the Association, the Secretary shall appoint to the advisory committee two representatives from the Survey (including the Associate Director for Core Science Systems, as Chair), two representatives from the State geological surveys, one representative from academia, and 2 representatives from the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9a9ea8b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9a9ea8c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and update the 5-year plan prepared by the Director pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s31e"},"text":"section 31e of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a9ea8d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the scientific progress of the geologic mapping program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a9ea8e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a scientific overview of geologic maps (including maps of geologic-based hazards) used or disseminated by Federal agencies for regulation or land-use planning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a9ea8f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit an annual report to the Secretary that evaluates the progress of the Federal, State, and university mapping activities and evaluates the progress made toward fulfilling the purposes of sections 31c through 31f of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9a9ea90-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/285/s5"},"text":"Pub. L. 102–285, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-18"},"text":"May 18, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/169"},"text":"106 Stat. 169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/c"},"text":"Pub. L. 105–36, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1110"},"text":"111 Stat. 1110","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/148/s5"},"text":"Pub. L. 106–148, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1722"},"text":"113 Stat. 1722","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXI/s11001/f"},"text":"Pub. L. 111–11, title XI, § 11001(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1415"},"text":"123 Stat. 1415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tV/s5002/b"},"text":"Pub. L. 116–9, title V, § 5002(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/768"},"text":"133 Stat. 768","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9a9ea91-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9a9ea92-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9a9ea93-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9"},"text":"Pub. L. 116–9","children":[],"tail":" substituted “Associate Director for Core Science Systems” for “Associate Director for Geology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s11001/f/3"},"text":"Pub. L. 111–11, § 11001(f)(3)","children":[],"tail":", substituted “11-member” for “10-member”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s11001/f/1/A"},"text":"Pub. L. 111–11, § 11001(f)(1)(A)","children":[],"tail":", inserted “the Secretary of the Interior or a designee from a land management agency of the Department of the Interior,” after “Administrator of the Environmental Protection Agency or a designee,”, inserted “and” after “Energy or a designee,”, and struck out “, and the Assistant to the President for Science and Technology or a designee” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s11001/f/1/B"},"text":"Pub. L. 111–11, § 11001(f)(1)(B)","children":[],"tail":", substituted “In consultation” for “Not later than 1 year after "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"December 9, 1999","children":[],"tail":", in consultation”, “Associate Director for Geology, as Chair” for “Chief Geologist, as Chairman”, and “2 representatives from the private sector” for “one representative from the private sector”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s11001/f/2"},"text":"Pub. L. 111–11, § 11001(f)(2)","children":[],"tail":", added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/148/s5/1"},"text":"Pub. L. 106–148, § 5(1)","children":[],"tail":", substituted “1 year after "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"December 9, 1999","children":[],"tail":",” for “90 days after "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"August 5, 1997","children":[],"tail":",”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/148/s5/2/A"},"text":"Pub. L. 106–148, § 5(2)(A)","children":[],"tail":", substituted “update the 5-year plan” for “critique the draft implementation plan”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/148/s5/2/B"},"text":"Pub. L. 106–148, § 5(2)(B)","children":[],"tail":", substituted “sections 31c through 31f of this title” for “sections 31a to 31h of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/c/1"},"text":"Pub. L. 105–36, § 3(c)(1)","children":[],"tail":", added subsec. (a) and struck out heading and text of former subsec. (a). Text read as follows: “There shall be established a sixteen member geologic mapping advisory committee to advise the Director on planning and implementation of the geologic mapping program. The President shall appoint one representative each from the Environmental Protection Agency, the Department of Energy, the Department of Agriculture, and the Office of Science and Technology Policy. Within 90 days and with the advice and consultation of the State Geological Surveys, the Secretary shall appoint to the advisory committee 2 representatives from the Survey (including the Chief Geologist, as Chairman), 4 representatives from the State geological surveys, 3 representatives from academia, and 3 representatives from the private sector.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/c/2"},"text":"Pub. L. 105–36, § 3(c)(2)","children":[],"tail":", substituted “Federal, State, and university mapping activities” for “Federal and State mapping activities”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9a9ea94-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9a9ea95-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory committees established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a committee established by the President or an officer of the Federal Government, such committee is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a committee established by Congress, its duration is otherwise provided by law, see "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
