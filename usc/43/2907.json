{"tag":"section","attrib":{"id":"idca986873-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2907"},"text":null,"children":[{"tag":"num","attrib":{"value":"2907"},"text":"§ 2907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca986874-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before conveying an eligible facility under this chapter, the Secretary shall comply with all applicable Federal environmental laws, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca986875-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2907/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca986876-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2907/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca986877-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2907/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subtitle III of title 54.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca986878-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that any Federal permitting and review processes required with respect to a conveyance of an eligible facility under this chapter should be completed with the maximum efficiency and effectiveness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca986879-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tVIII/s8007"},"text":"Pub. L. 116–9, title VIII, § 8007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/808"},"text":"133 Stat. 808","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca98687a-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca98687b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca98687c-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Endangered Species Act of 1973, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/205"},"text":"Pub. L. 93–205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/884"},"text":"87 Stat. 884","children":[],"tail":", which is classified principally to chapter 35 (§ 1531 et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"section 1531 of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
