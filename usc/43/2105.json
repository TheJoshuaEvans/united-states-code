{"tag":"section","attrib":{"id":"idca8a10ea-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2105"},"text":null,"children":[{"tag":"num","attrib":{"value":"2105"},"text":"§ 2105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of ownership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8a10eb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States title","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States asserts title to any abandoned shipwreck that is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8a10ec-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" embedded in submerged lands of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8a10ed-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" embedded in coralline formations protected by a State on submerged lands of a State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8a10ee-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2105/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on submerged lands of a State and is included in or determined eligible for inclusion in the National Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a10ef-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of shipwreck location; eligibility determination for inclusion in National Register of Historic Places","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The public shall be given adequate notice of the location of any shipwreck to which title is asserted under this section. The Secretary of the Interior, after consultation with the appropriate State Historic Preservation Officer, shall make a written determination that an abandoned shipwreck meets the criteria for eligibility for inclusion in the National Register of Historic Places under clause (a)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a10f0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of title to States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The title of the United States to any abandoned shipwreck asserted under subsection (a) of this section is transferred to the State in or on whose submerged lands the shipwreck is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a10f1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any abandoned shipwreck in or on the public lands of the United States is the property of the United States Government. Any abandoned shipwreck in or on any Indian lands is the property of the Indian tribe owning such lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a10f2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2105/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not affect any right reserved by the United States or by any State (including any right reserved with respect to Indian lands) under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8a10f3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2105/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1311, 1313, or 1314 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8a10f4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2105/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 414 or 415 of title 33.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8a10f5-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/298/s6"},"text":"Pub. L. 100–298, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/433"},"text":"102 Stat. 433","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
