{"tag":"section","attrib":{"id":"idc9e0b1b6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s446"},"text":null,"children":[{"tag":"num","attrib":{"value":"446"},"text":"§ 446.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to make entry on relinquishment of former entry under land laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Wherever the Secretary of the Interior, in carrying out the provisions of the reclamation Act, shall acquire by relinquishment lands covered by a bona fide unperfected entry under the land laws of the United States, the entryman upon such tract may make another and additional entry, as though the entry thus relinquished had not been made.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9e0b1b7-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1906-06-27/ch3559/s2"},"text":"June 27, 1906, ch. 3559, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/519"},"text":"34 Stat. 519","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9e0b1b8-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9e0b1b9-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9e0b1ba-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The reclamation Act, referred to in text, is identified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s434"},"text":"section 434 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
