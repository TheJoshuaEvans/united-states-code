{"tag":"section","attrib":{"id":"idc9d28170-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–20"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–20"},"text":"§ 390h–20.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hawaii reclamation projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d28171-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–20/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9d28172-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–20/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with the Board of Water Supply, City and County of Honolulu, Hawaii, participate in the design, planning, and construction of a project in Kalaeloa, Hawaii, to desalinate and distribute seawater for direct potable use within the service area of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9d28173-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–20/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with the County of Hawaii Department of Environmental Management, Hawaii, participate in the design, planning, and construction of facilities in Kealakehe, Hawaii, for the treatment and distribution of recycled water and for environmental purposes within the County; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9d28174-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–20/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with the County of Maui Wastewater Reclamation Division, Hawaii, participate in the design, planning, and construction of, and acquire land for, facilities in Lahaina, Hawaii, for the distribution of recycled water from the Lahaina Wastewater Reclamation Facility for non-potable uses within the County.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d28175-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–20/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of a project described in subsection (a) shall not exceed 25 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d28176-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–20/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided by the Secretary shall not be used for the operation and maintenance of a project described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d28177-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–20/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d28178-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s1638"},"text":"Pub. L. 102–575, title XVI, § 1638","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/70/s2/a/2"},"text":"Pub. L. 109–70, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-09-21"},"text":"Sept. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2009"},"text":"119 Stat. 2009","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
