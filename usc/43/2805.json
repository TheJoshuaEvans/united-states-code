{"tag":"section","attrib":{"id":"idca95f89d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805"},"text":null,"children":[{"tag":"num","attrib":{"value":"2805"},"text":"§ 2805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Geospatial Data Asset data themes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca95f89e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall designate as National Geospatial Data Asset data themes the primary topics and subjects for which the coordinated development, maintenance, and dissemination of geospatial data will benefit the Federal Government and the interests of the people of the United States, which shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95f89f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be representations of conceptual topics describing digital spatial information for the Nation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f8a0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contain associated datasets (with attribute records and coordinates)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f8a1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are documented, verifiable, and officially designated to meet recognized standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f8a2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that may be used in common; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f8a3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from which other datasets may be derived.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f8a4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead covered agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95f8a5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each National Geospatial Data Asset data theme, the Committee shall designate one or more covered agencies as the lead covered agencies for the National Geospatial Data Asset data theme.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f8a6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The lead covered agencies for a National Geospatial Data Asset data theme shall be responsible for ensuring the coordinated management of the data, supporting resources (including technology and personnel), and related services and products of the National Geospatial Data Asset data theme.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f8a7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To assist in fulfilling the responsibilities under paragraph (2) with respect to a National Geospatial Data Asset data theme, the lead covered agencies shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f8a8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide leadership and facilitate the development and implementation of geospatial data standards for the National Geospatial Data Asset data theme, with a particular emphasis on a data content standard for the National Geospatial Data Asset data theme, including by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca95f8a9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing existing standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f8aa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying anticipated or needed data standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f8ab-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" developing a plan to originate and implement needed standards with relevant community and international practices—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca95f8ac-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with Office of Management and Budget Circular A–119, or any successor thereto; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca95f8ad-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with or as a part of the plan described in subparagraph (B);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f8ae-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide leadership and facilitate the development and implementation of a plan for nationwide population of the National Geospatial Data Asset data theme, which shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca95f8af-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include developing partnership programs with States, Indian tribes, institutions of higher education, private sector entities, other Federal agencies, and local governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f8b0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the needs of users of geospatial data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f8b1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address human and financial resource needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f8b2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify needs relating to standards, metadata for geospatial data within the National Geospatial Data Asset data theme, and the GeoPlatform; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f8b3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expedite the development of necessary National Geospatial Data Asset data themes;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f8b4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish goals that support the strategic plan for the National Spatial Data Infrastructure prepared under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2804/c"},"text":"section 2804(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f8b5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as necessary, collect and analyze information from users of geospatial data within the National Geospatial Data Asset data theme regarding the needs of the users for geospatial data and incorporate the needs of users in strategies relating to the National Geospatial Data Asset data theme; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f8b6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as part of administering the National Geospatial Data Asset data theme—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca95f8b7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate a point of contact within the lead covered agency who shall be responsible for developing, maintaining, coordination relating to, and disseminating data using the GeoPlatform;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f8b8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Committee—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca95f8b9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/E/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a performance report, at least annually, that documents the activities relating to and implementation of the National Geospatial Data Asset data theme, including progress in achieving the requirements under subparagraphs (A), (B), (C), and (D); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca95f8ba-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/E/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comments, as appropriate, regarding the summary and evaluation of the performance report provided by the Committee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2802/c/12"},"text":"section 2802(c)(12) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f8bb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish maps or comparable graphics online (in accordance with the mapping conventions specified by the Committee) showing the extent and status of the National Geospatial Data Asset data themes for which the covered agency is a lead covered agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f8bc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage individuals and entities that are a source of geospatial data or metadata for geospatial data for the National Geospatial Data Asset data theme to provide access to such data through the GeoPlatform;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f8bd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/E/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the GeoPlatform; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f8be-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2805/b/3/E/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and publish proven practices for the use and application of geospatial data of the lead covered agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca95f8bf-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tVII/s756"},"text":"Pub. L. 115–254, div. B, title VII, § 756","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3421"},"text":"132 Stat. 3421","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
