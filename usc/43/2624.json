{"tag":"section","attrib":{"id":"idca93add9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2624"},"text":null,"children":[{"tag":"num","attrib":{"value":"2624"},"text":"§ 2624.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount available for administration of Coos Bay Wagon Road grant lands under subchapter I; covering of unused receipts into general fund of Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not to exceed 25 per centum of the annual receipts shall be available, in such amounts as the Congress shall from time to time appropriate for the administration of subchapter I, insofar as such sections apply to the Coos Bay Wagon Road grant lands. Any balance not used for administrative purposes shall be covered into the general fund of the Treasury of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca93adda-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-05-24/ch144/s4"},"text":"May 24, 1939, ch. 144, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/754"},"text":"53 Stat. 754","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca93addb-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca93addc-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca93addd-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter I, referred to in text, was in the original a reference to ","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-08-28/ch876"},"text":"act Aug. 28, 1937, ch. 876","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/874"},"text":"50 Stat. 874","children":[],"tail":", which is classified principally to subchapter I (§ 2601 et seq.) of this chapter. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca93adde-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1181f–4"},"text":"section 1181f–4 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
