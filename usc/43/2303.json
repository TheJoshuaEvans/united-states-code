{"tag":"section","attrib":{"id":"idca8c82b3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2303"},"text":null,"children":[{"tag":"num","attrib":{"value":"2303"},"text":"§ 2303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of inholdings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8c82b4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary and the Secretary of Agriculture shall establish a procedure to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8c82b5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify, by State, inholdings for which the landowner has indicated a desire to sell the land or interest therein to the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c82b6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize the acquisition of inholdings in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2305/c/3"},"text":"section 2305(c)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c82b7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2000-07-25"},"text":"July 25, 2000","children":[],"tail":", and periodically thereafter, the Secretary and the Secretary of Agriculture shall provide public notice of the procedures referred to in subsection (a), including any information necessary for the consideration of an inholding under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s2305"},"text":"section 2305 of this title","children":[],"tail":". Such notice shall include publication in the Federal Register and by such other means as the Secretary and the Secretary of Agriculture determine to be appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c82b8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An inholding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8c82b9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be considered for identification under this section only if the Secretary or the Secretary of Agriculture receive notification of a desire to sell from the landowner in response to public notice given under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c82ba-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be deemed to have been established as of the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8c82bb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2303/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the earlier of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca8c82bc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2303/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the land was withdrawn from the public domain; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8c82bd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2303/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the land was established or designated for special management; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8c82be-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2303/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the inholding was acquired by the current owner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c82bf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No obligation to convey or acquire","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The identification of an inholding under this section creates no obligation on the part of a landowner to convey the inholding or any obligation on the part of the United States to acquire the inholding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8c82c0-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/248/tII/s204"},"text":"Pub. L. 106–248, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-25"},"text":"July 25, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/615"},"text":"114 Stat. 615","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
