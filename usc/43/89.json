{"tag":"section","attrib":{"id":"idc9b11661-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s89"},"text":null,"children":[{"tag":"num","attrib":{"value":"89"},"text":"§ 89.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monthly returns of district land offices","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior or such officer as he may designate shall make to the Secretary of the Treasury monthly returns of the moneys received in district land offices, and pay over such money pursuant to his instructions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9b11662-3a70-11f1-bde1-a5140e158598"},"text":"(R.S. § 2245; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-10-28/ch114/s1"},"text":"Oct. 28, 1921, ch. 114, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/208"},"text":"42 Stat. 208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch462"},"text":"Mar. 3, 1925, ch. 462","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1145"},"text":"43 Stat. 1145","children":[],"tail":"; 1946 Reorg. Plan No. 3, § 403, eff. "},{"tag":"date","attrib":{"date":"1946-07-16"},"text":"July 16, 1946","children":[],"tail":", 11 F.R. 7876, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1100"},"text":"60 Stat. 1100","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9b11663-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9b11664-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9b11665-3a70-11f1-bde1-a5140e158598"},"text":null,