{"tag":"section","attrib":{"id":"idc9d4cb4b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390ll"},"text":null,"children":[{"tag":"num","attrib":{"value":"390ll"},"text":"§ 390ll.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corps of Engineers projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d4cb4c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390ll/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of Federal reclamation laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, neither the ownership or pricing limitation provisions nor the other provisions of Federal reclamation law, including this subchapter, shall be applicable to lands receiving benefits from Federal water resources projects constructed by the United States Army Corps of Engineers, unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9d4cb4d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390ll/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project has, by Federal statute, explicitly been designated, made a part of, or integrated with a Federal reclamation project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9d4cb4e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390ll/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, pursuant to his authority under Federal reclamation law, has provided project works for the control or conveyance of an agricultural water supply for the lands involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d4cb4f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390ll/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of construction, operation, maintenance and administrative costs allocated to conservation or irrigation storage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section to the contrary, obligations that require water users, pursuant to contracts with the Secretary, to repay the share of construction costs and to pay the share of the operation and maintenance and contract administrative costs of a Corps of Engineers project which are allocated to conservation storage or irrigation storage shall remain in effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d4cb50-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/293/tII/s212"},"text":"Pub. L. 97–293, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1269"},"text":"96 Stat. 1269","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d4cb51-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d4cb52-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9d4cb53-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Federal reclamation law, referred to in subsec. (a), is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390aa"},"text":"section 390aa of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
