{"tag":"section","attrib":{"id":"idc9fd61c1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s618k"},"text":null,"children":[{"tag":"num","attrib":{"value":"618k"},"text":"§ 618k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The following terms wherever used in this subchapter shall have the following respective meanings:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Project Act” shall mean the Boulder Canyon Project Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s617"},"text":"43 U.S.C. 617","children":[],"tail":" et seq.];"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Project” shall mean the works authorized by the Project Act to be constructed and owned by the United States, exclusive of the main canal and appurtenances mentioned therein, now known as the All-American Canal;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” shall mean the Secretary of the Interior of the United States;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Firm energy” and “allottees” shall have the meaning assigned to such terms in regulations promulgated before ","children":[{"tag":"date","attrib":{"date":"1940-07-19"},"text":"July 19, 1940","children":[],"tail":", by the Secretary and in effect on "},{"tag":"date","attrib":{"date":"1940-07-19"},"text":"July 19, 1940","children":[],"tail":";"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Replacements” shall mean such replacements as may be necessary to keep the project in good operating condition beginning ","children":[{"tag":"date","attrib":{"date":"1937-06-01"},"text":"June 1, 1937","children":[],"tail":", but shall not include (except where used in conjunction with the word “emergency” or the words “however necessitated”) replacements made necessary by any act of God, or of the public enemy, or by any major catastrophe; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Year of operation” shall mean the period from and including June 1 of any calendar year to and including May 31 of the following calendar year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9fd61c2-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-07-19/ch643/s12"},"text":"July 19, 1940, ch. 643, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/778"},"text":"54 Stat. 778","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/381/tI/s104/a/6"},"text":"Pub. L. 98–381, title I, § 104(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-18"},"text":"Aug. 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1335"},"text":"98 Stat. 1335","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9fd61c3-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9fd61c4-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9fd61c5-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Boulder Canyon Project Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-12-21/ch42"},"text":"act Dec. 21, 1928, ch. 42","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1057"},"text":"45 Stat. 1057","children":[],"tail":", which is classified generally to subchapter I (§ 617 et seq.) of this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s617t"},"text":"section 617t of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9fd61c6-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/381"},"text":"Pub. L. 98–381","children":[],"tail":" substituted “beginning "},{"tag":"date","attrib":{"date":"1937-06-01"},"text":"June 1, 1937","children":[],"tail":"” for “during the period from "},{"tag":"date","attrib":{"date":"1937-06-01"},"text":"June 1, 1937","children":[],"tail":", to "},{"tag":"date","attrib":{"date":"1987-05-31"},"text":"May 31, 1987","children":[],"tail":", inclusive” in definition of “Replacements”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
