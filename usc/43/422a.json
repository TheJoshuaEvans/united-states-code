{"tag":"section","attrib":{"id":"idc9d9acd0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s422a"},"text":null,"children":[{"tag":"num","attrib":{"value":"422a"},"text":"§ 422a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this subchapter is to encourage State and local participation in the development of projects under the Federal reclamation laws, with emphasis on rehabilitation and betterment of existing projects for purposes of significant conservation of water, energy and the environment and for purpose of water quality control, and to provide for Federal assistance in the development of similar projects in the seventeen western reclamation States by non-Federal organizations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9d9acd1-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-06/ch972/s1"},"text":"Aug. 6, 1956, ch. 972, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1044"},"text":"70 Stat. 1044","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/546/tIII/s302"},"text":"Pub. L. 99–546, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3053"},"text":"100 Stat. 3053","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d9acd2-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d9acd3-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9d9acd4-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal reclamation laws, referred to in text, are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s422b"},"text":"section 422b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9d9acd5-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/546"},"text":"Pub. L. 99–546","children":[],"tail":" inserted “, with emphasis on rehabilitation and betterment of existing projects for purposes of significant conservation of water, energy and the environment and for purpose of water quality control,” after “laws”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9d9acd6-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc9d9acd7-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/546/tIII/s310"},"text":"Pub. L. 99–546, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3055"},"text":"100 Stat. 3055","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/546/tIII/s310"},"text":"“The provisions of Sections 303 and 308 of this title [amending sections 422c and 422h of this title] shall take effect upon enactment of this title [","children":[{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":"]. The provisions of sections 304(a) and 305 of this title [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s422d"},"text":"section 422d of this title","children":[],"tail":"] shall be applicable to all proposals for which final applications are received by the Secretary after "},{"tag":"date","attrib":{"date":"1986-01-01"},"text":"January 1, 1986","children":[],"tail":". The provisions of Sections 302, 304(b), 306, and 307 [amending this section and sections 422d and 422e of this title] shall be applicable to all proposals for which draft applications are received by the Secretary after Auguest [sic] 15, 1986.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"idc9d9acd8-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-06/ch972/s12"},"text":"Act Aug. 6, 1956, ch. 972, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1047"},"text":"70 Stat. 1047","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1956-08-06/ch972/s12"},"text":"“If any provisions of this Act [enacting this subchapter] or the application of such provision to any person, organization, or circumstance shall be held invalid, the remainder of the Act and the application of such provision to persons, organizations, or circumstances other than those as to which it is held invalid shall not be affected thereby.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
