{"tag":"section","attrib":{"id":"idc9f17a9d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s565"},"text":null,"children":[{"tag":"num","attrib":{"value":"565"},"text":"§ 565.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of sale of town lots; installments of price","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the sale of town lots under the provisions of sections 562 and 563 of this title the Secretary of the Interior may, in his discretion, require payments for such town lots in full at time of sale or in annual installments, not exceeding five, with interest at the rate of 6 per centum per annum on deferred payments.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9f17a9e-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1910-06-11/ch284/s2"},"text":"June 11, 1910, ch. 284, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/466"},"text":"36 Stat. 466","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9f17a9f-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9f17aa0-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9f17aa1-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s594"},"text":"Section 594 of this title","children":[],"tail":", referred to in text, was omitted from the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
