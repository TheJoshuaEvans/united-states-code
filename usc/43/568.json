{"tag":"section","attrib":{"id":"idc9f17aa9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s568"},"text":null,"children":[{"tag":"num","attrib":{"value":"568"},"text":"§ 568.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of reclamation fund for expenses of and disposal of proceeds of sale of town sites","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Reclamation funds shall be available for the payment of all expenses incurred in executing the provisions of sections 561 to 563 and 566 of this title relating to town sites, and the proceeds of all sales of town sites shall be covered into the reclamation fund.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9f17aaa-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1906-06-27/ch3559/s4"},"text":"June 27, 1906, ch. 3559, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/520"},"text":"34 Stat. 520","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9f17aab-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9f17aac-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9f17aad-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on part of the proviso of section 4 of act ","children":[{"tag":"date","attrib":{"date":"1906-06-27"},"text":"June 27, 1906","children":[],"tail":". The remainder of section 4 is classified to section 561 and former "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s594"},"text":"section 594 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
