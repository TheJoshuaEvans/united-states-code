{"tag":"section","attrib":{"id":"idca9ab38a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3204"},"text":null,"children":[{"tag":"num","attrib":{"value":"3204"},"text":"§ 3204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical maintenance and repair","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca9ab38b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical failure at a reserved or transferred work","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9ab38c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3204/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A reserved or transferred work shall only be eligible for funding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s3201/2/A"},"text":"section 3201(2)(A) of this title","children":[],"tail":" if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab38d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3204/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction of the reserved or transferred work began on or before ","children":[{"tag":"date","attrib":{"date":"1915-01-01"},"text":"January 1, 1915","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab38e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3204/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of the reserved or transferred work suffered a critical failure in Bureau of Reclamation infrastructure during the 2-year period ending on ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", that resulted in the failure to deliver water to project beneficiaries."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab38f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3204/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rehabilitation, repair, and replacement activities for a transferred or reserved work using amounts made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s3201/2/A"},"text":"section 3201(2)(A) of this title","children":[],"tail":" may be used for the entire transferred or reserved work, regardless of whether the critical failure was limited to a single project of the overall work."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab390-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3204/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonreimbursable funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s510b/b"},"text":"section 510b(b) of this title","children":[],"tail":", amounts made available to a reserved or transferred work under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s3201/2/A"},"text":"section 3201(2)(A) of this title","children":[],"tail":" shall be nonreimbursable to the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab391-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carey Act projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall use amounts made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s3201/2/B"},"text":"section 3201(2)(B) of this title","children":[],"tail":" to fund the rehabilitation, reconstruction, or replacement of a dam—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9ab392-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3204/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction of which began on or after ","children":[{"tag":"date","attrib":{"date":"1905-01-01"},"text":"January 1, 1905","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab393-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3204/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that was developed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/act/1894-08-18/s4"},"text":"section 4 of the Act of August 18, 1894","children":[],"tail":" (commonly known as the “Carey Act”) ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s641"},"text":"43 U.S.C. 641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/28/422"},"text":"28 Stat. 422","children":[],"tail":", chapter 301);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab394-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3204/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that the Governor of the State in which the dam is located has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab395-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3204/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined the dam has reached its useful life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab396-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3204/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined the dam poses significant health and safety concerns; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab397-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3204/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requested Federal support; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab398-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3204/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the estimated rehabilitation, reconstruction, or replacement, engineering, and permitting costs would exceed $50,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca9ab399-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIX/s40904"},"text":"Pub. L. 117–58, div. D, title IX, § 40904","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1121"},"text":"135 Stat. 1121","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type"