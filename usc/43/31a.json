{"tag":"section","attrib":{"id":"idc9a52f1e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a"},"text":null,"children":[{"tag":"num","attrib":{"value":"31a"},"text":"§ 31a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9a52f1f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds and declares that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9a52f20-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" although significant progress has been made in the production of geologic maps since the establishment of the national cooperative geologic mapping program in 1992, no modern, digital, geologic map exists for approximately 75 percent of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a52f21-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" geologic maps are the primary data base for virtually all applied and basic earth-science investigations, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9a52f22-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exploration for and development of mineral, energy, and water resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a52f23-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" screening and characterizing sites for toxic and nuclear waste disposal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a52f24-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land use evaluation and planning for homeland and environmental protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a52f25-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" earthquake hazards reduction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a52f26-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying volcanic hazards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a52f27-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design and construction of infrastructure requirements such as utility lifelines, transportation corridors, and surface-water impoundments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a52f28-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing losses from landslides and other ground failures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a52f29-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mitigating effects of coastal and stream erosion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a52f2a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" siting of critical facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a52f2b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recreation and public awareness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a52f2c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic earth-science research;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a52f2d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal agencies, State and local governments, private industry, and the general public depend on the information provided by geologic maps to determine the extent of potential environmental damage before embarking on projects that could lead to preventable, costly environmental problems or litigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a52f2e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the combined capabilities of State, Federal, and academic groups to provide geologic mapping are not sufficient to meet the present and future needs of the United States for national security, environmental protection, and energy self-sufficiency of the Nation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a52f2f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States are willing to contribute 50 percent of the funding necessary to complete the mapping of the geology within the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a52f30-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lack of proper geologic maps has led to the poor design of such structures as dams and waste-disposal facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a52f31-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geologic maps have proven indispensable in the search for needed fossil-fuel and mineral resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a52f32-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geologic map information is required for the sustainable and balanced development of natural resources of all types, including energy, minerals, land, water, and biological resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a52f33-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advances in digital technology and geographical information system science have made geologic map databases increasingly available as decision support tools for land and resource management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a52f34-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive nationwide program of geologic mapping of surficial and bedrock deposits is required in order to systematically build the Nation’s geologic-map data base at a pace that responds to increasing demand.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9a52f35-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of sections 31a to 31h of this title is to expedite the production of a geologic-map data base for the Nation, to be located within the United States Geological Survey, which can be applied to land-use management, assessment, and utilization, conservation of natural resources, groundwater management, and environmental protection and management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9a77926-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/285/s2"},"text":"Pub. L. 102–285, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-18"},"text":"May 18, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/166"},"text":"106 Stat. 166","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/148/s2"},"text":"Pub. L. 106–148, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1719"},"text":"113 Stat. 1719","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXI/s11001/a"},"text":"Pub. L. 111–11, title XI, § 11001(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1414"},"text":"123 Stat. 1414","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9a77927-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9a77928-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9a77929-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 31a to 31h of this title, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/285"},"text":"Pub. L. 102–285","children":[],"tail":", known as the National Geologic Mapping Act of 1992, which is classified principally to sections 31a to 31h of this title. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9a7792a-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s11001/a/1"},"text":"Pub. L. 111–11, § 11001(a)(1)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “during the past 2 decades, the production of geologic maps has been drastically curtailed;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s11001/a/2/A"},"text":"Pub. L. 111–11, § 11001(a)(2)(A)","children":[],"tail":", inserted “homeland and” after “planning for”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s11001/a/2/B"},"text":"Pub. L. 111–11, § 11001(a)(2)(B)","children":[],"tail":", substituted “identifying” for “predicting”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(J), (K). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s11001/a/2/C"},"text":"Pub. L. 111–11, § 11001(a)(2)(C)","children":[],"tail":"–(E), added subpar. (J) and redesignated former subpar. (J) as (K)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s11001/a/3"},"text":"Pub. L. 111–11, § 11001(a)(3)","children":[],"tail":", substituted “available” for “important”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s11001/b"},"text":"Pub. L. 111–11, § 11001(b)","children":[],"tail":", inserted “and management” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(8) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/148"},"text":"Pub. L. 106–148","children":[],"tail":" added pars. (8) and (9) and redesignated former par. (8) as (10) and inserted “of surficial and bedrock deposits” after “geologic mapping”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9a7792b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idc9a7792c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/148/s1"},"text":"Pub. L. 106–148, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1719"},"text":"113 Stat. 1719","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/148/s1"},"text":"“This Act [enacting sections 31e, 31g and 31h of this title, amending sections 31a to 31d and 31f of this title, and repealing former sections 31e, 31g, and 31h of this title] may be cited as the ‘National Geologic Mapping Reauthorization Act of 1999’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idc9a7792d-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s1"},"text":"Pub. L. 105–36, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1107"},"text":"111 Stat. 1107","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/36/s1"},"text":"“This Act [amending sections 31b to 31h of this title and enacting provisions set out as a note under this section] may be cited as the ‘National Geologic Mapping Reauthorization Act of 1997’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idc9a7792e-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/285/s1"},"text":"Pub. L. 102–285, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-18"},"text":"May 18, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/166"},"text":"106 Stat. 166","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/285/s1"},"text":"“This Act [enacting this section and sections 31b to 31h of this title, amending sections 1457, 1457a, and 1782 of this title, sections 450ii–3, 665, 1133, and 3151 of Title 16, Conservation, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262k"},"text":"section 262k of Title 22","children":[],"tail":", Foreign Relations and Intercourse, "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1677"},"text":"section 1677 of Title 25","children":[],"tail":", Indians, sections 1, 1a, 2, 3, 4, 4c, 4d, 5, 6, 7, 8, 411, 412, 804, 812, 871, 878, 1224, 1229, 1232, 1311, 1315, and 1604 of Title 30, Mineral Lands and Mining, and sections 5814 and 6505 of Title 42, The Public Health and Welfare, enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s31"},"text":"section 31 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of Title 30","children":[],"tail":", and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1231"},"text":"section 1231 of Title 30","children":[],"tail":"] may be cited as the ‘National Geologic Mapping Act of 1992’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9a7792f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s2"},"text":"Pub. L. 105–36, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1107"},"text":"111 Stat. 1107","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/36/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in enacting the National Geologic Mapping Act of 1992 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s31a"},"text":"43 U.S.C. 31a","children":[],"tail":" et seq.), Congress found, among other things, that—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the 2 decades preceding enactment of that Act, the production of geologic maps had been drastically curtailed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geologic maps are the primary data base for virtually all applied and basic earth-science investigations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal agencies, State and local governments, private industry, and the general public depend on the information provided by geologic maps to determine the extent of potential environmental damage before embarking on projects that could lead to preventable, costly environmental problems or litigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lack of proper geologic maps has led to the poor design of such structures as dams and waste-disposal facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geologic maps have proven indispensable in the search for needed fossil fuel and mineral resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive nationwide program of geologic mapping is required in order to systematically build the Nation’s geologic-map data base at a pace that responds to increasing demand;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geologic mapping program called for by that Act has not been fully implemented; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is time for this important program to be fully implemented.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
