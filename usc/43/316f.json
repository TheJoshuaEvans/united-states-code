{"tag":"section","attrib":{"id":"idc9bf6e68-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316f"},"text":null,"children":[{"tag":"num","attrib":{"value":"316f"},"text":"§ 316f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions of lease","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9bf6e69-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of lease","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A lease may be made for such term as the Secretary deems reasonable, but not to exceed fifty-five years, taking into consideration all factors that are relevant to the exercise of the grazing privileges conferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9bf6e6a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Size of leasehold","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Leases shall be made for grazing on a definite area except where local conditions or the administration of grazing privileges makes more practicable a lease based on the number of stock to be grazed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9bf6e6b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms for surrender of lease","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each lease shall provide that the lessee may surrender his lease, and, if he has complied with the terms and conditions of the lease to the time of surrender, may avoid further liability for fees thereunder by giving written notice to the Secretary of such surrender. The lease shall specify the length of time of notice, which shall not exceed one year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9bf6e6c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms for renewal of lease","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each lease shall provide that the lessee may negotiate for renewal of such lease, subject to the provisions of this subchapter, at any time during the final five years of the term of such lease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9bf6e6d-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch513/s7"},"text":"Mar. 4, 1927, ch. 513, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1453"},"text":"44 Stat. 1453","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/403/s2"},"text":"Pub. L. 90–403, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-18"},"text":"July 18, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/358"},"text":"82 Stat. 358","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9bf6e6e-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9bf6e6f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9bf6e70-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s471f"},"text":"section 471f of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9bf6e71-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1968—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/403/s2/a"},"text":"Pub. L. 90–403, § 2(a)","children":[],"tail":", substituted provisions for reasonable term of leases, limited to fifty-five years, and based on all factors relevant to exercise of grazing privileges for prior provisions for twenty year leases, except where land may be required for other than grazing purposes within a ten year period, and for shorter term leases as desired by applicant."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/403/s2/b"},"text":"Pub. L. 90–403, § 2(b)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
