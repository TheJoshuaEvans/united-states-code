{"tag":"section","attrib":{"id":"idca3dc58d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1526"},"text":null,"children":[{"tag":"num","attrib":{"value":"1526"},"text":"§ 1526.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water salvage programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall undertake programs for water salvage and ground water recovery along and adjacent to the main stream of the Colorado River. Such programs shall be consistent with maintenance of a reasonable degree of undistributed habitat for fish and wildlife in the area, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca3dc58e-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/537/tIII/s306"},"text":"Pub. L. 90–537, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-09-30"},"text":"Sept. 30, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/893"},"text":"82 Stat. 893","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
