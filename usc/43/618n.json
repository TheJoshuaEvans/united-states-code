{"tag":"section","attrib":{"id":"idc9fd61cf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s618n"},"text":null,"children":[{"tag":"num","attrib":{"value":"618n"},"text":"§ 618n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wages of employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All laborers and mechanics employed in the construction of any part of the project, or in the operation, maintenance, or replacement of any part of the Hoover Dam, shall be paid not less than the prevailing rate of wages or compensation for work of a similar nature prevailing in the locality of the project. In the event any dispute arises as to what are the prevailing rates, the determination thereof shall be made by the Secretary of the Interior, and his decision, subject to the concurrence of the Secretary of Labor, shall be final.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9fd61d0-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-07-19/ch643/s15"},"text":"July 19, 1940, ch. 643, § 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/779"},"text":"54 Stat. 779","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-04-30/ch46"},"text":"Apr. 30, 1947, ch. 46","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/56"},"text":"61 Stat. 56","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9fd61d1-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9fd61d2-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idc9fd61d3-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Hoover Dam” substituted in text for “Boulder Dam” on authority of act ","children":[{"tag":"date","attrib":{"date":"1947-04-30"},"text":"Apr. 30, 1947","children":[],"tail":", which changed name of Boulder Dam to Hoover Dam."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
