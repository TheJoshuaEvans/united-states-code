{"tag":"section","attrib":{"id":"idca3dc58f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1527"},"text":null,"children":[{"tag":"num","attrib":{"value":"1527"},"text":"§ 1527.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fish and wildlife conservation and development","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The conservation and development of the fish and wildlife resources and the enhancement of recreation opportunities in connection with the project works authorized pursuant to this subchapter shall be in accordance with the provisions of the Federal Water Project Recreation Act (","children":[{"tag":"ref","attrib":{"href":"/us/stat/79/213"},"text":"79 Stat. 213","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460"},"text":"16 U.S.C. 460","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–12 et seq.], except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1522"},"text":"section 1522 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca3dc590-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/537/tIII/s308"},"text":"Pub. L. 90–537, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-09-30"},"text":"Sept. 30, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/893"},"text":"82 Stat. 893","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca3dc591-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca3dc592-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca3dc593-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Water Project Recreation Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/72"},"text":"Pub. L. 89–72","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-09"},"text":"July 9, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/213"},"text":"79 Stat. 213","children":[],"tail":", which is classified principally to part C (§ 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–12 et seq.) of subchapter LXIX of chapter 1 of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under section 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–12 of Title 16 and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
