{"tag":"section","attrib":{"id":"idca913d48-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2434"},"text":null,"children":[{"tag":"num","attrib":{"value":"2434"},"text":"§ 2434.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca913d49-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2434/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), the authority of the Secretary to carry out this subchapter terminates on the date that is 10 years after ","children":[{"tag":"date","attrib":{"date":"2006-12-22"},"text":"December 22, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913d4a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2434/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The termination of authority under subsection (a) shall have no effect on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca913d4b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2434/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any loans guaranteed by the United States under this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913d4c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2434/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"tex