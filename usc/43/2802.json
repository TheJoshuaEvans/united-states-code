{"tag":"section","attrib":{"id":"idca93ae31-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802"},"text":null,"children":[{"tag":"num","attrib":{"value":"2802"},"text":"§ 2802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Geographic Data Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca93ae32-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Department of the Interior an interagency committee to be known as the Federal Geographic Data Committee, which shall act as the lead entity in the executive branch for the development, implementation, and review of policies, practices, and standards relating to geospatial data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca93ae33-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca93ae34-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson and Vice Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior and the Director of the Office of Management and Budget shall serve as Chairperson of the Committee and Vice Chairperson of the Committee, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae35-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other members","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca93ae36-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of each covered agency and the Director of the National Geospatial-Intelligence Agency shall each designate a representative of their respective agency to serve as a member of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca93ae37-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An officer appointed to serve as a member of the Committee shall hold a position as an assistant secretary, or an equivalent position, or a higher ranking position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae38-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":", and as needed thereafter, the Director of the Office of Management and Budget shall update guidance with respect to membership of the Committee and the roles of members of the Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca93ae39-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca93ae3a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lead the development and management of and operational decision making for the National Spatial Data Infrastructure strategic plan and geospatial data policy in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2804"},"text":"section 2804 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae3b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate National Geospatial Data Asset data themes and oversee the coordinated management of the National Geospatial Data Asset data themes in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2805"},"text":"section 2805 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae3c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain geospatial data standards in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2806"},"text":"section 2806 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae3d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically review and determine the extent to which covered agencies comply with geospatial data standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae3e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the GeoPlatform operates in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2807"},"text":"section 2807 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae3f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct and facilitate national implementation of the system of National Geospatial Data Asset data themes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae40-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" communicate with and foster communication among covered agencies and other entities and individuals relating to geospatial data technology development, transfer, and exchange in order to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca93ae41-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and meet the needs of users of geospatial data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca93ae42-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote cost-effective data collection, documentation, maintenance, distribution, and preservation strategies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca93ae43-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage Federal and non-Federal resources, such as promoting Federal shared services and cross-agency coordination for marketplace solutions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae44-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" define roles and responsibilities and promote and guide cooperation and coordination among agencies of the Federal Government, State, tribal, and local governments, institutions of higher education, and the private sector in the collection, production, sharing, and use of geospatial information, the implementation of the National Spatial Data Infrastructure, and the identification of proven practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae45-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with international organizations having an interest in the National Spatial Data Infrastructure or global spatial data infrastructures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae46-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make available online and update at least annually—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca93ae47-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a summary of the status for each National Geospatial Data Asset data theme, based on the report submitted by the applicable lead covered agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2805/b/3/E/ii/I"},"text":"section 2805(b)(3)(E)(ii)(I) of this title","children":[],"tail":", which shall include—"}],"tail":null},{"tag":"clause","attrib":{"id":"idca93ae48-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/10/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the progress of each lead covered agency in achieving the requirements under subparagraphs (A), (B), (C), and (D) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2805/b/3"},"text":"section 2805(b)(3) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca93ae49-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/10/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a determination of whether, for each of subparagraphs (A), (B), (C), and (D) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2805/b/3"},"text":"section 2805(b)(3) of this title","children":[],"tail":", each lead covered agency meets expectations, has made progress toward expectations, or fails to meet expectations;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca93ae4a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary and evaluation of the achievements of each covered agency, based on the annual report submitted by the covered agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2808/b/1"},"text":"section 2808(b)(1) of this title","children":[],"tail":", which shall include a determination of whether the covered agency meets expectations, has made progress toward expectations, or fails to meet expectations for each of paragraphs (1) through (13) of "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s2808/a"},"text":"section 2808(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca93ae4b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a collection of periodic technical publications, management articles, and reports related to the National Spatial Data Infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca93ae4c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a membership directory for the Committee, including identifying members of any subcommittee or working group of the Committee;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae4d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca93ae4e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available to and request comments from the Advisory Committee regarding the summaries and evaluations required under subparagraphs (A) and (B) of paragraph (10);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca93ae4f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if requested by the Advisory Committee, respond to any comments by the Advisory Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca93ae50-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than once every 2 years, submit to Congress a report that includes the summaries and evaluations required under subparagraphs (A) and (B) of paragraph (10), the comments of the Advisory Committee, and the responses of the Committee to the comments;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae51-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca93ae52-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available to and request comments from covered agencies regarding the summaries and evaluations required under subparagraphs (A) and (B) of paragraph (10); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca93ae53-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than once every 2 years, submit to Congress a report that includes the comments of the covered agencies and the responses of the Committee to the comments; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae54-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support and promote the infrastructure of networks, systems, services, and standards that provide a digital representation of the Earth to users for many applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca93ae55-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2802/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall establish an Office of the Secretariat within the Department of the Interior to provide administrative support, strategic planning, funding, and technical support to the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca93ae56-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tVII/s753"},"text":"Pub. L. 115–254, div. B, title VII, § 753","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3415"},"text":"132 Stat. 3415","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
