{"tag":"section","attrib":{"id":"idc9e3231b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s464"},"text":null,"children":[{"tag":"num","attrib":{"value":"464"},"text":"§ 464.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increases of charges on failure to make water-right application","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In all cases where application for water right for lands in private ownership or lands held under entries not subject to the reclamation law shall not be made within one year after ","children":[{"tag":"date","attrib":{"date":"1914-08-13"},"text":"August 13, 1914","children":[],"tail":", or within one year after notice issued in pursuance of "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s419"},"text":"section 419 of this title","children":[],"tail":", in cases where such notice has not been issued prior to "},{"tag":"date","attrib":{"date":"1914-08-13"},"text":"August 13, 1914","children":[],"tail":", the construction charges for such land shall be increased 5 per centum each year until such application is made and an initial installment is paid."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9e3231c-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-08-13/ch247/s9"},"text":"Aug. 13, 1914, ch. 247, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/689"},"text":"38 Stat. 689","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9e3231d-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9e3231e-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9e3231f-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The reclamation law, referred to in text, is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s472"},"text":"section 472 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
