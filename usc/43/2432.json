{"tag":"section","attrib":{"id":"idca913d3d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2432"},"text":null,"children":[{"tag":"num","attrib":{"value":"2432"},"text":"§ 2432.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on the reclamation laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca913d3e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2432/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reclamation projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter supersedes or amends any Federal law associated with a project, or a portion of a project, constructed under the reclamation laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913d3f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2432/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No new or supplemental benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any assistance provided under this subchapter shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca913d40-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2432/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be considered to be a new or supplemental benefit for purposes of the Reclamation Reform Act of 1982 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390aa"},"text":"43 U.S.C. 390aa","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913d41-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2432/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affect any contract in existence on ","children":[{"tag":"date","attrib":{"date":"2006-12-22"},"text":"December 22, 2006","children":[],"tail":", that is executed under the reclamation laws."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca913d42-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/451/tII/s213"},"text":"Pub. L. 109–451, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3361"},"text":"120 Stat. 3361","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca913d43-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca913d44-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca913d45-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Reclamation Reform Act of 1982, referred to in subsec. (b)(1), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/293"},"text":"Pub. L. 97–293","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1263"},"text":"96 Stat. 1263","children":[],"tail":", which enacted subchapter I–A (§ 390aa et seq.) of chapter 12 of this title, amended sections 373a, 422e, 425b, and 485h of this title, and repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s383"},"text":"section 383 of Title 25","children":[],"tail":", Indians. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
