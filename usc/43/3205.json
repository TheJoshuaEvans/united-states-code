{"tag":"section","attrib":{"id":"idca9ab39f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205"},"text":null,"children":[{"tag":"num","attrib":{"value":"3205"},"text":"§ 3205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grant program for large-scale water recycling and reuse program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca9ab3a0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9ab3a1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab3a2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, Indian Tribe, municipality, irrigation district, water district, wastewater district, or other organization with water or power delivery authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab3a3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, regional, or local authority, the members of which include 1 or more organizations with water or power delivery authority; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab3a4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency established under State law for the joint exercise of powers or a combination of entities described in subparagraphs (A) and (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab3a5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible project” means a project described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab3a6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the grant program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab3a7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reclamation State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Reclamation State” means a State or territory described in the first section of the Act of ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s391"},"text":"43 U.S.C. 391","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/32/388"},"text":"32 Stat. 388","children":[],"tail":", chapter 1093)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab3a8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program to provide grants to eligible entities on a competitive basis for the planning, design, and construction of large-scale water recycling and reuse projects that provide substantial water supply and other benefits to the Reclamation States in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab3a9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project shall be eligible for a grant under this section if the project—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9ab3aa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reclaims and reuses—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab3ab-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" municipal, industrial, domestic, or agricultural wastewater; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab3ac-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impaired groundwater or surface water;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab3ad-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a total estimated cost of $500,000,000 or more;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab3ae-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located in a Reclamation State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab3af-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is constructed, operated, and maintained by an eligible entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab3b0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a Federal benefit in accordance with the reclamation laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab3b1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide a grant to an eligible project under the program if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9ab3b2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the eligible entity determines through the preparation of a feasibility study or equivalent study, and the Secretary concurs, that the eligible project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab3b3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is technically and financially feasible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab3b4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a Federal benefit in accordance with the reclamation laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab3b5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with applicable Federal and State laws;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab3b6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity has sufficient non-Federal funding available to complete the eligible project, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab3b7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity is financially solvent, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab3b8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 30 days after the date on which the Secretary concurs with the determinations under paragraph (1) with respect to the eligible project, the Secretary submits to Congress written notice of the determinations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab3b9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing grants to eligible projects under the program, the Secretary shall give priority to eligible projects that meet 1 or more of the following criteria:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9ab3ba-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The eligible project provides multiple benefits, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab3bb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water supply reliability benefits for drought-stricken States and communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab3bc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fish and wildlife benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab3bd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water quality improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab3be-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The eligible project is likely to reduce impacts on environmental resources from water projects owned or operated by Federal and State agencies, including through measurable reductions in water diversions from imperiled ecosystems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab3bf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The eligible project would advance water management plans across a multi-State area, such as drought contingency plans in the Colorado River Basin.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab3c0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The eligible project is regional in nature.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab3c1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The eligible project is collaboratively developed or supported by multiple stakeholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab3c2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9ab3c3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of any project provided a grant under the program shall not exceed 25 percent of the total cost of the eligible project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab3c4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total dollar cap","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not impose a total dollar cap on Federal contributions for all eligible individual projects provided a grant under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab3c5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonreimbursable funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds provided by the Secretary to an eligible entity under the program shall be considered nonreimbursable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab3c6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible project shall not be considered ineligible for assistance under the program because the eligible project has received assistance under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab3c7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Reclamation Wastewater and Groundwater Study and Facilities Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390h"},"text":"43 U.S.C. 390h","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab3c8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 4(a) of the Water Desalination Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10301"},"text":"42 U.S.C. 10301","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/104/298"},"text":"Public Law 104–298","children":[],"tail":") for eligible desalination projects; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab3c9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1602(e) of the Reclamation Wastewater and Groundwater Study and Facilities Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390h/e"},"text":"43 U.S.C. 390h(e)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab3ca-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing a grant for an eligible project under the program, the Secretary shall comply with all applicable environmental laws, including the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab3cb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary shall issue guidance on the implementation of the program, including guidelines for the preparation of feasibility studies or equivalent studies by eligible entities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab3cc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9ab3cd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the end of each fiscal year, the Secretary shall make available on the website of the Department of the Interior an annual report that lists each eligible project for which a grant has been awarded under this section during the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab3ce-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comptroller general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab3cf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the United States shall conduct an assessment of the administrative establishment, solicitation, selection, and justification process with respect to the funding of grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab3d0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of the initial award of grants under this section, the Comptroller General shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives a report that describes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca9ab3d1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/i/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy and effectiveness of the process by which each eligible project was selected, if applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab3d2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/i/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the justification and criteria used for the selection of each eligible project, if applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab3d3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of conveyance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consider the planning, design, and construction of a conveyance system for an eligible project to be eligible for grant funding under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab3d4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3205/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to carry out this section terminates on the date that is 5 years after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca9ab3d5-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIX/s40905"},"text":"Pub. L. 117–58, div. D, title IX, § 40905","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1122"},"text":"135 Stat. 1122","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca9ab3d6-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca9ab3d7-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca9ab3d8-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Reclamation Wastewater and Groundwater Study and Facilities Act, referred to in subsec. (f)(4)(A), is title XVI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575"},"text":"Pub. L. 102–575","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-30"},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4663"},"text":"106 Stat. 4663","children":[],"tail":", which enacted sections 390h to 390h–15 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s390h"},"text":"section 390h of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (g), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca9ab3d9-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca9ab3da-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
