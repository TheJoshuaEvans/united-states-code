{"tag":"section","attrib":{"id":"idca9868c5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3004"},"text":null,"children":[{"tag":"num","attrib":{"value":"3004"},"text":"§ 3004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National goal for renewable energy production on Federal land","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca9868c6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2022-09-01"},"text":"September 1, 2022","children":[],"tail":", the Secretary shall, in consultation with the Secretary of Agriculture and other heads of relevant Federal agencies, establish national goals for renewable energy production on Federal land."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9868c7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum production goal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall seek to issue permits that, in total, authorize production of not less than 25 gigawatts of electricity from wind, solar, and geothermal energy projects by not later than 2025, through management of public lands and administration of Federal laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca9868c8-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3104"},"text":"Pub. L. 116–260, div. Z, title III, § 3104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2516"},"text":"134 Stat. 2516","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
