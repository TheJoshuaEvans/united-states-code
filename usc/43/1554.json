{"tag":"section","attrib":{"id":"idca403710-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1554"},"text":null,"children":[{"tag":"num","attrib":{"value":"1554"},"text":"§ 1554.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal reclamation laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this chapter, in constructing, operating, and maintaining the units of the projects herein and hereafter authorized, the Secretary shall be governed by the Federal reclamation laws (Act of ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/32/388"},"text":"32 Stat. 388","children":[],"tail":", and Acts amendatory thereof or supplementary thereto) to which laws this chapter shall be deemed a supplement."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca403711-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/537/tVI/s604"},"text":"Pub. L. 90–537, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-09-30"},"text":"Sept. 30, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/901"},"text":"82 Stat. 901","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca403712-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca403713-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca403714-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":", referred to in text, is popularly known as the Reclamation Act, which is classified generally to chapter 12 (§ 371 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
