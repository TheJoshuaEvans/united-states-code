{"tag":"section","attrib":{"id":"idca09485c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s774"},"text":null,"children":[{"tag":"num","attrib":{"value":"774"},"text":"§ 774.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of surveyor by marshal","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever the President is satisfied that forcible opposition has been offered, or is likely to be offered, to any surveyor or deputy surveyor in the discharge of his duties in surveying the public lands, it may be lawful for the President to order the marshal of the State or district, by himself or deputy, to attend such surveyor or deputy surveyor with sufficient force to protect such officer in the execution of his duty, and to remove force should any be offered.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca09485d-3a70-11f1-bde1-a5140e158598"},"text":"(R.S. § 2413.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca09485e-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca09485f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca094860-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2413 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1830-05-29/ch163/s2"},"text":"act May 29, 1830, ch. 163, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/4/417"},"text":"4 Stat. 417","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
