{"tag":"section","attrib":{"id":"idc9d281be-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–32"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–32"},"text":"§ 390h–32.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rancho California Water District project, California","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d281bf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–32/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the Rancho California Water District, California, may participate in the design, planning, and construction of permanent facilities for water recycling, demineralization, and desalination, and distribution of non-potable water supplies in Southern Riverside County, California.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d281c0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–32/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of the project described in subsection (a) shall not exceed 25 percent of the total cost of the project or $20,000,000, whichever is less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d281c1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–32/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided by the Secretary under this section shall not be used for operation or maintenance of the project described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d281c2-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s1649"},"text":"Pub. L. 102–575, title XVI, § 1649","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tIX/s9104/a"},"text":"Pub. L. 111–11, title IX, § 9104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1303"},"text":"123 Stat. 1303","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
