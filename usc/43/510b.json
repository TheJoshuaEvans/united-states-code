{"tag":"section","attrib":{"id":"idc9ecbff9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b"},"text":null,"children":[{"tag":"num","attrib":{"value":"510b"},"text":"§ 510b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extraordinary operation and maintenance work performed by the Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9ecbffa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the transferred works operating entity may carry out, in accordance with subsection (b) and consistent with existing transfer contracts, any extraordinary operation and maintenance work on a project facility that the Secretary determines to be reasonably required to preserve the structural safety of the project facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9ecbffb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of costs arising from extraordinary operation and maintenance work","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9ecbffc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For reserved works, costs incurred by the Secretary in conducting extraordinary operation and maintenance work will be allocated to the authorized reimbursable purposes of the project and shall be repaid within 50 years, with interest, from the year in which work undertaken pursuant to this subchapter is substantially complete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ecbffd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For transferred works, the Secretary is authorized to advance the costs incurred by the transferred works operating entity in conducting extraordinary operation and maintenance work and negotiate appropriate 50-year repayment contracts with project beneficiaries providing for the return of reimbursable costs, with interest, under this subsection: Provided, however, That no contract entered into pursuant to this subchapter shall be deemed to be a new or amended contract for the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390cc/a"},"text":"section 390cc(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ecbffe-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of interest rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interest rate used for computing interest on work in progress and interest on the unpaid balance of the reimbursable costs of extraordinary operation and maintenance work authorized by this subchapter shall be determined by the Secretary of the Treasury, as of the beginning of the fiscal year in which extraordinary operation and maintenance work is commenced, on the basis of average market yields on outstanding marketable obligations of the United States with the remaining periods of maturity comparable to the applicable reimbursement period of the project, adjusted to the nearest ⅛ of 1 percent on the unamortized balance of any portion of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9ecbfff-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency extraordinary operation and maintenance work","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9ecc000-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the transferred works operating entity shall carry out any emergency extraordinary operation and maintenance work on a project facility that the Secretary determines to be necessary to minimize the risk of imminent harm to public health or safety, or property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ecc001-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may advance funds for emergency extraordinary operation and maintenance work and shall seek reimbursement from the transferred works operating entity or benefitting entity upon receiving a written assurance from the governing body of such entity that it will negotiate a contract pursuant to this section for repayment of costs incurred by the Secretary in undertaking such work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ecc002-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that a project facility inspected and maintained pursuant to the guidelines and criteria set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s510a/a"},"text":"section 510a(a) of this title","children":[],"tail":" requires extraordinary operation and maintenance pursuant to paragraph (1), the Secretary may provide Federal funds on a nonreimbursable basis sufficient to cover 35 percent of the cost of the extraordinary operation and maintenance allocable to the transferred works operating entity, which is needed to minimize the risk of imminent harm. The remaining share of the Federal funds advanced by the Secretary for such work shall be repaid under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9ecc003-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aging Infrastructure Account","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9ecc004-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established in the general fund of the Treasury a special account, to be known as the “Aging Infrastructure Account” (referred to in this subsection as the “Account”), to provide funds to, and provide for the extended repayment of the funds by, a transferred works operating entity or project beneficiary responsible for repayment of reimbursable costs for the conduct of extraordinary operation and maintenance work at a project facility, which shall consist of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9ef08f5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts that are specifically appropriated to the Account under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s510d"},"text":"section 510d of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ef08f6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts deposited in the Account under paragraph (3)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ef08f7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraphs (3) and (6), the Secretary may expend amounts in the Account to fund and provide for extended repayment of the funds for eligible projects identified in a report submitted under paragraph (5)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ef08f8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment contract","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9ef08f9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not expend amounts under paragraph (2) with respect to an eligible project described in that paragraph unless the transferred works operating entity or project beneficiary responsible for repayment of reimbursable costs has entered into a contract to repay the amounts under subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ef08fa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of repaid funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts repaid by a transferred works operating entity or project beneficiary responsible for repayment of reimbursable costs receiving funds under a repayment contract entered into under this subsection shall be deposited in the Account and shall be available to the Secretary for expenditure, subject to paragraph (6), in accordance with this subsection, and without further appropriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ef08fb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9ef08fc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning with fiscal year 2022, not less than once per fiscal year, the Secretary shall accept, during an application period established by the Secretary, applications from transferred works operating entities or project beneficiaries responsible for payment of reimbursable costs for funds and extended repayment for eligible projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ef08fd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project eligible for funding and extended repayment under this subsection is a project that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9ef08fe-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualifies as an extraordinary operation and maintenance work under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ef08ff-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is for the major, non-recurring maintenance of a mission-critical asset; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ef0900-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not eligible to be carried out or funded under the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s508/c"},"text":"section 508(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ef0901-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines for applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall issue guidelines describing the information required to be provided in an application for funds and extended repayment under this subsection that require, at a minimum—"}],"tail":null},{"tag":"clause","attrib":{"id":"idc9ef0902-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the project for which the funds are requested;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ef0903-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funds requested;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ef0904-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the repayment period requested by the transferred works operating entity or project beneficiary responsible for repayment of reimbursable costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ef0905-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/4/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative non-Federal funding options that have been evaluated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ef0906-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/4/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial justification for requesting an extended repayment period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ef0907-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/4/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial records of the transferred works operating entity or project beneficiary responsible for repayment of reimbursable costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ef0908-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review by the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall review each application submitted under subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9ef0909-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine whether the project is eligible for funds and an extended repayment period under this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ef090a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine if the project has been identified by the Bureau of Reclamation as part of the major rehabilitation and replacement of a project facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ef090b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/4/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to conduct a financial analysis of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc9ef090c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/4/D/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9ef090d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/4/D/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repayment capability of the transferred works operating entity or project beneficiary responsible for repayment of reimbursable costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ef090e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date on which an application period closes under paragraph (4)(A), the Secretary shall submit to the Committees on Energy and Natural Resources and Appropriations of the Senate and the Committees on Natural Resources and Appropriations of the House of Representatives a report that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9ef090f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the results of the Secretary’s review of each application under paragraph (4)(D), including a determination of whether the project is eligible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ef0910-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies each project eligible for funds and extended repayment under this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ef0911-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to each eligible project identified under subparagraph (B), includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9ef0912-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc9ef0913-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/5/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9ef0914-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/5/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated cost and duration of the eligible project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9ef0915-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/5/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any remaining engineering or environmental compliance that is required before the eligible project commences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9ef0916-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/5/C/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations the Secretary may have concerning the plan or design of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9ef0917-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/5/C/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any conditions the Secretary may require for construction of the project;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ef0918-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an analysis of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc9ef0919-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/5/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the repayment period proposed in the application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9ef091a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/5/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary recommends a minimum necessary repayment period that is different than the repayment period proposed in the application, the minimum necessary repayment period recommended by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ef091b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/5/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of alternative non-Federal funding options;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ef091c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the allocation of funds from deposits into the Account under paragraph (3)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ef091d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the balance of funds in the Account as of the date of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ef091e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative allocation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9ef091f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appropriations Acts may provide for alternate allocation of amounts reported pursuant to paragraph (5)(D) that are made available under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ef0920-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation by Secretary","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9ef0921-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No alternate allocations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If Congress has not enacted legislation establishing alternate allocations by the date on which the Act making full-year appropriations for energy and water development and related agencies for the applicable fiscal year is enacted into law, amounts made available under paragraph (1) shall be allocated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ef0922-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insufficient alternate allocations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If Congress enacts legislation establishing alternate allocations for amounts made available under paragraph (1) that are less than the full amount appropriated under that paragraph, the difference between the amount appropriated and the alternate allocation shall be allocated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ef0923-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of subsection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection affects—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9ef0924-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any funding provided, or contracts entered into, under subsection (a) before ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ef0925-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s510b/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of funds otherwise made available to the Secretary to carry out subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9ef0926-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tIX/s9603"},"text":"Pub. L. 111–11, title IX, § 9603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1348"},"text":"123 Stat. 1348","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tXI/s1101"},"text":"Pub. L. 116–260, div. FF, title XI, § 1101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3221"},"text":"134 Stat. 3221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9ef0927-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9ef0928-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9ef0929-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9ef092a-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9ef092b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repayment into the Aging Infrastructure Account","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/74/dB/tII/s208"},"text":"Pub. L. 119–74, div. B, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-01-23"},"text":"Jan. 23, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/74"},"text":"140 Stat. 74","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/74/dB/tII/s208"},"text":"“In this fiscal year and each fiscal year thereafter, notwithstanding the Act of ","children":[{"tag":"date","attrib":{"date":"1938-05-09"},"text":"May 9, 1938","children":[],"tail":", ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s392a"},"text":"43 U.S.C. 392a","children":[],"tail":"), all monies received by the United States in connection with the repayment or reimbursement of costs for all projects, including power, financed in whole or in part with money from the Aging Infrastructure Account created pursuant to section 9603(d) of the Omnibus Public Land Management Act of 2009 ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s510b/d"},"text":"43 U.S.C. 510b(d)","children":[],"tail":") shall be repaid and deposited to that account.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
