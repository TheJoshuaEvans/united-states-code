{"tag":"section","attrib":{"id":"idca95f8c0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2806"},"text":null,"children":[{"tag":"num","attrib":{"value":"2806"},"text":"§ 2806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geospatial data standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca95f8c1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2806/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with section 216 of the E-Government Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3501"},"text":"44 U.S.C. 3501","children":[],"tail":" note), the Committee shall establish standards for each National Geospatial Data Asset data theme, which—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95f8c2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2806/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f8c3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2806/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules, conditions, guidelines, and characteristics for the geospatial data within the National Geospatial Data Asset data theme and related processes, technology, and organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f8c4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2806/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" content standards for metadata for geospatial data within the National Geospatial Data Asset data theme;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f8c5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2806/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, shall be consistent with international standards and protocols;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f8c6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2806/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include universal data standards that shall be acceptable for the purposes of declassified intelligence community data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f8c7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2806/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee shall periodically review and update as necessary for the standards to remain current, relevant, and effective.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f8c8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2806/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95f8c9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2806/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop and promulgate standards under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f8ca-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2806/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with Office of Management and Budget Circular A–119, or any successor thereto; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f8cb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2806/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after consultation with a broad range of data users and providers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f8cc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2806/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent possible, use national and international standards adopted by voluntary standards consensus bodies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f8cd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2806/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish new standards only to the extent standards described in paragraph (2) do not exist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f8ce-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2806/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall withhold from public disclosure any information the disclosure of which reasonably could be expected to cause damage to the national interest, security, or defense of the United States, including information relating to geospatial intelligence data activities, as determined in consultation with the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca95f8cf-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tVII/s757"},"text":"Pub. L. 115–254, div. B, title VII, § 757","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3423"},"text":"132 Stat. 3423","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca95f8d0-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca95f8d1-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca95f8d2-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 216 of the E-Government Act of 2002, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347/s216"},"text":"section 216 of Pub. L. 107–347","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3501"},"text":"section 3501 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
