{"tag":"section","attrib":{"id":"idc9d73c00-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s400"},"text":null,"children":[{"tag":"num","attrib":{"value":"400"},"text":"§ 400.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advances as item of cost of construction and maintenance of project","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All money placed to the credit of the reclamation fund in pursuance of sections 397 and 398 to 400, of this title shall be devoted exclusively to the completion of work on reclamation projects begun prior to ","children":[{"tag":"date","attrib":{"date":"1910-06-25"},"text":"June 25, 1910","children":[],"tail":", as hereinbefore provided, and the same shall be included with all other expenses in future estimates of construction, operation, or maintenance."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9d73c01-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1910-06-25/ch407/s4"},"text":"June 25, 1910, ch. 407, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/836"},"text":"36 Stat. 836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d73c02-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d73c03-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9d73c04-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s399"},"text":"Section 399 of this title","children":[],"tail":", included within reference in text to sections 398 to 400, was omitted from the Code. See "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s391a–1"},"text":"section 391a–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9d73c05-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of first clause of section 4 of act ","children":[{"tag":"date","attrib":{"date":"1910-06-25"},"text":"June 25, 1910","children":[],"tail":". Second clause of such section 4 is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s413"},"text":"section 413 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
