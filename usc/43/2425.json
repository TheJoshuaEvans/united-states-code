{"tag":"section","attrib":{"id":"idca913d22-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2425"},"text":null,"children":[{"tag":"num","attrib":{"value":"2425"},"text":"§ 2425.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operations, maintenance, and replacement costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca913d23-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2425/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of operations, maintenance, and replacement costs for a project receiving Federal assistance under this subchapter shall be 100 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913d24-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2425/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On request of the non-Federal borrower, the Secretary may assist in the development of an operation, maintenance, and replacement plan to provide the necessary framework to assist the non-Federal borrower in establishing rates and fees for project beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca913d25-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/451/tII/s206"},"text":"Pub. L. 109–451, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3360"},"text":"120 Stat. 3360","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
