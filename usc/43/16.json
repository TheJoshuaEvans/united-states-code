{"tag":"section","attrib":{"id":"idc9a52ee5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"§ 16.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Engrossing and recording patents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The engrossing and recording of patents for public lands may be done by means of typewriters or other machines, under regulations to be made by the Secretary of the Interior and approved by the President.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9a52ee6-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-03-02/ch177/s3"},"text":"Mar. 2, 1895, ch. 177, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/807"},"text":"28 Stat. 807","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
