{"tag":"section","attrib":{"id":"idca390b50-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1473a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1473a"},"text":"§ 1473a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of contributions by Secretary; cooperation with prosecution of projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to accept lands, buildings, equipment, other contributions and, before, on, and after ","children":[{"tag":"date","attrib":{"date":"1991-11-13"},"text":"November 13, 1991","children":[],"tail":", fees to be deposited in the contributed funds account from public and private sources, and to prosecute projects using such contributions and fees in cooperation with other Federal, State or private agencies."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca390b51-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/154/tI"},"text":"Pub. L. 102–154, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-13"},"text":"Nov. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1002"},"text":"105 Stat. 1002","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca390b52-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca390b53-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca390b54-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Text of section is based