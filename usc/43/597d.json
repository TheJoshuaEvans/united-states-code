{"tag":"section","attrib":{"id":"idc9f3eb11-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s597d"},"text":null,"children":[{"tag":"num","attrib":{"value":"597d"},"text":"§ 597d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to perform any and all acts and to prescribe such regulations as may be necessary to carry out the provisions of sections 597a to 597d of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9f3eb12-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-03-14/ch51/s4"},"text":"Mar. 14, 1940, ch. 51, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/49"},"text":"54 Stat. 49","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
