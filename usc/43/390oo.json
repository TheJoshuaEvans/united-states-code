{"tag":"section","attrib":{"id":"idc9d4cb68-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390oo"},"text":null,"children":[{"tag":"num","attrib":{"value":"390oo"},"text":"§ 390oo.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary supplies of water","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d4cb69-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390oo/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations inapplicable","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Neither the ownership limitations of this subchapter nor the ownership limitations of any other provision of Federal reclamation law shall apply to lands which receive only a temporary, not to exceed one year, supply of water made possible as a result of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9d4cb6a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390oo/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an unusually large water supply not otherwise storable for project purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9d4cb6b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390oo/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" infrequent and otherwise unmanaged flood flows of short duration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d4cb6c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390oo/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of payment for temporary water supplies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall have the authority to waive payments for a supply of water described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d4cb6d-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/293/tII/s215"},"text":"Pub. L. 97–293, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1270"},"text":"96 Stat. 1270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d4cb6e-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d4cb6f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9d4cb70-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Federal reclamation law, referred to in subsec. (a), is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390aa"},"text":"section 390aa of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
