{"tag":"section","attrib":{"id":"idca3b54dd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1476a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1476a"},"text":"§ 1476a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unsworn written statements subject to penalties of presenting false claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Unsworn written statements made in public land matters within the jurisdiction of the Department of the Interior shall remain subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1001"},"text":"section 1001 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca3b54de-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-03/ch392/s2"},"text":"June 3, 1948, ch. 392, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/301"},"text":"62 Stat. 301","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca3b54df-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca3b54e0-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca3b54e1-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1212"},"text":"section 1212 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1001"},"text":"Section 1001 of title 18","children":[],"tail":"” substituted in text for “section 35(A) of the Criminal Code ("},{"tag":"ref","attrib":{"href":"/us/stat/35/1095"},"text":"35 Stat. 1095","children":[],"tail":", 18 U.S.C. sec. 80), as amended” on authority of "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"act June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/683"},"text":"62 Stat. 683","children":[],"tail":", the first section of which enacted Title 18, Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca3b54e2-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca3b54e3-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exemption of Department of the Interior From Restrictions on Notary Public","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-03/ch392/s3"},"text":"Act June 3, 1948, ch. 392, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/301"},"text":"62 Stat. 301","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1948-06-03/ch392/s3"},"text":"“That part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/s558"},"text":"section 558 of the Act of March 3, 1901","children":[],"tail":", entitled ‘An Act to establish a code of law for the District of Columbia’ ("},{"tag":"ref","attrib":{"href":"/us/stat/31/1279"},"text":"31 Stat. 1279","children":[],"tail":"), as amended "},{"tag":"date","attrib":{"date":"1944-12-15"},"text":"December 15, 1944","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/58/810"},"text":"58 Stat. 810","children":[],"tail":", D.C. Code, 1951 edition, sec. 1–501 [now sec. 1–1201(a)]), which reads as follows: "},{"tag":"i","attrib":{},"text":"‘And provided further","children":[],"tail":", That no notary public shall be authorized to take acknowledgments, administer oaths, certify papers, or perform any official acts in connection with matters in which he is employed as counsel, attorney or agent or in which he may be in any way interested before any of the Departments aforesaid’ shall not apply to matters before the Department of the Interior.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
