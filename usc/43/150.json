{"tag":"section","attrib":{"id":"idc9b5d131-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s150"},"text":null,"children":[{"tag":"num","attrib":{"value":"150"},"text":"§ 150.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawals of land for Indian reservations prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No public lands of the United States shall be withdrawn by Executive Order, proclamation, or otherwise, for or as an Indian reservation except by act of Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9b5d132-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1919-06-30/ch4/s27"},"text":"June 30, 1919, ch. 4, § 27","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/34"},"text":"41 Stat. 34","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
