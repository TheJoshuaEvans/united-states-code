{"tag":"section","attrib":{"id":"idca1a1188-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s971b"},"text":null,"children":[{"tag":"num","attrib":{"value":"971b"},"text":"§ 971b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of restored Alaskan lands; preference rights; consent of Federal agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may sell such restored lands for not less than their appraised value, giving an appropriate preference right to the holders of adjoining claims or entries and to owners of adjoining private lands. If such lands are under the jurisdiction of a Federal department or agency other than the Department of the Interior, any sale thereof shall be made only with the consent of such department or agency.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca1a1189-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch848/s2"},"text":"Aug. 1, 1956, ch. 848, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/898"},"text":"70 Stat. 898","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca1a118a-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca1a118b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca1a118c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s420a"},"text":"section 420a of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
