{"tag":"section","attrib":{"id":"idc9d281f5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–38"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–38"},"text":"§ 390h–38.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Yucaipa Valley regional water supply renewal project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d281f6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–38/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the Yucaipa Valley Water District, may participate in the design, planning, and construction of projects to treat impaired surface water, reclaim and reuse impaired groundwater, and provide brine disposal within the Santa Ana Watershed as described in the report submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390h–4"},"text":"section 390h–4 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d281f7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–38/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of the project described in subsection (a) shall not exceed 25 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d281f8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–38/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided by the Secretary shall not be used for operation or maintenance of the project described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d281f9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–38/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $20,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d281fa-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s1655"},"text":"Pub. L. 102–575, title XVI, § 1655","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tIX/s9114/a"},"text":"Pub. L. 111–11, title IX, § 9114(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1320"},"text":"123 Stat. 1320","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
