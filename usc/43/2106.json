{"tag":"section","attrib":{"id":"idca8a10f6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2106"},"text":null,"children":[{"tag":"num","attrib":{"value":"2106"},"text":"§ 2106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8a10f7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law of salvage and law of finds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The law of salvage and the law of finds shall not apply to abandoned shipwrecks to which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2105"},"text":"section 2105 of this title","children":[],"tail":" applies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a10f8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laws of United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter shall not change the laws of the United States relating to shipwrecks, other than those to which this chapter applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a10f9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter shall not affect any legal proceeding brought prior to ","children":[{"