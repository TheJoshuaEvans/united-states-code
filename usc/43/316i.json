{"tag":"section","attrib":{"id":"idc9bf6e84-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316i"},"text":null,"children":[{"tag":"num","attrib":{"value":"316i"},"text":"§ 316i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment of leases","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The lessee may, with the approval of the Secretary, assign in whole or in part any lease, and to the extent of such assignment be relieved from any liability in respect of such lease, accruing subsequent to the effective date of such assignment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9bf6e85-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch513/s10"},"text":"Mar. 4, 1927, ch. 513, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1453"},"text":"44 Stat. 1453","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9bf6e86-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9bf6e87-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9bf6e88-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s471i"},"text":"section 471i of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
