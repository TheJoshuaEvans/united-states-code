{"tag":"section","attrib":{"id":"idca1a117a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s970"},"text":null,"children":[{"tag":"num","attrib":{"value":"970"},"text":"§ 970.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture of Arkansas pipeline right of way for violation of antitrust law","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any citizen, company, or corporation taking advantage of the benefits of sections 966 to 970 of this title shall violate the Act of ","children":[{"tag":"date","attrib":{"date":"1890-07-02"},"text":"July 2, 1890","children":[],"tail":", entitled “An Act to protect trade and commerce against unlawful restraints and monopolies”, (commonly known as the Sherman antitrust act), or any amendment thereof, the right of way granted in sections 966 to 970 of this title shall be forfeited without further action or declaration on the part of the Government or any proceedings or judgment of any court."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca1a117b-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1910-04-12/ch155/s5"},"text":"Apr. 12, 1910, ch. 155, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/296"},"text":"36 Stat. 296","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca1a117c-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca1a117d-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca1a117e-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","chil