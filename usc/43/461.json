{"tag":"section","attrib":{"id":"idc9e3230c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s461"},"text":null,"children":[{"tag":"num","attrib":{"value":"461"},"text":"§ 461.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of construction charges generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The construction charges which shall be made per acre upon the entries and upon lands in private ownership which may be irrigated by the waters of any irrigation project shall be determined with a view of returning to the reclamation fund the estimated cost of construction of the project, and shall be apportioned equitably.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9e3230d-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-06-17/ch1093/s4"},"text":"June 17, 1902, ch. 1093, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/389"},"text":"32 Stat. 389","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9e3230e-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9e3230f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9e32310-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of part of section 4 of act ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":". Remainder of such section 4 is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s419"},"text":"section 419 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9e32311-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9e32312-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Section as Unaffected by Submerged Lands Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of this section as not amended, modified or repealed by the Submerged Lands Act, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1303"},"text":"section 1303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
