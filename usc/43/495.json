{"tag":"section","attrib":{"id":"idc9ea4f1a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s495"},"text":null,"children":[{"tag":"num","attrib":{"value":"495"},"text":"§ 495.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shutting off water for nonpayment of operation charge","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No water shall be delivered to the lands of any water-right applicant or entryman who shall be in arrears for more than one calendar year for the payment of any charge for operation and maintenance.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9ea4f1b-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-08-13/ch247/s6"},"text":"Aug. 13, 1914, ch. 247, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/688"},"text":"38 Stat. 688","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9ea4f1c-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9ea4f1d-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9ea4f1e-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of part of first sentence of section 6 of act ","children":[{"tag":"date","attrib":{"date":"1914-08-13"},"text":"Aug. 13, 1914","children":[],"tail":". Remainder of first sentence of such section 6 is classified to sections 479, 493 and 494 of this title; second and third sentences of such section 6 are classified to sections 496 and 497 of this title, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
