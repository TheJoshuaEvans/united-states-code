{"tag":"section","attrib":{"id":"idca1c5b29-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1064"},"text":null,"children":[{"tag":"num","attrib":{"value":"1064"},"text":"§ 1064.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations of chapter; punishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person violating any of the provisions of this chapter, whether as owner, part owner, or agent, or who shall aid, abet, counsel, advise, or assist in any violation hereof, shall be deemed guilty of a misdemeanor and fined in a sum not exceeding $1,000, or be imprisoned not exceeding one year, or both, for each offense.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca1c5b2a-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1885-02-25/ch149/s4"},"text":"Feb. 25, 1885, ch. 149, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/23/322"},"text":"23 Stat. 322","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1908-03-10/ch75"},"text":"Mar. 10, 1908, ch. 75","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/40"},"text":"35 Stat. 40","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
