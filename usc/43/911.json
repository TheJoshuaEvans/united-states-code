{"tag":"section","attrib":{"id":"idca12e53b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s911"},"text":null,"children":[{"tag":"num","attrib":{"value":"911"},"text":"§ 911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall prescribe such rules and regulations as will be necessary to the carrying out of the provisions of sections 908 to 910 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca12e53c-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1910-06-25/ch406/s4"},"text":"June 25, 1910, ch. 406, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/835"},"text":"36 Stat. 835","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
