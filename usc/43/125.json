{"tag":"section","attrib":{"id":"idc9b387ea-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s125"},"text":null,"children":[{"tag":"num","attrib":{"value":"125"},"text":"§ 125.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annexation of discontinued district to adjacent district","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever the cost of collecting the revenue from the sales of the public lands in any land district is as much as one-third of the whole amount of revenue collected in such district, it may be lawful for the President, if, in his opinion, not incompatible with the public interest, to discontinue the land office in such district, and to annex the same to some other adjoining land district.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9b387eb-3a70-11f1-bde1-a5140e158598"},"text":"(R.S. § 2250.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9b387ec-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9b387ed-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9b387ee-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2250 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1853-03-03/ch97/s1"},"text":"act Mar. 3, 1853, ch. 97, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/10/189"},"text":"10 Stat. 189","children":[],"tail":", 194."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idc9b387ef-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"idc9b387f0-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation to Secretary of the Interior of authority vested in President by this section, see Ex. Ord. No. 10250, ","children":[{"tag":"date","attrib":{"date":"1951-06-05"},"text":"June 5, 1951","children":[],"tail":", 16 F.R. 5385, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
