{"tag":"section","attrib":{"id":"idca17a04c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s962"},"text":null,"children":[{"tag":"num","attrib":{"value":"962"},"text":"§ 962.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of way in Colorado and Wyoming to pipeline companies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The right of way through the public lands of the United States situate in the State of Colorado and in the State of Wyoming outside of the boundary lines of the Yellowstone National Park is granted to any pipe-line company or corporation formed for the purpose of transporting oils, crude or refined, which shall have filed or may hereafter file with the Secretary of the Interior a copy of its articles of incorporation, and due proofs of its organization under the same, to the extent of the ground occupied by said pipe line and twenty-five feet on each side of the center line of the same; also the right to take from the public lands adjacent to the line of said pipe line, material, earth, and stone necessary for the construction of said pipe line.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca17a04d-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1896-05-21/ch212/s1"},"text":"May 21, 1896, ch. 212, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/29/127"},"text":"29 Stat. 127","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca17a04e-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca17a04f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idca17a050-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 962 to 965 of this title are popularly known as the “Oil Pipe Line Act”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca17a051-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca17a052-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal; Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579/tVII/s706/a"},"text":"Pub. L. 94–579, title VII, § 706(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2793"},"text":"90 Stat. 2793","children":[],"tail":", effective on and after "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", insofar as applicable to the issuance of rights-of-way over, upon, under, and through the public lands and lands in the National Forest System. Such repeal not to be construed as terminating any valid lease, permit, patent, etc., existing on "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/579/s701"},"text":"section 701 of Pub. L. 94–579","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
