{"tag":"section","attrib":{"id":"idca06fe2c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s665"},"text":null,"children":[{"tag":"num","attrib":{"value":"665"},"text":"§ 665.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of way over reservoir sites for wagon road, railroad, or other highway","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the form provided by existing law, the Secretary of the Interior may file and approve surveys and plats of any right of way for a wagon road, railroad, or other highway over and across any reservoir site when in his judgment the public interests will not be injuriously affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca06fe2d-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1899-03-03/ch427/s1"},"text":"Mar. 3, 1899, ch. 427, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/1233"},"text":"30 Stat. 1233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca06fe2e-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca06fe2f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca06fe30-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal; Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579/tVII/s706/a"},"text":"Pub. L. 94–579, title VII, § 706(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2793"},"text":"90 Stat. 2793","children":[],"tail":", effective on and after "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", insofar as applicable to the issuance of rights-of-way over, under, and through the public lands and lands in the National Forest Systems. Such repeal not to be construed as terminating any valid lease, permit, patent, etc., existing on "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/579/s701"},"text":"section 701 of Pub. L. 94–579","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
