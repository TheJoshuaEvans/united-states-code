{"tag":"section","attrib":{"id":"idca9d2400-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3208"},"text":null,"children":[{"tag":"num","attrib":{"value":"3208"},"text":"§ 3208.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal assistance for groundwater recharge, aquifer storage, and water source substitution projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca9d2401-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3208/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, at the request of and in coordination with affected Indian Tribes, States (including subdivisions and departments of a State), or a public agency organized pursuant to State law, may provide technical or financial assistance for, participate in, and enter into agreements (including agreements with irrigation entities) for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9d2402-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3208/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" groundwater recharge projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9d2403-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3208/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aquifer storage and recovery projects; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9d2404-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3208/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water source substitution for aquifer protection projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9d2405-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3208/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section authorizes additional technical or financial assistance for, or participation in an agreement for, a surface water storage facility to be constructed or expanded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9d2406-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3208/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A construction project shall only be eligible for financial assistance under this section if the project meets the conditions for funding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s3202/a/2/C/ii"},"text":"section 3202(a)(2)(C)(ii) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9d2407-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3208/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Cost sharing for a project funded under this section shall be in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s3202/b"},"text":"section 3202(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9d2408-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3208/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing funding for a project under this section, the Secretary shall comply with all applicable environmental laws, including —","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9d2409-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3208/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9d240a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3208/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any obligations for fish, wildlife, or water quality protection in permits or licenses granted by a Federal agency or a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9d240b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3208/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any applicable Federal or State laws (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9d240c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3208/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization by Congress for major project construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project with a total estimated cost of $500,000,000 or more shall only be eligible for construction funding under this section if the project is authorized for construction by an Act of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca9d240d-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIX/s40910"},"text":"Pub. L. 117–58, div. D, title IX, § 40910","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1126"},"text":"135 Stat. 1126","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca9d240e-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca9d240f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca9d2410-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (e)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca9d2411-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca9d2412-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
