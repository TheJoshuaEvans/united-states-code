{"tag":"section","attrib":{"id":"idca31ded1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1356c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1356c"},"text":"§ 1356c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wind lease sales for areas of the outer Continental Shelf offshore of territories of the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca31ded2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1356c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002085"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002085"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. There is no subsec. (b)."}],"tail":" Wind lease sales off coasts of territories of the United States"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca31ded3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1356c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Call for information and nominations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca31ded4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1356c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue calls for information and nominations for proposed wind lease sales for areas of the outer Continental Shelf described in paragraph (2) that are determined to be feasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca31ded5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1356c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial call","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":", the Secretary shall issue an initial call for information and nominations under this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca31ded6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1356c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditional wind lease sales","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may conduct wind lease sales in each area within the exclusive economic zone of the United States adjacent to the Commonwealth of Puerto Rico, Guam, American Samoa, the United States Virgin Islands, or the Commonwealth of the Northern Mariana Islands that meets each of the following criteria:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca31ded7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1356c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary has concluded that a wind lease sale in the area is feasible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca31ded8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1356c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary has determined that there is sufficient interest in leasing the area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca31ded9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1356c/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary has consulted with the Governor of the territory regarding the suitability of the area for wind energy development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca31deda-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1953-08-07/ch345/s33"},"text":"Aug. 7, 1953, ch. 345, § 33","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/169/tV/s50251/b/2"},"text":"Pub. L. 117–169, title V, § 50251(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2055"},"text":"136 Stat. 2055","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
