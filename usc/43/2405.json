{"tag":"section","attrib":{"id":"idca8ecc77-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405"},"text":null,"children":[{"tag":"num","attrib":{"value":"2405"},"text":"§ 2405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasibility studies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8ecc78-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On completion of an appraisal report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2404/c"},"text":"section 2404(c) of this title","children":[],"tail":" that recommends undertaking a feasibility study and subject to the availability of appropriations, the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8ecc79-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with a non-Federal project entity, carry out a study to determine the feasibility of the proposed rural water supply project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc7a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" receive and review a feasibility study that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8ecc7b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developed by the non-Federal project entity, with or without support from the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecc7c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitted to the Secretary by the non-Federal project entity; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc7d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8ecc7e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide a grant to, or enter into a cooperative agreement with, a non-Federal project entity to conduct a feasibility study, for submission to the Secretary, if the Secretary determines that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca8ecc7f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the non-Federal entity is qualified to complete the feasibility study in accordance with the criteria promulgated under subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8ecc80-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using the non-Federal project entity to conduct the feasibility study is a cost-effective alternative for completing the appraisal investigation; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecc81-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary determines not to provide a grant to, or enter into a cooperative agreement with, a non-Federal project entity under subparagraph (A), provide to the non-Federal project entity notice of the determination, including an explanation of the reason for the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8ecc82-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of non-Federal feasibility studies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8ecc83-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting a review of a feasibility study submitted under paragraph (2) or (3) of subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8ecc84-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with the feasibility factors described in subsection (c) and the criteria promulgated under subsection (d), assess the completeness of the feasibility study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecc85-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary determines that a feasibility study is not complete, notify the non-Federal entity of the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc86-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines under paragraph (1)(B) that a feasibility study is not complete, the non-Federal entity shall pay any costs associated with revising the feasibility study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8ecc87-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasibility factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Feasibility studies authorized or reviewed under this subchapter shall include an assessment of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8ecc88-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" near- and long-term water demand in the area to be served by the rural water supply project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc89-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advancement of public health and safety of any existing rural water supply project and other benefits of the proposed rural water supply project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc8a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative new water supplies in the study area, including any opportunities to treat and use low-quality water, nonpotable water, water reuse-based supplies, and brackish and saline waters through innovative and economically viable treatment technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc8b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental quality and source water protection issues related to the rural water supply project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc8c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" innovative opportunities for water conservation in the study area to reduce water use and water system costs, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8ecc8d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonstructural approaches to reduce the need for the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecc8e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstration technologies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc8f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the project and alternatives take advantage of economic incentives and the use of market-based mechanisms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc90-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8ecc91-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction costs and projected operations, maintenance, and replacement costs of all alternatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecc92-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic feasibility and lowest cost method of obtaining the desired results of each alternative, taking into account the Federal cost-share;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc93-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of guaranteed loans for a proposed rural water supply project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc94-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial capability of the non-Federal project entity to pay the non-Federal project entity’s proportionate share of the design and construction costs and 100 percent of operations, maintenance, and replacement costs, including the allocation of costs to each non-Federal project entity in the case of multiple entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc95-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the non-Federal project entity has developed an operations, management, and replacement plan to assist the non-Federal project entity in establishing rates and fees for beneficiaries of the rural water supply project that includes a schedule identifying the annual operations, maintenance, and replacement costs that should be allocated to each non-Federal entity participating in the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc96-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8ecc97-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the non-Federal project entity administrative organization that would implement construction, operations, maintenance, and replacement activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecc98-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fiscal, administrative, and operational controls to be implemented to manage the project;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc99-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which assistance for rural water supply is available under other Federal authorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc9a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the engineering, environmental, and economic activities to be undertaken to carry out the proposed rural water supply project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc9b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the project involves partnerships with other State, local, or tribal governments or Federal entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc9c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/c/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project intended for Indian tribes and tribal organizations, the extent to which the project addresses the goal of economic self-sufficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8ecc9d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasibility study criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8ecc9e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2006-12-22"},"text":"December 22, 2006","children":[],"tail":", the Secretary shall promulgate criteria (including the feasibility factors listed under subsection (c)) under which the feasibility studies shall be assessed for completeness and appropriateness."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc9f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall include in the criteria promulgated under paragraph (1) methods to scale the level of effort needed to complete the feasibility assessment relative to the total size and cost of the proposed rural water supply project and reduce total costs to non-Federal entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8ecca0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasibility report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8ecca1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002178"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002178"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" In general"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"After completion of appropriate feasibility studies for rural water supply projects that address the factors described in subsection (c) and the criteria promulgated under subsection (d), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8ecca2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop a feasibility report that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca8ecca3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a recommendation of the Secretary on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca8ecca4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/e/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the rural water supply project should be authorized for construction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca8ecca5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/e/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the appropriate non-Federal share of construction costs, which shall be—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idca8ecca6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/e/1/A/i/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 25 percent of the total construction costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idca8ecca7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/e/1/A/i/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined based on an analysis of the capability-to-pay information considered under subsections (c)(9) and (f); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8ecca8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the Secretary recommends that the project should be authorized for construction—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca8ecca9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/e/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" what amount of grants, loan guarantees, or combination of grants and loan guarantees should be used to provide the Federal cost share;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca8eccaa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/e/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a schedule that identifies the annual operations, maintenance, and replacement costs that should be allocated to each non-Federal entity participating in the rural water supply project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca8eccab-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/e/1/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the financial capability of each non-Federal entity participating in the rural water supply project to pay the allocated annual operation, maintenance, and replacement costs for the rural water supply project;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8eccac-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit the report to the Committee on Energy and Natural Resources of the Senate and the Committee on Resources of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8eccad-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the report publicly available, along with associated study documents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8eccae-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish in the Federal Register a notice of the availability of the results.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8eccaf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capability-to-pay","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8eccb0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating a proposed rural water supply project under this section, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8eccb1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the financial capability of any non-Federal project entities participating in the rural water supply project to pay 25 percent or more of the capital construction costs of the rural water supply project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8eccb2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend an appropriate Federal share and non-Federal share of the capital construction costs, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8eccb3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the financial capability of non-Federal project entities to pay for a rural water supply project under paragraph (1), the Secretary shall evaluate factors for the project area, relative to the State average, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8eccb4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" per capita income;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8eccb5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" median household income;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8eccb6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the poverty rate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8eccb7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the non-Federal project entity to raise tax revenues or assess fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8eccb8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strength of the balance sheet of the non-Federal project entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8eccb9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/f/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the existing cost of water in the region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8eccba-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the capability-to-pay of Indian tribe project beneficiaries, the Secretary may consider deferring the collection of all or part of the non-Federal construction costs apportioned to Indian tribe project beneficiaries unless or until the Secretary determines that the Indian tribe project beneficiaries should pay—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca913cbb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs allocated to the beneficiaries; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca913cbc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appropriate portion of the costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913cbd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca913cbe-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subsection, the Federal share of the cost of a feasibility study carried out under this section shall not exceed 50 percent of the study costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913cbf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share under paragraph (1) may be in the form of any in-kind services that the Secretary determines would contribute substantially toward the conduct and completion of the study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913cc0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial hardship","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may increase the Federal share of the costs of a feasibility study if the Secretary determines, based on a demonstration of financial hardship, that the non-Federal participant is unable to contribute at least 50 percent of the costs of the study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913cc1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Larger communities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting a feasibility study of a rural water supply system that includes a community with a population in excess of 50,000 inhabitants, the Secretary may require the non-Federal project entity to pay more than 50 percent of the costs of the study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913cc2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2405/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the non-Federal project entity, the Secretary shall consult and cooperate with appropriate Federal, State, tribal, regional, and local authorities during the conduct of each feasibility assessment and development of the feasibility report conducted under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca913cc3-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/451/tI/s106"},"text":"Pub. L. 109–451, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3351"},"text":"120 Stat. 3351","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
