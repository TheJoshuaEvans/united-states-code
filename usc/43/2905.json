{"tag":"section","attrib":{"id":"idca95f967-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2905"},"text":null,"children":[{"tag":"num","attrib":{"value":"2905"},"text":"§ 2905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca95f968-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective on the date of conveyance of any eligible facility under this chapter, the United States shall not be held liable by any court for damages of any kind arising out of any act, omission, or occurrence relating to the eligible facility, other than damages caused by acts of negligence committed by the United States or by agents or employees of the United States prior to the date of the conveyance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f969-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section increases the liability of the United States beyond that currently provided in chapter 171 of title 28 (commonly known as the “Federal Tort Claims Act”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca95f96a-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tVIII/s8005"},"text":"Pub. L. 116–9, title VIII, § 8005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/808"},"text":"133 Stat. 808","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
