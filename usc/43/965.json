{"tag":"section","attrib":{"id":"idca17a05f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s965"},"text":null,"children":[{"tag":"num","attrib":{"value":"965"},"text":"§ 965.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on use of Colorado and Wyoming pipeline right of way","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in sections 962 to 965 of this title shall authorize the use of such right of way except for the pipe line, and then only so far as may be necessary for its construction, maintenance, and care.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca17a060-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1896-05-21/ch212/s4"},"text":"May 21, 1896, ch. 212, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/29/127"},"text":"29 Stat. 127","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca17a061-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca17a062-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca17a063-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal; Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579/tVII/s706/a"},"text":"Pub. L. 94–579, title VII, § 706(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2793"},"text":"90 Stat. 2793","children":[],"tail":", effective on and after "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", insofar as applicable to the issuance of rights-of-way over, upon, under, and through the public lands and lands in the National Forest System. Such repeal not to be construed as terminating any valid lease, permit, patent, etc., existing on "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/579/s701"},"text":"section 701 of Pub. L. 94–579","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
