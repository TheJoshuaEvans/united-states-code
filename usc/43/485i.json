{"tag":"section","attrib":{"id":"idc9e7dded-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s485i"},"text":null,"children":[{"tag":"num","attrib":{"value":"485i"},"text":"§ 485i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to perform any and all acts and to make such rules and regulations as may be necessary and proper for the purpose of carrying the provisions of this subchapter into full force and effect.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9e7ddee-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-04/ch418/s15"},"text":"Aug. 4, 1939, ch. 418, § 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1198"},"text":"53 Stat. 1198","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
