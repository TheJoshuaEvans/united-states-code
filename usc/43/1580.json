{"tag":"section","attrib":{"id":"idca428169-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1580"},"text":null,"children":[{"tag":"num","attrib":{"value":"1580"},"text":"§ 1580.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter:","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca42816a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1580/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Navajo Generating Station means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca42816b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1580/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States entitlement to a portion of the output of power and energy from the Navajo Generating Station, Page, Arizona, pursuant to United States participation in that generating station;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca42816c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1580/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the event that said United States entitlement is integrated with other generating facilities, then Navajo Generating Station means that amount of power and energy from the integrated system which is attributable to the United States Navajo entitlement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca42816d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1580/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the Navajo Generating Station is replaced at the end of its useful life or an alternative resource is established, then Navajo Generating Station means an amount of power and energy equivalent to the present United States entitlement from Navajo, from the replacement resource.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca42816e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1580/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All terms used herein that are defined in the Colorado River Compact shall have the meanings therein defined.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca42816f-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/320/tI/s111"},"text":"Pub. L. 93–320, title I, § 111","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/336/s7"},"text":"Pub. L. 96–336, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-04"},"text":"Sept. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1065"},"text":"94 Stat. 1065","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
