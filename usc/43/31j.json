{"tag":"section","attrib":{"id":"idc9a9ead7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31j"},"text":null,"children":[{"tag":"num","attrib":{"value":"31j"},"text":"§ 31j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biological research activity of Survey; review and report by National Academy of Sciences","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Beginning in fiscal year 1998 and once every five years thereafter, the National Academy of Sciences shall review and report on the biological research activity of the Survey.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9a9ead8-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/d/tI"},"text":"Pub. L. 104–208, div. A, title I, § 101(d) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-181"},"text":"110 Stat. 3009–181","children":[],"tail":", 3009–189.)"}],"tail":"\n"}],"tail":null}
