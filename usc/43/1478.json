{"tag":"section","attrib":{"id":"idca3b550a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478"},"text":null,"children":[{"tag":"num","attrib":{"value":"1478"},"text":"§ 1478.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appraisal and valuation services for real property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca3b550b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" License, certification requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A covered appraiser needs to be licensed or certified in only 1 State to perform appraisal or valuation services for real property in any State for a transaction over which the Secretary has jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca3b550c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of non-Federal covered appraisers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary uses a non-Federal covered appraiser to perform appraisal or valuation services for real property for a transaction described in subsection (a), the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca3b550d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, to the maximum extent practicable, use a non-Federal covered appraiser who is a certified general real property appraiser licensed in a State in which the real property that is the subject of the transaction is located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca3b550e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may only use a non-Federal covered appraiser who is a certified general real property appraiser licensed in a State other than one in which the real property that is the subject of the transaction is located if a non-Federal covered appraiser described in paragraph (1) is, as determined by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca3b550f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unavailable to complete an assignment within a reasonable period of time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca3b5510-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not assignment qualified; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca3b5511-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not cost competitive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca3b5512-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", and annually thereafter for at least the following 4 years, the Secretary shall submit to Congress a report that includes the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca3b5513-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A comparison using quantitative data of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca3b5514-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of requests for appraisal and valuation services received by the Department during the reporting period and the number of requests for such services received by the Department in each of the 5 years before the reporting period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca3b5515-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of time required for the Department to complete a request for appraisal or valuation services before ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", and after "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca3b5516-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A qualitative assessment of the impact of subsection (a) in providing flexibility to the Secretary when contracting with non-Federal covered appraisers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca3b5517-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations, if any, for congressional action that could help the Department operate more efficiently or overcome challenges with respect to timely completion of requests for appraisal or valuation services while ensuring the independence, impartiality, and objectivity of such services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca3b5518-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An overview of the workforce of the Department with regard to appraisal and valuation services provided by the Department, including hiring and staffing during the reporting period with respect to employees and contractors of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca3b5519-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A complete list of cases in which the authority granted under this section was used during the reporting period, describing for each case the specific criteria used to satisfy the conditions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca3b551a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statutory clarifications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca3b551b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of relevant laws and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3), nothing in this section shall be interpreted to affect the application of any Federal or State law or regulation to a non-Federal covered appraiser with regard to the performance by such non-Federal covered appraiser of appraisal and valuation services for real property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca3b551c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be interpreted to authorize a non-Federal covered appraiser to perform appraisal and valuation services for real property in a State in which such non-Federal covered appraiser is not licensed or certified to perform such services except to the extent that such services are performed for a transaction over which the Secretary has jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca3b551d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of certain relevant laws and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any provision of a Federal or State law or regulation enacted before ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", that requires a covered appraiser to be licensed or certified in a specific State to perform appraisal or valuation services for real property in that State shall not apply to any transaction over which the Secretary has jurisdiction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca3b551e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the text of all policies (including any successor policies), including reference manuals, guidance documents, handbooks, standard operating procedures, and statements of policy specific to the scoping, contracting, and review of appraisals performed for the Department by Federal or non-Federal covered appraisers, shall be made publicly available online and provided upon request."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca3b551f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca3b5520-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered appraiser","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered appraiser” means a State-licensed or -certified real property appraiser.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca3b5521-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca3b5522-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “reporting period” means the 1-year period before the date on which a report is submitted under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca3b5523-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca3b5524-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1478/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States, the District of Columbia, and each territory and possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca3b5525-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/230/s2"},"text":"Pub. L. 118–230, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2826"},"text":"138 Stat. 2826","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
