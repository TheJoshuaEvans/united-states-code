{"tag":"section","attrib":{"id":"idc9faf093-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s618a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"618a–1"},"text":"§ 618a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of Colorado River Development Fund for investigation and construction purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The availability of appropriations from the Colorado River Development Fund for the investigation and construction of projects in any of the States of the Colorado River Basin shall not be held to forbid the expenditure of other funds for those purposes in any of those States where such funds are otherwise available therefor.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9faf094-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-01/ch364/s2"},"text":"June 1, 1948, ch. 364, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/285"},"text":"62 Stat. 285","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9faf095-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9faf096-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9faf097-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Boulder Canyon Project Adjustment Act which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
