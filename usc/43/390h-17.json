{"tag":"section","attrib":{"id":"idc9d28157-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–17"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–17"},"text":"§ 390h–17.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lakehaven, Washington, Water Reclamation and Reuse Project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d28158-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–17/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the Lakehaven Utility District, Washington, is authorized to participate in the design, planning, and construction of, and land acquisition for, a project to reclaim and reuse wastewater, including degraded groundwaters, within and outside of the service area of the Lakehaven Utility District.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d28159-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–17/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of the project authorized by this section shall not exceed 25 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d2815a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–17/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not provide funds for the operation and maintenance of the project authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d2815b-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s1635"},"text":"Pub. L. 102–575, title XVI, § 1635","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/344/s1"},"text":"Pub. L. 107–344, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2893"},"text":"116 Stat. 2893","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
