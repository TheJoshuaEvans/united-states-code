{"tag":"section","attrib":{"id":"idc9fd61db-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s619"},"text":null,"children":[{"tag":"num","attrib":{"value":"619"},"text":"§ 619.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in capacity of existing generating equipment at Hoover Powerplant; construction of Colorado River bridge crossing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9fd61dc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s619/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hoover Powerplant generating equipment; increase in capacity; improvement of appurtenances; authorization of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to increase the capacity of existing generating equipment and appurtenances at Hoover Powerplant (hereinafter in this subchapter referred to as “uprating program”); and to improve parking, visitor facilities, and roadways and to provide additional elevators, and other facilities that will contribute to the safety and sufficiency of visitor access to Hoover Dam and Powerplant (hereinafter in this subchapter referred to as “visitor facilities program”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9fd61dd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s619/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of Colorado River bridge crossing; authorization of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to construct a Colorado River bridge crossing, including suitable approach spans, immediately downstream from Hoover Dam for the purpose of alleviating traffic congestion and reducing safety hazards. This bridge shall not be a part of the Boulder Canyon project and shall neither be funded nor repaid from the Colorado River Dam Fund or the Lower Colorado River Basin Development Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9fd61de-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/381/tI/s101"},"text":"Pub. L. 98–381, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-17"},"text":"Aug. 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1333"},"text":"98 Stat. 1333","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9fd61df-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9fd61e0-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9fd61e1-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/381"},"text":"Pub. L. 98–381","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-17"},"text":"Aug. 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1333"},"text":"98 Stat. 1333","children":[],"tail":", which enacted this subchapter and sections 7274 and 7275 of Title 42, The Public Health and Welfare, and amended sections 617a, 617b, 618, 618a, 618e, 618k, and 1543 of this title. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9fd61e2-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idc9fd61e3-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/72/s1"},"text":"Pub. L. 112–72, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-20"},"text":"Dec. 20, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/777"},"text":"125 Stat. 777","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/72/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s619a"},"text":"section 619a of this title","children":[],"tail":"] may be cited as the ‘Hoover Power Allocation Act of 2011’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idc9fd61e4-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/381/s1"},"text":"Pub. L. 98–381, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-17"},"text":"Aug. 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1333"},"text":"98 Stat. 1333","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/381/s1"},"text":"“This Act [enacting this subchapter, provisions set out as notes under sections 617 and 618 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s839b"},"text":"section 839b of Title 16","children":[],"tail":", Conservation, sections 7274 and 7275 and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7133"},"text":"section 7133 of Title 42","children":[],"tail":", The Public Health and Welfare, and amending sections 617a, 617b, 618, 618a, 618e, 618k, and 1543 of this title] may be cited as the ‘Hoover Power Plant Act of 1984’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9fd61e5-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Hoover Dam Miscellaneous Sales","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/461"},"text":"Pub. L. 106–461","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1989"},"text":"114 Stat. 1989","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/461"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘Hoover Dam Miscellaneous Sales Act’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FINDINGS.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale and distribution of general public information about the use of public land and water areas for recreation, fish, wildlife, and other purposes serve significant public benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publications and other materials educate the public and provide general information about Bureau of Reclamation programs and projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in 1997, more than 1,000,000 visitors, including 300,000 from foreign countries, toured the Hoover Dam;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hundreds of thousands of additional visitors stopped to view the dam;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" visitors often ask to purchase maps, publications, and other items to enhance their experience or serve educational purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in many cases the Bureau of Reclamation is the sole source of those items;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau is in a unique position to fulfill public requests for those items; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a public agency, the Bureau should be responsive to the public by having appropriate items available for sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“SEC. 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PURPOSES.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“The purposes of this Act are—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize the Secretary of the Interior to offer for sale to members of the public that visit the Hoover Dam Visitor Center educational materials and memorabilia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use revenue from those sales to repay the costs relating to construction of the Hoover Dam Visitor Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“SEC. 4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" AUTHORITY TO CONDUCT SALES.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“With respect to the Hoover Dam, the Secretary of the Interior, acting through the Commissioner of Reclamation, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct sales of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" materials generated by the Bureau of Reclamation such as posters, maps, brochures, photographs, and similar publications, videotapes, and computer information discs that are related to programs or projects of the Bureau; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" memorabilia and other commemorative items that depict programs or projects of the Bureau;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convert unneeded property or scrap material into Bureau memorabilia for sale purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enter into agreements with nonprofit organizations, other Federal agencies, State and local governments, and commercial entities for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production or sale of items described in paragraphs (1) and (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale of publications described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“SEC. 5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" COSTS AND REVENUES.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All costs incurred by the Bureau of Reclamation under this Act shall be paid from the Colorado River Dam fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-12-21/s2"},"text":"section 2 of the Act of December 21, 1928","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s617a"},"text":"43 U.S.C. 617a","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revenues.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use for repayment of sales costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All revenues collected by the Bureau of Reclamation under this Act shall be credited to the Colorado River Dam fund to remain available, without further Act of appropriation, to pay costs associated with the production and sale of items in accordance with section 4.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use for repayment of construction costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All revenues collected by the Bureau of Reclamation under this Act that are not needed to pay costs described in paragraph (1) shall be transferred annually to the general fund of the Treasury in repayment of costs relating to construction of the Hoover Dam Visitor Center.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
