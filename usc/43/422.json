{"tag":"section","attrib":{"id":"idc9d9acca-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s422"},"text":null,"children":[{"tag":"num","attrib":{"value":"422"},"text":"§ 422.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of dams across Yellowstone River","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where, in carrying out projects under the provisions of the national reclamation Act it shall be necessary to construct dams in or across the Yellowstone River in the State of Montana, the Secretary of the Interior is hereby authorized to construct and use and operate the same in the manner and for the purposes contemplated by said reclamation Act.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9d9accb-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1905-03-03/ch1476"},"text":"Mar. 3, 1905, ch. 1476","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/33/1045"},"text":"33 Stat. 1045","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d9accc-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d9accd-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9d9acce-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The national reclamation Act, referred to in text, probably means ","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-06-17/ch1093"},"text":"act June 17, 1902, ch. 1093","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/388"},"text":"32 Stat. 388","children":[],"tail":", popularly known as the Reclamation Act, which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
