{"tag":"section","attrib":{"id":"idc9d2810a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–12k"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–12k"},"text":"§ 390h–12k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" City of West Jordan Water Reuse Project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d2810b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–12k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the City of West Jordan, Utah, is authorized to participate in the design, planning, and construction of the City of West Jordan Water Reuse Project to recycle and reuse water in its service area from the South Valley Water Reclamation Facility Discharge Waters in Utah.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d2810c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–12k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of a project described in subsection (a) shall not exceed 25 percent of the total cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d2810d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–12k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not provide funds for the operation or maintenance of a project described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d2810e-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s1625"},"text":"Pub. L. 102–575, title XVI, § 1625","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/266/s2/a/2"},"text":"Pub. L. 104–266, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3293"},"text":"110 Stat. 3293","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
