{"tag":"section","attrib":{"id":"idca665c5c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1639"},"text":null,"children":[{"tag":"num","attrib":{"value":"1639"},"text":"§ 1639.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction with Alaska Native Claims Settlement Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as specifically provided in this Act, (i) the provisions of the Alaska Native Claims Settlement Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.] are fully applicable to this Act, and (ii) nothing in this Act shall be construed to alter or amend any of such provisions."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca665c5d-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487/tXIV/s1412"},"text":"Pub. L. 96–487, title XIV, § 1412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2498"},"text":"94 Stat. 2498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca665c5e-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca665c5f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca665c60-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487"},"text":"Pub. L. 96–487","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2371"},"text":"94 Stat. 2371","children":[],"tail":", known as the Alaska National Interest Lands Conservation Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3101"},"text":"section 3101 of Title 16","children":[],"tail":", Conservation, and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Alaska Native Claims Settlement Act, referred to in cl. (i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203"},"text":"Pub. L. 92–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":", which is classified generally to chapter 33 (§ 1601 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca665c61-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of title IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487"},"text":"Pub. L. 96–487","children":[],"tail":" which comprises this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
