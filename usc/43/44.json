{"tag":"section","attrib":{"id":"idc9aea575-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s44"},"text":null,"children":[{"tag":"num","attrib":{"value":"44"},"text":"§ 44.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of transfers or copies of data","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the United States Geological Survey shall, if the regular map work of the Survey is in no wise interfered with thereby, furnish to any person, concern, institution, State or foreign government, that shall pay in advance the whole cost thereof with 10 per centum added, transfers or copies of any cartographic or other engraved or lithographic data in the division of engraving and printing of the Survey, and the moneys received by the Director for such transfers or copies shall be deposited in the Treasury.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9aea576-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1906-06-30/ch3914"},"text":"June 30, 1906, ch. 3914","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/727"},"text":"34 Stat. 727","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/154/tI"},"text":"Pub. L. 102–154, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-13"},"text":"Nov. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1000"},"text":"105 Stat. 1000","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9aea577-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9aea578-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idc9aea579-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States Geological Survey” substituted in text for “Geological Survey” pursuant to provision of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/154"},"text":"Pub. L. 102–154","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s31"},"text":"section 31 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idc9aea57a-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idc9aea57b-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1451"},"text":"section 1451 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
