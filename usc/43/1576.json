{"tag":"section","attrib":{"id":"idca42814f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1576"},"text":null,"children":[{"tag":"num","attrib":{"value":"1576"},"text":"§ 1576.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying out the provisions of this subchapter, the Secretary shall consult and cooperate with the Secretary of State, the Administrator of the Environmental Protection Agency, the Secretary of Agriculture, and other affected Federal, State, and local agencies.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca428150-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/320/tI/s107"},"text":"Pub. L. 93–320, title I, § 107","children":[],"tail":", formerly § 106, "},{"tag":"date","attrib":{"date":"1974-06-24"},"text":"June 24, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/270"},"text":"88 Stat. 270","children":[],"tail":"; renumbered § 107, "},{"tag":"ref","attrib":{"href":"/us/pl/96/336/s4"},"text":"Pub. L. 96–336, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-04"},"text":"Sept. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1064"},"text":"94 Stat. 1064","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca428151-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca428152-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idca428153-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":