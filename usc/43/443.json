{"tag":"section","attrib":{"id":"idc9e0b1ad-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s443"},"text":null,"children":[{"tag":"num","attrib":{"value":"443"},"text":"§ 443.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of amount of land holdable under assignment of entry","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person shall hold by assignment more than one farm unit prior to final payment of all charges for all the land held by him subject to the reclamation law, except operation and maintenance charges not then due.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9e0b1ae-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-08-13/ch247/s13"},"text":"Aug. 13, 1914, ch. 247, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/690"},"text":"38 Stat. 690","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9e0b1af-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9e0b1b0-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9e0b1b1-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The reclamation law, referred to in text, is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s472"},"text":"section 472 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
