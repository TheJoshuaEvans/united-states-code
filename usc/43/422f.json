{"tag":"section","attrib":{"id":"idc9dbf6fd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s422f"},"text":null,"children":[{"tag":"num","attrib":{"value":"422f"},"text":"§ 422f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals for projects previously authorized; waiver of requirements; approval; negotiation of contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any proposal with respect to the construction of a project which has theretofore been authorized for construction under the Federal reclamation laws shall be made in like manner as a proposal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s422d"},"text":"section 422d of this title","children":[],"tail":", but the Secretary may waive such requirements of subsections (a) and (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s422d"},"text":"section 422d of this title","children":[],"tail":" as he finds to be duplicative of, or rendered unnecessary or impossible by, action already taken by the United States. Upon approval of any such proposal by the Secretary he may negotiate and execute a contract which conforms, as nearly as may be, to the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s422e"},"text":"section 422e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9dbf6fe-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-06/ch972/s6"},"text":"Aug. 6, 1956, ch. 972, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1046"},"text":"70 Stat. 1046","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9dbf6ff-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9dbf700-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9dbf701-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal reclamation laws, referred to in text, are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s422b"},"text":"section 422b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
