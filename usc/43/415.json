{"tag":"section","attrib":{"id":"idc9d9ac76-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s415"},"text":null,"children":[{"tag":"num","attrib":{"value":"415"},"text":"§ 415.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipts applicable to project generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All moneys heretofore or hereafter refunded or received in connection with operations under the reclamation law, except repayments of construction and operation and maintenance charges, shall be a credit to the appropriation for the project or operation from or on account of which the collection is made and shall be available for expenditure in like manner as if said sum had been specifically appropriated for said project or operation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9d9ac77-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-06-12/ch27"},"text":"June 12, 1917, ch. 27","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/149"},"text":"40 Stat. 149","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d9ac78-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d9ac79-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9d9ac7a-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The reclamation law, referred to in text, is identified in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-06-12/ch27"},"text":"act June 12, 1917, ch. 27","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/147"},"text":"40 Stat. 147","children":[],"tail":", under the heading “"},{"tag":"inline","attrib":{},"text":"reclamation service","children":[],"tail":"”, as "},{"tag":"ref","attrib":{"href":"/us/act/1902-06-17/ch1093"},"text":"act June 17, 1902, ch. 1093","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/388"},"text":"32 Stat. 388","children":[],"tail":", and Acts amendatory thereof and supplementary thereto. Act "},{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":", popularly known as the Reclamation Act, is classified generally to this chapter. For complete classification of act "},{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":", to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
