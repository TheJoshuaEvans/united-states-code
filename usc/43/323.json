{"tag":"section","attrib":{"id":"idc9c1b7c3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s323"},"text":null,"children":[{"tag":"num","attrib":{"value":"323"},"text":"§ 323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to certain States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Sections 321 to 323, 325, and 327 to 329 of this title shall only apply to and take effect in the States of California, Colorado, Oregon, Nevada, Washington, Idaho, Montana, Utah, Wyoming, Arizona, New Mexico, and North and South Dakota.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9c1b7c4-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1877-03-03/ch107"},"text":"Mar. 3, 1877, ch. 107","children":[],"tail":", §§ 3, 8, "},{"tag":"ref","attrib":{"href":"/us/stat/19/377"},"text":"19 Stat. 377","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1891-03-03/ch561/s2"},"text":"Mar. 3, 1891, ch. 561, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/1097"},"text":"26 Stat. 1097","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1921-01-06/ch12"},"text":"Jan. 6, 1921, ch. 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1086"},"text":"41 Stat. 1086","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9c1b7c5-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9c1b7c6-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9c1b7c7-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the first clause of section 3 of act ","children":[{"tag":"date","attrib":{"date":"1877-03-03"},"text":"Mar. 3, 1877","children":[],"tail":", and the first clause of section 8 of act "},{"tag":"date","attrib":{"date":"1877-03-03"},"text":"Mar. 3, 1877","children":[],"tail":", as added by act "},{"tag":"date","attrib":{"date":"1891-03-03"},"text":"Mar. 3, 1891","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The second clauses of section 3 and 8 of act ","children":[{"tag":"date","attrib":{"date":"1877-03-03"},"text":"Mar. 3, 1877","children":[],"tail":", are incorporated in the second paragraph of section 322 and "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s325"},"text":"section 325 of this title","children":[],"tail":", respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The first clause of section 3 of act ","children":[{"tag":"date","attrib":{"date":"1877-03-03"},"text":"Mar. 3, 1877","children":[],"tail":", provided that “this act shall only apply to and take effect in the States of California, Oregon and Nevada, and the Territories of Washington, Idaho, Montana, Utah, Wyoming, Arizona, New Mexico and Dakota”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The first clause of section 8 of act ","children":[{"tag":"date","attrib":{"date":"1877-03-03"},"text":"Mar. 3, 1877","children":[],"tail":", as added by act "},{"tag":"date","attrib":{"date":"1891-03-03"},"text":"Mar. 3, 1891","children":[],"tail":", provided for the inclusion of Colorado."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Territories of Washington, Idaho, Montana, Utah, Wyoming, Arizona, New Mexico and Dakota have become States since the enactment of act ","children":[{"tag":"date","attrib":{"date":"1877-03-03"},"text":"Mar. 3, 1877","children":[],"tail":", the Territory of Dakota being divided, to form the States of North and South Dakota."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9c1b7c8-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9c1b7c9-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Section as Unaffected by Submerged Lands Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of this section as not amended, modified or repealed by the Submerged Lands Act, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1303"},"text":"section 1303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
