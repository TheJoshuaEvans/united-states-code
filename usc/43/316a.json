{"tag":"section","attrib":{"id":"idc9bf6e44-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316a"},"text":null,"children":[{"tag":"num","attrib":{"value":"316a"},"text":"§ 316a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9bf6e45-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” means individual, partnership, corporation, or association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9bf6e46-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “district” means any grazing district established under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s316b"},"text":"section 316b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9bf6e47-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9bf6e48-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “lessee” means the holder of any lease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9bf6e49-3a70-11f1-bde1-a5140e