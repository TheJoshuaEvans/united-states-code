{"tag":"section","attrib":{"id":"idca473c73-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1600h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1600h"},"text":"§ 1600h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter or the application thereof to any person or circumstances is held invalid, the remainder of the chapter and the application of such provision to other persons not similarly situated or to other circumstances shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca473c74-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/450/s10"},"text":"Pub. L. 99–450, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-08"},"text":"Oct. 8, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1134"},"text":"100 Stat. 1134","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
