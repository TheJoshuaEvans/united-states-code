{"tag":"section","attrib":{"id":"idc9d9ac99-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s420"},"text":null,"children":[{"tag":"num","attrib":{"value":"420"},"text":"§ 420.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of earth, timber, etc., from other public lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying out the provisions of the national irrigation law approved ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":", and in constructing works thereunder, the Secretary of the Interior is authorized to use and to permit the use by those engaged in the construction of works under said law, under rules and regulations to be prescribed by him, such earth, stone, and timber from the public lands of the United States as may be required in the construction of such works, and the Secretary of Agriculture is authorized to permit the use of earth, stone, and timber from the national forests of the United States for the same purpose, under rules and regulations to be prescribed by him."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9d9ac9a-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1905-02-08/ch552"},"text":"Feb. 8, 1905, ch. 552","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/33/706"},"text":"33 Stat. 706","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"Mar. 4, 1907, ch. 2907","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1269"},"text":"34 Stat. 1269","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d9ac9b-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d9ac9c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9d9ac9d-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The national irrigation law approved ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":", referred to in text, is "},{"tag":"ref","attrib":{"href":"/us/act/1902-06-17/ch1093"},"text":"act June 17, 1902, ch. 1093","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/388"},"text":"32 Stat. 388","children":[],"tail":", popularly known as the Reclamation Act, which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9d9ac9e-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1907-03-04"},"text":"Mar. 4, 1907","children":[],"tail":" redesignated “forest reserves” as “national forests”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
