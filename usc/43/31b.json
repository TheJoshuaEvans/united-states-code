":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a77934-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education component","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “education component” means the education component of the geologic mapping program described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s31c/d/3"},"text":"section 31c(d)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a77935-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal component","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal component” means the Federal component of the geologic mapping program described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s31c/d/1"},"text":"section 31c(d)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a77936-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geologic mapping program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “geologic mapping program” means the National Cooperative Geologic Mapping Program established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s31c/a"},"text":"section 31c(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":