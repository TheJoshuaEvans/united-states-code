{"tag":"section","attrib":{"id":"idca12e54c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s931"},"text":null,"children":[{"tag":"num","attrib":{"value":"931"},"text":"§ 931.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Navigable rivers as public highways","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All navigable rivers, within the territory occupied by the public lands, shall remain and be deemed public highways; and, in all cases where the opposite banks of any streams not navigable belong to different persons, the stream and the bed thereof shall become common to both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca12e54d-3a70-11f1-bde1-a5140e158598"},"text":"(R.S. § 2476.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca12e54e-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca12e54f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca12e550-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2476 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1796-05-18/ch29/s9"},"text":"May 18, 1796, ch. 29, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1/468"},"text":"1 Stat. 468","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1803-03-03/ch27/s17"},"text":"Mar. 3, 1803, ch. 27, § 17","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/2/235"},"text":"2 Stat. 235","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail