{"tag":"section","attrib":{"id":"idca8c823d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2215"},"text":null,"children":[{"tag":"num","attrib":{"value":"2215"},"text":"§ 2215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for drought-related planning in reclamation States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8c823e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2215/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide financial assistance in the form of cooperative agreements in States that are eligible to receive drought assistance under this subchapter to promote the development of drought contingency plans under subchapter II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c823f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2215/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2000-12-23"},"text":"December 23, 2000","children":[],"tail":", the Secretary shall submit to the Congress a report and recommendations on the advisability of providing financial assistance for the development of drought contingency plans in all entities that are eligible to receive assistance under subchapter II."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8c8240-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/250/tI/s105"},"text":"Pub. L. 102–250, title I, § 105","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/566/tII/s201/b"},"text":"Pub. L. 106–566, title II, § 201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2820"},"text":"114 Stat. 2820","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
