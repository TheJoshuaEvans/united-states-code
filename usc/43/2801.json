{"tag":"section","attrib":{"id":"idca93ae0c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801"},"text":null,"children":[{"tag":"num","attrib":{"value":"2801"},"text":"§ 2801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca93ae0d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Advisory Committee” means the National Geospatial Advisory Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2803/a"},"text":"section 2803(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae0e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Committee” means the Federal Geographic Data Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2802/a"},"text":"section 2802(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae0f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered agency”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca93ae10-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca93ae11-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Executive department, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of title 5","children":[],"tail":" that collects, produces, acquires, maintains, distributes, uses, or preserves geospatial data on paper or in electronic form to fulfill the mission of the Executive department, either directly or through a relationship with another organization, including a State, local government, Indian tribe, institution of higher education, business partner or contractor of the Federal Government, and the public;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca93ae12-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Aeronautics and Space Administration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca93ae13-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the General Services Administration; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca93ae14-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include the Department of Defense (including 30 components and agencies performing national missions) or any element of the intelligence community;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae15-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “GeoPlatform” means the GeoPlatform described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2807/a"},"text":"section 2807(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae16-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “geospatial data”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca93ae17-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means information that is tied to a location on the Earth, including by identifying the geographic location and characteristics of natural or constructed features and boundaries on the Earth, and that is generally represented in vector datasets by points, lines, polygons, or other complex geographic features or phenomena;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca93ae18-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be derived from, among other things, remote sensing, mapping, and surveying technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca93ae19-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes images and raster datasets, aerial photographs, and other forms of geospatial data or datasets in digitized or non-digitized form; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca93ae1a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca93ae1b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/5/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geospatial data and activities of an Indian tribe not carried out, in whole or in part, using Federal funds, as determined by the tribal government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca93ae1c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/5/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classified national security-related geospatial data and activities of the Department of Defense, unless declassified;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca93ae1d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/5/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classified national security-related geospatial data and activities of the Department of Energy, unless declassified;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca93ae1e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/5/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geospatial data and activities under chapter 22 of title 10 or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3045"},"text":"section 3045 of title 50","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca93ae1f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/5/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence geospatial data and activities, as determined by the Director of National Intelligence; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca93ae20-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/5/D/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certain declassified national security-related geospatial data and activities of the intelligence community, as determined by the Secretary of Defense, the Secretary of Energy, or the Director of National Intelligence;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae21-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Indian tribe” has the meaning given that term under section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b"},"text":"25 U.S.C. 450b","children":[],"tail":"); "},{"tag":"ref","attrib":{"idref":"fn002185"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002185"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae22-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “institution of higher education” has the meaning given that term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of title 20","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae23-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “intelligence community” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of title 50","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae24-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “lead covered agency” means a lead covered agency for a National Geospatial Data Asset data theme designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2805/b/1"},"text":"section 2805(b)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae25-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “local government” means any city, county, township, town, borough, parish, village, or other general purpose political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae26-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “metadata for geospatial data” means information about geospatial data, including the content, source, vintage, accuracy, condition, projection, method of collection, and other characteristics or descriptions of the geospatial data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae27-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “National Geospatial Data Asset data theme” means the National Geospatial Data Asset core geospatial datasets (including electronic records and coordinates) relating to a topic or subject designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2805"},"text":"section 2805 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae28-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “National Spatial Data Infrastructure” means the technology, policies, criteria, standards, and employees necessary to promote geospatial data sharing throughout the Federal Government, State, tribal, and local governments, and the private sector (including nonprofit organizations and institutions of higher education); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93ae29-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2801/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “proven practices” means methods and activities that advance the use of geospatial data for the benefit of society.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca93ae2a-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tVII/s752"},"text":"Pub. L. 115–254, div. B, title VII, § 752","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3414"},"text":"132 Stat. 3414","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca93ae2b-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca93ae2c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca93ae2d-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b"},"text":"25 U.S.C. 450b","children":[],"tail":"), referred to in par. (6), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/638/s4"},"text":"section 4 of Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2204"},"text":"88 Stat. 2204","children":[],"tail":", which was formerly classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b"},"text":"section 450b of Title 25","children":[],"tail":", Indians, prior to editorial reclassification as "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of Title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca93ae2e-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idca93ae2f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tVII/s751/a"},"text":"Pub. L. 115–254, div. B, title VII, § 751(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3413"},"text":"132 Stat. 3413","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dB/tVII/s751/a"},"text":"“This subtitle [subtitle F (§§ 751–759C) of title VII of div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":", enacting this chapter] may be cited as the ‘Geospatial Data Act of 2018’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca93ae30-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tVII/s751/b"},"text":"Pub. L. 115–254, div. B, title VII, § 751(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3413"},"text":"132 Stat. 3413","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dB/tVII/s751/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" open and publicly available data is essential to the successful operation of the GeoPlatform;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private sector in the United States, for the purposes of acquiring and producing quality geospatial data and geospatial data services, has been and continues to be invaluable in carrying out the varying missions of Federal departments and agencies, as well as contributing positively to the United States economy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" over the last 2 decades, Congress has passed legislation that promotes greater access and use of Government information and data, which has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sparked new, innovative start-ups and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" spurred economic growth in many sectors, such as in the geospatial services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced scientific research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoted public access to Federally funded services and data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved access to geospatial data for the purposes of promoting public health, weather forecasting, economic development, environmental protection, flood zone research, and other purposes.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
