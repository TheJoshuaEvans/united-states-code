{"tag":"section","attrib":{"id":"idc9cd9ef0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390g–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"390g–8"},"text":"§ 390g–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate transfer of water from Arkansas","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No funds authorized to be appropriated by sections 390g to 390g–8 of this title shall be used for any activities associated with:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9cd9ef1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390g–8/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interstate transfer of water from the State of Arkansas; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cd9ef2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390g–8/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the study or demonstration of the potential for the interstate transfer of water from the State of Arkansas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9cd9ef3-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/434/s10"},"text":"Pub. L. 98–434, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1677"},"text":"98 Stat. 1677","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
