{"tag":"section","attrib":{"id":"idc9faf066-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s617u"},"text":null,"children":[{"tag":"num","attrib":{"value":"617u"},"text":"§ 617u.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease of reserved lands in Boulder City, Nevada; disposition of revenues","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized and empowered, under such rules and regulations as he may prescribe, to establish rental rates for the lease of reserved lands of the United States situate within the exterior boundaries of Boulder City, Nevada, and, without prior advertising, to enter into leases therefor at not less than rates so established and for periods not exceeding fifty-three years from the date of such leases: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That all revenues which may accrue to the United States under the provisions of such leases shall be deposited in the Treasury and credited to the Colorado River Dam fund established by "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s617a"},"text":"section 617a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9faf067-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-06-18/ch395"},"text":"June 18, 1940, ch. 395","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/437"},"text":"54 Stat. 437","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9faf068-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9faf069-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9faf06a-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Boulder Canyon Project Act which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9faf06b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9faf06c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Boulder City Act of 1958","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/900"},"text":"Public Law 85–900","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1726"},"text":"72 Stat. 1726","children":[],"tail":", provided for disposal of certain Federal property in Boulder City for purposes of establishment of a municipal corporation incorporated under laws of Nevada."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
