{"tag":"section","attrib":{"id":"idca98687f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3001"},"text":null,"children":[{"tag":"num","attrib":{"value":"3001"},"text":"§ 3001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca986880-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered land” means land that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca986881-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3001/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal lands administered by the Secretary concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca986882-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3001/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not excluded from the development of geothermal, solar, or wind energy under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca986883-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3001/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a land use plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca986884-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3001/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca986885-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal land” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca986886-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3001/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public land as defined by section 103 of the Federal Land Policy Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1702"},"text":"43 U.S.C. 1702","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca986887-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3001/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land of the National Forest System (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1609/a"},"text":"section 1609(a) of title 16","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca986888-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3001/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land use plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “land use plan” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca986889-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3001/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for public land, a land use plan established under the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca98688a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3001/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for National Forest System land, a land management plan approved, amended, or revised under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1604"},"text":"section 1604 of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca98688b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3001/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible project” means a project carried out on covered land that uses wind, solar, or geothermal energy to generate energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca98688c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3001/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca98688d-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3101"},"text":"Pub. L. 116–260, div. Z, title III, § 3101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2513"},"text":"134 Stat. 2513","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca98688e-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca98688f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca986890-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this subtitle”, meaning subtitle B (§§ 3101–3106) of title III of div. Z of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2513"},"text":"134 Stat. 2513","children":[],"tail":", which is classified principally to this chapter. For complete classification of subtitle B to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in par. (3)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
