{"tag":"section","attrib":{"id":"idc9c8e3d5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s375a"},"text":null,"children":[{"tag":"num","attrib":{"value":"375a"},"text":"§ 375a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale under sections 374 and 375 of lands appraised at not exceeding $300","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary in his discretion, in any instances where property to be sold under section 374 or 375 of this title, is appraised at not to exceed $300, may sell said property at public or private sale without complying with the provisions of said sections as to notice, publication, and mode of sale.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9c8e3d6-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-04/ch418/s11"},"text":"Aug. 4, 1939, ch. 418, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1197"},"text":"53 Stat. 1197","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9c8e3d7-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9c8e3d8-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9c8e3d9-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Reclamation Project Act of 1939. See sections 387 to 389 and 485 et seq. of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id"