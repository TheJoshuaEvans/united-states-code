{"tag":"section","attrib":{"id":"idca95f907-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2809"},"text":null,"children":[{"tag":"num","attrib":{"value":"2809"},"text":"§ 2809.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of Federal funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca95f908-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2809/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “implementation date” means the date that is 5 years after the date on which standards for each National Geospatial Data Asset data theme are established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2806"},"text":"section 2806 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f909-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2809/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided otherwise in this section, on and after the implementation date, a covered agency may not use Federal funds for the collection, production, acquisition, maintenance, or dissemination of geospatial data that does not comply with the applicable standards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2806"},"text":"section 2806 of this title","children":[],"tail":", as determined by the Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f90a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2809/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for existing geospatial data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On and after the implementation date, a covered agency may use Federal funds to maintain and disseminate geospatial data that does not comply with the applicable standards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2806"},"text":"section 2806 of this title","children":[],"tail":" if the geospatial data was collected, produced, or acquired by the covered agency before the implementation date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f90b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2809/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95f90c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2809/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairperson of the Committee may grant a waiver of the limitation under subsection (b), upon a request from a covered agency submitted in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f90d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2809/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A request for a waiver under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f90e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2809/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be submitted not later than 30 days before the implementation date;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f90f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2809/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a detailed explanation of the reasons for seeking a waiver;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f910-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2809/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a detailed plan to achieve compliance with the applicable standards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2806"},"text":"section 2806 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f911-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2809/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the date by which the covered agency shall achieve compliance with the applicable standards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2806"},"text":"section 2806 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f912-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2809/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best efforts to comply during transition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the period beginning on the date on which standards for a National Geospatial Data Asset data theme are established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2806"},"text":"section 2806 of this title","children":[],"tail":" and ending on the implementation date, each covered agency, to the maximum extent practicable, shall collect, produce, acquire, maintain, and disseminate geospatial data within the National Geospatial Data Asset data theme in accordance with the standards."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca95f913-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tVII/s759A"},"text":"Pub. L. 115–254, div. B, title VII, § 759A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3427"},"text":"132 Stat. 3427","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
