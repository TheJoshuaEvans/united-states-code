{"tag":"section","attrib":{"id":"idca31df2d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1443"},"text":null,"children":[{"tag":"num","attrib":{"value":"1443"},"text":"§ 1443.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cancellation of leases of public lands used as airports made under law in force ","children":[{"tag":"date","attrib":{"date":"1928-05-24"},"text":"May 24, 1928","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"With the consent of the lessee, the Secretary of the Interior is authorized to cancel any lease of public lands for use as public aviation fields or airports, made under law in force ","children":[{"tag":"date","attrib":{"date":"1928-05-24"},"text":"May 24, 1928","children":[],"tail":", and to lease such lands to the lessee upon the conditions prescribed by "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1442"},"text":"section 1442 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca31df2e-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-05-24/ch728/s3"},"text":"May 24, 1928, ch. 728, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/729"},"text":"45 Stat. 729","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca31df2f-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca31df30-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca31df31-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was previously classified to section 213 of former Title 49, Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
