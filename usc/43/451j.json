{"tag":"section","attrib":{"id":"idc9e322ee-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s451j"},"text":null,"children":[{"tag":"num","attrib":{"value":"451j"},"text":"§ 451j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may perform any and all acts and make all rules and regulations necessary and proper for carrying out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9e322ef-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1953-08-13/ch428/s12"},"text":"Aug. 13, 1953, ch. 428, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/568"},"text":"67 Stat. 568","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
