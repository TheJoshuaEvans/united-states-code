{"tag":"section","attrib":{"id":"idc9d28186-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–23"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–23"},"text":"§ 390h–23.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Southern California desert region integrated water and economic sustainability plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d28187-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–23/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the Mojave Water Agency is authorized to participate in the design, planning, and construction of projects to implement the “Mojave Water Agency’s Integrated Regional Water Management Plan”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d28188-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–23/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the costs of the projects authorized by this section shall not exceed 25 percent of the total cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d28189-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–23/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section, $20,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d2818a-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s16"},"text":"Pub. L. 102–575, title XVI, § 16","children":[],"tail":"——, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dC/tII/s214/a"},"text":"Pub. L. 110–161, div. C, title II, § 214(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1955"},"text":"121 Stat. 1955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d2818b-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d2818c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9d2818d-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section “16——” of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575"},"text":"Pub. L. 102–575","children":[],"tail":". Two other sections “16——” of "},{"tag":"ref","attrib":{"href":"/us/pl/102/575"},"text":"Pub. L. 102–575","children":[],"tail":" have been enacted and are classified to sections 390h–21 and 390h–22 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9d2818e-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9d2818f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation on Funds; Credits Toward Non-Federal Share","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/dC/tII/s214/c"},"text":"Pub. L. 110–161, div. C, title II, § 214(c)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1956"},"text":"121 Stat. 1956","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/161/dC/tII/s214/c"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary [of the Interior] shall not provide funds for the operation or maintenance of a project authorized by this section [enacting this section].","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credits Toward Non-Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of subsection (b) [probably means subsec. (b) of this section] the Secretary shall credit the Mojave Water Agency with the value of all expenditures made prior to the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":"] that are used toward completion of projects that are compatible with this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
