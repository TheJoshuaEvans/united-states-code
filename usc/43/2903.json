{"tag":"section","attrib":{"id":"idca95f93a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2903"},"text":null,"children":[{"tag":"num","attrib":{"value":"2903"},"text":"§ 2903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of transfers of title to eligible facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca95f93b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95f93c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2903/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the requirements of this chapter, the Secretary, without further authorization from Congress, may, on application of a qualifying entity, convey to a qualifying entity all right, title, and interest of the United States in and to any eligible facility, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f93d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2903/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 90 days before the date on which the Secretary makes the conveyance, the Secretary submits to Congress—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca95f93e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2903/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written notice of the proposed conveyance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f93f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2903/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the reasons for the conveyance; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f940-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2903/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a joint resolution disapproving the conveyance is not enacted before the date on which the Secretary makes the conveyance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f941-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2903/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A conveyance under paragraph (1) shall be made by written agreement between the Secretary and the qualifying entity, developed in consultation with any existing water and power customers affected by the conveyance of the eligible facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f942-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of easement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may reserve an easement over a conveyed property if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95f943-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the easement is necessary for the management of any interests retained by the Federal Government under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f944-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Reclamation project or a portion of the Reclamation project remains under Federal ownership; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f945-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2903/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary enters into an agreement regarding the easement with the applicable qualifying entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f946-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interests in water","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No interests in water shall be conveyed under this chapter unless the conveyance is provided for in a separate, quantified agreement between the Secretary and the qualifying entity, subject to applicable State law and public process requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca95f947-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tVIII/s8003"},"text":"Pub. L. 116–9, title VIII, § 8003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/806"},"text":"133 Stat. 806","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
