{"tag":"section","attrib":{"id":"idc9a77940-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c"},"text":null,"children":[{"tag":"num","attrib":{"value":"31c"},"text":"§ 31c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geologic mapping program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9a77941-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9a77942-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a national cooperative geologic mapping program between the United States Geological Survey and the State geological surveys, acting through the Association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a77943-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Design, development, and administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The cooperative geologic mapping program shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9a77944-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed and administered to achieve the objectives set forth in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a77945-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developed in consultation with the advisory committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a77946-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administered through the Survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9a77947-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of the Survey","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9a77948-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Survey shall be the lead Federal agency responsible for planning, developing national priorities and standards for, coordinating, and managing the geologic mapping program. In carrying out this paragraph, the Secretary, acting through the Director, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9a77949-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a 5-year strategic plan for the geologic mapping program in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s31e"},"text":"section 31e of this title","children":[],"tail":", which plan shall be submitted to the Committee on Resources of the House of Representatives and the Committee on Energy and Natural Resources of the Senate not later than 1 year after "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a7794a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint, with the advice and consultation of the Association, the advisory committee not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s31d"},"text":"section 31d of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a7794b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit biennially a report to the Committee on Energy and Natural Resources of the United States Senate and to the Committee on Resources of the House of Representatives identifying—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9a7794c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Survey and the Association are coordinating the development and implementation of the geologic mapping program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9a7794d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Survey and the Association establish goals, mapping priorities, and target dates for implementation of the geologic mapping program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9a7794e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how long-term staffing plans for the various components of the geologic mapping program affect successful implementation of the geologic mapping program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a7794f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to paragraph (1), the Secretary, acting through the Director, shall be responsible for developing, as soon as practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9a77950-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with the Association, other Federal and State agencies, public and private sector organizations and academia, the geologic-map data base; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a77951-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maps and mapping techniques which achieve the objectives specified in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9a77952-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The objectives of the geologic mapping program shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9a77953-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining the Nation’s geologic framework through systematic development of geologic maps at scales appropriate to the geologic setting and the perceived applications, such maps to be contributed to the national geologic map data base;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a77954-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of a complementary national geochronologic and paleontologic data base that provides value-added descriptive and interpretative information to the geologic-map data base;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a77955-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" application of cost-effective mapping techniques that assemble, produce, translate and disseminate geologic-map information and that render such information of greater application and benefit to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a77956-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of public awareness of the role and application of geologic-map information to the resolution of national issues of land use management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9a77957-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program components","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9a77958-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal component","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9a77959-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The geologic mapping program shall include a Federal geologic mapping component, the objective of which shall be to determine the geologic framework of areas determined to be vital to the economic, social, environmental, or scientific welfare of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a7795a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mapping priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the Federal component, mapping priorities—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9a7795b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be described in the 5-year plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s31e"},"text":"section 31e of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9a7795c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be based on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc9a7795d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national requirements for geologic map information in areas of multiple-issue need or areas of compelling single-issue need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9a7795e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national requirements for geologic map information in areas where mapping is required to solve critical earth science problems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9a7795f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the needs of land management agencies of the Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a77960-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interdisciplinary studies","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9a77961-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal component shall include interdisciplinary studies that add value to geologic mapping.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9a77962-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representative categories","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Interdisciplinary studies under clause (i) may include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc9a77963-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishment of a national geologic map database under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s31f"},"text":"section 31f of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9a77964-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies that lead to the implementation of cost-effective digital methods for the acquisition, compilation, analysis, cartographic production, and dissemination of geologic map information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9a77965-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/1/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paleontologic, geochrono-logic, and isotopic investigations that provide information critical to understanding the age and history of geologic map units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9a77966-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/1/C/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geophysical investigations that assist in delineating and mapping the physical characteristics and 3-dimensional distribution of geologic materials and geologic structures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9a77967-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/1/C/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geochemical investigations and analytical operations that characterize the composition of geologic map units.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9a77968-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of results","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The results of investigations under clause (ii) shall be contributed to national databases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a77969-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State component","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9a7796a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The geologic mapping program shall include a State geologic mapping component, the objective of which shall be to establish the geologic framework of areas determined to be vital to the economic, social, environmental, or scientific welfare of individual States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a7796b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mapping priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the State component, mapping priorities—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9a7796c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be determined by State panels representing a broad range of users of geologic maps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9a7796d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be based on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc9a7796e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State requirements for geologic map information in areas of multiple-issue need or areas of compelling single-issue need; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9a7796f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State requirements for geologic map information in areas where mapping is required to solve critical earth science problems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a77970-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integration of Federal and State priorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A national panel including representatives of the Survey shall integrate the State mapping priorities under this paragraph with the Federal mapping priorities under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a77971-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Survey and recipients of grants under the State component shall not use more than 15.25 percent of the Federal funds made available under the State component for any fiscal year to pay indirect, servicing, or program management charges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a77972-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of activities under the State component for any fiscal year shall not exceed 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a77973-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education component","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9a77974-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The geologic mapping program shall include a geologic mapping education component for the training of geologic mappers, the objectives of which shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9a77975-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for broad education in geologic mapping and field analysis through support of field studies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9a77976-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop academic programs that teach students of earth science the fundamental principles of geologic mapping and field analysis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a77977-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The education component may include the conduct of investigations, which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9a77978-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be integrated with the Federal component and the State component; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9a77979-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall respond to mapping priorities identified for the Federal component and the State component.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a7797a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Survey and recipients of grants under the education component shall not use more than 15.25 percent of the Federal funds made available under the education component for any fiscal year to pay indirect, servicing, or program management charges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a7797b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of activities under the education component for any fiscal year shall not exceed 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a7797c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abandoned mine land and mine waste component","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9a7797d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The geologic mapping program shall include an abandoned mine land and mine waste geologic mapping component, the objective of which shall be to establish the geologic framework of abandoned mine land and other land containing mine waste.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a7797e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31c/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mapping priorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the component described in subparagraph (A), the priority shall be mapping abandoned mine land and other land containing mine waste where multiple critical mineral (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1606/a"},"text":"section 1606(a) of title 30","children":[],"tail":") and metal commodities are anticipated to be present, rather than single mineral resources."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9a7797f-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/285/s4"},"text":"Pub. L. 102–285, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-18"},"text":"May 18, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/167"},"text":"106 Stat. 167","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s16/a/1"},"text":"Pub. L. 103–437, § 16(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4594"},"text":"108 Stat. 4594","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/b"},"text":"Pub. L. 105–36, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1108"},"text":"111 Stat. 1108","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/148/s4"},"text":"Pub. L. 106–148, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1720"},"text":"113 Stat. 1720","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXI/s11001/c"},"text":"Pub. L. 111–11, title XI, § 11001(c)","children":[],"tail":"–(e), "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1414"},"text":"123 Stat. 1414","children":[],"tail":", 1415; "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tV/s5002/a/2"},"text":"Pub. L. 116–9, title V, § 5002(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/768"},"text":"133 Stat. 768","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tII/s40202/a"},"text":"Pub. L. 117–58, div. D, title II, § 40202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/959"},"text":"135 Stat. 959","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9a77980-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9a77981-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9a77982-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(1)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9"},"text":"Pub. L. 116–9","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s11001/c/1"},"text":"Pub. L. 111–11, § 11001(c)(1)","children":[],"tail":", substituted “not later than 1 year after "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":";” for “not later than 1 year after "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"December 9, 1999","children":[],"tail":";”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s11001/c/2"},"text":"Pub. L. 111–11, § 11001(c)(2)","children":[],"tail":", substituted “not later than 1 year after "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", in accordance” for “not later than 1 year after "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"December 9, 1999","children":[],"tail":", in accordance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s11001/c/3"},"text":"Pub. L. 111–11, § 11001(c)(3)","children":[],"tail":", substituted “submit biennially” for “not later than 3 years after "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"December 9, 1999","children":[],"tail":", and biennially thereafter, submit” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s11001/d"},"text":"Pub. L. 111–11, § 11001(d)","children":[],"tail":", struck out “geophysical-map data base, geochemical-map data base, and a” after “national” and substituted “provides” for “provide”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B)(ii)(III). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s11001/e"},"text":"Pub. L. 111–11, § 11001(e)","children":[],"tail":", added subcl. (III)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/148/s4/1/A"},"text":"Pub. L. 106–148, § 4(1)(A)","children":[],"tail":", substituted “national priorities and standards for” for “priorities” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/148/s4/1/B"},"text":"Pub. L. 106–148, § 4(1)(B)","children":[],"tail":", substituted “develop a 5-year strategic plan for the geologic mapping program” for “develop a geologic mapping program implementation plan” and “not later than 1 year after "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"December 9, 1999","children":[],"tail":"” for “within 300 days after "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"August 5, 1997","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/148/s4/1/C"},"text":"Pub. L. 106–148, § 4(1)(C)","children":[],"tail":", substituted “not later than 1 year after "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"December 9, 1999","children":[],"tail":",” for “within 90 days after "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"August 5, 1997","children":[],"tail":",”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/148/s4/1/D/i"},"text":"Pub. L. 106–148, § 4(1)(D)(i)","children":[],"tail":", substituted “not later than 3 years after "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"December 9, 1999","children":[],"tail":", and biennially thereafter” for “within 210 days after "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"August 5, 1997","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/148/s4/1/D/ii"},"text":"Pub. L. 106–148, § 4(1)(D)(ii)","children":[],"tail":", substituted “are coordinating” for “will coordinate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/148/s4/1/D/iii"},"text":"Pub. L. 106–148, § 4(1)(D)(iii)","children":[],"tail":", substituted “establish” for “will establish”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/148/s4/1/D/iv"},"text":"Pub. L. 106–148, § 4(1)(D)(iv)","children":[],"tail":", substituted “affect” for “will lead to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/148/s4/2"},"text":"Pub. L. 106–148, § 4(2)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d) which set out the Federal, support, State, and education components of the geological mapping program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/b/1"},"text":"Pub. L. 105–36, § 3(b)(1)","children":[],"tail":", added subsec. (a) and struck out heading and text of former subsec. (a). Text read as follows: “There is established in the United States Geological Survey a National Cooperative Geologic Mapping Program. The geologic mapping program shall be developed in consultation with the advisory committee and shall be designed and administered to achieve the objectives set forth in subsection (c) of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/b/2/A"},"text":"Pub. L. 105–36, § 3(b)(2)(A)","children":[],"tail":", (D), substituted “the Survey” for “USGS” in heading and realigned text margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/b/2/B/i"},"text":"Pub. L. 105–36, § 3(b)(2)(B)(i)","children":[],"tail":", (ii), inserted heading and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/b/2/B/iii"},"text":"Pub. L. 105–36, § 3(b)(2)(B)(iii)","children":[],"tail":", substituted “Committee on Resources” for “Committee on Natural Resources” and “"},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"August 5, 1997","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1992-05-18"},"text":"May 18, 1992","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/b/2/B/iv"},"text":"Pub. L. 105–36, § 3(b)(2)(B)(iv)","children":[],"tail":", substituted “Association” for “State geological surveys” and “"},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"August 5, 1997","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1992-05-18"},"text":"May 18, 1992","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/b/2/B/v/I"},"text":"Pub. L. 105–36, § 3(b)(2)(B)(v)(I)","children":[],"tail":", (II), in introductory provisions, substituted “"},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"August 5, 1997","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1992-05-18"},"text":"May 18, 1992","children":[],"tail":"” and “Committee on Resources” for “Committee on Natural Resources”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/b/2/B/v/III"},"text":"Pub. L. 105–36, § 3(b)(2)(B)(v)(III)","children":[],"tail":", inserted “and the Association” after “the Survey”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/b/2/B/v/III"},"text":"Pub. L. 105–36, § 3(b)(2)(B)(v)(III)","children":[],"tail":", (IV), inserted “and the Association” after “the Survey” and “and” after semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C)(iii), (iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/b/2/B/v/V"},"text":"Pub. L. 105–36, § 3(b)(2)(B)(v)(V)","children":[],"tail":", substituted period for “; and” at end of cl. (iii) and struck out cl. (iv) which read as follows: “the degree to which geologic mapping activities traditionally funded by the Survey, including the use of commercially available aerial photography, geodesy, professional land surveying, photogrammetric mapping, cartography, photographic processing, and related services, can be contracted to professional private mapping firms.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/b/2/C/i"},"text":"Pub. L. 105–36, § 3(b)(2)(C)(i)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/b/2/C/ii"},"text":"Pub. L. 105–36, § 3(b)(2)(C)(ii)","children":[],"tail":", substituted “Association” for “State geological surveys”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/b/3/A"},"text":"Pub. L. 105–36, § 3(b)(3)(A)","children":[],"tail":", substituted “interpretative information” for “interpretive information”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/b/3/B"},"text":"Pub. L. 105–36, § 3(b)(3)(B)","children":[],"tail":", substituted “public awareness of” for “public awareness for”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/b/4/A"},"text":"Pub. L. 105–36, § 3(b)(4)(A)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/b/4/B/i"},"text":"Pub. L. 105–36, § 3(b)(4)(B)(i)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/b/4/B/ii"},"text":"Pub. L. 105–36, § 3(b)(4)(B)(ii)","children":[],"tail":", added subpar. (D) and struck out former subpar. (D) which read as follows: “geochronologic and isotopic investigations that (i) provide radiometric age dates for geologic-map units and (ii) fingerprint the geothermometry, geobarometry, and alteration history of geologic-map units, which investigations shall be contributed to a national geochronologic data base;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/b/4/C"},"text":"Pub. L. 105–36, § 3(b)(4)(C)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/b/4/D"},"text":"Pub. L. 105–36, § 3(b)(4)(D)","children":[],"tail":", added par. (4) and struck out former par. (4) which read as follows: “A geologic mapping education component, whose objective shall be—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) to develop the academic programs that teach earth-science students the fundamental principles of geologic mapping and field analysis; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) to provide for broad education in geologic mapping and field analysis through support of field teaching institutes.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Investigations conducted under the geologic mapping education component shall be integrated with the other mapping components of the geologic mapping program, and shall respond to priorities identified for those components.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(1)(A), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" substituted “Natural Resources” for “Interior and Insular Affairs” before “of the House”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9a9ea83-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idc9a9ea84-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9a9ea85-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
