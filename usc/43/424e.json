{"tag":"section","attrib":{"id":"idc9de6769-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s424e"},"text":null,"children":[{"tag":"num","attrib":{"value":"424e"},"text":"§ 424e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary of the Interior; rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to perform any and all acts and to make all rules and regulations necessary and proper for carrying out the purposes of sections 424 to 424e of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9de676a-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-05-16/ch292/s6"},"text":"May 16, 1930, ch. 292, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/368"},"text":"46 Stat. 368","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
