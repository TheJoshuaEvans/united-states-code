{"tag":"section","attrib":{"id":"idca021c87-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s620n–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"620n–1"},"text":"§ 620n–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Top water bank","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca021c88-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s620n–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior may create and operate within the available capacity of Navajo Reservoir a top water bank.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca021c89-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s620n–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Water made available for the top water bank in accordance with subsections (c) and (d) shall not be subject to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/483/s11"},"text":"section 11 of Public Law 87–483","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/76/99"},"text":"76 Stat. 99","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca021c8a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s620n–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The top water bank authorized under subsection (a) shall be operated in a manner that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca021c8b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s620n–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with applicable law, except that, notwithstanding any other provision of law, water for purposes other than irrigation may be stored in the Navajo Reservoir pursuant to the rules governing the top water bank established under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca021c8c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s620n–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not impair the ability of the Secretary of the Interior to deliver water under contracts entered into under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca021c8d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s620n–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/483"},"text":"Public Law 87–483","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/76/96"},"text":"76 Stat. 96","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca021c8e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s620n–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" New Mexico State Engineer File Nos. 2847, 2848, 2849, and 2917.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca021c8f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s620n–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca021c90-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s620n–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior, in cooperation with the State of New Mexico (acting through the Interstate Stream Commission), shall develop any terms and procedures for the storage, accounting, and release of water in the top water bank that are necessary to comply with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca021c91-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s620n–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The terms and procedures developed under paragraph (1) shall include provisions requiring that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca021c92-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s620n–1/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the storage of banked water shall be subject to approval under State law by the New Mexico State Engineer to ensure that impairment of any existing water right does not occur, including storage of water under New Mexico State Engineer File No. 2849;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca021c93-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s620n–1/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water in the top water bank be subject to evaporation and other losses during storage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca048d94-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s620n–1/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water in the top water bank be released for delivery to the owner or assigns of the banked water on request of the owner, subject to reasonable scheduling requirements for making the release;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca048d95-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s620n–1/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water in the top water bank be the first water spilled or released for flood control purposes in anticipation of a spill, on the condition that top water bank water shall not be released or included for purposes of calculating whether a release should occur for purposes of satisfying the flow recommendations of the San Juan River Basin Recovery Implementation Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca048d96-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s620n–1/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water eligible for banking in the top water bank shall be water that otherwise would have been diverted and beneficially used in New Mexico that year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca048d97-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s620n–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior may charge fees to water users that use the top water bank in amounts sufficient to cover the costs incurred by the United States in administering the water bank.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca048d98-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-04-11/ch203/s16"},"text":"Apr. 11, 1956, ch. 203, § 16","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tX/s10401/b/2"},"text":"Pub. L. 111–11, title X, § 10401(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1371"},"text":"123 Stat. 1371","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca048d99-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idca048d9a-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s10701/e/2"},"text":"section 10701(e)(2) of Pub. L. 111–11","children":[],"tail":", see Termination Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca048d9b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca048d9c-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/483"},"text":"Public Law 87–483","children":[],"tail":", referred to in subsecs. (b) and (c)(2)(A), is "},{"tag":"ref","attrib":{"href":"/us/pl/87/483"},"text":"Pub. L. 87–483","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-06-13"},"text":"June 13, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/96"},"text":"76 Stat. 96","children":[],"tail":", which was classified principally to subchapter XXX (§ 615ii et seq.) of chapter 12 of this title, and was omitted from the Code. "},{"tag":"ref","attrib":{"href":"/us/pl/87/483/s11"},"text":"Section 11 of Pub. L. 87–483","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s615ss"},"text":"§ 615ss of this title","children":[],"tail":" prior to being omitted from the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca048d9d-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"idca048d9e-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section to be null and void on issuance of a court order terminating a certain Agreement and Contract between New Mexico, the Navajo Nation, and the United States, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s10701/e/2"},"text":"section 10701(e)(2) of Pub. L. 111–11","children":[],"tail":", set out as an Agreement note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s620"},"text":"section 620 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
