{"tag":"section","attrib":{"id":"idc9d281c9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–34"},"text":"§ 390h–34.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" North Bay Water Reuse Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d281ca-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9d281cb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means a member agency of the North Bay Water Reuse Authority of the State located in the North San Pablo Bay watershed in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9d281cc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Marin County;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9d281cd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Napa County;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9d281ce-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Solano County; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9d281cf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sonoma County.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9d281d0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water reclamation and reuse project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “water reclamation and reuse project” means a project carried out by the Secretary and an eligible entity in the North San Pablo Bay watershed relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9d281d1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water quality improvement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9d281d2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wastewater treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9d281d3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water reclamation and reuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9d281d4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" groundwater recharge and protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9d281d5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surface water augmentation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9d281d6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other related improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9d281d7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the State of California.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d281d8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" North Bay Water Reuse Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9d281d9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Contingent upon a finding of feasibility, the Secretary, acting through a cooperative agreement with the State or a subdivision of the State, is authorized to enter into cooperative agreements with eligible entities for the planning, design, and construction of water reclamation and reuse facilities and recycled water conveyance and distribution systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9d281da-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other Federal agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary and the eligible entity shall, to the maximum extent practicable, use the design work and environmental evaluations initiated by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9d281db-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" non-Federal entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9d281dc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corps of Engineers in the San Pablo Bay Watershed of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9d281dd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Phased project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A cooperative agreement described in paragraph (1) shall require that the North Bay Water Reuse Program carried out under this section shall consist of 2 phases as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9d281de-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First phase","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the first phase, the Secretary and an eligible entity shall complete the planning, design, and construction of the main treatment and main conveyance systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9d281df-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second phase","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the second phase, the Secretary and an eligible entity shall complete the planning, design, and construction of the sub-regional distribution systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9d281e0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9d281e1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of the first phase of the project authorized by this section shall not exceed 25 percent of the total cost of the first phase of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9d281e2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of non-Federal share","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The non-Federal share may be in the form of any in-kind services that the Secretary determines would contribute substantially toward the completion of the water reclamation and reuse project, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9d281e3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable costs incurred by the eligible entity relating to the planning, design, and construction of the water reclamation and reuse project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9d281e4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the acquisition costs of land acquired for the project that is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc9d281e5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used for planning, design, and construction of the water reclamation and reuse project facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9d281e6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by an eligible entity and directly related to the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9d281e7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not provide funds for the operation and maintenance of the project authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9d281e8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9d281e9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" affects or preempts—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9d281ea-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State water law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9d281eb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an interstate compact relating to the allocation of water; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9d281ec-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" confers on any non-Federal entity the ability to exercise any Federal right to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9d281ed-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the water of a stream; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9d281ee-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any groundwater resource.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9d281ef-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–34/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated for the Federal share of the total cost of the first phase of the project authorized by this section $25,000,000, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d281f0-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s1651"},"text":"Pub. L. 102–575, title XVI, § 1651","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tIX/s9110/a"},"text":"Pub. L. 111–11, title IX, § 9110(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1315"},"text":"123 Stat. 1315","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
