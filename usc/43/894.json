{"tag":"section","attrib":{"id":"idca107411-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s894"},"text":null,"children":[{"tag":"num","attrib":{"value":"894"},"text":"§ 894.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of land grants to railroads","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized and directed as of ","children":[{"tag":"date","attrib":{"date":"1887-03-03"},"text":"March 3, 1887","children":[],"tail":", to adjust, in accordance with the decisions of the Supreme Court, each of the railroad land grants made by Congress to aid in the construction of railroads and theretofore unadjusted."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca107412-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1887-03-03/ch376/s1"},"text":"Mar. 3, 1887, ch. 376, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/556"},"text":"24 Stat. 556","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
