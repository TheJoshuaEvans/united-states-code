{"tag":"section","attrib":{"id":"idca913cf4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2422"},"text":null,"children":[{"tag":"num","attrib":{"value":"2422"},"text":"§ 2422.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project eligibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca913cf5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2422/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca913cf6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2422/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and publish in the Federal Register criteria for determining the eligibility of a project for financial assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2423"},"text":"section 2423 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913cf7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2422/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Eligibility criteria shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca913cf8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2422/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submission of an application by the lender to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca913cf9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2422/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstration of the creditworthiness of the project, including a determination by the Secretary that any financing for the project has appropriate security features to ensure repayment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca913cfa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2422/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstration by the non-Federal borrower, to the satisfaction of the Secretary, of the ability of the non-Federal borrower to repay the project financing from user fees or other dedicated revenue sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca913cfb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2422/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstration by the non-Federal borrower, to the satisfaction of the Secretary, of the ability of the non-Federal borrower to pay all operations, maintenance, and replacement costs of the project facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca913cfc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2422/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other criteria as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913cfd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2422/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive any of the criteria in subsection (a)(2) that the Secretary determines to be duplicative or rendered unnecessary because of an action already taken by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913cfe-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2422/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects previously authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project that was authorized for construction under Federal reclamation laws prior to ","children":[{"tag":"date","attrib":{"date":"2006-12-22"},"text":"December 22, 2006","children":[],"tail":", shall be eligible for assistance under this subchapter, subject to the criteria established by the Secretary under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913cff-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2422/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for rural water supply projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A rural water supply project that is determined to be feasible under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2405"},"text":"section 2405 of this title","children":[],"tail":" is eligible for a loan guarantee under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s2423"},"text":"section 2423 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca913d00-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/451/tII/s203"},"text":"Pub. L. 109–451, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3357"},"text":"120 Stat. 3357","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
