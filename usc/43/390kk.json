{"tag":"section","attrib":{"id":"idc9d4cb49-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390kk"},"text":null,"children":[{"tag":"num","attrib":{"value":"390kk"},"text":"§ 390kk.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residency not required","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, irrigation water made available from the operation of reclamation project facilities shall not be withheld from delivery to any project lands for the reason that the owners, lessees, or operators do not live on or near them.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9d4cb4a-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/293/tII/s211"},"text":"Pub. L. 97–293, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1269"},"text":"96 Stat. 1269","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
