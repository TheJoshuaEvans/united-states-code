{"tag":"section","attrib":{"id":"idc9aea5b9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s50e"},"text":null,"children":[{"tag":"num","attrib":{"value":"50e"},"text":"§ 50e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" USGS energy and minerals research facility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9aea5ba-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s50e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the United States Geological Survey (referred to in this section as the “Director”),","children":[{"tag":"ref","attrib":{"idref":"fn002000"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002000"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" shall fund, through a cooperative agreement with an academic partner, the design, construction, and tenant build-out of a facility to support energy and minerals research and appurtenant associated structures."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9aea5bb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s50e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Geological Survey shall retain ownership of the facility and associated structures described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9aea5bc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s50e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may enter into agreements with, and to collect and expend funds or in-kind contributions from, academic, Federal, State, or other tenants over the life of the facility described in subsection (a) for the purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9aea5bd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s50e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facility planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9aea5be-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s50e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9aea5bf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s50e/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9aea5c0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s50e/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9b115c1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s50e/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facility improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9b115c2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s50e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may enter into a lease or other agreement with the academic partner with which the Director has entered into a cooperative agreement under subsection (a), at no cost to the Federal Government, to obtain land on which to construct the facility described in that subsection for a term of not less than 99 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9b115c3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s50e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall submit to Congress annual reports on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9b115c4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s50e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the facility described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9b115c5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s50e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authorities used under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9b115c6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s50e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary of the Interior to carry out this section $167,000,000 for fiscal year 2022, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9b115c7-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tII/s40204"},"text":"Pub. L. 117–58, div. D, title II, § 40204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/960"},"text":"135 Stat. 960","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9b115c8-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9b115c9-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9b115ca-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
