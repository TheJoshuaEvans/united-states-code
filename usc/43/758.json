{"tag":"section","attrib":{"id":"idca094811-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s758"},"text":null,"children":[{"tag":"num","attrib":{"value":"758"},"text":"§ 758.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery of patent contingent on refund of cost of survey","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In all cases of the survey of private land claims the cost of the same shall be refunded to the Treasury by the owner before the delivery of the patent.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca094812-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1885-03-03/ch360"},"text":"Mar. 3, 1885, ch. 360","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/23/499"},"text":"23 Stat. 499","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
