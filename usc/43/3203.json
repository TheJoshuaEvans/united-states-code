{"tag":"section","attrib":{"id":"idca9ab360-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203"},"text":null,"children":[{"tag":"num","attrib":{"value":"3203"},"text":"§ 3203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small water storage and groundwater storage projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca9ab361-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of a competitive grant program for small water storage and groundwater storage projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a competitive grant program, under which the non-Federal project sponsor of any project in a Reclamation State, including the State of Alaska or Hawaii, determined by the Secretary to be feasible under subsection (b)(2)(B) shall be eligible to apply for funding for the planning, design, and construction of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab362-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility and selection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9ab363-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to the Secretary","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab364-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A non-Federal project sponsor described in subsection (a) may submit to the Secretary a proposal for a project eligible to receive a grant under this section in the form of a completed feasibility study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab365-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project shall be considered eligible for consideration for a grant under this section if the project—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca9ab366-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has water storage capacity of not less than 200 acre-feet and not more than 30,000 acre-feet; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab367-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca9ab368-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increases surface water or groundwater storage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca9ab369-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conveys water, directly or indirectly, to or from surface water or groundwater storage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab36a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary shall issue guidelines for feasibility studies for small storage projects to provide sufficient information for the formulation of the studies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab36b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review by the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall review each feasibility study received under paragraph (1)(A) for the purpose of determining whether—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab36c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility study, and the process under which the study was developed, each comply with Federal laws (including regulations) applicable to feasibility studies of small storage projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab36d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the project is technically and financially feasible, in accordance with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca9ab36e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the guidelines developed under paragraph (1)(C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab36f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reclamation laws; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab370-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project provides a Federal benefit, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab371-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of receipt of a feasibility study received under paragraph (1)(A), the Secretary shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives a report that describes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab372-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the review of the study by the Secretary under paragraph (2), including a determination of whether the project is feasible and provides a Federal benefit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab373-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations that the Secretary may have concerning the plan or design of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab374-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any conditions the Secretary may require for construction of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab375-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab376-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal project sponsor of any project determined by the Secretary to be feasible under paragraph (3)(A) shall be eligible to apply to the Secretary for a grant to cover the Federal share of the costs of planning, designing, and constructing the project pursuant to subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab377-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to awarding grants to a small storage project, the Secretary shall determine whether there is sufficient non-Federal funding available to complete the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab378-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants to projects under this section, the Secretary shall give priority to projects that meet 1 or more of the following criteria:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab379-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Projects that are likely to provide a more reliable water supply for States, Indian Tribes, and local governments, including subdivisions of those entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab37a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Projects that are likely to increase water management flexibility and reduce impacts on environmental resources from projects operated by Federal and State agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab37b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Projects that are regional in nature.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab37c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Projects with multiple stakeholders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab37d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Projects that provide multiple benefits, including water supply reliability, ecosystem benefits, groundwater management and enhancements, and water quality improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab37e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ceiling on Federal share","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal share of the costs of each of the individual projects selected under this section shall not exceed the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9ab37f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent of the total project cost; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab380-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $30,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab381-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing funding for a grant for a project under this section, the Secretary shall comply with all applicable environmental laws, including the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab382-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3203/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to carry out this section terminates on the date that is 5 years after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca9ab383-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIX/s40903"},"text":"Pub. L. 117–58, div. D, title IX, § 40903","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1119"},"text":"135 Stat. 1119","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dCC/s105"},"text":"Pub. L. 117–328, div. CC, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5574"},"text":"136 Stat. 5574","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca9ab384-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca9ab385-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca9ab386-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca9ab387-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “200” for “2,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca9ab388-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca9ab389-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
