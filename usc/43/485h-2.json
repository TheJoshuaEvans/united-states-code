{"tag":"section","attrib":{"id":"idc9e7ddcd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s485h–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"485h–2"},"text":"§ 485h–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments to existing contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to negotiate amendments to existing contracts entered into pursuant to subsection (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s485h"},"text":"section 485h of this title","children":[],"tail":" to conform said contracts to the provisions of sections 485h–1 to 485h–5 of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9e7ddce-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-07-02/ch492/s2"},"text":"July 2, 1956, ch. 492, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/484"},"text":"70 Stat. 484","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9e7ddcf-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9e7ddd0-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9e7ddd1-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Reclamation Project Act of 1939 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
