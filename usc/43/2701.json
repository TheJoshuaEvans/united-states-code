{"tag":"section","attrib":{"id":"idca93adf8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2701"},"text":null,"children":[{"tag":"num","attrib":{"value":"2701"},"text":"§ 2701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Control of noxious plants on Federal lands; State programs; terms of entry","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The heads of Federal departments or agencies are authorized and directed to permit the commissioner of agriculture or other proper agency head of any State in which there is in effect a program for the control of noxious plants to enter upon any lands under their control or jurisdiction and destroy noxious plants growing on such land if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca93adf9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such entry is in accordance with a program submitted to and approved by such department or agency: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That no entry shall occur when the head of such Federal department or agency, or his designee, shall have certified that entry is inconsistent with national security;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93adfa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the means by which noxious plants are destroyed are acceptable to the head of such department or agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93adfb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2701/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the same procedure required by the State program with respect to privately owned land has been followed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca93adfc-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/583/s1"},"text":"Pub. L. 90–583, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-17"},"text":"Oct. 17, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1146"},"text":"82 Stat. 1146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca93adfd-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca93adfe-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca93adff-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1241"},"text":"section 1241 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
