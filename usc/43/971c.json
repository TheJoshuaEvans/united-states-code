{"tag":"section","attrib":{"id":"idca1a118d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s971c"},"text":null,"children":[{"tag":"num","attrib":{"value":"971c"},"text":"§ 971c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization or occupancy of Alaskan easements; consent of agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Lands in Alaska within an easement established under sections 971a to 971e of this title by the Secretary of the Interior may not be utilized or occupied without the permission of the Secretary, or an officer or agency designated by him. If the lands crossed by an easement established under sections 971a to 971e of this title are under the jurisdiction of a Federal department or agency other than the Department of the Interior, or of a State, Territory, or other government subdivision or agency, such permission may be granted only with the consent of such department, agency, or other governmental unit.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca1a118e-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch848/s3"},"text":"Aug. 1, 1956, ch. 848, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/898"},"text":"70 Stat. 898","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca1a118f-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca1a1190-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca1a1191-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s420b"},"text":"section 420b of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
