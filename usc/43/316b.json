{"tag":"section","attrib":{"id":"idc9bf6e4d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316b"},"text":null,"children":[{"tag":"num","attrib":{"value":"316b"},"text":"§ 316b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing districts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9bf6e4e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may establish grazing districts upon any public lands outside of the Aleutian Islands Reservation, national forests, and other reservations administered by the Secretary of Agriculture and outside of national parks and monuments which, in his opinion, are valuable for the grazing of livestock. Such districts may include such areas of surveyed and unsurveyed lands as he determines may be conveniently administered as a unit, even if such areas are neither contiguous nor adjacent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9bf6e4f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, after the establishment of a district, is authorized to lease the grazing privileges therein in accordance with the provisions of this subchapter.","children":[{"tag":"ref","attrib":{"idref":"fn002010"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002010"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9bf6e50-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch513/s3"},"text":"Mar. 4, 1927, ch. 513, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1452"},"text":"44 Stat. 1452","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9bf6e51-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9bf6e52-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9bf6e53-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (b), was in the original “this title” and has been translated as if the reference was to “this Act” to reflect the probable intent of Congress inasmuch as the act of ","children":[{"tag":"date","attrib":{"date":"1927-03-04"},"text":"Mar. 4, 1927","children":[],"tail":", was not divided into titles."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9bf6e54-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s471b"},"text":"section 471b of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
