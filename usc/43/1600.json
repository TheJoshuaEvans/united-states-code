{"tag":"section","attrib":{"id":"idca473c00-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1600"},"text":null,"children":[{"tag":"num","attrib":{"value":"1600"},"text":"§ 1600.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca473c01-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1600/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca473c02-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1600/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are multiple purposes established by law for the dams and other control structures administered by the Secretary of the Interior on the Colorado River;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca473c03-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1600/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maintenance of the Colorado River Floodway established in this chapter is essential to accomplish these multiple purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca473c04-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1600/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developments within the Floodway are and will continue to be vulnerable to damaging flows such as the property damage which occurred in 1983 and may occur in the future;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca473c05-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1600/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certain Federal programs which subsidize or permit development within the Floodway threaten human life, health, property, and natural resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca473c06-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1600/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a need for coordinated Federal, State, and local action to limit Floodway development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca473c07-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1600/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress declares that the purposes of this chapter are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca473c08-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1600/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish the Colorado River Floodway, as designated and described further in this chapter, so as to provide benefits to river users and to minimize the loss of human life, protect health and safety, and minimize damage to property and natural resources by restricting future Federal expenditures and financial assistance, except public health funds, which have the effect of encouraging development within the Colorado River Floodway; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca473c09-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1600/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a task force to advise the Secretary of the Interior and the Congress on establishment of the Floodway and on managing existing and future development within the Floodway, including the appropriateness of compensation in specified cases of extraordinary hardship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca473c0a-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/450/s2"},"text":"Pub. L. 99–450, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-08"},"text":"Oct. 8, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1129"},"text":"100 Stat. 1129","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca473c0b-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca473c0c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca473c0d-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/450"},"text":"Pub. L. 99–450","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-08"},"text":"Oct. 8, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1129"},"text":"100 Stat. 1129","children":[],"tail":", known as the Colorado River Floodway Protection Act, which enacted this chapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4029"},"text":"section 4029 of Title 42","children":[],"tail":", The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca473c0e-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idca473c0f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/450/s1"},"text":"Pub. L. 99–450, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-08"},"text":"Oct. 8, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1129"},"text":"100 Stat. 1129","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/450/s1"},"text":"“This Act [enacting this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4029"},"text":"section 4029 of Title 42","children":[],"tail":", The Public Health and Welfare] may be cited as the ‘Colorado River Floodway Protection Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
