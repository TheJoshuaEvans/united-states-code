{"tag":"section","attrib":{"id":"idca021c85-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s620n"},"text":null,"children":[{"tag":"num","attrib":{"value":"620n"},"text":"§ 620n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water quality study and reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is directed to continue studies and to make a report to the Congress and to the States of the Colorado River Basin on the quality of water of the Colorado River.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca021c86-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-04-11/ch203/s15"},"text":"Apr. 11, 1956, ch. 203, § 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/111"},"text":"70 Stat. 111","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
