. 5, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/370"},"text":"85 Stat. 370","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/144/tIII"},"text":"Pub. L. 91–144, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-11"},"text":"Dec. 11, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/331"},"text":"83 Stat. 331","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/689/tII"},"text":"Pub. L. 89–689, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1008"},"text":"80 Stat. 1008","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/511/tII"},"text":"Pub. L. 88–511, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-30"},"text":"Aug. 30, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/687"},"text":"78 Stat. 687","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/880/tII"},"text":"Pub. L. 87–880, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-24"},"text":"Oct. 24, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1221"},"text":"76 Stat. 1221","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9ea4f58-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Temporary Authority of Secretary of the Interior To Facilitate Emergency Actions With Regard to 1976–1977 Drought","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/18"},"text":"Pub. L. 95–18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-04-07"},"text":"Apr. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/36"},"text":"91 Stat. 36","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/95/107"},"text":"Pub. L. 95–107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-17"},"text":"Aug. 17, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/870"},"text":"91 Stat. 870","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/226"},"text":"Pub. L. 95–226","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-02-07"},"text":"Feb. 7, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/10"},"text":"92 Stat. 10","children":[],"tail":", directed Secretary of the Interior to undertake construction, management and conservation activities designed to mitigate losses and damages to Federal reclamation projects and Indian irrigation projects resulting from 1976–1977 drought, to assist willing buyers in purchasing available water supplies from willing sellers, and to undertake studies of potential facilities to mitigate effects of a recurrence of drought and make recommendations to President and Congress evaluating potential undertakings, authorized Secretary to defer, without penalty, the 1977 installment payments on charges owed the United States and to make loans to irrigators for construction, management, conservation activities, or acquisition and transportation of water, appropriated $100,000,000 to carry out provisions of this Act and specified the availability of such funds for expenditures, directed Secretary, not later than "},{"tag":"date","attrib":{"date":"1978-05-01"},"text":"May 1, 1978","children":[],"tail":", to provide President and Congress a complete report on expenditures and accomplishments, and provided that authorities conferred by this Act terminate on "},{"tag":"date","attrib":{"date":"1977-11-30"},"text":"Nov. 30, 1977","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idc9ea4f59-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idc9ea4f5a-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1451"},"text":"section 1451 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
