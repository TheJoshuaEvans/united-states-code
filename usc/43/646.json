{"tag":"section","attrib":{"id":"idca048e00-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s646"},"text":null,"children":[{"tag":"num","attrib":{"value":"646"},"text":"§ 646.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant extended to New Mexico and Arizona","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All the provisions of sections 641, 642 and 643 ","children":[{"tag":"ref","attrib":{"idref":"fn002049"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002049"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title are extended to the States of New Mexico and Arizona, and the said States upon complying with the provisions of said sections shall be entitled to have and receive all of the benefits therein conferred upon the States."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca048e01-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-02-18/ch150/s1"},"text":"Feb. 18, 1909, ch. 150, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/638"},"text":"35 Stat. 638","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca048e02-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca048e03-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca048e04-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[