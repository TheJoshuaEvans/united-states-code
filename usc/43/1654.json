{"tag":"section","attrib":{"id":"idca68a6a5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1654"},"text":null,"children":[{"tag":"num","attrib":{"value":"1654"},"text":"§ 1654.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antitrust laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The grant of a right-of-way, permit, lease, or other authorization pursuant to this chapter shall grant no immunity from the operation of the Federal anti-trust laws.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca68a6a6-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/153/tII/s205"},"text":"Pub. L. 93–153, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-11-16"},"text":"Nov. 16, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/588"},"text":"87 Stat. 588","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
