{"tag":"section","attrib":{"id":"idca094844-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s770"},"text":null,"children":[{"tag":"num","attrib":{"value":"770"},"text":"§ 770.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rectangular mode of survey; departure from","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior may, by regulation, provide that departures may be made from the system of rectangular surveys whenever it is not feasible or economical to extend the rectangular surveys in the regular manner or whenever such departure would promote the beneficial use of lands.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca094845-3a70-11f1-bde1-a5140e158598"},"text":"(R.S. § 2410; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-04-29/ch134/s2"},"text":"Apr. 29, 1950, ch. 134, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/93"},"text":"64 Stat. 93","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca094846-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca094847-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca094848-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2410 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1853-03-03/ch145/s4"},"text":"act Mar. 3, 1853, ch. 145, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/10/245"},"text":"10 Stat. 245","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca094849-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-04-29"},"text":"Apr. 29, 1950","children":[],"tail":", struck out limitation that, when there are departures from the rectangular surveys, the lands shall not be surveyed into less than 160 acres or subdivided into less than 40 acres, and by substituting a general provision for those departures."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
