{"tag":"section","attrib":{"id":"idc9d9ace7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s422c"},"text":null,"children":[{"tag":"num","attrib":{"value":"422c"},"text":"§ 422c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals; submission; payment for cost of examination","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any organization desiring to avail itself of the benefits provided in this subchapter shall submit a proposal therefor to the Secretary in such form and manner as he shall prescribe. Each such proposal shall be accompanied by a payment of $5,000 to defray, in part, the cost of examining the proposal.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9d9ace8-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-06/ch972/s3"},"text":"Aug. 6, 1956, ch. 972, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1044"},"text":"70 Stat. 1044","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/546/tIII/s303"},"text":"Pub. L. 99–546, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3053"},"text":"100 Stat. 3053","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d9ace9-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d9acea-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9d9aceb-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/546"},"text":"Pub. L. 99–546","children":[],"tail":" substituted “$5,000” for “$1,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
