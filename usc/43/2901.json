{"tag":"section","attrib":{"id":"idca95f91a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2901"},"text":null,"children":[{"tag":"num","attrib":{"value":"2901"},"text":"§ 2901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this chapter is to facilitate the transfer of title to Reclamation project facilities to qualifying entities on the completion of repayment of capital costs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca95f91b-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tVIII/s8001"},"text":"Pub. L. 116–9, title VIII, § 8001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/804"},"text":"133 Stat. 804","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
