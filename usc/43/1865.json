{"tag":"section","attrib":{"id":"idca8555f5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1865"},"text":null,"children":[{"tag":"num","attrib":{"value":"1865"},"text":"§ 1865.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation of reserves of oil and gas in Outer Continental Shelf","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall conduct a continuing investigation to determine an estimate of the total discovered crude oil and natural gas reserves by fields (including proved and indicated reserves) and undiscovered crude oil and natural gas resources (including hypothetical and speculative resources) of the Outer Continental Shelf.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall provide a biennial report to Congress on June 30 of every odd numbered year on the results of such investigation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca8555f6-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/372/tVI/s606"},"text":"Pub. L. 95–372, title VI, § 606","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/367/s2/c"},"text":"Pub. L. 99–367, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-07-31"},"text":"July 31, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/774"},"text":"100 Stat. 774","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca8555f7-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca8555f8-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idca8555f9-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1865, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/372/tVI/s606"},"text":"Pub. L. 95–372, title VI, § 606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-18"},"text":"Sept. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/696"},"text":"92 Stat. 696","children":[],"tail":", directed Secretary of the Interior to conduct a continuing investigation of reserves of oil and gas in the Outer Continental Shelf, specified items to be included in the investigation, provided for initial and subsequent reports to Congress, and required consultation with the Federal Trade Commission and information to be made available to the Federal Trade Commission, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/367/s2/c"},"text":"Pub. L. 99–367, § 2(c)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca8555fa-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca8555fb-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in this section relating to the requirement that the Secretary of the Interior provide a biennial report to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and the 17th item on page 111 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
