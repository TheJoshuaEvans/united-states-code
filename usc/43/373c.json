{"tag":"section","attrib":{"id":"idc9c699b5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s373c"},"text":null,"children":[{"tag":"num","attrib":{"value":"373c"},"text":"§ 373c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s373b"},"text":"section 373b of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9c699b6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s373c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “law enforcement personnel” means an employee of a Federal, State, or local government agency, including an Indian tribal agency, who has successfully completed law enforcement training approved by the Secretary and is authorized to carry firearms, make arrests, and execute service of process to enforce criminal laws of his or her employing jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9c699b7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s373c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reclamation project; reclamation lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Reclamation project” and “Reclamation lands” have the meaning given such terms in section 460","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–32 of title 16."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9c699b8-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/69/s2"},"text":"Pub. L. 107–69, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/595"},"text":"115 Stat. 595","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
