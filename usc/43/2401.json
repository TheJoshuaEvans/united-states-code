{"tag":"section","attrib":{"id":"idca8ecbf6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401"},"text":null,"children":[{"tag":"num","attrib":{"value":"2401"},"text":"§ 2401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8ecbf7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “construction” means the installation of infrastructure and the upgrading of existing facilities in locations in which the infrastructure or facilities are associated with the new infrastructure of a rural water project recommended by the Secretary pursuant to this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecbf8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal reclamation law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal reclamation law” means the Act of ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/32/388"},"text":"32 Stat. 388","children":[],"tail":", chapter 1093), and Acts supplemental to and amendatory of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"43 U.S.C. 371","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecbf9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian” means an individual who is a member of an Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecbfa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecbfb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal project entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “non-Federal project entity” means a State, regional, or local authority, Indian tribe or tribal organization, or other qualifying entity, such as a water conservation district, water conservancy district, or rural water district or association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecbfc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operations, maintenance, and replacement costs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8ecbfd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “operations, maintenance, and replacement costs” means all costs for the operation of a rural water supply project that are necessary for the safe, efficient, and continued functioning of the project to produce the benefits described in a feasibility study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecbfe-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “operations, maintenance, and replacement costs” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca8ecbff-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repairs of a routine nature that maintain a rural water supply project in a well kept condition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8ecc00-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" replacement of worn-out project elements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8ecc01-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rehabilitation activities necessary to bring a deteriorated project back to the original condition of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecc02-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “operations, maintenance, and replacement costs” does not include construction costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc03-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the rural water supply program carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2402"},"text":"section 2402 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc04-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reclamation States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Reclamation States” means the States and areas referred to in the first section of the Act of ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s391"},"text":"43 U.S.C. 391","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc05-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural water supply project","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8ecc06-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “rural water supply project” means a project that is designed to serve a community or group of communities, each of which has a population of not more than 50,000 inhabitants, which may include Indian tribes and tribal organizations, dispersed homesites, or rural areas with domestic, industrial, municipal, and residential water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecc07-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “rural water supply project” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca8ecc08-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incidental noncommercial livestock watering and noncommercial irrigation of vegetation and small gardens of less than 1 acre; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8ecc09-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a project to improve rural water infrastructure, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca8ecc0a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/9/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pumps, pipes, wells, and other diversions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca8ecc0b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/9/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" storage tanks and small impoundments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca8ecc0c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/9/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water treatment facilities for potable water supplies, including desalination facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca8ecc0d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/9/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment and management tools for water conservation, groundwater recovery, and water recycling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca8ecc0e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/9/B/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appurtenances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecc0f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “rural water supply project” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca8ecc10-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/9/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial irrigation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8ecc11-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/9/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" major impoundment structures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc12-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc13-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “tribal organization” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8ecc14-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recognized governing body of an Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecc15-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2401/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any legally established organization of Indians that is controlled, sanctioned, or chartered by the governing body or democratically elected by the adult members of the Indian community to be served by the organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8ecc16-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/451/tI/s102"},"text":"Pub. L. 109–451, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3346"},"text":"120 Stat. 3346","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca8ecc17-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca8ecc18-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca8ecc19-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/32/388"},"text":"32 Stat. 388","children":[],"tail":", chapter 1093), referred to in par. (2), is popularly known as the Reclamation Act and is classified generally to chapter 12 (§ 371 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca8ecc1a-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idca8ecc1b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/451/s1/a"},"text":"Pub. L. 109–451, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3345"},"text":"120 Stat. 3345","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/451/s1/a"},"text":"“This Act [enacting this chapter] may be cited as the ‘Rural Water Supply Act of 2006’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/451/tI/s101"},"text":"Pub. L. 109–451, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3346"},"text":"120 Stat. 3346","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/451/tI/s101"},"text":"“This title [enacting this subchapter] may be cited as the ‘Reclamation Rural Water Supply Act of 2006’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/451/tII/s201"},"text":"Pub. L. 109–451, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3356"},"text":"120 Stat. 3356","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/451/tII/s201"},"text":"“This title [enacting subchapter II of this chapter] may be cited as the ‘Twenty-First Century Water Works Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
