{"tag":"section","attrib":{"id":"idca87a047-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2002"},"text":null,"children":[{"tag":"num","attrib":{"value":"2002"},"text":"§ 2002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca87a048-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2002/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide a means for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca87a049-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2002/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selecting delivery systems to transport Alaskan and other crude oil to northern tier States and inland States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca87a04a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2002/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resolving both the west coast crude oil surplus and the crude oil supply problems in the northern tier States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca87a04b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2002/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide an expedited procedure for acting on applications for all Federal permits, licenses, and approvals required for the construction and operation or any transportation system approved under this chapter and the Long Beach-Midland project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca87a04c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2002/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assure that Federal decisions with respect to crude oil transportation systems are coordinated with State decisions to the maximum extent practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca87a04d-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617/tV/s502"},"text":"Pub. L. 95–617, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3157"},"text":"92 Stat. 3157","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca87a04e-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca87a04f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idca87a050-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definition of “State” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2602"},"text":"section 2602 of Title 16","children":[],"tail":", Conservation, applies to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
