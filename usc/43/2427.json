{"tag":"section","attrib":{"id":"idca913d2d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2427"},"text":null,"children":[{"tag":"num","attrib":{"value":"2427"},"text":"§ 2427.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca913d2e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2427/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter preempts or affects State water law or an interstate compact governing water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913d2f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2427/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall comply with State water laws in carrying out this subchapter. Nothing in this subchapter affects or preempts State water law or an interstate compact governing water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca913d30-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/451/tII/s208"},"text":"Pub. L. 109–451, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3360"},"text":"120 Stat. 3360","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
