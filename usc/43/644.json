{"tag":"section","attrib":{"id":"idca048df9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s644"},"text":null,"children":[{"tag":"num","attrib":{"value":"644"},"text":"§ 644.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference right to entryman under State laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior, when restoring to the public domain lands that have been segregated to a State under sections 641, 642 and 643 ","children":[{"tag":"ref","attrib":{"idref":"fn002048"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002048"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title is authorized, in his discretion and under such rules and regulations as he may establish to allow for not exceeding ninety days to any entryman under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s641"},"text":"section 641 of this title","children":[],"tail":" a preference right of entry under applicable land laws of any of such lands which such person had entered under and pursuant to the State laws providing for the administration of the grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s641"},"text":"section 641 of this title","children":[],"tail":" and upon which such person had established actual bona fide residence or had made substantial and permanent improvements: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That each entryman shall be entitled to a credit as residence upon his new homestead entry allowed hereunder of the time that he has actually lived upon the claim as a bona fide resident thereof."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca048dfa-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-02-14/ch74"},"text":"Feb. 14, 1920, ch. 74","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/407"},"text":"41 Stat. 407","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca048dfb-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca048dfc-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca048dfd-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s643"},"text":"Section 643 of this title","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/94/579/tVII/s704/a"},"text":"Pub. L. 94–579, title VII, § 704(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2792"},"text":"90 Stat. 2792","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
