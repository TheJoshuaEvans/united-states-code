{"tag":"section","attrib":{"id":"idca048dfe-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s645"},"text":null,"children":[{"tag":"num","attrib":{"value":"645"},"text":"§ 645.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional arid lands available to Colorado, Idaho, Nevada, and Wyoming for reclamation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An additional one million acres of arid lands within each of the States of Colorado, Idaho, Nevada, and Wyoming is made available and subject to the terms of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s641"},"text":"section 641 of this title","children":[],"tail":", and the States of Colorado, Nevada, Idaho, and Wyoming are allowed under the provisions of said section said additional area or so much thereof as may be necessary for the purposes and under the provisions of said section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca048dff-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1908-05-27/ch200"},"text":"May 27, 1908, ch. 200","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/347"},"text":"35 Stat. 347","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1911-03-04/ch285"},"text":"Mar. 4, 1911, ch. 285","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1417"},"text":"36 Stat. 1417","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1911-08-21"},"text":"Aug. 21, 1911","children":[],"tail":", No. 7, "},{"tag":"ref","attrib":{"href":"/us/stat/37/38"},"text":"37 Stat. 38","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
