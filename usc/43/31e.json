{"tag":"section","attrib":{"id":"idc9a9ea96-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e"},"text":null,"children":[{"tag":"num","attrib":{"value":"31e"},"text":"§ 31e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geologic mapping program 5-year plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9a9ea97-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director, shall, with the advice and review of the advisory committee, prepare a 5-year plan for the geologic mapping program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9a9ea98-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The 5-year plan shall identify—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9a9ea99-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overall priorities for the geologic mapping program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9a9ea9a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" implementation of the overall management structure and operation of the geologic mapping program, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9a9ea9b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the role of the Survey in the capacity of overall management lead, including the responsibility for developing the national geologic mapping program that meets Federal needs while fostering State needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a9ea9c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the responsibilities of the State geological surveys, with emphasis on mechanisms that incorporate the needs, missions, capabilities, and requirements of the State geological surveys, into the nationwide geologic mapping program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a9ea9d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" mechanisms for identifying short- and long-term priorities for each component of the geologic mapping program, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9a9ea9e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the Federal component, a priority-setting mechanism that responds to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc9a9ea9f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e/b/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal mission requirements for geologic map information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9a9eaa0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e/b/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" critical scientific problems that require geologic maps for their resolution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9a9eaa1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e/b/2/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shared Federal and State needs for geologic maps, in which joint Federal-State geologic mapping projects are in the national interest;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9a9eaa2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the State component, a priority-setting mechanism that responds to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc9a9eaa3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e/b/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific intrastate needs for geologic map information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9a9eaa4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e/b/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interstate needs shared by adjacent States that have common requirements; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9a9eaa5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the education component, a priority-setting mechanism that responds to requirements for geologic map information that are dictated by Federal and State mission requirements;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a9eaa6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a mechanism for adopting scientific and technical mapping standards for preparing and publishing general- and special-purpose geologic maps to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9a9eaa7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure uniformity of cartographic and scientific conventions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9a9eaa8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a basis for assessing the comparability and quality of map products; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9a9eaa9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31e/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mechanism for monitoring the inventory of published and current mapping investigations nationwide to facilitate planning and information exchange and to avoid redundancy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9a9eaaa-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/285/s6"},"text":"Pub. L. 102–285, § 6","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/148/s6"},"text":"Pub. L. 106–148, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1722"},"text":"113 Stat. 1722","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9a9eaab-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9a9eaac-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc9a9eaad-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 31e, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/285/s6"},"text":"Pub. L. 102–285, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-18"},"text":"May 18, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/170"},"text":"106 Stat. 170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/d"},"text":"Pub. L. 105–36, § 3(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1110"},"text":"111 Stat. 1110","children":[],"tail":", provided for the preparation of a geologic mapping program implementation plan, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/106/148/s6"},"text":"Pub. L. 106–148, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1722"},"text":"113 Stat. 1722","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
