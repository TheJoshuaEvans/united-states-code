{"tag":"section","attrib":{"id":"idc9e322f0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s451k"},"text":null,"children":[{"tag":"num","attrib":{"value":"451k"},"text":"§ 451k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations; expenses as nonreimbursable","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Appropriations heretofore or hereafter made for carrying on the functions of the Bureau of Reclamation shall be available for credits, expenses, charges, and costs provided by or incurred under this subchapter. Expenses incurred in carrying out the provisions of sections 451 to 451f of this title, shall be nonreimbursable and nonreturnable under the Federal reclamation laws.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9e322f1-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1953-08-13/ch428/s13"},"text":"Aug. 13, 1953, ch. 428, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/568"},"text":"67 Stat. 568","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9e322f2-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9e322f3-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9e322f4-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal reclamation laws, referred to in text, are identified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s451i"},"text":"section 451i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
