{"tag":"section","attrib":{"id":"idca9868ce-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3006"},"text":null,"children":[{"tag":"num","attrib":{"value":"3006"},"text":"§ 3006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ensuring energy security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca9868cf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9868d0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3006/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal land” means public lands (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1702"},"text":"section 1702 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9868d1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3006/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offshore lease sale","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “offshore lease sale” means an oil and gas lease sale—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9868d2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3006/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is held by the Secretary in accordance with the Outer Continental Shelf Lands Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"43 U.S.C. 1331","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9868d3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3006/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, if any acceptable bids have been received for any tract offered in the lease sale, results in the issuance of a lease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9868d4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3006/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Onshore lease sale","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “onshore lease sale” means a quarterly oil and gas lease sale—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9868d5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3006/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is held by the Secretary in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s226"},"text":"section 226 of title 30","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9868d6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3006/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, if any acceptable bids have been received for any parcel offered in the lease sale, results in the issuance of a lease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9868d7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on issuance of certain leases or rights-of-way","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the 10-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2022-08-16"},"text":"August 16, 2022","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9868d8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3006/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary may not issue a right-of-way for wind or solar energy development on Federal land unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9868d9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3006/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an onshore lease sale has been held during the 120-day period ending on the date of the issuance of the right-of-way for wind or solar energy development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9868da-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3006/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum total of acres offered for lease in onshore lease sales during the 1-year period ending on the date of the issuance of the right-of-way for wind or solar energy development is not less than the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca9868db-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3006/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2,000,000 acres; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9868dc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3006/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the acreage for which expressions of interest have been submitted for lease sales during that period; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9868dd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3006/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary may not issue a lease for offshore wind development under section 8(p)(1)(C) of the Outer Continental Shelf Lands Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1337/p/1/C"},"text":"43 U.S.C. 1337(p)(1)(C)","children":[],"tail":") unless—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9868de-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3006/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offshore lease sale has been held during the 1-year period ending on the date of the issuance of the lease for offshore wind development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9868df-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3006/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum total of acres offered for lease in offshore lease sales during the 1-year period ending on the date of the issuance of the lease for offshore wind development is not less than 60,000,000 acres.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9868e0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3006/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as expressly provided in paragraphs (1) and (2) of subsection (b), nothing in this section supersedes, amends, or modifies existing law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca9868e1-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tV/s50265"},"text":"Pub. L. 117–169, title V, § 50265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2060"},"text":"136 Stat. 2060","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca9868e2-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca9868e3-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca9868e4-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Outer Continental Shelf Lands Act, referred to in subsec. (a)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1953-08-07/ch345"},"text":"act Aug. 7, 1953, ch. 345","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/462"},"text":"67 Stat. 462","children":[],"tail":", which is classified generally to subchapter III (§ 1331 et seq.) of chapter 29 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1301"},"text":"section 1301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca9868e5-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":", and not as part of subtitle B of title III of div. Z of "},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca9868e6-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idca9868e7-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tV/s50211"},"text":"Pub. L. 117–169, title V, § 50211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2052"},"text":"136 Stat. 2052","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/169/tV/s50211"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this subtitle [subtitle B (§§ 50211–50281), enacting this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1356c"},"text":"section 1356c of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1727"},"text":"section 1727 of Title 30","children":[],"tail":", Mineral Lands and Mining, and amending sections 1331, 1337, and 1344 of this title and sections 188 and 226 of Title 30]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Secretary’ means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United states insular areas","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘United States Insular Areas’ means American Samoa, the Commonwealth of the Northern Mariana Islands, Guam, the Commonwealth of Puerto Rico, and the United States Virgin Islands.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
