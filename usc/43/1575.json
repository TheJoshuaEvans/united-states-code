{"tag":"section","attrib":{"id":"idca428148-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1575"},"text":null,"children":[{"tag":"num","attrib":{"value":"1575"},"text":"§ 1575.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to enter into contracts that he deems necessary to carry out the provisions of this subchapter in advance of the appropriation of funds therefor.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca428149-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/320/tI/s105"},"text":"Pub. L. 93–320, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-06-24"},"text":"June 24, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/270"},"text":"88 Stat. 270","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
