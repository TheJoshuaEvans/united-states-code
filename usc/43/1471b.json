{"tag":"section","attrib":{"id":"idca390b12-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1471b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1471b"},"text":"§ 1471b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations for suppression and emergency prevention of forest and range fires","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1992-10-02"},"text":"October 2, 1992","children":[],"tail":", the Secretary may authorize the expenditure or transfer (within each bureau or office) of any appropriation in this title "},{"tag":"ref","attrib":{"idref":"fn002089"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002089"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or appropriations made under this title "},{"tag":"ref","attrib":{"idref":"fn002089"},"text":"1","children":[],"tail":" in subsequent Energy and Water Development Appropriations Acts, in addition to the amounts included in the budget programs of the several agencies, for the suppression or emergency prevention of forest or range fires on or threatening lands under jurisdiction of the Department of the Interior."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca390b13-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/377/tII/s202"},"text":"Pub. L. 102–377, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1331"},"text":"106 Stat. 1331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca390b14-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":