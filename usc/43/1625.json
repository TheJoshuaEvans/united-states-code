{"tag":"section","attrib":{"id":"idca5a4e40-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625"},"text":null,"children":[{"tag":"num","attrib":{"value":"1625"},"text":"§ 1625.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securities laws exemption","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca5a4e41-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laws; termination date of exempt status","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Native Corporation shall be exempt from the provisions, as amended, of the Investment Company Act of 1940 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/54/789"},"text":"54 Stat. 789","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–1"},"text":"15 U.S.C. 80a–1","children":[],"tail":" et seq.], the Securities Act of 1933 ("},{"tag":"ref","attrib":{"href":"/us/stat/48/74"},"text":"48 Stat. 74","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"15 U.S.C. 77a","children":[],"tail":" et seq.], and the Securities Exchange Act of 1934 ("},{"tag":"ref","attrib":{"href":"/us/stat/48/881"},"text":"48 Stat. 881","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"15 U.S.C. 78a","children":[],"tail":" et seq.] until the earlier of the day after—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca5a4e42-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the date on which the corporation issues shares of stock other than Settlement Common Stock in a transaction where—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5a4e43-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transaction or the shares are not otherwise exempt from Federal securities laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5a4e44-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the shares are issued to persons or entities other than—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca5a4e45-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who held shares in the corporation on ","children":[{"tag":"date","attrib":{"date":"1988-02-03"},"text":"February 3, 1988","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5a4e46-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Natives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5a4e47-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" descendants of Natives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5a4e48-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who have received shares of Settlement Common Stock by inheritance pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1606/h/2"},"text":"section 1606(h)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5a4e49-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Settlement Trusts; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5a4e4a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/a/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities established for the sole benefit of Natives or descendants of Natives; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5a4e4b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which alienability restrictions are terminated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5a4e4c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the corporation files a registration statement with the Securities and Exchange Commission pursuant to either the Securities Act of 1933 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"15 U.S.C. 77a","children":[],"tail":" et seq.] or the Securities Exchange Act of 1934 ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"15 U.S.C. 78a","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca5a4e4d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of Native Corporations after termination date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this section shall be construed to require or imply that a Native Corporation shall, or shall not, be subject to provisions of the Acts listed in subsection (a) after any of the dates described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca5a4e4e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to shareholders; shareholders of record","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca5a4e4f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Native Corporation that, but for this section, would be subject to the provisions of the Securities Exchange Act of 1934 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"15 U.S.C. 78a","children":[],"tail":" et seq.] shall annually prepare and transmit to its shareholders a report that contains substantially all the information required to be included in an annual report to shareholders by a corporation subject to that Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5a4e50-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of determining the applicability of the registration requirements of the Securities Exchange Act of 1934 on or after the date described in subsection (a), holders of Settlement Common Stock shall be excluded from the calculation of the number of shareholders of record pursuant to section 12(g) of that Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78"},"text":"15 U.S.C. 78","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(g)]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca5a4e51-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wholly owned subsidiaries; Settlement Trusts; voluntary registration as Investment Company","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca5a4e52-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, prior to ","children":[{"tag":"date","attrib":{"date":"2001-01-01"},"text":"January 1, 2001","children":[],"tail":", the provisions of the Investment Company Act of 1940 ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–1"},"text":"15 U.S.C. 80a–1","children":[],"tail":" et seq.] shall not apply to any Native Corporation or any subsidiary of such corporation if such subsidiary is wholly owned (as that term is defined in the Investment Company Act of 1940) by the corporation and the corporation owns at least 95 per centum of the equity of the subsidiary."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5a4e53-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Investment Company Act of 1940 shall not apply to any Settlement Trust.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5a4e54-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1625/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, but for this section, a Native Corporation would qualify as an Investment Company under the Investment Company Act of 1940, it shall be entitled to voluntarily register pursuant to such Act and any such corporation which so registered shall thereafter comply with the provisions of such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca5a4e55-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203/s28"},"text":"Pub. L. 92–203, § 28","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/204/s3"},"text":"Pub. L. 94–204, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-01-02"},"text":"Jan. 2, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1147"},"text":"89 Stat. 1147","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/241/s14"},"text":"Pub. L. 100–241, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-02-03"},"text":"Feb. 3, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1811"},"text":"101 Stat. 1811","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca5a4e56-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca5a4e57-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca5a4e58-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Investment Company Act of 1940, referred to in subsecs. (a) and (d), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"act Aug. 22, 1940, ch. 686","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/789"},"text":"54 Stat. 789","children":[],"tail":", which is classified generally to subchapter I (§ 80a–1 et seq.) of chapter 2D of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–51"},"text":"section 80a–51 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Securities Act of 1933 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/48/74"},"text":"48 Stat. 74","children":[],"tail":"), referred to in subsec. (a), is "},{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38/tI"},"text":"act May 27, 1933, ch. 38, title I","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/74"},"text":"48 Stat. 74","children":[],"tail":", which is classified generally to subchapter I (§ 77a et seq.) of chapter 2A of Title 15. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"section 77a of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Securities Exchange Act of 1934, referred to in subsecs. (a) and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"act June 6, 1934, ch. 404","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/881"},"text":"48 Stat. 881","children":[],"tail":", which is classified principally to chapter 2B (§ 78a et seq.) of Title 15. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"section 78a of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca5a4e59-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/241"},"text":"Pub. L. 100–241","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “Any corporation organized pursuant to this chapter shall be exempt from the provisions of the Investment Company Act of 1940 ("},{"tag":"ref","attrib":{"href":"/us/stat/54/789"},"text":"54 Stat. 789","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–1"},"text":"15 U.S.C. 80a–1","children":[],"tail":" et seq.], the Securities Act of 1933 ("},{"tag":"ref","attrib":{"href":"/us/stat/48/74"},"text":"48 Stat. 74","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"15 U.S.C. 77a","children":[],"tail":" et seq.], and the Securities Exchange Act of 1934 ("},{"tag":"ref","attrib":{"href":"/us/stat/48/881"},"text":"48 Stat. 881","children":[],"tail":"), as amended ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"15 U.S.C. 78a","children":[],"tail":" et seq.], through "},{"tag":"date","attrib":{"date":"1991-12-31"},"text":"December 31, 1991","children":[],"tail":". Nothing in this section, however, shall be construed to mean that any such corporation shall or shall not, after such date, be subject to the provisions of such Acts. Any such corporation which, but for this section, would be subject to the provisions of the Securities Exchange Act of 1934 shall transmit to its stockholders each year a report containing substantially all the information required to be included in an annual report to stockholders by a corporation which is subject to the provisions of such Act.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca5a4e5a-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca5a4e5b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of Alaska Native Claims Settlement Act With ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/204"},"text":"Pub. L. 94–204","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/204/s18"},"text":"Pub. L. 94–204, § 18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-01-02"},"text":"Jan. 2, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1156"},"text":"89 Stat. 1156","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/204/s18"},"text":"“Except as specifically provided in this Act [enacting this section and sections 1626 and 1627 of this title, amending sections 1615, 1616, 1620 and 1621 of this title, and enacting provisions set out as notes under this section and sections 1604, 1605, 1611, 1613, and 1618 of this title], (i) the provisions of the Settlement Act [this chapter] are fully applicable to this Act, and (ii) nothing in this Act shall be construed to alter or amend any of such provisions.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
