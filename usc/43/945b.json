{"tag":"section","attrib":{"id":"idca179fe5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s945b"},"text":null,"children":[{"tag":"num","attrib":{"value":"945b"},"text":"§ 945b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction; procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Jurisdiction of an action brought by the United States or the landowner for the determination of just compensation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s945a"},"text":"section 945a of this title","children":[],"tail":" is hereby conferred on the United States district court in the district in which any such land is situated, without limitation to the amount of compensation sought by such suit. The procedure for such an action shall be governed by the Federal Rules of Civil Procedure for the condemnation of real and personal property."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca179fe6-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/561/s2"},"text":"Pub. L. 88–561, § 2","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/624"},"text":"Pub. L. 89–624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-04"},"text":"Oct. 4, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/874"},"text":"80 Stat. 874","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca179fe7-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca179fe8-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca179fe9-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Civil Procedure for the condemnation of real and personal property, referred to in text, means rule 71A of the Federal Rules of Civil Procedure, set out in the Appendix to Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca179fea-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idca179feb-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to Federal condemnation actions pending in any district court of the United States on or after ","children":[{"tag":"date","attrib":{"date":"1966-10-04"},"text":"Oct. 4, 1966","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/88/561/s3"},"text":"section 3 of Pub. L. 88–561","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/89/624"},"text":"Pub. L. 89–624","children":[],"tail":", set out as an Effective Date of 1966 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s945a"},"text":"section 945a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
