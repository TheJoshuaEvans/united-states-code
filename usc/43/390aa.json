{"tag":"section","attrib":{"id":"idc9d28201-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"390aa"},"text":"§ 390aa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of purpose; short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This subchapter shall amend and supplement the Act of ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":", and Acts supplementary thereto and amendatory thereof ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"43 U.S.C. 371","children":[],"tail":"), hereinafter referred to as “Federal reclamation law”. This subchapter may be referred to as the “Reclamation Reform Act of 1982”."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9d28202-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/293/tII/s201"},"text":"Pub. L. 97–293, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1263"},"text":"96 Stat. 1263","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d28203-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d28204-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9d28205-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this title”, meaning title II (§§ 201–230) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/293"},"text":"Pub. L. 97–293","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1263"},"text":"96 Stat. 1263","children":[],"tail":", known as the Reclamation Reform Act of 1982, which enacted this subchapter, amended sections 373a, 422e, 425b, and 485h of this title, and repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s383"},"text":"section 383 of Title 25","children":[],"tail":", Indians. For complete classification of title II to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":", referred to in text, is "},{"tag":"ref","attrib":{"href":"/us/act/1902-06-17/ch1093"},"text":"act June 17, 1902, ch. 1093","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/388"},"text":"32 Stat. 388","children":[],"tail":", popularly known as the Reclamation Act, which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
