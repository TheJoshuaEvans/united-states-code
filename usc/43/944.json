{"tag":"section","attrib":{"id":"idca152fd4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s944"},"text":null,"children":[{"tag":"num","attrib":{"value":"944"},"text":"§ 944.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of way in Oklahoma and Arizona","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where, under sections 934 to 939 of this title, or under special Acts of Congress, or under the laws of the former Territories of Oklahoma and Arizona, railroads have been constructed and were on ","children":[{"tag":"date","attrib":{"date":"1906-06-26"},"text":"June 26, 1906","children":[],"tail":", in operation in Oklahoma or Arizona which passed through any of the lands theretofore reserved for said Territories, such lands shall be disposed of subject to such railroad right or easement, but only to the extent of the right of way conferred by the said sections for such railroad purposes."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca152fd5-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1906-06-26/ch3548"},"text":"June 26, 1906, ch. 3548","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/481"},"text":"34 Stat. 481","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca152fd6-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca152fd7-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca152fd8-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal; Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579/tVII/s706/a"},"text":"Pub. L. 94–579, title VII, § 706(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2793"},"text":"90 Stat. 2793","children":[],"tail":", effective on and after "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", insofar as applicable to the issuance of rights-of-way over, upon, under, and through the public lands and lands in the National Forest System. Such repeal not to be construed as terminating any valid lease, permit, patent, etc., existing on "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/579/s701"},"text":"section 701 of Pub. L. 94–579","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
