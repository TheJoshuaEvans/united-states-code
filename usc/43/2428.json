{"tag":"section","attrib":{"id":"idca913d31-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2428"},"text":null,"children":[{"tag":"num","attrib":{"value":"2428"},"text":"§ 2428.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency coordination and cooperation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca913d32-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2428/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the Secretary of Agriculture before promulgating criteria with respect to financial appraisal functions and loan guarantee administration for activities carried out under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913d33-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2428/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memorandum of agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Secretary of Agriculture shall enter into a memorandum of agreement providing for Department of Agriculture financial appraisal functions and loan guarantee administration for activities carried out under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca913d34-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/451/tII/s209"},"text":"Pub. L. 109–451, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3360"},"text":"120 Stat. 3360","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
