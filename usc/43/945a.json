{"tag":"section","attrib":{"id":"idca152fde-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s945a"},"text":null,"children":[{"tag":"num","attrib":{"value":"945a"},"text":"§ 945a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation for rights-of-way for certain reclamation projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding the existence of any reservation of right-of-way to the United States for canals under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s945"},"text":"section 945 of this title","children":[],"tail":", or any State statute, the Secretary of the Interior shall pay just compensation, including severance damages, to the owners of private land utilized for ditches or canals in connection with any reclamation project, or any unit or any division of a reclamation project, provided the construction of said ditches or canals commenced after "},{"tag":"date","attrib":{"date":"1961-01-01"},"text":"January 1, 1961","children":[],"tail":", and such compensation shall be paid notwithstanding the execution of any agreements or any judgments entered in any condemnation proceeding, prior to "},{"tag":"date","attrib":{"date":"1964-09-02"},"text":"September 2, 1964","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca179fdf-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/561/s1"},"text":"Pub. L. 88–561, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-02"},"text":"Sept. 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/808"},"text":"78 Stat. 808","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/624"},"text":"Pub. L. 89–624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-04"},"text":"Oct. 4, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/873"},"text":"80 Stat. 873","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca179fe0-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca179fe1-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca179fe2-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/624"},"text":"Pub. L. 89–624","children":[],"tail":" inserted “to the United States” and “or any State statute,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca179fe3-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idca179fe4-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/561/s3"},"text":"Pub. L. 88–561, § 3","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/89/624"},"text":"Pub. L. 89–624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-04"},"text":"Oct. 4, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/874"},"text":"80 Stat. 874","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/624"},"text":"“The amendment made by this Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s945b"},"text":"section 945b of this title","children":[],"tail":" and amending this section] shall apply to any condemnation action pending in any district court of the United States on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1966-10-04"},"text":"Oct. 4, 1966","children":[],"tail":"] and to any such action instituted after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
