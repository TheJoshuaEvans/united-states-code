{"tag":"section","attrib":{"id":"idc9cd9edd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390g–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"390g–3"},"text":"§ 390g–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of water quality impacts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Bureau, and the Administrator of the Environmental Protection Agency (hereinafter referred to as the “Administrator”) shall enter into a memorandum-of-understanding to provide for an evaluation of the impacts to surface water and groundwater quality resulting from the groundwater recharge demonstration projects constructed pursuant to sections 390g to 390g–8 of this title. The Administrator shall consult with the United States Geological Survey and shall make maximum use of data, studies, and other technical resources and assistance available from State and local entities in conducting the evaluation. The evaluation of water quality impacts shall be completed so as to be included in the Secretary’s summary report to the Congress referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390g–2/c/2"},"text":"section 390g–2(c)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9cd9ede-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/434/s5"},"text":"Pub. L. 98–434, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1676"},"text":"98 Stat. 1676","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXXVI/s2601/1"},"text":"Pub. L. 102–575, title XXVI, § 2601(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-30"},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4689"},"text":"106 Stat. 4689","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9cd9edf-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9cd9ee0-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9cd9ee1-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575"},"text":"Pub. L. 102–575","children":[],"tail":" substituted “summary report” for “final report”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
