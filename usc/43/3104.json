{"tag":"section","attrib":{"id":"idca9ab2cf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104"},"text":null,"children":[{"tag":"num","attrib":{"value":"3104"},"text":"§ 3104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 3D elevation program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca9ab2d0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of 3D Elevation Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9ab2d1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program, to be known as the “3D Elevation Program”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab2d2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide 3D elevation data coverage for the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab2d3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate and facilitate the collection, dissemination, and use of 3D elevation data among Federal departments and agencies and non-Federal entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab2d4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to produce standard, publicly accessible 3D elevation data products for the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab2d5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to promote the collection, dissemination, and use of 3D elevation data among Federal, State, local, and Tribal governments, communities, institutions of higher education, and the private sector through—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca9ab2d6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperative agreements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab2d7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and maintenance of spatial data infrastructure to provide quality control and deliver to the public 3D elevation data products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab2d8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in coordination with the 3D Elevation Federal Interagency Coordinating Committee established under subsection (b), States, and industry and standards bodies, the development of standards and guidelines for 3D elevation data acquisition to increase accessibility to 3D elevation data in a standard, easy-to-use format; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab2d9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification, assessment, and adoption of emerging technologies to improve the accuracy and efficiency of the 3D Elevation Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab2da-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab2db-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall manage the 3D Elevation Program—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca9ab2dc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure efficiency with respect to related activities of the Department of the Interior and other participating Federal departments and agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab2dd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet the needs of Department of the Interior programs, stakeholders, and the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab2de-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other Federal departments and agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each Federal department and agency involved in the acquisition, production, distribution, or application of 3D elevation data shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca9ab2df-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the 3D Elevation Federal Interagency Coordinating Committee established under subsection (b) to acquire additional, enhanced 3D elevation data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab2e0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary a description of priority areas of interest for 3D elevation data collection for use in providing grants and cooperative agreements under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab2e1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement policies and procedures for data acquisition and sharing that are consistent with standards and guidelines developed under the 3D Elevation Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab2e2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in, and share the results and benefits of, the 3D Elevation Program, in accordance with standards and guidelines developed under the 3D Elevation Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab2e3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that any 3D elevation data acquired with Federal grant funding—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca9ab2e4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/2/B/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets 3D Elevation Program standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca9ab2e5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/a/2/B/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is included in the national holdings of those data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab2e6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 3D Elevation Federal Interagency Coordinating Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9ab2e7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in coordination with the Secretary of Commerce and the Secretary of Homeland Security, shall establish an interagency coordinating committee, to be known as the “3D Elevation Federal Interagency Coordinating Committee” (referred to in this subsection as the “Committee”), to better coordinate 3D elevation data management across the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab2e8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall be composed of the following members (or their designees):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab2e9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, who shall serve as Chairperson of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab2ea-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab2eb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab2ec-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab2ed-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab2ee-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Science and Technology Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab2ef-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab2f0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of any other Federal department or agency, at the request of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab2f1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall coordinate, as appropriate, with the existing activities of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab2f2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 3D Elevation Program Executive Forum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab2f3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Alaska Mapping Executive Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab2f4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 3D Elevation Working Group;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab2f5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 3D National Elevation Subcommittee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab2f6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State offices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab2f7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall meet at the call of the Chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab2f8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab2f9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee the planning, management, and coordination of the 3D Elevation Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab2fa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop, by not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-01-05"},"text":"January 5, 2021","children":[],"tail":", and update periodically thereafter—"}],"tail":null},{"tag":"clause","attrib":{"id":"idca9ab2fb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a strategic plan that establishes goals and priorities for activities carried out under the 3D Elevation Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab2fc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed management plan to implement the strategic plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab2fd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subcommittee of National Geospatial Advisory Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9ab2fe-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab2ff-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish, within the National Geospatial Advisory Committee, a subcommittee (referred to in this subsection as the “Subcommittee”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab300-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Subcommittee shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca9ab301-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consist of not fewer than 11 members, of whom none may be a Federal officer or employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab302-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include representatives of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca9ab303-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and academic institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca9ab304-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industry standards development organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca9ab305-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" units of State and local government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca9ab306-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/1/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab307-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab308-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Subcommittee shall conduct an assessment of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca9ab309-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" trends and developments in—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca9ab30a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection, dissemination, and use of 3D elevation data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca9ab30b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" science and technology relating to 3D elevation data;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab30c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the 3D Elevation Program in carrying out the activities described in subsection (a)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab30d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need to revise or reorganize the 3D Elevation Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab30e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management, coordination, implementation, and activities of the 3D Elevation Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab30f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-01-05"},"text":"January 5, 2021","children":[],"tail":", and every 2 years thereafter, the Subcommittee shall submit to the Secretary and the 3D Elevation Federal Interagency Coordinating Committee established under subsection (b) a report that includes—"}],"tail":null},{"tag":"clause","attrib":{"id":"idca9ab310-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings of the assessment under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab311-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations of the Subcommittee based on those findings, if any.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab312-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and cooperative agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9ab313-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants and enter into cooperative agreements with other Federal departments and agencies, units of State, local, or Tribal government, institutions of higher education, nonprofit research institutions, or other organizations to facilitate the improvement of nationwide coverage of 3D elevation data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab314-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant or enter into a cooperative agreement under this subsection, an entity described in paragraph (1) shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab315-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant or cooperative agreement under this subsection shall be subject to such terms and conditions as the Secretary determines to be appropriate, including making data publically available and interoperable with other Federal datasets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab316-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of fiscal years 2021 through 2024, there is authorized to be appropriated to the Secretary $40,000,000 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab317-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3104/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Derivation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds to carry out the activities under this section shall be derived from amounts authorized to be appropriated to the Secretary that are enacted after ","children":[{"tag":"date","attrib":{"date":"2021-01-05"},"text":"January 5, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca9ab318-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/323/s5"},"text":"Pub. L. 116–323, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5081"},"text":"134 Stat. 5081","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
