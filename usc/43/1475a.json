{"tag":"section","attrib":{"id":"idca3b54bd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1475a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1475a"},"text":"§ 1475a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of non-Federal entities in contract negotiations and source selection proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1992-10-02"},"text":"October 2, 1992","children":[],"tail":", the Bureau of Reclamation may invite non-Federal entities involved in cost sharing arrangements for the development of water projects to participate in contract negotiation and source selection proceedings without invoking provisions of chapter 10 of title 5: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That such non-Federal participants shall be subject to the provisions of chapter 21 of title 41 and to the conflict of interest provisions appearing at "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s201"},"text":"18 U.S.C. 201","children":[],"tail":" et seq. (1988)."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca3b54be-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/377/tII/s205"},"text":"Pub. L. 102–377, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1332"},"text":"106 Stat. 1332","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/283"},"text":"Pub. L. 117–286, § 4(a)(283)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4337"},"text":"136 Stat. 4337","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca3b54bf-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca3b54c0-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca3b54c1-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In text, “chapter 21 of title 41” substituted for “the Federal Procurement Integrity Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s423"},"text":"41 U.S.C. 423","children":[],"tail":" (1988))” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca3b54c2-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5:” for “the Federal Advisory Committee Act (5 U.S.C. Appendix (1988)):”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
