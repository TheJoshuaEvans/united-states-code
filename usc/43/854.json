{"tag":"section","attrib":{"id":"idca0bb935-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s854"},"text":null,"children":[{"tag":"num","attrib":{"value":"854"},"text":"§ 854.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selections in New Mexico to supply deficiencies of school lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All the provisions of sections 851 and 852 of this title are made applicable to New Mexico, and the grant of school lands to said State, and indemnity therefor, shall be administered and adjusted in accordance with the provisions of such sections, anything in the Act of Congress approved ","children":[{"tag":"date","attrib":{"date":"1898-06-21"},"text":"June 21, 1898","children":[],"tail":", making certain grants of land to the Territory of New Mexico, and for other purposes, to the contrary notwithstanding."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca0bb936-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1908-03-16/ch88"},"text":"Mar. 16, 1908, ch. 88","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/44"},"text":"35 Stat. 44","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca0bb937-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca0bb938-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca0bb939-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of Congress approved ","children":[{"tag":"date","at