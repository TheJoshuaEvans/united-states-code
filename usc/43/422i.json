{"tag":"section","attrib":{"id":"idc9dbf70d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s422i"},"text":null,"children":[{"tag":"num","attrib":{"value":"422i"},"text":"§ 422i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to perform any and all acts and to make such rules and regulations as may be necessary or proper in carrying out the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9dbf70e-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-06/ch972/s9"},"text":"Aug. 6, 1956, ch. 972, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1047"},"text":"70 Stat. 1047","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
