{"tag":"section","attrib":{"id":"idca09481c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s760"},"text":null,"children":[{"tag":"num","attrib":{"value":"760"},"text":"§ 760.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit for expenses deemed an appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The deposit of money in a proper United States depository, under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s759"},"text":"section 759 of this title","children":[],"tail":", shall be deemed an appropriation of the sums so deposited for the objects contemplated by said section, and the Secretary of the Treasury is authorized to cause the sums so deposited to be placed to the credit of the proper appropriations for the surveying service; but any excesses in such sums over and above the actual cost of the surveys, comprising all expenses incident thereto, for which they were severally deposited, shall be repaid to the depositors respectively."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca09481d-3a70-11f1-bde1-a5140e158598"},"text":"(R.S. § 2402.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca09481e-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca09481f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca094820-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2402 derived from Res. ","children":[{"tag":"date","attrib":{"date":"1864-07-01"},"text":"July 1, 1864","children":[],"tail":", No. 60, "},{"tag":"ref","attrib":{"href":"/us/stat/13/414"},"text":"13 Stat. 414","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
