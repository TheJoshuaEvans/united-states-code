{"tag":"section","attrib":{"id":"idca95f8d3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2807"},"text":null,"children":[{"tag":"num","attrib":{"value":"2807"},"text":"§ 2807.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geoplatform","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca95f8d4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2807/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall operate an electronic service that provides access to geospatial data and metadata for geospatial data to the general public, to be known as the GeoPlatform.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f8d5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2807/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95f8d6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2807/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The GeoPlatform—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f8d7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2807/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca95f8d8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2807/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be available through the internet and other communications means;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f8d9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2807/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be accessible through a common interface;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f8da-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2807/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include metadata for all geospatial data collected by covered agencies, directly or indirectly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f8db-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2807/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include download access to all open geospatial data directly or indirectly collected by covered agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f8dc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2807/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a set of programming instructions and standards providing an automated means of accessing available geospatial data, which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca95f8dd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2807/b/1/A/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" harmonize sources and data standards associated with geospatial data, including metadata; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca95f8de-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2807/b/1/A/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, as determined by the Chairperson of the Committee, shall be made publicly available;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f8df-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2807/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include geospatial data from a source other than a covered agency, if determined appropriate by the Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f8e0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2807/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not store or serve proprietary information or data acquired under a license by the Federal Government, unless authorized by the data provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f8e1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2807/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Managing partner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairperson of the Committee shall designate an agency to serve as the managing partner for developing and operating the GeoPlatform, taking direction from the Committee on the scope, functionality, and performance of the GeoPlatform.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f8e2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2807/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Although the GeoPlatform is intended to include all National Geospatial Data Asset and other Federal datasets, nothing in this chapter shall be construed to prevent a covered agency from also presenting, providing, or disseminating data that is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95f8e3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2807/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific to the functions of the covered agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f8e4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2807/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" targeted to information consumers that directly interface with the services, portals, or other mechanisms of the covered agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca95f8e5-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tVII/s758"},"text":"Pub. L. 115–254, div. B, title VII, § 758","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3424"},"text":"132 Stat. 3424","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
