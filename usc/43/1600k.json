{"tag":"section","attrib":{"id":"idca473c7e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1600k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1600k"},"text":"§ 1600k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notices and existing laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca473c7f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1600k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions relating to construction work, liability for damage, etc., on Mississippi River; notice to lessees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca473c80-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1600k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this chapter shall alter or affect in any way the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s702c"},"text":"section 702c of title 33","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca473c81-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1600k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide notice of the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s702c"},"text":"section 702c of title 33","children":[],"tail":" and this chapter to all existing and prospective lessees of lands leased by the United States and within the Colorado River Floodway."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca473c82-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1600k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Flood Insurance Act and National Flood Insurance Program; continuation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided in this chapter, all provisions of the National Flood Insurance Act of 1968, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4001"},"text":"42 U.S.C. 4001","children":[],"tail":" et seq.], and requirements of the National Flood Insurance Program (“NFIP”) shall continue in full force and effect within areas wholly or partially within the Colorado River Floodway. Any maps or other information required to be prepared by this chapter shall be used to the maximum extent practicable to support implementation of the NFIP."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca473c83-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1600k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Flood Insurance Act provisions relating directly to Floodway; notice to communities affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish notice on three successive occasions in newspapers of general circulation in communities affected by the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4029"},"text":"section 4029 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca473c84-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/450/s14"},"text":"Pub. L. 99–450, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-08"},"text":"Oct. 8, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1136"},"text":"100 Stat. 1136","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca473c85-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca473c86-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca473c87-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Flood Insurance Act of 1968, referred to in subsec. (b), is title XIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448"},"text":"Pub. L. 90–448","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/572"},"text":"82 Stat. 572","children":[],"tail":", which is classified principally to chapter 50 (§ 4001 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4001"},"text":"section 4001 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
