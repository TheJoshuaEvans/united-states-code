{"tag":"section","attrib":{"id":"idca8c8272-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2244"},"text":null,"children":[{"tag":"num","attrib":{"value":"2244"},"text":"§ 2244.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of chapter on other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8c8273-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2244/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conformity with State and Federal law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All actions taken pursuant to this chapter pertaining to the diversion, storage, use, or transfer of water shall be in conformity with applicable State and applicable Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c8274-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2244/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on jurisdiction, authority, and water rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed as expanding or diminishing State, Federal, or tribal jurisdiction or authority over water resources development, control, or water rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8c8275-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/250/tIII/s304"},"text":"Pub. L. 102–250, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-05"},"text":"Mar. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/59"},"text":"106 Stat. 59","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
