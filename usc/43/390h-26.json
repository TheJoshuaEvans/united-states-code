{"tag":"section","attrib":{"id":"idc9d2819a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–26"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–26"},"text":"§ 390h–26.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pittsburg recycled water project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d2819b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–26/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the City of Pittsburg, California, and the Delta Diablo Sanitation District, is authorized to participate in the design, planning, and construction of recycled water system facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d2819c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–26/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of the project authorized by this section shall not exceed 25 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d2819d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–26/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not provide funds for the operation and maintenance of the project authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d2819e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–26/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $1,750,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d2819f-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s1643"},"text":"Pub. L. 102–575, title XVI, § 1643","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/229/tV/s512/a/1"},"text":"Pub. L. 110–229, title V, § 512(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-08"},"text":"May 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/841"},"text":"122 Stat. 841","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
