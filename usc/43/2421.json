lations”."}],"tail":" (or any successor regulation), known as Rule 144A(a) of the Securities and Exchange Commission and issued under the Securities Act of 1933 ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"15 U.S.C. 77a","children":[],"tail":" et seq.)); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca913cdf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2421/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a clean renewable energy bond lender (as defined in section 54(j)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002181"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002181"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of title 26 (as in effect on "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"December 22, 2006","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913ce0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2421/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan guarantee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “loan guarantee” has the meaning given the term “loan guarantee” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a"},"text":"section 661a of title 2","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913ce1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2421/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal borrower","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “non-Federal borrower” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca913ce2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2421/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State (including a department, agency, or political subdivision of a State); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca913ce3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2421/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a conservancy district, irrigation district, canal company, water users’ association, Indian tribe, an agency created by interstate compact, or any other entity that has the capacity to contract with the United States under Federal reclamation law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913ce4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2421/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “obligation” means a loan or other debt obligation that is guaranteed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913ce5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2421/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “project” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca913ce6-3a70-