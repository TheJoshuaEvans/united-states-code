{"tag":"section","attrib":{"id":"idc9f17a93-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s563"},"text":null,"children":[{"tag":"num","attrib":{"value":"563"},"text":"§ 563.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of town sites set apart prior to ","children":[{"tag":"date","attrib":{"date":"1906-06-27"},"text":"June 27, 1906","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any town site set apart or established prior to ","children":[{"tag":"date","attrib":{"date":"1906-06-27"},"text":"June 27, 1906","children":[],"tail":", by proclamation of the President, under the provisions of sections 711 and 712 "},{"tag":"ref","attrib":{"idref":"fn002043"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002043"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, within or in the vicinity of any reclamation project, may be appraised and disposed of in accordance with the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s562"},"text":"section 562 of this title","children":[],"tail":" and all necessary expenses incurred in the appraisal and sale of lands embraced within any such town site shall be paid from the reclamation fund, and the proceeds of the sales of such lands shall be covered into the reclamation fund."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9f17a94-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1906-06-27/ch3559/s3"},"text":"June 27, 1906, ch. 3559, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/519"},"text":"34 Stat. 519","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9f17a95-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"ro