{"tag":"section","attrib":{"id":"idca748cea-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1748a–2"},"text":"§ 1748a–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca748ceb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the end of the fiscal year for which additional new budget authority is used, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s901/b/2/F/i"},"text":"section 901(b)(2)(F)(i) of title 2","children":[],"tail":", as added by section 102 of this division, the Secretary of the Interior or the Secretary of Agriculture (as applicable), in consultation with the Director of the Office of Management and Budget, shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca748cec-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare an annual report with respect to the additional new budget authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca748ced-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committees on Appropriations, the Budget, and Natural Resources of the House of Representatives and the Committees on Appropriations, the Budget, and Energy and Natural Resources of the Senate the annual report prepared under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca748cee-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the report prepared under paragraph (1) available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca748cef-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The annual report prepared under subsection (a)(1) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca748cf0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" document obligations and outlays of the additional new budget authority for wildfire suppression operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca748cf1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify risk-based factors that influenced management decisions with respect to wildfire suppression operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca748cf2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" analyze a statistically significant sample of large fires, including an analysis for each fire of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca748cf3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost drivers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca748cf4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of risk management techniques and whether fire operations strategy tracked the risk assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca748cf5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any resulting ecological or other benefits to the landscape;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca748cf6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of investments in wildfire suppression operations preparedness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca748cf7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effectiveness of wildfire suppression operations, including an analysis of resources lost versus dollars invested;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca748cf8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effectiveness of any fuel treatments on fire behavior and suppression expenditures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca748cf9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" levels of exposure experienced by firefighters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca748cfa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suggested corrective actions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca748cfb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/b/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other factors the Secretary of the Interior or Secretary of Agriculture (as applicable) determines to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca748cfc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include an accounting of overall fire management and spending by the Department of the Interior or the Department of Agriculture, which shall be analyzed by fire size, cost, regional location, and other factors, and shall include an accounting of any spending in the first two quarters of the succeeding fiscal year that is attributable to suppression operations in the fiscal year for which the report was prepared;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca748cfd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe any lessons learned in the conduct of wildfire suppression operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca748cfe-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748a–2/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include any other elements that the Secretary of the Interior or the Secretary of Agriculture (as applicable) determines to be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca748cff-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dO/tI/s104"},"text":"Pub. L. 115–141, div. O, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1061"},"text":"132 Stat. 1061","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/74/dC/tIV/s439"},"text":"Pub. L. 119–74, div. C, title IV, § 439","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-01-23"},"text":"Jan. 23, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/170"},"text":"140 Stat. 170","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca748d00-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca748d01-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca748d02-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 102 of this division, referred to in subsec. (a), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dO/s102"},"text":"section 102 of div. O of Pub. L. 115–141","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca748d03-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Wildfire Suppression Funding and Forest Management Activities Act, and also as part of the Consolidated Appropriations Act, 2018, and not as part of the Federal Land Policy and Management Act of 1976 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca748d04-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2026—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/74/s439/1"},"text":"Pub. L. 119–74, § 439(1)","children":[],"tail":", substituted “180” for “90” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/74/s439/2"},"text":"Pub. L. 119–74, § 439(2)","children":[],"tail":", inserted “, and shall include an accounting of any spending in the first two quarters of the succeeding fiscal year that is attributable to suppression operations in the fiscal year for which the report was prepared” before semicolon at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
