{"tag":"section","attrib":{"id":"idc9dbf71e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s422l"},"text":null,"children":[{"tag":"num","attrib":{"value":"422l"},"text":"§ 422l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of this subchapter to Hawaii","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This subchapter as heretofore and hereafter amended, shall apply to the State of Hawaii.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9dbf71f-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/624/s31"},"text":"Pub. L. 86–624, § 31","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/421"},"text":"74 Stat. 421","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9dbf720-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9dbf721-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9dbf722-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as a part of the Hawaii Omnibus Act, and not as a part of the Small Reclamation Projects Act of 1956 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
