{"tag":"section","attrib":{"id":"idc9c1b7cc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s325"},"text":null,"children":[{"tag":"num","attrib":{"value":"325"},"text":"§ 325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resident citizenship of State as qualification for entry","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Excepting in the State of Nevada, no person shall be entitled to make entry of desert lands unless he be a resident citizen of the State or Territory in which the land sought to be entered is located.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9c1b7cd-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1877-03-03/ch107/s8"},"text":"Mar. 3, 1877, ch. 107, § 8","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1891-03-03/ch561/s2"},"text":"Mar. 3, 1891, ch. 561, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/1097"},"text":"26 Stat. 1097","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1921-01-06/ch12"},"text":"Jan. 6, 1921, ch. 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1086"},"text":"41 Stat. 1086","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9c1b7ce-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9c1b7cf-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9c1b7d0-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sectio