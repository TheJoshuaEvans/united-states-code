{"tag":"section","attrib":{"id":"idca06fe25-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s664"},"text":null,"children":[{"tag":"num","attrib":{"value":"664"},"text":"§ 664.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of way over reservoir sites generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All reservoir sites reserved or to be reserved shall be open to use and occupation under sections 946 to 949 ","children":[{"tag":"ref","attrib":{"idref":"fn002051"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002051"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, and any State is authorized to improve and occupy such reservoir sites to the same extent as an individual or private corporation, under such rules and regulations as the Secretary of the Interior may prescribe: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the charges for water coming in whole or part from reservoir sites used or occupied under the provisions of this section shall always be subject to the control and regulation of the respective States and Territories in which such reservoirs are in whole or part situate."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca06fe26-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1897-02-26/ch335"},"text":"Feb. 26, 1897, ch. 335","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/29/599"},"text":"29 Stat. 599","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca06fe27-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca06fe28-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca06fe29-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 946 to 949 of this title, referred to in text, were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579/tVII/s706/a"},"text":"Pub. L. 94–579, title VII, § 706(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2793"},"text":"90 Stat. 2793","children":[],"tail":", effective on and after "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", insofar as applicable to the issuance of rights-of-way over, upon, under, and through the public lands and lands in the National Forest System."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca06fe2a-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca06fe2b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal; Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579/tVII/s706/a"},"text":"Pub. L. 94–579, title VII, § 706(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2793"},"text":"90 Stat. 2793","children":[],"tail":", effective on and after "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", insofar as applicable to the issuance of rights-of-way over, upon, under, and through the public lands and lands in the National Forest System. Such repeal not to be construed as terminating any valid lease, permit, patent, etc., existing on "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/579/s701"},"text":"section 701 of Pub. L. 94–579","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
