{"tag":"section","attrib":{"id":"idc9b1163a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s79d"},"text":null,"children":[{"tag":"num","attrib":{"value":"79d"},"text":"§ 79d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alaska land claimant liable for fees, commissions or purchase money; deposit in Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No provision of this Act shall relieve any public land claimant from the necessity of making payment of fees, commissions, or purchase money required by law or regulation in connection with an application, selection, location, or lease of public lands in Alaska, and all such payments, when made, shall be covered into the Treasury of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9b1163b-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1942-10-09/ch584/s5"},"text":"Oct. 9, 1942, ch. 584, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/779"},"text":"56 Stat. 779","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9b1163c-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9b1163d-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9b1163e-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1942-10-09/ch584"},"text":"act Oct. 9, 1942, ch. 584","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/778"},"text":"56 Stat. 778","children":[],"tail":", which enacted sections 79d and 123a of this title and sections 366 and 367 of Title 48, Territories and Insular Possessions, amended sections 80 and 751b of this title, repealed sections 366 and 367 of Title 48, and enacted provisions formerly set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s366"},"text":"section 366 of Title 48","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9b1163f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s367a"},"text":"section 367a of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
