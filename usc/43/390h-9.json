{"tag":"section","attrib":{"id":"idc9d00fb4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–9"},"text":"§ 390h–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" San Francisco area water reclamation study","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d00fb5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the city and county of San Francisco, shall conduct a feasibility study of the potential for development of demonstration and permanent facilities to reclaim water in the San Francisco area for the purposes of export and reuse elsewhere in California.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d00fb6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the costs of the study authorized by this section shall not exceed 50 per centum of the total.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d00fb7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–9/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit the report authorized by this section to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives not later than five years after appropriation of funds authorized by sections 390h to 390h–39 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d00fb8-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s1611"},"text":"Pub. L. 102–575, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-30"},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4667"},"text":"106 Stat. 4667","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s16/a/2"},"text":"Pub. L. 103–437, § 16(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4594"},"text":"108 Stat. 4594","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/266/s6"},"text":"Pub. L. 104–266, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3296"},"text":"110 Stat. 3296","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d00fb9-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d00fba-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9d00fbb-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/266"},"text":"Pub. L. 104–266","children":[],"tail":" substituted “five” for “four”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" substituted “Natural Resources” for “Interior and Insular Affairs” before “of the House”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
