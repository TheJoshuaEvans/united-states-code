{"tag":"section","attrib":{"id":"idc9c8e3e7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s375f"},"text":null,"children":[{"tag":"num","attrib":{"value":"375f"},"text":"§ 375f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to perform any and all acts and to make rules and regulations necessary and proper for carrying out the purposes of sections 375b to 375f of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9c8e3e8-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-31/ch78/s5"},"text":"Mar. 31, 1950, ch. 78, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/40"},"text":"64 Stat. 40","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
