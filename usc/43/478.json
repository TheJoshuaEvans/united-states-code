{"tag":"section","attrib":{"id":"idc9e5934c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s478"},"text":null,"children":[{"tag":"num","attrib":{"value":"478"},"text":"§ 478.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pecuniary penalty for nonpayment of installments of construction charges","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any water-right applicant or entryman shall have, prior to ","children":[{"tag":"date","attrib":{"date":"1924-12-05"},"text":"December 5, 1924","children":[],"tail":", failed to pay any installment of his construction charges when due, there shall be added to the amount unpaid a penalty of 1 per centum thereof, and there shall be added a like penalty of 1 per centum of the amount unpaid on the first day of each month thereafter so long as such default shall have continued: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the penalty of 1 per centum per month against delinquent accounts, is reduced to one-half of 1 per centum per month, as to all installments which may become due after "},{"tag":"date","attrib":{"date":"1924-12-05"},"text":"December 5, 1924","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9e5934d-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-08-13/ch247/s3"},"text":"Aug. 13, 1914, ch. 247, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/687"},"text":"38 Stat. 687","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1924-12-05/ch4/s4"},"text":"Dec. 5, 1924, ch. 4, § 4","children":[],"tail":", subsec. H, "},{"tag":"ref","attrib":{"href":"/us/stat/43/703"},"text":"43 Stat. 703","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9e5934e-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9e5934f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9e59350-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates first sentence of act ","children":[{"tag":"date","attrib":{"date":"1914-08-13"},"text":"Aug. 13, 1914","children":[],"tail":", § 3, with act "},{"tag":"date","attrib":{"date":"1924-12-05"},"text":"Dec. 5, 1924","children":[],"tail":", § 4, subsec. H."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
