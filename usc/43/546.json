{"tag":"section","attrib":{"id":"idc9ef097e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s546"},"text":null,"children":[{"tag":"num","attrib":{"value":"546"},"text":"§ 546.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of district court for enforcement of this subchapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Jurisdiction of suits by the United States for the enforcement of the provisions of this subchapter is conferred on the United States district courts of the districts in which the lands are situated.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9ef097f-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1912-08-09/ch278/s5"},"text":"Aug. 9, 1912, ch. 278, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/267"},"text":"37 Stat. 267","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
