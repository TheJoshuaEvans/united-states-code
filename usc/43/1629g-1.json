{"tag":"section","attrib":{"id":"idca5f30d2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1629g–1"},"text":"§ 1629g–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alaska Native Vietnam era veterans land allotment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca5f30d3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca5f30d4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Available Federal land","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f30d5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “available Federal land” means Federal land in the State that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca5f30d6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is vacant, unappropriated, and unreserved and is identified as available for selection under subsection (b)(5); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f30d7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has been selected by, but not yet conveyed to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca5f30d8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State, if the State agrees to voluntarily relinquish the selection of the Federal land for selection by an eligible individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca5f30d9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Regional Corporation or a Village Corporation, if the Regional Corporation or Village Corporation agrees to voluntarily relinquish the selection of the Federal land for selection by an eligible individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f30da-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “available Federal land” does not include any Federal land in the State that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca5f30db-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca5f30dc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a right-of-way of the TransAlaska Pipeline; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca5f30dd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an inner or outer corridor of such a right-of-way;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f30de-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdrawn or acquired for purposes of the Armed Forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f30df-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under review for a pending right-of-way for a natural gas corridor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f30e0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the Arctic National Wildlife Refuge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f30e1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within a unit of the National Forest System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f30e2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designated as wilderness by Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f30e3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within a unit of the National Park System, a National Preserve, or a National Monument;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f30e4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/1/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within a component of the National Trails System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f30e5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/1/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within a component of the National Wild and Scenic Rivers System; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f30e6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/1/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the National Petroleum Reserve–Alaska.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f30e7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible individual” means an individual who, as determined by the Secretary in accordance with subsection (c)(1), is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f30e8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a Native veteran—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca5f30e9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who served in the Armed Forces during the period between ","children":[{"tag":"date","attrib":{"date":"1964-08-05"},"text":"August 5, 1964","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1971-12-31"},"text":"December 31, 1971","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f30ea-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has not received an allotment made pursuant to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca5f30eb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1906-05-17"},"text":"May 17, 1906","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/34/197"},"text":"34 Stat. 197","children":[],"tail":", chapter 2469) (as in effect on "},{"tag":"date","attrib":{"date":"1971-12-17"},"text":"December 17, 1971","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca5f30ec-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1613/h/5"},"text":"section 1613(h)(5) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca5f30ed-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/2/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1629g"},"text":"section 1629g of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f30ee-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is ","children":[{"tag":"ref","attrib":{"idref":"fn002132"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002132"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “is” probably should not appear."}],"tail":" the personal representative of the estate of a deceased eligible individual described in subparagraph (A), who has been duly appointed in the appropriate Alaska State court or a registrar has qualified, acting for the benefit of the heirs of the estate of a deceased eligible individual described in subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f30ef-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native; Regional Corporation; Village Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Native”, “Regional Corporation”, and “Village Corporation” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f30f0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the State of Alaska.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f30f1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veteran","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “veteran” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca5f30f2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments for eligible individuals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca5f30f3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to determine eligibility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f30f4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary of Defense, in coordination with the Secretary of Veterans Affairs, shall provide to the Secretary a list of all members of the Armed Forces who served during the period between "},{"tag":"date","attrib":{"date":"1964-08-05"},"text":"August 5, 1964","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1971-12-31"},"text":"December 31, 1971","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f30f5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use the information provided under subparagraph (A) to determine whether an individual meets the military service requirements under subsection (a)(2)(A)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f30f6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach and assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in coordination with the Secretary of Veterans Affairs, shall conduct outreach, and provide assistance in applying for allotments, to eligible individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f30f7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall promulgate regulations to carry out this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f30f8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection by eligible individuals","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f30f9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca5f30fa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may select 1 parcel of not less than 2.5 acres and not more than 160 acres of available Federal land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f30fb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on making a selection pursuant to clause (i), shall submit to the Secretary an allotment selection application for the applicable parcel of available Federal land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f30fc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible individual may apply for an allotment during the 10-year period beginning on the effective date of the final regulations issued under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f30fd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicting selections","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If 2 or more eligible individuals submit to the Secretary an allotment selection application under paragraph (3)(A)(ii) for the same parcel of available Federal land, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f30fe-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give preference to the selection application received on the earliest date; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f30ff-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to each eligible individual the selection application of whom is rejected under subparagraph (A) an opportunity to select a substitute parcel of available Federal land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f3100-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of available Federal land administered by the Bureau of Land Management","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f3101-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary, in consultation with the State, Regional Corporations, and Village Corporations, shall identify Federal land administered by the Bureau of Land Management as available Federal land for allotment selection in the State by eligible individuals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f3102-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification; survey","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca5f3103-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that the available Federal land identified under subparagraph (A) is free of known contamination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f3104-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" survey the available Federal land identified under subparagraph (A) into aliquot parts and lots, segregating all navigable and meanderable waters and land not available for allotment selection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f3105-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the date on which available Federal land is identified under subparagraph (A), the Secretary shall submit to Congress, and publish in the Federal Register, 1 or more maps depicting the identified available Federal land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f3106-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any available Federal land conveyed to an eligible individual under this paragraph shall be subject to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca5f3107-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/5/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" valid existing rights; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f3108-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/5/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reservation of minerals to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f3109-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intent of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the intent of Congress that not later than 1 year after the date on which an eligible individual submits an allotment selection application for available Federal land that meets the requirements of this section, as determined by the Secretary, the Secretary shall issue to the eligible individual a certificate of allotment with respect to the available Federal land covered by the allotment selection application, subject to the requirements of subparagraph (D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca5f310a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of available Federal land in units of the National Wildlife Refuge System","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca5f310b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f310c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a study to determine whether any additional Federal lands within units of the National Wildlife Refuge System in the State should be made available for allotment selection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f310d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report the findings and conclusions of the study to Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f310e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of the report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall include in the report required under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f310f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary’s determination whether Federal lands within units of the National Wildlife Refuge System in the State should be made available for allotment selection by eligible individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f3110-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of the specific areas (including maps) within units of the National Wildlife Refuge System in the State that the Secretary determines should be made available, consistent with the mission of the National Wildlife Refuge System and the specific purposes for which the unit was established, and this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f3111-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors to be considered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether Federal lands within units of the National Wildlife Refuge System in the State should be made available under paragraph (1)(A), the Secretary shall take into account—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f3112-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proximity of the Federal land made available for allotment selection under subsection (b)(5) to eligible individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f3113-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proximity of the units of the National Wildlife Refuge System in the State to eligible individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f3114-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of additional Federal land within units of the National Wildlife Refuge System in the State that the Secretary estimates would be necessary to make allotments available for selection by eligible individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f3115-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identifying Federal land in units of the National Wildlife Refuge System","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In identifying whether Federal lands within units of the National Wildlife Refuge System in the State should be made available for allotment under paragraph (2)(B), the Secretary shall not identify any Federal land in a unit of the National Wildlife Refuge System—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f3116-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the conveyance of which, independently or as part of a group of allotments—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca5f3117-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could significantly interfere with biological, physical, cultural, scenic, recreational, natural quiet, or subsistence values of the unit of the National Wildlife Refuge System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f3118-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could obstruct access by the public or the Fish and Wildlife Service to the resource values of the unit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f3119-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could trigger development or future uses in an area that would adversely affect resource values of the surrounding National Wildlife Refuge System land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f311a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could open an area of a unit to new access and uses that adversely affect resources values of the unit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f311b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/4/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could interfere with the management plan of the unit;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f311c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located within 300 feet from the shore of a navigable water body;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f311d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not consistent with the purposes for which the unit of the National Wildlife Refuge System was established;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f311e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is designated as wilderness by Congress; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f311f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is within the Arctic National Wildlife Refuge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca5f3120-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No Federal land may be identified for selection or made available for allotment within a unit of the National Wildlife Refuge System unless it has been authorized by an Act of Congress subsequent to ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":". Further, any proposed conveyance of land within a unit of the National Wildlife Refuge System must have been identified by the Secretary in accordance with subsection (c)(4) in the report to Congress required by subsection (c) and include patent provisions that the land remains subject to the laws and regulations governing the use and development of the Refuge."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca617a11-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tI/s1119"},"text":"Pub. L. 116–9, title I, § 1119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/630"},"text":"133 Stat. 630","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/63/s2"},"text":"Pub. L. 119–63, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1983"},"text":"139 Stat. 1983","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca617a12-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca617a13-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca617a14-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1906-05-17"},"text":"May 17, 1906","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"1971-12-17"},"text":"December 17, 1971","children":[],"tail":", referred to in subsec. (a)(2)(A)(ii)(I), means "},{"tag":"ref","attrib":{"href":"/us/act/1906-05-17/ch2469"},"text":"act May 17, 1906, ch. 2469","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/197"},"text":"34 Stat. 197","children":[],"tail":", which was classified to sections 270–1 to 270–3 of this title prior to its repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/92/203/s18/a"},"text":"Pub. L. 92–203, § 18(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/710"},"text":"85 Stat. 710","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca617a15-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the John D. Dingell, Jr. Conservation, Management, and Recreation Act, and not as part of the Alaska Native Claims Settlement Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca617a16-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/63"},"text":"Pub. L. 119–63","children":[],"tail":" substituted “10-year period” for “5-year period”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca617a17-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idca617a18-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” means the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2"},"text":"section 2 of Pub. L. 116–9","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"section 1 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
