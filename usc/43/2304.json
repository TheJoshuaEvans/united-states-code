{"tag":"section","attrib":{"id":"idca8c82c1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2304"},"text":null,"children":[{"tag":"num","attrib":{"value":"2304"},"text":"§ 2304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of public land","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8c82c2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program, using funds made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2305"},"text":"section 2305 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8c82c3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to complete appraisals and satisfy other legal requirements for the sale or exchange of public land identified for disposal under approved land use plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1712"},"text":"section 1712 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c82c4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":", to establish and make available to the public, on the website of the Department of the Interior, a database containing a comprehensive list of all the land referred to in paragraph (1); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c82c5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2304/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain the database referred to in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c82c6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of public land","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8c82c7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sale of public land so identified shall be conducted in accordance with sections 1713 and 1719 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c82c8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions to competitive bidding requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The exceptions to competitive bidding requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1713/f"},"text":"section 1713(f) of this title","children":[],"tail":" shall apply to this section in cases in which the Secretary determines it to be necessary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c82c9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report in Public Land Statistics","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide in the annual publication of Public Land Statistics, a report of activities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8c82ca-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/248/tII/s205"},"text":"Pub. L. 106–248, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-25"},"text":"July 25, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/615"},"text":"114 Stat. 615","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/212/tIII/s3007/a"},"text":"Pub. L. 111–212, title III, § 3007(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2339"},"text":"124 Stat. 2339","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dO/tIII/s302/4"},"text":"Pub. L. 115–141, div. O, title III, § 302(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1075"},"text":"132 Stat. 1075","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca8c82cb-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca8c82cc-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca8c82cd-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s302/4/A"},"text":"Pub. L. 115–141, § 302(4)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t43/s2305"},"text":"section 2305 of this title","children":[],"tail":"—” and pars. (1) to (3) for “"},{"tag":"ref","attrib":{"href":"/us/usc/t43/s2305"},"text":"section 2305 of this title","children":[],"tail":", to complete appraisals and satisfy other legal requirements for the sale or exchange of public land identified for disposal under approved land use plans (as in effect on "},{"tag":"date","attrib":{"date":"2000-07-25"},"text":"July 25, 2000","children":[],"tail":") under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1712"},"text":"section 1712 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s302/4/B"},"text":"Pub. L. 115–141, § 302(4)(B)","children":[],"tail":", struck out subsec. (d). Text read as follows: “The authority provided under this section shall terminate 11 years after "},{"tag":"date","attrib":{"date":"2000-07-25"},"text":"July 25, 2000","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/212"},"text":"Pub. L. 111–212","children":[],"tail":" substituted “11 years” for “10 years”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
