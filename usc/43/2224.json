{"tag":"section","attrib":{"id":"idca8c8259-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2224"},"text":null,"children":[{"tag":"num","attrib":{"value":"2224"},"text":"§ 2224.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8c825a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2224/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit each plan prepared pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2222"},"text":"section 2222 of this title","children":[],"tail":" to the Congress, together with the Secretary’s recommendations, including recommendations for authorizing legislation, if needed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c825b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2224/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pacific Northwest region","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A contingency plan under subsection (a) for the State of Washington, Oregon, Idaho, or Montana, may be approved by the Secretary only at the request of the Governor of the affected State in coordination with the other States in the region and the Administrator of the Bonneville Power Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8c825c-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/250/tII/s204"},"text":"Pub. L. 102–250, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-05"},"text":"Mar. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/57"},"text":"106 Stat. 57","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
