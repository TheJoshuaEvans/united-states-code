{"tag":"section","attrib":{"id":"idc9aea573-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s43"},"text":null,"children":[{"tag":"num","attrib":{"value":"43"},"text":"§ 43.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copies to Senators, Representatives, and Delegates","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"One copy of each map and atlas shall be sent to each Senator and each Representative and Delegate in Congress, if published within his term; and a second copy shall be placed at the disposal of each such Senator, Representative and Delegate","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9aea574-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"date","attrib":{"date":"1897-02-18"},"text":"Feb. 18, 1897","children":[],"tail":", No. 13, § 2, "},{"tag":"ref","attrib":{"href":"/us/stat/29/701"},"text":"29 Stat. 701","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
