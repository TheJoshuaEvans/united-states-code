{"tag":"section","attrib":{"id":"idc9d73bef-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s395"},"text":null,"children":[{"tag":"num","attrib":{"value":"395"},"text":"§ 395.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions by State, municipality, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All moneys received after ","children":[{"tag":"date","attrib":{"date":"1921-03-04"},"text":"March 4, 1921","children":[],"tail":", from any State, municipality, corporation, association, firm, district, or individual for investigations, surveys, construction work, or any other development work incident thereto involving operations similar to those provided for by the reclamation law shall be covered into the reclamation fund and shall be available for expenditure for the purposes for which contributed in like manner as if said sums had been specifically appropriated for said purposes."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9d73bf0-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-03-04/ch161"},"text":"Mar. 4, 1921, ch. 161","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1404"},"text":"41 Stat. 1404","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d73bf1-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d73bf2-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9d73bf3-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The reclamation law, referred to in text, is identified in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-03-04/ch161"},"text":"act Mar. 4, 1921, ch. 161","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1402"},"text":"41 Stat. 1402","children":[],"tail":", under the heading “"},{"tag":"inline","attrib":{},"text":"reclamation service","children":[],"tail":"”, as "},{"tag":"ref","attrib":{"href":"/us/act/1902-06-17/ch1093"},"text":"act June 17, 1902, ch. 1093","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/388"},"text":"32 Stat. 388","children":[],"tail":", and Acts amendatory thereof or supplementary thereto. Act "},{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":", popularly known as the Reclamation Act, is classified generally to this chapter. For complete classification of act "},{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":", to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
