{"tag":"section","attrib":{"id":"idca9ab339-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202"},"text":null,"children":[{"tag":"num","attrib":{"value":"3202"},"text":"§ 3202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water storage, groundwater storage, and conveyance projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca9ab33a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9ab33b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasibility studies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab33c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A feasibility study shall only be eligible for funding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s3201/1"},"text":"section 3201(1) of this title","children":[],"tail":" if—"}],"tail":null},{"tag":"clause","attrib":{"id":"idca9ab33d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility study has been authorized by an Act of Congress before ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab33e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress has approved funding for the feasibility study in accordance with section 4007 of the Water Infrastructure Improvements for the Nation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390b"},"text":"43 U.S.C. 390b","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Public Law 114–322","children":[],"tail":") before "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab33f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility study is authorized under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab340-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasibility study authorizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may carry out feasibility studies for the following projects:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca9ab341-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Verde Reservoirs Sediment Mitigation Project in the State of Arizona.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab342-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Tualatin River Basin Project in the State of Oregon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab343-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project shall only be eligible for construction funding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s3201/1"},"text":"section 3201(1) of this title","children":[],"tail":" if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab344-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Act of Congress enacted before ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", authorizes construction of the project;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab345-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Congress has approved funding for construction of the project in accordance with section 4007 of the Water Infrastructure Improvements for the Nation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390b"},"text":"43 U.S.C. 390b","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Public Law 114–322","children":[],"tail":") before "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", except for any project for which—"}],"tail":null},{"tag":"clause","attrib":{"id":"idca9ab346-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress did not approve the recommendation of the Secretary for funding under subsection (h)(2) of that section for at least 1 fiscal year before ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab347-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State funding for the project was rescinded by the State before ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab348-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca9ab349-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress has authorized or approved funding for a feasibility study for the project in accordance with clause (i) or (ii) of paragraph (1)(A) (except that projects described in clauses (i) and (ii) of subparagraph (B) shall not be eligible); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab34a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on completion of the feasibility study for the project, the Secretary—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca9ab34b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" finds the project to be technically and financially feasible in accordance with the reclamation laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca9ab34c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that sufficient non-Federal funding is available for the non-Federal cost share of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca9ab34d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/2/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"item","attrib":{"id":"idca9ab34e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/2/C/ii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" finds the project to be in the public interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idca9ab34f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/a/2/C/ii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommends the project for construction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab350-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9ab351-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal share—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab352-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a project authorized by an Act of Congress shall be determined in accordance with that Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab353-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a project approved by Congress in accordance with section 4007 of the Water Infrastructure Improvements for the Nation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390b"},"text":"43 U.S.C. 390b","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Public Law 114–322","children":[],"tail":") (including construction resulting from a feasibility study authorized under that Act) shall be as provided in that Act; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab354-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for a project not described in subparagraph (A) or (B)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca9ab355-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a federally owned project, shall not exceed 50 percent of the total cost of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab356-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a non-Federal project, shall not exceed 25 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab357-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before funding a project under this section, the Secretary shall determine that, in return for the Federal investment in the project, at least a proportionate share of the benefits are Federal benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab358-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reimbursability of Federal funding of projects under this section shall be in accordance with the reclamation laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9ab359-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing funding for a project under this section, the Secretary shall comply with all applicable environmental laws, including the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca9ab35a-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIX/s40902"},"text":"Pub. L. 117–58, div. D, title IX, § 40902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1118"},"text":"135 Stat. 1118","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca9ab35b-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca9ab35c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca9ab35d-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Water Infrastructure Improvements for the Nation Act, referred to in subsec. (b)(1)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Pub. L. 114–322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1628"},"text":"130 Stat. 1628","children":[],"tail":", also known as the WIIN Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of Title 33","children":[],"tail":", Navigation and Navigable Waters, and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca9ab35e-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca9ab35f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
