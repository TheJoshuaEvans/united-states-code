{"tag":"section","attrib":{"id":"idc9faf0ab-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s618g"},"text":null,"children":[{"tag":"num","attrib":{"value":"618g"},"text":"§ 618g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations; contracts; modification of allotments of energy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized from time to time to promulgate such regulations and enter into such contracts as he may find necessary or appropriate for carrying out the purposes of this subchapter and the Project Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s617"},"text":"43 U.S.C. 617","children":[],"tail":" et seq.], as modified hereby, and, by mutual consent, to terminate or modify any such contract: "},{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That no allotment of energy to any allottee made by any rule or regulation heretofore promulgated shall be modified or changed without the consent of such allottee."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9faf0ac-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-07-19/ch643/s8"},"text":"July 19, 1940, ch. 643, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/777"},"text":"54 Stat. 777","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9faf0ad-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9faf0ae-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9faf0af-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Project Act, referred to in text, is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s618k"},"text":"section 618k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
