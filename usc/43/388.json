{"tag":"section","attrib":{"id":"idc9c8e447-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s388"},"text":null,"children":[{"tag":"num","attrib":{"value":"388"},"text":"§ 388.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts for materials; liability of United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When appropriations have been made for the commencement or continuation of construction or operation and maintenance of any project, the Secretary may, in connection with such construction or operation and maintenance, enter into contracts for miscellaneous services, for materials and supplies, as well as for construction, which may cover such periods of time as the Secretary may consider necessary but in which the liability of the United States shall be contingent upon appropriations being made therefor.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9c8e448-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-04/ch418/s12"},"text":"Aug. 4, 1939, ch. 418, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1197"},"text":"53 Stat. 1197","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9c8e449-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9c8e44a-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idc9c8e44b-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s485a"},"text":"section 485a of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
