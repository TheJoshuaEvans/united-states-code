{"tag":"section","attrib":{"id":"idca913d35-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2429"},"text":null,"children":[{"tag":"num","attrib":{"value":"2429"},"text":"§ 2429.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records; audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca913d36-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2429/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A recipient of a loan guarantee shall keep such records and other pertinent documents as the Secretary shall prescribe by regulation, including such records as the Secretary may require to facilitate an effective audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913d37-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2429/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Comptroller General of the United States, or their duly authorized representatives, shall have access, for the purpose of audit, to the records and other pertinent documents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca913d38-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/451/tII/s210"},"text":"Pub. L. 109–451, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3360"},"text":"120 Stat. 3360","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
