{"tag":"section","attrib":{"id":"idca403715-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1555"},"text":null,"children":[{"tag":"num","attrib":{"value":"1555"},"text":"§ 1555.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Power Act inapplicable to Colorado River between Hoover Dam and Glen Canyon Dam","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Part I of the Federal Power Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s791a"},"text":"16 U.S.C. 791a","children":[],"tail":" et seq.] shall not be applicable to the reaches of the main stream of the Colorado River between Hoover Dam and Glen Canyon Dam until and unless otherwise provided by Congress."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca403716-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/537/tVI/s605"},"text":"Pub. L. 90–537, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-09-30"},"text":"Sept. 30, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/901"},"text":"82 Stat. 901","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca403717-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca403718-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca403719-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Power Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"act June 10, 1920, ch. 285","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1063"},"text":"41 Stat. 1063","children":[],"tail":". Part I of the Federal Power Act is classified generally to subchapter I (§ 791a et seq.) of chapter 12 of Title 16, Conservation. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s791a"},"text":"section 791a of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
