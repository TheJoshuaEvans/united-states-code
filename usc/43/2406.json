{"tag":"section","attrib":{"id":"idca913cc4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2406"},"text":null,"children":[{"tag":"num","attrib":{"value":"2406"},"text":"§ 2406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca913cc5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2406/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into contracts, financial assistance agreements, and such other agreements, and promulgate such regulations, as are necessary to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913cc6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2406/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter authorizes the transfer of pre-existing facilities or pre-existing components of any water system from Federal to private ownership or from private to Federal ownership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913cc7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2406/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal reclamation law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter supersedes or amends any Federal law associated with a project, or portion of a project, constructed under Federal reclamation law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913cc8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2406/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate the Program carried out under this subchapter with existing Federal and State rural water and wastewater programs to facilitate the most efficient and effective solution to meeting the water needs of the non-Federal project sponsors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913cc9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2406/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple Indian tribes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which a contract is entered into with, or a grant is made, to ","children":[{"tag":"ref","attrib":{"idref":"fn002179"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002179"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should follow “to”."}],"tail":" an organization to perform services benefitting more than 1 Indian tribe under this subchapter, the approval of each such Indian tribe shall be a prerequisite to entering into the contract or making the grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913cca-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2406/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership of facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Title to any facility planned, designed, and recommended for construction under this subchapter shall be held by the non-Federal project entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913ccb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2406/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that a community to be served by a proposed rural water supply project has urgent and compelling water needs, the Secretary shall, to the maximum extent practicable, expedite appraisal investigations and reports conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2404"},"text":"section 2404 of this title","children":[],"tail":" and feasibility studies and reports conducted under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s2405"},"text":"section 2405 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913ccc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2406/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on State water law","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca913ccd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2406/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter preempts or affects State water law or an interstate compact governing water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913cce-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2406/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall comply with State water laws in carrying out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913ccf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2406/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No additional requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter requires a feasibility study for, or imposes any other additional requirements with respect to, rural water supply projects or programs that are authorized before ","children":[{"tag":"date","attrib":{"date":"2006-12-22"},"text":"December 22, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca913cd0-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/451/tI/s107"},"text":"Pub. L. 109–451, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3355"},"text":"120 Stat. 3355","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
