{"tag":"section","attrib":{"id":"idc9d9ac65-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s412"},"text":null,"children":[{"tag":"num","attrib":{"value":"412"},"text":"§ 412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prerequisites to initiation of project or division of project","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"1924-12-05"},"text":"December 5, 1924","children":[],"tail":", no new project or new division of a project shall be approved for construction or estimates submitted therefor by the Secretary until information in detail shall be secured by him concerning the water supply, the engineering features, the cost of construction, land prices, and the probable cost of development, and he shall have made a finding in writing that it is feasible, that it is adaptable for actual settlement and farm homes, and that it will probably return the cost thereof to the United States."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9d9ac66-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1924-12-05/ch4/s4"},"text":"Dec. 5, 1924, ch. 4, § 4","children":[],"tail":", subsec. B, "},{"tag":"ref","attrib":{"href":"/us/stat/43/702"},"text":"43 Stat. 702","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d9ac67-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9d9ac68-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idc9d9ac69-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
