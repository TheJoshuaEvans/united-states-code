{"tag":"section","attrib":{"id":"idc9d28168-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–19"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–19"},"text":"§ 390h–19.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Williamson County, Texas, water recycling and reuse project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d28169-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–19/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the Lower Colorado River Authority, Texas, is authorized to participate in the design, planning, and construction of permanent facilities to reclaim and reuse water in Williamson County, Texas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d2816a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–19/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the costs of the project described in subsection (a) shall not exceed 25 percent of the total cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d2816b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–19/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not provide funds for the operation and maintenance of the project described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d2816c-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s1637"},"text":"Pub. L. 102–575, title XVI, § 1637","children":[],"tail":", formerly § 1636, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/316/s1/b"},"text":"Pub. L. 108–316, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-05"},"text":"Oct. 5, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1202"},"text":"118 Stat. 1202","children":[],"tail":"; renumbered § 1637, "},{"tag":"ref","attrib":{"href":"/us/pl/109/70/s2/a/1"},"text":"Pub. L. 109–70, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-09-21"},"text":"Sept. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2009"},"text":"119 Stat. 2009","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d2816d-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d2816e-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9d2816f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390h–17a"},"text":"section 390h–17a of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/109/70"},"text":"Pub. L. 109–70","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],