{"tag":"section","attrib":{"id":"idca913d39-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2430"},"text":null,"children":[{"tag":"num","attrib":{"value":"2430"},"text":"§ 2430.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full faith and credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The full faith and credit of the United States is pledged to the payment of all guarantees issued under this section with respect to principal and interest.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca913d3a-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/451/tII/s211"},"text":"Pub. L. 109–451, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3360"},"text":"120 Stat. 3360","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
