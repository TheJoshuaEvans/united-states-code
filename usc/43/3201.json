tag":"date","attrib":{"date":"2021-07-01"},"text":"July 1, 2021","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab328-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3201/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selected for funding under the program authorized pursuant to section 4(a) of the Water Desalination Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10301"},"text":"42 U.S.C. 10301","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/104/298"},"text":"Public Law 104–298","children":[],"tail":"), with funding to be made available under this paragraph in accordance with that subsection, notwithstanding section 4013 of the Water Infrastructure Improvements for the Nation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s390b"},"text":"43 U.S.C. 390b","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Public Law 114–322","children":[],"tail":"), except that paragraph (2)(F) of section 4(a) of the Water Desalination Act of 1996 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10301"},"text":"42 U.S.C. 10301","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/104/298"},"text":"Public Law 104–298","children":[],"tail":") (as redesignated by section 40908) shall not apply to amounts made available under this paragraph;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9ab329-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3201/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500,000,000 for the safety of dams program, in accordance with the Reclamation Safety of Dams Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s506"},"text":"43 U.S.C. 506","children":