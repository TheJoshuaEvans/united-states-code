nt","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/392"},"text":"Public Law 106–392","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/114/1602"},"text":"114 Stat. 1602","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab331-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3201/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Grand Canyon Protection Act of 1992 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575"},"text":"Public Law 102–575","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/106/4669"},"text":"106 Stat. 4669","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9ab332-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3201/12/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subtitle E of title IX of the Omnibus Public Land Management Act of 2009 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Public Law 111–11","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/123/1327"},"text":"123 Stat. 1327","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca9ab333-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIX/s40901"},"text":"Pub. L. 117–58, div. D, title IX, § 40901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1116"},"text":"135 Stat. 1116","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca9ab334-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca9ab335-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca9ab336-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in introductory provisions, was in the original “this title”, meaning title IX of div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which is classified principally to this chapter. For complete classification of title IX of div. D of "},{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Reclamation Rural Water Supply Act of 2006, referred to in par. (3), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/451"},"text":"Pub. L. 109–451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3346"},"text":"120 Stat. 3346","children":[],"tail":", which is classified generally to subchapter I (§ 2401 et seq.) of chapter 42 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s2401"},"text":"section 2401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Reclamation Wastewater and Groundwater Study and Facilities Act, referred to in par. (4)(A), is title XVI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575"},"text":"Pub. L. 102–575","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-30"},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4663"},"text":"106 Stat. 4663","children":[],"tail":", which enacted sections 390h to 390h–15 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s390h"},"text":"section 390h of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 40908, referred to in par. (5)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40908"},"text":"section 40908 of Pub. L. 117–58","children":[],"tail":", div. D, title IX, "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1126"},"text":"135 Stat. 1126","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/298/s4/a"},"text":"section 4(a) of Pub. L. 104–298","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10301"},"text":"section 10301 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Reclamation Safety of Dams Act of 1978, referred to in par. (6), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/578"},"text":"Pub. L. 95–578","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2471"},"text":"92 Stat. 2471","children":[],"tail":", which is classified principally to subchapter XI–A (§ 506 et seq.) of chapter 12 of this title. For complete classification of this Act to the Code, see Short Title of 1978 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s506"},"text":"section 506 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Colorado River Drought Contingency Plan Authorization Act, referred to in par. (8), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/14"},"text":"Pub. L. 116–14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-04-16"},"text":"Apr. 16, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/850"},"text":"133 Stat. 850","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Omnibus Public Land Management Act of 2009, referred to in pars. (9) and (12)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/991"},"text":"123 Stat. 991","children":[],"tail":". Subtitle A of title VI of the Act is classified generally to chapter 18A (§ 1015 et seq.) of Title 16, Conservation. Subtitle E of title IX of the Act is not classified to the Code. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Grand Canyon Protection Act of 1992, referred to in par. (12)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVIII"},"text":"Pub. L. 102–575, title XVIII","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-30"},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4669"},"text":"106 Stat. 4669","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca9ab337-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"i