"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" $1,000,000,000 for water recycling and reuse projects, of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9ab322-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3201/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" $550,000,000 shall be made available for water recycling and reuse projects authorized in accordance with the Reclamation Wastewater and Groundwater Study and Facilities Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390h"},"text":"43 U.S.C. 390h","children":[],"tail":" et seq.) that are—"}],"tail":null},{"tag":"clause","attrib":{"id":"idca9ab323-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3201/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized or approved for construction funding by an Act of Congress before ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca9ab324-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3201/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selected for funding under the competitive grant program authorized pursuant to section 1602(f) of the Reclamation Wastewater and Groundwater Study and Facilities Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390h/f"},"text":"43 U.S.C. 390h(f)","children":[],"tail":"), with funding under this subparagraph to be provided in accordance with that section, notwithstanding section 4013 of the Water Infrastructure Improvements for the Nation Act ("},{"tag":"ref","attrib":{"href":"/us/u