{"tag":"section","attrib":{"id":"idca390b70-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1474a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1474a"},"text":"§ 1474a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency Department of the Interior Firefighting Fund; amounts considered “emergency requirements”","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1991-11-13"},"text":"November 13, 1991","children":[],"tail":", beginning in fiscal year 1993, and in each year thereafter, only amounts for emergency rehabilitation and wildfire suppression activities that are in excess of the average of such costs for the previous ten years shall be considered “emergency requirements” pursuant to section 901(b)(2)(D) "},{"tag":"ref","attrib":{"idref":"fn002095"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002095"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 2, and such amounts shall on and after "},{"tag":"date","attrib":{"date":"1991-11-13"},"text":"November 13, 1991","children":[],"tail":", be so designated."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca390b71-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/154/tI"},"text":"Pub. L. 102–154, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-13"},"text":"Nov. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/991"},"text":"105 Stat. 991","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca390b72-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca390b73-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca390b74-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s901"},"text":"Section 901 of title 2","children":[],"tail":", referred to in text, was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tX/s10203/a/4"},"text":"Pub. L. 105–33, title X, § 10203(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/699"},"text":"111 Stat. 699","children":[],"tail":", and by "},{"tag":"ref","attrib":{"href":"/us/pl/112/25/tI/s101"},"text":"Pub. L. 112–25, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-08-02"},"text":"Aug. 2, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/241"},"text":"125 Stat. 241","children":[],"tail":". As so amended, "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s901/b/2/D"},"text":"section 901(b)(2)(D) of title 2","children":[],"tail":" no longer refers to “emergency requirements”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
