{"tag":"section","attrib":{"id":"idc9aea5b3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s50d"},"text":null,"children":[{"tag":"num","attrib":{"value":"50d"},"text":"§ 50d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services of students or recent graduates","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States Geological Survey may on and after ","children":[{"tag":"date","attrib":{"date":"1999-11-29"},"text":"November 29, 1999","children":[],"tail":", contract directly with individuals or indirectly with institutions or nonprofit organizations, without regard to "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":", for the temporary or intermittent services of students or recent graduates, who shall be considered employees for the purposes of chapters 57 and 81 of title 5, relating to compensation for travel and work injuries, and chapter 171 of title 28, relating to tort claims, but shall not be considered to be Federal employees for any other purposes."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9aea5b4-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/3/tI"},"text":"Pub. L. 106–113, div. B, § 1000(a)(3) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–146.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9aea5b5-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9aea5b6-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","child