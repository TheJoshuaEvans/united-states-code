{"tag":"section","attrib":{"id":"idca913d01-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2423"},"text":null,"children":[{"tag":"num","attrib":{"value":"2423"},"text":"§ 2423.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan guarantees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca913d02-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2423/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Secretary may make available to lenders for a project meeting the eligibility criteria established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2422"},"text":"section 2422 of this title","children":[],"tail":" loan guarantees to supplement private-sector or lender financing for the project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913d03-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2423/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca913d04-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2423/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Loan guarantees under this section for a project shall be on such terms and conditions and contain such covenants, representations, warranties, and requirements as the Secretary determines to be appropriate to protect the financial interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913d05-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2423/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Loan guarantees by the Secretary shall not exceed an amount equal to 90 percent of the cost of the project that is the subject of the loan guarantee, as estimated at the time at which the loan guarantee is issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913d06-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2423/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An obligation shall bear interest at a rate that does not exceed a level that the Secretary determines to be appropriate, taking into account the prevailing rate of interest in the private sector for similar loans and risks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913d07-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2423/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amortization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan guarantee under this section shall provide for complete amortization of the loan guarantee within not more than 40 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913d08-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2423/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonsubordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An obligation shall be subject to the condition that the obligation is not subordinate to other financing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913d09-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2423/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prepayment and refinancing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any prepayment or refinancing terms on a loan guarantee shall be negotiated between the non-Federal borrower and the lender with the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca913d0a-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/451/tII/s204"},"text":"Pub. L. 109–451, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3358"},"text":"120 Stat. 3358","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
