{"tag":"section","attrib":{"id":"idc9c8e3e9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s376"},"text":null,"children":[{"tag":"num","attrib":{"value":"376"},"text":"§ 376.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of land donations not needed","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where real property or any interest therein heretofore has been, or hereafter shall be, donated and conveyed to the United States for use in connection with a project, and the Secretary decides not to utilize the donation, he is authorized without charge to reconvey such property or any part thereof to the donating grantor, or to the heirs, successors, or assigns of such grantor.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9c8e3ea-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1924-12-05/ch4/s4"},"text":"Dec. 5, 1924, ch. 4, § 4","children":[],"tail":", subsec. Q, "},{"tag":"ref","attrib":{"href":"/us/stat/43/704"},"text":"43 Stat. 704","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9c8e3eb-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9c8e3ec-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idc9c8e3ed-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
