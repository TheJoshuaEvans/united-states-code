{"tag":"section","attrib":{"id":"idc9ecbfc3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s509a"},"text":null,"children":[{"tag":"num","attrib":{"value":"509a"},"text":"§ 509a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project beneficiaries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9ecbfc4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s509a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of modification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On identifying a Bureau of Reclamation facility for modification, the Secretary shall provide to the project beneficiaries written notice—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9ecbfc5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s509a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the need for the modification and the process for identifying and implementing the modification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ecbfc6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s509a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summarizing the administrative and legal requirements relating to the modification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9ecbfc7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s509a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9ecbfc8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s509a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide project beneficiaries an opportunity to consult with the Bureau of Reclamation on the planning, design, and construction of the proposed modification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ecbfc9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s509a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with project beneficiaries, develop and provide timeframes for the consultation described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9ecbfca-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s509a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternatives","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9ecbfcb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s509a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prior to submitting the reports required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s509"},"text":"section 509 of this title","children":[],"tail":", the Secretary shall consider any alternative submitted in writing, in accordance with the timeframes established under subsection (b), by a project beneficiary that has elected to consult with the Bureau of Reclamation on a modification."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ecbfcc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s509a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide to the project beneficiary a timely written response describing proposed actions, if any, to address the recommendation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ecbfcd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s509a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The response of the Secretary shall be included in the reports required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s509"},"text":"section 509 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9ecbfce-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s509a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive 1 or more of the requirements of subsections (a), (b), and (c), if the Secretary determines that implementation of the requirement could have an adverse impact on dam safety or security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9ecbfcf-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/578/s5A"},"text":"Pub. L. 95–578, § 5A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/439/s2/b"},"text":"Pub. L. 108–439, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2627"},"text":"118 Stat. 2627","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
