{"tag":"section","attrib":{"id":"idca986939-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101"},"text":null,"children":[{"tag":"num","attrib":{"value":"3101"},"text":"§ 3101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca98693a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 3D","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “3D” means 3-dimensional.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca98693b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 3D elevation data","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca98693c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “3D elevation data” means 3D, high-resolution data obtained using LiDAR, IfSAR, or other methods over the United States (including territories).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca98693d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “3D elevation data” includes terrestrial and bathymetric elevation data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca98693e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 3D elevation program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “3D Elevation Program” means the 3D Elevation Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s3104/a"},"text":"section 3104(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca98693f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" IfSAR","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “IfSAR” means interferometric synthetic aperture radar.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca986940-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca986941-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lahar","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “lahar” means a large debris flow of mostly volcanic material that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca986942-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" often fast-moving; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca986943-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a hazard in watersheds downstream of volcanic peaks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca986944-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" LiDAR","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “LiDAR” means light detection and ranging.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca986945-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior, acting through the Director of the United States Geological Survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca986946-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca986947-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca986948-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca986949-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State office” means any unit of State government that handles the identification, mapping, assessment, and research of landslide hazards or responding to landslide events, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca98694a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State geological survey office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca98694b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State department of emergency response; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca98694c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State department of transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca98694d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territory","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “territory” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca98694e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commonwealth of Puerto Rico;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca98694f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Guam;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca986950-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" American Samoa;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca986951-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/11/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commonwealth of the Northern Mariana Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca986952-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/11/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federated States of Micronesia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca986953-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/11/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Republic of the Marshall Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca986954-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/11/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Republic of Palau; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca986955-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3101/11/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca986956-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/323/s2"},"text":"Pub. L. 116–323, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"ta