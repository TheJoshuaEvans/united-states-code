{"tag":"section","attrib":{"id":"idca748d17-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1748b–1"},"text":"§ 1748b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildfire technology modernization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca748d18-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this section is to promote the use of the best available technology to enhance the effective and cost-efficient response to wildfires—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca748d19-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet applicable protection objectives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca748d1a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to increase the safety of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca748d1b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" firefighters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca748d1c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca748d1d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca748d1e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretaries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretaries” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca748d1f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca748d20-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca748d21-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary concerned","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretary concerned” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca748d22-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, with respect to activities under the Department of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca748d23-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, with respect to activities under the Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca748d24-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unmanned aircraft systems","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca748d25-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the terms “unmanned aircraft” and “unmanned aircraft system” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44801"},"text":"section 44801 of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca748d26-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary, in consultation with the Secretary of Agriculture, shall establish a research, development, and testing program, or expand an applicable existing program, to assess unmanned aircraft system technologies, including optionally piloted aircraft, across the full range of wildland fire management operations in order to accelerate the deployment and integration of those technologies into the operations of the Secretaries."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca748d27-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanding use of unmanned aircraft systems on wildfires","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program established under paragraph (2), the Secretaries, in coordination with the Federal Aviation Administration, State wildland firefighting agencies, and other relevant Federal agencies, shall enter into an agreement under which the Secretaries shall develop consistent protocols and plans for the use on wildland fires of unmanned aircraft system technologies, including for the development of real-time maps of the location of wildland fires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca748d28-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location systems for wildland firefighters","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca748d29-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", subject to the availability of appropriations, the Secretaries, in coordination with State wildland firefighting agencies, shall jointly develop and operate a tracking system (referred to in this subsection as the “system”) to remotely locate the positions of fire resources for use by wildland firefighters, including, at a minimum, any fire resources assigned to Federal type 1 wildland fire incident management teams."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca748d2a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The system shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca748d2b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the most practical and effective technology available to the Secretaries to remotely track the location of an active resource, such as a Global Positioning System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca748d2c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depict the location of each fire resource on the applicable maps developed under subsection (c)(3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca748d2d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate continuously during the period for which any firefighting personnel are assigned to the applicable Federal wildland fire; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca748d2e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be subject to such terms and conditions as the Secretary concerned determines necessary for the effective implementation of the system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca748d2f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca748d30-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" before commencing operation of the system—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca748d31-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct not fewer than 2 pilot projects relating to the operation, management, and effectiveness of the system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca748d32-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the results of those pilot projects;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca748d33-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct training, and maintain a culture, such that an employee, officer, or contractor shall not rely on the system for safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca748d34-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish procedures for the collection, storage, and transfer of data collected under this subsection to ensure—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca748d35-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/d/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca748d36-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/d/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the privacy of wildland fire personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca748d37-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildland fire decision support","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca748d38-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protocol","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, the Secretaries shall ensure that wildland fire management activities conducted by the Secretaries, or conducted jointly by the Secretaries and State wildland firefighting agencies, achieve compliance with applicable incident management objectives in a manner that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca748d39-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimizes firefighter exposure to the lowest level necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca748d3a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces overall costs of wildfire incidents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca748d3b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildfire decision support system","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca748d3c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries, in coordination with State wildland firefighting agencies, shall establish a system or expand an existing system to track and monitor decisions made by the Secretaries or State wildland firefighting agencies in managing wildfires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca748d3d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The system established or expanded under subparagraph (A) shall be able to alert the Secretaries if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca748d3e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unusual costs are incurred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca748d3f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an action to be carried out would likely—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca748d40-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/e/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" endanger the safety of a firefighter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca748d41-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/e/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be ineffective in meeting an applicable suppression or protection goal; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca748d42-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a decision regarding the management of a wildfire deviates from—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca748d43-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/e/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicable protocol established by the Secretaries, including the requirement under paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca748d44-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/e/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicable spatial fire management plan or fire management plan of the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca748d45-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Smoke projections from active wildland fires","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretaries shall establish a program, to be known as the “Interagency Wildland Fire Air Quality Response Program”, under which the Secretary concerned—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca748d46-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, shall assign 1 or more air resource advisors to a type 1 incident management team managing a Federal wildland fire; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca748d47-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may assign 1 or more air resource advisors to a type 2 incident management team managing a wildland fire.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca748d48-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca748d49-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rapid Response Erosion Database","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca748d4a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries, in consultation with the Administrator of the National Aeronautics and Space Administration and the Secretary of Commerce, shall establish and maintain a database, to be known as the “Rapid Response Erosion Database” (referred to in this subsection as the “Database”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76fe4b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Open-source Database","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca76fe4c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretaries shall make the Database (including the original source code)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca76fe4d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/h/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" web-based; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca76fe4e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/h/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available without charge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca76fe4f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, the Database shall provide for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca76fe50-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/h/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the automatic incorporation of spatial data relating to vegetation, soils, and elevation into an applicable map created by the Secretary concerned that depicts the changes in land-cover and soil properties caused by a wildland fire; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca76fe51-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/h/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the generation of a composite map that can be used by the Secretary concerned to model the effectiveness of treatments in the burned area to prevent flooding, erosion, and landslides under a range of weather scenarios.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76fe52-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned shall use the Database, as applicable, in developing recommendations for emergency stabilization treatments or modifications to drainage structures to protect values-at-risk following a wildland fire.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76fe53-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries may share the Database, and any results generated in using the Database, with any State or unit of local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca76fe54-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Predicting where wildfires will start","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca76fe55-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries, in consultation with the Administrator of the National Aeronautics and Space Administration, the Secretary of Energy, and the Secretary of Commerce, through the capabilities and assets located at the National Laboratories, shall establish and maintain a system to predict the locations of future wildfires for fire-prone areas of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76fe56-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation; components","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The system established under paragraph (1) shall be based on, and seek to enhance, similar systems in existence on ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", including the Fire Danger Assessment System."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76fe57-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use in forecasts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretaries shall use the system established under paragraph (1), to the maximum extent practicable, for purposes of developing any wildland fire potential forecasts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76fe58-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries may share the system established under paragraph (1), and any results generated in using the system, with any State or unit of local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca76fe59-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided by this section terminates on the date that is 10 years after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca76fe5a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca76fe5b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires the Secretary concerned to establish a new program, system, or database to replace an existing program, system, or database that meets the objectives of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76fe5c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" precludes the Secretary concerned from using existing or future technology that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca76fe5d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/k/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is more efficient, safer, or better meets the needs of firefighters, other personnel, or the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca76fe5e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748b–1/k/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the objectives of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca76fe5f-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tI/s1114"},"text":"Pub. L. 116–9, title I, § 1114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/615"},"text":"133 Stat. 615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca76fe60-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca76fe61-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca76fe62-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s1114"},"text":"section 1114 of Pub. L. 116–9","children":[],"tail":". Subsec. (g) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/s1114"},"text":"section 1114 of Pub. L. 116–9","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2208"},"text":"section 2208 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca76fe63-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idca76fe64-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":null},{"tag":"p","attrib":{},"text":"“Secretary” means the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2"},"text":"section 2 of Pub. L. 116–9","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"section 1 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
