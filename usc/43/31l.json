{"tag":"section","attrib":{"id":"idc9ac5b0e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l"},"text":null,"children":[{"tag":"num","attrib":{"value":"31l"},"text":"§ 31l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Earth Mapping Resources Initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9ac5b0f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of critical mineral","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “critical mineral” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1606/a"},"text":"section 1606(a) of title 30","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9ac5b10-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the United States Geological Survey an initiative, to be known as the “Earth Mapping Resources Initiative” (referred to in this section as the “Initiative”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9ac5b11-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the Initiative shall be to accelerate efforts to carry out the fundamental resources and mapping mission of the United States Geological Survey by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9ac5b12-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing integrated topographic, geologic, geochemical, and geophysical mapping;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ac5b13-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accelerating the integration and consolidation of geospatial and resource data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ac5b14-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing interpretation of subsurface and above-ground mineral resources data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9ac5b15-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9ac5b16-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the Initiative, the Director of the United States Geological Survey may enter into cooperative agreements with State geological surveys.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ac5b17-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (1) precludes the Director of the United States Geological Survey from using existing contracting authorities in carrying out the Initiative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9ac5b18-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive mapping modernization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9ac5b19-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 10 years after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Initiative shall complete an initial comprehensive national modern surface and subsurface mapping and data integration effort."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ac5b1a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approach","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1) with regard to minerals, mineralization, and mineral deposits, the Initiative shall focus on the full range of minerals, using a whole ore body approach rather than a single commodity approach, to emphasize all of the recoverable critical minerals in a given surface or subsurface deposit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ac5b1b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1) with regard to minerals, mineralization, and mineral deposits, the Initiative shall prioritize mapping and assessing critical minerals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ac5b1c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the Initiative shall also—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9ac5b1d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" map and collect data for areas containing mine waste to increase understanding of above-ground critical mineral resources in previously disturbed areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ac5b1e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for analysis of samples, including samples within the National Geological and Geophysical Data Preservation Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15908/b"},"text":"section 15908(b) of title 42","children":[],"tail":" for the occurrence of critical minerals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9ac5b1f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Initiative shall make the geospatial data and metadata gathered by the Initiative under subsection (e)(1) electronically publicly accessible on an ongoing basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9ac5b20-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integration of data sources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Initiative shall integrate data sources, including data from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9ac5b21-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Cooperative Geologic Mapping Program established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s31c/a/1"},"text":"section 31c(a)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ac5b22-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Geological and Geophysical Data Preservation Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15908/b"},"text":"section 15908(b) of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ac5b23-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the USMIN Mineral Deposit Database of the United States Geological Survey;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ac5b24-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 3D Elevation Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s3104/a"},"text":"section 3104(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ac5b25-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant sources, including sources providing geothermal resources data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9ac5b26-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31l/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $320,000,000 for the period of fiscal years 2022 through 2026, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9ac5b27-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tII/s40201"},"text":"Pub. L. 117–58, div. D, title II, § 40201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/958"},"text":"135 Stat. 958","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9ac5b28-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9ac5b29-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9ac5b2a-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idc9ac5b2b-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of Secretary as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18701"},"text":"section 18701 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
