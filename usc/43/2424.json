{"tag":"section","attrib":{"id":"idca913d0b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424"},"text":null,"children":[{"tag":"num","attrib":{"value":"2424"},"text":"§ 2424.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defaults","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca913d0c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments by Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca913d0d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a borrower defaults on the obligation, the holder of the loan guarantee shall have the right to demand payment of the unpaid amount from the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913d0e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"By such date as may be specified in the loan guarantee or related agreements, the Secretary shall pay to the holder of the loan guarantee the unpaid interest on, and unpaid principal of, the obligation with respect to which the borrower has defaulted, unless the Secretary finds that there was not default by the borrower in the payment of interest or principal or that the default has been remedied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913d0f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forbearance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection precludes any forbearance by the holder of the obligation for the benefit of the non-Federal borrower that may be agreed on by the parties to the obligation and approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913d10-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subrogation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca913d11-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary makes a payment under subsection (a), the Secretary shall be subrogated to the rights of the recipient of the payment as specified in the loan guarantee or related agreements, including, as appropriate, the authority (notwithstanding any other provision of law) to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca913d12-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete, maintain, operate, lease, or otherwise dispose of any property acquired pursuant to the loan guarantee or related agreements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca913d13-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit the non-Federal borrower, pursuant to an agreement with the Secretary, to continue to pursue the purposes of the project if the Secretary determines the purposes to be in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913d14-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Superiority of rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rights of the Secretary, with respect to any property acquired pursuant to a loan guarantee or related agreement, shall be superior to the rights of any other person with respect to the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913d15-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of principal and interest by Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any obligation guaranteed under this section, the Secretary may enter into a contract to pay, and pay, holders of the obligation, for and on behalf of the non-Federal borrower, from funds appropriated for that purpose, the principal and interest payments that become due and payable on the unpaid balance of the obligation if the Secretary finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca913d16-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca913d17-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the non-Federal borrower is unable to meet the payments and is not in default;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca913d18-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the public interest to permit the non-Federal borrower to continue to pursue the purposes of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca913d19-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the probable net benefit to the Federal Government in paying the principal and interest will be greater than that which would result in the event of a default;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913d1a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the payment that the Secretary is authorized to pay shall be no greater than the amount of principal and interest that the non-Federal borrower is obligated to pay under the agreement being guaranteed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913d1b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the borrower agrees to reimburse the Secretary for the payment (including interest) on terms and conditions that are satisfactory to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913d1c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by Attorney General","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca913d1d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the non-Federal borrower defaults on an obligation, the Secretary shall notify the Attorney General of the default.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913d1e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On notification, the Attorney General shall take such action as is appropriate to recover the unpaid principal and interest due from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca913d1f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such assets of the defaulting non-Federal borrower as are associated with the obligation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca913d20-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2424/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other security pledged to secure the obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca913d21-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/451/tII/s205"},"text":"Pub. L. 109–451, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3358"},"text":"120 Stat. 3358","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
