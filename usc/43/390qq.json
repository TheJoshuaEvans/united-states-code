{"tag":"section","attrib":{"id":"idc9d4cb76-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390qq"},"text":null,"children":[{"tag":"num","attrib":{"value":"390qq"},"text":"§ 390qq.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Isolated tracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Neither the ownership limitations of this subchapter nor the ownership limitations of any other provision of Federal reclamation law shall apply to lands which are isolated tracts found by the Secretary to be economically farmable only if they are included in a larger farming operation but which may, as a result of their inclusion in that operation, cause it to exceed such ownership limitations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9d4cb77-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/293/tII/s217"},"text":"Pub. L. 97–293, title II, § 217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1270"},"text":"96 Stat. 1270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d4cb78-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d4cb79-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9d4cb7a-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Federal reclamation law, referred to in text, is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390aa"},"text":"section 390aa of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
