{"tag":"section","attrib":{"id":"idca8ecc1c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402"},"text":null,"children":[{"tag":"num","attrib":{"value":"2402"},"text":"§ 2402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural water supply program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8ecc1d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in cooperation with non-Federal project entities and consistent with this subchapter, may carry out a rural water supply program in Reclamation States to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8ecc1e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate and identify opportunities to ensure safe and adequate rural water supply projects for domestic, municipal, and industrial use in small communities and rural areas of the Reclamation States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc1f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plan the design and construction, through the conduct of appraisal investigations and feasibility studies, of rural water supply projects in Reclamation States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc20-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee, as appropriate, the construction of rural water supply projects in Reclamation States that are recommended by the Secretary in a feasibility report developed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2405"},"text":"section 2405 of this title","children":[],"tail":" and subsequently authorized by Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8ecc21-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal project entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any activity carried out under this subchapter shall be carried out in cooperation with a qualifying non-Federal project entity, consistent with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8ecc22-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2006-12-22"},"text":"December 22, 2006","children":[],"tail":", the Secretary shall, consistent with this subchapter, develop and publish in the Federal Register criteria for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8ecc23-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining the eligibility of a rural community for assistance under the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc24-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritizing requests for assistance under the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8ecc25-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The criteria developed under subsection (c) shall take into account such factors as whether—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8ecc26-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a rural water supply project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8ecc27-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" serves—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca8ecc28-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rural areas and small communities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8ecc29-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian tribes; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecc2a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotes and applies a regional or watershed perspective to water resources management;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc2b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" there is an urgent and compelling need for a rural water supply project that would—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8ecc2c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the health or aesthetic quality of water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecc2d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in continuous, measurable, and significant water quality benefits; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecc2e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address current or future water supply needs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc2f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rural water supply project helps meet applicable requirements established by law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc30-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rural water supply project is cost effective.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8ecc31-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8ecc32-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that connection provides a reliable water supply, a connection to pre-existing infrastructure (including impoundments and conveyance channels) as part of a rural water supply project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecc33-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2402/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding the limitation on population under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2401/9/A"},"text":"section 2401(9)(A) of this title","children":[],"tail":", a town or community with a population in excess of 50,000 inhabitants in an area served by a rural water supply project if, at the discretion of the Secretary, the town or community is considered to be a critical partner in the rural supply project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8ecc34-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/451/tI/s103"},"text":"Pub. L. 109–451, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3347"},"text":"120 Stat. 3347","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
