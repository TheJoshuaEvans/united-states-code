{"tag":"section","attrib":{"id":"idca72434d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1742a"},"text":"§ 1742a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Good Samaritan Search and Recovery Act","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca72434e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca72434f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible”, with respect to an organization or individual, means that the organization or individual, respectively, is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca724350-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acting in a not-for-profit capacity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca724351-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" composed entirely of members who, at the time of the good Samaritan search-and-recovery mission, have attained the age of majority under the law of the State where the mission takes place.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca724352-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Good Samaritan search-and-recovery mission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “good Samaritan search-and-recovery mission” means a search conducted by an eligible organization or individual for 1 or more missing individuals believed to be deceased at the time that the search is initiated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca724353-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary or the Secretary of Agriculture, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca724354-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca724355-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Secretary shall develop and implement a process to expedite access to Federal land under the administrative jurisdiction of the Secretary for eligible organizations and individuals to request access to Federal land to conduct good Samaritan search-and-recovery missions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca724356-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The process developed and implemented under this subsection shall include provisions to clarify that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca724357-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an eligible organization or individual granted access under this section—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca724358-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be acting for private purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca724359-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be considered to be a Federal volunteer;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca72435a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an eligible organization or individual conducting a good Samaritan search-and-recovery mission under this section shall not be considered to be a volunteer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s102301/c"},"text":"section 102301(c) of title 54","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca72435b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 171 of title 28 (commonly known as the “Federal Tort Claims Act”) shall not apply to an eligible organization or individual carrying out a privately requested good Samaritan search-and-recovery mission under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca72435c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 81 of title 5 (commonly known as the “Federal Employees Compensation Act”) shall not apply to an eligible organization or individual conducting a good Samaritan search-and-recovery mission under this section, and the conduct of the good Samaritan search-and-recovery mission shall not constitute civilian employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca72435d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release of Federal Government from liability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not require an eligible organization or individual to have liability insurance as a condition of accessing Federal land under this section, if the eligible organization or individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca72435e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acknowledges and consents, in writing, to the provisions described in subparagraphs (A) through (D) of subsection (b)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca72435f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" signs a waiver releasing the Federal Government from all liability relating to the access granted under this section and agrees to indemnify and hold harmless the United States from any claims or lawsuits arising from any conduct by the eligible organization or individual on Federal land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca724360-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval and denial of requests","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca724361-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall notify an eligible organization or individual of the approval or denial of a request by the eligible organization or individual to carry out a good Samaritan search-and-recovery mission under this section by not later than 48 hours after the request is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca724362-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denials","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary denies a request from an eligible organization or individual to carry out a good Samaritan search-and-recovery mission under this section, the Secretary shall notify the eligible organization or individual of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca724363-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reason for the denial of the request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca724364-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any actions that the eligible organization or individual can take to meet the requirements for the request to be approved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca724365-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Secretary shall develop search-and-recovery-focused partnerships with search-and-recovery organizations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca724366-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate good Samaritan search-and-recovery missions on Federal land under the administrative jurisdiction of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca724367-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expedite and accelerate good Samaritan search-and-recovery mission efforts for missing individuals on Federal land under the administrative jurisdiction of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca724368-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretaries shall submit to Congress a joint report describing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca724369-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans to develop partnerships described in subsection (e)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca72436a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1742a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts carried out to expedite and accelerate good Samaritan search-and-recovery mission efforts for missing individuals on Federal land under the administrative jurisdiction of each Secretary pursuant to subsection (e)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca72436b-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tIX/s9002"},"text":"Pub. L. 116–9, title IX, § 9002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/830"},"text":"133 Stat. 830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca72436c-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca72436d-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca72436e-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the John D. Dingell, Jr. Conservation, Management, and Recreation Act, and not as part of the Federal Land Policy and Management Act of 1976 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca72436f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idca724370-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2"},"text":"section 2 of Pub. L. 116–9","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"section 1 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
