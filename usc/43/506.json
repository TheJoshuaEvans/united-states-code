{"tag":"section","attrib":{"id":"idc9ecbf9f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s506"},"text":null,"children":[{"tag":"num","attrib":{"value":"506"},"text":"§ 506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary to make modifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In order to preserve the structural safety of Bureau of Reclamation dams and related facilities the Secretary of the Interior is authorized to perform such modifications as he determines to be reasonably required. Said performance of work shall be in accordance with the Federal reclamation laws (Act of ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/388"},"text":"32 Stat. 388","children":[],"tail":", and Acts amendatory or supplementary thereto)."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9ecbfa0-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/578/s2"},"text":"Pub. L. 95–578, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2471"},"text":"92 Stat. 2471","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9ecbfa1-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9ecbfa2-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9ecbfa3-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":", referred to in text, is popularly known as the Reclamation Act, which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9ecbfa4-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idc9ecbfa5-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/404/s1"},"text":"Pub. L. 98–404, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-28"},"text":"Aug. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1481"},"text":"98 Stat. 1481","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/404/s1"},"text":"“That this Act [amending sections 508 and 509 of this title] may be cited as ‘The Reclamation Safety of Dams Act Amendments of 1984’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idc9ecbfa6-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/578/s1"},"text":"Pub. L. 95–578, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2471"},"text":"92 Stat. 2471","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/578/s1"},"text":"“That this Act [enacting this subchapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1511"},"text":"section 1511 of this title","children":[],"tail":"] shall be cited as the ‘Reclamation Safety of Dams Act of 1978’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9ecbfa7-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Facilities Included Within Scope of Reclamation Safety of Dams Act of 1978","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/578/s12"},"text":"Pub. L. 95–578, § 12","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/98/404/s1/4"},"text":"Pub. L. 98–404, § 1(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-28"},"text":"Aug. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1482"},"text":"98 Stat. 1482","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/404/s1/4"},"text":"“Included within the scope of this Act [this subchapter] are Fish Lake, Four Mile, Ochoco, Savage Rapids Diversion and Warm Springs Dams, Oregon; Como Dam, Montana; Little Wood River Dam, Idaho; and related facilities which have been made a part of a Federal reclamation project by previous Acts of Congress. Coolidge Dam, San Carlos Irrigation Project, Arizona, shall also be included within the scope of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
