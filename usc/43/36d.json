{"tag":"section","attrib":{"id":"idc9ac5b5a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s36d"},"text":null,"children":[{"tag":"num","attrib":{"value":"36d"},"text":"§ 36d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of the Federal Grant and Cooperative Agreement Act of 1977 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6301–630"},"text":"31 U.S.C. 6301–630","children":[],"tail":"8), the United States Geological Survey is authorized to continue existing, and on and after "},{"tag":"date","attrib":{"date":"2003-11-10"},"text":"November 10, 2003","children":[],"tail":", to enter into new cooperative agreements directed towards a particular cooperator, in support of joint research and data collection activities with Federal, State, and academic partners funded by appropriations herein, including those that provide for space in cooperator facilities."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9ac5b5b-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/108/tI"},"text":"Pub. L. 108–108, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-10"},"text":"Nov. 10, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1254"},"text":"117 Stat. 1254","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9ac5b5c-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9ac5b5d-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9ac5