{"tag":"section","attrib":{"id":"idc9f17aae-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s569"},"text":null,"children":[{"tag":"num","attrib":{"value":"569"},"text":"§ 569.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of land for park, playground, or community center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9f17aaf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s569/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579/tVII/s704/a"},"text":"Pub. L. 94–579, title VII, § 704(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2792"},"text":"90 Stat. 2792","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9f17ab0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s569/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the provisions hereinafter contained in this section every such tract of land so set apart shall be supplied with water from the Government irrigation system, the cost thereof to be charged to the remaining lands of the project as a part of the construction charge of such project, and shall be maintained and used in perpetuity by the people upon said reclaimed lands for a pleasure park, public playground, and community center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9f17ab1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s569/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract for maintenance and use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out and effecting the objects of this section the Secretary of the Interior is authorized to enter into a contract with the organization formed by the owners of the lands irrigated within said project or project unit pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s498"},"text":"section 498 of this title","children":[],"tail":", stipulating and providing that the organization will maintain and use such of the lands so reserved for the purposes prescribed in this section as such organization may desire, and that upon failure to so maintain and use such lands, or in the event that same shall be permitted to be used or occupied for other purposes than those stipulated in this section, the control of the lands shall revert to the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9f17ab2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s569/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of land not contracted for","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any of such lands not contracted for in accordance with the provisions of subsection (c) of this section within ten years from the time water is available for the same, or sooner, if the Secretary of the Interior may deem it desirable, shall be disposed of in accordance with the public land laws applicable thereto, and the proceeds from the disposition of lands reverting to the United States under the provisions of this section, and from sales of water rights, shall be covered into the reclamation fund and placed to the credit of the project wherein the lands are situate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9f17ab3-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-10-05/ch316"},"text":"Oct. 5, 1914, ch. 316","children":[],"tail":", §§ 1–4, "},{"tag":"ref","attrib":{"href":"/us/stat/38/727"},"text":"38 Stat. 727","children":[],"tail":", 728; "},{"tag":"ref","attrib":{"href":"/us/pl/94/579/tVII/s704/a"},"text":"Pub. L. 94–579, title VII, § 704(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2792"},"text":"90 Stat. 2792","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9f17ab4-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9f17ab5-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9f17ab6-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":" struck out subsec. (a) authorizing Secretary of the Interior to withdraw and reserve lands for country parks, public playgrounds, etc."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9f17ab7-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc9f17ab8-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579/tVII/s704/a"},"text":"Pub. L. 94–579, title VII, § 704(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2792"},"text":"90 Stat. 2792","children":[],"tail":", provided that the amendment made by section 704(a) is effective on and after "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idc9f17ab9-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":" not to be construed as terminating any valid lease, permit, patent, etc., existing on "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/579/s701"},"text":"section 701 of Pub. L. 94–579","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
