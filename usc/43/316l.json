{"tag":"section","attrib":{"id":"idc9bf6e96-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316l"},"text":null,"children":[{"tag":"num","attrib":{"value":"316l"},"text":"§ 316l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stock driveways and free grazing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9bf6e97-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment, maintenance and regulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish and maintain, and regulate the use of, stock driveways in districts and may charge a fee for or permit the free use of such driveways.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9bf6e98-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing of livestock free of charge","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may permit any person, including prospectors and miners, to graze free of charge a small number of livestock upon any land included within any grazing district.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9bf6e99-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing allotments to Eskimos or other native or half-breed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may in his discretion grant a permit or lease for a grazing allotment without charge on unallotted public lands to any Eskimo or other native or half-breed. Whenever such native or half-breed grazes his livestock through cooperative agreement on allotment held by other lessee or permittee, any grazing fees charged for said allotment shall be reduced in proportion to the relative number of such native owned livestock to the total number on said allotment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9bf6e9a-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch513/s13"},"text":"Mar. 4, 1927, ch. 513, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1454"},"text":"44 Stat. 1454","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9bf6e9b-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9bf6e9c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9bf6e9d-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 471","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of Title 48, Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
