{"tag":"section","attrib":{"id":"idca809bdc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787"},"text":null,"children":[{"tag":"num","attrib":{"value":"1787"},"text":"§ 1787.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jupiter Inlet Lighthouse Outstanding Natural Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca809bdd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca809bde-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commandant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commandant” means the Commandant of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca809bdf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lighthouse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Lighthouse” means the Jupiter Inlet Lighthouse located in Palm Beach County, Florida.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca809be0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local Partners","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Local Partners” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca809be1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Palm Beach County, Florida;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca809be2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Town of Jupiter, Florida;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca809be3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Village of Tequesta, Florida; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca809be4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Loxahatchee River Historical Society.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca809be5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “management plan” means the management plan developed under subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca809be6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “map” means the map entitled “Jupiter Inlet Lighthouse Outstanding Natural Area” and dated ","children":[{"tag":"date","attrib":{"date":"2007-10-29"},"text":"October 29, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca809be7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outstanding Natural Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Outstanding Natural Area” means the Jupiter Inlet Lighthouse Outstanding Natural Area established by subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca809be8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “public land” has the meaning given the term “public lands” in section 103(e) of the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1702/e"},"text":"43 U.S.C. 1702(e)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca809be9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca809bea-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the State of Florida.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca809beb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of the Jupiter Inlet Lighthouse Outstanding Natural Area","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca809bec-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to valid existing rights, there is established for the purposes described in paragraph (2) the Jupiter Inlet Lighthouse Outstanding Natural Area, the boundaries of which are depicted on the map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82e4dd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Outstanding Natural Area are to protect, conserve, and enhance the unique and nationally important historic, natural, cultural, scientific, educational, scenic, and recreational values of the Federal land surrounding the Lighthouse for the benefit of present generations and future generations of people in the United States, while—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca82e4de-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowing certain recreational and research activities to continue in the Outstanding Natural Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82e4df-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that Coast Guard operations and activities are unimpeded within the boundaries of the Outstanding Natural Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82e4e0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map shall be on file and available for public inspection in appropriate offices of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82e4e1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca82e4e2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, subsection (e), and any existing withdrawals under the Executive orders and public land order described in subparagraph (B), the Federal land and any interests in the Federal land included in the Outstanding Natural Area are withdrawn from—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca82e4e3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all forms of entry, appropriation, or disposal under the public land laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca82e4e4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca82e4e5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation of the mineral leasing and geothermal leasing laws and the mineral materials laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82e4e6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of Executive orders","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Executive orders and public land order described in subparagraph (A) are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca82e4e7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Executive Order dated ","children":[{"tag":"date","attrib":{"date":"1854-10-22"},"text":"October 22, 1854","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca82e4e8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Executive Order No. 4254 (","children":[{"tag":"date","attrib":{"date":"1925-06-12"},"text":"June 12, 1925","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca82e4e9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/b/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public Land Order No. 7202 (61 Fed. Reg. 29758).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca82e4ea-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca82e4eb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2008-05-08"},"text":"May 8, 2008","children":[],"tail":", the Secretary, in consultation with the Commandant, shall develop a comprehensive management plan in accordance with section 202 of the Federal Land Policy and Management Act of 1976 ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1712"},"text":"43 U.S.C. 1712","children":[],"tail":") to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca82e4ec-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide long-term management guidance for the public land in the Outstanding Natural Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82e4ed-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the Outstanding Natural Area fulfills the purposes for which the Outstanding Natural Area is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82e4ee-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation; public participation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The management plan shall be developed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca82e4ef-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with appropriate Federal, State, county, and local government agencies, the Commandant, the Local Partners, and other partners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82e4f0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that ensures full public participation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82e4f1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The management plan shall, to the maximum extent practicable, be consistent with existing resource plans, policies, and programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82e4f2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The management plan shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca82e4f3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" objectives and provisions to ensure—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca82e4f4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection and conservation of the resource values of the Outstanding Natural Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca82e4f5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the restoration of native plant communities and estuaries in the Outstanding Natural Area, with an emphasis on the conservation and enhancement of healthy, functioning ecological systems in perpetuity;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82e4f6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" objectives and provisions to maintain or recreate historic structures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82e4f7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an implementation plan for a program of interpretation and public education about the natural and cultural resources of the Lighthouse, the public land surrounding the Lighthouse, and associated structures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82e4f8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a proposal for administrative and public facilities to be developed or improved that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca82e4f9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are compatible with achieving the resource objectives for the Outstanding Natural Area described in subsection (d)(1)(A)(ii); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca82e4fa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would accommodate visitors to the Outstanding Natural Area;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82e4fb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural and cultural resource management strategies for the Outstanding Natural Area, to be developed in consultation with appropriate departments of the State, the Local Partners, and the Commandant, with an emphasis on resource conservation in the Outstanding Natural Area and the interpretive, educational, and long-term scientific uses of the resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82e4fc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recreational use strategies for the Outstanding Natural Area, to be prepared in consultation with the Local Partners, appropriate departments of the State, and the Coast Guard, with an emphasis on passive recreation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82e4fd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until a management plan is adopted for the Outstanding Natural Area, the Jupiter Inlet Coordinated Resource Management Plan (including any updates or amendments to the Jupiter Inlet Coordinated Resource Management Plan) shall be in effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca82e4fe-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of the Jupiter Inlet Lighthouse Outstanding Natural Area","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca82e4ff-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca82e500-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Local Partners and the Commandant, shall manage the Outstanding Natural Area—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca82e501-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as part of the National Landscape Conservation System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca82e502-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that conserves, protects, and enhances the unique and nationally important historical, natural, cultural, scientific, educational, scenic, and recreational values of the Outstanding Natural Area, including an emphasis on the restoration of native ecological systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca82e503-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.) and other applicable laws."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82e504-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In managing the Outstanding Natural Area, the Secretary shall not take any action that precludes, prohibits, or otherwise affects the conduct of ongoing or future Coast Guard operations or activities on lots 16 and 18, as depicted on the map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82e505-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to valid existing rights and subsection (e), the Secretary shall only allow uses of the Outstanding Natural Area that the Secretary, in consultation with the Commandant and Local Partners, determines would likely further the purposes for which the Outstanding Natural Area is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82e506-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To facilitate implementation of the management plan and to continue the successful partnerships with local communities and other partners, the Secretary may, in accordance with section 307(b) of the Federal Land Management ","children":[{"tag":"ref","attrib":{"idref":"fn002165"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002165"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “Management” probably should not appear."}],"tail":" Policy and Management Act of 1976 ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1737/b"},"text":"43 U.S.C. 1737(b)","children":[],"tail":"), enter into cooperative agreements with the appropriate Federal, State, county, other local government agencies, and other partners (including the Loxahatchee River Historical Society) for the long-term management of the Outstanding Natural Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82e507-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To continue successful research partnerships, pursue future research partnerships, and assist in the development and implementation of the management plan, the Secretary may, in accordance with section 307(a) of the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1737/a"},"text":"43 U.S.C. 1737(a)","children":[],"tail":"), authorize the conduct of appropriate research activities in the Outstanding Natural Area for the purposes described in subsection (b)(2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82e508-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of land","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca82e509-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), the Secretary may acquire for inclusion in the Outstanding Natural Area any State or private land or any interest in State or private land that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca82e50a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjacent to the Outstanding Natural Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca82e50b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified in the management plan as appropriate for acquisition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82e50c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Means of acquisition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Land or an interest in land may be acquired under subparagraph (A) only by donation, exchange, or purchase from a willing seller with donated or appropriated funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82e50d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additions to the Outstanding Natural Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any land or interest in land adjacent to the Outstanding Natural Area acquired by the United States after ","children":[{"tag":"date","attrib":{"date":"2008-05-08"},"text":"May 8, 2008","children":[],"tail":", under subparagraph (A) shall be added to, and administered as part of, the Outstanding Natural Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82e50e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section, the management plan, or the Jupiter Inlet Coordinated Resource Management Plan (including any updates or amendments to the Jupiter Inlet Coordinated Resource Management Plan) precludes, prohibits, or otherwise affects—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca82e50f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any maritime security, maritime safety, or environmental protection mission or activity of the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82e510-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any border security operation or law enforcement activity by the Department of Homeland Security or the Department of Justice; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82e511-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any law enforcement activity of any Federal, State, or local law enforcement agency in the Outstanding Natural Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82e512-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Future disposition of Coast Guard facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Commandant determines, after ","children":[{"tag":"date","attrib":{"date":"2008-05-08"},"text":"May 8, 2008","children":[],"tail":", that Coast Guard facilities within the Outstanding Natural Area exceed the needs of the Coast Guard, the Commandant may relinquish the facilities to the Secretary without removal, subject only to any environmental remediation that may be required by law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca82e513-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on ongoing and future Coast Guard operations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section, the management plan, or the Jupiter Inlet Coordinated Resource Management Plan (including updates or amendments to the Jupiter Inlet Coordinated Resource Management Plan) precludes, prohibits, or otherwise affects ongoing or future Coast Guard operations or activities in the Outstanding Natural Area, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca82e514-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the continued and future operation of, access to, maintenance of, and, as may be necessitated for Coast Guard missions, the expansion, enhancement, or replacement of, the Coast Guard High Frequency antenna site on lot 16;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82e515-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the continued and future operation of, access to, maintenance of, and, as may be necessitated for Coast Guard missions, the expansion, enhancement, or replacement of, the military family housing area on lot 18;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82e516-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the continued and future use of, access to, maintenance of, and, as may be necessitated for Coast Guard missions, the expansion, enhancement, or replacement of, the pier on lot 18;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82e517-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the existing lease of the Jupiter Inlet Lighthouse on lot 18 from the Coast Guard to the Loxahatchee River Historical Society; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82e518-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any easements or other less-than-fee interests in property appurtenant to existing Coast Guard facilities on lots 16 and 18.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca82e519-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1787/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca82e51a-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/229/tII/s202"},"text":"Pub. L. 110–229, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-08"},"text":"May 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/763"},"text":"122 Stat. 763","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca82e51b-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca82e51c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca82e51d-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Executive Order dated ","children":[{"tag":"date","attrib":{"date":"1854-10-22"},"text":"October 22, 1854","children":[],"tail":", and Executive Order No. 4254 ("},{"tag":"date","attrib":{"date":"1925-06-12"},"text":"June 12, 1925","children":[],"tail":"), referred to in subsec. (b)(4)(B)(i), (ii), were not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in subsec. (d)(1)(A)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca82e51e-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Consolidated Natural Resources Act of 2008, and not as part of the Federal Land Policy and Management Act of 1976 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
