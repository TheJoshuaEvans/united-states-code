{"tag":"section","attrib":{"id":"idca048deb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s641b"},"text":null,"children":[{"tag":"num","attrib":{"value":"641b"},"text":"§ 641b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of application for quitclaim deeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall not issue such quitclaim deeds or patents to any State, however, unless that State files a proper application for the transfer of these lands within three years after ","children":[{"tag":"date","attrib":{"date":"1954-08-13"},"text":"August 13, 1954","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca048dec-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-13/ch727/s2"},"text":"Aug. 13, 1954, ch. 727, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/703"},"text":"68 Stat. 703","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
