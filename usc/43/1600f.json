{"tag":"section","attrib":{"id":"idca473c69-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1600f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1600f"},"text":"§ 1600f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall, on behalf of each Federal agency concerned, make written certification that each agency has complied with the provisions of this chapter during each fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"1985-09-30"},"text":"September 30, 1985","children":[],"tail":". Such certification shall be submitted on an annual basis to the United States House of Representatives and the United States Senate on or before January 15 of each fiscal year."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca473c6a-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/450/s8"},"text":"Pub. L. 99–450, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-08"},"text":"Oct. 8, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1134"},"text":"100 Stat. 1134","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca473c6b-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca473c6c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca473c6d-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in this section relating to the requirement that the Secretary submit written certifications on an annual basis to the United States House of Representatives and the United States Senate, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and the 6th item on page 113 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
