{"tag":"section","attrib":{"id":"idc9d28119-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–12n"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–12n"},"text":"§ 390h–12n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of effluent from sanitation districts of Los Angeles County through city of Long Beach","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d2811a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–12n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the Water Replenishment District of Southern California, the Orange County Water District in the State of California, and other appropriate authorities, is authorized to participate in the design, planning, and construction of water reclamation and reuse projects to treat approximately 10,000 acre-feet per year of effluent from the sanitation districts of Los Angeles County through the city of Long Beach.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d2811b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–12n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of a project described in subsection (a) shall not exceed 25 percent of the total cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d2811c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–12n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not provide funds for the operation or maintenance of a project described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d2811d-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s1628"},"text":"Pub. L. 102–575, title XVI, § 1628","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/266/s2/a/2"},"text":"Pub. L. 104–266, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3293"},"text":"110 Stat. 3293","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
