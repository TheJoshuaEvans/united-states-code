{"tag":"section","attrib":{"id":"idca094828-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s762"},"text":null,"children":[{"tag":"num","attrib":{"value":"762"},"text":"§ 762.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits made by settlers for surveys to go in part payment of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where settlers or owners or grantees of public lands make deposits in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s759"},"text":"section 759 of this title","children":[],"tail":", certificates shall be issued for such deposits which may be used by settlers in part payment for the lands settled upon by them, the survey of which is paid for out of such deposits, or said certificates may be assigned by indorsement and may be received by the Government in payment for any public lands of the United States in the States where the surveys were made, entered or to be entered under the laws thereof."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca094829-3a70-11f1-bde1-a5140e158598"},"text":"(R.S. § 2403; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1876-04-27/ch84"},"text":"Apr. 27, 1876, ch. 84","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/19/38"},"text":"19 Stat. 38","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1879-03-03/ch170"},"text":"Mar. 3, 1879, ch. 170","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/20/352"},"text":"20 Stat. 352","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1894-08-20/ch302/s2"},"text":"Aug. 20, 1894, ch. 302, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/423"},"text":"28 Stat. 423","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca09482a-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag