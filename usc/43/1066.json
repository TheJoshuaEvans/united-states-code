{"tag":"section","attrib":{"id":"idca1c5b2d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1066"},"text":null,"children":[{"tag":"num","attrib":{"value":"1066"},"text":"§ 1066.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permission of Secretary to sue","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where the alleged unlawful inclosure includes less than one hundred and sixty acres of land, no suit shall be brought under the provisions of this chapter without authority from the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca1c5b2e-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1885-02-25/ch149/s6"},"text":"Feb. 25, 1885, ch. 149, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/23/322"},"text":"23 Stat. 322","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
