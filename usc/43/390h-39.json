{"tag":"section","attrib":{"id":"idc9d281fb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–39"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–39"},"text":"§ 390h–39.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" City of Corona Water Utility, California, water recycling and reuse project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d281fc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–39/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the City of Corona Water Utility, California, is authorized to participate in the design, planning, and construction of, and land acquisition for, a project to reclaim and reuse wastewater, including degraded groundwaters, within and outside of the service area of the City of Corona Water Utility, California.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d281fd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–39/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of the project authorized by this section shall not exceed 25 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d281fe-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–39/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not provide funds for the operation and maintenance of the project authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d281ff-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s1656"},"text":"Pub. L. 102–575, title XVI, § 1656","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tIX/s9114/a"},"text":"Pub. L. 111–11, title IX, § 9114(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1320"},"text":"123 Stat. 1320","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
