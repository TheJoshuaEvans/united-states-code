{"tag":"section","attrib":{"id":"idca31df17-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1441"},"text":null,"children":[{"tag":"num","attrib":{"value":"1441"},"text":"§ 1441.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease of contiguous public lands for public airports; authority of Secretary of the Interior","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized, in his discretion and under such regulations as he may prescribe, to lease for use as a public airport any contiguous public lands, unreserved and unappropriated, not to exceed two thousand five hundred and sixty acres in area, subject to valid rights in such lands under the public-land laws.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca31df18-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-05-24/ch728/s1"},"text":"May 24, 1928, ch. 728, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/728"},"text":"45 Stat. 728","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1941-08-16/ch354"},"text":"Aug. 16, 1941, ch. 354","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/621"},"text":"55 Stat. 621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca31df19-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca31df1a-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca31df1b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was previously classified to section 211 of former Title 49, Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca31df1c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1941—Act ","children":[{"tag":"date","attrib":{"date":"1941-08-16"},"text":"Aug. 16, 1941","children":[],"tail":", increased area of land authorized for lease as airport from six hundred and forty acres to two thousand five hundred and sixty acres."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
