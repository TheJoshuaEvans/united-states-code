{"tag":"section","attrib":{"id":"idc9b387f1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s126"},"text":null,"children":[{"tag":"num","attrib":{"value":"126"},"text":"§ 126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change of location of land offices","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is authorized to change the location of the land offices in the several land districts established by law, and to relocate the same from time to time at such point in the district as he deems expedient.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9b387f2-3a70-11f1-bde1-a5140e158598"},"text":"(R.S. § 2251.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9b387f3-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9b387f4-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9b387f5-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2251 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1853-03-03/ch97/s1"},"text":"Mar. 3, 1853, ch. 97, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/10/204"},"text":"10 Stat. 204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1853-03-03/ch144"},"text":"Mar. 3, 1853, ch. 144","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/10/244"},"text":"10 Stat. 244","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idc9b387f6-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"idc9b387f7-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation to Secretary of the Interior of authority vested in President by this section, see Ex. Ord. No. 10250, ","children":[{"tag":"date","attrib":{"date":"1951-06-05"},"text":"June 5, 1951","children":[],"tail":", 16 F.R. 5385, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
