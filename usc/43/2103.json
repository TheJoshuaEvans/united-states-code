{"tag":"section","attrib":{"id":"idca8a10d5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2103"},"text":null,"children":[{"tag":"num","attrib":{"value":"2103"},"text":"§ 2103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of access","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8a10d6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8a10d7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clarify that State waters and shipwrecks offer recreational and educational opportunities to sport divers and other interested groups, as well as irreplaceable State resources for tourism, biological sanctuaries, and historical research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8a10d8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that reasonable access by the public to such abandoned shipwrecks be permitted by the State holding title to such shipwrecks pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2105"},"text":"section 2105 of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"it is the declared policy of the Congress that States carry out their responsibilities under this chapter to develop appropriate and consistent policies so as to—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8a10d9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2103/a/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect natural resources and habitat areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8a10da-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2103/a/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guarantee recreational exploration of shipwreck sites; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8a10db-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2103/a/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow for appropriate public and private sector recovery of shipwrecks consistent with the protection of historical values and environmental integrity of the shipwrecks and the sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a10dc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parks and protected areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In managing the resources subject to the provisions of this chapter, States are encouraged to create underwater parks or areas to provide additional protection for such resources. Funds available to States from grants from the Historic Preservation Fund shall be available, in accordance with the provisions of chapter 3029 of title 54, for the study, interpretation, protection, and preservation of historic shipwrecks and properties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8a10dd-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/298/s4"},"text":"Pub. L. 100–298, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/433"},"text":"102 Stat. 433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca8a10de-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca8a10df-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca8a10e0-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b), “chapter 3029 of title 54” substituted for “title I of the National Historic Preservation Act” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s6/e"},"text":"Pub. L. 113–287, § 6(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3272"},"text":"128 Stat. 3272","children":[],"tail":", which Act enacted Title 54, National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
