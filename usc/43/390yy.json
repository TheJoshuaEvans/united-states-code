{"tag":"section","attrib":{"id":"idc9d4cbac-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390yy"},"text":null,"children":[{"tag":"num","attrib":{"value":"390yy"},"text":"§ 390yy.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leasing requirements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of Federal reclamation law, including this subchapter, lands which receive irrigation water may be leased only if the lease instrument is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9d4cbad-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390yy/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" written; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9d4cbae-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390yy/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a term not to exceed ten years, including any exercisable options: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That leases of lands for the production of perennial crops having an average life of more than ten years may be for periods of time equal to the average life of the perennial crop but in any event not to exceed twenty-five years."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d4cbaf-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/293/tII/s227"},"text":"Pub. L. 97–293, title II, § 227","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1273"},"text":"96 Stat. 1273","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d4cbb0-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d4cbb1-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9d4cbb2-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Federal reclamation law, referred to in text, is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390aa"},"text":"section 390aa of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
