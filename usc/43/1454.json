{"tag":"section","attrib":{"id":"idca342959-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1454"},"text":null,"children":[{"tag":"num","attrib":{"value":"1454"},"text":"§ 1454.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Assistant Secretary and assistant to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary of the Interior shall perform such duties in the Department of the Interior as shall be prescribed by the Secretary, or may be required by law. The assistant to the Secretary of the Interior is authorized to sign such official papers and documents as the Secretary may direct.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca34295a-3a70-11f1-bde1-a5140e158598"},"text":"(R.S. § 439; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1918-03-28/ch29"},"text":"Mar. 28, 1918, ch. 29","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/499"},"text":"40 Stat. 499","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca34295b-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca34295c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca34295d-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 439 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1862-03-14/ch41/s6"},"text":"act Mar. 14, 1862, ch. 41, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/369"},"text":"12 Stat. 369","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s483"},"text":"section 483 of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idca34295e-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idca34295f-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1451"},"text":"section 1451 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
