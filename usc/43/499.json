{"tag":"section","attrib":{"id":"idc9ea4f31-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s499"},"text":null,"children":[{"tag":"num","attrib":{"value":"499"},"text":"§ 499.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary power to transfer management","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever any legally organized water-users’ association or irrigation district shall so request, the Secretary of the Interior is authorized, in his discretion, to transfer to such water-users’ association or irrigation district the care, operation, and maintenance of all or any part of the project works, subject to such rules and regulations as he may prescribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9ea4f32-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-08-13/ch247/s5"},"text":"Aug. 13, 1914, ch. 247, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/687"},"text":"38 Stat. 687","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9ea4f33-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9ea4f34-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9ea4f35-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of part of first sentence of section 5 of act ","children":[{"tag":"date","attrib":{"date":"1914-08-13"},"text":"Aug. 13, 1914","children":[],"tail":". Remainder of first sentence and second sentence of such section 5 are classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s492"},"text":"section 492 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
