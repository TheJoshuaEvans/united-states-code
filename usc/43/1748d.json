{"tag":"section","attrib":{"id":"idca76fed7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1748d"},"text":"§ 1748d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on wildfire, insect infestation, and disease prevention on Federal land","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", and every year thereafter, the Secretary and the Secretary of Interior "},{"tag":"ref","attrib":{"idref":"fn002149"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002149"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “the”."}],"tail":" shall submit to the Committee on Agriculture of the House of Representatives, the Committee on Natural Resources of the House of Representatives, the Committee on Agriculture, Nutrition, and Forestry of the Senate, and the Committee on Energy and Natural Resources of the Senate a jointly written report on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca76fed8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of acres of Federal land treated by the Secretary or the Secretary of the Interior for wildfire, insect infestation, or disease prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76fed9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of acres of Federal land categorized as a high or extreme fire risk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76feda-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total timber production from Federal land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76fedb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of acres and average fire intensity of wildfires affecting Federal land treated for wildfire, insect infestation, or disease prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76fedc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of acres and average fire intensity of wildfires affecting Federal land not treated for wildfire, insect infestation, or disease prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76fedd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal response time for each fire on greater than 25,000 acres;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76fede-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of miles of roads and trails on Federal land in need of maintenance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76fedf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of miles of roads on Federal land in need of decommissioning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76fee0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maintenance backlog, as of the date of the report, for roads, trails, and recreational facilities on Federal land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76fee1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other measures needed to maintain, improve, or restore water quality on Federal land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76fee2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1748d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other measures needed to improve ecosystem function or resiliency on Federal land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca76fee3-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII/s8706"},"text":"Pub. L. 115–334, title VIII, § 8706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4880"},"text":"132 Stat. 4880","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","at