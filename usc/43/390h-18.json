{"tag":"section","attrib":{"id":"idc9d28160-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–18"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–18"},"text":"§ 390h–18.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Irvine basin groundwater and surface water improvement projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d28161-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–18/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the Irvine Ranch Water District, California, is authorized to participate in the design, planning, and construction of projects to naturally treat impaired surface water, reclaim and reuse impaired groundwater, and provide brine disposal within the San Diego Creek Watershed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d28162-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–18/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the costs of the projects authorized by this section shall not exceed 25 percent of the total cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d28163-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–18/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not provide funds for the operation or maintenance of a project authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d28164-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s1636"},"text":"Pub. L. 102–575, title XVI, § 1636","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/233/s2/a"},"text":"Pub. L. 108–233, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-05-28"},"text":"May 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/654"},"text":"118 Stat. 654","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d28165-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d28166-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc9d28167-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/s1636"},"text":"section 1636 of Pub. L. 102–575","children":[],"tail":" was renumbered 1637 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s390h–19"},"text":"section 390h–19 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
