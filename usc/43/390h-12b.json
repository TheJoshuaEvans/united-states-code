{"tag":"section","attrib":{"id":"idc9d00fd0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–12b"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–12b"},"text":"§ 390h–12b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calleguas Municipal Water District Recycling Project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d00fd1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–12b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the appropriate State and local authorities, is authorized to participate in the design, planning, and construction of the Calleguas Municipal Water District Recycling Project to reclaim and reuse water in the service area of the Calleguas Municipal Water District in Ventura County, California.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d00fd2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–12b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of a project described in subsection (a) shall not exceed 25 percent of the total cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d00fd3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–12b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not provide funds for the operation or maintenance of a project described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d00fd4-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s1616"},"text":"Pub. L. 102–575, title XVI, § 1616","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/266/s2/a/2"},"text":"Pub. L. 104–266, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3290"},"text":"110 Stat. 3290","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d00fd5-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d00fd6-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc9d00fd7-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/s1616"},"text":"section 1616 of Pub. L. 102–575","children":[],"tail":" was renumbered section 1632 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s390h–14"},"text":"section 390h–14 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
