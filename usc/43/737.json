{"tag":"section","attrib":{"id":"idca06fedd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s737"},"text":null,"children":[{"tag":"num","attrib":{"value":"737"},"text":"§ 737.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unrestricted deeds for townsite lands held by Alaska natives","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The trustee or trustees to whom a patent has been issued for a townsite surveyed pursuant to section 732 or 735 ","children":[{"tag":"ref","attrib":{"idref":"fn002053"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002053"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, upon a finding by the Secretary of the Interior or his authorized representative that any Alaska native who claims and occupies a tract of land within such townsite is competent to manage his own affairs and has petitioned the Secretary or his authorized representative for an unrestricted deed, or "},{"tag":"ref","attrib":{"idref":"fn002054"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002054"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original."}],"tail":" shall issue to such native an unrestricted deed, and thereafter all restrictions as to sale, encumbrance, or taxation of said lands shall be removed, but said land shall not be liable to the satisfaction of any debt, except obligations owed the Federal Government, contracted prior to the issuing of such deed."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca06fede-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-02-26/ch72"},"text":"Feb. 26, 1948, ch. 72","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/35"},"text":"62 Stat. 35","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca06fedf-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca06fee0-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca06fee1-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 732 and 735 of this title, referred to in text, were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579/tVII/s703/a"},"text":"Pub. L. 94–579, title VII, § 703(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2789"},"text":"90 Stat. 2789","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca06fee2-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s355e"},"text":"section 355e of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
