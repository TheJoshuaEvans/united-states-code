{"tag":"section","attrib":{"id":"idca93ae00-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2702"},"text":null,"children":[{"tag":"num","attrib":{"value":"2702"},"text":"§ 2702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of States for expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any State incurring expenses pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2701"},"text":"section 2701 of this title","children":[],"tail":" upon presentation of an itemized account of such expenses shall be reimbursed by the head of the department or agency having control or jurisdiction of the land with respect to which such expenses were incurred: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That such reimbursement shall be only to the extent that funds appropriated specifically to carry out the purposes of this chapter are available therefor during the fiscal year in which the expenses are incurred."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca93ae01-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/583/s2"},"text":"Pub. L. 90–583, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-17"},"text":"Oct. 17, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1146"},"text":"82 Stat. 1146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca93ae02-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca93ae03-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca93ae04-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1242"},"text":"section 1242 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
