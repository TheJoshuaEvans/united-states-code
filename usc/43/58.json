{"tag":"section","attrib":{"id":"idc9b115fb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s58"},"text":null,"children":[{"tag":"num","attrib":{"value":"58"},"text":"§ 58.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transcripts from records of Louisiana","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any copy of a plat of survey, or transcript from the records of the office of the former surveyor general of Louisiana, duly certified, shall be admitted as evidence in all the courts of the United States and the Territories thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9b115fc-3a70-11f1-bde1-a5140e158598"},"text":"(R.S. § 2225.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9b115fd-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9b115fe-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9b115ff-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “former” was inserted in text before “surveyor general” because of the discontinuance of the office of surveyor general in Louisiana.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2225 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1831-03-03/ch116/s5"},"text":"act Mar. 3, 1831, ch. 116, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/4/493"},"text":"4 Stat. 493","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
