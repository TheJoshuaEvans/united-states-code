{"tag":"section","attrib":{"id":"idca3b54d8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1476"},"text":null,"children":[{"tag":"num","attrib":{"value":"1476"},"text":"§ 1476.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elimination of oaths for written statements; discretion of Secretary of the Interior","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Written statement in public land matters within the jurisdiction of the Department of the Interior, heretofore required by law to be made under oath, need no longer be made under oath unless the Secretary of the Interior shall, in his discretion, so require.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca3b54d9-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-03/ch392/s1"},"text":"June 3, 1948, ch. 392, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/301"},"text":"62 Stat. 301","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca3b54da-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca3b54db-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca3b54dc-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1211"},"text":"section 1211 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
