{"tag":"section","attrib":{"id":"idc9c69984-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s373"},"text":null,"children":[{"tag":"num","attrib":{"value":"373"},"text":"§ 373.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority of Secretary of the Interior","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to perform any and all acts and to make such rules and regulations as may be necessary and proper for the purpose of carrying out the provisions of this Act into full force and effect.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9c69985-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-06-17/ch1093/s10"},"text":"June 17, 1902, ch. 1093, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/390"},"text":"32 Stat. 390","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1914-08-13/ch247/s15"},"text":"Aug. 13, 1914, ch. 247, § 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/690"},"text":"38 Stat. 690","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9c69986-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9c69987-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9c69988-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, refers both to act ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":", popularly known as the Reclamation Act, and to act "},{"tag":"date","attrib":{"date":"1914-08-13"},"text":"Aug. 13, 1914","children":[],"tail":". See Codification note set out below. For classification of act "},{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":" to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of this title","children":[],"tail":" and Tables. Act "},{"tag":"date","attrib":{"date":"1914-08-13"},"text":"Aug. 13, 1914","children":[],"tail":", is classified to sections 373, 414, 418, 435 to 437, 440, 443, 464, 465, 469, 471, 472, 475, 477 to 481, 492, 493, 494 to 497, and 499 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9c69989-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1914-08-13"},"text":"Aug. 13, 1914","children":[],"tail":", cited as a credit to this section, did not amend act "},{"tag":"date","attrib":{"date":"1902-07-17"},"text":"July 17, 1902","children":[],"tail":", but contained identical provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9c6998a-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9c6998b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Section as Unaffected by Submerged Lands Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of this section as not amended, modified or repealed by the Submerged Lands Act, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1303"},"text":"section 1303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
