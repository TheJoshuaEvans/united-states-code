{"tag":"section","attrib":{"id":"idca1c5b6d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1099"},"text":null,"children":[{"tag":"num","attrib":{"value":"1099"},"text":"§ 1099.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Division into counties before opening to settlement; reservation for county seats","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Before any lands in Oklahoma are open to settlement it shall be the duty of the Secretary of the Interior to divide the same into counties which shall contain as near as possible not less than seven hundred square miles in each county: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That as soon as the county lines are designated by the Secretary he shall reserve not to exceed one-half section of land in each, to be located near the center of said county, for county seat purposes, to be entered under sections 718 and 719 "},{"tag":"ref","attrib":{"idref":"fn002066"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002066"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca1c5b6e-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1891-03-03/ch543/s37"},"text":"Mar. 3, 1891, ch. 543, § 37","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/1043"},"text":"26 Stat. 1043","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca1c5b6f-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca1c5b70-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca1c5b71-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 718 and 719 of this title, referred to in text, were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579/tVII/s703/a"},"text":"Pub. L. 94–579, title VII, § 703(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2789"},"text":"90 Stat. 2789","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
