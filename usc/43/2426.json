{"tag":"section","attrib":{"id":"idca913d26-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2426"},"text":null,"children":[{"tag":"num","attrib":{"value":"2426"},"text":"§ 2426.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Title to newly constructed facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca913d27-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2426/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New projects and facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All new projects or facilities constructed in accordance with this subchapter shall remain under the jurisdiction and control of the non-Federal borrower subject to the terms of the repayment agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca913d28-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2426/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing projects and facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter affects the title of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca913d29-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2426/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reclamation projects authorized prior to ","children":[{"tag":"date","attrib":{"date":"2006-12-22"},"text":"December 22, 2006","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913d2a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2426/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" works supplemental to existing reclamation projects; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca913d2b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2426/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" works constructed to rehabilitate existing reclamation projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca913d2c-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/451/tII/s207"},"text":"Pub. L. 109–451, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3360"},"text":"120 Stat. 3360","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
