{"tag":"section","attrib":{"id":"idc9de6787-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s433"},"text":null,"children":[{"tag":"num","attrib":{"value":"433"},"text":"§ 433.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Character and capital qualification of entrymen","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized, under regulations to be promulgated by him, to require of each applicant including preference right ex-service men for entry to public lands on a project, such qualifications as to industry, experience, character, and capital, as in his opinion are necessary to give reasonable assurance of success by the prospective settler. The Secretary is authorized to appoint boards in part composed of private citizens, to assist in determining such qualifications.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9de6788-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1924-12-05/ch4/s4"},"text":"Dec. 5, 1924, ch. 4, § 4","children":[],"tail":", subsec. C, "},{"tag":"ref","attrib":{"href":"/us/stat/43/702"},"text":"43 Stat. 702","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9de6789-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9de678a-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9de678b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Advances by Farm Security Administration as Capital","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-07/ch509"},"text":"Act Aug. 7, 1939, ch. 509","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1238"},"text":"53 Stat. 1238","children":[],"tail":", as amended "},{"tag":"ref","attrib":{"href":"/us/act/1940-06-17/ch390"},"text":"June 17, 1940, ch. 390","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/402"},"text":"54 Stat. 402","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1941-05-28/ch136"},"text":"May 28, 1941, ch. 136","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/206"},"text":"55 Stat. 206","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-08-01/ch540"},"text":"Aug. 1, 1942, ch. 540","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/732"},"text":"56 Stat. 732","children":[],"tail":", authorized Secretary of the Interior during fiscal years 1940 to 1943 to consider money made available to settlers by the former Farm Security Administration to be all or part of the capital required under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idc9de678c-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
