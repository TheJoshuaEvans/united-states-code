{"tag":"section","attrib":{"id":"idc9d73c50-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s411"},"text":null,"children":[{"tag":"num","attrib":{"value":"411"},"text":"§ 411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surveys for, location, and construction of irrigation works generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized and directed to make examinations and surveys for, and to locate and construct, as herein provided, irrigation works for the storage, diversion, and development of waters, including artesian wells.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9d73c51-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-06-17/ch1093/s2"},"text":"June 17, 1902, ch. 1093, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/388"},"text":"32 Stat. 388","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-07/ch770/s1/7"},"text":"Aug. 7, 1946, ch. 770, § 1(7)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/867"},"text":"60 Stat. 867","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d73c52-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d73c53-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9d73c54-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Herein, referred to in text, means in act ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":", popularly known as the Reclamation Act, which is classified generally to this chapter. For complete classification of act "},{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":", to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc9d73c55-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1889-03-02/ch411/s1"},"text":"Mar. 2, 1889, ch. 411, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/25/960"},"text":"25 Stat. 960","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1888-10-02/ch1069/s1"},"text":"Oct. 2, 1888, ch. 1069, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/25/526"},"text":"25 Stat. 526","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9d73c56-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1946—Act ","children":[{"tag":"date","attrib":{"date":"1946-08-07"},"text":"Aug. 7, 1946","children":[],"tail":", struck out provisions requiring annual reports to Congress as to results of those examinations and surveys."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9d73c57-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Note