{"tag":"section","attrib":{"id":"idc9ecbf95-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"505a–2"},"text":"§ 505a–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asset Management Report enhancements for transferred works","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9ecbf96-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate with the non-Federal entities responsible for the operation and maintenance of transferred works in developing reporting requirements for Asset Management Reports with respect to major repair and rehabilitation needs for transferred works that are similar to the reporting requirements described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s505a–1/b"},"text":"section 505a–1(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9ecbf97-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9ecbf98-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After considering input from water and power contractors of the Bureau, the Secretary shall develop and implement a rating system for transferred works that incorporates, to the maximum extent practicable, the rating system for major repair and rehabilitation needs for reserved works developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s505a–1/b/3"},"text":"section 505a–1(b)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ecbf99-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The ratings system developed under paragraph (1) shall be included in the updated Asset Management Reports under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s505a–1/c"},"text":"section 505a–1(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9ecbf9a-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tVIII/s8603"},"text":"Pub. L. 116–9, title VIII, § 8603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/828"},"text":"133 Stat. 828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9ecbf9b-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9ecbf9c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idc9ecbf9d-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2"},"text":"section 2 of Pub. L. 116–9","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"section 1 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
