{"tag":"section","attrib":{"id":"idc9d28102-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–12j"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–12j"},"text":"§ 390h–12j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Orange County Regional Water Reclamation Project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d28103-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–12j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the appropriate State and local authorities, is authorized to participate in the design, planning, and construction of the Orange County Regional Water Reclamation Project, to reclaim and reuse water within the service area of the Orange County Water District in California.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d28104-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–12j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of a project described in subsection (a) shall not exceed 25 percent of the total cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d28105-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–12j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not provide funds for the operation or maintenance of a project described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d28106-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s1624"},"text":"Pub. L. 102–575, title XVI, § 1624","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/266/s2/a/2"},"text":"Pub. L. 104–266, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3292"},"text":"110 Stat. 3292","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tIX/s9111/c"},"text":"Pub. L. 111–11, title IX, § 9111(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1318"},"text":"123 Stat. 1318","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d28107-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d28108-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9d28109-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s9111/c/1"},"text":"Pub. L. 111–11, § 9111(c)(1)","children":[],"tail":", struck out “Phase 1 of the” before “Orange County” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s9111/c/2"},"text":"Pub. L. 111–11, § 9111(c)(2)","children":[],"tail":", struck out “phase 1 of” before “the Orange County”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
