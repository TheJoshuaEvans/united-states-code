{"tag":"section","attrib":{"id":"idc9e7ddd2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s485h–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"485h–3"},"text":"§ 485h–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Long-term contract” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in sections 485h–1 to 485h–5 of this title, the term “long-term contract” shall mean any contract the term of which is more than ten years.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9e7ddd3-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-07-02/ch492/s3"},"text":"July 2, 1956, ch. 492, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/484"},"text":"70 Stat. 484","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9e7ddd4-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9e7ddd5-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9e7ddd6-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Reclamation Project Act of 1939 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
