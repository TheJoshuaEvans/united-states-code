{"tag":"section","attrib":{"id":"idca95f948-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904"},"text":null,"children":[{"tag":"num","attrib":{"value":"2904"},"text":"§ 2904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility criteria","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca95f949-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish criteria for determining whether a facility is eligible for conveyance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f94a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95f94b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement of qualifying entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The criteria established under subsection (a) shall include a requirement that a qualifying entity shall agree—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f94c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept title to the eligible facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f94d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use the eligible facility for substantially the same purposes for which the eligible facility is being used at the time the Secretary evaluates the potential transfer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f94e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide, as consideration for the assets to be conveyed, compensation to the reclamation fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s391"},"text":"section 391 of this title","children":[],"tail":", in an amount that is the equivalent of the net present value of any repayment obligation to the United States or other income stream that the United States derives from the eligible facility to be transferred, as of the date of the transfer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f94f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations of Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The criteria established under subsection (a) shall include a requirement that the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f950-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be able to enter into an agreement with the qualifying entity with respect to the legal, institutional, and financial arrangements relating to the conveyance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f951-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" determine that the proposed transfer—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca95f952-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would not have an unmitigated significant effect on the environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f953-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is consistent with the responsibilities of the Secretary—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca95f954-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the role as trustee for federally recognized Indian Tribes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca95f955-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure compliance with any applicable international and Tribal treaties and agreements and interstate compacts and agreements;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f956-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the financial interest of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f957-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protects the public aspects of the eligible facility, including water rights managed for public purposes, such as flood control or fish and wildlife;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f958-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with all applicable Federal and State law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f959-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not result in an adverse impact on fulfillment of existing water delivery obligations consistent with historical operations and applicable contracts; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f95a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the eligible facility proposed to be transferred is a dam or diversion works (not including canals or other project features that receive or convey water from the diverting works) diverting water from a water body containing a species listed as a threatened species or an endangered species or critical habitat under the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.), determine that—"}],"tail":null},{"tag":"clause","attrib":{"id":"idca95f95b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible facility continues to comply with the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.) in a manner that provides no less protection to the listed species as existed under Federal ownership; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f95c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible facility is not part of the Central Valley Project in the State of California.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f95d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of reclamation land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The criteria established under subsection (a) shall require that any land to be conveyed out of Federal ownership under this chapter is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f95e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land acquired by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f95f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" land withdrawn by the Secretary, only if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca95f960-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines in writing that the withdrawn land is encumbered by facilities to the extent that the withdrawn land is unsuitable for return to the public domain; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f961-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the qualifying entity agrees to pay fair market value based on historical or existing uses for the withdrawn land to be conveyed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f962-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hold harmless","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No conveyance under this chapter shall adversely impact applicable Federal power rates, repayment obligations, or other project power uses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca95f963-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tVIII/s8004"},"text":"Pub. L. 116–9, title VIII, § 8004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/806"},"text":"133 Stat. 806","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca95f964-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca95f965-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca95f966-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Endangered Species Act of 1973, referred to in subsec. (b)(2)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/205"},"text":"Pub. L. 93–205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/884"},"text":"87 Stat. 884","children":[],"tail":", which is classified principally to chapter 35 (§ 1531 et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"section 1531 of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
