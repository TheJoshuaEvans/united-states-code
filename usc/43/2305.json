{"tag":"section","attrib":{"id":"idca8c82ce-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305"},"text":null,"children":[{"tag":"num","attrib":{"value":"2305"},"text":"§ 2305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Land Disposal Account","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8c82cf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other law (except a law that specifically provides for a proportion of the proceeds to be distributed to any trust funds of any States), the gross proceeds of the sale or exchange of public land under this chapter ","children":[{"tag":"ref","attrib":{"idref":"fn002176"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002176"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall be deposited in a separate account in the Treasury of the United States to be known as the “Federal Land Disposal Account”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c82d0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Federal Land Disposal Account shall be available to the Secretary and the Secretary of Agriculture, without further Act of appropriation, to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c82d1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of the Federal Land Disposal Account","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8c82d2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds in the Federal Land Disposal Account shall be expended in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c82d3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund allocation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8c82d4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purchase of land","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as authorized under subparagraph (C), funds shall be used to purchase lands or interests therein that are otherwise authorized by law to be acquired, and that are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca8c82d5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inholdings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8c82d6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjacent to federally designated areas and contain exceptional resources; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8c82d7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjacent to inaccessible lands open to public hunting, fishing, recreational shooting, or other recreational purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8c82d8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inholdings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less than 80 percent of the funds allocated for the purchase of land within each State shall be used to acquire inholdings identified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2303"},"text":"section 2303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecbc9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative and other expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An amount not to exceed 20 percent of the funds deposited in the Federal Land Disposal Account may be used by the Secretary for administrative and other expenses necessary to carry out the land disposal program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2304"},"text":"section 2304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecbca-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Same state purchases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the amounts not used under subparagraph (C), not less than 80 percent shall be expended within the State in which the funds were generated. Any remaining funds may be expended in any other State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecbcb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any funds made available under subparagraph (D) that are not obligated or expended by the end of the fourth full fiscal year after the date of the sale or exchange of land that generated the funds may be expended in any State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecbcc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary and the Secretary of Agriculture shall develop a procedure for prioritizing the acquisition of inholdings and non-Federal lands with exceptional resources as provided in paragraph (2). Such procedure shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8ecbcd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date the inholding was established (as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2303/c"},"text":"section 2303(c) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecbce-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the acquisition of the land or interest therein will increase the public availability of resources for, and facilitate public access to, hunting, fishing, and other recreational activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecbcf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which acquisition of the land or interest therein will facilitate management efficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecbd0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other criteria as the Secretary and the Secretary of Agriculture deem appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecbd1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis of sale","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any land acquired under this section shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8ecbd2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from a willing seller;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecbd3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contingent on the conveyance of title acceptable to the Secretary, or the Secretary of Agriculture in the case of an acquisition of National Forest System land, using title standards of the Attorney General;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecbd4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a price not to exceed fair market value consistent with applicable provisions of the Uniform Appraisal Standards for Federal Land Acquisitions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8ecbd5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" managed as part of the unit within which it is contained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8ecbd6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contaminated sites and sites difficult and uneconomic to manage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds in the Federal Land Disposal Account shall not be used to purchase land or an interest in land that, as determined by the Secretary or the Secretary of Agriculture—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8ecbd7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains a hazardous substance or is otherwise contaminated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8ecbd8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of the location or other characteristics of the land, would be difficult or uneconomic to manage as Federal land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8ecbd9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2305/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter 2003 of title 54","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under this section shall be supplemental to any funds appropriated under chapter 2003 of title 54.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8ecbda-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/248/tII/s206"},"text":"Pub. L. 106–248, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-25"},"text":"July 25, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/616"},"text":"114 Stat. 616","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s5"},"text":"Pub. L. 113–287, § 5","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(9), "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3271"},"text":"128 Stat. 3271","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dO/tIII/s302/5"},"text":"Pub. L. 115–141, div. O, title III, § 302(5)","children":[],"tail":"–(7), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1075"},"text":"132 Stat. 1075","children":[],"tail":", 1076.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca8ecbdb-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca8ecbdc-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca8ecbdd-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act” and was translated as reading “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/248"},"text":"Pub. L. 106–248","children":[],"tail":", which enacted this chapter, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca8ecbde-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s302/5/A"},"text":"Pub. L. 115–141, § 302(5)(A)","children":[],"tail":", substituted “inholdings;” for “inholdings; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s302/5/B"},"text":"Pub. L. 115–141, § 302(5)(B)","children":[],"tail":", substituted “exceptional resources; or” for “exceptional resources.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s302/5/C"},"text":"Pub. L. 115–141, § 302(5)(C)","children":[],"tail":", added cl. (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s302/5/D"},"text":"Pub. L. 115–141, § 302(5)(D)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(B) to (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s302/6"},"text":"Pub. L. 115–141, § 302(6)","children":[],"tail":", added subpar. (B) and redesignated former subpars. (B) and (C) as (C) and (D), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s302/7"},"text":"Pub. L. 115–141, § 302(7)","children":[],"tail":", struck out subsec. (f). Text read as follows: “On termination of activities under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s2304"},"text":"section 2304 of this title","children":[],"tail":"—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the Federal Land Disposal Account shall be terminated; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) any remaining balance in the account shall become available for appropriation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s200303"},"text":"section 200303 of title 54","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s5"},"text":"Pub. L. 113–287, § 5","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(9)(A), substituted “chapter 2003 of title 54” for “the Land and Water Conservation Fund Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460l–4"},"text":"16 U.S.C. 460l–4","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s5"},"text":"Pub. L. 113–287, § 5","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(9)(B), which directed substitution of “"},{"tag":"ref","attrib":{"href":"/us/usc/t54/s200303"},"text":"section 200303 of title 54","children":[],"tail":"” for “section 3 of the Land and Water Conservation Fund Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460"},"text":"16 U.S.C. 460","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–6)”, was executed by making the substitution for “section 3 of the Land and Water Conservation Fund Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460"},"text":"16 U.S.C. 460","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–6)” to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
