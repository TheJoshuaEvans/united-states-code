{"tag":"section","attrib":{"id":"idca094865-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776"},"text":null,"children":[{"tag":"num","attrib":{"value":"776"},"text":"§ 776.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cadastre of Federal real property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca094866-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca094867-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cadastre","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca094868-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “cadastre” means an inventory of real property developed through collecting, storing, retrieving, or disseminating graphical or digital data depicting natural or man-made physical features, phenomena, or boundaries of the earth, and any information related to the data, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca094869-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surveys;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca09486a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca09486b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca09486c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satellite and airborne remote sensing data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca09486d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" images; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca09486e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" services of an architectural or engineering nature performed by 1 or more professionals, as authorized to perform the services under State law, if applicable, such as—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca09486f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/1/A/vi/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a surveyor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca094870-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/1/A/vi/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a photogrammetrist;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca094871-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/1/A/vi/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a hydrographer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca094872-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/1/A/vi/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a geodesist; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca094873-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/1/A/vi/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cartographer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca094874-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “cadastre” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca094875-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reference frame consisting of a current geodetic network that is consistent with, and not duplicative of, the National Geodic Survey of the National Oceanic and Atmospheric Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca094876-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a series of current and accurate large-scale maps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca094877-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an existing cadastral boundary overlay delineating all cadastral parcels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca094878-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a system for indexing and identifying each cadastral parcel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca094879-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a series of land data files, each including the parcel identifier, which can be used to retrieve information and cross-reference between and among other existing data files that may contain information about the use, assets, and infrastructure of each parcel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca09487a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal real property","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca09487b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal real property” means any real property owned, leased, or otherwise managed by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca09487c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal real property” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca09487d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" real property held in trust by the Federal Government for the benefit of 1 or more Indian Tribes or individual Indians; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca09487e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restricted land owned by an Indian Tribe or individual Indians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca09487f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “real property” means real estate consisting of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca094880-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca094881-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" buildings, crops, forests, or other resources still attached to or within the land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca094882-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvements or fixtures permanently attached to the land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca094883-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any structure on the land; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca094884-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any interest, benefit, right, or privilege in the property described in subparagraphs (A) through (D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca094885-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary concerned","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretary concerned” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca094886-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca094887-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, acting through the Chief of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca094888-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cadastre of Federal real property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca094889-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency data standardization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", the Secretaries concerned shall jointly develop and adopt interagency standards to ensure compatibility and interoperability among applicable Federal databases with respect to the collection and dissemination of data relating to Federal real property."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca09488a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of cadastre","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", the Secretaries concerned, subject to the availability of appropriations, shall develop (and thereafter maintain) a current and accurate multipurpose cadastre of Federal real property under the jurisdiction of the Secretaries concerned to support Federal land management activities on Federal real property, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca09488b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resource development and conservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca09488c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca09488d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" active forest management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca09488e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental protection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca09488f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other use of the real property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca094890-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation and report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", the Secretaries concerned shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives a report describing—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca094891-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the existing real property inventories or any components of any cadastre of Federal real property currently authorized by law or maintained by the Secretary concerned, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca094892-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statutory authorization for each existing real property inventory or component of a cadastre; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca094893-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount expended by the Federal Government for each existing real property inventory or component of a cadastre in fiscal year 2022;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca094894-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the existing real property inventories or any components of any cadastre of Federal real property currently authorized by law or maintained by the Secretary concerned that will be eliminated or consolidated into the multipurpose cadastre under paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca094895-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca094896-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the existing real property inventories or any components of any cadastre of Federal real property currently authorized by law or maintained by the Secretary concerned that will not be eliminated or consolidated into the multipurpose cadastre under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca094897-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a justification for not eliminating or consolidating an existing real property inventory or component of a cadastre described in clause (i) into the multipurpose cadastre under paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca094898-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of existing real property inventories or any components of any cadastre currently maintained by any unit of State or local government that can be used to identify Federal real property within that unit of government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca094899-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost savings that will be achieved by eliminating or consolidating duplicative or unneeded real property inventories or any components of any cadastre of Federal real property currently authorized by law or maintained by the Secretary concerned that will become part of the multipurpose cadastre under paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca09489a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for the implementation of this section, including a cost estimate and an assessment of the feasibility of using revenue from any transactional activity authorized by law to offset any costs of implementing this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca09489b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for any legislation necessary to increase the cost savings and enhance the effectiveness and efficiency of replacing, eliminating, or consolidating Federal real property inventories or any components of any cadastre of Federal real property currently authorized by law or maintained by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca09489c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca09489d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretaries concerned shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca09489e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate (in accordance with section 216 of the E-Government Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3501"},"text":"44 U.S.C. 3501","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/107/347"},"text":"Public Law 107–347","children":[],"tail":") and section 757 of the Geospatial Data Act of 2018 ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s2806"},"text":"43 U.S.C. 2806","children":[],"tail":")) in the establishment of such standards and common protocols as are necessary to ensure the interoperability of geospatial information pertaining to the cadastre under paragraph (2) for all users of the information;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca09489f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate with, seek assistance and cooperation of, and provide liaison to the Federal Geographic Data Committee established by section 753(a) of the Geospatial Data Act of 2018 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2802/a"},"text":"43 U.S.C. 2802(a)","children":[],"tail":") for the implementation of and compliance with such standards and requirements of that Act as may be applicable to—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idca0948a0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cadastre under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca0948a1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any aspect of the development of the cadastre under paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca0948a2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrate, or make the cadastre interoperable with, the Federal Real Property Profile or other inventories established pursuant to Executive Order 13327 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s121"},"text":"40 U.S.C. 121","children":[],"tail":" note; relating to Federal real property asset management), the Federal Assets Sale and Transfer Act of 2016 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s1303"},"text":"40 U.S.C. 1303","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/114/287"},"text":"Public Law 114–287","children":[],"tail":"), or the Federal Property Management Reform Act of 2016 ("},{"tag":"ref","attrib":{"href":"/us/pl/114/318"},"text":"Public Law 114–318","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/130/1608"},"text":"130 Stat. 1608","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca0948a3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, integrate with and leverage current cadastre activities of units of State and local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca0948a4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts considered surveying and mapping","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca0948a5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A contract between the Secretaries concerned and a member of the private sector to provide products and services for the development of the cadastre shall be considered to be a contract for services of surveying and mapping (within the meaning of chapter 11 of title 40).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca0948a6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A contract described in clause (i) shall be entered into in accordance with the selection procedures in chapter 11 of title 40.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca0948a7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transparency and public access","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca0948a8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with any requirements applicable to the Secretary concerned under section 759 of the Geospatial Data Act of 2018 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2808"},"text":"43 U.S.C. 2808","children":[],"tail":"), make the cadastre under subsection (b)(2) publicly available on the internet—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca0948a9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a graphically geo-enabled and searchable format; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca0948aa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that is consistent with, and meets any requirements for integration with, the GeoPlatform established under section 758(a) of that Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2807/a"},"text":"43 U.S.C. 2807(a)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca0948ab-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the inventory referred to in subsection (b) includes the identification of all land suitable for disposal and the appraised value of the land, if an appraisal has been conducted, in accordance with the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca0948ac-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the Secretary of Defense and the Secretary of Homeland Security, prevent the disclosure of any parcel or parcels of land, any buildings or facilities on the land, or any information related to the land, buildings, or facilities if that disclosure would impair or jeopardize the national security or homeland defense of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca0948ad-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any data that is part of the cadastre developed under subsection (b)(2) shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca0948ae-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considered to be geospatial data for purposes of the Geospatial Data Act of 2018 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2801"},"text":"43 U.S.C. 2801","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca0948af-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the requirements of that Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca0948b0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca0948b1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creates any substantive or procedural right or benefit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca0948b2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" requires or authorizes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca0948b3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any new surveying or mapping of Federal real property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca0948b4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the evaluation of any parcel of land or other real property for potential management by a non-Federal entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca0948b5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disposal of any Federal real property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca0948b6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any new appraisal or assessment of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca0948b7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/e/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of any parcel of Federal land or other real property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca0948b8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s776/e/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cultural and archaeological resources on any parcel of Federal land or other real property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca0948b9-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tI/s103"},"text":"Pub. L. 117–328, div. DD, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5576"},"text":"136 Stat. 5576","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca0948ba-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca0948bb-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca0948bc-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Property Management Reform Act of 2016, referred to in subsec. (b)(4)(A)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/318/s1"},"text":"Pub. L. 114–318, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1608"},"text":"130 Stat. 1608","children":[],"tail":", which enacted subchapter VII of chapter 5 of Title 40, Public Buildings, Property, and Works, and chapter 29 of Title 39, Postal Service, amended sections 102, 524, and 571 of Title 40, enacted provisions set out as notes under sections 571 and 621 of Title 40, and amended provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s1303"},"text":"section 1303 of Title 40","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s101"},"text":"section 101 of Title 40","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in subsec. (c)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Geospatial Data Act of 2018 and that Act, referred to in subsec. (d), is subtitle F (§§ 751–759C) of title VII of div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3413"},"text":"132 Stat. 3413","children":[],"tail":", which is classified generally to chapter 46 (§ 2801 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s2801"},"text":"section 2801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca0bb8bd-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idca0bb8be-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/s1"},"text":"Pub. L. 117–328, div. DD, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5574"},"text":"136 Stat. 5574","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dDD/s1"},"text":"“In this division [see Tables for classification], the term ‘Secretary’ means the Secretary of the Interior.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
