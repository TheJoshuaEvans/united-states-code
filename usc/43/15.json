{"tag":"section","attrib":{"id":"idc9a2bede-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"§ 15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance and signing of patents by Secretary of the Interior; delegation of authority; notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All patents for public lands shall be issued and signed by the Secretary of the Interior in the name of the United States: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the Secretary may delegate his authority under this section to officers or employees of the Department of the Interior, but notice of any such delegation shall be given by publication in the Federal Register."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9a2bedf-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-17/ch496/s1"},"text":"June 17, 1948, ch. 496, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/476"},"text":"62 Stat. 476","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9a52ee0-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9a52ee1-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc9a52ee2-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 15, R.S. § 458; 1940 Reorg. Plan No. III, § 4 eff. ","children":[{"tag":"date","attrib":{"date":"1940-06-30"},"text":"June 30, 1940","children":[],"tail":", 5 F.R. 2108, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1232"},"text":"54 Stat. 1232","children":[],"tail":"; 1946 Reorg. Plan No. 3, § 403, eff. "},{"tag":"date","attrib":{"date":"1946-07-16"},"text":"July 16, 1946","children":[],"tail":", 11 F.R. 7876, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1100"},"text":"60 Stat. 1100","children":[],"tail":", related to issuance of patents, prior to repeal by section 2(c) of act "},{"tag":"date","attrib":{"date":"1948-06-17"},"text":"June 17, 1948","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idc9a52ee3-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idc9a52ee4-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1451"},"text":"section 1451 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
