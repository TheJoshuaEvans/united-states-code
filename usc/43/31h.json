il":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9a9ead0-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 31a to 31h of this title, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/285"},"text":"Pub. L. 102–285","children":[],"tail":", known as the National Geologic Mapping Act of 1992, which is classified principally to sections 31a to 31h of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s31a"},"text":"section 31a of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc9a9ead1-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 31h, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/285/s9"},"text":"Pub. L. 102–285, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-18"},"text":"May 18, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/171"},"text":"106 Stat. 171","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/36/s3/g"},"text":"Pub. L. 105–36, § 3(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1111"},"text":"111 Stat. 1111","children":[],"tail":", authorized appropriations for the national cooperative geologic mapping program, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/106/148/s9"},"text":"Pub. L. 106–148, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1724"},"text":"113 Stat. 1724","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9a9ead2-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" substituted “2031” for “2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9"},"text":"Pub. L. 116–9","children":[],"tail":" substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s11001/i/1"},"text":"Pub. L. 111–11, § 11001(i)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which appropriated funds to carry out sections 31a to 31h of this title for fiscal years 1999 to 2005."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s11001/i/2/A"},"text":"Pub. L. 111–11, § 11001(i)(2)(A)","children":[],"tail":", substituted “2005” for “2000” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s11001/i/2/B"},"text":"Pub. L. 111–11, § 11001(i)(2)(B)","children":[],"tail":", substituted “50” for “48”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s11001/i/2/C"},"text":"Pub. L. 111–11, § 11001(i)(2)(C)","children":[],"tail":", which directed amendment of par. (2) “by striking 2 and inserting ‘4’ ”, was executed by substituting “4” for “2”, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"cros