{"tag":"section","attrib":{"id":"idc9ecbfa8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s507"},"text":null,"children":[{"tag":"num","attrib":{"value":"507"},"text":"§ 507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction for dam safety","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s509b"},"text":"section 509b of this title","children":[],"tail":", construction authorized by this subchapter shall be for the purposes of dam safety and not for the specific purposes of providing additional conservation storage capacity or of developing benefits over and above those provided by the original dams and reservoirs. Nothing in this subchapter shall be construed to reduce the amount of project costs allocated to reimbursable purposes heretofore authorized."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9ecbfa9-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/578/s3"},"text":"Pub. L. 95–578, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2471"},"text":"92 Stat. 2471","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dD/tII/s203/1"},"text":"Pub. L. 114–113, div. D, title II, § 203(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2406"},"text":"129 Stat. 2406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9ecbfaa-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9ecbfab-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9ecbfac-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":" substituted “Except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s509b"},"text":"section 509b of this title","children":[],"tail":", construction” for “Construction”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
