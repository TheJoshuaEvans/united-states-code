{"tag":"section","attrib":{"id":"idca5f305f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1629e"},"text":"§ 1629e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlement Trust option","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca5f3060-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyance of corporate assets","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca5f3061-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f3062-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Native Corporation may convey assets (including stock or beneficial interests therein) to a Settlement Trust in accordance with the laws of the State (except to the extent that such laws are inconsistent with this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1629b"},"text":"section 1629b of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f3063-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The approval of the shareholders of the corporation in the form of a resolution shall be required to convey all or substantially all of the assets of the corporation to a Settlement Trust. A conveyance in violation of this clause shall be void ab initio and shall not be given effect by any court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f3064-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No subsurface estate in land shall be conveyed to a Settlement Trust. A conveyance of title to, or any other interest in, subsurface estate in violation of this subparagraph shall be void ab initio and shall not be given effect by any court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f3065-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Conveyances made pursuant to this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f3066-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be subject to applicable laws respecting fraudulent conveyance and creditors rights; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f3067-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall give rise to dissenters rights to the extent provided under the laws of the State only if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca5f3068-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rights of beneficiaries in the Settlement Trust receiving a conveyance are inalienable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f3069-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a shareholder vote on such transfer is required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1629b/a/4"},"text":"section 1629b(a)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f306a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this subsection shall not prohibit a Native Corporation from engaging in any conveyance, reorganization, or transaction not otherwise prohibited under the laws of the State or the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca5f306b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority and limitations of a Settlement Trust","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca5f306c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The purpose of a Settlement Trust shall be to promote the health, education, and welfare of its beneficiaries and preserve the heritage and culture of Natives. A Settlement Trust shall not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f306d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate as a business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f306e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alienate land or any interest in land received from the settlor Native Corporation (except if the recipient of the land is the settlor corporation or the land is conveyed for a homesite by the Trust to a beneficiary of the Trust who is also a legal resident under Alaska law of the Native village of the settlor corporation and the conveyance does not exceed 1.5 acres); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f306f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discriminate in favor of a group of individuals composed only or principally of employees, officers, or directors of the settlor Native Corporation.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"An alienation of land or an interest in land in violation of this paragraph shall be void ab initio and shall not be given effect by any court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f3070-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A Native Corporation that has established a Settlement Trust shall have exclusive authority to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f3071-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint the trustees of the trust, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f3072-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remove the trustees of the trust for cause.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Only a natural person shall be appointed a trustee of a Settlement Trust. An appointment or removal of a trustee in violation of this paragraph shall be void ab initio and shall not be given effect by any court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f3073-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Native Corporation that has established a Settlement Trust may expand the class of beneficiaries to include holders of Settlement Common Stock issued after the establishment of the trust without compensation to the original beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f3074-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Settlement Trust shall not be held to violate any laws against perpetuities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca5f3075-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca5f3076-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this chapter shall continue to apply to any land or interest in land received from the Federal Government pursuant to this chapter and later conveyed to a Settlement Trust as if the land or interest in land were still held by the Native Corporation that conveyed the land or interest in land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f3077-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No timber resources subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1606/i"},"text":"section 1606(i) of this title","children":[],"tail":" conveyed to a Settlement Trust shall be sold, exchanged, or otherwise conveyed except as necessary to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f3078-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dispose of diseased or dying timber or to prevent the spread of disease or insect infestation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f3079-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent or suppress fire; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f307a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure public safety.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The revenue, if any, from such timber harvests shall be subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1606/i"},"text":"section 1606(i) of this title","children":[],"tail":" as if such conveyance had not occurred."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f307b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The conveyance of assets (including stock or beneficial interests) pursuant to subsection (a) shall not affect the applicability or enforcement (including specific performance) of a valid contract, judgment, lien, or other obligation (including an obligation arising under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1606/i"},"text":"section 1606(i) of this title","children":[],"tail":") to which such assets, stock, or beneficial interests were subject immediately prior to such conveyance."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f307c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A claim based upon paragraph (1), (2), or (3) shall be enforceable against the transferee Settlement Trust holding the land, interest in land, or other assets (including stock or beneficial interests) in question to the same extent as such claim would have been enforceable against the transferor Native Corporation, and valid obligations arising under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1606/i"},"text":"section 1606(i) of this title","children":[],"tail":" as well as claims with respect to a conveyance in violation of a valid contract, judgment, lien, or other obligation shall also be enforceable against the transferor corporation."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f307d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraphs (1), (2), (3), and (4), once a Native Corporation has made, pursuant to subsection (a), a conveyance to a Settlement Trust that does not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f307e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" render it—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca5f307f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/c/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unable to satisfy claims based upon paragraph (1), (2), or (3); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f3080-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/c/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insolvent; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f3081-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occur when the Native Corporation is insolvent;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the assets so conveyed to the Settlement Trust shall not be subject to attachment, distraint, or sale on execution of judgment or other process or order of any court, except with respect to the lawful debts or obligations of the Settlement Trust.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f3082-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No transferee Settlement Trust shall make a distribution or conveyance of assets (including cash, stock, or beneficial interests) that would render it unable to satisfy a claim made pursuant to paragraph (1), (2), or (3). A distribution or conveyance made in violation of this paragraph shall be void ab initio and shall not be given effect by any court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f3083-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except where otherwise expressly provided, no provision of this section shall be construed to require shareholder approval of an action where shareholder approval would not be required under the laws of the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f3084-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629e/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A beneficiary’s interest in a settlement trust and the distributions thereon shall be subject to creditor action (including without limitation, levy attachment, pledge, lien, judgment execution, assignment, and the insolvency and bankruptcy laws) only to the extent that Settlement Common Stock and the distributions thereon are subject to such creditor action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1606/h"},"text":"section 1606(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca5f3085-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203/s39"},"text":"Pub. L. 92–203, § 39","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/241/s10"},"text":"Pub. L. 100–241, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-02-03"},"text":"Feb. 3, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1804"},"text":"101 Stat. 1804","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/333/s13"},"text":"Pub. L. 105–333, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3135"},"text":"112 Stat. 3135","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/559/tIII/s302"},"text":"Pub. L. 106–559, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2782"},"text":"114 Stat. 2782","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tIII/s337/b"},"text":"Pub. L. 108–7, div. F, title III, § 337(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/278"},"text":"117 Stat. 278","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/221/tI/s101/b"},"text":"Pub. L. 109–221, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-05-12"},"text":"May 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/337"},"text":"120 Stat. 337","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca5f3086-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca5f3087-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca5f3088-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221/s101/b/1"},"text":"Pub. L. 109–221, § 101(b)(1)","children":[],"tail":", made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/s337/b"},"text":"Pub. L. 108–7, § 337(b)","children":[],"tail":". See 2003 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221/s101/b/2"},"text":"Pub. L. 109–221, § 101(b)(2)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1629b/a/4"},"text":"section 1629b(a)(4) of this title","children":[],"tail":"” for “(a)(4) of "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1629b"},"text":"section 1629b of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/s337/b"},"text":"Pub. L. 108–7, § 337(b)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us