{"tag":"section","attrib":{"id":"idca390b08-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1471"},"text":null,"children":[{"tag":"num","attrib":{"value":"1471"},"text":"§ 1471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations; availability for payment of property damages","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Appropriations for contingent expenses of the Department of the Interior shall be available, to the extent specified therein, for the payment of damages to private property (not to exceed $500 in any one case) caused by the negligent operation of motor vehicles under such appropriations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca390b09-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-25/ch472/s2"},"text":"June 25, 1946, ch. 472, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/306"},"text":"60 Stat. 306","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca390b0a-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca390b0b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca390b0c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s693"},"text":"section 693 of Title 31","children":[],"tail":" prior to the general revision and enactment of Title 31, Money and Finance, by "},{"tag":"ref","attrib":{"href":