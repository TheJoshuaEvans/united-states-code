{"tag":"section","attrib":{"id":"idc9b387f8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s127"},"text":null,"children":[{"tag":"num","attrib":{"value":"127"},"text":"§ 127.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change of boundaries of land districts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is authorized to change and reestablish the boundaries of land districts whenever, in his opinion, the public interests will be subserved thereby, without authority to increase the number of land offices or land districts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9b387f9-3a70-11f1-bde1-a5140e158598"},"text":"(R.S. § 2253.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9b387fa-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9b387fb-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9b387fc-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2253 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1870-06-29/ch171"},"text":"act June 29, 1870, ch. 171","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/16/171"},"text":"16 Stat. 171","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idc9b387fd-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"idc9b387fe-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation to Secretary of the Interior of authority vested in President by this section, see Ex. Ord. No. 10250, ","children":[{"tag":"date","attrib":{"date":"1951-06-05"},"text":"June 5, 1951","children":[],"tail":", 16 F.R. 5385, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
