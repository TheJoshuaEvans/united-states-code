{"tag":"section","attrib":{"id":"idca95f916-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2811"},"text":null,"children":[{"tag":"num","attrib":{"value":"2811"},"text":"§ 2811.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private sector","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Committee and each covered agency may, to the maximum extent practical, rely upon and use the private sector in the United States for the provision of geospatial data and services.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca95f917-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tVII/s759C"},"text":"Pub. L. 115–254, div. B, title VII, § 759C","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3427"},"text":"132 Stat. 3427","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
