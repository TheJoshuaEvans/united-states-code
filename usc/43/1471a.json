{"tag":"section","attrib":{"id":"idca390b0d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1471a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1471a"},"text":"§ 1471a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations for emergency repair or replacement of damaged or destroyed facilities and equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Appropriations in this title ","children":[{"tag":"ref","attrib":{"idref":"fn002088"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002088"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or appropriations made under this title "},{"tag":"ref","attrib":{"idref":"fn002088"},"text":"1","children":[],"tail":" in subsequent Energy and Water Development Appropriations Acts shall on and after "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"October 2, 1992","children":[],"tail":", be available for expenditure or transfer (within each bureau or office), with the approval of the Secretary, for the emergency reconstruction, replacement, or repair of aircraft, buildings, utilities or other facilities or equipment damaged, rendered inoperable, or destroyed by fire, flood, storm, drought, or other unavoidable causes: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That no funds shall be made available under this authority until funds specifically made available to the Department of the Interior for emergencies shall have been exhausted."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca390b0e-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/377/tII/s201"},"text":"Pub. L. 102–377, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1331"},"text":"106 Stat. 1331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca390b0f-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca390b10-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca390b11-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in text, is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/377"},"text":"Pub. L. 102–377","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1327"},"text":"106 Stat. 1327","children":[],"tail":". For complete classification of title II to Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
