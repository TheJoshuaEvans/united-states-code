{"tag":"section","attrib":{"id":"idca8c8246-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2223"},"text":null,"children":[{"tag":"num","attrib":{"value":"2223"},"text":"§ 2223.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan elements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8c8247-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2223/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Elements of the contingency plans prepared pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2222"},"text":"section 2222 of this title","children":[],"tail":" may include, but are not limited to, any or all of the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8c8248-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2223/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Water banks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c8249-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2223/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriate water conservation actions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c824a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2223/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Water transfers to serve users inside or outside authorized Federal Reclamation project service areas in order to mitigate the effects of drought.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c824b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2223/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use of Federal Reclamation project facilities to store and convey nonproject water for agricultural, municipal and industrial, fish and wildlife, or other uses both inside and outside an authorized Federal Reclamation project service area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c824c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2223/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use of water from dead or inactive reservoir storage or increased use of ground water resources for temporary water supplies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c824d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2223/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Water supplies for fish and wildlife resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c824e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2223/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Minor structural actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c824f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2223/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Reclamation projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each contingency plan shall identify the following two types of plan elements related to Federal Reclamation projects:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8c8250-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2223/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Those plan elements which pertain exclusively to the responsibilities and obligations of the Secretary pursuant to Federal Reclamation law and the responsibilities and obligations of the Secretary for a specific Federal Reclamation project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c8251-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2223/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Those plan elements that pertain to projects, purposes, or activities not constructed, financed, or otherwise governed by the Federal Reclamation law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c8252-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2223/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drought levels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to work with other Federal and State agencies to improve hydrologic data collection systems and water supply forecasting techniques to provide more accurate and timely warning of potential drought conditions and drought levels that would trigger the implementation of contingency plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c8253-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2223/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The contingency plans and plan elements shall comply with all requirements of applicable Federal law, including the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":"), "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2265/a"},"text":"section 2265(a) of title 33","children":[],"tail":", and the Fish and Wildlife Coordination Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s661"},"text":"16 U.S.C. 661","children":[],"tail":" et seq.], and shall be in accordance with applicable State law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c8254-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2223/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The contingency plans shall include provisions for periodic review to assure the adequacy of the contingency plan to respond to current conditions, and such plans may be modified accordingly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8c8255-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/250/tII/s203"},"text":"Pub. L. 102–250, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-05"},"text":"Mar. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/57"},"text":"106 Stat. 57","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca8c8256-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca8c8257-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca8c8258-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Fish and Wildlife Coordination Act, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-03-10/ch55"},"text":"act Mar. 10, 1934, ch. 55","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/401"},"text":"48 Stat. 401","children":[],"tail":", which is classified generally to sections 661 to 666c–1 of Title 16, Conservation. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s661/a"},"text":"section 661(a) of Title 16","children":[],"tail":", Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s661"},"text":"section 661 of Title 16","children":[],"tail":", and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
