{"tag":"section","attrib":{"id":"idca048dbe-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s625"},"text":null,"children":[{"tag":"num","attrib":{"value":"625"},"text":"§ 625.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release of unentered land from lien on noncompletion of irrigation project","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior may, upon the expiration of ten years from the date of his approval of said map and plan of any irrigation district, release from the lien authorized by this chapter any unentered land or lands upon which final certificate has not issued, for which irrigation works have not been constructed and water of such district made available for the land.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca048dbf-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch319/s3"},"text":"Aug. 11, 1916, ch. 319, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/508"},"text":"39 Stat. 508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca048dc0-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca048dc1-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca048dc2-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of the first proviso in section 3 of act ","children":[{"tag":"date","attrib":{"date":"1916-08-11"},"text":"Aug. 11, 1916","children":[],"tail":". The remainder of section 3 is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s623"},"text":"section 623 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
