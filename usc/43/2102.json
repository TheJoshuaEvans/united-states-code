{"tag":"section","attrib":{"id":"idca8a10c6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2102"},"text":null,"children":[{"tag":"num","attrib":{"value":"2102"},"text":"§ 2102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8a10c7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “embedded” means firmly affixed in the submerged lands or in coralline formations such that the use of tools of excavation is required in order to move the bottom sediments to gain access to the shipwreck, its cargo, and any part thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a10c8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “National Register” means the National Register of Historic Places maintained by the Secretary of the Interior under section 101 of the National Historic Preservation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s470a"},"text":"16 U.S.C. 470a","children":[],"tail":"); "},{"tag":"ref","attrib":{"idref":"fn002173"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002173"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a10c9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “public lands”, “Indian lands”, and “Indian tribe” have the same meaning given the terms in the Archaeological Resource ","children":[{"tag":"ref","attrib":{"idref":"fn002174"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002174"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “Resources”."}],"tail":" Protection Act of 1979 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s470aa–470"},"text":"16 U.S.C. 470aa–470","children":[],"tail":null},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a10ca-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “shipwreck” means a vessel or wreck, its cargo, and other contents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a10cb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2102/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means a State of the United States, the District of Columbia, Puerto Rico, Guam, the Virgin Islands, American Samoa, and the Northern Mariana Islands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a10cc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2102/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “submerged lands” means the lands—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8a10cd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2102/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are “lands beneath navigable waters,” as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1301"},"text":"section 1301 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8a10ce-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2102/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of Puerto Rico, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s749"},"text":"section 749 of title 48","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8a10cf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2102/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of Guam, the Virgin Islands and American Samoa, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1705"},"text":"section 1705 of title 48","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8a10d0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2102/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the Commonwealth of the Northern Mariana Islands, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/241/s801"},"text":"section 801 of Public Law 94–241","children":[],"tail":"."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8a10d1-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/298/s3"},"text":"Pub. L. 100–298, § 3","children":[],"tail":", "},{"tag":"date","attrib":{