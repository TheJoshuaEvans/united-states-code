{"tag":"section","attrib":{"id":"idca1a11ce-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s984"},"text":null,"children":[{"tag":"num","attrib":{"value":"984"},"text":"§ 984.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal subdivisions mostly wet and unfit for cultivation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In making out lists and plats of the lands aforesaid all legal subdivisions, the greater part whereof is wet and unfit for cultivation, shall be included in said lists and plats, but when the greater part of a subdivision is not of that character, the whole of it shall be excluded therefrom.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca1a11cf-3a70-11f1-bde1-a5140e158598"},"text":"(R.S. § 2481.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca1a11d0-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca1a11d1-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca1a11d2-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2481 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1850-09-28/ch84/s3"},"text":"act Sept. 28, 1850, ch. 84, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/519"},"text":"9 Stat. 519","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
