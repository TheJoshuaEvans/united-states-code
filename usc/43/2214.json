{"tag":"section","attrib":{"id":"idca8c8233-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2214"},"text":null,"children":[{"tag":"num","attrib":{"value":"2214"},"text":"§ 2214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable period of drought program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8c8234-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2214/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The programs and authorities established under this subchapter shall become operative in any Reclamation State and in the State of Hawaii only after the Governor or Governors of the affected State or States, or on a reservation, when the governing body of the affected tribe has made a request for temporary drought assistance and the Secretary has determined that such temporary assistance is merited, or upon the approval of a drought contingency plan as provided in subchapter II of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c8235-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2214/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with BPA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a Governor referred to in subsection (a) is the Governor of the State of Washington, Oregon, Idaho, or Montana, the Governor shall coordinate with the Administrator of the Bonneville Power Administration before making a request under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c8236-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2214/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authorities established under this subchapter shall terminate on ","children":[{"tag":"date","attrib":{"date":"2028-09-30"},"text":"September 30, 2028","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8c8237-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/250/tI/s104"},"text":"Pub. L. 102–250, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-05"},"text":"Mar. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/56"},"text":"106 Stat. 56","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/566/tII/s201/a"},"text":"Pub. L. 106–566, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2820"},"text":"114 Stat. 2820","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/234/tII/s2306/a"},"text":"Pub. L. 109–234, title II, § 2306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-06-15"},"text":"June 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/456"},"text":"120 Stat. 456","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/212/tI/s404/a"},"text":"Pub. L. 111–212, title I, § 404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2313"},"text":"124 Stat. 2313","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/76/dD/tI