{"tag":"section","attrib":{"id":"idca1c5b2b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1065"},"text":null,"children":[{"tag":"num","attrib":{"value":"1065"},"text":"§ 1065.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summary removal of inclosures","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is authorized to take such measures as shall be necessary to remove and destroy any unlawful inclosure of any of the public lands mentioned in this chapter, and to employ civil or military force as may be necessary for that purpose.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca1c5b2c-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1885-02-25/ch149/s5"},"text":"Feb. 25, 1885, ch. 149, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/23/322"},"text":"23 Stat. 322","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
