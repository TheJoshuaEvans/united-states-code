{"tag":"section","attrib":{"id":"idc9cb557e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"390b–1"},"text":"§ 390b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving planning and administration of water supply storage","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9cb557f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each water supply feature of a reservoir managed by the Secretary, the Secretary shall notify the applicable non-Federal interests before each fiscal year of the anticipated operation and maintenance activities for that fiscal year and each of the subsequent 4 fiscal years (including the cost of those activities) for which the non-Federal interests are required to contribute amounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cb5580-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information provided to a non-Federal interest under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9cb5581-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–1/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be an estimate which the non-Federal interest may use for planning purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9cb5582-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–1/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be construed as or relied upon by the non-Federal interest as the actual amounts that the non-Federal interest will be required to contribute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9cb5583-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tI/s1046/b"},"text":"Pub. L. 113–121, title I, § 1046(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1254"},"text":"128 Stat. 1254","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9cb5584-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9cb5585-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9cb5586-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
