{"tag":"section","attrib":{"id":"idca094836-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s766"},"text":null,"children":[{"tag":"num","attrib":{"value":"766"},"text":"§ 766.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geological surveys, extension of public surveys, expenses of subdividing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be no further geological survey by the Government, unless authorized by law. The public surveys shall extend over all mineral lands; and all subdividing of surveyed lands into lots less than one hundred and sixty acres may be done by county and local surveyors at the expense of claimants; but nothing in this section contained shall require the survey of waste or useless lands.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca094837-3a70-11f1-bde1-a5140e158598"},"text":"(R.S. § 2406.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca094838-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca094839-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca09483a-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2406 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1852-07-21/ch66/s1"},"text":"July 21, 1852, ch. 66, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/10/15"},"text":"10 Stat. 15","children":[],"tail":", 21; "},{"tag":"ref","attrib":{"href":"/us/act/1870-07-09/ch235/s16"},"text":"July 9, 1870, ch. 235, § 16","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/16/218"},"text":"16 Stat. 218","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca09483b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca09483c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Section as Unaffected by Submerged Lands Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of this section as not amended, modified or repealed by the Submerged Lands Act, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1303"},"text":"section 1303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
