{"tag":"section","attrib":{"id":"idc9d00fa4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–7"},"text":"§ 390h–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tucson area water reclamation study","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d00fa5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the State of Arizona and appropriate local and regional entities, shall conduct a feasibility study of comprehensive water reclamation and reuse system for Southern Arizona. For the purpose of this section, the term “Southern Arizona” means those portions of the counties of Pima, Santa Cruz, and Pinal within the Tucson Active Management Hydrologic Area as defined by the Arizona Department of Water Resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d00fa6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the costs of the study authorized by this section shall not exceed 50 per centum of the total.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d00fa7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit the report authorized by this section to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives not later than four years after appropriation of funds authorized by sections 390h to 390h–39 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d00fa8-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s1609"},"text":"Pub. L. 102–575, title XVI, § 1609","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-30"},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4666"},"text":"106 Stat. 4666","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s16/a/2"},"text":"Pub. L. 103–437, § 16(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4594"},"text":"108 Stat. 4594","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d00fa9-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d00faa-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9d00fab-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" substituted “Natural Resources” for “Interior and Insular Affairs” before “of the House”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
