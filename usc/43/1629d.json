{"tag":"section","attrib":{"id":"idca5f3039-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1629d"},"text":"§ 1629d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissenters rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca5f303a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca5f303b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding the laws of the State, if the shareholders of a Native Corporation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f303c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to approve an amendment authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1629c/b"},"text":"section 1629c(b) of this title","children":[],"tail":" to terminate alienability restrictions, a shareholder who voted for the amendment may demand payment from the corporation for all of his or her shares of Settlement Common Stock; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f303d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve an amendment authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1629c/d"},"text":"section 1629c(d) of this title","children":[],"tail":" to continue alienability restrictions without issuing alienable common stock pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1629c/d/6"},"text":"section 1629c(d)(6) of this title","children":[],"tail":", a shareholder who voted against the amendment may demand payment from the corporation for all of his or her shares of Settlement Common Stock."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f303e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f303f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A demand for payment made pursuant to paragraph (1)(A) shall be honored only if at the same time as the vote giving rise to the demand, the shareholders of the corporation approved a resolution providing for the purchase of Settlement Common Stock from dissenting shareholders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f3040-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A demand for payment made pursuant to paragraph (1)(B) shall be honored.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca5f3041-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to State procedure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca5f3042-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this section, the laws of the State governing the right of a dissenting shareholder to demand and receive payment for his or her shares shall apply to demands for payment honored pursuant to subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f3043-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The board of directors of a Native Corporation may approve a resolution to provide a dissenting shareholder periods of time longer than those provided under the laws of the State to take actions required to demand and receive payment for his or her shares.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca5f3044-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Valuation of stock","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca5f3045-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Prior to a vote described in subsection (a)(1), the board of directors of a Native Corporation may approve a resolution to provide that one or more of the following conditions will apply in the event a demand for payment is honored pursuant to subsection (a)(2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f3046-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Settlement Common Stock shall be valued as restricted stock; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f3047-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the value of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca5f3048-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any land conveyed to the corporation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1613/h/1"},"text":"section 1613(h)(1) of this title","children":[],"tail":" or any other land used as a cemetery; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f3049-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the surface estate of any land that is both—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca5f304a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/c/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempt from real estate taxation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1636/d/1/A"},"text":"section 1636(d)(1)(A) of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca5f304b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/c/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used by the shareholders of the corporation for subsistence uses (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3113"},"text":"section 3113 of title 16","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f304c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any land or interest in land which the board of directors believes to be only of speculative value;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be excluded by the shareholder making the demand for payment, the corporation purchasing the Settlement Common Stock of the shareholder, and any court determining the fair value of the shares of Settlement Common Stock to be purchased.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f304d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person shall have a claim against a Native Corporation or its board of directors based upon the failure of the board to approve a resolution authorized by this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca5f304e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of payment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca5f304f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Prior to a vote described in subsection (a)(1), the board of directors of a Native Corporation may approve a resolution to provide that in the event a demand for payment is honored pursuant to subsection (a)(2) payments to each dissenting shareholder shall be made by the corporation through the issuance of a negotiable note in the principal amount of the payment due, which shall be secured by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f3050-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a payment bond issued by an insurance company or financial institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f3051-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deposit in escrow of securities or property having a fair market value equal to at least 125 per centum of the face value of the note; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f3052-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a lien upon real property interests of the corporation valued at 125 percent or more of the face amount of the note, except that no such lien shall be applicable to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca5f3053-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land conveyed to the corporation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1613/h/1"},"text":"section 1613(h)(1) of this title","children":[],"tail":", or any other land used as a cemetery;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f3054-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage interest in the corporation’s timber resources and subsurface estate that exceeds its percentage interest in revenues from such property under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1606/i"},"text":"section 1606(i) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f3055-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/d/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the surface estate of land that is both—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca5f3056-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/d/1/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempt from real estate taxation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1636/d/1/A"},"text":"section 1636(d)(1)(A) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca5f3057-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/d/1/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used by the shareholders of the corporation for subsistence uses (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3113"},"text":"section 3113 of title 16","children":[],"tail":"),"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless the Board of Directors ","children":[{"tag":"ref","attrib":{"idref":"fn002129"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002129"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" of the corporation acts so as to make such lien applicable to such surface estate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f3058-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A note issued pursuant to paragraph (1) shall provide that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f3059-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest shall be paid semi-annually, beginning as of the date on which the vote described in subsection (a)(1) occurred, at the rate applicable on such date to obligations of the United States having a maturity date of one year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f305a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the principal amount and accrued interest on such note shall be payable to the holder at a time specified by the corporation but in no event later than the date that is five years after the date of the vote described in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca5f305b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dividend adjustment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca5f305c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cash payment made pursuant to subsection (a) or the principal amount of a note issued pursuant to subsection (d) to a dissenting shareholder shall be reduced by the amount of dividends paid to such shareholder with respect to his or her Settlement Common Stock after the date of the vote described in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f305d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon receipt of a cash payment pursuant to subsection (a) or a note pursuant to subsection (d), a dissenting shareholder shall no longer have an interest in the shares of Settlement Common Stock or in the Native Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca5f305e-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203/s38"},"text":"Pub. L. 92–203, § 38","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/241/s9"},"text":"Pub. L. 100–241, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-02-03"},"text":"Feb. 3, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1802"},"text":"101 Stat. 1802","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
