{"tag":"section","attrib":{"id":"idc9bf6e72-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316g"},"text":null,"children":[{"tag":"num","attrib":{"value":"316g"},"text":"§ 316g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9bf6e73-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall determine for each lease the grazing fee to be paid. Such fee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9bf6e74-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Be fixed on the basis of the area leased or on the basis of the number and kind of stock permitted to be grazed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9bf6e75-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Be fixed, for the period of the lease, as a seasonal or annual fee, payable annually or semi-annually on the date specified in the lease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9bf6e76-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316g/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Be fixed with due regard to the general economic value of the grazing privileges, and in no case shall exceed such value; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9bf6e77-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316g/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Be moderate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9bf6e78-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary determines such action to be for the public interest by reason of (1) depletion or destruction of the range by any cause beyond the control of the lessee, or (2) calamity or disease causing wholesale destruction of or injury to livestock, he may grant an extension of time for making payment of any grazing fee undue any lease, reduce the amount of any such payment, or release or discharge the lessee from making such payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9bf6e79-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch513/s8"},"text":"Mar. 4, 1927, ch. 513, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1453"},"text":"44 Stat. 1453","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9bf6e7a-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9bf6e7b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9bf6e7c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s471g"},"text":"section 471g of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
