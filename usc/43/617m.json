{"tag":"section","attrib":{"id":"idc9faf04c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s617m"},"text":null,"children":[{"tag":"num","attrib":{"value":"617m"},"text":"§ 617m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reclamation law applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This subchapter shall be deemed a supplement to the reclamation law, which said reclamation law shall govern the construction, operation, and management of the works herein authorized, except as otherwise therein provided.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9faf04d-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-12-21/ch42/s14"},"text":"Dec. 21, 1928, ch. 42, § 14","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1065"},"text":"45 Stat. 1065","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9faf04e-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9faf04f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9faf050-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The reclamation law, referred to in text, is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s617k"},"text":"section 617k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
