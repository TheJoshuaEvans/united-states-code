{"tag":"section","attrib":{"id":"idca42814a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1575a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1575a"},"text":"§ 1575a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration and disposition of lands and constructed facilities; revenues credited to general fund of Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is hereby authorized to administer and dispose of lands and interests in lands acquired, and facilities constructed under this subchapter, and revenues received in connection with this authority shall be credited to the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca42814b-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/320/tI/s106"},"text":"Pub. L. 93–320, title I, § 106","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/336/s4"},"text":"Pub. L. 96–336, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-04"},"text":"Sept. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1064"},"text":"94 Stat. 1064","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca42814c-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca42814d-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idca42814e-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/320/s106"},"text":"section 106 of Pub. L. 93–320","children":[],"tail":" was renumbered section 107 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1576"},"text":"section 1576 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
