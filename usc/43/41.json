{"tag":"section","attrib":{"id":"idc9aea55b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s41"},"text":null,"children":[{"tag":"num","attrib":{"value":"41"},"text":"§ 41.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publications and reports; preparation and sale","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s1318"},"text":"section 1318 of title 44","children":[],"tail":", the publications of the United States Geological Survey shall consist of geological and economic maps, illustrating the resources and classification of the lands, and reports upon general and economic geology and paleontology. All special memoirs and reports of said survey shall be issued in uniform quarto series if deemed necessary by the director, but otherwise in ordinary octavos. Three thousand copies of each shall be published for scientific exchanges and for sale at the price of publication, and all literary and cartographic materials received in exchange shall be the property of the United States and form a part of the library of the organization; and the money resulting from the sale of such publications shall be covered into the Treasury of the United States, under the direction of the Secretary of the Interior."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9aea55c-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1879-03-03/ch182"},"text":"Mar. 3, 1879, ch. 182","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/20/394"},"text":"20 Stat. 394","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-07/ch770/s1/10"},"text":"Aug. 7, 1946, ch. 770, § 1(10)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/867"},"text":"60 Stat. 867","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/154/tI"},"text":"Pub. L. 102–154, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-13"},"text":"Nov. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1000"},"text":"105 Stat. 1000","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9aea55d-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9aea55e-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9aea55f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s1318"},"text":"Section 1318 of title 44","children":[],"tail":"” substituted in text for “"},{"tag":"ref","attrib":{"href":"/us/usc/t44/s260"},"text":"section 260 of title 44","children":[],"tail":"” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/90/620/s2/b"},"text":"Pub. L. 90–620, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1238"},"text":"82 Stat. 1238","children":[],"tail":", the first section of which enacted Title 44, Public Printing and Documents."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “Except as otherwise provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s260"},"text":"section 260 of title 44","children":[],"tail":"” were originally inserted in text to avoid conflict with the provisions of such "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s260"},"text":"section 260 of title 44","children":[],"tail":", as set out prior to the general revision of title 44 by "},{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", derived from Joint Res. "},{"tag":"date","attrib":{"date":"1902-05-16"},"text":"May 16, 1902","children":[],"tail":", No. 22."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9aea560-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1946—Act ","children":[{"tag":"date","attrib":{"date":"1946-08-07"},"text":"Aug. 7, 1946","children":[],"tail":", repealed all provisions requiring preparation, and transmission by Secretary of the Interior, of an annual report of operations."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9aea561-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idc9aea562-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States Geological Survey” substituted in text for “Geological Survey” pursuant to provision of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/154"},"text":"Pub. L. 102–154","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s31"},"text":"section 31 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idc9aea563-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idc9aea564-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1451"},"text":"section 1451 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
