{"tag":"section","attrib":{"id":"idc9b5d127-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s147"},"text":null,"children":[{"tag":"num","attrib":{"value":"147"},"text":"§ 147.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of proceeds of sale of withdrawn lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The moneys derived from the sale of such lands and improvements shall be disposed of as are other receipts from the sale and disposal of public lands.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9b5d128-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-01-26/ch27/s3"},"text":"Jan. 26, 1921, ch. 27, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1090"},"text":"41 Stat. 1090","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
