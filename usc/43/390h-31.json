{"tag":"section","attrib":{"id":"idc9d281b8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–31"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–31"},"text":"§ 390h–31.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" South Bay advanced recycled water treatment facility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d281b9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–31/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the City of San Jose, California, and the Santa Clara Valley Water District, is authorized to participate in the design, planning, and construction of recycled water treatment facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d281ba-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–31/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of the project authorized by this section shall not exceed 25 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d281bb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–31/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not provide funds for the operation and maintenance of the project authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d281bc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–31/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $8,250,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d281bd-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s1648"},"text":"Pub. L. 102–575, title XVI, § 1648","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/229/tV/s512/a/1"},"text":"Pub. L. 110–229, title V, § 512(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-08"},"text":"May 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/842"},"text":"122 Stat. 842","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
