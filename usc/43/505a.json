{"tag":"section","attrib":{"id":"idc9ecbf6b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a"},"text":null,"children":[{"tag":"num","attrib":{"value":"505a"},"text":"§ 505a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In sections 505a to 505a–2 of this title:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9ecbf6c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asset","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9ecbf6d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “asset” means any of the following assets that are used to achieve the mission of the Bureau to manage, develop, and protect water and related resources in an environmentally and economically sound manner in the interest of the people of the United States:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9ecbf6e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Capitalized facilities, buildings, structures, project features, power production equipment, recreation facilities, or quarters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ecbf6f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Capitalized and noncapitalized heavy equipment and other installed equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ecbf70-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “asset” includes assets described in subparagraph (A) that are considered to be mission critical.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ecbf71-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asset Management Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Asset Management Report” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9ecbf72-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual plan prepared by the Bureau known as the “Asset Management Plan”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ecbf73-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any publicly available information relating to the plan described in subparagraph (A) that summarizes the efforts of the Bureau to evaluate and manage infrastructure assets of the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ecbf74-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major repair and rehabilitation need","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “major repair and rehabilitation need” means major nonrecurring maintenance at a Reclamation facility, including maintenance related to the safety of dams, extraordinary maintenance of dams, deferred major maintenance activities, and all other significant repairs and extraordinary maintenance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9ecbf75-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tVIII/s8601"},"text":"Pub. L. 116–9, title VIII, § 8601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/827"},"text":"133 Stat. 827","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9ecbf76-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9ecbf77-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9ecbf78-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 505a to 505a–2 of this title, referred to in text, was in the original “this part”, which was translated as reading “this subtitle”, meaning subtitle G of title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9"},"text":"Pub. L. 116–9","children":[],"tail":", which is classified generally to sections 505a to 505a–2 of this title, to reflect the probable intent of Congress. Subtitle G of title VIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/9"},"text":"Pub. L. 116–9","children":[],"tail":" does not contain parts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
