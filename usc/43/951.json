{"tag":"section","attrib":{"id":"idca17a00b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s951"},"text":null,"children":[{"tag":"num","attrib":{"value":"951"},"text":"§ 951.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of way for water transportation, domestic purposes, or development of power","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Rights of way for ditches, canals, or reservoirs heretofore or hereafter approved under the provisions of sections 946 to 949 of this title may be used for purposes of a public nature; and said rights of way may be used for purposes of water transportation, for domestic purposes, or for the development of power, as subsidiary to the main purpose of irrigation or drainage.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca17a00c-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1898-05-11/ch292/s2"},"text":"May 11, 1898, ch. 292, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/404"},"text":"30 Stat. 404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1917-03-04/ch184/s2"},"text":"Mar. 4, 1917, ch. 184, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/1197"},"text":"39 Stat. 1197","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca17a00d-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca17a00e-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca17a00f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal; Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579/tVII/s706/a"},"text":"Pub. L. 94–579, title VII, § 706(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2793"},"text":"90 Stat. 2793","children":[],"tail":", effective on and after "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", insofar as applicable to the issuance of rights-of-way over, upon, under, and through the public lands and lands in the National Forest System. Such repeal not to be construed as terminating any valid lease, permit, patent, etc., existing on "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/579/s701"},"text":"section 701 of Pub. L. 94–579","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
