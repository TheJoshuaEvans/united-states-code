{"tag":"section","attrib":{"id":"idc9ba8cab-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s301"},"text":null,"children":[{"tag":"num","attrib":{"value":"301"},"text":"§ 301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to make all necessary rules and regulations in harmony with the provisions and purposes of this subchapter for the purpose of carrying the same into effect.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9ba8cac-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-12-29/ch9/s11"},"text":"Dec. 29, 1916, ch. 9, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/865"},"text":"39 Stat. 865","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
