{"tag":"section","attrib":{"id":"idca986917-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008"},"text":null,"children":[{"tag":"num","attrib":{"value":"3008"},"text":"§ 3008.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewable energy revenue sharing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca986918-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca986919-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" County","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “county” includes a parish, township, borough, and any other similar, independent unit of local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca98691a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered land” means land that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca98691b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public land administered by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca98691c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not excluded from the development of solar or wind energy under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca98691d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a land use plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca98691e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca98691f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Forest System","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca986920-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Forest System” means land of the National Forest System (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1609/a"},"text":"section 1609(a) of title 16","children":[],"tail":") administered by the Secretary of Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca986921-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Forest System” does not include any forest reserve not created from the public domain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca986922-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “public land” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca986923-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public lands (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1702"},"text":"section 1702 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca986924-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Forest System land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca986925-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewable energy project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “renewable energy project” means a system described in section 2801.9(a)(4) of title 43, Code of Federal Regulations (as in effect on ","children":[{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":"), located on covered land that uses wind or solar energy to generate energy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca986926-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretary” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca986927-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior, with respect to land controlled or administered by the Secretary of the Interior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca986928-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, with respect to National Forest System land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca986929-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of revenue","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca98692a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of revenues","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning on ","children":[{"tag":"date","attrib":{"date":"2026-01-01"},"text":"January 1, 2026","children":[],"tail":", the amounts collected from a renewable energy project as bonus bids, rentals, fees, or other payments under a right-of-way, permit, lease, or other authorization shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca98692b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be deposited in the general fund of the Treasury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca98692c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" without further appropriation or fiscal year limitation, be allocated as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca98692d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent shall be paid from amounts in the general fund of the Treasury to the State within the boundaries of which the revenue is derived.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca98692e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent shall be paid from amounts in the general fund of the Treasury to each county in a State within the boundaries of which the revenue is derived, to be allocated among each applicable county based on the percentage of county land from which the revenue is derived.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca98692f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to States and counties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca986930-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts paid to States and counties under paragraph (1) shall be used in accordance with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s191"},"text":"section 191 of title 30","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca986931-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments in lieu of taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A payment to a county under paragraph (1) shall be in addition to a payment in lieu of taxes received by the county under chapter 69 of title 31.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca986932-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3008/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts required to be paid under paragraph (1)(B) for an applicable fiscal year shall be made available in the fiscal year that immediately follows the fiscal year for which the amounts were collected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca986933-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tV/s50303"},"text":"Pub. L. 119–21, title V, § 50303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/150"},"text":"139 Stat. 150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca986934-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca986935-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca986936-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":", and not as part of subtitle B of title III of div. Z of "},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" which comprises this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
