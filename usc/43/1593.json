{"tag":"section","attrib":{"id":"idca44f19f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1593"},"text":null,"children":[{"tag":"num","attrib":{"value":"1593"},"text":"§ 1593.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning reports; research and demonstration projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca44f1a0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1593/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary is authorized and directed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca44f1a1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1593/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Expedite completion of the planning reports on the following units, described in the Secretary’s report, “Colorado River Water Quality Improvement Program, February 1972”;","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca44f1a2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1593/a/1/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Irrigation source control:","children":[{"tag":"p","attrib":{"role":"listItem"},"text":"Lower Gunnison","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Uintah Basin","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Colorado River Indian Reservation","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Palo Verde Irrigation District","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca44f1a3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1593/a/1/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Point source control:","children":[{"tag":"p","attrib":{"role":"listItem"},"text":"LaVerkin Springs","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Littlefield Springs","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Glenwood-Dotsero Springs","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca44f1a4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1593/a/1/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Diffuse source control:","children":[{"tag":"p","attrib":{"role":"listItem"},"text":"Price River","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"San Rafael River","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Dirty Devil River","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"McElmo Creek","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Big Sandy River","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca44f1a5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1593/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Submit each planning report on the units named in paragraph (1) of this subsection promptly to the Colorado River Basin States and to such other parties as the Secretary deems appropriate for their review and comments. After receipt of comments on a unit and careful consideration thereof, the Secretary shall submit each final report with his recommendations, simultaneously, to the President, other concerned Federal departments and agencies, the Congress, and the Colorado River Basin States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca44f1a6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1593/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary is directed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca44f1a7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1593/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the investigation, planning, construction, and implementation of any salinity control unit involving control of salinity from irrigation sources, to cooperate with the Secretary of Agriculture in carrying out research and demonstration projects and in implementing on-the-farm improvements and farm management practices and programs which will further the objective of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca44f1a8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1593/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to undertake research on additional methods for accomplishing the objective of this subchapter, utilizing to the fullest extent practicable the capabilities and resources of other Federal departments and agencies, interstate institutions, States, and private organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca44f1a9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1593/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop a comprehensive program for minimizing salt contributions to the Colorado River from lands administered by the Bureau of Land Management and submit a report which describes the program and recommended implementation actions to the Congress and to the members of the advisory council established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1594/a"},"text":"section 1594(a) of this title","children":[],"tail":" by "},{"tag":"date","attrib":{"date":"1987-07-01"},"text":"July 1, 1987","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca44f1aa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1593/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to undertake feasibility investigations of saline water use and disposal opportunities, including measures and all necessary appurtenant and associated works, to demonstrate saline water use technology and to beneficially use and dispose of saline and brackish waters of the Colorado River Basin in joint ventures with current and future industrial water users, using, but not limited to, the concepts generally described in the Bureau of Reclamation Special Report of September 1981, entitled “Saline water use and disposal opportunities”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca44f1ab-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1593/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to undertake advance planning activities on the Sinbad Valley Unit, Colorado, as described in the Bureau of Land Management Salinity Status Report, covering the period 1978–1979 and dated February 1980.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca44f1ac-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/320/tII/s203"},"text":"Pub. L. 93–320, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-06-24"},"text":"June 24, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/271"},"text":"88 Stat. 271","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/569/s3"},"text":"Pub. L. 98–569, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2937"},"text":"98 Stat. 2937","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca44f1ad-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca44f1ae-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca44f1af-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/569"},"text":"Pub. L. 98–569","children":[],"tail":" added pars. (3) to (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca44f1b0-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idca44f1b1-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/569"},"text":"Pub. L. 98–569","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/569/s6"},"text":"section 6 of Pub. L. 98–569","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1591"},"text":"section 1591 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
