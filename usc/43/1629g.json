{"tag":"section","attrib":{"id":"idca5f3097-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1629g"},"text":"§ 1629g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Open season for certain Alaska Native veterans for allotments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca5f3098-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca5f3099-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During the eighteen month period following promulgation of implementing rules pursuant to subsection (e), a person described in subsection (b) shall be eligible for an allotment of not more than two parcels of federal ","children":[{"tag":"ref","attrib":{"idref":"fn002131"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002131"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" land totaling 160 acres or less under the Act of "},{"tag":"date","attrib":{"date":"1906-05-17"},"text":"May 17, 1906","children":[],"tail":" (chapter 2469; "},{"tag":"ref","attrib":{"href":"/us/stat/34/197"},"text":"34 Stat. 197","children":[],"tail":"), as such Act was in effect before "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"December 18, 1971","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f309a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Allotments may be selected only from lands that were vacant, unappropriated, and unreserved on the date when the person eligible for the allotment first used and occupied those lands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f309b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may not convey allotments containing any of the following—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f309c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lands upon which a native or non-native campsite is located, except for a campsite used primarily by the person selecting the allotment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f309d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lands selected by, but not conveyed to, the State of Alaska pursuant to the Alaska Statehood Act or any other provision of law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f309e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lands selected by, but not conveyed to, a Village or Regional Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f309f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lands designated as wilderness by statute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f30a0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquired lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f30a1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lands containing a building, permanent structure, or other development owned or controlled by the United States, another unit of government, or a person other than the person selecting the allotment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f30a2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lands withdrawn or reserved for national defense purposes other than National Petroleum Reserve-Alaska;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f30a3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Forest Lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f30a4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" lands selected or claimed, but not conveyed, under a public land law, including but not limited to the following:","children":[],"tail":null},{"tag":"level","attrib":{"id":"idca5f30a5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/3/I/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lands within a recorded mining claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"level","attrib":{"id":"idca5f30a6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/3/I/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Home sites.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"level","attrib":{"id":"idca5f30a7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/3/I/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Trade and Manufacturing sites.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"level","attrib":{"id":"idca5f30a8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/3/I/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reindeer sites or headquarters sites.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"level","attrib":{"id":"idca5f30a9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/3/I/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cemetery sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f30aa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person who qualifies for an allotment on lands prohibited from conveyance by a provision of subsection (a)(3) may select an alternative allotment from the following lands located within the geographic boundaries of the same Regional Corporation as the excluded allotment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f30ab-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lands withdrawn pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1610/a/1"},"text":"section 1610(a)(1) of this title","children":[],"tail":" which were not selected, or were relinquished after selection;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f30ac-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lands contiguous to the outer boundary of lands withdrawn pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1610/a/1/C"},"text":"section 1610(a)(1)(C) of this title","children":[],"tail":", except lands excluded from selection by a provision of subsection (a)(3) and lands within a National Park; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f30ad-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vacant, unappropriated and unreserved lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f30ae-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After consultation with a person entitled to an allotment within a Conservation System Unit, the Secretary may convey alternative lands of equal acreage, including lands within a Conservation System Unit, to that person if the Secretary determines that the allotment would be incompatible with a purpose for which the Conservation System Unit was established.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f30af-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" All conveyances under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f30b0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be subject to valid existing rights, including any right of the United States to income derived, directly or indirectly, from a lease, license, permit, right-of-way or easement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f30b1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reserve to the United States deposits of oil, gas and coal, together with the right to explore, mine, and remove these minerals, on lands which the Secretary determines to be prospectively valuable for development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca5f30b2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible person","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca5f30b3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person is eligible to select an allotment under this section if that person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f30b4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would have been eligible for an allotment under the Act of ","children":[{"tag":"date","attrib":{"date":"1906-05-17"},"text":"May 17, 1906","children":[],"tail":" (chapter 2469; "},{"tag":"ref","attrib":{"href":"/us/stat/34/197"},"text":"34 Stat. 197","children":[],"tail":"), as that Act was in effect before "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"December 18, 1971","children":[],"tail":" (except that the term “nonmineral”, as used in that Act, shall for the purpose of this subsection be defined as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1634/a/3"},"text":"section 1634(a)(3) of this title","children":[],"tail":", except that such definition shall not apply to land within a conservation system unit); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f30b5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is a veteran who served during the period between ","children":[{"tag":"date","attrib":{"date":"1969-01-01"},"text":"January 1, 1969","children":[],"tail":" and "},{"tag":"date","attrib":{"date":"1971-12-31"},"text":"December 31, 1971","children":[],"tail":" and—"}],"tail":null},{"tag":"clause","attrib":{"id":"idca5f30b6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served at least 6 months between ","children":[{"tag":"date","attrib":{"date":"1969-01-01"},"text":"January 1, 1969","children":[],"tail":" and "},{"tag":"date","attrib":{"date":"1971-12-31"},"text":"December 31, 1971","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f30b7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enlisted or was drafted into military service after ","children":[{"tag":"date","attrib":{"date":"1971-06-02"},"text":"June 2, 1971","children":[],"tail":" but before "},{"tag":"date","attrib":{"date":"1971-12-03"},"text":"December 3, 1971","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f30b8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f30b9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The personal representative or special administrator, appointed in an Alaska State court proceeding of the estate of a decedent who was eligible under subsection (b)(1)(A) may, for the benefit of the heirs, select an allotment if the decedent was a veteran who served in South East Asia at any time during the period beginning ","children":[{"tag":"date","attrib":{"date":"1964-08-05"},"text":"August 5, 1964","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"1971-12-31"},"text":"December 31, 1971","children":[],"tail":", and during that period the decedent—"}],"tail":null},{"tag":"clause","attrib":{"id":"idca5f30ba-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was killed in action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f30bb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was wounded in action and subsequently died as a direct consequence of that wound, as determined by the Department of Veterans Affairs or based on other evidence acceptable to the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f30bc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" died while a prisoner of war.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f30bd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca5f30be-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary requests that the Secretary of Veterans Affairs make a determination whether a veteran died as a direct consequence of a wound received in action, the Secretary of Veterans Affairs shall, within 60 days of receipt of the request—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca5f30bf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a determination to the Secretary if the records of the Department of Veterans Affairs contain sufficient information to support such a determination; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca5f30c0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the Secretary that the records of the Department of Veterans Affairs do not contain sufficient information to support a determination and that further investigation will be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca5f30c1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 1 year after notification to the Secretary that further investigation is necessary, the Department of Veterans Affairs shall complete the investigation and provide a determination to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f30c2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person who received an allotment or has a pending allotment under the Act of ","children":[{"tag":"date","attrib":{"date":"1906-05-17"},"text":"May 17, 1906","children":[],"tail":" may receive an allotment under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca5f30c3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca5f30c4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Interior shall conduct a study to identify and assess the circumstances of veterans of the Vietnam era who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca5f30c5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served during a period other than that specified in subsection (b)(1)(B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f30c6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were eligible for an allotment under the Act of ","children":[{"tag":"date","attrib":{"date":"1906-05-17"},"text":"May 17, 1906","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca5f30c7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" did not apply for an allotment under that Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f30c8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, within one year of ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"October 21, 1998","children":[],"tail":", issue a written report on the study, including findings and recommendations, to the Committee on Appropriations and the Committee on Energy and Natural Resources in the Senate and the Committee on Appropriations and the Committee on Resources in the House of Representatives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca5f30c9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, the terms “veteran” and “Vietnam era” have the meanings given those terms by paragraphs (2) and (29), respectively, of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca5f30ca-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629g/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"October 21, 1998","children":[],"tail":", the Secretary of the Interior shall promulgate, after consultation with Alaska Natives groups, rules to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca5f30cb-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203/s41"},"text":"Pub. L. 92–203, § 41","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tIV/s432"},"text":"Pub. L. 105–276, title IV, § 432","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2516"},"text":"112 Stat. 2516","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/559/tIII/s301"},"text":"Pub. L. 106–559, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2782"},"text":"114 Stat. 2782","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/452/tIII/s306"},"text":"Pub. L. 108–452, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3590"},"text":"118 Stat. 3590","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca5f30cc-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca5f30cd-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca5f30ce-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attr