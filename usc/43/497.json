{"tag":"section","attrib":{"id":"idc9ea4f24-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s497"},"text":null,"children":[{"tag":"num","attrib":{"value":"497"},"text":"§ 497.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action to recover operation charge and penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the discretion of the Secretary of the Interior suit or action may be brought for the amounts of operation or maintenance charges in default and penalties in like manner as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s481"},"text":"section 481 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9ea4f25-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-08-13/ch247/s6"},"text":"Aug. 13, 1914, ch. 247, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/688"},"text":"38 Stat. 688","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9ea4f26-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9ea4f27-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9ea4f28-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of third sentence of section 6 of act ","children":[{"tag":"date","attrib":{"date":"1914-08-13"},"text":"Aug. 13, 1914","children":[],"tail":". First and second sentences of such section 6 are classified to sections 479, 493, 494, 495, and 496 of this title, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
