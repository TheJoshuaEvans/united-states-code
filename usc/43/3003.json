{"tag":"section","attrib":{"id":"idca9868bb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3003"},"text":null,"children":[{"tag":"num","attrib":{"value":"3003"},"text":"§ 3003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increasing economic certainty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca9868bc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may consider acreage rental rates, capacity fees, and other recurring annual fees in total when evaluating existing rates paid for the use of Federal land by eligible projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9868bd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reductions in base rental rates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may reduce acreage rental rates and capacity fees, or both, for existing and new wind and solar authorizations if the Secretary determines—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9868be-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3003/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that the existing rates—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9868bf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3003/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exceed fair market value;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9868c0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3003/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose economic hardships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9868c1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3003/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit commercial interest in a competitive lease sale or right-of-way grant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9868c2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3003/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not competitively priced compared to other available land; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9868c3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3003/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that a reduced rental rate or capacity fee is necessary to promote the greatest use of wind and solar energy resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca9868c4-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3103"},"text":"Pub. L. 116–260, div. Z, title III, § 3103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2516"},"text":"134 Stat. 2516","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
