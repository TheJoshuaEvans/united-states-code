{"tag":"section","attrib":{"id":"idca390b23-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1471d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1471d"},"text":"§ 1471d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations for transportation, reprint, telephone, and library membership expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Appropriations in this title ","children":[{"tag":"ref","attrib":{"idref":"fn002091"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002091"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or appropriations made under this title "},{"tag":"ref","attrib":{"idref":"fn002091"},"text":"1","children":[],"tail":" in subsequent Energy and Water Development Appropriations Acts shall on and after "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"October 2, 1992","children":[],"tail":", be available for hire, maintenance, and operation of aircraft; hire of passenger motor vehicles; purchases of reprints; payment for telephone services in private residences in the field, when authorized under regulations approved by the Secretary; and the payment of dues, when authorized by the Secretary, for library memberships in societies or associations which issue publications to members only or at a price to members lower than to subscribers who are not members."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca390b24-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/377/tII/s204"},"text":"Pub. L. 102–377, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1332"},"text":"106 Stat. 1332","children":[],"tai