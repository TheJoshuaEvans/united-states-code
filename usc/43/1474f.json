{"tag":"section","attrib":{"id":"idca3b54af-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1474f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1474f"},"text":"§ 1474f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sums received by the Bureau of Land Management from vendors under enterprise information technology-procurements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Sums not to exceed 1 percent of the total value of procurements received by the Bureau of Land Management from vendors under enterprise information technology-procurements that the Department of the Interior and other Federal Government agencies may use to order information technology on and after ","children":[{"tag":"date","attrib":{"date":"2009-03-11"},"text":"March 11, 2009","children":[],"tail":", may be deposited into the Management of Lands and Resources account to offset costs incurred in conducting the procurement."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca3b54b0-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8/dE/tI"},"text":"Pub. L. 111–8, div. E, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/704"},"text":"123 Stat. 704","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca3b54b1-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca3b54b2-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca3b54b3-3a70-11f1-bde1-a5140e158598"}