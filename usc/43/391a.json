{"tag":"section","attrib":{"id":"idc9d73bc9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s391a"},"text":null,"children":[{"tag":"num","attrib":{"value":"391a"},"text":"§ 391a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advances to reclamation fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury is authorized, upon request of the Secretary of the Interior and upon approval of the President, to transfer from time to time to the credit of the reclamation fund created by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s391"},"text":"section 391 of this title","children":[],"tail":", such sum or sums, not exceeding in the aggregate $5,000,000, as the Secretary of the Interior may deem necessary for the construction and operation of reclamation projects authorized under the Act of "},{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/32/388"},"text":"32 Stat. 388","children":[],"tail":"), and under way on "},{"tag":"date","attrib":{"date":"1931-03-03"},"text":"March 3, 1931","children":[],"tail":", and Acts amendatory thereof or supplementary thereto."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9d73bca-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1931-03-03/ch435/s1"},"text":"Mar. 3, 1931, ch. 435, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/1507"},"text":"46 Stat. 1507","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d73bcb-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d73bcc-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9d73bcd-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":", referred to in text, is popularly known as the Reclamation Act, which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
