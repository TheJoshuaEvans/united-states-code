{"tag":"section","attrib":{"id":"idca9d23e5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207"},"text":null,"children":[{"tag":"num","attrib":{"value":"3207"},"text":"§ 3207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multi-benefit projects to improve watershed health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca9d23e6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible applicant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible applicant” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9d23e7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9d23e8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Tribal or local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9d23e9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization with power or water delivery authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9d23ea-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regional authority; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9d23eb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit conservation organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9d23ec-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of competitive grant program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary, in consultation with the heads of relevant agencies, shall establish a competitive grant program under which the Secretary shall award grants to eligible applicants for the design, implementation, and monitoring of conservation outcomes of habitat restoration projects that improve watershed health in a river basin that is adversely impacted by a Bureau of Reclamation water project by accomplishing 1 or more of the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9d23ed-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ecosystem benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9d23ee-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Restoration of native species.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9d23ef-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mitigation against the impacts of climate change to fish and wildlife habitats.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9d23f0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Protection against invasive species.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9d23f1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Restoration of aspects of the natural ecosystem.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9d23f2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enhancement of commercial, recreational, subsistence, or Tribal ceremonial fishing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9d23f3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enhancement of river-based recreation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9d23f4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9d23f5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding a grant to an eligible applicant under subsection (b), the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9d23f6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall give priority to an eligible applicant that would carry out a habitat restoration project that achieves more than 1 of the benefits described in that subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9d23f7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not provide a grant to carry out a habitat restoration project the purpose of which is to meet existing environmental mitigation or compliance obligations under Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9d23f8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A habitat restoration project awarded a grant under subsection (b) shall comply with all applicable Federal and State laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9d23f9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal share of the cost of any habitat restoration project that is awarded a grant under subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9d23fa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not exceed 50 percent of the cost of the habitat restoration project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9d23fb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3207/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a habitat restoration project that provides benefits to ecological or recreational values in which the nonconsumptive water conservation benefit or habitat restoration benefit accounts for at least 75 percent of the cost of the habitat restoration project, as determined by the Secretary, shall not exceed 75 percent of the cost of the habitat restoration project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca9d23fc-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIX/s40907"},"text":"Pub. L. 117–58, div. D, title IX, § 40907","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1125"},"text":"135 Stat. 1125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca9d23fd-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca9d23fe-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca9d23ff-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
