{"tag":"section","attrib":{"id":"idca724371-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1743"},"text":null,"children":[{"tag":"num","attrib":{"value":"1743"},"text":"§ 1743.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of financial interests by officers or employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca724372-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1743/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual written statement; availability to public","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each officer or employee of the Secretary and the Bureau who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca724373-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1743/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs any function or duty under this Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca724374-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1743/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has any known financial interest in any person who (A) applies for or receives any permit, lease, or right-of-way under, or (B) applies for or acquires any land or interests therein under, or (C) is otherwise subject to the provisions of, this Act,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall, beginning on ","children":[{"tag":"date","attrib":{"date":"1977-02-01"},"text":"February 1, 1977","children":[],"tail":", annually file with the Secretary a written statement concerning all such interests held by such officer or employee during the preceding calendar year. Such statement shall be available to the public."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca724375-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1743/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca724376-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1743/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" act within ninety days after ","children":[{"tag":"date","attrib":{"date":"1976-10-21"},"text":"October 21, 1976","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca724377-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1743/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to define the term “known financial interests” for the purposes of subsection (a) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca724378-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1743/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish the methods by which the requirement to file written statements specified in subsection (a) of this section will be monitored and enforced, including appropriate provisions for the filing by such officers and employees of such statements and the review by the Secretary of such statements; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca724379-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1743/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Congress on June 1 of each calendar year with respect to such disclosures and the actions taken in regard thereto during the preceding calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca72437a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1743/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempted personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the rules prescribed in subsection (b) of this section, the Secretary may identify specific positions within the Department of the Interior which are of a nonregulatory or nonpolicymaking nature and provide that officers or employees occupying such positions shall be exempt from the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca72437b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1743/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations; criminal penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any officer or employee who is subject to, and knowingly violates, this section, shall be fined not more than $2,500 or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca72437c-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579/tIII/s313"},"text":"Pub. L. 94–579, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2768"},"text":"90 Stat. 2768","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca72437d-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca72437e-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca72437f-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a)(1), (2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", known as the Federal Land Policy and Management Act of 1976. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca724380-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca724381-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (b) of this section relating to the requirement that the Secretary report to Congress on June 1 of each calendar year, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and the 2nd item on page 108 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
