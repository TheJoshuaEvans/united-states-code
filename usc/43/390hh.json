{"tag":"section","attrib":{"id":"idc9d4cb2d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390hh"},"text":null,"children":[{"tag":"num","attrib":{"value":"390hh"},"text":"§ 390hh.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation and maintenance charges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d4cb2e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390hh/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Price adequate to recover charges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The price of irrigation water delivered by the Secretary pursuant to a contract or an amendment to a contract with a district, as specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390cc"},"text":"section 390cc of this title","children":[],"tail":", shall be at least sufficient to recover all operation and maintenance charges which the district is obligated to pay to the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d4cb2f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390hh/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever a district enters into a contract or requests that its contract be amended as specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390cc"},"text":"section 390cc of this title","children":[],"tail":", and each year thereafter, the Secretary shall calculate such operation and maintenance charges and shall modify the price of irrigation water delivered under the contract as necessary to reflect any changes in such costs by amending the district’s contract accordingly."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d4cb30-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390hh/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Districts not operating from Federal funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to districts which operate and maintain project facilities and finance the operation and maintenance thereof from non-Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d4cb31-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/293/tII/s208"},"text":"Pub. L. 97–293, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1267"},"text":"96 Stat. 1267","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
