{"tag":"section","attrib":{"id":"idc9faf055-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s617p"},"text":null,"children":[{"tag":"num","attrib":{"value":"617p"},"text":"§ 617p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims of United States; priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided in title 11, claims of the United States arising out of any contract authorized by this subchapter shall have priority over all others, secured or unsecured.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9faf056-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-12-21/ch42/s17"},"text":"Dec. 21, 1928, ch. 42, § 17","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1065"},"text":"45 Stat. 1065","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tIII/s332"},"text":"Pub. L. 95–598, title III, § 332","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2679"},"text":"92 Stat. 2679","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9faf057-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9faf058-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9faf059-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598