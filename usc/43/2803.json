{"tag":"section","attrib":{"id":"idca93ae57-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803"},"text":null,"children":[{"tag":"num","attrib":{"value":"2803"},"text":"§ 2803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Geospatial Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca93ae58-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall establish within the Department of the Interior the National Geospatial Advisory Committee to provide advice and recommendations to the Chairperson of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca93ae59-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca93ae5a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall be composed of not more than 30 members, at least one of which will be from the National Geospatial-Intelligence Agency, who shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f84b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed by the Chairperson of the Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f84c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be selected—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca95f84d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to generally achieve a balanced representation of the viewpoints of various interested parties involved in national geospatial activities and the development of the National Spatial Data Infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f84e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with consideration of a geographic balance of residence of the members; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f84f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be selected from among groups involved in the geospatial community, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca95f850-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f851-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f852-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regional governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f853-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f854-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/1/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private sector entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f855-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/1/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geospatial information user industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f856-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/1/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f857-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/1/C/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scholarly associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f858-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/1/C/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f859-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/1/C/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f85a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/1/C/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" licensed geospatial data acquisition professionals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f85b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/1/C/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f85c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairperson of the Committee shall appoint the Chairperson of the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f85d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of appointment; vacancies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f85e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members shall be appointed for a term of 3 years, with the term of ⅓ of the members expiring each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f85f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy in the Advisory Committee shall not affect its powers, but shall be filled in the same manner as the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f860-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except for the member from the National Geospatial-Intelligence Agency, an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f861-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be appointed to more than 2 consecutive terms as a member of the Advisory Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f862-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after serving for 2 consecutive terms, is eligible to be appointed as a member of the Advisory Committee on and after the date that is 2 years after the end of the second consecutive term of the individual as a member of the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f863-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ethical requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Advisory Committee may not participate in any specific-party matter (including a lease, license, permit, contract, claim, agreement, or related litigation) with the Department of the Interior in which the member has a direct financial interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f864-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incumbents","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f865-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual serving on the day before ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":", as a member of the National Geospatial Advisory Committee established by the Secretary of the Interior may serve as a member of the Advisory Committee until the end of the term of the individual under the appointment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f866-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any period of service as a member of the National Geospatial Advisory Committee established by the Secretary of the Interior shall be considered a period of service as a member of the Advisory Committee for purposes of paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f867-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subcommittees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A subcommittee of the Advisory Committee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95f868-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be formed for the purposes of compiling information or conducting research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f869-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be composed of members appointed by the Chairperson of the Advisory Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f86a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall act under the direction of the Chairperson of the Advisory Committee and the officer or employee designated under section 10(e) of the Federal Advisory Committee Act (5 U.S.C. App.) ","children":[{"tag":"ref","attrib":{"idref":"fn002186"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002186"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" with respect to the Advisory Committee;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f86b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall report the recommendations of the subcommittee to the Advisory Committee for consideration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f86c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall meet as necessary to accomplish the objectives of the subcommittee, subject to the approval of the Chairperson of the Advisory Committee and the availability of resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f86d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95f86e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall meet at the call of the Chairperson, not less than 1 time each year and not more than 4 times each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f86f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members of the Advisory Committee shall constitute a quorum, but a lesser number of members may hold meetings or hearings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f870-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Advisory Committee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95f871-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide advice and recommendations relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f872-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management of Federal and national geospatial programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f873-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of the National Spatial Data Infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f874-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation of this chapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f875-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and comment on geospatial policy and management issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f876-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the views of representatives of non-Federal interested parties involved in national geospatial activities are conveyed to the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f877-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of the Advisory Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95f878-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee may hold meetings (which shall be open to the public) and sit and act at such times and places as the Advisory Committee considers advisable to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f879-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information from covered agencies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f87a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee, with the concurrence of the Chairperson of the Committee, may secure directly from any covered agency such information as the Advisory Committee considers necessary to carry out this chapter. Upon request of the Chairperson of the Advisory Committee, the head of such agency shall furnish such information to the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f87b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall include in the comments of the Advisory Committee submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2802/c/11"},"text":"section 2802(c)(11) of this title","children":[],"tail":" a discussion of any failure by a covered agency to furnish information in response to a request under subparagraph (A) of this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f87c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postal services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee may use the United States mails in the same manner and under the same conditions as other agencies of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f87d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee personnel matters","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95f87e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No compensation of members","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f87f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Advisory Committee who is not an officer or employee of the Federal Government shall serve without compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f880-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Advisory Committee who is an officer or employee of the Federal Government shall serve without compensation in addition to the compensation received for the services of the member as an officer or employee of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f881-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Advisory Committee shall be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5 while away from their homes or regular places of business in the performance of services for the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f882-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of Government employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Federal Government employee may be detailed to the Committee to support the Advisory Committee without reimbursement, and such detail shall be without interruption or loss of civil service status or privilege.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f883-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of the Secretariat established by the Committee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2802/d"},"text":"section 2802(d) of this title","children":[],"tail":" shall provide administrative support to the Advisory Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f884-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of FACA","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95f885-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the Federal Advisory Committee Act (5 U.S.C. App.) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall apply to the Advisory Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f886-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 14(a)(2) of the Federal Advisory Committee Act (5 U.S.C. App.) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall not apply to the Advisory Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95f887-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95f888-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the Advisory Committee shall terminate 10 years after ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f889-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2803/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee may be continued for successive 10-year periods by action taken by the Secretary of the Interior to renew the Advisory Committee before the date on which the Advisory Committee would otherwise terminate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca95f88a-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tVII/s754"},"text":"Pub. L. 115–254, div. B, title VII, § 754","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3418"},"text":"132 Stat. 3418","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca95f88b-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca95f88c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca95f88d-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Advisory Committee Act, referred to in subsecs. (c)(3) and (h), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/463"},"text":"Pub. L. 92–463","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-06"},"text":"Oct. 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/770"},"text":"86 Stat. 770","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was substantially repealed and restated in chapter 10 (§ 1001 et seq.) of Title 5 by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(a), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4197"},"text":"136 Stat. 4197","children":[],"tail":", 4361. Sections 10 and 14 of the Act were repealed and restated as sections 1009 and 1013, respectively, of Title 5. For disposition of sections of the Act into chapter 10 of Title 5, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
