{"tag":"section","attrib":{"id":"idca40370c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1553"},"text":null,"children":[{"tag":"num","attrib":{"value":"1553"},"text":"§ 1553.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Upper Colorado River Basin; rights to consumptive uses not to be reduced or prejudiced; duties and powers of Commission not impaired","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca40370d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1553/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rights of the upper basin to the consumptive use of water available to that basin from the Colorado River system under the Colorado River Compact shall not be reduced or prejudiced by any use of such water in the lower basin.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca40370e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1553/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this chapter shall be construed so as to impair, conflict with, or otherwise change the duties and powers of the Upper Colorado River Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca40370f-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/537/tVI/s603"},"text":"Pub. L. 90–537, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-09-30"},"text":"Sept. 30, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/901"},"text":"82 Stat. 901","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
