{"tag":"section","attrib":{"id":"idca9868e8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007"},"text":null,"children":[{"tag":"num","attrib":{"value":"3007"},"text":"§ 3007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewable energy fees on Federal land","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca9868e9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9868ea-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual Adjustment Factor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Annual Adjustment Factor” means 3 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9868eb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encumbrance Factor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Encumbrance Factor” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9868ec-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent for a solar energy generation facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9868ed-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount determined by the Secretary, but not less than 10 percent for a wind energy generation facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9868ee-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Forest System","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9868ef-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Forest System” means land of the National Forest System (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1609/a"},"text":"section 1609(a) of title 16","children":[],"tail":") administered by the Secretary of Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9868f0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Forest System” does not include any forest reserve not created from the public domain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9868f1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Per-Acre Rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Per-Acre Rate”, with respect to a right-of-way, means the average of the per-acre pastureland rental rates published in the Cash Rents Survey by the National Agricultural Statistics Service for the State in which the right-of-way is located over the 5 calendar-year period preceding the issuance or renewal of the right-of-way.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9868f2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “project” means a system described in section 2801.9(a)(4) of title 43, Code of Federal Regulations (as in effect on ","children":[{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9868f3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “public land” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9868f4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public lands (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1702"},"text":"section 1702 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9868f5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Forest System land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9868f6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewable energy project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “renewable energy project” means a project located on public land that uses wind or solar energy to generate energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9868f7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right-of-way","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “right-of-way” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1702"},"text":"section 1702 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9868f8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretary” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9868f9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior, with respect to land controlled or administered by the Secretary of the Interior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9868fa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, with respect to National Forest System land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9868fb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acreage rent for wind and solar rights-of-way","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9868fc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1764/g"},"text":"section 1764(g) of this title","children":[],"tail":", the Secretary shall, subject to paragraph (3) and not later than January 1 of each calendar year, collect from the holder of a right-of-way for a renewable energy project an acreage rent in an amount determined by the equation described in paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9868fd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of acreage rent rate","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca9868fe-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of an acreage rent collected under paragraph (1) shall be determined using the following equation: Acreage rent = A × B × ((1 + C)","children":[{"tag":"sup","attrib":{},"text":"D","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca9868ff-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of the equation described in subparagraph (A):","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca986900-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The letter “A” means the Per-Acre Rate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca986901-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The letter “B” means the Encumbrance Factor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca986902-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The letter “C” means the Annual Adjustment Factor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca986903-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The letter “D” means the year in the term of the right-of-way.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca986904-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment until production","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The holder of a right-of-way for a renewable energy project shall pay an acreage rent collected under paragraph (1) until the date on which energy generation begins.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca986905-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capacity fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca986906-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, subject to paragraph (3), annually collect a capacity fee from the holder of a right-of-way for a renewable energy project based on the amount described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca986907-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of capacity fee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a capacity fee collected under paragraph (1) shall be equal to the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca986908-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the acreage rent described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca986909-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3.9 percent of the gross proceeds from the sale of electricity produced by the renewable energy project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca98690a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple-use reduction factor","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca98690b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The holder of a right-of-way for a wind energy generation project may request that the Secretary apply a multiple-use reduction factor of 10-percent to the amount of a capacity fee determined under paragraph (2) by submitting to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca98690c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may approve an application submitted under subparagraph (A) only if not less than 25 percent of the land within the area of the right-of-way is authorized for use, occupancy, or development with respect to an activity other than the generation of wind energy for the entirety of the year in which the capacity fee is collected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca98690d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Late determination","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca98690e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary approves an application under subparagraph (B) for a wind energy generation project after the date on which the holder of the right-of-way for the project begins paying a capacity fee, the Secretary shall apply the multiple-use reduction factor described in subparagraph (A) to the capacity fee for the first year beginning after the date of approval and each year thereafter for the period during which the right-of-way remains in effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca98690f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not refund the holder of a right-of-way for the difference in the amount of a capacity fee paid in a previous year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca986910-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Late payment fee; termination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca986911-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may charge the holder of a right-of-way for a renewable energy project a late payment fee if the Secretary does not receive payment for the acreage rent under subsection (b) or the capacity fee under subsection (c) by the date that is 15 days after the date on which the payment was due.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca986912-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3007/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of right-of-way","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may terminate a right-of-way for a renewable energy project if the Secretary does not receive payment for the acreage rent under subsection (b) or the capacity fee under subsection (c) by the date that is 90 days after the date on which the payment was due.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca986913-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tV/s50302"},"text":"Pub. L. 119–21, title V, § 50302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/148"},"text":"139 Stat. 148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca986914-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca986915-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca986916-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":", and not as part of subtitle B of title III of div. Z of "},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" which comprises this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
