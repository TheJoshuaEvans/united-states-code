{"tag":"section","attrib":{"id":"idca796f4d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1761a"},"text":"§ 1761a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Streamlining the Forest Service process for consideration of communications facility location applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca796f4e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca796f4f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communications facility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “communications facility” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca796f50-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any infrastructure, including any transmitting device, tower, or support structure, and any equipment, switches, wiring, cabling, power sources, shelters, or cabinets, associated with the licensed or permitted unlicensed wireless or wireline transmission of writings, signs, signals, data, images, pictures, and sounds of all kinds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca796f51-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any antenna or apparatus that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca796f52-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designed for the purpose of emitting radio frequency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca796f53-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designed to be operated, or is operating, from a fixed location pursuant to authorization by the Federal Communications Commission or is using duly authorized devices that do not require individual licenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca796f54-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is added to a tower, building, or other structure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca796f55-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communications site","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “communications site” means an area of covered land designated for communications uses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca796f56-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communications use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “communications use” means the placement and operation of a communications facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca796f57-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communications use authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “communications use authorization” means an easement, right-of-way, lease, license, or other authorization to locate or modify a communications facility on covered land by the Forest Service for the primary purpose of authorizing the occupancy and use of the covered land for communications use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca796f58-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered land” means National Forest System land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca796f59-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Forest Service” means the United States Forest Service of the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca796f5a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organizational unit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “organizational unit” means, within the Forest Service—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca796f5b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regional office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca796f5c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the headquarters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca796f5d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a management unit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca796f5e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/a/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a ranger district office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca796f5f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1455"},"text":"section 1455 of title 47","children":[],"tail":" or section 606 of the Repack Airwaves Yielding Better Access for Users of Modern Services Act of 2018 ("},{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Public Law 115–141","children":[],"tail":"), not later than 1 year after "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the Secretary shall issue regulations—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca796f60-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to streamline the process for considering applications to locate or modify communications facilities on covered land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca796f61-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure, to the maximum extent practicable, that the process is uniform and standardized across the organizational units of the Forest Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca796f62-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require that the applications described in paragraph (1) be considered and granted on a competitively neutral, technology neutral, and non-discriminatory basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca796f63-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations issued under subsection (b) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca796f64-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Procedures for the tracking of applications described in subsection (b)(1), including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca796f65-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identifying the number of applications—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca796f66-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca796f67-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca796f68-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" denied;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca796f69-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an application that is denied, describing the reasons for the denial; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca796f6a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the amount of time between the receipt of an application and the issuance of a final decision on an application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca796f6b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provision for minimum lease terms of not less than 15 years for leases with respect to the location of communications facilities on covered land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca796f6c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A structure of fees for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca796f6d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitting an application described in subsection (b)(1), based on the cost to the Forest Service of considering such an application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca796f6e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuing communications use authorizations, based on the cost to the Forest Service of any maintenance or other activities required to be performed by the Forest Service as a result of the location or modification of the communications facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca796f6f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provision for prioritization or streamlining of the consideration of applications to locate or modify communications facilities on covered land in a previously disturbed right-of-way.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca796f70-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In issuing regulations under subsection (b), the Secretary shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca796f71-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how discrete reviews in considering an application described in subsection (b)(1) can be conducted simultaneously, rather than sequentially, by any organizational units of the Forest Service that must approve the location or modification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca796f72-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how to eliminate overlapping requirements among the organizational units of the Forest Service with respect to the location or modification of a communications facility on covered land administered by those organizational units.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca796f73-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communication of streamlined process to organizational units","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, with respect to the regulations issued under subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca796f74-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communicate the regulations to the organizational units of the Forest Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca796f75-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the organizational units of the Forest Service follow the regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca796f76-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit and availability of fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca796f77-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall establish a special account in the Treasury for the Forest Service for the deposit of fees collected by the Forest Service under subsection (c)(3) for communications use authorizations on covered land granted, issued, or executed by the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca796f78-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for fees collected","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Fees collected by the Forest Service under subsection (c)(3) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca796f79-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collected only to the extent provided in advance in appropriations Acts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca796f7a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on the costs described in subsection (c)(3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca796f7b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" competitively neutral, technology neutral, and nondiscriminatory with respect to other users of the communications site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca796f7c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees collected by the Forest Service under subsection (c)(3) shall be deposited in the special account established for the Forest Service under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca796f7d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of fees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts deposited in the special account for the Forest Service shall be available, to the extent and in such amounts as are provided in advance in appropriation Acts, to the Secretary to cover costs incurred by the Forest Service described in subsection (c)(3), including the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca796f7e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Preparing needs assessments or other programmatic analyses necessary to designate communications sites and issue communications use authorizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca796f7f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing management plans for communications sites.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca796f80-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training for management of communications sites.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca796f81-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/f/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Obtaining or improving access to communications sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca796f82-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No additional appropriations authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (4), no other amounts are authorized to be appropriated to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca796f83-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreement authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations made in advance for such purposes, the Secretary may enter into cooperative agreements to carry out the activities described in subparagraphs (A) through (D) of paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca796f84-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca796f85-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real property authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section, or the amendments made by this section, shall be construed as providing any executive agency with any new leasing or other real property authorities not existing prior to ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca796f86-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1761a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section, or the amendments made by this section, and no actions taken pursuant to this section, or the amendments made by this section, shall impact a decision or determination by any executive agency to sell, dispose of, declare excess or surplus, lease, reuse, or redevelop any Federal real property pursuant to title 40, the Federal Assets Sale and Transfer Act of 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s1303"},"text":"40 U.S.C. 1303","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/114/287"},"text":"Public Law 114–287","children":[],"tail":"), or any other law governing real property activities of the Federal Government. No agreement entered into pursuant to this section, or the amendments made by this section, may obligate the Federal Government to hold, control, or otherwise retain or use real property that may otherwise be deemed as excess, surplus, or that could otherwise be sold, leased, or redeveloped."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca796f87-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII/s8705"},"text":"Pub. L. 115–334, title VIII, § 8705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4878"},"text":"132 Stat. 4878","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dD/tIV/s416"},"text":"Pub. L. 116–94, div. D, title IV, § 416","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2746"},"text":"133 Stat. 2746","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s143/b"},"text":"Pub. L. 118–234, title I, § 143(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2866"},"text":"138 Stat. 2866","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca796f88-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca796f89-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca796f8a-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 606 of the Repack Airwaves Yielding Better Access for Users of Modern Services Act of 2018, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/s606"},"text":"section 606 of div. P of Pub. L. 115–141","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1455"},"text":"section 1455 of Title 47","children":[],"tail":", Telecommunications, and enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1455"},"text":"section 1455 of Title 47","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca796f8b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agriculture Improvement Act of 2018, and not as part of the Federal Land Policy and Management Act of 1976 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca796f8c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (f)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234"},"text":"Pub. L. 118–234","children":[],"tail":" added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “Fees collected by the Forest Service under subsection (c)(3) shall be—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) based on the costs described in subsection (c)(3); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) competitively neutral, technology neutral, and nondiscriminatory with respect to other users of the communications site.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca796f8d-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idca796f8e-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” means the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2"},"text":"section 2 of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
