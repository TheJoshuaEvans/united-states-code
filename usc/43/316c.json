{"tag":"section","attrib":{"id":"idc9bf6e55-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316c"},"text":null,"children":[{"tag":"num","attrib":{"value":"316c"},"text":"§ 316c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alteration of grazing districts","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"After any district is established the area embraced therein may be altered in any of the following ways:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9bf6e56-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may add to such districts any public lands which, in his opinion, should be made a part of the district.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9bf6e57-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, subject to existing rights of any lessee, may exclude from such district any lands which he determines are no longer valuable for grazing purposes or are more valuable for other purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9bf6e58-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s316c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may enter into cooperative agreement with any person, in respect of the administration, as a part of a district, of lands owned by such person which are contiguous or adjacent to such district or any part thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9bf6e59-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch513/s4"},"text":"Mar. 4, 1927, ch. 513, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1452"},"text":"44 Stat. 1452","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9bf6e5a-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9bf6e5b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9bf6e5c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s471c"},"text":"section 471c of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
