{"tag":"section","attrib":{"id":"idc9e7dde8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s485h–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"485h–7"},"text":"§ 485h–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment of repayment contract for payment of annual installments in two parts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In any repayment contract which provides for payment of construction charges by single annual installments, the Secretary may by agreement with the contracting organization amend such contract to provide for the payment of such annual installments in two parts on such dates in the calendar year as may best enable the contracting organization to meet its payments.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9e7dde9-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/613/s3"},"text":"Pub. L. 87–613, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-08-28"},"text":"Aug. 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/408"},"text":"76 Stat. 408","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9e7ddea-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9e7ddeb-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9e7ddec-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Reclamation Project Act of 1939 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
