{"tag":"section","attrib":{"id":"idc9d28128-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–13"},"text":"§ 390h–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d28129-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out the purposes and provisions of sections 390h through 390h–12p of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d2812a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prerequisite cost-sharing agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9d2812b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–13/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Funds may not be appropriated for the construction of any project authorized by sections 390h to 390h–39 of this title until after—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9d2812c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–13/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appraisal investigation and a feasibility study that complies with the provisions of sections 390h–1(b) or 390h–2(c) of this title, as the case may be, have been completed by the Secretary or the non-Federal project sponsor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9d2812d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–13/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has determined that the non-Federal project sponsor is financially capable of funding the non-Federal share of the project’s costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9d2812e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–13/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has approved a cost-sharing agreement with the non-Federal project sponsor which commits the non-Federal project sponsor to funding its proportionate share of the project’s construction costs on an annual basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9d2812f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–13/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirements of paragraph (1) shall not apply to those projects authorized by sections 390h to 390h–39 of this title for which funds were appropriated prior to ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d28130-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–13/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall notify the Committees on Resources and Appropriations of the House of Representatives and the Committees on Energy and Natural Resources and Appropriations of the Senate within 30 days after the signing of a cost-sharing agreement pursuant to subsection (b) that such an agreement has been signed and that the Secretary has determined that the non-Federal project sponsor is financially capable of funding the project’s non-Federal share of the project’s costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d28131-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–13/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ceiling on Federal share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9d28132-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–13/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of sections 390h to 390h–39 of this title and except as provided by paragraph (2), the Federal share of the costs of each of the individual projects authorized by sections 390h to 390h–39 of this title shall not exceed $20,000,000 (October 1996 prices).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9d28133-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–13/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9d28134-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–13/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraph (B), in the case of any project authorized by sections 390h to 390h–39 of this title for which construction funds were appropriated before ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":", the Federal share of the cost of such project may not exceed the amount specified as the “total Federal obligation” for that project in the budget justification made by the Bureau of Reclamation for fiscal year 1997, as contained in part 3 of the report of the hearing held on "},{"tag":"date","attrib":{"date":"1996-03-27"},"text":"March 27, 1996","children":[],"tail":", before the Subcommittee on Energy and Water Development of the Committee on Appropriations of the House of Representatives."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9d28135-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–13/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of the San Gabriel Basin demonstration project authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390h–12"},"text":"section 390h–12 of this title","children":[],"tail":", the Federal share of the cost of such project may not exceed the sum determined by adding—"}],"tail":null},{"tag":"clause","attrib":{"id":"idc9d28136-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–13/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount that applies to that project under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9d28137-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–13/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $6,500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d28138-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s1631"},"text":"Pub. L. 102–575, title XVI, § 1631","children":[],"tail":", formerly § 1615, "},{"tag":"date","attrib":{"date":"1992-10-30"},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4668"},"text":"106 Stat. 4668","children":[],"tail":"; renumbered § 1631 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/266"},"text":"Pub. L. 104–266","children":[],"tail":", §§ 2(a)(1), (b)(1), 7, "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3290"},"text":"110 Stat. 3290","children":[],"tail":", 3294, 3296; "},{"tag":"ref","attrib":{"href":"/us/pl/108/418/s1"},"text":"Pub. L. 108–418, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2340"},"text":"118 Stat. 2340","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d28139-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d2813a-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9d2813b-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 390h through 390h–12p of this title, referred to in subsec. (a), was in the original “sections 1601 through 1630 of this title” meaning sections 1601 through 1630 of title XVI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575"},"text":"Pub. L. 102–575","children":[],"tail":", which are classified to sections 390h to 390h–12p of this title and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s390h"},"text":"section 390h of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9d2813c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/418"},"text":"Pub. L. 108–418","children":[],"tail":" designated existing provisions as subpar. (A), substituted “Subject to subparagraph (B), in the case” for “In the case”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/266"},"text":"Pub. L. 104–266","children":[],"tail":" designated existing provisions as subsec. (a), substituted “300h–12p” for “300h–12”, and added subsecs. (b) to (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9d2813d-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idc9d2813e-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
