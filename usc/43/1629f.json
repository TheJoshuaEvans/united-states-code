{"tag":"section","attrib":{"id":"idca5f308b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1629f"},"text":"§ 1629f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims arising from contamination of transferred lands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca5f308c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this section the term “contaminant” means ","children":[{"tag":"ref","attrib":{"idref":"fn002130"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002130"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “means a”."}],"tail":" hazardous substance harmful to public health or the environment, including friable asbestos."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca5f308d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Within 18 months of ","children":[{"tag":"date","attrib":{"date":"1995-11-02"},"text":"November 2, 1995","children":[],"tail":", and after consultation with the Secretary of Agriculture, State of Alaska, and appropriate Alaska Native Corporations and organizations, the Secretary shall submit to the Committee on Resources of the House of Representatives and the Committee on Energy and Natural Resources of the Senate, a report addressing issues presented by the presence of contaminants on lands conveyed or prioritized for conveyance to such corporations pursuant to this chapter. Such report shall consist of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca5f308e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing information concerning the nature and types of contaminants present on such lands prior to conveyance to Alaska Native Corporations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f308f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing information identifying to the extent practicable the existence and availability of potentially responsible parties for the removal or remediation of the effects of such contaminants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f3090-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of existing remedies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f3091-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629f/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for any additional legislation that the Secretary concludes is necessary to remedy the problem of contaminants on the lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca5f3092-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1629f/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in addition to the identification of contaminants, identification of structures known to have asbestos present and recommendations to inform Native landowners on the containment of asbestos.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca5f3093-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203/s40"},"text":"Pub. L. 92–203, § 40","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/42/tI/s103"},"text":"Pub. L. 104–42, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-02"},"text":"Nov. 2, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/354"},"text":"109 Stat. 354","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca5f3094-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca5f3095-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idca5f3096-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
