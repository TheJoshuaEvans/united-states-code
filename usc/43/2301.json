{"tag":"section","attrib":{"id":"idca8c8281-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301"},"text":null,"children":[{"tag":"num","attrib":{"value":"2301"},"text":"§ 2301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8c8282-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Land Management has authority under the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.) to sell land identified for disposal under its land use planning;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c8283-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Land Management has authority under that Act to exchange Federal land for non-Federal land if the exchange would be in the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c8284-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through land use planning under that Act, the Bureau of Land Management has identified certain tracts of public land for disposal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c8285-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal land management agencies of the Departments of the Interior and Agriculture have authority under existing law to acquire land consistent with the mission of each agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c8286-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sale or exchange of land identified for disposal and the acquisition of certain non-Federal land from willing landowners would—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8c8287-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow for the reconfiguration of land ownership patterns to better facilitate resource management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8c8288-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to administrative efficiency within Federal land management units; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8c8289-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow for increased effectiveness of the allocation of fiscal and human resources within the Federal land management agencies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c828a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a more expeditious process for disposal and acquisition of land, established to facilitate a more effective configuration of land ownership patterns, would benefit the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c828b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" many private individuals own land within the boundaries of Federal land management units and desire to sell the land to the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c828c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such land lies within national parks, national monuments, national wildlife refuges, national forests, and other areas designated for special management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c828d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal land management agencies are facing increased workloads from rapidly growing public demand for the use of public land, making it difficult for Federal managers to address problems created by the existence of inholdings in many areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c828e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in many cases, inholders and the Federal Government would mutually benefit from Federal acquisition of the land on a priority basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c828f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceeds generated from the disposal of public land may be properly dedicated to the acquisition of inholdings and other land that will improve the resource management ability of the Federal land management agencies and adjoining landowners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c8290-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" using proceeds generated from the disposal of public land to purchase inholdings and other such land from willing sellers would enhance the ability of the Federal land management agencies to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8c8291-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work cooperatively with private landowners and State and local governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8c8292-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote consolidation of the ownership of public and private land in a manner that would allow for better overall resource management;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c8293-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in certain locations, the sale of public land that has been identified for disposal is the best way for the public to receive fair market value for the land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c8294-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2301/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allow for the least disruption of existing land and resource management programs, the Bureau of Land Management may use non-Federal entities to prepare appraisal documents for agency review and approval consistent with applicable provisions of the Uniform Standards for Federal Land Acquisition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8c8295-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/248/tII/s202"},"text":"Pub. L. 106–248, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-25"},"text":"July 25, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/613"},"text":"114 Stat. 613","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca8c8296-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca8c8297-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca8c8298-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in pars. (1) to (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca8c8299-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idca8c829a-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dO/tIII/s301"},"text":"Pub. L. 115–141, div. O, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1074"},"text":"132 Stat. 1074","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/141/dO/tIII/s301"},"text":"“This title [amending sections 2302 and 2304 to 2306 of this title] may be cited as the ‘Federal Land Transaction Facilitation Act Reauthorization of 2018’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idca8c829b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/248/tII/s201"},"text":"Pub. L. 106–248, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-25"},"text":"July 25, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/613"},"text":"114 Stat. 613","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/248/tII/s201"},"text":"“This title [enacting this chapter] may be cited as the ‘Federal Land Transaction Facilitation Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
