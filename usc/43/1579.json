{"tag":"section","attrib":{"id":"idca428162-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1579"},"text":null,"children":[{"tag":"num","attrib":{"value":"1579"},"text":"§ 1579.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fish and wildlife habitat; mitigation of losses","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":", and to such extent and in such amounts as are provided in advance in appropriate "},{"tag":"ref","attrib":{"idref":"fn002099"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002099"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “appropriation”."}],"tail":" Acts, in order to provide measures determined by the Secretary of the Interior to be appropriated to mitigate loss of fish and wildlife habitat associated with other measures taken under this subchapter:"}],"tail":null},{"tag":"subsection","attrib":{"id":"idca428163-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1579/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation of funds; acquisition and disposal of lands; facilities undertakings; funds restriction for non-Federal facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca428164-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1579/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire lands by purchase, eminent domain, or exchange;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca428165-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1579/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dispose of land, facilities, and equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca428166-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1579/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construct, operate, maintain, and make replacements of facilities: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That no funds will be provided for operation, maintenance, or replacement of non-Federal facilities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca428167-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1579/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonreimbursable costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All costs authorized by this section are nonreimbursable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca428168-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/320/tI/s110"},"text":"Pub. L. 93–320, title I, § 110","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/336/s6"},"text":"Pub. L. 96–336, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-04"},"text":"Sept. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1064"},"text":"94 Stat. 1064","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
