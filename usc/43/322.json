{"tag":"section","attrib":{"id":"idc9bf6eca-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s322"},"text":null,"children":[{"tag":"num","attrib":{"value":"322"},"text":"§ 322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Desert lands defined; question how determined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All lands exclusive of timber lands and mineral lands which will not, without irrigation, produce some agricultural crop, shall be deemed desert lands, within the meaning of sections 321 to 323, 325, and 327 to 329 of this title, which fact shall be ascertained by proof of two or more credible witnesses under oath, whose affidavits shall be filed in the land office in which said tract of land may be situated.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The determination of what may be considered desert land shall be subject to the decision and regulation of the Secretary of the Interior or such officer as he may designate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9bf6ecb-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1877-03-03/ch107"},"text":"Mar. 3, 1877, ch. 107","children":[],"tail":", §§ 2, 3, "},{"tag":"ref","attrib":{"href":"/us/stat/19/377"},"text":"19 Stat. 377","children":[],"tail":"; 1946 Reorg. Plan No. 3, § 403, eff. "},{"tag":"date","attrib":{"date":"1946-07-16"},"text":"July 16, 1946","children":[],"tail":", 11 F.R. 7876, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1100"},"text":"60 Stat. 1100","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9bf6ecc-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9bf6ecd-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9bf6ece-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The first paragraph of this section is from section 2 of act ","children":[{"tag":"date","attrib":{"date":"1877-03-03"},"text":"Mar. 3, 1877","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The second paragraph of this section is from the last clause of section 3 of act ","children":[{"tag":"date","attrib":{"date":"1877-03-03"},"text":"Mar. 3, 1877","children":[],"tail":". The first clause of section 3 is incorporated in "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s323"},"text":"section 323 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9bf6ecf-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9bf6ed0-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Section as Unaffected by Submerged Lands Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of this section as not amended, modified or repealed by the Submerged Lands Act, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1303"},"text":"section 1303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idc9c1b7c1-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idc9c1b7c2-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of the Interior or such officer as he may designate” substituted for “Commissioner of the General Land Office” on authority of section 403 of Reorg. Plan No. 3 of 1946, which abolished General Land Office and Commissioner thereof and transferred functions of General Land Office to a new agency in Department of the Interior to be known as Bureau of Land Management. See section 403 of Reorg. Plan No. 3 of 1946, set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
