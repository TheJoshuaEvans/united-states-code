{"tag":"section","attrib":{"id":"idc9c8e3e5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s375e"},"text":null,"children":[{"tag":"num","attrib":{"value":"375e"},"text":"§ 375e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Moneys from sale of small tracts covered into reclamation fund; credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The moneys derived from the sale of such lands shall be covered into the reclamation fund and be placed to the credit of the project on which such lands are located.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9c8e3e6-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-31/ch78/s4"},"text":"Mar. 31, 1950, ch. 78, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/40"},"text":"64 Stat. 40","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
