{"tag":"section","attrib":{"id":"idca8c825d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2225"},"text":null,"children":[{"tag":"num","attrib":{"value":"2225"},"text":"§ 2225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reclamation Drought Response Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall undertake a study of the need, if any, to establish a Reclamation Drought Response Fund to be available for defraying those expenses which the Secretary determines necessary to implement plans prepared under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2222"},"text":"section 2222 of this title","children":[],"tail":" and to make loans for nonstructural and minor structural activities for the prevention or mitigation of the adverse effects of drought."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca8c825e-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/250/tII/s205"},"text":"Pub. L. 102–250, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-05"},"text":"Mar. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/58"},"text":"106 Stat. 58","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
