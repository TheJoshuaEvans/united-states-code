{"tag":"section","attrib":{"id":"idc9ac5ad9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k"},"text":null,"children":[{"tag":"num","attrib":{"value":"31k"},"text":"§ 31k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Volcano Early Warning and Monitoring System","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9ac5ada-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9ac5adb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary, acting through the Director of the United States Geological Survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ac5adc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of Commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary of Commerce” means the Secretary of Commerce, acting through the Under Secretary of Commerce for Oceans and Atmosphere.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ac5add-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “System” means the National Volcano Early Warning and Monitoring System established under subsection (b)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ac5ade-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volcanic Ash Advisory Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Volcanic Ash Advisory Center” means an entity designated by the International Civil Aviation Organization that is responsible for informing aviation interests about the presence of volcanic ash in the airspace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9ac5adf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Volcano Early Warning and Monitoring System","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9ac5ae0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9ac5ae1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish within the United States Geological Survey a system, to be known as the “National Volcano Early Warning and Monitoring System”, to monitor, warn, and protect citizens of the United States from undue and avoidable harm from volcanic activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ac5ae2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the System are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9ac5ae3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to organize, modernize, standardize, and stabilize the monitoring systems of the volcano observatories in the United States, which includes the Alaska Volcano Observatory, California Volcano Observatory, Cascades Volcano Observatory, Hawaiian Volcano Observatory, and Yellowstone Volcano Observatory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ac5ae4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to unify the monitoring systems of volcano observatories in the United States into a single interoperative system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ac5ae5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to strengthen the warning and monitoring systems of volcano observatories in the United States by integrating relevant capacities of the National Oceanic and Atmospheric Administration, including with the Volcanic Ash Advisory Centers located in Anchorage, Alaska, and Washington, D.C., to observe and model emissions of gases, aerosols, and ash, atmospheric dynamics and chemistry, and ocean chemistry resulting from volcanic eruptions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ac5ae6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objective","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The objective of the System is to monitor all the volcanoes in the United States at a level commensurate with the threat posed by the volcanoes by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9ac5ae7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upgrading existing networks on monitored volcanoes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ac5ae8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" installing new networks on unmonitored volcanoes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ac5ae9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employing geodetic and other components when applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ac5aea-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System components","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9ac5aeb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The System shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9ac5aec-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national volcano watch office that is operational 24 hours a day and 7 days a week;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ac5aed-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national volcano data center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ac5aee-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an external grants program to support research in volcano monitoring science and technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ac5aef-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modernization activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Modernization activities under the System shall include the comprehensive application of emerging technologies, including digital broadband seismometers, real-time continuous Global Positioning System receivers, satellite and airborne radar interferometry, acoustic pressure sensors, spectrometry to measure gas emissions, and unoccupied aerial vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ac5af0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memorandum of understanding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Secretary of Commerce shall develop and execute a memorandum of understanding to establish cooperative support for the activities of the System from the National Oceanic and Atmospheric Administration, including environmental observations, modeling, and temporary duty assignments of personnel to support emergency activities, as necessary or appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ac5af1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9ac5af2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9ac5af3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall submit to Congress a 5-year management plan for establishing and operating the System."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ac5af4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The management plan submitted under clause (i) shall include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc9ac5af5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual cost estimates for modernization activities and operation of the System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9ac5af6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual milestones, standards, and performance goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9ac5af7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/3/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for, and progress towards, establishing new, or enhancing existing, partnerships to leverage resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ac5af8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Update","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc9ac5af9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/3/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Oceanic and Atmospheric Administration cost estimates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall submit to the Secretary annual cost estimates for modernization activities and support of the System for the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc9ac5afa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/3/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Update of management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall update the management plan submitted under clause (i) to include the cost estimates submitted under subclause (I).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ac5afb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an advisory committee to assist the Secretary in implementing the System, to be comprised of representatives of relevant agencies and members of the scientific community, to be appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ac5afc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into cooperative agreements with institutions of higher education and State agencies designating the institutions of higher education and State agencies as volcano observatory partners for the System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ac5afd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall coordinate the activities under this section with the heads of relevant Federal agencies, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9ac5afe-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ac5aff-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Federal Aviation Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ac5b00-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the National Oceanic and Atmospheric Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ac5b01-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/3/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ac5b02-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall collaborate with the Secretary to implement activities carried out under this section related to the expertise of the National Oceanic and Atmospheric Administration, including observations and modeling of emissions of gases, aerosols, and ash, atmospheric dynamics and chemistry, and ocean chemistry resulting from volcanic eruptions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ac5b03-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Annually, the Secretary shall submit to Congress a report that describes the activities carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9ac5b04-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9ac5b05-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations, United States Geological Survey","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the United States Geological Survey to carry out this section $55,000,000 for the period of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ac5b06-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations, National Oceanic and Atmospheric Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the National Oceanic and Atmospheric Administration to carry out this section such sums as may be necessary for the period of fiscal years 2023 through 2024.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ac5b07-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s31k/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other sources of Federal funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available under this subsection shall supplement, and not supplant, Federal funds made available for other hazards activities and programs of the United States Geological Survey and the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9ac5b08-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tV/s5001"},"text":"Pub. L. 116–9, title V, § 5001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/766"},"text":"133 Stat. 766","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCV/s10501/a"},"text":"Pub. L. 117–263, div. J, title CV, § 10501(a)","children":[],"tail":"–(e), "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3993"},"text":"136 Stat. 3993","children":[],"tail":", 3994.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9ac5b09-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9ac5b0a-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9ac5b0b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10501/a"},"text":"Pub. L. 117–263, § 10501(a)","children":[],"tail":", added pars. (2) and (4) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10501/b"},"text":"Pub. L. 117–263, § 10501(b)","children":[],"tail":", added cl. (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10501/c/1"},"text":"Pub. L. 117–263, § 10501(c)(1)","children":[],"tail":", struck out “and” before “spectrometry” and inserted “, and unoccupied aerial vehicles” after “emissions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10501/c/2"},"text":"Pub. L. 117–263, § 10501(c)(2)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10501/d/1"},"text":"Pub. L. 117–263, § 10501(d)(1)","children":[],"tail":", added cl. (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10501/d/2"},"text":"Pub. L. 117–263, § 10501(d)(2)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10501/e/1"},"text":"Pub. L. 117–263, § 10501(e)(1)","children":[],"tail":", inserted “, United States Geological Survey” after “appropriations” in heading and “to the United States Geological Survey” after “appropriated” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10501/e/3"},"text":"Pub. L. 117–263, § 10501(e)(3)","children":[],"tail":", added par. (2). Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10501/e/2"},"text":"Pub. L. 117–263, § 10501(e)(2)","children":[],"tail":", (4), redesignated par. (2) as (3), struck out “United States Geological Survey” before “hazards activities”, and inserted “of the United States Geological Survey and the National Oceanic and Atmospheric Administration” after “programs”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9ac5b0c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idc9ac5b0d-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2"},"text":"section 2 of Pub. L. 116–9","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
