{"tag":"section","attrib":{"id":"idc9ecbf79-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"505a–1"},"text":"§ 505a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asset Management Report enhancements for reserved works","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9ecbf7a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall submit to Congress an Asset Management Report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9ecbf7b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describes the efforts of the Bureau—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9ecbf7c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain in a reliable manner all reserved works at Reclamation facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ecbf7d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to standardize and streamline data reporting and processes across regions and areas for the purpose of maintaining reserved works at Reclamation facilities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ecbf7e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expands on the information otherwise provided in an Asset Management Report, in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9ecbf7f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Infrastructure maintenance needs assessment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9ecbf80-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Asset Management Report submitted under subsection (a) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9ecbf81-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed assessment of major repair and rehabilitation needs for all reserved works at all Reclamation projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ecbf82-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, an itemized list of major repair and rehabilitation needs of individual Reclamation facilities at each Reclamation project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ecbf83-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, the itemized list of major repair and rehabilitation needs under paragraph (1)(B) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9ecbf84-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a budget level cost estimate of the appropriations needed to complete each item; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ecbf85-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assignment of a categorical rating for each item, consistent with paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ecbf86-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rating requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9ecbf87-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The system for assigning ratings under paragraph (2)(B) shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc9ecbf88-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with existing uniform categorization systems to inform the annual budget process and agency requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc9ecbf89-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the guidance and instructions issued under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9ecbf8a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall issue guidance that describes the applicability of the rating system applicable under paragraph (2)(B) to Reclamation facilities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ecbf8b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (5), the Secretary shall make publicly available, including on the internet, the Asset Management Report required under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ecbf8c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may exclude from the public version of the Asset Management Report made available under paragraph (4) any information that the Secretary identifies as sensitive or classified, but shall make available to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives a version of the report containing the sensitive or classified information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9ecbf8d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after the date on which the Asset Management Report is submitted under subsection (a) and biennially thereafter, the Secretary shall update the Asset Management Report, subject to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s505a–2/b/2"},"text":"section 505a–2(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9ecbf8e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent that such consultation would assist the Secretary in preparing the Asset Management Report under subsection (a) and updates to the Asset Management Report under subsection (c), the Secretary shall consult with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9ecbf8f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Army (acting through the Chief of Engineers); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9ecbf90-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s505a–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water and power contractors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9ecbf91-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tVIII/s8602"},"text":"Pub. L. 116–9, title VIII, § 8602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/827"},"text":"133 Stat. 827","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9ecbf92-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9ecbf93-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idc9ecbf94-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2"},"text":"section 2 of Pub. L. 116–9","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"section 1 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
