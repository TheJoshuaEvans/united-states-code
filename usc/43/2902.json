{"tag":"section","attrib":{"id":"idca95f91c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902"},"text":null,"children":[{"tag":"num","attrib":{"value":"2902"},"text":"§ 2902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95f91d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyed property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “conveyed property” means an eligible facility that has been conveyed to a qualifying entity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2903"},"text":"section 2903 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f91e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible facility” means a facility that meets the criteria for potential transfer established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2904/a"},"text":"section 2904(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f91f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f920-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “facility” includes a dam or appurtenant works, canal, lateral, ditch, gate, control structure, pumping station, other infrastructure, recreational facility, building, distribution and drainage works, and associated land or interest in land or water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f921-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “facility” does not include a Reclamation project facility, or a portion of a Reclamation project facility—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca95f922-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is a reserved works as of ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f923-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that generates hydropower marketed by a Federal power marketing administration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f924-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is managed for recreation under a lease, permit, license, or other management agreement that does contribute to capital repayment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f925-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project use power","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “project use power” means the electrical capacity, energy, and associated ancillary service components required to provide the minimum electrical service needed to operate or maintain Reclamation project facilities in accordance with the authorization for the Reclamation project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f926-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualifying entity” means an agency of a State or political subdivision of a State, a joint action or powers agency, a water users association, or an Indian Tribe or Tribal utility authority that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f927-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of the date of conveyance under this chapter, is the current operator of the eligible facility pursuant to a contract with Reclamation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f928-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as determined by the Secretary, has the capacity to continue to manage the eligible facility for the same purposes for which the property has been managed under the reclamation laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f929-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reclamation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Reclamation” means the Bureau of Reclamation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f92a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reclamation project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Reclamation project” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f92b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any reclamation or irrigation project, including incidental features of the project—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca95f92c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is authorized by the reclamation laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f92d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is constructed by the United States pursuant to the reclamation laws; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f92e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with which there is a repayment or water service contract executed by the United States pursuant to the reclamation laws; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f92f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any project constructed by the Secretary for the reclamation of land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f930-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserved works","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “reserved works” means any building, structure, facility, or equipment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95f931-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is owned by the Bureau; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95f932-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for which operations and maintenance are performed, regardless of the source of funding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca95f933-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an employee of the Bureau; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca95f934-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through a contract entered into by the Commissioner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95f935-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s2902/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary, acting through the Commissioner of Reclamation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca95f936-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tVIII/s8002"},"text":"Pub. L. 116–9, title VIII, § 8002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/804"},"text":"133 Stat. 804","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca95f937-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca95f938-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idca95f939-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2"},"text":"section 2 of Pub. L. 116–9","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"section 1 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
