{"tag":"section","attrib":{"id":"idc9d4cb80-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390ss"},"text":null,"children":[{"tag":"num","attrib":{"value":"390ss"},"text":"§ 390ss.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Religious or charitable organizations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An individual religious or charitable entity or organization (including but not limited to a congregation, parish, school, ward, or chapter) which is exempt from taxation under section 501 of the Internal Revenue Code of 1986, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501"},"text":"26 U.S.C. 501","children":[],"tail":"), and which owns, operates, or leases any lands within a district shall be treated as an individual under the provisions of this subchapter regardless of such entity or organization’s affiliation with a central organization or its subjugation to a hierarchical authority of the same faith and regardless of whether or not the individual entity is the owner of record if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9d4cb81-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390ss/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agricultural produce and the proceeds of sales of such produce are directly used only for charitable purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9d4cb82-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390ss/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" said land is operated by said individual religious or charitable entity or organization (or subdivisions thereof); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9d4cb83-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390ss/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no part of the net earnings of such religious or charitable entity or organization (or subdivision thereof) shall inure to the benefit of any private shareholder or individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d4cb84-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/293/tII/s219"},"text":"Pub. L. 97–293, title II, § 219","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1271"},"text":"96 Stat. 1271","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d4cb85-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d4cb86-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9d4cb87-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
