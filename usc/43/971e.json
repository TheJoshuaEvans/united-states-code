{"tag":"section","attrib":{"id":"idca1a1197-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s971e"},"text":null,"children":[{"tag":"num","attrib":{"value":"971e"},"text":"§ 971e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of restored Alaskan lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of sections 971a to 971e of this title, the words “restored lands” include, without limiting the meaning thereof, those lands at Big Delta and Tok Junctions that are withdrawn by public land orders numbered 808 and 975 and that lie between the centerline of the Richardson and Glenn Highways and the land included within United States surveys 2727, 2728, 2770, 2771, 2772, 2773, 2774, 2723, 2724, 2725, and 2726.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca1a1198-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch848/s5"},"text":"Aug. 1, 1956, ch. 848, § 5","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/86/512"},"text":"Pub. L. 86–512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-11"},"text":"June 11, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/207"},"text":"74 Stat. 207","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca1a1199-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca1a119a-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca1a119b-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s420d"},"text":"section 420d of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
