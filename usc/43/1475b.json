{"tag":"section","attrib":{"id":"idca3b54c3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1475b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1475b"},"text":"§ 1475b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteer authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca3b54c4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1475b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior may recruit, train, and accept, without regard to the civil service classification laws, rules, or regulations, the services of individuals, contributed without compensation as volunteers, for aiding in or facilitating the activities administered by the Secretary through the Bureau of Indian Affairs, the United States Geological Survey, the Bureau of Reclamation, and the Office of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca3b54c5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1475b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on activities of volunteers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca3b54c6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1475b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accepting such services of individuals as volunteers, the Secretary shall not permit the use of volunteers in law enforcement work, in regulatory and enforcement work, in policymaking processes, or to displace any employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca3b54c7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1475b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No volunteer services authorized by this Act may be conducted on private property unless the officer or employee charged with supervising the volunteer obtains appropriate consent to enter the property from the property owner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca3b54c8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1475b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hazardous duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may accept the services of individuals in hazardous duty only upon a determination by the Secretary that such individuals are skilled in performing hazardous duty activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca3b54c9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1475b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that an appropriate officer or employee of the United States provides adequate and appropriate supervision of each volunteer whose services the Secretary accepts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca3b54ca-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1475b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of services and costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide for services and costs incidental to the utilization of volunteers, including transportation, supplies, uniforms, lodging, subsistence (without regard to place of residence), recruiting, training, supervision, and awards and recognition (including nominal cash awards).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca3b54cb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1475b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal employment status of volunteers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca3b54cc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1475b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this subsection, a volunteer shall not be deemed a Federal employee and shall not be subject to the provisions of law relating to Federal employment, including those provisions relating to hours of work, rates of compensation, leave, unemployment compensation, and Federal employee benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca3b54cd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1475b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Volunteers shall be deemed employees of the United States for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca3b54ce-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1475b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tort claims provisions of title 28;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca3b54cf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1475b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter I of chapter 81 of title 5; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca3b54d0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1475b/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" claims relating to damage to, or loss of, personal property of a volunteer incident to volunteer service, in which case the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3721"},"text":"section 3721 of title 31","children":[],"tail":" shall apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca3b54d1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1475b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Volunteers under this Act shall be subject to chapter 11 of title 18, unless the Secretary, with the concurrence of the Director of the Office of Government Ethics, determines in writing published in the Federal Register that the provisions of that chapter, except section 201, shall not apply to the actions of a class or classes of volunteers who carry out only those duties or functions specified in the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca3b54d2-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/125/s3"},"text":"Pub. L. 109–125, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-07"},"text":"Dec. 7, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2544"},"text":"119 Stat. 2544","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca3b54d3-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca3b54d4-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca3b54d5-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (b)(2) and (d)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/125"},"text":"Pub. L. 109–125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-07"},"text":"Dec. 7, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2544"},"text":"119 Stat. 2544","children":[],"tail":", known as the Department of the Interior Volunteer Recruitment Act of 2005, which enacted this section and provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1451"},"text":"section 1451 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2005 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1451"},"text":"section 1451 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca3b54d6-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca3b54d7-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/125/s2"},"text":"Pub. L. 109–125, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-07"},"text":"Dec. 7, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2544"},"text":"119 Stat. 2544","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/125/s2"},"text":"“The purpose of this Act [enacting this section and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1451"},"text":"section 1451 of this title","children":[],"tail":"] is to authorize the Secretary of the Interior to recruit and use volunteers to assist with, or facilitate, the programs of the Bureau of Indian Affairs, the United States Geological Survey, the Bureau of Reclamation, and the Office of the Secretary.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
