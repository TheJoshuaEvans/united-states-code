{"tag":"section","attrib":{"id":"idc9d4cb5e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390nn"},"text":null,"children":[{"tag":"num","attrib":{"value":"390nn"},"text":"§ 390nn.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trusts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d4cb5f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390nn/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ownership and full cost pricing limitations of this subchapter and the ownership limitations provided in any other provision of Federal reclamation law shall not apply to lands in a district which are held by an individual or corporate trustee in a fiduciary capacity for a beneficiary or beneficiaries whose interests in the lands served do not exceed the ownership and pricing limitations imposed by Federal reclamation law, including this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d4cb60-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390nn/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Lands placed in a revocable trust shall be attributable to the grantor if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9d4cb61-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390nn/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trust is revocable at the discretion of the grantor and revocation results in the title to such lands reverting either directly or indirectly to the grantor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9d4cb62-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390nn/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trust is revoked or terminated by its terms upon the expiration of a specified period of time and the revocation or termination results in the title to such lands reverting either directly or indirectly to the grantor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d4cb63-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/293/tII/s214"},"text":"Pub. L. 97–293, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1270"},"text":"96 Stat. 1270","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5302/b"},"text":"Pub. L. 100–203, title V, § 5302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-269"},"text":"101 Stat. 1330–269","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9d4cb64-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9d4cb65-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9d4cb66-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Federal reclamation law, referred to in subsec. (a), is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390aa"},"text":"section 390aa of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9d4cb67-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
