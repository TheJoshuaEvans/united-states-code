{"tag":"section","attrib":{"id":"idc9cb5587-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"390b–2"},"text":"§ 390b–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leveraging Federal infrastructure for increased water supply","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9cb5588-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the request of a non-Federal interest, the Secretary may review proposals to increase the quantity of available supplies of water at a Federal water resources development project through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9cb5589-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modification of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cb558a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modification of how the project is managed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cb558b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accessing water released from the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9cb558c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A proposal under subsection (a) may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9cb558d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the storage capacity of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cb558e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" diversion of water released or withdrawn from the project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9cb558f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recharge groundwater;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9cb5590-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to aquifer storage and recovery; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9cb5591-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any other storage facility;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cb5592-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction of facilities for delivery of water from pumping stations constructed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cb5593-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction of facilities to access water; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cb5594-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a combination of the activities described in paragraphs (1) through (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9cb5595-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply to a proposal that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9cb5596-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reallocates existing water supply or hydropower storage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cb5597-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces water available for any authorized project purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9cb5598-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other Federal projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which a proposal relates to a Federal project that is not operated by the Secretary, this section shall apply only to activities under the authority of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9cb5599-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9cb559a-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On receipt of a proposal submitted under subsection (a), the Secretary shall provide a copy of the proposal to each entity described in paragraph (2) and, if applicable, the Federal agency that operates the project, in the case of a project operated by an agency other than the Department of the Army.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cb559b-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public participation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In reviewing proposals submitted under subsection (a), and prior to making any decisions regarding a proposal, the Secretary shall comply with all applicable public participation requirements under law, including consultation with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9cb559c-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affected States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9cb559d-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" power marketing administrations, in the case of reservoirs with Federal hydropower projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9cb559e-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities responsible for operation and maintenance costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9cb559f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any entity that has a contractual right from the Federal Government or a State to withdraw water from, or use storage at, the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9cb55a0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities that the State determines hold rights under State law to the use of water from the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9cb55a1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" units of local government with flood risk reduction responsibilities downstream of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9cb55a2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A proposal submitted to the Secretary under subsection (a) may be reviewed and approved, if applicable and appropriate, under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9cb55a3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific authorization for the water resources development project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cb55a4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s549a"},"text":"section 549a of title 33","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cb55a5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390b"},"text":"section 390b of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cb55a6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s408"},"text":"section 408 of title 33","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9cb55a7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not approve a proposal submitted under subsection (a) that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9cb55a8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not supported by the Federal agency that operates the project, if that agency is not the Department of the Army;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cb55a9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interferes with an authorized purpose of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cb55aa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adversely impacts contractual rights to water or storage at the reservoir;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cb55ab-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adversely impacts legal rights to water under State law, as determined by an affected State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cb55ac-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increases costs for any entity other than the entity that submitted the proposal; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cb55ad-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/g/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a project is subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390b/e"},"text":"section 390b(e) of this title","children":[],"tail":", makes modifications to the project that do not meet the requirements of that section unless the modification is submitted to and authorized by Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9cb55ae-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9cb55af-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), 100 percent of the cost of developing, reviewing, and implementing a proposal submitted under subsection (a) shall be provided by an entity other than the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cb55b0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning assistance to states","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a proposal from an entity authorized to receive assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962d–16"},"text":"section 1962d–16 of title 42","children":[],"tail":", the Secretary may use funds available under that section to pay 50 percent of the cost of a review of a proposal submitted under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cb55b1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation and maintenance costs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9cb55b2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraphs (B) and (C), the operation and maintenance costs for the non-Federal sponsor of a proposal submitted under subsection (a) shall be 100 percent of the separable operation and maintenance costs associated with the costs of implementing the proposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9cb55b3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain water supply storage projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For a proposal submitted under subsection (a) for constructing additional water supply storage at a reservoir for use under a water supply storage agreement, in addition to the costs under subparagraph (A), the non-Federal costs shall include the proportional share of any joint-use costs for operation, maintenance, repair, replacement, or rehabilitation of the reservoir project determined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390b"},"text":"section 390b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9cd9ea4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/h/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity other than an entity described in subparagraph (A) may voluntarily contribute to the costs of implementing a proposal submitted under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9cd9ea5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributed funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9cd9ea6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributed funds for corps projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may may receive and expend funds contributed by a non-Federal interest for the review and approval of a proposal submitted under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cd9ea7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributed funds for other Federal reservoir projects","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc9cd9ea8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to receive and expend funds from a non-Federal interest or a Federal agency that owns a Federal reservoir project described in subparagraph (B) to formulate, review, or revise operational documents pursuant to a proposal submitted in accordance with subsection (a) for such a Federal reservoir project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc9cd9ea9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal reservoir projects described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Federal reservoir project referred to in subparagraph (A) is a reservoir for which the Secretary is authorized to prescribe regulations for the use of storage allocated for flood control or navigation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s709"},"text":"section 709 of title 33","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9cd9eaa-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On request by a non-Federal interest, the Secretary may provide technical assistance in the development or implementation of a proposal under subsection (a), including assistance in obtaining necessary permits for construction, if the non-Federal interest contracts with the Secretary to pay all costs of providing the technical assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9cd9eab-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply to reservoirs in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc9cd9eac-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Upper Missouri River;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cd9ead-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Apalachicola-Chattahoochee-Flint river system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cd9eae-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/k/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Alabama-Coosa-Tallapoosa river system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc9cd9eaf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/k/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Stones River.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9cd9eb0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390b–2/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section affects or modifies any authority of the Secretary to review or modify reservoirs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9cd9eb1-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1118"},"text":"Pub. L. 114–322, title I, § 1118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1640"},"text":"130 Stat. 1640","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s162"},"text":"Pub. L. 116–260, div. AA, title I, § 162","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2667"},"text":"134 Stat. 2667","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1165"},"text":"Pub. L. 118–272, div. A, title I, § 1165","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3049"},"text":"138 Stat. 3049","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9cd9eb2-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9cd9eb3-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9cd9eb4-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (i)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272"},"text":"Pub. L. 118–272","children":[],"tail":" added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “The Secretary is authorized to receive and expend funds from a non-Federal interest to formulate, review, or revise operational documents, pursuant to a proposal submitted in accordance subsection (a), for any reservoir for which the Secretary is authorized to prescribe regulations for the use of storage allocated for flood control or navigation pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s709"},"text":"section 709 of title 33","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9cd9eb5-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9cd9eb6-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1002"},"text":"section 1002 of Pub. L. 114–322","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
