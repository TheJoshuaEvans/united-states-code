{"tag":"section","attrib":{"id":"idca7bb8b0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1767"},"text":null,"children":[{"tag":"num","attrib":{"value":"1767"},"text":"§ 1767.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights-of-way for Federal departments and agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca7bb8b1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1767/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may provide under applicable provisions of this subchapter for the use of any department or agency of the United States a right-of-way over, upon, under or through the land administered by him, subject to such terms and conditions as he may impose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7bb8b2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1767/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Where a right-of-way has been reserved for the use of any department or agency of the United States, the Secretary shall take no action to terminate, or otherwise limit, that use without the consent of the head of such department or agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca7bb8b3-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579/tV/s507"},"text":"Pub. L. 94–579, title V, § 507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2781"},"text":"90 Stat. 2781","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca7bb8b4-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idca7bb8b5-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idca7bb8b6-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"See note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1763"},"text":"section 1763 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
