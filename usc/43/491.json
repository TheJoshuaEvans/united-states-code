{"tag":"section","attrib":{"id":"idc9ea4efc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s491"},"text":null,"children":[{"tag":"num","attrib":{"value":"491"},"text":"§ 491.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary to operate works","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized and directed to use the reclamation fund for the operation and maintenance of all reservoirs and irrigation works constructed under the provisions of this Act.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9ea4efd-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-06-17/ch1093/s6"},"text":"June 17, 1902, ch. 1093, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/389"},"text":"32 Stat. 389","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9ea4efe-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9ea4eff-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9ea4f00-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is act ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":", popularly known as the Reclamation Act, which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9ea4f01-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of part of section 6 of act ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":". Remainder of such section 6 is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s498"},"text":"section 498 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9ea4f02-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9ea4f03-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Section as Unaffected by Submerged Lands Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of this section as not amended, modified or repealed by the Submerged Lands Act, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1303"},"text":"section 1303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
