{"tag":"section","attrib":{"id":"idca49acac-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602"},"text":null,"children":[{"tag":"num","attrib":{"value":"1602"},"text":"§ 1602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter, the term—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca49acad-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca49acae-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Native” means a citizen of the United States who is a person of one-fourth degree or more Alaska Indian (including Tsimshian Indians not enrolled in the Metlaktla ","children":[{"tag":"ref","attrib":{"idref":"fn002110"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002110"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Metlakatla”."}],"tail":" Indian Community) Eskimo, or Aleut blood, or combination thereof. The term includes any Native as so defined either or both of whose adoptive parents are not Natives. It also includes, in the absence of proof of a minimum blood quantum, any citizen of the United States who is regarded as an Alaska Native by the Native village or Native group of which he claims to be a member and whose father or mother is (or, if deceased, was) regarded as Native by any village or group. Any decision of the Secretary regarding eligibility for enrollment shall be final;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca49acaf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Native village” means any tribe, band, clan, group, village, community, or association in Alaska listed in sections 1610 and 1615 of this title, or which meets the requirements of this chapter, and which the Secretary determines was, on the 1970 census enumeration date (as shown by the census or other evidence satisfactory to the Secretary, who shall make findings of fact in each instance), composed of twenty-five or more Natives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca49acb0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Native group” means any tribe, band, clan, village, community, or village association of Natives in Alaska composed of less than twenty-five Natives, who comprise a majority of the residents of the locality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca49acb1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Public lands” means all Federal lands and interests therein located in Alaska except: (1) the smallest practicable tract, as determined by the Secretary, enclosing land actually used in connection with the administration of any Federal installation, and (2) land selections of the State of Alaska which have been patented or tentatively approved under section 6(g) of the Alaska Statehood Act, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/stat/72/341"},"text":"72 Stat. 341","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/223"},"text":"77 Stat. 223","children":[],"tail":"), or identified for selection by the State prior to "},{"tag":"date","attrib":{"date":"1969-01-17"},"text":"January 17, 1969","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca49acb2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means the State of Alaska;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca49acb3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Regional Corporation” means an Alaska Native Regional Corporation established under the laws of the State of Alaska in accordance with the provisions of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca49acb4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Person” means any individual, group, firm, corporation, association, or partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca49acb5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Municipal Corporation” means any general unit of municipal government under the laws of the State of Alaska;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca49acb6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Village Corporation” means an Alaska Native Village Corporation organized under the laws of the State of Alaska as a business for profit or nonprofit corporation to hold, invest, manage and/or distribute lands, property, funds, and other rights and assets for and on behalf of a Native village in accordance with the terms of this chapter.","children":[{"tag":"ref","attrib":{"idref":"fn002111"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002111"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca49acb7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Fund” means the Alaska Native Fund in the Treasury of the United States established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1605"},"text":"section 1605 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca49acb8-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Planning Commission” means the Joint Federal-State Land Use Planning Commission established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1616"},"text":"section 1616 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca49acb9-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Native Corporation” means any Regional Corporation, any Village Corporation, any Urban Corporation, and any Group Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca49acba-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Group Corporation” means an Alaska Native Group Corporation organized under the laws of the State of Alaska as a business for profit or nonprofit corporation to hold, invest, manage and/or distribute lands, property, funds, and other rights and assets for and on behalf of members of a Native group in accordance with the terms of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca49acbb-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/o"},"text":null,"children":[{"tag":"num","attrib":{"value":"o"},"text":"(o)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Urban Corporation” means an Alaska Native Urban Corporation organized under the laws of the State of Alaska as a business for profit or nonprofit corporation to hold, invest, manage and/or distribute lands, property, funds, and other rights and assets for and on behalf of members of an urban community of Natives in accordance with the terms of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca49acbc-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/p"},"text":null,"children":[{"tag":"num","attrib":{"value":"p"},"text":"(p)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Settlement Common Stock” means stock of a Native Corporation issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1606/g/1"},"text":"section 1606(g)(1) of this title","children":[],"tail":" that carries with it the rights and restrictions listed in "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1606/h/1"},"text":"section 1606(h)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca49acbd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/q"},"text":null,"children":[{"tag":"num","attrib":{"value":"q"},"text":"(q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Replacement Common Stock” means stock of a Native Corporation issued in exchange for Settlement Common Stock pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1606/h/3"},"text":"section 1606(h)(3) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca49acbe-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/r"},"text":null,"children":[{"tag":"num","attrib":{"value":"r"},"text":"(r)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Descendant of a Native” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca49acbf-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/r/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lineal descendant of a Native or of an individual who would have been a Native if such individual were alive on ","children":[{"tag":"date","attrib":{"date":"1971-12-18"},"text":"December 18, 1971","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca49acc0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/r/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an adoptee of a Native or of a descendant of a Native, whose adoption—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca49acc1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/r/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occurred prior to his or her majority, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca49acc2-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/r/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is recognized at law or in equity;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca49acc3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/s"},"text":null,"children":[{"tag":"num","attrib":{"value":"s"},"text":"(s)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Alienability restrictions” means the restrictions imposed on Settlement Common Stock by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1606/h/1/B"},"text":"section 1606(h)(1)(B) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca49acc4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/t"},"text":null,"children":[{"tag":"num","attrib":{"value":"t"},"text":"(t)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Settlement Trust” means a trust—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca49acc5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/t/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" established and registered by a Native Corporation under the laws of the State of Alaska pursuant to a resolution of its shareholders, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca49acc6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1602/t/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operated for the benefit of shareholders, Natives, and descendants of Natives, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1629e"},"text":"section 1629e of this title","children":[],"tail":" and the laws of the State of Alaska."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca49acc7-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203/s3"},"text":"Pub. L. 92–203, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/689"},"text":"85 Stat. 689","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/487/tXIV/s1401/d"},"text":"Pub. L. 96–487, title XIV, § 1401(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2492"},"text":"94 Stat. 2492","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/241/s3"},"text":"Pub. L. 100–241, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-02-03"},"text":"Feb. 3, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1789"},"text":"101 Stat. 1789","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/194/s3"},"text":"Pub. L. 106–194, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-02"},"text":"May 2, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/243"},"text":"114 Stat. 243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca49acc8-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca49acc9-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca49acca-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 6(g) of the Alaska Statehood Act, as amended, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/508/s6/g"},"text":"section 6(g) of Pub. L. 85–508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-07"},"text":"July 7, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/339"},"text":"72 Stat. 339","children":[],"tail":", which is set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s21"},"text":"section 21 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca49accb-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (t)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/194"},"text":"Pub. L. 106–194","children":[],"tail":" substituted “benefit of shareholders, Natives, and descendants of Natives,” for “sole benefit of the holders of the corporation’s Settlement Common Stock”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/241/s3/1"},"text":"Pub. L. 100–241, § 3(1)","children":[],"tail":", inserted “group,” after “individual,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/241/s3/2"},"text":"Pub. L. 100–241, § 3(2)","children":[],"tail":", struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/100/241/s3/3"},"text":"Pub. L. 100–241, § 3(3)","children":[],"tail":", substituted semicolon for period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (m). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/241/s3/4"},"text":"Pub. L. 100–241, § 3(4)","children":[],"tail":", substituted “Group Corporation;” for “Native Group.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (n) to (t). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/241/s3/5"},"text":"Pub. L. 100–241, § 3(5)","children":[],"tail":", added subsecs. (n) to (t)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (m). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487"},"text":"Pub. L. 96–487","children":[],"tail":" added subsec. (m)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca49accc-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idca49accd-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/452/s2"},"text":"Pub. L. 108–452, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3576"},"text":"118 Stat. 3576","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/452/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this Act [see Short Title of 2004 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Native allotment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Native allotment’ means an allotment claimed under the Act of ","children":[{"tag":"date","attrib":{"date":"1906-05-17"},"text":"May 17, 1906","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/34/197"},"text":"34 Stat. 197","children":[],"tail":", chapter 2469) [former "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s270–1"},"text":"43 U.S.C. 270–1","children":[],"tail":" to 270–3]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Secretary’ means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘State’ means the State of Alaska.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
