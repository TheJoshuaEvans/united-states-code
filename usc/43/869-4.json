{"tag":"section","attrib":{"id":"idca1073b0-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s869–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"869–4"},"text":"§ 869–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of moneys received from or on account of revested Oregon and California Railroad grant lands or reconveyed Coos Bay Wagon Road grant lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All moneys received from or on account of any revested Oregon and California Railroad grant lands or reconveyed Coos Bay Wagon Road grant lands under sections 869 to 869–4 of this title shall be deposited respectively in the Oregon and California land-grant fund and the Coos Bay Wagon Road grant fund, and shall be applied in the manner prescribed respectively by title II of the Act of ","children":[{"tag":"date","attrib":{"date":"1937-08-28"},"text":"August 28, 1937","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/50/875"},"text":"50 Stat. 875","children":[],"tail":"), as amended ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1181f"},"text":"43 U.S.C. 1181f","children":[],"tail":"),"},{"tag":"ref","attrib":{"idref":"fn002056"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002056"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and by subchapter II of chapter 44 of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca1073b1-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-06-14/ch578/s6"},"text":"June 14, 1926, ch. 578, § 6","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/86/66/s3"},"text":"Pub. L. 86–66, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-06-23"},"text":"June 23, 1959","children"