{"tag":"section","attrib":{"id":"idca06fe95-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s687c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"687c–1"},"text":"§ 687c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Execution of provisions of section 687c; authority of Secretary of the Interior","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to perform any and all acts, and to make such rules and regulations as may be necessary and proper, for the purpose of carrying the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s687c"},"text":"section 687c of this title","children":[],"tail":" into effect, including provisions for the forfeiture of any lease for failure to stock the same with fur-bearing animals within a period of one year from the date of the lease, or in the event of the devotion of the lease area primarily to any purpose other than the rearing of such fur-bearing animals."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca06fe96-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-07-03/ch745/s2"},"text":"July 3, 1926, ch. 745, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/822"},"text":"44 Stat. 822","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca06fe97-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca06fe98-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca06fe99-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s361"},"text":"section 361 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
