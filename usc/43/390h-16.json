{"tag":"section","attrib":{"id":"idc9d28152-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–16"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–16"},"text":"§ 390h–16.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Willow Lake Natural Treatment System Project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d28153-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–16/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the city of Salem, Oregon, is authorized to participate in the design, planning, and construction of the Willow Lake Natural Treatment System Project to reclaim and reuse wastewater within and without the service area of the city of Salem.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d28154-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–16/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of the project authorized by this section shall not exceed 25 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d28155-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–16/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not provide funds for the operation and maintenance of the project authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d28156-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s1634"},"text":"Pub. L. 102–575, title XVI, § 1634","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/321/s6/a"},"text":"Pub. L. 105–321, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3025"},"text":"112 Stat. 3025","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
