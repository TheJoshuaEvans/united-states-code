{"tag":"section","attrib":{"id":"idc9d9acc1-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s421f"},"text":null,"children":[{"tag":"num","attrib":{"value":"421f"},"text":"§ 421f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing loan contracts; negotiation by Secretary of amendments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is hereby authorized to negotiate amendments to existing water service and irrigation distribution system loan contracts to conform said contracts to the provisions of sections 421a to 421h of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9d9acc2-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-04/ch271/s6"},"text":"July 4, 1955, ch. 271, § 6","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/487"},"text":"Pub. L. 92–487","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-13"},"text":"Oct. 13, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/805"},"text":"86 Stat. 805","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
