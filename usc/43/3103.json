{"tag":"section","attrib":{"id":"idca9ab2cd-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s3103"},"text":null,"children":[{"tag":"num","attrib":{"value":"3103"},"text":"§ 3103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ground subsidence","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As the Secretary determines to be appropriate and subject to appropriations, the Secretary, through existing programs, shall advance the identification, mapping, research, and monitoring of subsidence and groundwater resource accounting, particularly in areas affected by drought.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca9ab2ce-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/323/s4"},"text":"Pub. L. 116–323, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5081"},"text":"134 Stat. 5081","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
