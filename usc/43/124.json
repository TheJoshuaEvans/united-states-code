{"tag":"section","attrib":{"id":"idc9b387e5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s124"},"text":null,"children":[{"tag":"num","attrib":{"value":"124"},"text":"§ 124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation of land offices","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be the duty of the Secretary of the Interior to consolidate the district land offices where practicable and consistent with the public interests.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9b387e6-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1892-08-05/ch380/s1"},"text":"Aug. 5, 1892, ch. 380, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/27/368"},"text":"27 Stat. 368","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9b387e7-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9b387e8-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9b387e9-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1893-03-03/ch208"},"text":"Act Mar. 3, 1893, ch. 208","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/27/591"},"text":"27 Stat. 591","children":[],"tail":", required the Secretary of the Interior to consolidate the district land offices so as to bring the total compensation of the registers and receivers for the fiscal year 1894, within the appropriation made therefor by the sundry Civil Appropriation Act for that year, which was fixed at $520,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
