{"tag":"section","attrib":{"id":"idc9ea4f09-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s493"},"text":null,"children":[{"tag":"num","attrib":{"value":"493"},"text":"§ 493.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation charges; date of payment; discount; advance payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All operation and maintenance charges upon projects existing prior to ","children":[{"tag":"date","attrib":{"date":"1924-12-05"},"text":"December 5, 1924","children":[],"tail":", shall become due and payable on the date fixed for each project by the Secretary of the Interior, and if such charge is paid on or before the date when due there shall be a discount of 5 per centum of such charge."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"All contracts providing for new projects and new divisions of projects approved after ","children":[{"tag":"date","attrib":{"date":"1924-12-05"},"text":"December 5, 1924","children":[],"tail":", shall require that all operation and maintenance charges shall be payable in advance. In each case where the care, operation, and maintenance of a project or division of a project are transferred to the water users the contract shall require the payment of operation and maintenance charges in advance. Whenever an adjustment of water charges is made under sections 371, 376, 377, 412, 417, 433, 438,"},{"tag":"ref","attrib":{"idref":"fn002037"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002037"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" 462, 463,"},{"tag":"ref","attrib":{"idref":"fn002037"},"text":"1","children":[],"tail":" 466, 467,"},{"tag":"ref","attrib":{"idref":"fn002037"},"text":"1","children":[],"tail":" 473,"},{"tag":"ref","attrib":{"idref":"fn002037"},"text":"1","children":[],"tail":" 474,"},{"tag":"ref","attrib":{"idref":"fn002037"},"text":"1","children":[],"tail":" 478, 493, 494, 500, 501 and 526 of this title the adjustment contract shall provide that thereafter all operation and maintenance charges shall be payable in advance."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9ea4f0a-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-08-13/ch247/s6"},"text":"Aug. 13, 1914, ch. 247, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/688"},"text":"38 Stat. 688","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1924-12-05/ch4/s4"},"text":"Dec. 5, 1924, ch. 4, § 4","children":[],"tail":", subsec. N, "},{"tag":"ref","attrib":{"href":"/us/stat/43/704"},"text":"43 Stat. 704","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9ea4f0b-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9ea4f0c-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc9ea4f0d-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s438"},"text":"Section 438 of this title","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1953-08-13/ch428/s10"},"text":"act Aug. 13, 1953, ch. 428, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/568"},"text":"67 Stat. 568","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 463, 467, 473, and 474 of this title, referred to in text, were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-25/ch383/s47"},"text":"act May 25, 1926, ch. 383, § 47","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/650"},"text":"44 Stat. 650","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9ea4f0e-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"First paragraph of this section is comprised of part of first sentence of section 6 of act ","children":[{"tag":"date","attrib":{"date":"1914-08-13"},"text":"Aug. 13, 1914","children":[],"tail":". Remainder of first sentence of such section 6 is classified to sections 479, 494, and 495 of this title; second and third sentences of such section 6 are classified to sections 496 and 497 of this title, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Second paragraph of this section is from act ","children":[{"tag":"date","attrib":{"date":"1924-12-05"},"text":"Dec. 5, 1924","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Language was inserted in the first paragraph of this section limiting it to projects existing prior to ","children":[{"tag":"date","attrib":{"date":"1924-12-05"},"text":"Dec. 5, 1924","children":[],"tail":", to avoid conflict with second paragraph applicable to projects after "},{"tag":"date","attrib":{"date":"1924-12-05"},"text":"Dec. 5, 1924","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9ea4f0f-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idc9ea4f10-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
