{"tag":"section","attrib":{"id":"idca342960-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s1455"},"text":null,"children":[{"tag":"num","attrib":{"value":"1455"},"text":"§ 1455.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitor; appointment; duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1946-06-26"},"text":"June 26, 1946","children":[],"tail":" the legal work of the Department of the Interior shall be performed under the supervision and direction of the Solicitor of the Department of the Interior, who shall be appointed by the President with the advice and consent of the Senate."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca342961-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-26/ch494"},"text":"June 26, 1946, ch. 494","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/312"},"text":"60 Stat. 312","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca342962-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca342963-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca342964-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of this section which prescribed the compensation of the Solicitor were omitted to conform to the provisions of the Federal Executive Salary Schedule. See section 5311 et seq. of Title 5, Government Organization and Employees.","children"