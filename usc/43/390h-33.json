{"tag":"section","attrib":{"id":"idc9d281c3-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–33"},"text":null,"children":[{"tag":"num","attrib":{"value":"390h–33"},"text":"§ 390h–33.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elsinore Valley Municipal Water District projects, California","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc9d281c4-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–33/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the Elsinore Valley Municipal Water District, California, may participate in the design, planning, and construction of permanent facilities needed to establish recycled water distribution and wastewater treatment and reclamation facilities that will be used to treat wastewater and provide recycled water in the Elsinore Valley Municipal Water District, California.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d281c5-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–33/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of each project described in subsection (a) shall not exceed 25 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d281c6-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–33/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided by the Secretary under this section shall not be used for operation or maintenance of the projects described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc9d281c7-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s390h–33/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $12,500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc9d281c8-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXVI/s1650"},"text":"Pub. L. 102–575, title XVI, § 1650","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tIX/s9109/a"},"text":"Pub. L. 111–11, title IX, § 9109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1315"},"text":"123 Stat. 1315","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
