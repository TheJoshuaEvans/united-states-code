{"tag":"section","attrib":{"id":"idc9bf6e22-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s315o–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"315o–2"},"text":"§ 315o–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Animals and equipment for field employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior may require field employees of the Bureau of Land Management to furnish horses and miscellaneous equipment necessary for the performance of their official work and may provide at Government expense forage, care, and housing for such animals and equipment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9bf6e23-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1942-12-18/ch769"},"text":"Dec. 18, 1942, ch. 769","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/1067"},"text":"56 Stat. 1067","children":[],"tail":"; 1946 Reorg. Plan No. 3, § 403, eff. "},{"tag":"date","attrib":{"date":"1946-07-16"},"text":"July 16, 1946","children":[],"tail":", 11 F.R. 7876, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1100"},"text":"60 Stat. 1100","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9bf6e24-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9bf6e25-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9bf6e26-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as a part of act ","children":[{"tag":"date","attrib":{"date":"1934-06-28"},"text":"June 28, 1934","children":[],"tail":", known as the Taylor Grazing Act, which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idc9bf6e27-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idc9bf6e28-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Bureau of Land Management” substituted for “Grazing Service” on authority of section 403 of Reorg. Plan No. 3 of 1946, which abolished Grazing Service and transferred functions of Grazing Service to a new agency to be known as Bureau of Land Management. See section 403 of Reorg. Plan No. 3 of 1946, set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
