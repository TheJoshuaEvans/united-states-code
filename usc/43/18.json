{"tag":"section","attrib":{"id":"idc9a52eee-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"§ 18.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copies of papers filed","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever any person claiming to be interested in or entitled to land, under any grant or patent from the United States, applies to the Department of the Interior for copies of papers filed and remaining therein, in anywise affecting the title to such land, it shall be the duty of the Secretary of the Interior to cause such copies to be made out and authenticated, under his hand and the seal of the Bureau of Land Management, for the person so applying.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9a52eef-3a70-11f1-bde1-a5140e158598"},"text":"(R.S. § 460; 1946 Reorg. Plan No. 3, § 403, eff. ","children":[{"tag":"date","attrib":{"date":"1946-07-16"},"text":"July 16, 1946","children":[],"tail":", 11 F.R. 7876, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1100"},"text":"60 Stat. 1100","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9a52ef0-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9a52ef1-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9a52ef2-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 460 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1823-01-23/ch6"},"text":"Jan. 23, 1823, ch. 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/3/721"},"text":"3 Stat. 721","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1836-07-04/ch352/s7"},"text":"July 4, 1836, ch. 352, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/5/111"},"text":"5 Stat. 111","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idc9a52ef3-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idc9a52ef4-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1451"},"text":"section 1451 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Bureau of Land Management” substituted for “General Land Office” on authority of section 403 of Reorg. Plan No. 3 of 1946. See note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
