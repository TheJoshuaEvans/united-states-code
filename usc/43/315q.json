{"tag":"section","attrib":{"id":"idc9bf6e2f-3a70-11f1-bde1-a5140e158598","identifier":"/us/usc/t43/s315q"},"text":null,"children":[{"tag":"num","attrib":{"value":"315q"},"text":"§ 315q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal of lands for war or national defense purposes; payment for cancellation of permits or licenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever use for war or national defense purposes of the public domain or other property owned by or under the control of the United States prevents its use for grazing, persons holding grazing permits or licenses and persons whose grazing permits or licenses have been or will be canceled because of such use shall be paid out of the funds appropriated or allocated for such project such amounts as the head of the department or agency so using the lands shall determine to be fair and reasonable for the losses suffered by such persons as a result of the use of such lands for war or national defense purposes. Such payments shall be deemed payment in full for such losses. Nothing contained in this section shall be construed to create any liability not now existing against the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc9bf6e30-3a70-11f1-bde1-a5140e158598"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1942-07-09/ch500"},"text":"July 9, 1942, ch. 500","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/654"},"text":"56 Stat. 654","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-05-28/ch353/s1"},"text":"May 28, 1948, ch. 353, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/277"},"text":"62 Stat. 277","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc9bf6e31-3a70-11f1-bde1-a5140e158598"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc9bf6e32-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc9bf6e33-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as a part of act ","children":[{"tag":"date","attrib":{"date":"1934-06-28"},"text":"June 28, 1934","children":[],"tail":", known as the Taylor Grazing Act, which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc9bf6e34-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1948—Act ","children":[{"tag":"date","attrib":{"date":"1948-05-28"},"text":"May 28, 1948","children":[],"tail":", inserted “or national defense” between “war” and “purposes” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc9bf6e35-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc9bf6e36-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1948 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1948-05-28/ch353/s2"},"text":"Act May 28, 1948, ch. 353, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/277"},"text":"62 Stat. 277","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1948-05-28/ch353/s2"},"text":"“This amendment [amending this section] is to take effect as of ","children":[{"tag":"date","attrib":{"date":"1947-07-25"},"text":"July 25, 1947","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc9bf6e37-3a70-11f1-bde1-a5140e158598"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of War and Emergencies","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Joint Res. ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-25/ch327/s3"},"text":"July 25, 1947, ch. 327, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/451"},"text":"61 Stat. 451","children":[],"tail":", provided that in the interpretation of this section, the date "},{"tag":"date","attrib":{"date":"1947-07-25"},"text":"July 25, 1947","children":[],"tail":", shall be deemed to be the date of termination of any state of war theretofore declared by Congress and of the national emergencies proclaimed by the President on "},{"tag":"date","attrib":{"date":"1939-09-08"},"text":"September 8, 1939","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1941-05-27"},"text":"May 27, 1941","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
