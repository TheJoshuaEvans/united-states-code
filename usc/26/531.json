{"tag":"section","attrib":{"id":"id43cbbddb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s531"},"text":null,"children":[{"tag":"num","attrib":{"value":"531"},"text":"§ 531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of accumulated earnings tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to other taxes imposed by this chapter, there is hereby imposed for each taxable year on the accumulated taxable income (as defined in section 535) of each corporation described in section 532, an accumulated earnings tax equal to 20 percent of the accumulated taxable income.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id43cbbddc-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/179"},"text":"68A Stat. 179","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1001/a/2/A"},"text":"Pub. L. 100–647, title I, § 1001(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3349"},"text":"102 Stat. 3349","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII"},"text":"Pub. L. 103–66, title XIII","children":[],"tail":", §§ 13201(b)(1), 13202(b), "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/459"},"text":"107 Stat. 459","children":[],"tail":", 461; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tI/s101/c/4"},"text":"Pub. L. 107–16, title I, § 101(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/43"},"text":"115 Stat. 43","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/27/tIII/s302/e/5"},"text":"Pub. L. 108–27, title III, § 302(e)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-28"},"text":"May 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/764"},"text":"117 Stat. 764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/tI/s102/c/1/A"},"text":"Pub. L. 112–240, title I, § 102(c)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2319"},"text":"126 Stat. 2319","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43cbbddd-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43cbbdde-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43cbbddf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/240"},"text":"Pub. L. 112–240","children":[],"tail":" substituted “20 percent” for “15 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/27"},"text":"Pub. L. 108–27","children":[],"tail":" substituted “equal to 15 percent of the accumulated taxable income.” for “equal to the product of the highest rate of tax under section 1(c) and the accumulated taxable income.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16"},"text":"Pub. L. 107–16",