{"tag":"section","attrib":{"id":"id473464b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715"},"text":null,"children":[{"tag":"num","attrib":{"value":"6715"},"text":"§ 6715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dyed fuel sold for use or used in taxable use, etc.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id473464b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id473464b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any dyed fuel is sold or held for sale by any person for any use which such person knows or has reason to know is not a nontaxable use of such fuel,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id473464b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any dyed fuel is held for use or used by any person for a use other than a nontaxable use and such person knew, or had reason to know, that such fuel was so dyed,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id473464b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person willfully alters, chemically or otherwise, or attempts to so alter, the strength or composition of any dye or marking done pursuant to section 4082 in any dyed fuel, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id473464b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who has knowledge that a dyed fuel which has been altered as described in paragraph (3) sells or holds for sale such fuel for any use which the person knows or has reason to know is not a nontaxable use of such fuel,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then such person shall pay a penalty in addition to the tax (if any).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id473464b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of penalty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id473464ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), the amount of the penalty under subsection (a) on each act shall be the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id473464bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id473464bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10 for each gallon of the dyed fuel involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id473464bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the penalty under subsection (a) on any person, paragraph (1) shall be applied by increasing the amount in paragraph (1)(A) by the product of such amount and the number of prior penalties (if any) imposed by this section on such person (or a related person or any predecessor of such person or related person).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id473464be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id473464bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dyed fuel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “dyed fuel” means any dyed diesel fuel or kerosene, whether or not the fuel was dyed pursuant to section 4082.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id473464c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nontaxable use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nontaxable use” has the meaning given such term by section 4082(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id473464c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint and several liability of certain officers and employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a penalty is imposed under this section on any business entity, each officer, employee, or agent of such entity who willfully participated in any act giving rise to such penalty shall be jointly and severally liable with such entity for such penalty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id473464c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No administrative appeal for third and subsequent violations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any person who is found to be subject to the penalty under this section after a chemical analysis of such fuel and who has been penalized under this section at least twice after the date of the enactment of this subsection, no administrative appeal or review shall be allowed with respect to such finding except in the case of a claim regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id473464c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fraud or mistake in the chemical analysis, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id473464c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mathematical calculation of the amount of the penalty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id473464c5-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13242/b/1"},"text":"Pub. L. 103–66, title XIII, § 13242(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/520"},"text":"107 Stat. 520","children":[],"tail":", § 6714; renumbered § 6715, "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1703/n/9/A"},"text":"Pub. L. 104–188, title I, § 1703(n)(9)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1877"},"text":"110 Stat. 1877","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1032/e/11"},"text":"Pub. L. 105–34, title X, § 1032(e)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/935"},"text":"111 Stat. 935","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII"},"text":"Pub. L. 108–357, title VIII","children":[],"tail":", §§ 855(a), 856(a), (b), "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1616"},"text":"118 Stat. 1616","children":[],"tail":", 1617.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id473464c6-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id473464c7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id473464c8-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this subsection, referred to in subsec. (e), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id473464c9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s856/a"},"text":"Pub. L. 108–357, § 856(a)","children":[],"tail":", which directed amendment of par. (2) by striking “or”, was executed by striking “or” at the end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s856/b"},"text":"Pub. L. 108–357, § 856(b)","children":[],"tail":", substituted “alters, chemically or otherwise, or attempts to so alter,” for “alters, or attempts to alter,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s856/a"},"text":"Pub. L. 108–357, § 856(a)","children":[],"tail":", inserted “or” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s856/a"},"text":"Pub. L. 108–357, § 856(a)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s855/a"},"text":"Pub. L. 108–357, § 855(a)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" inserted “or kerosene” after “diesel fuel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6714"},"text":"section 6714 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id473464ca-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id473464cb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s855/b"},"text":"Pub. L. 108–357, title VIII, § 855(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1616"},"text":"118 Stat. 1616","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tVIII/s855/b"},"text":"“The amendment made by this section [amending this section] shall apply to penalties assessed after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s856/c"},"text":"Pub. L. 108–357, title VIII, § 856(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1617"},"text":"118 Stat. 1617","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tVIII/s856/c"},"text":"“The amendments made by this section [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id473464cc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-07-01"},"text":"July 1, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1032/f/1"},"text":"section 1032(f)(1) of Pub. L. 105–34","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4041"},"text":"section 4041 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id473464cd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1994-01-01"},"text":"Jan. 1, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13242/e"},"text":"section 13242(e) of Pub. L. 103–66","children":[],"tail":", set out as an Effective Date of 1993 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4041"},"text":"section 4041 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
