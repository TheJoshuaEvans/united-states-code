{"tag":"section","attrib":{"id":"id45f4e042-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966"},"text":null,"children":[{"tag":"num","attrib":{"value":"4966"},"text":"§ 4966.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxes on taxable distributions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45f4e043-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of taxes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f4e044-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On the sponsoring organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on each taxable distribution a tax equal to 20 percent of the amount thereof. The tax imposed by this paragraph shall be paid by the sponsoring organization with respect to the donor advised fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e045-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On the fund management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on the agreement of any fund manager to the making of a distribution, knowing that it is a taxable distribution, a tax equal to 5 percent of the amount thereof. The tax imposed by this paragraph shall be paid by any fund manager who agreed to the making of the distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f4e046-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f4e047-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint and several liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If more than one person is liable under subsection (a)(2) with respect to the making of a taxable distribution, all such persons shall be jointly and severally liable under such paragraph with respect to such distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e048-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit for management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any one taxable distribution, the maximum amount of the tax imposed by subsection (a)(2) shall not exceed $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f4e049-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f4e04a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “taxable distribution” means any distribution from a donor advised fund—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f4e04b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any natural person, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f4e04c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to any other person if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45f4e04d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such distribution is for any purpose other than one specified in section 170(c)(2)(B), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f4e04e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sponsoring organization does not exercise expenditure responsibility with respect to such distribution in accordance with section 4945(h).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e04f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such term shall not include any distribution from a donor advised fund—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f4e050-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any organization described in section 170(b)(1)(A) (other than a disqualified supporting organization),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f4e051-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the sponsoring organization of such donor advised fund, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f4e052-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any other donor advised fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f4e053-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f4e054-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sponsoring organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “sponsoring organization” means any organization which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f4e055-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is described in section 170(c) (other than in paragraph (1) thereof, and without regard to paragraph (2)(A) thereof),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f4e056-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a private foundation (as defined in section 509(a)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f4e057-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains 1 or more donor advised funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e058-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donor advised fund","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f4e059-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B) or (C), the term “donor advised fund” means a fund or account—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45f4e05a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is separately identified by reference to contributions of a donor or donors,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f4e05b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is owned and controlled by a sponsoring organization, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f4e05c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which a donor (or any person appointed or designated by such donor) has, or reasonably expects to have, advisory privileges with respect to the distribution or investment of amounts held in such fund or account by reason of the donor’s status as a donor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f4e05d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “donor advised fund” shall not include any fund or account—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45f4e05e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which makes distributions only to a single identified organization or governmental entity, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f4e05f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to which a person described in subparagraph (A)(iii) advises as to which individuals receive grants for travel, study, or other similar purposes, if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id45f4e060-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person’s advisory privileges are performed exclusively by such person in the person’s capacity as a member of a committee all of the members of which are appointed by the sponsoring organization,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id45f4e061-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no combination of persons described in subparagraph (A)(iii) (or persons related to such persons) control, directly or indirectly, such committee, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id45f4e062-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all grants from such fund or account are awarded on an objective and nondiscriminatory basis pursuant to a procedure approved in advance by the board of directors of the sponsoring organization, and such procedure is designed to ensure that all such grants meet the requirements of paragraph (1), (2), or (3) of section 4945(g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f4e063-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may exempt a fund or account not described in subparagraph (B) from treatment as a donor advised fund—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45f4e064-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such fund or account is advised by a committee not directly or indirectly controlled by the donor or any person appointed or designated by the donor for the purpose of advising with respect to distributions from such fund (and any related parties), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f4e065-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such fund benefits a single identified charitable purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e066-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund manager","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “fund manager” means, with respect to any sponsoring organization—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f4e067-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer, director, or trustee of such sponsoring organization (or an individual having powers or responsibilities similar to those of officers, directors, or trustees of the sponsoring organization), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f4e068-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any act (or failure to act), the employees of the sponsoring organization having authority or responsibility with respect to such act (or failure to act).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e069-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualified supporting organization","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f4e06a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “disqualified supporting organization” means, with respect to any distribution—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45f4e06b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any type III supporting organization (as defined in section 4943(f)(5)(A)) which is not a functionally integrated type III supporting organization (as defined in section 4943(f)(5)(B)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f4e06c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any organization which is described in subparagraph (B) or (C) if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id45f4e06d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the donor or any person designated by the donor for the purpose of advising with respect to distributions from a donor advised fund (and any related parties) directly or indirectly controls a supported organization (as defined in section 509(f)(3)) of such organization, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id45f4e06e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines by regulations that a distribution to such organization otherwise is inappropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f4e06f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Type I and type II supporting organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An organization is described in this subparagraph if the organization meets the requirements of subparagraphs (A) and (C) of section 509(a)(3) and is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45f4e070-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operated, supervised, or controlled by one or more organizations described in paragraph (1) or (2) of section 509(a), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f4e071-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervised or controlled in connection with one or more such organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f4e072-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4966/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functionally integrated type III supporting organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organization is described in this subparagraph if the organization is a functionally integrated type III supporting organization (as defined under section 4943(f)(5)(B)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45f4e073-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1231/a"},"text":"Pub. L. 109–280, title XII, § 1231(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1095"},"text":"120 Stat. 1095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45f4e074-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45f4e075-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45f4e076-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1231/c"},"text":"section 1231(c) of Pub. L. 109–280","children":[],"tail":", set out as an Effective Date of 2006 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4963"},"text":"section 4963 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
