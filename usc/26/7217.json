{"tag":"section","attrib":{"id":"id474777f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7217"},"text":null,"children":[{"tag":"num","attrib":{"value":"7217"},"text":"§ 7217.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on executive branch influence over taxpayer audits and other investigations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id474777f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7217/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any applicable person to request, directly or indirectly, any officer or employee of the Internal Revenue Service to conduct or terminate an audit or other investigation of any particular taxpayer with respect to the tax liability of such taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id474777f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7217/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any officer or employee of the Internal Revenue Service receiving any request prohibited by subsection (a) shall report the receipt of such request to the Treasury Inspector General for Tax Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id474777f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7217/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to any written request made—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id474777f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7217/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an applicable person by or on behalf of the taxpayer and forwarded by such applicable person to the Internal Revenue Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474777f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7217/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an applicable person for disclosure of return or return information under section 6103 if such request is made in accordance with the requirements of such section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474777f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7217/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Secretary of the Treasury as a consequence of the implementation of a change in tax policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id474777fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7217/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who willfully violates subsection (a) or fails to report under subsection (b) shall be punished upon conviction by a fine in any amount not exceeding $5,000, or imprisonment of not more than 5 years, or both, together with the costs of prosecution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id474777fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7217/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “applicable person” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id474777fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7217/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President, the Vice President, any employee of the executive office of the President, and any employee of the executive office of the Vice President; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474777fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7217/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual (other than the Attorney General of the United States) serving in a position specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5312"},"text":"section 5312 of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id474777fe-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tI/s1105/a"},"text":"Pub. L. 105–206, title I, § 1105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/711"},"text":"112 Stat. 711","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id474777ff-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47477800-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id47477801-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7217, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXII/s1202/e/1"},"text":"Pub. L. 94–455, title XII, § 1202(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1687"},"text":"90 Stat. 1687","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s701/bb/7"},"text":"Pub. L. 95–600, title VII, § 701(bb)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2923"},"text":"92 Stat. 2923","children":[],"tail":", related to civil damages for unauthorized disclosure of returns and return information, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s357/b/1"},"text":"Pub. L. 97–248, title III, § 357(b)(1)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/646"},"text":"96 Stat. 646","children":[],"tail":", applicable with respect to disclosures made after "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47477802-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47477803-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tI/s1105/c"},"text":"Pub. L. 105–206, title I, § 1105(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/711"},"text":"112 Stat. 711","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/206/tI/s1105/c"},"text":"“The amendments made by this section [enacting this section] shall apply to requests made after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
