{"tag":"section","attrib":{"id":"id475cfad2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7452"},"text":null,"children":[{"tag":"num","attrib":{"value":"7452"},"text":"§ 7452.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation of parties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall be represented by the Chief Counsel for the Internal Revenue Service or his delegate in the same manner before the Tax Court as he has heretofore been represented in proceedings before such Court. The taxpayer shall continue to be represented in accordance with the rules of practice prescribed by the Court. No qualified person shall be denied admission to practice before the Tax Court because of his failure to be a member of any profession or calling.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id475cfad3-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/884"},"text":"68A Stat. 884","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/368/s2/a"},"text":"Pub. L. 86–368, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-22"},"text":"Sept. 22, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/648"},"text":"73 Stat. 648","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id475cfad4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id475cfad5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id475cfad6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/368"},"text":"Pub. L. 86–368","children":[],"tail":" substituted “Chief Counsel for the Internal Revenue Service or his delegate” for “Assistant General Counsel of the Treasury Department serving as Chief Counsel of the Internal Revenue Service, or the delegate of such Chief Counsel,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id475cfad7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id475cfad8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1959 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/368"},"text":"Pub. L. 86–368","children":[],"tail":" effective when Chief Counsel for Internal Revenue Service first appointed pursuant to amendment of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7801"},"text":"section 7801 of this title","chi