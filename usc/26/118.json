{"tag":"section","attrib":{"id":"id4166cc79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118"},"text":null,"children":[{"tag":"num","attrib":{"value":"118"},"text":"§ 118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions to the capital of a corporation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4166cc7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a corporation, gross income does not include any contribution to the capital of the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4166cc7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), except as provided in subsection (c), the term “contribution to the capital of the taxpayer” does not include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4166cc7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contribution in aid of construction or any other contribution as a customer or potential customer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4166cc7d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contribution by any governmental entity or civic group (other than a contribution made by a shareholder as such).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4166cc7e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for water and sewerage disposal utilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4166cc7f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “contribution to the capital of the taxpayer” includes any amount of money or other property received from any person (whether or not a shareholder) by a regulated public utility which provides water or sewerage disposal services if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4166cc80-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such amount is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4166cc81-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contribution in aid of construction, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4166cc82-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contribution to the capital of such utility by a governmental entity providing for the protection, preservation, or enhancement of drinking water or sewerage disposal services,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41693c83-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a contribution in aid of construction which is property other than water or sewerage disposal facilities, such amount meets the requirements of the expenditure rule of paragraph (2), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41693c84-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount (or any property acquired or constructed with such amount) is not included in the taxpayer’s rate base for ratemaking purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41693c85-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An amount meets the requirements of this paragraph if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41693c86-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an amount equal to such amount is expended for the acquisition or construction of tangible property described in section 1231(b)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id41693c87-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is the property for which the contribution was made or is of the same type as such property, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id41693c88-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is used predominantly in the trade or business of furnishing water or sewerage disposal services,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41693c89-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expenditure referred to in subparagraph (A) occurs before the end of the second taxable year after the year in which such amount was received, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41693c8a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accurate records are kept of the amounts contributed and expenditures made, the expenditures to which contributions are allocated, and the year in which the contributions and expenditures are received and made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41693c8b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41693c8c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contribution in aid of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “contribution in aid of construction” shall be defined by regulations prescribed by the Secretary, except that such term shall not include amounts paid as service charges for starting or stopping services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41693c8d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Predominantly","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “predominantly” means 80 percent or more.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41693c8e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulated public utility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “regulated public utility” has the meaning given such term by section 7701(a)(33), except that such term shall not include any utility which is not required to provide water or sewerage disposal services to members of the general public in its service area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41693c8f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disallowance of deductions and credits; adjusted basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subtitle, no deduction or credit shall be allowed for, or by reason of, any expenditure which constitutes a contribution in aid of construction to which this subsection applies. The adjusted basis of any property acquired with contributions in aid of construction to which this subsection applies shall be zero.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41693c90-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the taxpayer for any taxable year treats an amount as a contribution to the capital of the taxpayer described in subsection (c)(1)(A)(i), then—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41693c91-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the statutory period for the assessment of any deficiency attributable to any part of such amount shall not expire before the expiration of 3 years from the date the Secretary is notified by the taxpayer (in such manner as the Secretary may prescribe) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41693c92-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the expenditure referred to in subparagraph (A) of subsection (c)(2),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41693c93-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer’s intention not to make the expenditures referred to in such subparagraph, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41693c94-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a failure to make such expenditure within the period described in subparagraph (B) of subsection (c)(2), and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41693c95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such deficiency may be assessed before the expiration of such 3-year period notwithstanding the provisions of any other law or rule of law which would otherwise prevent such assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41693c96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41693c97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For basis of property acquired by a corporation through a contribution to its capital, see section 362.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41693c98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s118/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For special rules in the case of contributions of indebtedness, see section 108(e)(6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id41693c99-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/39"},"text":"68A Stat. 39","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXXI/s2120/a"},"text":"Pub. L. 94–455, title XXI, § 2120(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1912"},"text":"90 Stat. 1912","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tIII/s364/a"},"text":"Pub. L. 95–600, title III, § 364(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2854"},"text":"92 Stat. 2854","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/589/s2/e/2"},"text":"Pub. L. 96–589, § 2(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3396"},"text":"94 Stat. 3396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s163/a"},"text":"Pub. L. 98–369, div. A, title I, § 163(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/697"},"text":"98 Stat. 697","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVIII/s824/a"},"text":"Pub. L. 99–514, title VIII, § 824(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2374"},"text":"100 Stat. 2374","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1613/a/1"},"text":"Pub. L. 104–188, title I, § 1613(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1848-1850"},"text":"110 Stat. 1848–1850","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13312/a"},"text":"Pub. L. 115–97, title I, § 13312(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2132"},"text":"131 Stat. 2132","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dH/tVI/s80601/a"},"text":"Pub. L. 117–58, div. H, title VI, § 80601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1337"},"text":"135 Stat. 1337","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id41693c9a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id41693c9b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id41693c9c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s80601/a/1"},"text":"Pub. L. 117–58, § 80601(a)(1)","children":[],"tail":", inserted “except as provided in subsection (c),” after “For purposes of subsection (a),” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s80601/a/2"},"text":"Pub. L. 117–58, § 80601(a)(2)","children":[],"tail":", (3), added subsecs. (c) and (d), redesignated former subsec. (d) as (e), and struck out former subsec. (c) which related to regulations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsecs. (b) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" added subsecs. (b) and (c), redesignated subsec. (e) as (d), and struck out former subsecs. (b) to (d) which related to contributions in aid of construction, special rules for water and sewerage disposal utilities, and statute of limitations for assessment of deficiencies, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1613/a/2"},"text":"Pub. L. 104–188, § 1613(a)(2)","children":[],"tail":", inserted “except as provided in subsection (c),” before “the term”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1613/a/1"},"text":"Pub. L. 104–188, § 1613(a)(1)","children":[],"tail":", added subsecs. (c) and (d) and redesignated former subsec. (c) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s824/a"},"text":"Pub. L. 99–514, § 824(a)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) relating to contributions in aid of construction, containing par. (1) general rule, par. (2) expenditure rule, par. (3) definitions, and par. (4) disallowance of deductions and investment credit; adjusted basis."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s824/a"},"text":"Pub. L. 99–514, § 824(a)","children":[],"tail":", redesignated former subsec. (d) as (c) and struck out former subsec. (c), statute of limitations, which read as follows: “If the taxpayer for any taxable year treats an amount as a contribution to the capital of the taxpayer described in subsection (b), then—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the statutory period for the assessment of any deficiency attributable to any part of such amount shall not expire before the expiration of 3 years from the date the Secretary is notified by the taxpayer (in such manner as the Secretary may prescribe) of—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the amount of the expenditure referred to in subparagraph (A) of subsection (b)(2),","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the taxpayer’s intention not to make the expenditures referred to in such subparagraph, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) a failure to make such expenditure within the period described in subparagraph (B) of subsection (b)(2); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) such deficiency may be assessed before the expiration of such 3-year period notwithstanding the provisions of any other law or rule of law which would otherwise prevent such assessment.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/589"},"text":"Pub. L. 96–589","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s364/a/1"},"text":"Pub. L. 95–600, § 364(a)(1)","children":[],"tail":", (2), substituted in provisions preceding subpar. (A) “electric energy, gas (through a local distribution system or transportation by pipeline), water,” for “water” and in subpar. (B) “electric energy, gas, steam, water,” for “water”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s364/a/3"},"text":"Pub. L. 95–600, § 364(a)(3)","children":[],"tail":", substituted “electric energy, gas, steam, water,” for “water”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s364/a/4"},"text":"Pub. L. 95–600, § 364(a)(4)","children":[],"tail":", substituted “line to an electric line, a gas main, a steam line, or a main water or sewer line” for “property to a main water or sewer line”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s364/a/5"},"text":"Pub. L. 95–600, § 364(a)(5)","children":[],"tail":", substituted “electric energy, gas, water,” for “water” and inserted “(including in the case of a gas transmission utility, the provision of gas services by sale for resale to the general public)” after “members of the general public”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s2120/a"},"text":"Pub. L. 94–455, § 2120(a)","children":[],"tail":", added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id41693c9d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41693c9e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dH/tVI/s80601/b"},"text":"Pub. L. 117–58, div. H, title VI, § 80601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1338"},"text":"135 Stat. 1338","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/58/dH/tVI/s80601/b"},"text":"“The amendments made by this section [amending this section] shall apply to contributions made after ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41693c9f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13312/b"},"text":"Pub. L. 115–97, title I, § 13312(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2132"},"text":"131 Stat. 2132","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/97/tI/s13312/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the amendments made by this section [amending this section] shall apply to contributions made after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section shall not apply to any contribution, made after the date of enactment of this Act by a governmental entity, which is made pursuant to a master development plan that has been approved prior to such date by a governmental entity.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41693ca0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1613/a/3"},"text":"Pub. L. 104–188, title I, § 1613(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1850"},"text":"110 Stat. 1850","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/188/tI/s1613/a/3"},"text":"“The amendments made by this subsection [amending this section] shall apply to amounts received after ","children":[{"tag":"date","attrib":{"date":"1996-06-12"},"text":"June 12, 1996","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41693ca1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVIII/s824/c"},"text":"Pub. L. 99–514, title VIII, § 824(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2374"},"text":"100 Stat. 2374","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1008/j/2"},"text":"Pub. L. 100–647, title I, § 1008(j)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3445"},"text":"102 Stat. 3445","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1008/j/2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this subsection, the amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s362"},"text":"section 362 of this title","children":[],"tail":"] shall apply to amounts received after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", in taxable years ending after such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of certain water supply projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section shall not apply to amounts which are paid by the New Jersey Department of Environmental Protection for construction of alternative water supply projects in zones of drinking water contamination and which are designated by such department as being taken into account under this paragraph. Not more than $4,631,000 of such amounts may be designated under the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of certain contributions by transportation authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section shall not apply to contributions in aid of construction by a qualified transportation authority which were clearly identified in a master plan in existence on ","children":[{"tag":"date","attrib":{"date":"1984-09-13"},"text":"September 13, 1984","children":[],"tail":", and which are designated by such authority as being taken into account under this paragraph. Not more than $68,000,000 of such contributions may be designated under the preceding sentence. For purposes of this paragraph, a qualified transportation authority is an entity which was created on "},{"tag":"date","attrib":{"date":"1967-02-20"},"text":"February 20, 1967","children":[],"tail":", and which was established by an interstate compact and consented to by Congress in "},{"tag":"ref","attrib":{"href":"/us/pl/89/774"},"text":"Public Law 89–774","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1324"},"text":"80 Stat. 1324","children":[],"tail":" (1966)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of certain partnerships","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a partnership with a taxable year beginning ","children":[{"tag":"date","attrib":{"date":"1986-05-01"},"text":"May 1, 1986","children":[],"tail":", if such partnership realized net capital gain during the period beginning on the 1st day of such taxable year and ending on "},{"tag":"date","attrib":{"date":"1986-05-29"},"text":"May 29, 1986","children":[],"tail":", pursuant to an underwriting agreement dated "},{"tag":"date","attrib":{"date":"1986-05-06"},"text":"May 6, 1986","children":[],"tail":", then such partnership may elect to treat each asset to which such net capital gain relates as having been distributed to the partners of such partnership in proportion to their distributive share of the capital gain or loss realized by the partnership with respect to such asset and to treat each such asset as having been sold by each partner on the date of the sale of the asset by the partnership. If such an election is made, the consideration received by the partnership in connection with the sale of such assets shall be treated as having been received by the partners in connection with the deemed sale of such assets. In the case of a tiered partnership, for purposes of this paragraph each partnership shall be treated as having realized net capital gain equal to its proportionate share of the net capital gain of each partnership in which it is a partner, and the election provided by this paragraph shall apply to each tier.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41693ca2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s163/c"},"text":"Pub. L. 98–369, div. A, title I, § 163(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/698"},"text":"98 Stat. 698","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"“The amendments made by this section [amending this section and sections 6501 and 6511 of this title] shall apply to expenditures with respect to which the second taxable year described in [former] section 118(b)(2)(B) of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] ends after ","children":[{"tag":"date","attrib":{"date":"1984-12-31"},"text":"December 31, 1984","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41693ca3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/589"},"text":"Pub. L. 96–589","children":[],"tail":" applicable to transactions which occur after "},{"tag":"date","attrib":{"date":"1980-12-31"},"text":"Dec. 31, 1980","children":[],"tail":", other than transactions which occur in a proceeding in a bankruptcy case or similar judicial proceeding or in a proceeding under Title 11 commencing on or after "},{"tag":"date","attrib":{"date":"1980-12-31"},"text":"Dec. 31, 1980","children":[],"tail":", with an exception permitting the debtor to make the amendment applicable to transactions occurring after "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"Sept. 30, 1979","children":[],"tail":", in a specified manner, see section 7(a)(1), (f) of "},{"tag":"ref","attrib":{"href":"/us/pl/96/589"},"text":"Pub. L. 96–589","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s108"},"text":"section 108 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41693ca4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/tIII/s364/b"},"text":"Pub. L. 95–600, title III, § 364(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2854"},"text":"92 Stat. 2854","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/600/tIII/s364/b"},"text":"“The amendments made by this section [amending this section] shall apply to contributions made after ","children":[{"tag":"date","attrib":{"date":"1976-01-31"},"text":"January 31, 1976","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41693ca5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXXI/s2120/c"},"text":"Pub. L. 94–455, title XXI, § 2120(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1913"},"text":"90 Stat. 1913","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/455/tXXI/s2120/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s362"},"text":"section 362 of this title","children":[],"tail":"] apply to contributions made after "},{"tag":"date","attrib":{"date":"1976-01-31"},"text":"January 31, 1976","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
