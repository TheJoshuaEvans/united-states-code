99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of any decedent—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who dies before ","children":[{"tag":"date","attrib":{"date":"1984-08-13"},"text":"August 13, 1984","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who made a gift (before ","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"August 13, 1981","children":[],"tail":", and during the 3-year period ending on the date of the decedent’s death) on which tax imposed by chapter 12 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] has been paid before "},{"tag":"date","attrib":{"date":"1982-04-16"},"text":"April 16, 1982","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such decedent’s executor may make an election to have subtitle B of such Code (relating to estate and gift taxes) applied with respect to such decedent without regard to any of the amendments made by title IV of the Economic Recovery Tax Act of 1981 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV"},"text":"Pub. L. 97–34, title IV","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An election under subparagraph (A) shall be made at such time and in such manner as the Secretary of the Treasury or his delegate shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An election under subparagraph (A), once made, shall be irrevocable.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
