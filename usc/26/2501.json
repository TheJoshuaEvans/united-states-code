{"tag":"section","attrib":{"id":"id453d4fa7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501"},"text":null,"children":[{"tag":"num","attrib":{"value":"2501"},"text":"§ 2501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id453d4fa8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable transfers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id453d4fa9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A tax, computed as provided in section 2502, is hereby imposed for each calendar year on the transfer of property by gift during such calendar year by any individual resident or nonresident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453d4faa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of intangible property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3), paragraph (1) shall not apply to the transfer of intangible property by a nonresident not a citizen of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453d4fab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id453d4fac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (2) shall not apply in the case of a donor to whom section 877(b) applies for the taxable year which includes the date of the transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id453d4fad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit for foreign gift taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by this section solely by reason of this paragraph shall be credited with the amount of any gift tax actually paid to any foreign country in respect of any gift which is taxable under this section solely by reason of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453fc0ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers to political organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to the transfer of money or other property to a political organization (within the meaning of section 527(e)(1)) for the use of such organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453fc0af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of certain stock","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id453fc0b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a transfer of stock in a foreign corporation described in subparagraph (B) by a donor to whom section 877(b) applies for the taxable year which includes the date of the transfer—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id453fc0b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 2511(a) shall be applied without regard to whether such stock is situated within the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id453fc0b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of such stock for purposes of this chapter shall be its U.S.-asset value determined under subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id453fc0b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign corporation described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A foreign corporation is described in this subparagraph with respect to a donor if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id453fc0b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the donor owned (within the meaning of section 958(a)) at the time of such transfer 10 percent or more of the total combined voting power of all classes of stock entitled to vote of the foreign corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id453fc0b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such donor owned (within the meaning of section 958(a)), or is considered to have owned (by applying the ownership rules of section 958(b)), at the time of such transfer, more than 50 percent of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id453fc0b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a/5/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total combined voting power of all classes of stock entitled to vote of such corporation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id453fc0b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a/5/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total value of the stock of such corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id453fc0b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" U.S.-asset value","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the U.S.-asset value of stock shall be the amount which bears the same ratio to the fair market value of such stock at the time of transfer as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id453fc0b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value (at such time) of the assets owned by such foreign corporation and situated in the United States, bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id453fc0ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total fair market value (at such time) of all assets owned by such foreign corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453fc0bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers to certain exempt organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to the transfer of money or other property to an organization described in paragraph (4), (5), or (6) of section 501(c) and exempt from tax under section 501(a), for the use of such organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453fc0bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain residents of possessions considered citizens of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A donor who is a citizen of the United States and a resident of a possession thereof shall, for purposes of the tax imposed by this chapter, be considered a “citizen” of the United States within the meaning of that term wherever used in this title unless he acquired his United States citizenship solely by reason of (1) his being a citizen of such possession of the United States, or (2) his birth or residence within such possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453fc0bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain residents of possessions considered nonresidents not citizens of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A donor who is a citizen of the United States and a resident of a possession thereof shall, for purposes of the tax imposed by this chapter, be considered a “nonresident not a citizen of the United States” within the meaning of that term wherever used in this title, but only if such donor acquired his United States citizenship solely by reason of (1) his being a citizen of such possession of the United States, or (2) his birth or residence within such possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453fc0be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id453fc0bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For increase in basis of property acquired by gift for gift tax paid, see section 1015(d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453fc0c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2501/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For exclusion of transfers of property outside the United States by a nonresident who is not a citizen of the United States, see section 2511(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id453fc0c1-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/403"},"text":"68A Stat. 403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI"},"text":"Pub. L. 85–866, title I","children":[],"tail":", §§ 43(b), 102(b), "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1641"},"text":"72 Stat. 1641","children":[],"tail":", 1674; "},{"tag":"ref","attrib":{"href":"/us/pl/86/779/s4/d"},"text":"Pub. L. 86–779, § 4(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-14"},"text":"Sept. 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/1000"},"text":"74 Stat. 1000","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/tI/s109/a"},"text":"Pub. L. 89–809, title I, § 109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1574"},"text":"80 Stat. 1574","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/614/tI/s102/a/1"},"text":"Pub. L. 91–614, title I, § 102(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1838"},"text":"84 Stat. 1838","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/625/s14/a"},"text":"Pub. L. 93–625, § 14(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2121"},"text":"88 Stat. 2121","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1902(a)(10), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1805"},"text":"90 Stat. 1805","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV/s442/a/1"},"text":"Pub. L. 97–34, title IV, § 442(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/320"},"text":"95 Stat. 320","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tIII/s3031/a/2"},"text":"Pub. L. 100–647, title III, § 3031(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3635"},"text":"102 Stat. 3635","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11601/b/2"},"text":"Pub. L. 101–508, title XI, § 11601(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-490"},"text":"104 Stat. 1388–490","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tV/s511/e/2"},"text":"Pub. L. 104–191, title V, § 511(e)(2)","children":[],"tail":", (f)(2)(B), "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2098"},"text":"110 Stat. 2098","children":[],"tail":", 2100; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXVI/s1602/g/5"},"text":"Pub. L. 105–34, title XVI, § 1602(g)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1095"},"text":"111 Stat. 1095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s804/d"},"text":"Pub. L. 108–357, title VIII, § 804(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1571"},"text":"118 Stat. 1571","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tIV/s408/a"},"text":"Pub. L. 114–113, div. Q, title IV, § 408(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3120"},"text":"129 Stat. 3120","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id453fc0c2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id453fc0c3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id453fc0c4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":" added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" added pars. (3) and (5), redesignated former par. (5) as (4), and struck out former pars. (3) and (4) which related to exception of certain individuals from taxable transfers and burden of proof."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" substituted “donor” for “decedent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/s511/e/2"},"text":"Pub. L. 104–191, § 511(e)(2)","children":[],"tail":", substituted “Exception” for “Exceptions” in heading and amended text generally. Prior to amendment, text read as follows: “Paragraph (2) shall not apply in the case of a donor who at any time after "},{"tag":"date","attrib":{"date":"1965-03-08"},"text":"March 8, 1965","children":[],"tail":", and within the 10-year period ending with the date of transfer lost United States citizenship unless—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) such donor’s loss of United States citizenship resulted from the application of section 301(b), 350, or 355 of the Immigration and Nationality Act, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1401/b"},"text":"8 U.S.C. 1401(b)","children":[],"tail":", 1482, or 1487), or"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) such loss did not have for one of its principal purposes the avoidance of taxes under this subtitle or subtitle A.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/s511/f/2/B"},"text":"Pub. L. 104–191, § 511(f)(2)(B)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" struck out par. (3) which read as follows: “For treatment of certain transfers related to estate tax valuation freezes as gifts to which this chapter applies, see section 2036(c)(4).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a)(1), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" substituted “calendar year” for “calendar quarter” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" inserted “for each calendar quarter” after “hereby imposed” and struck out “For the first calendar quarter of calendar year 1971 and each calendar quarter thereafter” after “General rule-”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a)(5). ","children":[{