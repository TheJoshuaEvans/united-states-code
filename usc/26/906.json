{"tag":"section","attrib":{"id":"id44703bc7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s906"},"text":null,"children":[{"tag":"num","attrib":{"value":"906"},"text":"§ 906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonresident alien individuals and foreign corporations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44703bc8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A nonresident alien individual or a foreign corporation engaged in trade or business within the United States during the taxable year shall be allowed a credit under section 901 for the amount of any income, war profits, and excess profits taxes paid or accrued during the taxable year to any foreign country or possession of the United States with respect to income effectively connected with the conduct of a trade or business within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44703bc9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44703bca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s906/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of subsection (a) and for purposes of determining the deductions allowable under sections 873(a) and 882(c), in determining the amount of any tax paid or accrued to any foreign country or possession there shall not be taken into account any amount of tax to the extent the tax so paid or accrued is imposed with respect to income from sources within the United States which would not be taxed by such foreign country or possession but for the fact that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44703bcb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s906/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a nonresident alien individual, such individual is a citizen or resident of such foreign country or possession, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44703bcc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s906/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a foreign corporation, such corporation was created or organized under the law of such foreign country or possession or is domiciled for tax purposes in such country or possession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44703bcd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s906/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of subsection (a), in applying section 904 the taxpayer’s taxable income shall be treated as consisting only of the taxable income effectively connected with the taxpayer’s conduct of a trade or business within the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44703bce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s906/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The credit allowed pursuant to subsection (a) shall not be allowed against any tax imposed by section 871(a) (relating to income of nonresident alien individual not connected with United States business) or 881 (relating to income of foreign corporations not connected with United States business).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44703bcf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s906/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"[(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":", (5) Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s14301/c/23"},"text":"Pub. L. 115–97, title I, § 14301(c)(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2223"},"text":"131 Stat. 2223","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44703bd0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s906/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No credit shall be allowed under this section against the tax imposed by section 884.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44703bd1-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809/tI/s106/a/1"},"text":"Pub. L. 89–809, title I, § 106(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1568"},"text":"80 Stat. 1568","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVIII/s801/d/3"},"text":"Pub. L. 98–369, div. A, title VIII, § 801(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/996"},"text":"98 Stat. 996","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1241/c"},"text":"Pub. L. 99–514, title XII, § 1241(c)","children":[],"tail":", title XVIII, § 1876(d)(3), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2580"},"text":"100 Stat. 2580","children":[],"tail":", 2899; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/q/10"},"text":"Pub. L. 100–647, title I, § 1012(q)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3524"},"text":"102 Stat. 3524","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/172/s11/g/11"},"text":"Pub. L. 110–172, § 11(g)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-29"},"text":"Dec. 29, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2490"},"text":"121 Stat. 2490","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s14301/c/22"},"text":"Pub. L. 115–97, title I, § 14301(c)(22)","children":[],"tail":", (23), "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2223"},"text":"131 Stat. 2223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44703bd2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44703bd3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44703bd4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s14301/c/22"},"text":"Pub. L. 115–97, § 14301(c)(22)","children":[],"tail":", struck out “(or deemed, under section 902, paid or accrued during the taxable year)” after “paid or accrued during the taxable year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s14301/c/23"},"text":"Pub. L. 115–97, § 14301(c)(23)","children":[],"tail":", struck out pars. (4) and (5) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) For purposes of sections 902(a) and 78, a foreign corporation choosing the benefits of this subpart which receives dividends shall, with respect to such dividends, be treated as a domestic corporation.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) For purposes of section 902, any income, war profits, and excess profits taxes paid or accrued (or deemed paid or accrued) to any foreign country or possession of the United States with respect to income effectively connected with the conduct of a trade or business within the United States shall not be taken into account, and any accumulated profits attributable to such income shall not be taken into account.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(5) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172"},"text":"Pub. L. 110–172","children":[],"tail":" redesignated pars. (6) and (7) as (5) and (6), respectively, and struck out former par. (5) which read as follows: “No credit shall be allowed under this section for any income, war profits, and excess profits taxes paid or accrued with respect to the foreign trade income (within the meaning of section 923(b)) of a FSC.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" redesignated par. (6), relating to credit against tax imposed by section 884, as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1876/d/3"},"text":"Pub. L. 99–514, § 1876(d)(3)","children":[],"tail":", added par. (6) relating to credit for income, war profits, and excess profits taxes paid or accrued to a foreign country or possession of the United States."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1241/c"},"text":"Pub. L. 99–514, § 1241(c)","children":[],"tail":", added par. (6) relating to credit against tax imposed by section 884."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" added par. (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44703bd5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44703bd6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" applicable to taxable years of foreign corporations beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", and to taxable years of United States shareholders in which or with which such taxable years of foreign corporations end, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s14301/d"},"text":"section 14301(d) of Pub. L. 115–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s78"},"text":"section 78 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44703bd7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44703bd8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1241/c"},"text":"section 1241(c) of Pub. L. 99–514","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1241/e"},"text":"section 1241(e) of Pub. L. 99–514","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s884"},"text":"section 884 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1876/d/3"},"text":"section 1876(d)(3) of Pub. L. 99–514","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44703bd9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" applicable to transactions after "},{"tag":"date","attrib":{"date":"1984-12-31"},"text":"Dec. 31, 1984","children":[],"tail":", in taxable years ending after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s805/a/1"},"text":"section 805(a)(1) of Pub. L. 98–369","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s245"},"text":"section 245 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44703bda-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1966-12-31"},"text":"Dec. 31, 1966","children":[],"tail":", and, in applying "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s904"},"text":"section 904 of this title","children":[],"tail":" with respect to this section, no amount to be carried from or to any taxable year beginning before "},{"tag":"date","attrib":{"date":"1967-01-01"},"text":"Jan. 1, 1967","children":[],"tail":", and no such year to be taken into account, see "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/s106/a/6"},"text":"section 106(a)(6) of Pub. L. 89–809","children":[],"tail":", set out as an Effective Date of 1966 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s874"},"text":"section 874 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id44703bdb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1800–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
