{"tag":"section","attrib":{"id":"id46bfa990-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6227"},"text":null,"children":[{"tag":"num","attrib":{"value":"6227"},"text":"§ 6227.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative adjustment request by partnership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46bfa991-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6227/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A partnership may file a request for an administrative adjustment in the amount of one or more partnership-related items for any partnership taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bfa992-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6227/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any such adjustment under subsection (a) shall be determined and taken into account for the partnership taxable year in which the administrative adjustment request is filed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46bfa993-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6227/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the partnership under rules similar to the rules of section 6225 (other than paragraphs (2), (7), and (9) of subsection (c) thereof) for the partnership taxable year in which the administrative adjustment request is filed, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bfa994-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6227/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the partnership and partners under rules similar to the rules of section 6226 (determined without regard to the substitution described in subsection (c)(2)(C) thereof).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In the case of an adjustment that would not result in an imputed underpayment, paragraph (1) shall not apply and paragraph (2) shall apply with appropriate adjustments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bfa995-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6227/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A partnership may not file such a request more than 3 years after the later of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46bfa996-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6227/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the partnership return for such year is filed, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bfa997-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6227/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the last day for filing the partnership return for such year (determined without regard to extensions).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In no event may a partnership file such a request after a notice of an administrative proceeding with respect to the taxable year is mailed under section 6231.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bfa998-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6227/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with adjustments related to foreign tax credits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue regulations or other guidance which provide for the proper coordination of this section and section 905(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46bfa999-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/74/tXI/s1101/c/1"},"text":"Pub. L. 114–74, title XI, § 1101(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/631"},"text":"129 Stat. 631","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tII"},"text":"Pub. L. 115–141, div. U, title II","children":[],"tail":", §§ 201(c)(5), 206(f), (p)(2), (3), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1173"},"text":"132 Stat. 1173","children":[],"tail":", 1179, 1182.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46bfa99a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46bfa99b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","