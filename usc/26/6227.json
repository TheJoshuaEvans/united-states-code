en":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/740"},"text":"112 Stat. 740","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/172/s11/a/36"},"text":"Pub. L. 110–172, § 11(a)(36)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-29"},"text":"Dec. 29, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2487"},"text":"121 Stat. 2487","children":[],"tail":", related to additional administrative provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46bfa99d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s201/c/5"},"text":"Pub. L. 115–141, § 201(c)(5)","children":[],"tail":", substituted “partnership-related items” for “items of income, gain, loss, deduction, or credit of the partnership”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/p/2"},"text":"Pub. L. 115–141, § 206(p)(2)","children":[],"tail":", substituted “is filed” for “is made” in introductory provisions and in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/p/3"},"text":"Pub. L. 115–141, § 206(p)(3)","children":[],"tail":", which directed substitution of “paragraphs (2), (7), and (9)” for “paragraphs (2), (6), and (7)”, was executed by making the substitution for “paragraphs (2), (6) and (7)” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/f"},"text":"Pub. L. 115–141, § 206(f)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","