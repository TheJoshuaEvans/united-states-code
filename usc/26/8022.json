{"tag":"section","attrib":{"id":"id47a48bd7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8022"},"text":null,"children":[{"tag":"num","attrib":{"value":"8022"},"text":"§ 8022.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It shall be the duty of the Joint Committee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47a48bd8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8022/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47a48bd9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8022/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation and effects of law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To investigate the operation and effects of the Federal system of internal revenue taxes;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47a48bda-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8022/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To investigate the administration of such taxes by the Internal Revenue Service or any executive department, establishment, or agency charged with their administration; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47a48bdb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8022/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other investigations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To make such other investigations in respect of such system of taxes as the Joint Committee may deem necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48bdc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8022/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simplification of law","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47a48bdd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8022/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation of methods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To investigate measures and methods for the simplification of such taxes, particularly the income tax; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47a48bde-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8022/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To publish, from time to time, for public examination and analysis, proposed measures and methods for the simplification of such taxes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48bdf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8022/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47a48be0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8022/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To report, from time to time, to the Committee on Finance and the Committee on Ways and Means, and, in its discretion, to the Senate or House of Representatives, or both, the results of its investigations, together with such recommendations as it may deem advisable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47a48be1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8022/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to amounts specifically appropriated to carry out this subparagraph, to report, at least once each Congress, to the Committee on Finance and the Committee on Ways and Means on the overall state of the Federal tax system, together with recommendations with respect to possible simplification proposals and other matters relating to the administration of the Federal tax system as it may deem advisable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48be2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8022/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For duties of the Joint Committee relating to refunds of income and estate taxes, see section 6405.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47a48be3-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/927"},"text":"68A Stat. 927","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIV/s4002/a"},"text":"Pub. L. 105–206, title IV, § 4002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/784"},"text":"112 Stat. 784","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/311/tIII/s321/b"},"text":"Pub. L. 108–311, title III, § 321(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-04"},"text":"Oct. 4, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1182"},"text":"118 Stat. 1182","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/b/57"},"text":"Pub. L. 115–141, div. U, title IV, § 401(b)(57)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1205"},"text":"132 Stat. 1205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47a48be4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47a48be5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47a48be6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" struck out subpar. (C) which read as follows: “To report, for each calendar year after 1998 and before 2005, to the Committees on Finance, Appropriations, and Governmental Affairs of the Senate, and to the Committees on Ways and Means, Appropriations, and Government Reform and Oversight of the House of Representatives, with respect to the matters addressed in the joint review referred to in section 8021(f)(2).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Par. (3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311"},"text":"Pub. L. 108–311","children":[],"tail":" substituted “2005” for “2004” and “with respect to the matters addressed in the joint review referred to in section 8021(f)(2).” for “with respect to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) strategic and business plans for the Internal Revenue Service;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) progress of the Internal Revenue Service in meeting its objectives;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) the budget for the Internal Revenue Service and whether it supports its objectives;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iv) progress of the Internal Revenue Service in improving taxpayer service and compliance;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(v) progress of the Internal Revenue Service on technology modernization; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(vi) the annual filing season.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “To report, from time to time, to the Committee on Finance and the Committee on Ways and Means, and, in its discretion, to the Senate or the House of Representatives, or both, the results of its investigations, together with such recommendation as it may deem advisable.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47a48be7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47a48be8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIV/s4002/b"},"text":"Pub. L. 105–206, title IV, § 4002(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/784"},"text":"112 Stat. 784","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/206/tIV/s4002/b"},"text":"“The amendment made by this section [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id47a48be9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that nothing in amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" be construed to affect treatment of certain transactions occurring, property acquired, or items of income, loss, deduction, or credit taken into account prior to "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", for purposes of determining liability for tax for periods ending after "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/e"},"text":"section 401(e) of Pub. L. 115–141","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s23"},"text":"section 23 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id47a48bea-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Analysis To Accompany Certain Legislation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIV/s4022/b"},"text":"Pub. L. 105–206, title IV, § 4022(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/785"},"text":"112 Stat. 785","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/206/tIV/s4022/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Joint Committee on Taxation, in consultation with the Internal Revenue Service and the Department of the Treasury, shall include a tax complexity analysis in each report for legislation, or provide such analysis to members of the committee reporting the legislation as soon as practicable after the report is filed, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such legislation is reported by the Committee on Finance in the Senate, the Committee on Ways and Means of the House of Representatives, or any committee of conference; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such legislation includes a provision which would directly or indirectly amend the Internal Revenue Code of 1986 and which has widespread applicability to individuals or small businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tax complexity analysis","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term ‘tax complexity analysis’ means, with respect to any legislation, a report on the complexity and administrative difficulties of each provision described in paragraph (1)(B) which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the number of taxpayers affected by the provision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, the income level of taxpayers affected by the provision; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" should include (if determinable)—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which tax forms supplied by the Internal Revenue Service would require revision and whether any new forms would be required;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which taxpayers would be required to keep additional records;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated cost to taxpayers to comply with the provision;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"“(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which enactment of the provision would require the Internal Revenue Service to develop or modify regulatory guidance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"“(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the provision may result in disagreements between taxpayers and the Internal Revenue Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"“(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any expected impact on the Internal Revenue Service from the provision (including the impact on internal training, revision of the Internal Revenue Manual, reprogramming of computers, and the extent to which the Internal Revenue Service would be required to divert or redirect resources in response to the provision).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Legislation subject to point of order in house of representatives","children":[],"tail":".—"}],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id47a48beb-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"[Amended the Rules of the House of Representatives, which are not classified to the Code.]","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection shall apply to legislation considered on and after ","children":[{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id47a48bec-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Tax Revision Study","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tV/s507"},"text":"Pub. L. 94–455, title V, § 507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1569"},"text":"90 Stat. 1569","children":[],"tail":", mandated a full and complete study by the Joint Committee on Taxation with respect to simplifying the tax laws and the feasibility of a reduction of tax rates; a report of such study with recommendations was to be submitted to the committees of Congress before "},{"tag":"date","attrib":{"date":"1977-07-01"},"text":"July 1, 1977","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id47a6d5dd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Expanded Participation in Individual Retirement Accounts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXV/s1509"},"text":"Pub. L. 94–455, title XV, § 1509","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1741"},"text":"90 Stat. 1741","children":[],"tail":", directed Joint Committee on Taxation to carry out study with respect to broadening class of individuals eligible to claim deduction for retirement savings under section 219 or 220 of this title, and to report its findings to Committee on Ways and Means of the House of Representatives and to Committee on Finance of the Senate."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id47a6d5de-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Tax Incentives Study","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXXI/s2133"},"text":"Pub. L. 94–455, title XXI, § 2133","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1925"},"text":"90 Stat. 1925","children":[],"tail":", mandated a study by the Joint Committee on Taxation, in consultation with the Treasury, of the cost effectiveness of different kinds of tax incentives, including an analysis of the most effective way to use tax cuts to provide economic stimulus; such report with its recommendations was to be submitted to the Committees of Congress no later than "},{"tag":"date","attrib":{"date":"1977-09-30"},"text":"Sept. 30, 1977","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
