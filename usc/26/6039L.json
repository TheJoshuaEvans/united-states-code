{"tag":"section","attrib":{"id":"id466e7c6a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039L"},"text":null,"children":[{"tag":"num","attrib":{"value":"6039L"},"text":"§ 6039L.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information required from qualified opportunity zone businesses and qualified rural opportunity zone businesses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id466e7c6b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039L/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every applicable qualified opportunity zone business shall furnish to the qualified opportunity fund described in subsection (b) a written statement at such time, in such manner, and setting forth such information as the Secretary may by regulations prescribe for purposes of enabling such qualified opportunity fund to meet the requirements of section 6039K(b)(5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id466e7c6c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039L/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable qualified opportunity zone business","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the term “applicable qualified opportunity zone business” means any qualified opportunity zone business—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id466e7c6d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039L/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is a trade or business of a qualified opportunity fund,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id466e7c6e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039L/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which a qualified opportunity fund holds qualified opportunity zone stock, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id466e7c6f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039L/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which a qualified opportunity fund holds a qualified opportunity zone partnership interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id466e7c70-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039L/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any term used in this section which is also used in subchapter Z of chapter 1 shall have the meaning given such term under such subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id466e7c71-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039L/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to qualified rural opportunity businesses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every applicable qualified rural opportunity zone business (as defined in subsection (b) determined after application of the substitutions described in this sentence) shall furnish the written statement required under subsection (a), applied—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id466e7c72-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039L/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “qualified rural opportunity” for “qualified opportunity” each place it appears, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id466e7c73-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039L/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by treating any reference (after the application of paragraph (1)) to qualified rural opportunity zone stock, a qualified rural opportunity zone partnership interest, or a qualified rural opportunity zone business as stock, an interest, or a business, respectively, described in subclause (I) or (II), as the case may be, of section 1400Z–2(b)(2)(C)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id466e7c74-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70421/d/1"},"text":"Pub. L. 119–21, title VII, § 70421(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/229"},"text":"139 Stat. 229","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id466e7c75-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id466e7c76-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id466e7c77-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70421/d/5"},"text":"section 70421(d)(5) of Pub. L. 119–21","children":[],"tail":", set out as an Effective Date of 2025 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6011"},"text":"section 6011 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
