{"tag":"section","attrib":{"id":"id43f69ef4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s676"},"text":null,"children":[{"tag":"num","attrib":{"value":"676"},"text":"§ 676.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power to revoke","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43f69ef5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s676/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The grantor shall be treated as the owner of any portion of a trust, whether or not he is treated as such owner under any other provision of this part, where at any time the power to revest in the grantor title to such portion is exercisable by the grantor or a non-adverse party, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f69ef6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s676/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power affecting beneficial enjoyment only after occurrence of event","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to a power the exercise of which can only affect the beneficial enjoyment of the income for a period commencing after the occurrence of an event such that a grantor would not be treated as the owner under section 673 if the power were a reversionary interest. But the grantor may be treated as the owner after the occurrence of such event unless the power is relinquished.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43f69ef7-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/230"},"text":"68A Stat. 230","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIV/s1402/b/2"},"text":"Pub. L. 99–514, title XIV, § 1402(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2712"},"text":"100 Stat. 2712","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43f69ef8-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43f69ef9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43f69efa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “occurrence of event” for “expiration of 10-year period” in heading and in text substituted “the occurrence of an event” for “the expiration of a period” and “the occurrence of such event” for “the expiration of such period”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43f69efb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43f69efc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" applicable with respect to transfers in trust made after "},{"tag":"date","attrib":{"date":"1986-03-01"},"text":"Mar. 1, 1986","children":[],"tail":", except for transfers pursuant to a certain binding property settlement agreement, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1402/c"},"text":"section 1402(c) of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s673"},"text":"section 673 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
