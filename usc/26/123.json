{"tag":"section","attrib":{"id":"id416df860-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s123"},"text":null,"children":[{"tag":"num","attrib":{"value":"123"},"text":"§ 123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts received under insurance contracts for certain living expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id416df861-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual whose principal residence is damaged or destroyed by fire, storm, or other casualty, or who is denied access to his principal residence by governmental authorities because of the occurrence or threat of occurrence of such a casualty, gross income does not include amounts received by such individual under an insurance contract which are paid to compensate or reimburse such individual for living expenses incurred for himself and members of his household resulting from the loss of use or occupancy of such residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id416df862-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall apply to amounts received by the taxpayer for living expenses incurred during any period only to the extent the amounts received do not exceed the amount by which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id416df863-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s123/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual living expenses incurred during such period for himself and members of his household resulting from the loss of use or occupancy of their residence, exceed","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id416df864-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s123/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the normal living expenses which would have been incurred for himself and members of his household during such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id416df865-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIX/s901/a"},"text":"Pub. L. 91–172, title IX, § 901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/709"},"text":"83 Stat. 709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id416df866-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id416df867-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id416df868-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 123 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s140"},"text":"section 140 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id416df869-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id416df86a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIX/s901/c"},"text":"Pub. L. 91–172, title IX, § 901(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/709"},"text":"83 Stat. 709","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/172/tIX/s901/c"},"text":"“The amendments made by this section [enacting this section] shall apply with respect to amounts received on or after ","children":[{"tag":"date","attrib":{"date":"1969-01-01"},"text":"January 1, 1969","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
