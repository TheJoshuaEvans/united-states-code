{"tag":"section","attrib":{"id":"id46223116-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5053"},"text":null,"children":[{"tag":"num","attrib":{"value":"5053"},"text":"§ 5053.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46223117-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5053/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removals for export","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beer may be removed from the brewery, without payment of tax, for export, in such containers and under such regulations, and on the giving of such notices, entries, and bonds and other security, as the Secretary may by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46223118-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5053/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removals when unfit for beverage use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When beer has become sour or damaged, so as to be incapable of use as such, a brewer may remove the same from his brewery without payment of tax, for manufacturing purposes, under such regulations as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46223119-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5053/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removals for laboratory analysis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beer may be removed from the brewery, without payment of tax, for laboratory analysis, subject to such limitations and under such regulations as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4622311a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5053/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removals for research, development, or testing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under such conditions and regulations as the Secretary may prescribe, beer may be removed from the brewery without payment of tax for use in research, development, or testing (other than consumer testing or other market analysis) of processes, systems, materials, or equipment relating to beer or brewery operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4622311b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5053/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beer for personal or family use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to regulation prescribed by the Secretary, any adult may, without payment of tax, produce beer for personal or family use and not for sale. The aggregate amount of beer exempt from tax under this subsection with respect to any household shall not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4622311c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5053/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 200 gallons per calendar year if there are 2 or more adults in such household, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4622311d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5053/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 gallons per calendar year if there is only 1 adult in such household.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of this subsection, the term “adult” means an individual who has attained 18 years of age, or the minimum age (if any) established by law applicable in the locality in which the household is situated at which beer may be sold to individuals, whichever is greater.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4622311e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5053/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal for use as distilling material","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to such regulations as the Secretary may prescribe, beer may be removed from a brewery without payment of tax to any distilled spirits plant for use as distilling material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4622311f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5053/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removals for use of foreign embassies, legations, etc.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46223120-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5053/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to such regulations as the Secretary may prescribe—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46223121-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5053/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beer may be withdrawn from the brewery without payment of tax for transfer to any customs bonded warehouse for entry pending withdrawal therefrom as provided in subparagraph (B), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46223122-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5053/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beer entered into any customs bonded warehouse under subparagraph (A) may be withdrawn for consumption in the United States by, and for the official and family use of, such foreign governments, organizations, and individuals as are entitled to withdraw imported beer from such warehouses free of tax.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Beer transferred to any customs bonded warehouse under subparagraph (A) shall be entered, stored, and accounted for in such warehouse under such regulations and bonds as the Secretary may prescribe, and may be withdrawn therefrom by such governments, organizations, and individuals free of tax under the same conditions and procedures as imported beer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46223123-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5053/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other rules to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of paragraphs (2) and (3) of section 5362(e) shall apply for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46223124-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5053/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removals for destruction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to such regulations as the Secretary may prescribe, beer may be removed from the brewery without payment of tax for destruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46223125-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5053/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal as supplies for certain vessels and aircraft","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For exemption as to supplies for certain vessels and aircraft, see section 309 of the Tariff Act of 1930, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1309"},"text":"19 U.S.C. 1309","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46223126-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1334"},"text":"72 Stat. 1334","children":[],"tail":"; amended "},{"tag":"ref",