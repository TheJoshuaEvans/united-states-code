l":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46223129-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5053, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/612"},"text":"68A Stat. 612","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4622312a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1414/b"},"text":"Pub. L. 105–34, § 1414(b)","children":[],"tail":", added subsec. (f). Former subsec. (f) redesignated (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1418/a"},"text":"Pub. L. 105–34, § 1418(a)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1419/a"},"text":"Pub. L. 105–34, § 1419(a)","children":[],"tail":", added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1414/b"},"text":"Pub. L. 105–34, § 1414(b)","children":[],"tail":", redesignated subsec. (f) as (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/458"},"text":"Pub. L. 95–458","children":[],"tail":" added subsec. (e) and redesignated former subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/673"},"text":"Pub. L. 91–673","children":[],"tail":" added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" struck out “to a foreign country” after “export”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4622312b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4622312c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIV/s1414/d"},"text":"Pub. L. 105–34, title XIV, § 1414(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1047"},"text":"111 Stat. 1047","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tXIV/s1414/d"},"text":"“The amendments made by this section [amending this section and sections 5056 and 5222 of this title] shall take effect on the 1st day of the 1st calendar quarter that begins at least 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIV/s1418/b"},"text":"Pub. L. 105–34, title XIV, § 1418(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1049"},"text":"111 Stat. 1049","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tXIV/s1418/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on the 1st day of the 1st calendar quarter that begins at least 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIV/s1419/b"},"text":"Pub. L. 105–34, title XIV, § 1419(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1049"},"text":"111 Stat. 1049","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tXIV/s1419/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on the 1st day of the 1st calendar quarter that begins at least 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4622312d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"E