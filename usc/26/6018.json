{"tag":"section","attrib":{"id":"id465dda4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6018"},"text":null,"children":[{"tag":"num","attrib":{"value":"6018"},"text":"§ 6018.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estate tax returns","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id465dda50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6018/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns by executor","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id465dda51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6018/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citizens or residents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In all cases where the gross estate at the death of a citizen or resident exceeds the basic exclusion amount in effect under section 2010(c) for the calendar year which includes the date of death, the executor shall make a return with respect to the estate tax imposed by subtitle B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id465dda52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6018/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonresidents not citizens of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of the estate of every nonresident not a citizen of the United States if that part of the gross estate which is situated in the United States exceeds $60,000, the executor shall make a return with respect to the estate tax imposed by subtitle B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id465dda53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6018/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment for certain gifts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount applicable under paragraph (1) and the amount set forth in paragraph (2) shall each be reduced (but not below zero) by the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id465dda54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6018/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the adjusted taxable gifts (within the meaning of section 2001(b)) made by the decedent after ","children":[{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":", plus"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id465dda55-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6018/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount allowed as a specific exemption under section 2521 (as in effect before its repeal by the Tax Reform Act of 1976) with respect to gifts made by the decedent after ","children":[{"tag":"date","attrib":{"date":"1976-09-08"},"text":"September 8, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id465dda56-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6018/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns by beneficiaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the executor is unable to make a complete return as to any part of the gross estate of the decedent, he shall include in his return a description of such part and the name of every person holding a legal or beneficial interest therein. Upon notice from the Secretary such person shall in like manner make a return as to such part of the gross estate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id465dda57-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/739"},"text":"68A Stat. 739","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/tI/s108/g"},"text":"Pub. L. 89–809, title I, § 108(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1574"},"text":"80 Stat. 1574","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", title XX, § 2001(c)(1)(J), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":", 1852; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV/s401/a/2/B"},"text":"Pub. L. 97–34, title IV, § 401(a)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/299"},"text":"95 Stat. 299","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tV/s544/b/3"},"text":"Pub. L. 98–369, div. A, title V, § 544(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/894"},"text":"98 Stat. 894","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1011A/g/12"},"text":"Pub. L. 100–647, title I, § 1011A(g)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3482"},"text":"102 Stat. 3482","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7304/b/2/B"},"text":"Pub. L. 101–239, title VII, § 7304(b)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2353"},"text":"103 Stat. 2353","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11801/a/43"},"text":"Pub. L. 101–508, title XI, § 11801(a)(43)","children":[],"tail":", (c)(19)(C), "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-521"},"text":"104 Stat. 1388–521","children":[],"tail":", 1388–528; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tV/s501/a/1/C"},"text":"Pub. L. 105–34, title V, § 501(a)(1)(C)","children":[],"tail":", title X, § 1073(b)(4), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/845"},"text":"111 Stat. 845","children":[],"tail":", 948; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tV/s542/b/1"},"text":"Pub. L. 107–16, title V, § 542(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/81"},"text":"115 Stat. 81","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/312/tIII"},"text":"Pub. L. 111–312, title III","children":[],"tail":", §§ 301(a), 303(b)(3), "},{"tag":"date","attrib":{"date":"2010-12-17"},"text":"Dec. 17, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3300"},"text":"124 Stat. 3300","children":[],"tail":", 3303.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id465dda58-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id465dda59-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id465dda5a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s2521"},"text":"Section 2521 of this title","children":[],"tail":", referred to in subsec. (a)(3)(B), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s2001/b/3"},"text":"section 2001(b)(3) of Pub. L. 94–455","children":[],"tail":", applicable to gifts made after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"Dec. 31, 1976","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Tax Reform Act of 1976, referred to in subsec. (a)(3)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1520"},"text":"90 Stat. 1520","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1976 Amendments note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id465dda5b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312/s301/a"},"text":"Pub. L. 111–312, § 301(a)","children":[],"tail":", amended section to read as if amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/s542/b/1"},"text":"Pub. L. 107–16, § 542(b)(1)","children":[],"tail":", had never been enacted. See 2001 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312/s303/b/3"},"text":"Pub. L. 111–312, § 303(b)(3)","children":[],"tail":", substituted “basic exclusion amount” for “applicable exclusion amount”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s542/b/1"},"text":"Pub. L. 107–16, § 542(b)(1)","children":[],"tail":", amended section generally, substituting provisions related to tax returns for certain large transfers at death for provisions related to estate tax returns."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s501/a/1/C"},"text":"Pub. L. 105–34, § 501(a)(1)(C)","children":[],"tail":", substituted “the applicable exclusion amount in effect under section 2010(c) for the calendar year which includes the date of death” for “$600,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1073/b/4"},"text":"Pub. L. 105–34, § 1073(b)(4)","children":[],"tail":", struck out par. (4) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) ","children":[{"tag":"inline","attrib":{},"text":"Return required if excess retirement accumulation tax","children":[],"tail":".—The executor shall make a return with respect to the estate tax imposed by subtitle B in any case where such tax is increased by reason of section 4980A(d).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" redesignated pars. (4) and (5) as (3) and (4), respectively, and struck out former par. (3) which provided for phase-in of estate tax return filing requirement amount."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" struck out subsec. (c) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"inline","attrib":{},"text":"Election Under Section","children":[],"tail":" 2210.—In all cases in which subsection (a) requires the filing of a return, if an executor elects the applications of section 2210—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Return by executor","children":[],"tail":".—The return which the executor is required to file under the provisions of subsection (a) shall be made with respect to that portion of estate tax imposed by subtitle B which the executor is required to pay."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Return by plan administrator","children":[],"tail":".—The plan administrator of an employee stock ownership plan or the eligible worker-owned cooperative, as the case may be, shall make a return with respect to that portion of the tax imposed by section 2001 which such plan or cooperative is required to pay under section 2210(b).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s401/a/2/B/i"},"text":"Pub. L. 97–34, § 401(a)(2)(B)(i)","children":[],"tail":", substituted “$600,000” for “$175,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s401/a/2/B/ii"},"text":"Pub. L. 97–34, § 401(a)(2)(B)(ii)","children":[],"tail":", set forth par. (1) substitutions for “$600,000” amount of “$225,000”, “$275,000”, “$325,000”, “$400,000”, and “$500,000” in the case of decedents dying in 1982, 1983, 1984, 1985, and 1986, respectively, and struck out par. (1) substitutions for “$175,000” amount of “$120,000”, “$134,000”, “$147,000”, and “$161,000” in the case of decedents dying during 1977, 1978, 1979, and 1980, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s2001/c/1/J/i"},"text":"Pub. L. 94–455, § 2001(c)(1)(J)(i)","children":[],"tail":", substituted “$175,000” for “$60,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s2001/c/1/J/ii"},"text":"Pub. L. 94–455, § 2001(c)(1)(J)(ii)","children":[],"tail":", substituted “$60,000” for “$30,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s2001/c/1/J/iii"},"text":"Pub. L. 94–455, § 2001(c)(1)(J)(iii)","children":[],"tail":", added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809"},"text":"Pub. L. 89–809","children":[],"tail":" substituted “$30,000” for “$2,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id465dda5c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id465dda5d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312/s301/a"},"text":"section 301(a) of Pub. L. 111–312","children":[],"tail":" applicable to estates of decedents dying, and transfers made after "},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"Dec. 31, 2009","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/312/s301/e"},"text":"section 301(e) of Pub. L. 111–312","children":[],"tail":", set out as an Effective and Termination Dates of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s121"},"text":"section 121 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312/s303/b/3"},"text":"section 303(b)(3) of Pub. L. 111–312","children":[],"tail":" applicable to estates of decedents dying and gifts made after "},{"tag":"date","attrib":{"date":"2010-12-31"},"text":"Dec. 31, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/312/s303/c/1"},"text":"section 303(c)(1) of Pub. L. 111–312","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s