{"tag":"section","attrib":{"id":"id41648201-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s111"},"text":null,"children":[{"tag":"num","attrib":{"value":"111"},"text":"§ 111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of tax benefit items","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id41648202-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross income does not include income attributable to the recovery during the taxable year of any amount deducted in any prior taxable year to the extent such amount did not reduce the amount of tax imposed by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41648203-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41648204-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41648205-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s111/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a credit was allowable with respect to any amount for any prior taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41648206-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s111/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the taxable year there is a downward price adjustment or similar adjustment,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the tax imposed by this chapter for the taxable year shall be increased by the amount of the credit attributable to the adjustment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41648207-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception where credit did not reduce tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to the extent that the credit allowable for the recovered amount did not reduce the amount of tax imposed by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41648208-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s111/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for investment tax credit and foreign tax credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not apply with respect to the credit determined under section 46 and the foreign tax credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41648209-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of carryovers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, an increase in a carryover which has not expired before the beginning of the taxable year in which the recovery or adjustment takes place shall be treated as reducing tax imposed by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4164820a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s111/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for accumulated earnings tax and for personal holding company tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In applying subsection (a) for the purpose of determining the accumulated earnings tax under section 531 or the tax under section 541 (relating to personal holding companies)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4164820b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s111/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any excluded amount under subsection (a) allowed for the purposes of this subtitle (other than section 531 or section 541) shall be allowed whether or not such amount resulted in a reduction of the tax under section 531 or the tax under section 541 for the prior taxable year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4164820c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s111/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where any excluded amount under subsection (a) was not allowable as a deduction for the prior taxable year for purposes of this subtitle other than of section 531 or section 541 but was allowable for the same taxable year under section 531 or section 541, then such excluded amount shall be allowable if it did not result in a reduction of the tax under section 531 or the tax under section 541.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4164820d-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/33"},"text":"68A Stat. 33","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/589/s2/c"},"text":"Pub. L. 96–589, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3396"},"text":"94 Stat. 3396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s171/a"},"text":"Pub. L. 98–369, div. A, title I, § 171(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/698"},"text":"98 Stat. 698","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1812/a/1"},"text":"Pub. L. 99–514, title XVIII, § 1812(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2833"},"text":"100 Stat. 2833","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4164820e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4164820f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id41648210-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1812/a/1"},"text":"Pub. L. 99–514, § 1812(a)(1)","children":[],"tail":", substituted “did not reduce the amount of tax imposed by this chapter” for “did not reduce income subject to tax”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1812/a/2"},"text":"Pub. L. 99–514, § 1812(a)(2)","children":[],"tail":", substituted “reducing tax imposed by this chapter” for “reducing income subject to tax or reducing tax imposed by this chapter, as the case may be”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" amended section generally, substituting provisions relating to recovery of tax benefit items for provisions relating to recovery of bad debts, prior taxes, and delinquency amounts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/589"},"text":"Pub. L. 96–589","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id41648211-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41648212-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41648213-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s171/c"},"text":"Pub. L. 98–369, div. A, title I, § 171(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/699"},"text":"98 Stat. 699","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tI/s171/c"},"text":"“The amendments made by this section [amending this section] shall apply to amounts recovered after ","children":[{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":", in taxable years ending after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41648214-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/589"},"text":"Pub. L. 96–589","children":[],"tail":" applicable to transactions which occur after "},{"tag":"date","attrib":{"date":"1980-12-31"},"text":"Dec. 31, 1980","children":[],"tail":", other than transactions which occur in a proceeding in a bankruptcy case or similar judicial proceeding or in a proceeding under Title 11 commencing on or after "},{"tag":"date","attrib":{"date":"1980-12-31"},"text":"Dec. 31, 1980","children":[],"tail":", with an exception permitting the debtor to make the amendment applicable to transactions occurring after "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"Sept. 30, 1979","children":[],"tail":", in a specified manner, see section 7(a)(1), (f) of "},{"tag":"ref","attrib":{"href":"/us/pl/96/589"},"text":"Pub. L. 96–589","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s108"},"text":"section 108 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id41648215-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1800–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
