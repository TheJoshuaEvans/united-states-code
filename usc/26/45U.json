{"tag":"section","attrib":{"id":"id40dc8d5c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U"},"text":null,"children":[{"tag":"num","attrib":{"value":"45U"},"text":"§ 45U.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Zero-emission nuclear power production credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40dc8d5d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of credit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of section 38, the zero-emission nuclear power production credit for any taxable year is an amount equal to the amount by which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40dc8d5e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40dc8d5f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.3 cents, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40dc8d60-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the kilowatt hours of electricity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40dc8d61-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produced by the taxpayer at a qualified nuclear power facility, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40dc8d62-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sold by the taxpayer to an unrelated person during the taxable year, exceeds","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d63-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduction amount for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40dc8d64-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40dc8d65-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified nuclear power facility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified nuclear power facility” means any nuclear facility—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40dc8d66-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is owned by the taxpayer and which uses nuclear energy to produce electricity,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40dc8d67-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is not an advanced nuclear power facility as defined in subsection (d)(1) of section 45J, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40dc8d68-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is placed in service before the date of the enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d69-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40dc8d6a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “reduction amount” means, with respect to any qualified nuclear power facility for any taxable year, the amount equal to the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40dc8d6b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under subsection (a)(1), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40dc8d6c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the amount equal to 16 percent of the excess of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id40dc8d6d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/b/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subparagraph (B), the gross receipts from any electricity produced by such facility (including any electricity services or products provided in conjunction with the electricity produced by such facility) and sold to an unrelated person during such taxable year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id40dc8d6e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/b/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the amount equal to the product of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id40dc8d6f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/b/2/A/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2.5 cents, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id40dc8d70-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/b/2/A/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under subsection (a)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40dc8d71-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain receipts","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40dc8d72-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to clause (iii), the amount determined under subparagraph (A)(ii)(I) shall include any amount received by the taxpayer during the taxable year with respect to the qualified nuclear power facility from a zero-emission credit program. For purposes of determining the amount received during such taxable year, the taxpayer shall take into account any reductions required under such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40dc8d73-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Zero-emission credit program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subparagraph, the term “zero-emission credit program” means any payments with respect to a qualified nuclear power facility as a result of any Federal, State or local government program for, in whole or in part, the zero-emission, zero-carbon, or air quality attributes of any portion of the electricity produced by such facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40dc8d74-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of clause (i), any amount received by the taxpayer from a zero-emission credit program shall be excluded from the amount determined under subparagraph (A)(ii)(I) if the full amount of the credit calculated pursuant to subsection (a) (determined without regard to this subparagraph) is used to reduce payments from such zero-emission credit program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electricity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “electricity” means the energy produced by a qualified nuclear power facility from the conversion of nuclear fuel into electric power.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40dc8d76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40dc8d77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The 0.3 cent amount in subsection (a)(1)(A) and the 2.5 cent amount in subsection (b)(2)(A)(ii)(II)(aa) shall each be adjusted by multiplying such amount by the inflation adjustment factor (as determined under section 45(e)(2), as applied by substituting “calendar year 2023” for “calendar year 1992” in subparagraph (B) thereof) for the calendar year in which the sale occurs. If the 0.3 cent amount as increased under this paragraph is not a multiple of 0.05 cent, such amount shall be rounded to the nearest multiple of 0.05 cent. If the 2.5 cent amount as increased under this paragraph is not a multiple of 0.1 cent, such amount shall be rounded to the nearest multiple of 0.1 cent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of paragraphs (1), (3), (4), (5), and (13) of section 45(e) shall apply for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions relating to prohibited foreign entities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40dc8d7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No credit shall be determined under subsection (a) for any taxable year beginning after the date of enactment of this paragraph if the taxpayer is a specified foreign entity (as defined in section 7701(a)(51)(B)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40dc8d7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other prohibited foreign entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No credit shall be determined under subsection (a) for any taxable year beginning after the date which is 2 years after the date of enactment of this paragraph if the taxpayer is a foreign-influenced entity (as defined in section 7701(a)(51)(D), without regard to clause (i)(II) thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40dc8d7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wage requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40dc8d7d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increased credit amount for qualified nuclear power facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any qualified nuclear power facility which satisfies the requirements of paragraph (2)(A), the amount of the credit determined under subsection (a) shall be equal to such amount (as determined without regard to this sentence) multiplied by 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d7e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevailing wage requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40dc8d7f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements described in this subparagraph with respect to any qualified nuclear power facility are that the taxpayer shall ensure that any laborers and mechanics employed by the taxpayer or any contractor or subcontractor in the alteration or repair of such facility shall be paid wages at rates not less than the prevailing rates for alteration or repair of a similar character in the locality in which such facility is located as most recently determined by the Secretary of Labor, in accordance with subchapter IV of chapter 31 of title 40, United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40defe80-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction and penalty related to failure to satisfy wage requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of section 45(b)(7)(B) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defe81-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue such regulations or other guidance as the Secretary determines necessary to carry out the purposes of this subsection, including regulations or other guidance which provides for requirements for recordkeeping or information reporting for purposes of administering the requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40defe82-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45U/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2032-12-31"},"text":"December 31, 2032","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id40defe83-3a70-11f1-a967-d35dac11796a"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI"},"text":"Pub. L. 117–169, title I","children":[],"tail":", §§ 13105(a), 13204(b)(2), "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1929"},"text":"136 Stat. 1929","children":[],"tail":", 1940; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70510/a"},"text":"Pub. L. 119–21, title VII, § 70510(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/252"},"text":"139 Stat. 252","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id40defe84-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id40defe85-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id40defe86-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (b)(1)(C), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this paragraph, referred to in subsec. (c)(3), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id40defe87-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/11