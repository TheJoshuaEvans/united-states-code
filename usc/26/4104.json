{"tag":"section","attrib":{"id":"id45bba7cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4104"},"text":null,"children":[{"tag":"num","attrib":{"value":"4104"},"text":"§ 4104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information reporting for persons claiming certain tax benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45bba7cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require any person claiming tax benefits—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45bba7cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the provisions of sections 34, 40, and 40A, to file a return at the time such person claims such benefits (in such manner as the Secretary may prescribe), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45bba7ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the provisions of section 4041(b)(2), 6426, or 6427(e) to file a quarterly return (in such manner as the Secretary may prescribe).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45bba7cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any return filed under this section shall provide such information relating to such benefits and the coordination of such benefits as the Secretary may require to ensure the proper administration and use of such benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45bba7d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any person described in subsection (a) and subject to registration requirements under this title, rules similar to rules of section 4222(c) shall apply with respect to any requirement under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45bba7d1-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIII/s303/a"},"text":"Pub. L. 108–357, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1466"},"text":"118 Stat. 1466","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/220"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(220)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1194"},"text":"132 Stat. 1194","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45bba7d2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45bba7d3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45bba7d4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “sections 34” for “section 34”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45bba7d5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45bba7d6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIII/s303/c"},"text":"Pub. L. 108–357, title III, § 303(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1466"},"text":"118 Stat. 1466","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tIII/s303/c"},"text":"“The amendments made by this section [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2005-01-01"},"text":"January 1, 2005","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
