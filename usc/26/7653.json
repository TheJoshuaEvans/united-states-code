{"tag":"section","attrib":{"id":"id4780b02c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7653"},"text":null,"children":[{"tag":"num","attrib":{"value":"7653"},"text":"§ 7653.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shipments from the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4780b02d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7653/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax imposed","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4780b02e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7653/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Puerto Rico","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All articles of merchandise of United States manufacture coming into Puerto Rico shall be entered at the port of entry upon payment of a tax equal in rate and amount to the internal revenue tax imposed in Puerto Rico upon the like articles of Puerto Rican manufacture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4780b02f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7653/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Virgin Islands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be imposed in the Virgin Islands upon articles imported from the United States a tax equal to the internal revenue tax imposed in such islands upon like articles there manufactured.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4780b030-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7653/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from tax imposed in the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Articles, goods, wares, or merchandise going into Puerto Rico, the Virgin Islands, Guam, and American Samoa from the United States shall be exempted from the payment of any tax imposed by the internal revenue laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4780b031-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7653/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drawback of tax paid in the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All provisions of law for the allowance of drawback of internal revenue tax on articles exported from the United States are, so far as applicable, extended to like articles upon which an internal revenue tax has been paid when shipped from the United States to Puerto Rico, the Virgin Islands, Guam, or American Samoa.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4780b032-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7653/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the disposition of the proceeds of all taxes collected under the internal revenue laws of the United States on articles produced in Guam and transported into the United States or its possessions, or consumed in Guam, see the Act of ","children":[{"tag":"date","attrib":{"date":"1950-08-01"},"text":"August 1, 1950","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1421h"},"text":"48 U.S.C. 1421h","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4780b033-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":" "},{"tag":"ref","attrib":{"href":"/us/stat/68A/908"},"text":"68A Stat. 908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/70/s22/f"},"text":"Pub. L. 86–70, § 22(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-06-25"},"text":"June 25, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/146"},"text":"73 Stat. 146","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/624/s18/h"},"text":"Pub. L. 86–624, § 18(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/416"},"text":"74 Stat. 416","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/a/56"},"text":"Pub. L. 94–455, title XIX, § 1906(a)(56)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1832"},"text":"90 Stat. 1832","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4780b034-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4780b035-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","at