{"tag":"section","attrib":{"id":"id472d389d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6688"},"text":null,"children":[{"tag":"num","attrib":{"value":"6688"},"text":"§ 6688.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessable penalties with respect to information required to be furnished under section 7654","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to any criminal penalty provided by law, any person described in section 7654(a) who is required under section 937(c) or by regulations prescribed under section 7654 to furnish information and who fails to comply with such requirement at the time prescribed by such regulations unless it is shown that such failure is due to reasonable cause and not to willful neglect, shall pay (upon notice and demand by the Secretary and in the same manner as tax) a penalty of $1,000 for each such failure.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id472d389e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/606/s1/c"},"text":"Pub. L. 92–606, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-31"},"text":"Oct. 31, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1496"},"text":"86 Stat. 1496","children":[],"tail":", § 6687; renumbered § 6688, "},{"tag":"ref","attrib":{"href":"/us/pl/93/406/tII/s1016/b/4"},"text":"Pub. L. 93–406, title II, § 1016(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/932"},"text":"88 Stat. 932","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s908/b"},"text":"Pub. L. 108–357, title VIII, § 908(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1656"},"text":"118 Stat. 1656","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id472d389f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id472d38a0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id472d38a1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" inserted “under section 937(c) or” before “by regulations” and substituted “$1,000” for “$100”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id472d38a2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id472d38a3-3a70-11f1-a967-d35dac11796a"},"text":null,"childr