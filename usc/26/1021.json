{"tag":"section","attrib":{"id":"id44a4b8de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1021"},"text":null,"children":[{"tag":"num","attrib":{"value":"1021"},"text":"§ 1021.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of annuities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In case of the sale of an annuity contract, the adjusted basis shall in no case be less than zero.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id44a4b8df-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/302"},"text":"68A Stat. 302","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
