{"tag":"section","attrib":{"id":"id44ddf16f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281"},"text":null,"children":[{"tag":"num","attrib":{"value":"1281"},"text":"§ 1281.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current inclusion in income of discount on certain short-term obligations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44ddf170-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any short-term obligation to which this section applies, for purposes of this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ddf171-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there shall be included in the gross income of the holder an amount equal to the sum of the daily portions of the acquisition discount for each day during the taxable year on which such holder held such obligation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ddf172-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any interest payable on the obligation (other than interest taken into account in determining the amount of the acquisition discount) shall be included in gross income as it accrues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ddf173-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short-term obligations to which section applies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ddf174-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall apply to any short-term obligation which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ddf175-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is held by a taxpayer using an accrual method of accounting,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ddf176-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is held primarily for sale to customers in the ordinary course of the taxpayer’s trade or business,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ddf177-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is held by a bank (as defined in section 581),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ddf178-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is held by a regulated investment company or a common trust fund,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ddf179-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is identified by the taxpayer under section 1256(e)(2) as being part of a hedging transaction, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ddf17a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a stripped bond or stripped coupon held by the person who stripped the bond or coupon (or by any other person whose basis is determined by reference to the basis in the hands of such person).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ddf17b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of obligations held by pass-thru entities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ddf17c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall apply also to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44ddf17d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any short-term obligation which is held by a pass-thru entity which is formed or availed of for purposes of avoiding the provisions of this section, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44ddf17e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any short-term obligation which is acquired by a pass-thru entity (not described in clause (i)) during the required accrual period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ddf17f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required accrual period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the term “required accrual period” means the period—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44ddf180-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which begins with the first taxable year for which the ownership test of subparagraph (C) is met with respect to the pass-thru entity (or a predecessor), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44ddf181-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which ends with the first taxable year after the taxable year referred to in clause (i) for which the ownership test of subparagraph (C) is not met and with respect to which the Secretary consents to the termination of the required accrual period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ddf182-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership test","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The ownership test of this subparagraph is met for any taxable year if, on at least 90 days during the taxable year, 20 percent or more of the value of the interests in the pass-thru entity are held by persons described in paragraph (1) or by other pass-thru entities to which subparagraph (A) applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ddf183-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pass-thru entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “pass-thru entity” means any partnership, S corporation, trust, or other pass-thru entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ddf184-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1281/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For special rules limiting the application of this section to original issue discount in the case of nongovernmental obligations, see section 1283(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44ddf185-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s41/a"},"text":"Pub. L. 98–369, div. A, title I, § 41(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/548"},"text":"98 Stat. 548","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1803/a/7"},"text":"Pub. L. 99–514, title XVIII, § 1803(a)(7)","children":[],"tail":", (8)(A), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2793"},"text":"100 Stat. 2793","children":[],"tail":", 2794.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44ddf186-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44ddf187-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44ddf188-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1803/a/8"},"text":"Pub. L. 99–514, § 1803(a)(8)","children":[],"tail":", amended subsec. (a) generally, designating existing provisions as par. (1) and adding par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1803/a/7"},"text":"Pub. L. 99–514, § 1803(a)(7)","children":[],"tail":", added subpar. (F)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44ddf189-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44ddf18a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1803/a/7"},"text":"section 1803(a)(7) of Pub. L. 99–514","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1803/a/8/A"},"text":"Section 1803(a)(8)(A) of Pub. L. 99–514","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1018/c/1"},"text":"Pub. L. 100–647, title I, § 1018(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3578"},"text":"102 Stat. 3578","children":[],"tail":", provided that the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1803/a/8/A"},"text":"section 1803(a)(8)(A) of Pub. L. 99–514","children":[],"tail":" is effective with respect to obligations acquired after "},{"tag":"date","attrib":{"date":"1985-12-31"},"text":"Dec. 31, 1985","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44ddf18b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years ending after ","children":[{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", and applicable to obligations acquired after that date, with certain elections available, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s44"},"text":"section 44 of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1271"},"text":"section 1271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id44ddf18c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1800–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
