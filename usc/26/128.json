{"tag":"section","attrib":{"id":"id4172da46-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s128"},"text":null,"children":[{"tag":"num","attrib":{"value":"128"},"text":"§ 128.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer contributions to Trump accounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4172da47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s128/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross income of an employee does not include amounts paid by the employer as a contribution to the Trump account of such employee or of any dependent of such employee if the amounts are paid or incurred pursuant to a program which is described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4172da48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s128/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4172da49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s128/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount which may be excluded under subsection (a) with respect to any employee shall not exceed $2,500.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4172da4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s128/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4172da4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s128/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any taxable year beginning after 2027, the $2,500 amount in paragraph (1) shall be increased by an amount equal to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4172da4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s128/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dollar amount, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4172da4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s128/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost-of-living adjustment determined under section 1(f)(3) for the calendar year in which the taxable year begins by substituting “calendar year 2026” for “calendar year 2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4172da4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s128/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rounding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any increase determined under subparagraph (A) is not a multiple of $100, such increase shall be rounded to the next lowest multiple of $100.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4172da4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s128/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trump account contribution program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, a Trump account contribution program is a separate written plan of an employer for the exclusive benefit of his employees to provide contributions to the Trump accounts of such employees or dependents of such employees which meets requirements similar to the requirements of paragraphs (2), (3), (6), (7), and (8) of section 129(d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4172da50-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70204/b/1"},"text":"Pub. L. 119–21, title VII, § 70204(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/186"},"text":"139 Stat. 186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4172da51-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4172da52-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4172da53-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 128, added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIII"},"text":"Pub. L. 97–34, title III","children":[],"tail":", §§ 301(a), 302(a), (d)(1), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/267"},"text":"95 Stat. 267","children":[],"tail":", 270, 274; "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tI"},"text":"Pub. L. 97–448, title I","children":[],"tail":", §§ 103(a)(1), (5), (b), 109, "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2374"},"text":"96 Stat. 2374","children":[],"tail":", 2375, 2391; "},{"tag":"ref","attrib":{"href":"/us/pl/98/21/tI"},"text":"Pub. L. 98–21, title I","children":[],"tail":", §§ 121(f)(2), (g), 122(c)(3), (d), "},{"tag":"date","attrib":{"date":"1983-04-20"},"text":"Apr. 20, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/84"},"text":"97 Stat. 84","children":[],"tail":", 87; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s16/a"},"text":"Pub. L. 98–369, div. A, title I, § 16(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/505"},"text":"98 Stat. 505","children":[],"tail":", related to interest on certain savings certificates, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11801/a/10"},"text":"Pub. L. 101–508, title XI, § 11801(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-520"},"text":"104 Stat. 1388–520","children":[],"tail":". For savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11821/b"},"text":"section 11821(b) of Pub. L. 101–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s45K"},"text":"section 45K of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 128 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s140"},"text":"section 140 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4172da54-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4172da55-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70204/e"},"text":"Pub. L. 119–21, title VII, § 70204(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/188"},"text":"139 Stat. 188","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70204/e"},"text":"“The amendments made by this section [enacting this section and sections 139J, 530A, 6434, and 6659 of this title and amending sections 529A, 4973, 6213, and 6693 of this title] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
