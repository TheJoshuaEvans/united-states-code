{"tag":"section","attrib":{"id":"id454df176-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702"},"text":null,"children":[{"tag":"num","attrib":{"value":"2702"},"text":"§ 2702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special valuation rules in case of transfers of interests in trusts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id454df177-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Valuation rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454df178-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Solely for purposes of determining whether a transfer of an interest in trust to (or for the benefit of) a member of the transferor’s family is a gift (and the value of such transfer), the value of any interest in such trust retained by the transferor or any applicable family member (as defined in section 2701(e)(2)) shall be determined as provided in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454df179-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Valuation of retained interests","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454df17a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The value of any retained interest which is not a qualified interest shall be treated as being zero.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454df17b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Valuation of qualified interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The value of any retained interest which is a qualified interest shall be determined under section 7520.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454df17c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454df17d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection shall not apply to any transfer—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id454df17e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such transfer is an incomplete gift,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id454df17f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such transfer involves the transfer of an interest in trust all the property in which consists of a residence to be used as a personal residence by persons holding term interests in such trust, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id454df180-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that regulations provide that such transfer is not inconsistent with the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454df181-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incomplete gift","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the term “incomplete gift” means any transfer which would not be treated as a gift whether or not consideration was received for such transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454df182-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified interest” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454df183-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any interest which consists of the right to receive fixed amounts payable not less frequently than annually,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454df184-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any interest which consists of the right to receive amounts which are payable not less frequently than annually and are a fixed percentage of the fair market value of the property in the trust (determined annually), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454df185-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any noncontingent remainder interest if all of the other interests in the trust consist of interests described in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454df186-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain property treated as held in trust","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454df187-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The transfer of an interest in property with respect to which there is 1 or more term interests shall be treated as a transfer of an interest in a trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454df188-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint purchases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If 2 or more members of the same family acquire interests in any property described in paragraph (1) in the same transaction (or a series of related transactions), the person (or persons) acquiring the term interests in such property shall be treated as having acquired the entire property and then transferred to the other persons the interests acquired by such other persons in the transaction (or series of transactions). Such transfer shall be treated as made in exchange for the consideration (if any) provided by such other persons for the acquisition of their interests in such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454df189-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “term interest” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454df18a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a life interest in property, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454df18b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an interest in property for a term of years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454df18c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Valuation rule for certain term interests","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the nonexercise of rights under a term interest in tangible property would not have a substantial effect on the valuation of the remainder interest in such property—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454df18d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraph (A) of subsection (a)(2) shall not apply to such term interest, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454df18e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of such term interest for purposes of applying subsection (a)(1) shall be the amount which the holder of the term interest establishes as the amount for which such interest could be sold to an unrelated third party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454df18f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of transfers of interests in portion of trust","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a transfer of an income or remainder interest with respect to a specified portion of the property in a trust, only such portion shall be taken into account in applying this section to such transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454df190-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2702/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Member of the family","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “member of the family” shall have the meaning given such term by section 2704(c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id454df191-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11602/a"},"text":"Pub. L. 101–508, title XI, § 11602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-497"},"text":"104 Stat. 1388–497","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1702/f/11"},"text":"Pub. L. 104–188, title I, § 1702(f)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1872"},"text":"110 Stat. 1872","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id454df192-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id454df193-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id454df194-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(3)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1702/f/11/A/i"},"text":"Pub. L. 104–188, § 1702(f)(11)(A)(i)","children":[],"tail":", (ii), (B)(i), substituted “if” for “to the extent” and “incomplete gift” for “incomplete transfer”, and struck out “or” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1702/f/11/A/iii"},"text":"Pub. L. 104–188, § 1702(f)(11)(A)(iii)","children":[],"tail":", substituted “, or” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1702/f/11/A/iv"},"text":"Pub. L. 104–188, § 1702(f)(11)(A)(iv)","children":[],"tail":", added cl. (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1702/f/11/B"},"text":"Pub. L. 104–188, § 1702(f)(11)(B)","children":[],"tail":", substituted “incomplete gift” for “incomplete transfer” in heading and text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id454df195-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id454df196-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" effective, except as otherwise expressly provided, as if included in the provision of the Revenue Reconciliation Act of 1990, "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI"},"text":"Pub. L. 101–508, title XI","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1702/i"},"text":"section 1702(i) of Pub. L. 104–188","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
