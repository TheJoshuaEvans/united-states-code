{"tag":"section","attrib":{"id":"id46c1f3ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6233"},"text":null,"children":[{"tag":"num","attrib":{"value":"6233"},"text":"§ 6233.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest and penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46c1f3cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6233/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest and penalties determined from reviewed year","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46c1f3d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6233/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except to the extent provided in section 6226(c), in the case of a partnership adjustment for a reviewed year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46c1f3d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6233/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest shall be computed under paragraph (2), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c1f3d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6233/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the partnership shall be liable for any penalty, addition to tax, or additional amount as provided in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f3d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6233/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interest computed under this paragraph with respect to any partnership adjustment is the interest which would be determined under chapter 67 for the period beginning on the day after the return due date for the reviewed year and ending on the return due date for the adjustment year (or, if earlier, the date payment of the imputed underpayment is made). Proper adjustments in the amount determined under the preceding sentence shall be made for adjustments required for partnership taxable years after the reviewed year and before the adjustment year by reason of such partnership adjustment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f3d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6233/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any penalty, addition to tax, or additional amount shall be determined at the partnership level as if such partnership had been an individual subject to tax under chapter 1 for the reviewed year and the imputed underpayment were an actual underpayment (or understatement) for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46c1f3d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6233/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest and penalties with respect to adjustment year return","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46c1f3d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6233/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any failure to pay an imputed underpayment on the date prescribed therefor, the partnership shall be liable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46c1f3d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6233/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for interest as determined under paragraph (2), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c1f3d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6233/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any penalty, addition to tax, or additional amount as determined under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f3d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6233/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Interest determined under this paragraph is the interest that would be determined by treating the imputed underpayment as an underpayment of tax imposed in the adjustment year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f3da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6233/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Penalties, additions to tax, or additional amounts determined under this paragraph are the penalties, additions to tax, or additional amounts that would be determined—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46c1f3db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6233/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by applying section 6651(a)(2) to such failure to pay, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c1f3dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6233/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by treating the imputed underpayment as an underpayment of tax for purposes of part II of subchapter A of chapter 68.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46c1f3dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6233/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit to suspend interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For rules allowing deposits to suspend running of interest on potential underpayments, see section 6603.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46c1f3de-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/74/tXI/s1101/c/1"},"text":"Pub. L. 114–74, title XI, § 1101(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/633"},"text":"129 Stat. 633","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tII/s206/i"},"text":"Pub. L. 115–141, div. U, title II, § 206(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1180"},"text":"132 Stat. 1180","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46c1f3df-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46c1f3e0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46c1f3e1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6233, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII/s714/p/1"},"text":"Pub. L. 98–369, div. A, title VII, § 714(p)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/964"},"text":"98 Stat. 964","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1307/c/3/B"},"text":"Pub. L. 104–188, title I, § 1307(c)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1782"},"text":"110 Stat. 1782","children":[],"tail":", related to extension to entities filing partnership returns, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/p