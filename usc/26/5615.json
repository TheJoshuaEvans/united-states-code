{"tag":"section","attrib":{"id":"id46412ae5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615"},"text":null,"children":[{"tag":"num","attrib":{"value":"5615"},"text":"§ 5615.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property subject to forfeiture","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The following property shall be forfeited to the United States:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46412ae6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unregistered still or distilling apparatus","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every still or distilling apparatus not registered as required by section 5179, together with all personal property in the possession or custody or under the control of the person required by section 5179 to register the still or distilling apparatus, and found in the building or in any yard or inclosure connected with the building in which such still or distilling apparatus is set up; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46412ae7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distilling apparatus removed without notice or set up without notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any still, boiler, or other vessel to be used for the purpose of distilling—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46412ae8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is removed without notice having been given when required by section 5101(a)(1), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46412ae9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is set up without notice having been given when required by section 5101(a)(2); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46412aea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distilling without giving bond or with intent to defraud","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever any person carries on the business of a distiller without having given bond as required by law or gives any false, forged, or fraudulent bond; or engages in or carries on the business of a distiller with intent to defraud the United States of the tax on the distilled spirits distilled by him, or any part thereof; or after the time fixed in the notice declaring his intention to suspend work, filed under section 5221(a), carries on the business of a distiller on the premises covered by such notice, or has mash, wort, or beer on such premises, or on any premises connected therewith, or has in his possession or under his control any mash, wort, or beer, with intent to distill the same on such premises—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46412aeb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all distilled spirits or wines, and all stills or other apparatus fit or intended to be used for the distillation or rectification of spirits, or for the compounding of liquors, owned by such person, wherever found; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46412aec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all distilled spirits, wines, raw materials for the production of distilled spirits, and personal property found in the distillery or in any building, room, yard, or inclosure connected therewith and used with or constituting a part of the premises; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46412aed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all the right, title, and interest of such person in the lot or tract of land on which the distillery is situated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46412aee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all the right, title, and interest in the lot or tract of land on which the distillery is located of every person who knowingly has suffered or permitted the business of a distiller to be there carried on, or has connived at the same; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46412aef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all personal property owned by or in possession of any person who has permitted or suffered any building, yard, or inclosure, or any part thereof, to be used for purposes of ingress or egress to or from the distillery, which shall be found in any such building, yard, or inclosure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46412af0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all the right, title, and interest of every person in any premises used for ingress or egress to or from the distillery who knowingly has suffered or permitted such premises to be used for such ingress or egress; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46412af1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful production and removals from vinegar plants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46412af2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all distilled spirits in excess of 15 percent of alcohol by volume produced on the premises of a vinegar plant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46412af3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all vinegar or other fluid or other material containing a greater proportion than 2 percent of proof spirits removed from any vinegar plant; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46412af4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False or omitted entries in records, returns, and reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever any person required by section 5207 to keep or file any record, return, report, summary, transcript, or other document, shall, with intent to defraud the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46412af5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to keep any such document or to make required entries therein; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46412af6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make any false entry in such document; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46412af7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cancel, alter, or obliterate any part of such document, or any entry therein, or destroy any part of such document, or entry therein; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46412af8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hinder or obstruct any internal revenue officer from inspecting any such document or taking any abstracts therefrom; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46412af9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail or refuse to preserve or produce any such document, as required by this chapter or regulations issued pursuant thereto; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46412afa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit any of the acts described in the preceding subparagraphs to be performed;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"all interest of such person in the distilled spirits plant where such acts or omissions occur, and in the equipment thereon, and in the lot or tract of land on which such distilled spirits plant stands, and in all personal property on the premises of the distilled spirits plant where such acts or omissions occur, used in the business there carried on; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46412afb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful removal of distilled spirits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All distilled spirits on which the tax has not been paid or determined which have been removed, other than as authorized by law, from the place of manufacture, storage, or instrument of transportation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46412afc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5615/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of fictitious proof","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All distilled spirits on which the tax has not been paid or determined as provided by law to which any ingredient or substance has been added for the purpose of creating fictitious proof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46412afd-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1405"},"text":"72 Stat. 1405","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/56"},"text":"Pub. L. 96–39, title VIII, § 807(a)(56)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/289"},"text":"93 Stat. 289","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s451/b/2"},"text":"Pub. L. 98–369, div. A, title IV, § 451(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/819"},"text":"98 Stat. 819","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46412afe-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46412aff-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46412b00-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5615, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/686"},"text":"68A Stat. 686","children":[],"tail":", related to penalty for refusal or neglect of distillers and rectifiers to give assistance to officers, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See sections 5203(e) and 5687 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising this section were contained in prior sections of act ","children":[{"tag":"date","attrib":{"date":"1954-08-16"},"text":"Aug. 16, 1954","children":[],"tail":", prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":", as follows:"},{"tag":"quotedContent","attrib":{},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id46412b01-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Present subds.:","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Prior sections","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5601.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5602.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5604, 5606, 5626, 5650.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(4)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5608(b).","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(5)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5620.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(6)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5631, 5632, 5643, 5647.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(7)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5634.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The prior sections, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", are set out in "},{"tag":"ref","attrib":{"href":"/us/stat/68A/683"},"text":"68A Stat. 683","children":[],"tail":" to 690, 692, 693, 695."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5616, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/686"},"text":"68A Stat. 686","children":[],"tail":", related to penalty for obstructing or refusing to admit officer to distillery premises, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5687"},"text":"section 5687 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5617, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/686"},"text":"68A Stat. 686","children":[],"tail":", related to penalty for failure to keep distillery accessible, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5687"},"text":"section 5687 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5618, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/686"},"text":"68A Stat. 686","children":[],"tail":", related to penalty for failure of distiller to identify fixed pipes, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5687"},"text":"section 5687 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5619, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/686"},"text":"68A Stat. 686","children":[],"tail":", related to penalty for refusal or neglect to draw off water and clean condensers or worm tanks, prior to the gene