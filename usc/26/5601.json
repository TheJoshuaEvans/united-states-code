{"tag":"section","attrib":{"id":"id463ee159-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601"},"text":null,"children":[{"tag":"num","attrib":{"value":"5601"},"text":"§ 5601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id463ee15a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id463ee15b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unregistered stills","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"has in his possession or custody, or under his control, any still or distilling apparatus set up which is not registered, as required by section 5179(a); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee15c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to file application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"engages in the business of a distiller or processor without having filed application for and received notice of registration, as required by section 5171(c); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee15d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False or fraudulent application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"engages, or intends to engage, in the business of distiller, warehouseman, or processor of distilled spirits, and files a false or fraudulent application under section 5171; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee15e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure or refusal of distiller, warehouseman, or processor to give bond","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"carries on the business of a distiller, warehouseman, or processor without having given bond as required by law; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee15f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False, forged, or fraudulent bond","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"engages, or intends to engage, in the business of distiller, warehouseman, or processor of distilled spirits, and gives any false, forged, or fraudulent bond, under subchapter B; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee160-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distilling on prohibited premises","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"uses, or possesses with intent to use, any still, boiler, or other utensil for the purpose of producing distilled spirits, or aids or assists therein, or causes or procures the same to be done, in any dwelling house, or in any shed, yard, or inclosure connected with such dwelling house (except as authorized under section 5178(a)(1)(C)), or on board any vessel or boat, or on any premises where beer or wine is made or produced, or where liquors of any description are retailed, or on premises where any other business is carried on (except when authorized under section 5178(b)); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee161-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful production, removal, or use of material fit for production of distilled spirits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"except as otherwise provided in this chapter, makes or ferments mash, wort, or wash, fit for distillation or for the production of distilled spirits, in any building or on any premises other than the designated premises of a distilled spirits plant lawfully qualified to produce distilled spirits, or removes, without authorization by the Secretary, any mash, wort, or wash, so made or fermented, from the designated premises of such lawfully qualified plant before being distilled; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee162-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful production of distilled spirits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"not being a distiller authorized by law to produce distilled spirits, produces distilled spirits by distillation or any other process from any mash, wort, wash, or other material; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee163-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unauthorized use of distilled spirits in manufacturing processes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"except as otherwise provided in this chapter, uses distilled spirits in any process of manufacture unless such spirits—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id463ee164-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been produced in the United States by a distiller authorized by law to produce distilled spirits and withdrawn in compliance with law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id463ee165-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been imported (or otherwise brought into the United States) and withdrawn in compliance with law; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee166-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful processing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"engages in or carries on the business of a processor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id463ee167-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to defraud the United States of any tax on the distilled spirits processed by him; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id463ee168-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to aid, abet, or assist any person or persons in defrauding the United States of the tax on any distilled spirits; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee169-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful purchase, receipt, or processing of distilled spirits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"purchases, receives, or processes any distilled spirits, knowing or having reasonable grounds to believe that any tax due on such spirits has not been paid or determined as required by law; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee16a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful removal or concealment of distilled spirits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"removes, other than as authorized by law, any distilled spirits on which the tax has not been paid or determined, from the place of manufacture or storage, or from any instrument of transportation, or conceals spirits so removed; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee16b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of fictitious proof","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"adds, or causes to be added, any ingredient or substance (other than ingredients or substances authorized by law to be added) to any distilled spirits before the tax is paid thereon, or determined as provided by law, for the purpose of creating fictitious proof; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee16c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distilling after notice of suspension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"after the time fixed in the notice given under section 5221(a) to suspend operations as a distiller, carries on the business of a distiller on the premises covered by the notice of suspension, or has mash, wort, or beer on such premises, or on any premises connected therewith, or has in his possession or under his control any mash, wort, or beer, with intent to distill the same on such premises; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee16d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unauthorized withdrawal, use, sale, or distribution of distilled spirits for fuel use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"withdraws, uses, sells, or otherwise disposes of distilled spirits produced under section 5181 for other than fuel use;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined not more than $10,000, or imprisoned not more than 5 years, or both, for each such offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id463ee16e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever on trial for violation of subsection (a)(4) the defendant is shown to have been at the site or place where, and at the time when, the business of a distiller or processor was so engaged in or carried on, such presence of the defendant shall be deemed sufficient evidence to authorize conviction, unless the defendant explains such presence to the satisfaction of the jury (or of the court when tried without jury).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id463ee16f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1398"},"text":"72 Stat. 1398","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1905(a)(22), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1820"},"text":"90 Stat. 1820","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/52"},"text":"Pub. L. 96–39, title VIII, § 807(a)(52)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/288"},"text":"93 Stat. 288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/223/tII/s232/e/2/A"},"text":"Pub. L. 96–223, title II, § 232(e)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-02"},"text":"Apr. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/280"},"text":"94 Stat. 280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/248"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(248)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1196"},"text":"132 Stat. 1196","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id463ee170-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id463ee171-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id463ee172-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5601, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/683"},"text":"68A Stat. 683","children":[],"tail":", consisted of provisions similar to those comprising subsec. (a)(1) of this section, and also related to forfeiture for possession of unregistered still or distilling apparatus, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5615/1"},"text":"section 5615(1) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising subsecs. (a)(2) to (8), (9)(A), (10) to (14) of this section were contained in prior sections of act ","children":[{"tag":"date","attrib":{"date":"1954-08-16"},"text":"Aug. 16, 1954","children":[],"tail":", prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":", as follows:"},{"tag":"quotedContent","attrib":{},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id463ee173-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Present subd. of subsec. (a):","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Prior sections","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5172, 5603.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5603.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(4)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5172, 5604, 5606.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(5)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5604.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","att