{"tag":"section","attrib":{"id":"id459f1e48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3404"},"text":null,"children":[{"tag":"num","attrib":{"value":"3404"},"text":"§ 3404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return and payment by governmental employer","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If the employer is the United States, or a State, or political subdivision thereof, or the District of Columbia, or any agency or instrumentality of any one or more of the foregoing, the return of the amount deducted and withheld upon any wages may be made by any officer or employee of the United States, or of such State, or political subdivision, or of the District of Columbia, or of such agency or instrumentality, as the case may be, having control of the payment of such wages, or appropriately designated for that purpose.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id459f1e49-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/469"},"text":"68A Stat. 469","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1903/c"},"text":"Pub. L. 94–455, title XIX, § 1903(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1810"},"text":"90 Stat. 1810","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id459f1e4a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id459f1e4b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id459f1e4c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “Territory” after “or a State” and “of such State”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
