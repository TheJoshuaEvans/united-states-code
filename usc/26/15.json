"},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tI/s101/b"},"text":"Pub. L. 99–514, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2099"},"text":"100 Stat. 2099","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/a"},"text":"Pub. L. 100–647, title I, § 1006(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3393"},"text":"102 Stat. 3393","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tI/s101/c/3"},"text":"Pub. L. 107–16, title I, § 101(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/43"},"text":"115 Stat. 43","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id404d6c81-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id404d6c82-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id404d6c83-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s101/c/3"},"text":"Pub. L. 107–16, § 101(c)(3)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" amended subsec. (d) generally, substituting “apply to inflation adjustments” for “apply to section 1 rate changes made by Economic Recovery Tax Act of 1981” in heading and struck out “section 1 attributable to the amendments made by section 101 of the Economic Tax Act of 1981 or” before “subsection (f)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s21"},"text":"section 21 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" substituted provisions that this section shall not apply to any change in rates under section 1 attributable to the amendments made by section 101 of the Economic Recovery Tax Act of 1981 or subsec. (f) of section 1 for provisions that had related to the changes made by section 303(b) of the Tax Reduction Act of 1975 in the surtax exemption."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" struck out subsecs. (e) and (f) which had related, respectively, to changes made by the Tax Reduction and Simplification Act of 1977 and to changes made by Revenue Act of 1978."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/30/s101/d/2/A"},"text":"Pub. L. 95–30, § 101(d)(2)(A)","children":[],"tail":", (B), redesignated subsec. (f) as (d). Former subsec. (d), which directed that, in applying subsec. (a) to a taxable year of an individual which was not a calendar year, each change made by the Tax Reform Act of 1969 in part I or in the application of part IV or V of subchapter B for purposes of the determination of taxable income should be treated as a change in a rate of tax, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/30/s101/d/2/A"},"text":"Pub. L. 95–30, § 101(d)(2)(A)","children":[],"tail":", (C), added subsec. (e). Former subsec. (e), which directed that, in applying subsec. (a) to a taxable year of an individual which was not a calendar year, each change made by the Revenue Act of 1971 in section 141 (relating to the standard deduction) and section 151 (relating to personal exemptions) should be treated as a change in a rate of tax, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/30/s101/d/2/B"},"text":"Pub. L. 95–30, § 101(d)(2)(B)","children":[],"tail":", redesignated subsec. (f) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted “in the surtax exemption and any change under section 11(d) in the surtax exemption” for “and the change made by section 3(c) of the Revenue Adjustment Act of 1975 in section 11(d) (relating to corporate surtax exemption)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/164"},"text":"Pub. L. 94–164","children":[],"tail":" inserted reference to change made by section 3(c) of the Revenue Adjustment Act of 1975."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/12"},"text":"Pub. L. 94–12","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/178"},"text":"Pub. L. 92–178","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" substituted provisions covering changes made by the Tax Reform Act of 1969 in case of individuals for provisions covering changes made by Revenue Act of 1964."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272"},"text":"Pub. L. 88–272","children":[],"tail":" amended subsection generally by substituting provisions relating to changes made by the Revenue Act of 1964, for provisions relating to taxable years beginning before "},{"tag":"date","attrib":{"date":"1954-01-01"},"text":"Jan. 1, 1954","children":[],"tail":", and ending after "},{"tag":"date","attrib":{"date":"1953-12-31"},"text":"Dec. 31, 1953","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id404d6c84-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id404d6c85-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16"},"text":"Pub. L. 107–16","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2000-12-31"},"text":"Dec. 31, 2000","children":[],"tail":", see