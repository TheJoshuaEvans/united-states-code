{"tag":"section","attrib":{"id":"id404d6c73-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"§ 15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of changes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id404d6c74-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s15/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any rate of tax imposed by this chapter changes, and if the taxable year includes the effective date of the change (unless that date is the first day of the taxable year), then—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id404d6c75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s15/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tentative taxes shall be computed by applying the rate for the period before the effective date of the change, and the rate for the period on and after such date, to the taxable income for the entire taxable year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id404d6c76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s15/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax for such taxable year shall be the sum of that proportion of each tentative tax which the number of days in each period bears to the number of days in the entire taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id404d6c77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s15/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeal of tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id404d6c78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s15/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a tax is repealed, the repeal shall be considered a change of rate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id404d6c79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s15/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate for the period after the repeal shall be zero.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id404d6c7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s15/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of change","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsections (a) and (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id404d6c7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s15/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the rate changes for taxable years “beginning after” or “ending after” a certain date, the following day shall be considered the effective date of the change; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id404d6c7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s15/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a rate changes for taxable years “beginning on or after” a certain date, that date shall be considered the effective date of the change.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id404d6c7d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s15/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section not to apply to inflation adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to any change in rates under subsection (f) of section 1 (relating to adjustments in tax tables so that inflation will not result in tax increases).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id404d6c7e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s15/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References to highest rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the change referred to in subsection (a) involves a change in the highest rate of tax imposed by section 1 or 11(b), any reference in this chapter to such highest rate (other than in a provision imposing a tax by reference to such rate) shall be treated as a reference to the weighted average of the highest rates before and after the change determined on the basis of the respective portions of the taxable year before the date of the change and on or after the date of the change.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id404d6c7f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s15/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate reductions enacted by Economic Growth and Tax Relief Reconciliation Act of 2001","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to any change in rates under subsection (i) of section 1 (relating to rate reductions after 2000).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id404d6c80-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/12"},"text":"68A Stat. 12","children":[],"tail":", § 21; "},{"tag":"ref","attrib":{"href":"/us/pl/88/272/tI/s132"},"text":"Pub. L. 88–272, title I, § 132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/30"},"text":"78 Stat. 30","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tVIII/s803/e"},"text":"Pub. L. 91–172, title VIII, § 803(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/685"},"text":"83 Stat. 685","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/178/tII/s205"},"text":"Pub. L. 92–178, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/511"},"text":"85 Stat. 511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/12/tIII/s305/b/2"},"text":"Pub. L. 94–12, title III, § 305(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-03-29"},"text":"Mar. 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/45"