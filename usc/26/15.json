th respect to taxable years ending after "},{"tag":"date","attrib":{"date":"1963-12-31"},"text":"Dec. 31, 1963","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id404d6c8d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coordination of 2025 Amendment With Section 15","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70001/b"},"text":"Pub. L. 119–21, title VII, § 70001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/158"},"text":"139 Stat. 158","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70001/b"},"text":"“Section 15 of the Internal Revenue Code of 1986 shall not apply to any change in rate of tax by reason of any provision of, or amendment made by, this title [see Tables for classification].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id404d6c8e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coordination of 2017 Amendment With Section 15","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section not to apply to any change in a rate of tax by reason of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1/j"},"text":"section 1(j) of this title","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1/j/6"},"text":"section 1(j)(6) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id404d6c8f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coordination of 1997 Amendment With Section 15","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tI/s1/c"},"text":"Pub. L. 105–34, title I, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/788"},"text":"111 Stat. 788","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tI/s1/c"},"text":"“No amendment made by this Act [see Tables for classification] shall be treated as a change in a rate of tax for purposes of section 15 of the Internal Revenue Code of 1986.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id404d6c90-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coordination of 1993 Amendment With Section 15","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13001/c"},"text":"Pub. L. 103–66, title XIII, § 13001(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/416"},"text":"107 Stat. 416","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/66/tXIII/s13001/c"},"text":"“Except in the case of the amendments made by section 13221 [amending sections 11, 852, 1201, and 1445 of this title] (relating to corporate rate increase), no amendment made by this chapter [chapter 1 (§§ 13001–13444) of title XIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":", see Tables for classification] shall be treated as a change in a rate of tax for purposes of section 15 of the Internal Revenue Code of 1986.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id404d6c91-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coordination of 1990 Amendment With Section 15","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11001/c"},"text":"Pub. L. 101–508, title XI, § 11001(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-400"},"text":"104 Stat. 1388–400","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/508/tXI/s11001/c"},"text":"“Except as otherwise expressly provided in this title, no amendment made by this title [see Tables for classification] shall be treated as a change in a rate of tax for purposes of section 15 of the Internal Revenue Code of 1986.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id404d6c92-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coordination of 1987 Amendment With Section 15","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10000/c"},"text":"Pub. L. 100–203, title X, § 10000(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-382"},"text":"101 Stat. 1330–382","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/203/tX/s10000/c"},"text":"“No amendment made by this title [see Tables for classification] shall be treated as a change in a rate of tax for purposes [of] section 15 of the Internal Revenue Code of 1986.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id404d6c93