{"tag":"section","attrib":{"id":"id47c38586-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701"},"text":null,"children":[{"tag":"num","attrib":{"value":"9701"},"text":"§ 9701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions of general applicability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47c38587-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans and funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c38588-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" UMWA Benefit Plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c38589-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “UMWA Benefit Plan” means a plan—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47c3858a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is described in section 404(c), or a continuation thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47c3858b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which provides health benefits to retirees and beneficiaries of the industry which maintained the 1950 UMWA Pension Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c3858c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1950 UMWA Benefit Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “1950 UMWA Benefit Plan” means a UMWA Benefit Plan, participation in which is substantially limited to individuals who retired before 1976.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c3858d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1974 UMWA Benefit Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “1974 UMWA Benefit Plan” means a UMWA Benefit Plan, participation in which is substantially limited to individuals who retired on or after ","children":[{"tag":"date","attrib":{"date":"1976-01-01"},"text":"January 1, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c3858e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1950 UMWA Pension Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “1950 UMWA Pension Plan” means a pension plan described in section 404(c) (or a continuation thereof), participation in which is substantially limited to individuals who retired before 1976.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c3858f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1974 UMWA Pension Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “1974 UMWA Pension Plan” means a pension plan described in section 404(c) (or a continuation thereof), participation in which is substantially limited to individuals who retired in 1976 and thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c38590-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1992 UMWA Benefit Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “1992 UMWA Benefit Plan” means the plan referred to in section 9712.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c38591-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Combined Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Combined Fund” means the United Mine Workers of America Combined Benefit Fund established under section 9702.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c38592-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c38593-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coal wage agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “coal wage agreement” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c38594-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Bituminous Coal Wage Agreement, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c38595-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any other agreement entered into between an employer in the coal industry and the United Mine Workers of America that required or requires one or both of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47c38596-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of health benefits to retirees of such employer, eligibility for which is based on years of service credited under a plan established by the settlors and described in section 404(c) or a continuation of such plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47c38597-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contributions to the 1950 UMWA Benefit Plan or the 1974 UMWA Benefit Plan, or any predecessor thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c38598-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “settlors” means the United Mine Workers of America and the Bituminous Coal Operators’ Association, Inc. (referred to in this chapter as the “BCOA”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c38599-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Bituminous Coal Wage Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Bituminous Coal Wage Agreement” means a collective bargaining agreement negotiated by the BCOA and the United Mine Workers of America.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c3859a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms relating to operators","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c3859b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Signatory operator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “signatory operator” means a person which is or was a signatory to a coal wage agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c3859c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related persons","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c3859d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person shall be considered to be a related person to a signatory operator if that person is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47c3859e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the controlled group of corporations (within the meaning of section 52(a)) which includes such signatory operator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47c3859f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trade or business which is under common control (as determined under section 52(b)) with such signatory operator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47c385a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person who is identified as having a partnership interest or joint venture with a signatory operator in a business within the coal industry, but only if such business employed eligible beneficiaries, except that this clause shall not apply to a person whose only interest is as a limited partner.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A related person shall also include a successor in interest of any person described in clause (i), (ii), or (iii).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c385a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The relationships described in clauses (i), (ii), and (iii) of subparagraph (A) shall be determined as of ","children":[{"tag":"date","attrib":{"date":"1992-07-20"},"text":"July 20, 1992","children":[],"tail":", except that if, on "},{"tag":"date","attrib":{"date":"1992-07-20"},"text":"July 20, 1992","children":[],"tail":", a signatory operator is no longer in business, the relationships shall be determined as of the time immediately before such operator ceased to be in business."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c385a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1988 agreement operator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “1988 agreement operator” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c385a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a signatory operator which was a signatory to the 1988 National Bituminous Coal Wage Agreement,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c385a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employer in the coal industry which was a signatory to an agreement containing pension and health care contribution and benefit provisions which are the same as those contained in the 1988 National Bituminous Coal Wage Agreement, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c385a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employer from which contributions were actually received after 1987 and before ","children":[{"tag":"date","attrib":{"date":"1992-07-20"},"text":"July 20, 1992","children":[],"tail":", by the 1950 UMWA Benefit Plan or the 1974 UMWA Benefit Plan in connection with employment in the coal industry during the period covered by the 1988 National Bituminous Coal Wage Agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c385a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Last signatory operator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “last signatory operator” means, with respect to a coal industry retiree, a signatory operator which was the most recent coal industry employer of such retiree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c385a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assigned operator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “assigned operator” means, with respect to an eligible beneficiary defined in section 9703(f), the signatory operator to which liability under subchapter B with respect to the beneficiary is assigned under section 9706.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c385a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operators of dependent beneficiaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the signatory operator, last signatory operator, or assigned operator of any eligible beneficiary under this chapter who is a coal industry retiree shall be considered to be the signatory operator, last signatory operator, or assigned operator with respect to any other individual who is an eligible beneficiary under this chapter by reason of a relationship to the retiree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c385a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, a person shall be considered to be in business if such person conducts or derives revenue from any business activity, whether or not in the coal industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c385aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Successor in interest","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c385ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe harbor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “successor in interest” shall not include any person who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47c385ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an unrelated person to an eligible seller described in subparagraph (C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47c385ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchases for fair market value assets, or all of the stock, of a related person to such seller, in a bona fide, arm’s-length sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c385ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unrelated person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “unrelated person” means a purchaser who does not bear a relationship to the eligible seller described in section 267(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c385af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/c/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible seller","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the term “eligible seller” means an assigned operator described in section 9704(j)(2) or a related person to such assigned operator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c385b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9701/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enactment date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the term “enactment date” means the date of the enactment of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47c385b1-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s19143/a"},"text":"Pub. L. 102–486, title XIX, § 19143(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3037"},"text":"106 Stat. 3037","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dC/tII/s211/d"},"text":"Pub. L. 109–432, div. C, title II, § 211(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3023"},"text":"120 Stat. 3023","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/343"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(343)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1200"},"text":"132 Stat. 1200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47c385b2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47c385b3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id47c385b4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this chapter, referred to in subsec. (d), is the date of the enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47c385b5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “section 9712” for “section 9713A”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" added par. (8)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47c385b6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47c385b7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/dC/tII/s211/e"},"text":"Pub. L. 109–432, div. C, title II, § 211(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3023"},"text":"120 Stat. 3023","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/432/dC/tII/s211/e"},"text":"“The amendments made by this section [amending this section and sections 9704, 9711, and 9712 of this title] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":"], except that the amendment made by subsection (d) [amending this section] shall apply to transactions after the date of the enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id47c385b8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings and Declaration of Policy","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s19142"},"text":"Pub. L. 102–486, title XIX, § 19142","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3037"},"text":"106 Stat. 3037","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/486/tXIX/s19142"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production, transportation, and use of coal substantially affects interstate and foreign commerce and the national public interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in order to secure the stability of interstate commerce, it is necessary to modify the current private health care benefit plan structure for retirees in the coal industry to identify persons most responsible for plan liabilities in order to stabilize plan funding and allow for the provision of health care benefits to such retirees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statement of Policy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the policy of this subtitle [subtitle C (§§ 19141–19143) of title XIX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":", enacting this subtitle, amending sections 1231 and 1232 of Title 30, Mineral Lands and Mining, and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"]—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to remedy problems with the provision and funding of health care benefits with respect to the beneficiaries of multiemployer benefit plans that provide health care benefits to retirees in the coal industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allow for sufficient operating assets for such plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the continuation of a privately financed self-sufficient program for the delivery of health care benefits to the beneficiaries of such plans.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
