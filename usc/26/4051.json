{"tag":"section","attrib":{"id":"id45afbfe0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051"},"text":null,"children":[{"tag":"num","attrib":{"value":"4051"},"text":"§ 4051.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax on heavy trucks and trailers sold at retail","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45afbfe1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45afbfe2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby imposed on the first retail sale of the following articles (including in each case parts or accessories sold on or in connection therewith or with the sale thereof) a tax of 12 percent of the amount for which the article is so sold:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45afbfe3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Automobile truck chassis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afbfe4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Automobile truck bodies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afbfe5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Truck trailer and semitrailer chassis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afbfe6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Truck trailer and semitrailer bodies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afbfe7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tractors of the kind chiefly used for highway transportation in combination with a trailer or semitrailer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afbfe8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion for trucks weighing 33,000 pounds or less","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by paragraph (1) shall not apply to automobile truck chassis and automobile truck bodies, suitable for use with a vehicle which has a gross vehicle weight of 33,000 pounds or less (as determined under regulations prescribed by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afbfe9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion for trailers weighing 26,000 pounds or less","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by paragraph (1) shall not apply to truck trailer and semitrailer chassis and bodies, suitable for use with a trailer or semitrailer which has a gross vehicle weight of 26,000 pounds or less (as determined under regulations prescribed by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afbfea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion for tractors weighing 19,500 pounds or less","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The tax imposed by paragraph (1) shall not apply to tractors of the kind chiefly used for highway transportation in combination with a trailer or semitrailer if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45afbfeb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such tractor has a gross vehicle weight of 19,500 pounds or less (as determined by the Secretary), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afbfec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such tractor, in combination with a trailer or semitrailer, has a gross combined weight of 33,000 pounds or less (as determined by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afbfed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of trucks, etc., treated as sale of chassis and body","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, a sale of an automobile truck or truck trailer or semitrailer shall be considered to be a sale of a chassis and of a body described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45afbfee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate purchase of truck or trailer and parts and accessories therefor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45afbfef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45afbff0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner, lessee, or operator of any vehicle which contains an article taxable under subsection (a) installs (or causes to be installed) any part or accessory on such vehicle, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afbff1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such installation is not later than the date 6 months after the date such vehicle (as it contains such article) was first placed in service,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then there is hereby imposed on such installation a tax equal to 12 percent of the price of such part or accessory and its installation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afbff2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45afbff3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the part or accessory installed is a replacement part or accessory, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afbff4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate price of the parts and accessories (and their installation) described in paragraph (1) with respect to any vehicle does not exceed $1,000 (or such other amount or amounts as the Secretary may by regulations prescribe).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afbff5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Installers secondarily liable for tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The owners of the trade or business installing the parts or accessories shall be secondarily liable for the tax imposed by paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45afbff6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"2028-10-01"},"text":"October 1, 2028","children":[],"tail":", the taxes imposed by this section shall not apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45afbff7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit against tax for tire tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45afbff8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tires are sold on or in connection with the sale of any article, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afbff9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4051/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tax is imposed by this subchapter on the sale of such tires,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"there shall be allowed as a credit against the tax imposed by this subchapter an amount equal to the tax (if any) imposed by section 4071 on such tires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45afbffa-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/424/tV/s512/b/1"},"text":"Pub. L. 97–424, title V, § 512(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-06"},"text":"Jan. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2174"},"text":"96 Stat. 2174","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII/s734/g"},"text":"Pub. L. 98–369, div. A, title VII, § 734(g)","children":[],"tail":", title IX, § 921, "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/980"},"text":"98 Stat. 980","children":[],"tail":", 1009; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII"},"text":"Pub. L. 99–514, title XVIII","children":[],"tail":", §§ 1877(c), 1899A(47), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2902"},"text":"100 Stat. 2902","children":[],"tail":", 2961; "},{"tag":"ref","attrib":{"href":"/us/pl/100/17/tV/s502/a/2"},"text":"Pub. L. 100–17, title V, § 502(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-02"},"text":"Apr. 2, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/256"},"text":"101 Stat. 256","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11211/c/1"},"text":"Pub. L. 101–508, title XI, § 11211(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"