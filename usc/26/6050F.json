{"tag":"section","attrib":{"id":"id467a63e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050F"},"text":null,"children":[{"tag":"num","attrib":{"value":"6050F"},"text":"§ 6050F.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns relating to social security benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id467a63e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050F/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The appropriate Federal official shall make a return, according to the forms and regulations prescribed by the Secretary, setting forth—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467a63e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050F/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467a63e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050F/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aggregate amount of social security benefits paid with respect to any individual during any calendar year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467a63e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050F/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aggregate amount of social security benefits repaid by such individual during such calendar year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467a63e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050F/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aggregate reductions under section 224 of the Social Security Act (or under section 3(a)(1) of the Railroad Retirement Act of 1974) in benefits which would otherwise have been paid to such individual during the calendar year on account of amounts received under a workmen’s compensation act, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467a63e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050F/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467a63e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050F/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements to be furnished to persons with respect to whom information is required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every person required to make a return under subsection (a) shall furnish to each individual whose name is required to be set forth in such return a written statement showing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467a63e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050F/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the agency making the payments, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467a63ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050F/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of payments, of repayments, and of reductions, with respect to the individual required to be shown on such return.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The written statement required under the preceding sentence shall be furnished to the individual on or before January 31 of the year following the calendar year for which the return under subsection (a) was required to be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467a63eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050F/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467a63ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050F/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate Federal official","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate Federal official” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467a63ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050F/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commissioner of Social Security in the case of social security benefits described in section 86(d)(1)(A), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467a63ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050F/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Railroad Retirement Board in the case of social security benefits described in section 86(d)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467a63ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050F/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Social security benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “social security benefit” has the meaning given to such term by section 86(d)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id467a63f0-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/21/tI/s121/b"},"text":"Pub. L. 98–21, title I, § 121(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-04-20"},"text":"Apr. 20, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/82"},"text":"97 Stat. 82","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1501/c/9"},"text":"Pub. L. 99–514, title XV, § 1501(c)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2738"},"text":"100 Stat. 2738","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/360/tI/s111/b"},"text":"Pub. L. 100–360, title I, § 111(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-01"},"text":"July 1, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/697"},"text":"102 Stat. 697","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/234/tI/s102/a"},"text":"Pub. L. 101–234, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-13"},"text":"Dec. 13, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1980"},"text":"103 Stat. 1980","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/296/tI/s108/h/4"},"text":"Pub. L. 103–296, title I, § 108(h)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-15"},"text":"Aug. 15, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1487"},"text":"108 Stat. 1487","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id467a63f1-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id467a63f2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id467a63f3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 224 of the Social Security Act, referred to in subsec. (a)(1)(C), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s424a"},"text":"section 424a of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3(a)(1) of the Railroad Retirement Act of 1974, referred to in subsec. (a)(1)(C), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s231b/a/1"},"text":"section 231b(a)(1) of Title 45","children":[],"tail":", Railroads."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id467a63f4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296"},"text":"Pub. L. 103–296","children":[],"tail":" substituted “Commissioner of Social Security” for “Secretary of Health and Human Services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsecs. (a), (b)(1), (2), (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/234/s102/a"},"text":"Pub. L. 101–234, § 102(a)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/100/360/s111"},"text":"Pub. L. 100–360, § 111","children":[],"tail":", and provided that the provisions of law amended by such section are restored or revived as if such section had not been enacted, see 1988 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s111/b/1"},"text":"Pub. L. 100–360, § 111(b)(1)","children":[],"tail":", added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s111/b/2/A"},"text":"Pub. L. 100–360, § 111(b)(2)(A)","children":[],"tail":", inserted “or making the determination under subsection (a)(2)” after “payments”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s111/b/2/B"},"text":"Pub. L. 100–360, § 111(b)(2)(B)","children":[],"tail":", inserted “and the information required under subsection (a)(2),” after “reductions,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s111/b/3"},"text":"Pub. L. 100–360, § 111(b)(3)","children":[],"tail":", inserted “and the information required under subsection (a)(2)” after “section 86(d)(1)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", in amending subsec. (b) generally, substituted “information is required” for “information is furnished” in heading and, in text, substituted references to persons required to make a return for former references to persons making a return and references to persons whose name is required to be set forth for former references to persons whose name is set forth."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id467a63f5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id467a63f6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296"},"text":"Pub. L. 103–296","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1995-03-31"},"text":"Mar. 31, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/296/s110/a"},"text":"section 110(a) of Pub. L. 103–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s401"},"text":"section 401 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id467a63f7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/234"},"text":"Pub. L. 101–234","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1988-12-31"},"text":"Dec. 31, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/234/s102/d/2"},"text":"section 102(d)(2) of Pub. L. 101–234","children":[],"tail":", set out as an Effective Date of Repeal note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s59B"},"text":"section 59B of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id467a63f8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360"},"text":"Pub. L. 100–360","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1988-12-31"},"text":"Dec. 31, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/360/s111/e"},"text":"section 111(e) of Pub. L. 100–360","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s59B"},"text":"section 59B of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id467a63f9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" applicable to returns the due date for which (determined without regard to extensions) is after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1501/e"},"text":"section 1501(e) of Pub. L. 99–514","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6721"},"text":"section 6721 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id467a63fa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to benefits received after ","children":[{"tag":"date","attrib":{"date":"1983-12-31"},"text":"Dec. 31, 1983","children":[],"tail":", in taxable years ending after such date, except for any portion of a lump-sum payment of social security benefits received after "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"Dec. 31, 1983","children":[],"tail":", if the generally applicable payment date for such portion was before "},{"tag":"date","attrib":{"date":"1984-01-01"},"text":"Jan. 1, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/21/s121/g"},"text":"section 121(g) of Pub. L. 98–21","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s86"},"text":"section 86 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id467a63fb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Supplemental Medicare Premium and Federal Hospital Insurance Catastrophic Coverage Reserve Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/234/tI/s102/a"},"text":"Pub. L. 101–234, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-13"},"text":"Dec. 13, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1980"},"text":"103 Stat. 1980","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/234/tI/s102/a"},"text":"“Sections 111 and 112 of MCCA [","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360"},"text":"Pub. L. 100–360","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s59B"},"text":"section 59B of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395i–1a"},"text":"section 1395i–1a of Title 42","children":[],"tail":", The Public Health and Welfare, amended this section, and enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s59B"},"text":"section 59B of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395i–1a"},"text":"section 1395i–1a of Title 42","children":[],"tail":"] are repealed and the provisions of law amended by such sections are restored or revived as if such sections had not been enacted.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
