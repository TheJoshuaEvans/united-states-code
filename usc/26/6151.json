{"tag":"section","attrib":{"id":"id46ac9746-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6151"},"text":null,"children":[{"tag":"num","attrib":{"value":"6151"},"text":"§ 6151.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time and place for paying tax shown on returns","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46ac9747-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6151/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subchapter, when a return of tax is required under this title or regulations, the person required to make such return shall, without assessment or notice and demand from the Secretary, pay such tax to the internal revenue officer with whom the return is filed, and shall pay such tax at the time and place fixed for filing the return (determined without regard to any extension of time for filing the return).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46ac9748-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6151/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46ac9749-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6151/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income tax not computed by taxpayer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the taxpayer elects under section 6014 not to show the tax on the return, the amount determined by the Secretary as payable shall be paid within 30 days after the mailing by the Secretary to the taxpayer of a notice stating such amount and making demand therefor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ac974a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6151/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of government depositaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For authority of the Secretary to require payments to Government depositaries, see section 6302(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46ac974b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6151/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date fixed for payment of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which a tax is required to be paid on or before a certain date, or within a certain period, any reference in this title to the date fixed for payment of such tax shall be deemed a reference to the last day fixed for such payment (determined without regard to any extension of time for paying the tax).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46ac974c-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/757"},"text":"68A Stat. 757","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/713/s1/b"},"text":"Pub. L. 89–713, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1108"},"text":"80 Stat. 1108","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/452/s3/c/2"},"text":"Pub. L. 94–452, § 3(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-02"},"text":"Oct. 2, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1514"},"text":"90 Stat. 1514","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46ac974d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46ac974e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46ac974f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/452"},"text":"Pub. L. 94–452","children":[],"tail":" substituted “subchapter,” for “section,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/713"},"text":"Pub. L. 89–713","children":[],"tail":" substituted the revenue officer with whom the return is filed for the principal internal revenue officer for the internal revenue district in which the return is required to be filed as the description of the person to whom the tax is paid."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46ac9750-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46ac9751-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/452/s3/e"},"text":"Pub. L. 94–452, § 3(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-02"},"text":"Oct. 2, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1514"},"text":"90 Stat. 1514","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6158"},"text":"section 6158 of this title","children":[],"tail":" and amending this section and sections 6503 and 6601 of this title] shall take effect on "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":", with respect to sales after "},{"tag":"date","attrib":{"date":"1970-07-07"},"text":"July 7, 1970","children":[],"tail":", in taxable years ending after "},{"tag":"date","attrib":{"date":"1970-07-07"},"text":"July 7, 1970","children":[],"tail":", but only in the case of qualified bank holding corporations (within the meaning of section 1103(b) of the Internal Revenue Code of 1986 [formerly I.R.C. 1954], as amended by section 2(a) of this Act)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for certifying sales which have already taken place","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of section 6158(a) of the Internal Revenue Code of 1986 (as added by subsection (a) of this section) in the case of any sale which takes place on or before the 90th day after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1976-10-02"},"text":"Oct. 2, 1976","children":[],"tail":"], a certification by the Federal Reserve Board described in section 6158(a) shall be treated as made before the sale if application for such certification is made before the close of the 90th day after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1976-10-02"},"text":"Oct. 2, 1976","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Refund of tax.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any tax attributable to a sale which occurred before ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":", is payable in annual installments by reason of an election under section 6158(a) of the Internal Revenue Code of 1986, any portion of such tax for which the due date of the installment does not occur before "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":", shall, on application of the taxpayer, be treated as an overpayment of tax."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interest on overpayments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of section 6611(b) in the case of any overpayment attributable to subparagraph (A), the date of the overpayment shall be the day which is 6 months after the latest of the following:","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which application for refund or credit of such overpayment is filed,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the due date prescribed by law (determined without extensions) for filing the return of tax under chapter 1 of the Internal Revenue Code of 1986 for the taxable year the tax of which is being refunded or credited, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1976-10-02"},"text":"Oct. 2, 1976","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension of period of limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any refund or credit of tax attributable to the application of subparagraph (A) is prevented at any time before ","children":[{"tag":"date","attrib":{"date":"1978-10-01"},"text":"October 1, 1978","children":[],"tail":", by the operation of any law or rule of law, refund or credit of such overpayment may, nevertheless, be made or allowed if claim therefor is filed before "},{"tag":"date","attrib":{"date":"1978-10-01"},"text":"October 1, 1978","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46ac9752-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/713"},"text":"Pub. L. 89–713","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/713/s6"},"text":"section 6 of Pub. L. 89–713","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6091"},"text":"section 6091 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
