{"tag":"section","attrib":{"id":"id47bc5994-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9506"},"text":null,"children":[{"tag":"num","attrib":{"value":"9506"},"text":"§ 9506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inland Waterways Trust Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47bc5995-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of Trust Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established in the Treasury of the United States a trust fund to be known as the “Inland Waterways Trust Fund”, consisting of such amounts as may be appropriated or credited to such Trust Fund as provided in this section or section 9602(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47bc5996-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer to Trust Fund of amounts equivalent to certain taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are hereby appropriated to the Inland Waterways Trust Fund amounts equivalent to the taxes received in the Treasury under section 4042 (relating to tax on fuel used in commercial transportation on inland waterways). The preceding sentence shall apply only to so much of such taxes as are attributable to the Inland Waterways Trust Fund financing rate under section 4042(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47bc5997-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures from Trust Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47bc5998-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9506/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), amounts in the Inland Waterways Trust Fund shall be available, as provided by appropriation Acts, for making construction and rehabilitation expenditures for navigation on the inland and coastal waterways of the United States described in section 206 of the Inland Waterways Revenue Act of 1978, as in effect on the date of the enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47beca99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9506/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than ½ of the cost of any construction to which section 102(a) of the Water Resources Development Act of 1986 applies (as in effect on the date of the enactment of this section) may be paid from the Inland Waterways Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47beca9a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXIV/s1405/a"},"text":"Pub. L. 99–662, title XIV, § 1405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4271"},"text":"100 Stat. 4271","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/tV/s521/b/3"},"text":"Pub. L. 99–499, title V, § 521(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1778"},"text":"100 Stat. 1778","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1018/u/18"},"text":"Pub. L. 100–647, title I, § 1018(u)(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3591"},"text":"102 Stat. 3591","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47beca9b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47beca9c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id47beca9d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 206 of the Inland Waterways Revenue Act of 1978, as in effect on the date of the enactment of this section, referred to in subsec. (c)(1), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1804"},"text":"section 1804 of Title 33","children":[],"tail":", Navigation and Navigable Waters. The date of the enactment of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9506"},"text":"section 9506 of this title","children":[],"tail":" is the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/99/662"},"text":"Pub. L. 99–662","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 102(a) of the Water Resources Development Act of 1986 (as in effect on the date of enactment of this section), referred to in subsec. (c)(2), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2212/a"},"text":"section 2212(a) of Title 33","children":[],"tail":". The date of enactment of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9506"},"text":"section 9506 of this title","children":[],"tail":" is the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/99/662"},"text":"Pub. L. 99–662","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47beca9e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" made technical corrections to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/s521/b/3"},"text":"Pub. L. 99–499, § 521(b)(3)","children":[],"tail":", see 1986 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499"},"text":"Pub. L. 99–499","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1018/u/18"},"text":"Pub. L. 100–647, § 1018(u)(18)","children":[],"tail":", inserted at end “The preceding sentence shall apply only to so much of such taxes as are attributable to the Inland Waterways Trust Fund financing rate under section 4042(b).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47beca9f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47becaa0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47becaa1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499"},"text":"Pub. L. 99–499","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/s521/e"},"text":"section 521(e) of Pub. L. 99–499","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4041"},"text":"section 4041 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47becaa2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXIV/s1405/d"},"text":"Pub. L. 99–662, title XIV, § 1405(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4271"},"text":"100 Stat. 4271","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/662/tXIV/s1405/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting this section and repealing sections 1801 and 1802 of Title 33, Navigation and Navigable Waters] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inland waterways trust fund treated as continuation of old trust fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Inland Waterways Trust Fund established by the amendments made by this section shall be treated for all purposes of law as a continuation of the Inland Waterways Trust Fund established by section 203 of the Inland Waterways Revenue Act of 1978 [former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1801"},"text":"33 U.S.C. 1801","children":[],"tail":"]. Any reference in any law to the Inland Waterways Trust Fund established by such section 203 shall be deemed to include (wherever appropriate) a reference to the Inland Waterways Trust Fund established by this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
