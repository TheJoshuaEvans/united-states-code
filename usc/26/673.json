{"tag":"section","attrib":{"id":"id43f42dbd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s673"},"text":null,"children":[{"tag":"num","attrib":{"value":"673"},"text":"§ 673.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reversionary interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43f42dbe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s673/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The grantor shall be treated as the owner of any portion of a trust in which he has a reversionary interest in either the corpus or the income therefrom, if, as of the inception of that portion of the trust, the value of such interest exceeds 5 percent of the value of such portion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f42dbf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s673/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reversionary interest taking effect at death of minor lineal descendant beneficiary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any beneficiary who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43f42dc0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s673/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a lineal descendant of the grantor, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f42dc1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s673/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holds all of the present interests in any portion of a trust,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the grantor shall not be treated under subsection (a) as the owner of such portion solely by reason of a reversionary interest in such portion which takes effect upon the death of such beneficiary before such beneficiary attains age 21.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f42dc2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s673/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for determining value of reversionary interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), the value of the grantor’s reversionary interest shall be determined by assuming the maximum exercise of discretion in favor of the grantor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f42dc3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s673/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postponement of date specified for reacquisition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any postponement of the date specified for the reacquisition of possession or enjoyment of the reversionary interest shall be treated as a new transfer in trust commencing with the date on which the postponement is effective and terminating with the date prescribed by the postponement. However, income for any period shall not be included in the income of the grantor by reason of the preceding sentence if such income would not be so includible in the absence of such postponement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43f42dc4-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/227"},"text":"68A Stat. 227","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tII/s201/c"},"text":"Pub. L. 91–172, title II, § 201(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/560"},"text":"83 Stat. 560","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIV/s1402/a"},"text":"Pub. L. 99–514, title XIV, § 1402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2711"},"text":"100 Stat. 2711","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1014/b"},"text":"Pub. L. 100–647, title I, § 1014(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3559"},"text":"102 Stat. 3559","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43f42dc5-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43f42dc6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43f42dc7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" added subsecs. (c) and (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" amended section generally, substituting “the value of such interest exceeds 5 percent of the value of such portion” for “the interest will or may reasonably be expected to take effect in possession or enjoyment within 10 years commencing with the date of the transfer of that portion of the trust” in subsec. (a), adding subsec. (b), striking out subsec. (c) which provided that the grantor not be treated under subsec. (a) as the owner of any portion of a trust where his reversionary interest in such portion was not to take effect in possession or enjoyment until the death of the persons to whom the income therefrom was payable, and subsec. (d) which provided that any postponement of the date specified for the reacquisition of possession or enjoyment of the reversionary interest be treated as a new transfer in trust commencing with the date on which the postponement was effected and terminating with the date prescribed by the postponement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" struck out provisions relating to trusts where the income was payable to a charitable beneficiary for at least a two-year period."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43f42dc8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43f42dc9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43f42dca-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIV/s1402/c"},"text":"Pub. L. 99–514, title XIV, § 1402(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2712"},"text":"100 Stat. 2712","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXIV/s1402/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the amendments made by this section [amending this section and sections 674, 676, and 677 of this title] shall apply with respect to transfers in trust made after ","children":[{"tag":"date","attrib":{"date":"1986-03-01"},"text":"March 1, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfers pursuant to property settlement agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section shall not apply to any transfer in trust made after ","children":[{"tag":"date","attrib":{"date":"1986-03-01"},"text":"March 1, 1986","children":[],"tail":", pursuant to a binding property settlement agreement entered into on or before "},{"tag":"date","attrib":{"date":"1986-03-01"},"text":"March 1, 1986","children":[],"tail":", which required the taxpayer to establish a grantor trust and for the transfer of a specified sum of money or property to the trust by the taxpayer. This paragraph shall apply only to the extent of the amount required to be transferred under the agreement described in the preceding sentence.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43f42dcb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1969 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" applicable to transfers in trust made after "},{"tag":"date","attrib":{"date":"1969-04-22"},"text":"April 22, 1969","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/s201/g/3"},"text":"section 201(g)(3) of Pub. L. 91–172","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s170"},"text":"section 170 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
