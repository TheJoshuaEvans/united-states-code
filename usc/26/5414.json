{"tag":"section","attrib":{"id":"id463c705b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5414"},"text":null,"children":[{"tag":"num","attrib":{"value":"5414"},"text":"§ 5414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of beer between bonded facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id463c705c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beer may be removed from one brewery to another brewery, without payment of tax, and may be mingled with beer at the receiving brewery, subject to such conditions, including payment of the tax, and in such containers, as the Secretary by regulations shall prescribe, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id463c705d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5414/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any removal from one brewery to another brewery belonging to the same brewer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463c705e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5414/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any removal from a brewery owned by one corporation to a brewery owned by another corporation when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id463c705f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5414/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one such corporation owns the controlling interest in the other such corporation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id463c7060-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5414/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the controlling interest in each such corporation is owned by the same person or persons, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463c7061-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5414/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any removal from one brewery to another brewery when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id463c7062-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5414/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proprietors of transferring and receiving premises are independent of each other and neither has a proprietary interest, directly or indirectly, in the business of the other, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id463c7063-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5414/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transferor has divested itself of all interest in the beer so transferred and the transferee has accepted responsibility for payment of the tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id463c7064-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5414/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of liability for tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a)(3), such relief from liability shall be effective from the time of removal from the transferor’s premises, or from the time of divestment of interest, whichever is later.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id463c7065-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1389"},"text":"72 Stat. 1389","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13803/a"},"text":"Pub. L. 115–97, title I, § 13803(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2172"},"text":"131 Stat. 2172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dQ/tI/s144/c/1"},"text":"Pub. L. 116–94, div. Q, title I, § 144(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3235"},"text":"133 Stat. 3235","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/tI/s106/c/1"},"text":"Pub. L. 116–260, div. EE, title I, § 106(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3042"},"text":"134 Stat. 3042","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id463c7066-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id463c7067-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id463c7068-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5414, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/675"},"text":"68A Stat. 675","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id463c7069-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" amended section generally. Prior to amendment, section related to removals of beer from one brewery to another belonging to the same brewer."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":