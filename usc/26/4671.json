{"tag":"section","attrib":{"id":"id45df83c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4671"},"text":null,"children":[{"tag":"num","attrib":{"value":"4671"},"text":"§ 4671.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45df83c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4671/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed a tax on any taxable substance sold or used by the importer thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45df83c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4671/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45df83c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4671/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the amount of the tax imposed by subsection (a) with respect to any taxable substance shall be the amount of the tax which would have been imposed by section 4661 on the taxable chemicals used as materials in the manufacture or production of such substance if such taxable chemicals had been sold in the United States for use in the manufacture or production of such taxable substance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45df83ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4671/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate where importer does not furnish information to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the importer does not furnish to the Secretary (at such time and in such manner as the Secretary shall prescribe) sufficient information to determine under paragraph (1) the amount of the tax imposed by subsection (a) on any taxable substance, the amount of the tax imposed on such taxable substance shall be 10 percent of the appraised value of such substance as of the time such substance was entered into the United States for consumption, use, or warehousing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45df83cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4671/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to prescribe rate in lieu of paragraph (2) rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prescribe for each taxable substance a tax which, if prescribed, shall apply in lieu of the tax specified in paragraph (2) with respect to such substance. The tax prescribed by the Secretary shall be equal to the amount of tax which would be imposed by subsection (a) with respect to the taxable substance if such substance were produced using the predominant method of production of such substance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45df83cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4671/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions for substances taxed under sections 4611 and 4661","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No tax shall be imposed by this section on the sale or use of any substance if tax is imposed on such sale or use under section 4611 or 4661.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45df83cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4671/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax-free sales, etc. for substances used as certain fuels or in the production of fertilizer or animal feed","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Rules similar to the following rules shall apply for purposes of applying this section with respect to taxable substances used or sold for use as described in such rules:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45df83ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4671/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraphs (2), (5), and (9) of section 4662(b) (relating to tax-free sales of chemicals used as fuel or in the production of fertilizer or animal feed).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45df83cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4671/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraphs (2), (3), and (4) of section 4662(d) (relating to refund or credit of tax on certain chemicals used as fuel or in the production of fertilizer or animal feed).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45df83d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4671/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No tax shall be imposed by this section after ","children":[{"tag":"date","attrib":{"date":"2031-12-31"},"text":"December 31, 2031","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45df83d1-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499/tV/s515/a"},"text":"Pub. L. 99–499, title V, § 515(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1767"},"text":"100 Stat. 1767","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tVIII/s8032/c/3"},"text":"Pub. L. 99–509, title VIII, § 8032(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1958"},"text":"100 Stat. 1958","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dH/tII/s80201/a/2"},"text":"Pub. L. 117–58, div. H, title II, § 80201(a)(2)","children":[],"tail":", (b)(2), "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1328"},"text":"135 Stat. 1328","children":[],"tail":", 1330.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45df83d2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45df83d3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45df83d4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s80201/b/2"},"text":"Pub. L. 117–58, § 80201(b)(2)","children":[],"tail":", substituted “10 percent” for “5 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s80201/a/2"},"text":"Pub. L. 117–58, § 80201(a)(2)","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, text read as follows: “No tax shall be imposed under this section during any period during which the Hazardous Substance Superfund financing rate under section 4611 does not apply.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509"},"text":"Pub. L. 99–509","children":[],"tail":" substituted “the Hazardous Substance Superfund financing rate under section 4611 does not apply” for “no tax is imposed under section 4611(a)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45df83d5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45df83d6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-07-01"},"text":"July 1, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s80201/d"},"text":"section 80201(d) of Pub. L. 117–58","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4661"},"text":"section 4661 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45df83d7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509"},"text":"Pub. L. 99–509","children":[],"tail":" effective on commencement date as defined in former section 4611(f)(2), see "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/s8032/d"},"text":"section 8032(d) of Pub. L. 99–509","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4611"},"text":"section 4611 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45df83d8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499/tV/s515/c"},"text":"Pub. L. 99–499, title V, § 515(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1769"},"text":"100 Stat. 1769","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/499/tV/s515/c"},"text":"“The amendments made by this section [enacting this subchapter] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id45df83d9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study and Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499/tV/s515/d"},"text":"Pub. L. 99–499, title V, § 515(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1769"},"text":"100 Stat. 1769","children":[],"tail":", directed the Secretary of the Treasury or his delegate to conduct a study of issues relating to the implementation of the tax imposed by this section and certain credit for exports of taxable substances, and report to Congress not later than "},{"tag":"date","attrib":{"date":"1988-01-01"},"text":"Jan. 1, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
