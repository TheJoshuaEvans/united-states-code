{"tag":"section","attrib":{"id":"id43f42d93-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s671"},"text":null,"children":[{"tag":"num","attrib":{"value":"671"},"text":"§ 671.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust income, deductions, and credits attributable to grantors and others as substantial owners","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where it is specified in this subpart that the grantor or another person shall be treated as the owner of any portion of a trust, there shall then be included in computing the taxable income and credits of the grantor or the other person those items of income, deductions, and credits against tax of the trust which are attributable to that portion of the trust to the extent that such items would be taken into account under this chapter in computing taxable income or credits against the tax of an individual. Any remaining portion of the trust shall be subject to subparts A through D. No items of a trust shall be included in computing the taxable income and credits of the grantor or of any other person solely on the grounds of his dominion and control over the trust under section 61 (relating to definition of gross income) or any other provision of this title, except as specified in this subpart.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id43f42d94-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/226"},"text":"68A Stat. 226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43f42d95-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43f42d96-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id43f42d97-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Certain Entities Not Treated as Corporations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s646"},"text":"Pub. L. 99–514, title VI, § 646","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2292"},"text":"100 Stat. 2292","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/k"},"text":"Pub. L. 100–647, title I, § 1006(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3411"},"text":"102 Stat. 3411","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1006/k"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of the Internal Revenue Code of 1986, if the entity described in subsection (b) makes an election under subsection (c), such entity shall be treated as a trust to which subpart E of part 1 of subchapter J of chapter 1 of such Code applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Entity","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity is described in this subsection if—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such entity was created in 1906 as a common law trust and is governed by the trust laws of the State of Minnesota,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such entity is exclusively engaged in the leasing of mineral property and activities incidental thereto, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" income interests in such entity are publicly traded as of ","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":", on a national stock exchange."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An election under this subsection to have the provisions of this section apply—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made by the board of trustees of the entity before ","children":[{"tag":"date","attrib":{"date":"1991-01-01"},"text":"January 1, 1991","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be valid unless accompanied by an agreement described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The agreement described in this paragraph is a written agreement signed by the board of trustees of the entity which provides that the entity will not acquire any additional property other than property described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Permissible acquisitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Property is described in this paragraph if it is—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" surface rights to property the acquisition of which—","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"     “(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to mine mineral rights held on ","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"     “(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required by a written binding agreement between the entity and an unrelated person entered into on or before ","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" surface rights to property which are not described in clause (i) and which—","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"     “(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are acquired in an exchange to which section 1031 [probably means ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1031"},"text":"section 1031 of this title","children":[],"tail":"] applies, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"     “(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are necessary to mine mineral rights held on ","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tangible personal property incidental to the leasing of mineral property and activities incidental thereto, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"“(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part of any required reserves of the entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Beginning of period for which election is in effect","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The period during which an election is in effect under this subsection shall begin on the 1st day of the 1st taxable year beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":"] and following the taxable year in which the election is made."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Manner of election","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any election under this subsection shall be made in such manner as the Secretary of the Treasury or his delegate may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rules for Taxation of Trust.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election treated as a liquidation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an election is made under subsection (c) with respect to any entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such entity shall be treated as having been liquidated into a trust immediately before the period described in subsection (c)(3) in a liquidation to which section 333 of the Internal Revenue Code of 1954 (as in effect before the amendments made by this Act) applies, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for purposes of section 333 of such Code (as so in effect)—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person holding an income interest in such entity as of such time shall be treated as a qualified electing shareholder, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the earnings and profits, and the value of money or stock or securities, of such entity shall be apportioned ratably among persons described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The amendments made by subtitle D of this title [subtitle D (§§ 631–634) of title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", see Tables for classification] and section 1804 of this Act [see Tables for classification] shall not apply to any liquidation under this paragraph."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of election","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an entity ceases to be described in subsection (b) or violates any term of the agreement described in subsection (c)(2), the entity shall, for purposes of the Internal Revenue Code of 1986, be treated as a corporation for the taxable year in which such cessation or violation occurs and for all subsequent taxable years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Trust ceasing to exist","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (2) shall not apply if the trust ceases to be described in subsection (b) or violates the agreement in subsection (c)(2) because the trust ceases to exist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rule for Persons Holding Income Interests","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In applying subpart E of part I of subchapter J of chapter 1 of the Internal Revenue Code of 1986 to any entity to which this section applies—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reversionary interest shall not be taken into account until it comes into possession, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all items of income, gain, loss, deduction, and credit shall be allocated to persons holding income interests for the period of the allocation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
