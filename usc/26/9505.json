{"tag":"section","attrib":{"id":"id47bc5981-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9505"},"text":null,"children":[{"tag":"num","attrib":{"value":"9505"},"text":"§ 9505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harbor Maintenance Trust Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47bc5982-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of Trust Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby established in the Treasury of the United States a trust fund to be known as the “Harbor Maintenance Trust Fund”, consisting of such amounts as may be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47bc5983-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriated to the Harbor Maintenance Trust Fund as provided in this section,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47bc5984-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transferred to the Harbor Maintenance Trust Fund by the Great Lakes St. Lawrence Seaway Development Corporation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-05-13/s13/a"},"text":"section 13(a) of the Act of May 13, 1954","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47bc5985-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9505/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" credited to the Harbor Maintenance Trust Fund as provided in section 9602(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47bc5986-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer to Harbor Maintenance Trust Fund of amounts equivalent to certain taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are hereby appropriated to the Harbor Maintenance Trust Fund amounts equivalent to the taxes received in the Treasury under section 4461 (relating to harbor maintenance tax).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47bc5987-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures from Harbor Maintenance Trust Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts in the Harbor Maintenance Trust Fund shall be available, as provided by appropriation Acts, for making expenditures—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47bc5988-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9505/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out section 210 of the Water Resources Development Act of 1986,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47bc5989-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9505/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for payments of rebates of tolls or charges pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-05-13/s13/b"},"text":"section 13(b) of the Act of May 13, 1954","children":[],"tail":" (as in effect on "},{"tag":"date","attrib":{"date":"1987-04-01"},"text":"April 1, 1987","children":[],"tail":"), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47bc598a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9505/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the payment of all expenses of administration incurred by the Department of the Treasury, the Army Corps of Engineers, and the Department of Commerce related to the administration of subchapter A of chapter 36 (relating to harbor maintenance tax), but not in excess of $5,000,000 for any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47bc598b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXIV/s1403/a"},"text":"Pub. L. 99–662, title XIV, § 1403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4269"},"text":"100 Stat. 4269","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s683/a"},"text":"Pub. L. 103–182, title VI, § 683(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2218"},"text":"107 Stat. 2218","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/303/tVI/s601"},"text":"Pub. L. 104–303, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3792"},"text":"110 Stat. 3792","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tII/s2102/c"},"text":"Pub. L. 113–121, title II, § 2102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1278"},"text":"128 Stat. 1278","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tV/s512/c/3"},"text":"Pub. L. 116–260, div. AA, title V, § 512(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2756"},"text":"134 Stat. 2756","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47bc598c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47bc598d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id47bc598e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1954-05-13/s13"},"text":"Section 13 of the Act of May 13, 1954","children":[],"tail":", referred to in subsecs. (a)(2) and (c)(2), is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s988a"},"text":"section 988a of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 210 of the Water Resources Development Act of 1986, referred to in subsec. (c)(1), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2238"},"text":"section 2238 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47bc598f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “Great Lakes St. Lawrence Seaway Development Corporation” for “Saint Lawrence Seaway Development Corporation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121"},"text":"Pub. L. 113–121","children":[],"tail":" struck out “(as in effect on the date of the enactment of the Water Resources Development Act of 1996)” after “1986”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303"},"text":"Pub. L. 104–303","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “to carry out section 210(a) of the Water Resources Development Act of 1986 (as in effect on the date of enactment of this section),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":" amended par. (3) generally. Prior to amendment, par. (3) read as follows: “for the payment of all expenses of administration incurred—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) by the Department of the Treasury in administering subchapter A of chapter 36 (relating to harbor maintenance tax), but not in excess of $5,000,000 for any fiscal year, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) for periods during which no fee applies under paragraph (9) or (10) of section 13031(a) of the Consolidated Omnibus Budget Reconciliation Act of 1985.”","children":[],"tail":"\n"}],"tail":"