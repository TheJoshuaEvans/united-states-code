{"tag":"section","attrib":{"id":"id46b60cf3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6206"},"text":null,"children":[{"tag":"num","attrib":{"value":"6206"},"text":"§ 6206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules applicable to excessive claims under certain sections","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any portion of a refund made under section 6416(a)(4) and any portion of a payment made under section 6420, 6421, 6427, or 6435 which constitutes an excessive amount (as defined in section 6675(b)), and any civil penalty provided by section 6675, may be assessed and collected as if it were a tax imposed by section 4081 (with respect to refunds under section 6416(a)(4) and payments under sections 6420, 6421, and 6435), or 4041 or 4081 (with respect to payments under section 6427) and as if the person who made the claim were liable for such tax. The period for assessing any such portion, and for assessing any such penalty, shall be 3 years from the last day prescribed for the filing of the claim under section 6416(a)(4), 6420, 6421, 6427, or 6435, as the case may be.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id46b60cf4-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-04-02/ch160/s4/b/1"},"text":"Apr. 2, 1956, ch. 160, § 4(b)(1)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/90"},"text":"70 Stat. 90","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1956-06-29/ch462"},"text":"June 29, 1956, ch. 462","children":[],"tail":", title II, § 208(d)(1), "},{"tag":"ref","attrib":{"href":"/us/stat/70/396"},"text":"70 Stat. 396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tII/s202/c/2/A"},"text":"Pub. L. 89–44, title II, § 202(c)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/139"},"text":"79 Stat. 139","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/258/tII/s207/d/3"},"text":"Pub. L. 91–258, title II, § 207(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-05-21"},"text":"May 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/248"},"text":"84 Stat. 248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/424/tV/s515/b/3/A"},"text":"Pub. L. 97–424, title V, § 515(b)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-06"},"text":"Jan. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2181"},"text":"96 Stat. 2181","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10502/d/5"},"text":"Pub. L. 100–203, title X, § 10502(d)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-444"},"text":"101 Stat. 1330–444","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13242/d/14"},"text":"Pub. L. 103–66, title XIII, § 13242(d)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/524"},"text":"107 Stat. 524","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s853/d/2/F"},"text":"Pub. L. 108–357, title VIII, § 853(d)(2)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1613"},"text":"118 Stat. 1613","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11163/d/1"},"text":"Pub. L. 109–59, title XI, § 11163(d)(1)","children":[],"tail":", "},{"tag":"date","at