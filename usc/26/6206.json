on of a refund made under section 6416(a)(4) and any portion” for “Any portion” and “refunds under section 6416(a)(4) and payments under sections 6420” for “payments under sections 6420”, and in second sentence substituted “section 6416(a)(4), 6420” for “section 6420”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" substituted “or 4081” for “, 4081, or 4091”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" substituted “4041, 4081, or 4091” for “4041 or 4091”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" substituted “or 4041 or 4091” for “or 4041”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/424"},"text":"Pub. L. 97–424","children":[],"tail":" struck out reference to section 6424 in section catchline, and in text struck out “4091 (with respect to payments under section 6424),” after “6421),”, and “6424,” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/258"},"text":"Pub. L. 91–258","children":[],"tail":" inserted reference to section 6427 in section catchline, inserted reference to section 6427 in first and second sentences, and substituted “by section 4081 (with respect to payments under sections 6420 and 6421), 4091 (with respect to payments under section 6424), or 4041 (with respect to payments under section 6427)” for “by section 4081 (or, in the case of lubricating oil, by section 4091)”, in first sentence, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" struck out “6420 and 6421” wherever appearing in section catchline and text and substituted therefor “6420, 6421, and 6424” and inserted “(or, in the case of lubricating oil, by section 4091)” after “4081” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-06-29"},"text":"June 29, 1956","children":[],"tail":", inserted reference to excessive claims under section 6421 in section catchline and text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46b60cf9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46b60cfa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70525/c"},"text":"Pub. L. 119–21, title VII, § 70525(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/283"},"text":"139 Stat. 283","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70525/c"},"text":"“The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6435"},"text":"section 6435 of this title","children":[],"tail":" and amending this section and sections 6430 and 6675 of this title] shall apply to eligible indelibly dyed diesel fuel or kerosene removed on or after the date that is 180 days after the date of the enactment of this section ["},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":"].