{"tag":"section","attrib":{"id":"id45edb335-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4944"},"text":null,"children":[{"tag":"num","attrib":{"value":"4944"},"text":"§ 4944.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxes on investments which jeopardize charitable purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45edb336-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4944/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial taxes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45edb337-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4944/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On the private foundation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a private foundation invests any amount in such a manner as to jeopardize the carrying out of any of its exempt purposes, there is hereby imposed on the making of such investment a tax equal to 10 percent of the amount so invested for each year (or part thereof) in the taxable period. The tax imposed by this paragraph shall be paid by the private foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45edb338-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4944/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On the management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which a tax is imposed by paragraph (1), there is hereby imposed on the participation of any foundation manager in the making of the investment, knowing that it is jeopardizing the carrying out of any of the foundation’s exempt purposes, a tax equal to 10 percent of the amount so invested for each year (or part thereof) in the taxable period, unless such participation is not willful and is due to reasonable cause. The tax imposed by this paragraph shall be paid by any foundation manager who participated in the making of the investment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45edb339-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4944/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional taxes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45edb33a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4944/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On the foundation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which an initial tax is imposed by subsection (a)(1) on the making of an investment and such investment is not removed from jeopardy within the taxable period, there is hereby imposed a tax equal to 25 percent of the amount of the investment. The tax imposed by this paragraph shall be paid by the private foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45edb33b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4944/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On the management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which an additional tax is imposed by paragraph (1), if a foundation manager refused to agree to part or all of the removal from jeopardy, there is hereby imposed a tax equal to 5 percent of the amount of the investment. The tax imposed by this paragraph shall be paid by any foundation manager who refused to agree to part or all of the removal from jeopardy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45edb33c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4944/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for program-related investments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, investments, the primary purpose of which is to accomplish one or more of the purposes described in section 170(c)(2)(B), and no significant purpose of which is the production of income or the appreciation of property, shall not be considered as investments which jeopardize the carrying out of exempt purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45edb33d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4944/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsections (a) and (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45edb33e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4944/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint and several liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If more than one person is liable under subsection (a)(2) or (b)(2) with respect to any one investment, all such persons shall be jointly and severally liable under such paragraph with respect to such investment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45edb33f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4944/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit for management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any one investment, the maximum amount of the tax imposed by subsection (a)(2) shall not exceed $10,000, and the maximum amount of the tax imposed by subsection (b)(2) shall not exceed $20,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45edb340-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4944/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45edb341-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4944/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “taxable period” means, with respect to any investment which jeopardizes the carrying out of exempt purposes, the period beginning with the date on which the amount is so invested and ending on the earliest of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45edb342-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4944/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of mailing of a notice of deficiency with respect to the tax imposed by subsection (a)(1) under section 6212,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45edb343-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4944/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the tax imposed by subsection (a)(1) is assessed, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45edb344-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4944/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the amount so invested is removed from jeopardy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45edb345-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4944/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal from jeopardy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An investment which jeopardizes the carrying out of exempt purposes shall be considered to be removed from jeopardy when such investment is sold or otherwise disposed of, and the proceeds of such sale or other disposition are not investments which jeopardize the carrying out of exempt purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45edb346-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tI/s101/b"},"text":"Pub. L. 91–172, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/511"},"text":"83 Stat. 511","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/596/s2/a/1/E"},"text":"Pub. L. 96–596, § 2(a)(1)(E)","children":[],"tail":", (2)(D), (3)(D), "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3469-3471"},"text":"94 Stat. 3469–3471","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1212/d"},"text":"Pub. L. 109–280, title XII, § 1212(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1074"},"text":"120 Stat. 1074","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45edb347-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45edb348-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id45edb349-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1212/d"},"text":"Section 1212(d) of Pub. L. 109–280","children":[],"tail":", which directed the amendment of section 4944 without specifying the act to be amended, was executed to this section, which is section 4944 of the Internal Revenue Code of 1986, to reflect the probable intent of Congress. See 2006 Amendment notes below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45edb34a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1212/d/1"},"text":"Pub. L. 109–280, § 1212(d)(1)","children":[],"tail":", substituted “10 percent” for “5 percent” in pars. (1) and (2). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1212/d/2"},"text":"Pub. L. 109–280, § 1212(d)(2)","children":[],"tail":", substituted “$10,000,” for “$5,000,” and “$20,000.” for “$10,000.” See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/596/s2/a/1/E"},"text":"Pub. L. 96–596, § 2(a)(1)(E)","children":[],"tail":", substituted “taxable period” for “correction period”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/596/s2/a/2/D"},"text":"Pub. L. 96–596, § 2(a)(2)(D)","children":[],"tail":", added subpar. (B) and redesignated former subpar. (B) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/596/s2/a/3/D"},"text":"Pub. L. 96–596, § 2(a)(3)(D)","children":[],"tail":", struck out par. (3), which defined correction period, with respect to any investment which jeopardizes the carrying out of exempt purposes, as the period beginning with the date on which such investment is entered into and ending 90 days after the date of mailing of a notice of deficiency with respect to the tax imposed by subsec. (b)(1) of this section under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6212"},"text":"section 6212 of this title","children":[],"tail":", extended by any period in which a deficiency cannot be assessed under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6213/a"},"text":"section 6213(a) of this title","children":[],"tail":" and any other period which the Secretary determines is reasonable and necessary to bring about removal from jeopardy."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (e)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45edb34b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45edb34c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1212/f"},"text":"section 1212(f) of Pub. L. 109–280","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4941"},"text":"section 4941 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45edb34d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/596"},"text":"Pub. L. 96–596","children":[],"tail":" with respect to any first tier tax and to any second tier tax, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/596/s2/d"},"text":"section 2(d) of Pub. L. 96–596","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4961"},"text":"section 4961 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
