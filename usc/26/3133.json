{"tag":"section","attrib":{"id":"id456cebb0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3133"},"text":null,"children":[{"tag":"num","attrib":{"value":"3133"},"text":"§ 3133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule related to tax on employers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id456cebb1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3133/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The credit allowed by section 3131 and the credit allowed by section 3132 shall each be increased by the amount of the taxes imposed by subsections (a) and (b) of section 3111 and section 3221(a) on qualified sick leave wages, or qualified family leave wages, for which credit is allowed under such section 3131 or 3132 (respectively).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id456cebb2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3133/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of double benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For denial of double benefit with respect to the credit increase under subsection (a), see sections 3131(f)(3) and 3132(f)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id456cebb3-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIX/s9641/a"},"text":"Pub. L. 117–2, title IX, § 9641(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/171"},"text":"135 Stat. 171","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id456cebb4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id456cebb5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id456cebb6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to amounts paid with respect to calendar quarters beginning after ","children":[{"tag":"date","attrib":{"date":"2021-03-31"},"text":"Mar. 31, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/s9641/d"},"text":"section 9641(d) of Pub. L. 117–2","children":[],"tail":", set out as a note under secton 3131 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
