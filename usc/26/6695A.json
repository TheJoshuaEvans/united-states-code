{"tag":"section","attrib":{"id":"id472fa93d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695A"},"text":null,"children":[{"tag":"num","attrib":{"value":"6695A"},"text":"§ 6695A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial and gross valuation misstatements attributable to incorrect appraisals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id472fa93e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472fa93f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person prepares an appraisal of the value of property and such person knows, or reasonably should have known, that the appraisal would be used in connection with a return or a claim for refund, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472fa940-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claimed value of the property on a return or claim for refund which is based on such appraisal results in a substantial valuation misstatement under chapter 1 (within the meaning of section 6662(e)), a substantial estate or gift tax valuation understatement (within the meaning of section 6662(g)), or a gross valuation misstatement (within the meaning of section 6662(h)), with respect to such property,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then such person shall pay a penalty in the amount determined under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472fa941-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the penalty imposed under subsection (a) on any person with respect to an appraisal shall be equal to the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472fa942-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id472fa943-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent of the amount of the underpayment (as defined in section 6664(a)) attributable to the misstatement described in subsection (a)(2), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id472fa944-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472fa945-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 125 percent of the gross income received by the person described in subsection (a)(1) from the preparation of the appraisal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472fa946-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed under subsection (a) if the person establishes to the satisfaction of the Secretary that the value established in the appraisal was more likely than not the proper value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id472fa947-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1219/b/1"},"text":"Pub. L. 109–280, title XII, § 1219(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1084"},"text":"120 Stat. 1084","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/172"},"text":"Pub. L. 110–172","children":[],"tail":", §§ 3(e)(1), 11(a)(40), "},{"tag":"date","attrib":{"date":"2007-12-29"},"text":"Dec. 29, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2474"},"text":"121 Stat. 2474","children":[],"tail":", 2488.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id472fa948-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id472fa949-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id472fa94a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1219/b/1"},"text":"Section 1219(b)(1) of Pub. L. 109–280","children":[],"tail":", which directed the addition of section 6695A at the end of part I of subchapter B of chapter 68, without specifying the act to be amended, was executed by adding section 6695A at the end of part I of subchapter B of chapter 68 of this title, which consists of the Internal Revenue Code of 1986, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id472fa94b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172/s11/a/40"},"text":"Pub. L. 110–172, § 11(a)(40)","children":[],"tail":", designated the words “then such person shall pay a penalty in the amount determined under subsection (b).”, appearing in par. (2), as concluding provisions of subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172/s3/e/1"},"text":"Pub. L. 110–172, § 3(e)(1)","children":[],"tail":", inserted “a substantial estate or gift tax valuation understatement (within the meaning of section 6662(g)),” before “or a gross valuation misstatement”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id472fa94c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id472fa94d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172/s3/e/1"},"text":"section 3(e)(1) of Pub. L. 110–172","children":[],"tail":" effective as if included in the provisions of the Pension Protection Act of 2006, "},{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/172/s3/j"},"text":"section 3(j) of Pub. L. 110–172","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s170"},"text":"section 170 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id472fa94e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to appraisals prepared with respect to returns or submissions filed after ","children":[{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", with special rule for certain easements, see section 1219(e)(2), (3) of "},{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":", set out as an Effective Date of 2006 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s170"},"text":"section 170 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
