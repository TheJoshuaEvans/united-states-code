{"tag":"section","attrib":{"id":"id44028593-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s733"},"text":null,"children":[{"tag":"num","attrib":{"value":"733"},"text":"§ 733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis of distributee partner’s interest","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In the case of a distribution by a partnership to a partner other than in liquidation of a partner’s interest, the adjusted basis to such partner of his interest in the partnership shall be reduced (but not below zero) by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44028594-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s733/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any money distributed to such partner, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44028595-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s733/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the basis to such partner of distributed property other than money, as determined under section 732.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44028596-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/247"},"text":"68A Stat. 247","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
