{"tag":"section","attrib":{"id":"id47d69826-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825"},"text":null,"children":[{"tag":"num","attrib":{"value":"9825"},"text":"§ 9825.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting on pharmacy benefits and drug costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47d69827-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of the Consolidated Appropriations Act, 2021, and not later than June 1 of each year thereafter, a group health plan shall submit to the Secretary, the Secretary of Health and Human Services, and the Secretary of Labor the following information with respect to the health plan in the previous plan year:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47d69828-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The beginning and end dates of the plan year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d69829-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of participants and beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d6982a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each State in which the plan is offered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d6982b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The 50 brand prescription drugs most frequently dispensed by pharmacies for claims paid by the plan, and the total number of paid claims for each such drug.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d6982c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The 50 most costly prescription drugs with respect to the plan by total annual spending, and the annual amount spent by the plan for each such drug.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d6982d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The 50 prescription drugs with the greatest increase in plan expenditures over the plan year preceding the plan year that is the subject of the report, and, for each such drug, the change in amounts expended by the plan in each such plan year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d6982e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Total spending on health care services by such group health plan, broken down by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47d6982f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the type of costs, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47d69830-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hospital costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47d69831-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care provider and clinical service costs, for primary care and specialty care separately;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47d69832-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs for prescription drugs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47d69833-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/7/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other medical costs, including wellness services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d69834-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" spending on prescription drugs by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47d69835-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the health plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47d69836-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participants and beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d69837-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The average monthly premium—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47d69838-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid by employers on behalf of participants and beneficiaries, as applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d69839-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid by participants and beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d6983a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any impact on premiums by rebates, fees, and any other remuneration paid by drug manufacturers to the plan or its administrators or service providers, with respect to prescription drugs prescribed to participants or beneficiaries in the plan, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47d6983b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts so paid for each therapeutic class of drugs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d6983c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts so paid for each of the 25 drugs that yielded the highest amount of rebates and other remuneration under the plan from drug manufacturers during the plan year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d6983d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any reduction in premiums and out-of-pocket costs associated with rebates, fees, or other remuneration described in paragraph (9).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47d6983e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after the date on which the first report is required under subsection (a) and biannually thereafter, the Secretary, acting in coordination with the Inspector General of the Department of the Treasury, shall make available on the internet website of the Department of the Treasury a report on prescription drug reimbursements under group health plans, prescription drug pricing trends, and the role of prescription drug costs in contributing to premium increases or decreases under such plans, aggregated in such a way as no drug or plan specific information will be made public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47d6983f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9825/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy protections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No confidential or trade secret information submitted to the Secretary under subsection (a) shall be included in the report under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47d69840-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/tII/s204/c"},"text":"Pub. L. 116–260, div. BB, title II, § 204(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2920"},"text":"134 Stat. 2920","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47d69841-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47d69842-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id47d69843-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Consolidated Appropriations Act, 2021, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
