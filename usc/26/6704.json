{"tag":"section","attrib":{"id":"id47321b07-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6704"},"text":null,"children":[{"tag":"num","attrib":{"value":"6704"},"text":"§ 6704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to keep records necessary to meet reporting requirements under section 6047(d)","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47321b08-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47321b09-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a duty to report or may have a duty to report any information under section 6047(d), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47321b0a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to keep such records as may be required by regulations prescribed under section 6047(d) for the purpose of providing the necessary data base for either current reporting or future reporting,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall pay a penalty for each calendar year for which there is any failure to keep such records.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47321b0b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of penalty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47321b0c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalty of any person for any calendar year shall be $50, multiplied by the number of individuals with respect to whom such failure occurs in such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47321b0d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalty under this section of any person for any calendar year shall not exceed $50,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47321b0e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47321b0f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6704/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable cause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed by this section on any person for any failure which is shown to be due to reasonable cause and not to willful neglect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47321b10-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6704/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inability to correct previous failure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed by this section on any failure by a person if such failure is attributable to a prior failure which has been penalized under this section and with respect to which the person has made all reasonable efforts to correct the failure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47321b11-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6704/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pre-1983 failures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed by this section on any person for any failure which is attributable to a failure occurring before ","children":[{"tag":"date","attrib":{"date":"1983-01-01"},"text":"January 1, 1983","children":[],"tail":", if the person has made all reasonable efforts to correct such pre-1983 failure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47321b12-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s334/c/1"},"text":"Pub. L. 97–248, title III, § 334(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/627"},"text":"96 Stat. 627","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1848/e/1"},"text":"Pub. L. 99–514, title XVIII, § 1848(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2857"},"text":"100 Stat. 2857","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47321b13-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47321b14-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47321b15-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “section 6047(d)” for “section 6047(e)” in section catchline and in subsec. (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47321b16-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47321b17-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47321b18-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1985-01-01"},"text":"Jan. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/s334/e/3"},"text":"section 334(e)(3) of Pub. L. 97–248","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3405"},"text":"section 3405 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id47321b19-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1800–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children"