{"tag":"section","attrib":{"id":"id47abb837-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9036"},"text":null,"children":[{"tag":"num","attrib":{"value":"9036"},"text":"§ 9036.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification by Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47abb838-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9036/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial certifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 10 days after a candidate establishes his eligibility under section 9033 to receive payments under section 9037, the Commission shall certify to the Secretary for payment to such candidate under section 9037 payment in full of amounts to which such candidate is entitled under section 9034. The Commission shall make such additional certifications as may be necessary to permit candidates to receive payments for contributions under section 9037.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47abb839-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9036/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality of determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Initial certifications by the Commission under subsection (a), and all determinations made by it under this chapter, are final and conclusive, except to the extent that they are subject to examination and audit by the Commission under section 9038 and judicial review under section 9041.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47abb83a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443/tIV/s408/c"},"text":"Pub. L. 93–443, title IV, § 408(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-15"},"text":"Oct. 15, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1300"},"text":"88 Stat. 1300","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47abb83b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47abb83c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47abb83d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/s410/c/1"},"text":"section 410(c)(1) of Pub. L. 93–443","children":[],"tail":", set out as an Effective Date of 1974 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
