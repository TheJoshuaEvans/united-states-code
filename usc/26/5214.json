{"tag":"section","attrib":{"id":"id463088ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214"},"text":null,"children":[{"tag":"num","attrib":{"value":"5214"},"text":"§ 5214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal of distilled spirits from bonded premises free of tax or without payment of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46308900-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Distilled spirits on which the internal revenue tax has not been paid or determined may, subject to such regulations as the Secretary shall prescribe, be withdrawn from the bonded premises of any distilled spirits plant in approved containers—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46308901-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" free of tax after denaturation of such spirits in the manner prescribed by law for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46308902-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46308903-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use in the manufacture of ether, chloroform, or other definite chemical substance where such distilled spirits are changed into some other chemical substance and do not appear in the finished product; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46308904-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other use in the arts and industries (except for uses prohibited by section 5273(b) or (d)) and for fuel, light, and power; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46308905-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" free of tax by, and for the use of, the United States or any governmental agency thereof, any State, any political subdivision of a State, or the District of Columbia, for nonbeverage purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46308906-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" free of tax for nonbeverage purposes and not for resale or use in the manufacture of any product for sale—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46308907-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the use of any educational organization described in section 170(b)(1)(A)(ii) which is exempt from income tax under section 501(a), or for the use of any scientific university or college of learning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46308908-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any laboratory for use exclusively in scientific research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46308909-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for use at any hospital, blood bank, or sanitarium), (including use in making any analysis or test at such hospital, blood bank, or sanitarium), or at any pathological laboratory exclusively engaged in making analyses, or tests, for hospitals or sanitariums; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4630890a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the use of any clinic operated for charity and not for profit (including use in the compounding of bona fide medicines for treatment outside of such clinics of patients thereof); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4630890b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without payment of tax for exportation, after making such application and entries, filing such bonds as are required by section 5175, and complying with such other requirements as may by regulations be prescribed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4630890c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without payment of tax for use in wine production, as authorized by section 5373; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4630890d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without payment of tax for transfer to manufacturing bonded warehouses for manufacturing in such warehouses for export, as authorized by law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4630890e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without payment of tax for use of certain vessels and aircraft, as authorized by law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4630890f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without payment of tax for transfer to foreign-trade zones, as authorized by law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46308910-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without payment of tax, for transfer (for the purpose of storage pending exportation) to any customs bonded warehouse from which distilled spirits may be exported, and distilled spirits transferred to a customs bonded warehouse under this paragraph shall be entered, stored, and accounted for under such regulations and bonds as the Secretary may prescribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46308911-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without payment of tax by a proprietor of bonded premises for use in research, development, or testing (other than consumer testing or other market analysis) of processes, systems, materials, or equipment, relating to distilled spirits or distilled spirits operations, under such limitations and conditions as to quantities, use, and accountability as the Secretary may by regulations require for the protection of the revenue; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46308912-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" free of tax when contained in an article (within the meaning of section 5002(a)(14)); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46308913-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" free of tax in the case of distilled spirits produced under section 5181; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46308914-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without payment of tax for use on bonded wine cellar premises in the production of wine or wine products which will be rendered unfit for beverage use and removed pursuant to section 5362(d); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46308915-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to distilled spirits removed after ","children":[{"tag":"date","attrib":{"date":"2019-12-31"},"text":"December 31, 2019","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", free of tax for use in or contained in hand sanitizer produced and distributed in a manner consistent with any guidance issued by the Food and Drug Administration that is related to the outbreak of virus SARS–CoV–2 or coronavirus disease 2019 (COVID–19)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46308916-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46308917-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions relating to denaturation, see sections 5241 and 5242.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46308918-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions requiring permit for users of distilled spirits withdrawn free of tax and for users of specially denatured distilled spirits, see section 5271.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46308919-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions relating to withdrawal of distilled spirits without payment of tax for use of certain vessels and aircraft, as authorized by law, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1309"},"text":"19 U.S.C. 1309","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4630891a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions relating to withdrawal of distilled spirits without payment of tax for manufacture in manufacturing bonded warehouse, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1311"},"text":"19 U.S.C. 1311","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4630891b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions relating to foreign-trade zones, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s81c"},"text":"19 U.S.C. 81c","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4630891c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions authorizing regulations for withdrawal of distilled spirits free of tax for use of the United States, see section 7510.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4630891d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions authorizing removal of distillates to bonded wine cellars for use in the production of distilling material, see section 5373(c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4630891e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5214/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions relating to distilled spirits for use of foreign embassies, legations, etc., see section 5066.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4630891f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1362"},"text":"72 Stat. 1362","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tI/s101/j/29"},"text":"Pub. L. 91–172, title I, § 101(j)(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/529"},"text":"83 Stat. 529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1905(c)(2), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1823"},"text":"90 Stat. 1823","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/95/176"},"text":"Pub. L. 95–176","children":[],"tail":", §§ 3(a), (d), 4(a), "},{"tag":"date","attrib":{"date":"1977-11-14"},"text":"Nov. 14, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1365"},"text":"91 Stat. 1365","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/28"},"text":"Pub. L. 96–39, title VIII, § 807(a)(28)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/285"},"text":"93 Stat. 285","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/223/tII/s232/e/2/B"},"text":"Pub. L. 96–223, title II, § 232(e)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-02"},"text":"Apr. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/280"},"text":"94 Stat. 280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s455/a"},"text":"Pub. L. 98–369, div. A, title IV, § 455(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/823"},"text":"98 Stat. 823","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tII/s2308/a"},"text":"Pub. L. 116–136, div. A, title II, § 2308(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/359"},"text":"134 Stat. 359","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46308920-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46308921-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":