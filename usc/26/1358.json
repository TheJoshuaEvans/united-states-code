{"tag":"section","attrib":{"id":"id44ec492c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1358"},"text":null,"children":[{"tag":"num","attrib":{"value":"1358"},"text":"§ 1358.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of credits, income, and deductions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44ec492d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1358/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying shipping activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the qualifying shipping activities of an electing corporation shall be treated as a separate trade or business activity distinct from all other activities conducted by such corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ec492e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1358/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of credits or deductions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ec492f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1358/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No deduction shall be allowed against the notional shipping income of an electing corporation, and no credit shall be allowed against the tax imposed by section 1352(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ec4930-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1358/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No deduction shall be allowed for any net operating loss attributable to the qualifying shipping activities of any person to the extent that such loss is carried forward by such person from a taxable year preceding the first taxable year for which such person was an electing corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ec4931-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1358/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transactions not at arm’s length","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Section 482 applies in accordance with this subsection to a transaction or series of transactions—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ec4932-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1358/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as between an electing corporation and another person, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ec4933-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1358/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as between a person’s qualifying shipping activities and other activities carried on by it.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44ec4934-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tII/s248/a"},"text":"Pub. L. 108–357, title II, § 248(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1456"},"text":"118 Stat. 1456","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/188"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(188)","children":[],"tail":", (189), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1193"},"text":"132 Stat. 1193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44ec4935-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44ec4936-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44ec4937-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/188"},"text":"Pub. L. 115–141, § 401(a)(188)","children":[],"tail":", substituted “section 1352(2)” for “section 1352(a)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/189"},"text":"Pub. L. 115–141, § 401(a)(189)","children":[],"tail":", substituted “a person’s” for “an person’s”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44ec4938-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44ec4939-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s248/c"},"text":"section 248(c) of Pub. L. 108–357","children":[],"tail":", set out as an Effective Date of 2004 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s56"},"text":"section 56 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
