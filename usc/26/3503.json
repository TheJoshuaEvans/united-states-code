{"tag":"section","attrib":{"id":"id45a3d952-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3503"},"text":null,"children":[{"tag":"num","attrib":{"value":"3503"},"text":"§ 3503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Erroneous payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any tax paid under chapter 21 or 22 by a taxpayer with respect to any period with respect to which he is not liable to tax under such chapter shall be credited against the tax, if any, imposed by such other chapter upon the taxpayer, and the balance, if any, shall be refunded.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id45a3d953-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/471"},"text":"68A Stat. 471","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
