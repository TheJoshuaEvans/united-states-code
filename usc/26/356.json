{"tag":"section","attrib":{"id":"id42c30076-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356"},"text":null,"children":[{"tag":"num","attrib":{"value":"356"},"text":"§ 356.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt of additional consideration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42c30077-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gain on exchanges","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42c30078-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition of gain","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42c30079-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 354 or 355 would apply to an exchange but for the fact that","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42c3007a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property received in the exchange consists not only of property permitted by section 354 or 355 to be received without the recognition of gain but also of other property or money,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then the gain, if any, to the recipient shall be recognized, but in an amount not in excess of the sum of such money and the fair market value of such other property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42c3007b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as dividend","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an exchange is described in paragraph (1) but has the effect of the distribution of a dividend (determined with the application of section 318(a)), then there shall be treated as a dividend to each distributee such an amount of the gain recognized under paragraph (1) as is not in excess of his ratable share of the undistributed earnings and profits of the corporation accumulated after ","children":[{"tag":"date","attrib":{"date":"1913-02-28"},"text":"February 28, 1913","children":[],"tail":". The remainder, if any, of the gain recognized under paragraph (1) shall be treated as gain from the exchange of property."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42c3007c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional consideration received in certain distributions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42c3007d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 355 would apply to a distribution but for the fact that","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42c3007e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property received in the distribution consists not only of property permitted by section 355 to be received without the recognition of gain, but also of other property or money,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then an amount equal to the sum of such money and the fair market value of such other property shall be treated as a distribution of property to which section 301 applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42c3007f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loss","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42c30080-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 354 would apply to an exchange or section 355 would apply to an exchange or distribution, but for the fact that","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42c30081-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property received in the exchange or distribution consists not only of property permitted by section 354 or 355 to be received without the recognition of gain or loss, but also of other property or money,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then no loss from the exchange or distribution shall be recognized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42c30082-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securities as other property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42c30083-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the term “other property” includes securities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42c30084-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42c30085-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securities with respect to which nonrecognition of gain would be permitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “other property” does not include securities to the extent that, under section 354 or 355, such securities would be permitted to be received without the recognition of gain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42c30086-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greater principal amount in section 354 exchange","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42c30087-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an exchange described in section 354 (other than subsection (c) thereof), securities of a corporation a party to the reorganization are surrendered and securities of any corporation a party to the reorganization are received, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42c30088-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the principal amount of such securities received exceeds the principal amount of such securities surrendered,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then, with respect to such securities received, the term “other property” means only the fair market value of such excess. For purposes of this subparagraph and subparagraph (C), if no securities are surrendered, the excess shall be the entire principal amount of the securities received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42c30089-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greater principal amount in section 355 transaction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, in an exchange or distribution described in section 355, the principal amount of the securities in the controlled corporation which are received exceeds the principal amount of the securities in the distributing corporation which are surrendered, then, with respect to such securities received, the term “other property” means only the fair market value of such excess.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42c3008a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonqualified preferred stock treated as other property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42c3008b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the term “other property” includes nonqualified preferred stock (as defined in section 351(g)(2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42c3008c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “other property” does not include nonqualified preferred stock (as so defined) to the extent that, under section 354 or 355, such preferred stock would be permitted to be received without the recognition of gain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42c3008d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchanges for section 306 stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, to the extent that any of the other property (or money) is received in exchange for section 306 stock, an amount equal to the fair market value of such other property (or the amount of such money) shall be treated as a distribution of property to which section 301 applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42c3008e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transactions involving gift or compensation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For special rules for a transaction described in section 354, 355, or this section, but which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42c3008f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results in a gift, see section 2501 and following, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42c30090-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s356/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the effect of the payment of compensation, see section 61(a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id42c30091-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/115"},"text":"68A Stat. 115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/253/s1/c"},"text":"Pub. L. 94–253, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-03-31"},"text":"Mar. 31, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/296"},"text":"90 Stat. 296","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tII/s227/b"},"text":"Pub. L. 97–248, title II, § 227(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/492"},"text":"96 Stat. 492","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11801/c/8/E"},"text":"Pub. L. 101–508, title XI, § 11801(c)(8)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-524"},"text":"104 Stat. 1388–524","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1014/d"},"text":"Pub. L. 105–34, title X, § 1014(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/921"},"text":"111 Stat. 921","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id42c30092-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id42c30093-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id42c30094-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsecs. (e) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" added subsec. (e) and redesignated former subsecs. (e) and (f) as (f) and (g), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" struck out “or (d)” after “subsection (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" inserted “(determined with the application of section 318(a))” after “distribution of a dividend”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (d)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/253"},"text":"Pub. L. 94–253","children":[],"tail":" substituted “subsection (c) or (d) thereof” for “subsection (c) thereof”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id42c30095-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42c30096-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" applicable, with certain exceptions, to transactions after "},{"tag":"date","attrib":{"date":"1997-06-08"},"text":"June 8, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1014/f"},"text":"section 1014(f) of Pub. L. 105–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s351"},"text":"section 351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42c30097-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tII/s227/c/2"},"text":"Pub. L. 97–248, title II, § 227(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/492"},"text":"96 Stat. 492","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/248/tII/s227/c/2"},"text":"“The amendment made by subsection (b) [amending this section] shall apply to distributions after ","children":[{"tag":"date","attrib":{"date":"1982-08-31"},"text":"August 31, 1982","children":[],"tail":", in taxable years ending after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42c30098-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/253"},"text":"Pub. L. 94–253","children":[],"tail":" applicable to taxable years ending after "},{"tag":"date","attrib":{"date":"1976-03-31"},"text":"Mar. 31, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/253/s2"},"text":"section 2 of Pub. L. 94–253","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s354"},"text":"section 354 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id42c30099-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that nothing in amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" be construed to affect treatment of certain transactions occurring, property acquired, or items of income, loss, deduction, or credit taken into account prior to "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", for purposes of determining liability for tax for periods ending after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11821/b"},"text":"section 11821(b) of Pub. L. 101–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s45K"},"text":"section 45K of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
