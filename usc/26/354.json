{"tag":"section","attrib":{"id":"id42be45a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354"},"text":null,"children":[{"tag":"num","attrib":{"value":"354"},"text":"§ 354.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchanges of stock and securities in certain reorganizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42be45a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42be45a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No gain or loss shall be recognized if stock or securities in a corporation a party to a reorganization are, in pursuance of the plan of reorganization, exchanged solely for stock or securities in such corporation or in another corporation a party to the reorganization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42be45a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42be45a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess principal amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42be45a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the principal amount of any such securities received exceeds the principal amount of any such securities surrendered, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42be45aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any such securities are received and no such securities are surrendered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42be45ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property attributable to accrued interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Neither paragraph (1) nor so much of section 356 as relates to paragraph (1) shall apply to the extent that any stock (including nonqualified preferred stock, as defined in section 351(g)(2)), securities, or other property received is attributable to interest which has accrued on securities on or after the beginning of the holder’s holding period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42be45ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonqualified preferred stock","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42be45ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nonqualified preferred stock (as defined in section 351(g)(2)) received in exchange for stock other than nonqualified preferred stock (as so defined) shall not be treated as stock or securities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42be45ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recapitalizations of family-owned corporations","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id42be45af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/a/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Clause (i) shall not apply in the case of a recapitalization under section 368(a)(1)(E) of a family-owned corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id42be45b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/a/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family-owned corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this clause, except as provided in regulations, the term “family-owned corporation” means any corporation which is described in clause (i) of section 447(d)(2)(C) ","children":[{"tag":"ref","attrib":{"idref":"fn002101"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002101"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" throughout the 8-year period beginning on the date which is 5 years before the date of the recapitalization. For purposes of the preceding sentence, stock shall not be treated as owned by a family member during any period described in section 355(d)(6)(B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id42be45b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/a/2/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of statute of limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The statutory period for the assessment of any deficiency attributable to a corporation failing to be a family-owned corporation shall not expire before the expiration of 3 years after the date the Secretary is notified by the corporation (in such manner as the Secretary may prescribe) of such failure, and such deficiency may be assessed before the expiration of such 3-year period notwithstanding the provisions of any other law or rule of law which would otherwise prevent such assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42be45b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42be45b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For treatment of the exchange if any property is received which is not permitted to be received under this subsection (including nonqualified preferred stock and an excess principal amount of securities received over securities surrendered, but not including property to which paragraph (2)(B) applies), see section 356.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42be45b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For treatment of accrued interest in the case of an exchange described in paragraph (2)(B), see section 61.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42be45b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42be45b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to an exchange in pursuance of a plan of reorganization within the meaning of subparagraph (D) or (G) of section 368(a)(1), unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42be45b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the corporation to which the assets are transferred acquires substantially all of the assets of the transferor of such assets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42be45b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the stock, securities, and other properties received by such transferor, as well as the other properties of such transferor, are distributed in pursuance of the plan of reorganization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42be45b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For special rules for certain exchanges in pursuance of plans of reorganization within the meaning of subparagraph (D) or (G) of section 368(a)(1), see section 355.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42be45ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s354/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain railroad reorganizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subchapter, subsection (a)(1) (and so much of section 356 as relates to this section) shall apply with respect to a plan of reorganization (whether or not a reorganization within the meaning of section 368(a)) for a railroad confirmed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1173"},"text":"section 1173 of title 11","children":[],"tail":" of the United States Code, as being in the public interest."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id42be45bb-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/112"},"text":"68A Stat. 112","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/253/s1/c"},"text":"Pub. L. 94–253, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-03-31"},"text":"Mar. 31, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/296"},"text":"90 Stat. 296","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/473/s2/a/2/F"},"text":"Pub. L. 95–473, § 2(a)(2)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1465"},"text":"92 Stat. 1465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/589"},"text":"Pub. L. 96–589","children":[],"tail":", §§ 4(e)(1), (h)(1), 6(i)(2), "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3403"},"text":"94 Stat. 3403","children":[],"tail":", 3404, 3410; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11801/c/8/D"},"text":"Pub. L. 101–508, title XI, § 11801(c)(8)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-524"},"text":"104 Stat. 1388–524","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tIII/s304/c"},"text":"Pub. L. 104–88, title III, § 304(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/944"},"text":"109 Stat. 944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1014/b"},"text":"Pub. L. 105–34, title X, § 1014(b)","children":[],"tail":", (e)(1), (2), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/920"},"text":"111 Stat. 920","children":[],"tail":", 921; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tVI/s6010/e/2"},"text":"Pub. L. 105–206, title VI, § 6010(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/814"},"text":"112 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id42be45bc-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id42be45bd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id42be45be-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 447(d), referred to in subsec. (a)(2)(C)(ii)(II), was repealed and provisions not relating to family-owned corporations were redesignated as section 447(d) by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13102/a/5/C"},"text":"Pub. L. 115–97, title I, § 13102(a)(5)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2103"},"text":"131 Stat. 2103","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id42be45bf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(2)(C)(ii)(III). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" added subcl. (III)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1014/e/1"},"text":"Pub. L. 105–34, § 1014(e)(1)","children":[],"tail":", inserted “(including nonqualified preferred stock, as defined in section 351(g)(2))” after “stock”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1014/b"},"text":"Pub. L. 105–34, § 1014(b)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1014/e/2"},"text":"Pub. L. 105–34, § 1014(e)(2)","children":[],"tail":", inserted “nonqualified preferred stock and” after “subsection (including”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" struck out “or approved by the Interstate Commerce Commission under subchapter IV of chapter 113 of title 49,” after “Code,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" struck out subsec. (d) “Exchanges under the final system plan for ConRail” which read as follows: “No gain or loss shall be recognized if stock or securities in a corporation are, in pursuance of an exchange to which paragraph (1) or (2) of section 374(c) applies, exchanged solely for stock of the Consolidated Rail Corporation, securities of such Corporation, certificates of value of the United States Railway Association, or any combination thereof.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/589/s4/e/1"},"text":"Pub. L. 96–589, § 4(e)(1)","children":[],"tail":", redesignated existing pars. (A) and (B) as par. (A)(i), (ii), and added par. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/589/s4/e/1"},"text":"Pub. L. 96–589, § 4(e)(1)","children":[],"tail":", designated existing provisions as subpar. (A), inserted provisions excluding property to which paragraph (2)(B) applies, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/589/s4/h/1"},"text":"Pub. L. 96–589, § 4(h)(1)","children":[],"tail":", substituted “subparagraph (D) or (G) of section 368(a)(1)” for “section 368(a)(1)(D)”, wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/589/s6/i/2"},"text":"Pub. L. 96–589, § 6(i)(2)","children":[],"tail":", substituted “confirmed under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1173"},"text":"section 1173 of title 11","children":[],"tail":" of the United States Code, or approved by the Interstate Commerce Commission” for “approved by the Interstate Commerce Commission under section 77 of the Bankruptcy Act, or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Pub. L. 95–473","children":[],"tail":" substituted “subchapter IV of chapter 113 of title 49” for “section 20b of the Interstate Commerce Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/253"},"text":"Pub. L. 94–253","children":[],"ta