{"tag":"section","attrib":{"id":"id4736d630-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721"},"text":null,"children":[{"tag":"num","attrib":{"value":"6721"},"text":"§ 6721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to file correct information returns","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4736d631-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of penalty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4736d632-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a failure described in paragraph (2) by any person with respect to an information return, such person shall pay a penalty of $250 for each return with respect to which such a failure occurs, but the total amount imposed on such person for all such failures during any calendar year shall not exceed $3,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d633-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failures subject to penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the failures described in this paragraph are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d634-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any failure to file an information return with the Secretary on or before the required filing date, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d635-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any failure to include all of the information required to be shown on the return or the inclusion of incorrect information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d636-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction where correction in specified period","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4736d637-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction within 30 days","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any failure described in subsection (a)(2) is corrected on or before the day 30 days after the required filing date—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d638-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the penalty imposed by subsection (a) shall be $50 in lieu of $250, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d639-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount imposed on the person for all such failures during any calendar year which are so corrected shall not exceed $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d63a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failures corrected on or before August 1","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any failure described in subsection (a)(2) is corrected after the 30th day referred to in paragraph (1) but on or before August 1 of the calendar year in which the required filing date occurs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d63b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the penalty imposed by subsection (a) shall be $100 in lieu of $250, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d63c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount imposed on the person for all such failures during the calendar year which are so corrected shall not exceed $1,500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d63d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions for certain de minimis failures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4736d63e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for de minimis failure to include all required information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d63f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an information return is filed with the Secretary,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d640-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a failure described in subsection (a)(2)(B) (determined after the application of section 6724(a)) with respect to such return, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d641-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such failure is corrected on or before August 1 of the calendar year in which the required filing date occurs,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for purposes of this section, such return shall be treated as having been filed with all of the correct required information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d642-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The number of information returns to which paragraph (1) applies for any calendar year shall not exceed the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d643-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d644-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-half of 1 percent of the total number of information returns required to be filed by the person during the calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d645-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe harbor for certain de minimis errors","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d646-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, with respect to an information return filed with the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4736d647-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are 1 or more failures described in subsection (a)(2)(B) relating to an incorrect dollar amount,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4736d648-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no single amount in error differs from the correct amount by more than $100, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4736d649-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no single amount reported for tax withheld on the information return differs from the correct amount by more than $25,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then no correction shall be required and, for purposes of this section, such return shall be treated as having been filed with all of the correct required information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d64a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply with respect to any incorrect dollar amount to the extent that such error relates to an amount with respect to which an election is made under section 6722(c)(3)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d64b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may issue regulations to prevent the abuse of the safe harbor under this paragraph, including regulations providing that this paragraph shall not apply to the extent necessary to prevent any such abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d64c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lower limitations for persons with gross receipts of not more than $5,000,000","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4736d64d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any person meets the gross receipts test of paragraph (2) with respect to any calendar year, with respect to failures during such calendar year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d64e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a)(1) shall be applied by substituting “$1,000,000” for “$3,000,000”,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d64f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b)(1)(B) shall be applied by substituting “$175,000” for “$500,000”, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d650-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b)(2)(B) shall be applied by substituting “$500,000” for “$1,500,000”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d651-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gross receipts test","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d652-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person meets the gross receipts test of this paragraph for any calendar year if the average annual gross receipts of such person for the most recent 3 taxable years ending before such calendar year do not exceed $5,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d653-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain rules made applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the rules of paragraphs (2) and (3) of section 448(c) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d654-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty in case of intentional disregard","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If 1 or more failures described in subsection (a)(2) are due to intentional disregard of the filing requirement (or the correct information reporting requirement), then, with respect to each such failure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4736d655-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsections (b), (c), and (d) shall not apply,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d656-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the penalty imposed under subsection (a) shall be $500, or, if greater—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d657-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a return other than a return required under section 6045(a), 6041A(b), 6050H, 6050I, 6050J, 6050K, or 6050L, 10 percent of the aggregate amount of the items required to be reported correctly,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d658-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a return required to be filed by section 6045(a), 6050K, or 6050L, 5 percent of the aggregate amount of the items required to be reported correctly,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d659-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a return required to be filed under section 6050I(a) with respect to any transaction (or related transactions), the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4736d65a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4736d65b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of cash (within the meaning of section 6050I(d)) received in such transaction (or related transactions) to the extent the amount of such cash does not exceed $100,000, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d65c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a return required to be filed under section 6050V, 10 percent of the value of the benefit of any contract with respect to which information is required to be included on the return, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d65d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of any penalty determined under paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d65e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the $3,000,000 limitation under subsection (a) shall not apply, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d65f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such penalty shall not be taken into account in applying such limitation (or any similar limitation under subsection (b)) to penalties not determined under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d660-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment for inflation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4736d661-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any failure relating to a return required to be filed in a calendar year beginning after 2014, each of the dollar amounts under subsections (a), (b), (d) (other than paragraph (2)(A) thereof), and (e) shall be increased by an amount equal to such dollar amount multiplied by the cost-of-living adjustment determined under section 1(f)(3) for the calendar year determined by substituting “calendar year 2011” for “calendar year 2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d662-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rounding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any amount adjusted under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d663-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not less than $75,000 and is not a multiple of $500, such amount shall be rounded to the next lowest multiple of $500, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d664-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6721/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not described in subparagraph (A) and is not a multiple of $10, such amount shall be rounded to the next lowest multiple of $10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4736d665-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/