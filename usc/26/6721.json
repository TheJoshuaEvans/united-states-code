,"attrib":{},"text":"Inflation Adjusted Items for Certain Years","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For inflation adjustment of certain items in this section, see Revenue Procedures listed in a table under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4736d668-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4736d669-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(3)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s101/f/2"},"text":"Pub. L. 115–141, § 101(f)(2)","children":[],"tail":", substituted “the information return” for “any information return”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/299/F"},"text":"Pub. L. 115–141, § 401(a)(299)(F)","children":[],"tail":", inserted “an amount equal to” after “increased by” and “for the calendar year” after “section 1(f)(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" substituted “for ‘calendar year 2016’ in subparagraph (A)(ii)” for “for ‘calendar year 1992’ in subparagraph (B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27/s806/a"},"text":"Pub. L. 114–27, § 806(a)","children":[],"tail":", substituted “$250” for “$100” and “$3,000,000” for “$1,500,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27/s806/b/1/A"},"text":"Pub. L. 114–27, § 806(b)(1)(A)","children":[],"tail":", (B), substituted “$50” for “$30” and “$250” for “$100”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27/s806/b/1/C"},"text":"Pub. L. 114–27, § 806(b)(1)(C)","children":[],"tail":", substituted “$500,000” for “$250,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27/s806/b/2/A"},"text":"Pub. L. 114–27, § 806(b)(2)(A)","children":[],"tail":", (B), substituted “$100” for “$60” and “$250” for “$100”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27/s806/b/2/C"},"text":"Pub. L. 114–27, § 806(b)(2)(C)","children":[],"tail":", substituted “$1,500,000” for “$500,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s202/d/1"},"text":"Pub. L. 114–113, § 202(d)(1)","children":[],"tail":", substituted “Exceptions for certain de minimis failures” for “Exception for de minimis failures to include all required information” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s202/d/2"},"text":"Pub. L. 114–113, § 202(d)(2)","children":[],"tail":", substituted “Exception for de minimis failure to include all required information” for “In general” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s202/a"},"text":"Pub. L. 114–113, § 202(a)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27/s806/c/1"},"text":"Pub. L. 114–27, § 806(c)(1)","children":[],"tail":", substituted “$1,000,000” for “$500,000” and “$3,000,000” for “$1,500,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27/s806/c/2"},"text":"Pub. L. 114–27, § 806(c)(2)","children":[],"tail":", substituted “$175,000” for “$75,000” and “$500,000” for “$250,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27/s806/c/3"},"text":"Pub. L. 114–27, § 806(c)(3)","children":[],"tail":", substituted “$500,000” for “$200,000” and “$1,500,000” for “$500,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27/s806/d/1"},"text":"Pub. L. 114–27, § 806(d)(1)","children":[],"tail":", substituted “$500” for “$250”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27/s806/d/2"},"text":"Pub. L. 114–27, § 806(d)(2)","children":[],"tail":", substituted “$3,000,000” for “$1,500,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" substituted “In the case of any failure relating to a return required to be filed in a calendar year beginning after 2014” for “For each fifth calendar year beginning after 2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/240/s2102/a"},"text":"Pub. L. 111–240, § 2102(a)","children":[],"tail":", substituted “$100” for “$50” and “$1,500,000” for “$250,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/240/s2102/a/1"},"text":"Pub. L. 111–240, § 2102(a)(1)","children":[],"tail":", (b)(1), substituted “$30” for “$15” and “$100” for “$50”."}],"tail":"\