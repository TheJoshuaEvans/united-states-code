{"tag":"section","attrib":{"id":"id45f0255c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958"},"text":null,"children":[{"tag":"num","attrib":{"value":"4958"},"text":"§ 4958.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxes on excess benefit transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45f0255d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial taxes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f0255e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On the disqualified person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on each excess benefit transaction a tax equal to 25 percent of the excess benefit. The tax imposed by this paragraph shall be paid by any disqualified person referred to in subsection (f)(1) with respect to such transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f0255f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On the management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which a tax is imposed by paragraph (1), there is hereby imposed on the participation of any organization manager in the excess benefit transaction, knowing that it is such a transaction, a tax equal to 10 percent of the excess benefit, unless such participation is not willful and is due to reasonable cause. The tax imposed by this paragraph shall be paid by any organization manager who participated in the excess benefit transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f02560-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional tax on the disqualified person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which an initial tax is imposed by subsection (a)(1) on an excess benefit transaction and the excess benefit involved in such transaction is not corrected within the taxable period, there is hereby imposed a tax equal to 200 percent of the excess benefit involved. The tax imposed by this subsection shall be paid by any disqualified person referred to in subsection (f)(1) with respect to such transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f02561-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess benefit transaction; excess benefit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f02562-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess benefit transaction","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f02563-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “excess benefit transaction” means any transaction in which an economic benefit is provided by an applicable tax-exempt organization directly or indirectly to or for the use of any disqualified person if the value of the economic benefit provided exceeds the value of the consideration (including the performance of services) received for providing such benefit. For purposes of the preceding sentence, an economic benefit shall not be treated as consideration for the performance of services unless such organization clearly indicated its intent to so treat such benefit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f02564-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “excess benefit” means the excess referred to in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f02565-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for donor advised funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any donor advised fund (as defined in section 4966(d)(2))—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f02566-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “excess benefit transaction” includes any grant, loan, compensation, or other similar payment from such fund to a person described in subsection (f)(7) with respect to such fund, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f02567-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “excess benefit” includes, with respect to any transaction described in subparagraph (A), the amount of any such grant, loan, compensation, or other similar payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f02568-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for supporting organizations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f02569-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any organization described in section 509(a)(3)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45f0256a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “excess benefit transaction” includes—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id45f0256b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any grant, loan, compensation, or other similar payment provided by such organization to a person described in subparagraph (B), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id45f0256c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any loan provided by such organization to a disqualified person (other than an organization described in subparagraph (C)(ii)), and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f0256d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “excess benefit” includes, with respect to any transaction described in clause (i), the amount of any such grant, loan, compensation, or other similar payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f0256e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person is described in this subparagraph if such person is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45f0256f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantial contributor to such organization,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f02570-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the family (determined under section 4958(f)(4)) of an individual described in clause (i), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f02571-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 35-percent controlled entity (as defined in section 4958(f)(3) by substituting “persons described in clause (i) or (ii) of section 4958(c)(3)(B)” for “persons described in subparagraph (A) or (B) of paragraph (1)” in subparagraph (A)(i) thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f02572-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial contributor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45f02573-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “substantial contributor” means any person who contributed or bequeathed an aggregate amount of more than $5,000 to the organization, if such amount is more than 2 percent of the total contributions and bequests received by the organization before the close of the taxable year of the organization in which the contribution or bequest is received by the organization from such person. In the case of a trust, such term also means the creator of the trust. Rules similar to the rules of subparagraphs (B) and (C) of section 507(d)(2) shall apply for purposes of this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f29574-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such term shall not include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id45f29575-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/3/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organization described in paragraph (1), (2), or (4) of section 509(a), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id45f29576-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/3/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organization which is treated as described in such paragraph (2) by reason of the last sentence of section 509(a) and which is a supported organization (as defined in section 509(f)(3)) of the organization to which subparagraph (A) applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f29577-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to include certain other private inurement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent provided in regulations prescribed by the Secretary, the term “excess benefit transaction” includes any transaction in which the amount of any economic benefit provided to or for the use of a disqualified person is determined in whole or in part by the revenues of 1 or more activities of the organization but only if such transaction results in inurement not permitted under paragraph (3) or (4) of section 501(c), as the case may be. In the case of any such transaction, the excess benefit shall be the amount of the inurement not so permitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f29578-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f29579-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint and several liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If more than 1 person is liable for any tax imposed by subsection (a) or subsection (b), all such persons shall be jointly and severally liable for such tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f2957a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit for management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any 1 excess benefit transaction, the maximum amount of the tax imposed by subsection (a)(2) shall not exceed $20,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f2957b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable tax-exempt organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the term “applicable tax-exempt organization” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f2957c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organization which (without regard to any excess benefit) would be described in paragraph (3), (4), or (29) of section 501(c) and exempt from tax under section 501(a), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f2957d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organization which was described in paragraph (1) at any time during the 5-year period ending on the date of the transaction.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term shall not include a private foundation (as defined in section 509(a)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f2957e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f2957f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualified person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “disqualified person” means, with respect to any transaction—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f29580-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who was, at any time during the 5-year period ending on the date of such transaction, in a position to exercise substantial influence over the affairs of the organization,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f29581-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the family of an individual described in subparagraph (A),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f29582-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 35-percent controlled entity,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f29583-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who is described in subparagraph (A), (B), or (C) with respect to an organization described in section 509(a)(3) and organized and operated exclusively for the benefit of, to perform the functions of, or to carry out the purposes of the applicable tax-exempt organization,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f29584-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which involves a donor advised fund (as defined in section 4966(d)(2)), any person who is described in paragraph (7) with respect to such donor advised fund (as so defined), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f29585-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which involves a sponsoring organization (as defined in section 4966(d)(1)), any person who is described in paragraph (8) with respect to such sponsoring organization (as so defined).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f29586-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization manager","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “organization manager” means, with respect to any applicable tax-exempt organization, any officer, director, or trustee of such organization (or any individual having powers or responsibilities similar to those of officers, directors, or trustees of the organization).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f29587-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 35-percent controlled entity","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f29588-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “35-percent controlled entity” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45f29589-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation in which persons described in subparagraph (A) or (B) of paragraph (1) own more than 35 percent of the total combined voting power,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f2958a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership in which such persons own more than 35 percent of the profits interest, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f2958b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trust or estate in which such persons own more than 35 percent of the beneficial interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f2958c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Constructive ownership rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of paragraphs (3) and (4) of section 4946(a) shall apply for purposes of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f2958d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of an individual’s family shall be determined under section 4946(d); except that such members also shall include the brothers and sisters (whether by the whole or half blood) of the individual and their spouses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f2958e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “taxable period” means, with respect to any excess benefit transaction, the period beginning with the date on which the transaction occurs and ending on the earliest of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f2958f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of mailing a notice of deficiency under section 6212 with respect to the tax imposed by subsection (a)(1), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f29590-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the tax imposed by subsection (a)(1) is assessed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f29591-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “correction” and “correct” mean, with respect to any excess benefit transaction, undoing the excess benefit to the extent possible, and taking any additional measures necessary to place the organization in a financial position not worse than that in which it would be if the disqualified person were dealing under the highest fiduciary standards, except that in the case of any correction of an excess benefit transaction described in subsection (c)(2), no amount repaid in a manner prescribed by the Secretary may be held in any donor advised fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f29592-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donors and donor advisors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)(E), a person is described in this paragraph if such person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f29593-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is described in section 4966(d)(2)(A)(iii),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f29594-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of the family of an individual described in subparagraph (A), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f29595-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a 35-percent controlled entity (as defined in paragraph (3) by substituting “persons described in subparagraph (A) or (B) of paragraph (7)” for “persons described in subparagraph (A) or (B) of paragraph (1)” in subparagraph (A)(i) thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f29596-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment advisors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)(F)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f29597-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person is described in this paragraph if such person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45f29598-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an investment advisor,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f29599-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of the family of an individual described in clause (i), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f2959a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/8/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a 35-percent controlled entity (as defined in paragraph (3) by substituting “persons described in clause (i) or (ii) of paragraph (8)(A)” for “persons described in subparagraph (A) or (B) of paragraph (1)” in subparagraph (A)(i) thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f2959b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4958/f/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment advisor defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the term “investment advisor” means, with respect to any sponsoring organization (as defined in section 4966(d)(1)), any person (other than an employee of such organization) compensated by such organization for managing the investment of, or providing investment advice with respect to, assets maintained in donor advised funds (as defined in section 4966(d)(2)) owned by such organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45f2959c-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/tXIII/s1311/a"},"text":"Pub. L. 104–168, title XIII, § 1311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1475"},"text":"110 Stat. 1475","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII"},"text":"Pub. L. 109–280, title XII","children":[],"tail":", §§ 1212(a)(3), 1232(a), (b), 1242(a), (b), "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1074"},"text":"120 Stat. 1074","children":[],"tail":", 1098, 1099, 1104; "},{"tag":"ref","attrib":{"href":"/us/pl/110/172/s3/i"},"text":"Pub. L. 110–172, § 3(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-29"},"text":"Dec. 29, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2475"},"text":"121 Stat. 2475","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1322/h/3"},"text":"Pub. L. 111–148, title I, § 1322(h)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/192"},"text":"124 Stat. 192","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/224"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(224)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1194"},"text":"132 Stat. 1194","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45f2959d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45f2959e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id45f2959f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 1212(a)(3), 1232(a), (b), and 1242(a), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":", which directed the amendment of section 4958 without specifying the act to be amended, were executed to this section, which is section 4958 of the Internal Revenue Code of 1986, to reflect the probable intent of Congress. See 2006 Amendment notes below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45f295a0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted comma for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" substituted “paragraph (3), (4), or (29)” for “paragraph (3) or (4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (c)(3)(A)(i)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172/s3/i/1"},"text":"Pub. L. 110–172, § 3(i)(1)","children":[],"tail":", substituted “subparagraph (C)(ii)” for “paragraph (1), (2), or (4) of section 509(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172/s3/i/2"},"text":"Pub. L. 110–172, § 3(i)(2)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “Such term shall not include any organization described in paragraph (1), (2), or (4) of section 509(a).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1232/b/1"},"text":"Pub. L. 109–280, § 1232(b)(1)","children":[],"tail":", added par. (2). Former par. (2) redesignated (3). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1242/b"},"text":"Pub. L. 109–280, § 1242(b)","children":[],"tail":", added par. (3). Former par. (3) redesignated (4). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1232/b/1"},"text":"Pub. L. 109–280, § 1232(b)(1)","children":[],"tail":", redesignated par. (2) as (3). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1242/b"},"text":"Pub. L. 109–280, § 1242(b)","children":[],"tail":", redesignated par. (3) as (4). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1212/a/3"},"text":"Pub. L. 109–280, § 1212(a)(3)","children":[],"tail":", substituted “$20,000” for “$10,000”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1242/a"},"text":"Pub. L. 109–280, § 1242(a)","children":[],"tail":", added subpar. (D). Former subpar. (D) redesignated (E). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1232/a/1"},"text":"Pub. L. 109–280, § 1232(a)(1)","children":[],"tail":", added subpar. (D). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1242/a"},"text":"Pub. L. 109–280, § 1242(a)","children":[],"tail":", redesignated subpar. (D) as (E). Former subpar. (E) redesignated (F). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1232/a/1"},"text":"Pub. L. 109–280, § 1232(a)(1)","children":[],"tail":", added subpar. (E). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1242/a"},"text":"Pub. L. 109–280, § 1242(a)","children":[],"tail":", redesignated subpar. (E) as (F). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1232/b/2"},"text":"Pub. L. 109–280, § 1232(b)(2)","children":[],"tail":", inserted “, except that in the case of any correction of an excess benefit transaction described in subsection (c)(2), no amount repaid in a manner prescribed by the Secretary may be held in any donor advised fund” after “standards”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1232/a/2"},"text":"Pub. L. 109–280, § 1232(a)(2)","children":[],"tail":", added pars. (7) and (8). See Codification note above."}],"tail":"\n"}],"tail":"\n"