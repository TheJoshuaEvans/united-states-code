{"tag":"section","attrib":{"id":"id44db801c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277"},"text":null,"children":[{"tag":"num","attrib":{"value":"1277"},"text":"§ 1277.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferral of interest deduction allocable to accrued market discount","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44db801d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, the net direct interest expense with respect to any market discount bond shall be allowed as a deduction for the taxable year only to the extent that such expense exceeds the portion of the market discount allocable to the days during the taxable year on which such bond was held by the taxpayer (as determined under the rules of section 1276(b)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44db801e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disallowed deduction allowed for later years","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44db801f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to take into account in later year where net interest income from bond","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44db8020-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44db8021-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is net interest income for any taxable year with respect to any market discount bond, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44db8022-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer makes an election under this subparagraph with respect to such bond,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"any disallowed interest expense with respect to such bond shall be treated as interest paid or accrued by the taxpayer during such taxable year to the extent such disallowed interest expense does not exceed the net interest income with respect to such bond.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44db8023-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of disallowed interest expense","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the amount of the disallowed interest expense—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44db8024-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be determined as of the close of the preceding taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44db8025-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not include any amount previously taken into account under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44db8026-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net interest income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the term “net interest income” means the excess of the amount determined under paragraph (2) of subsection (c) over the amount determined under paragraph (1) of subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44db8027-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remainder of disallowed interest expense allowed for year of disposition","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44db8028-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this paragraph, the amount of the disallowed interest expense with respect to any market discount bond shall be treated as interest paid or accrued by the taxpayer in the taxable year in which such bond is disposed of.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44db8029-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonrecognition transactions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any market discount bond is disposed of in a nonrecognition transaction—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44db802a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disallowed interest expense with respect to such bond shall be treated as interest paid or accrued in the year of disposition only to the extent of the amount of gain recognized on such disposition, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44db802b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the disallowed interest expense with respect to such property (to the extent not so treated) shall be treated as disallowed interest expense—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id44db802c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a transaction described in section 1276(c)(1), of the transferee with respect to the transferred basis property, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44db802d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a transaction described in section 1276(c)(2), with respect to the exchanged basis property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44db802e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disallowed interest expense reduced for amounts previously taken into account under paragraph (1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the amount of the disallowed interest expense shall not include any amount previously taken into account under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44db802f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disallowed interest expense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “disallowed interest expense” means the aggregate amount disallowed under subsection (a) with respect to the market discount bond.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44db8030-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net direct interest expense","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “net direct interest expense” means, with respect to any market discount bond, the excess (if any) of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44db8031-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of interest paid or accrued during the taxable year on indebtedness which is incurred or continued to purchase or carry such bond, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44db8032-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1277/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of interest (including original issue discount) includible in gross income for the taxable year with respect to such bond.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In the case of any financial institution which is a bank (as defined in section 585(a)(2)), the determination of whether interest is described in paragraph (1) shall be made under principles similar to the principles of section 291(e)(1)(B)(ii). Under rules similar to the rules of section 265(a)(5), short sale expenses shall be treated as interest for purposes of determining net direct interest expense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44db8033-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s41/a"},"text":"Pub. L. 98–369, div. A, title I, § 41(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/545"},"text":"98 Stat. 545","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tIX"},"text":"Pub. L. 99–514, title IX","children":[],"tail":", §§ 901(d)(4)(F), § 902(e)(2), title XVIII, § 1899A(29)–(31), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2380"},"text":"100 Stat. 2380","children":[],"tail":", 2382, 2960; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1018/u/31"},"text":"Pub. L. 100–647, title I, § 1018(u)(31)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3592"},"text":"102 Stat. 3592","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13206/b/1/B"},"text":"Pub. L. 103–66, title XIII, § 13206(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/465"},"text":"107 Stat. 465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1616/b/14"},"text":"Pub. L. 104–188, title I, § 1616(b)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1857"},"text":"110 Stat. 1857","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44db8034-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44db8035-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44db8036-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" struck out “or to which section 593 applies” after “585(a)(2))” in closing provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" struck out heading and text of subsec. (d). Text read as follows: “In the case of a market discount bond issued on or before "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", any gain recognized by the taxpayer on any disposition of such bond shall be treated as ordinary income to the extent the amount of such gain does not exceed the amount allowable with respect to such bond under subsection (b)(2) for the taxable year in which such bond is disposed of.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" inserted a closing parenthesis after “section 585(a)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1899A/29"},"text":"Pub. L. 99–514, § 1899A(29)","children":[],"tail":", substituted “this paragraph” for “this paragaph”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1899A/30"},"text":"Pub. L. 99–514, § 1899A(30)","children":[],"tail":", substituted “paragraph (1)” for “paragraph 1” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s901/d/4/F"},"text":"Pub. L. 99–514, § 901(d)(4)(F)","children":[],"tail":", substituted “which is a bank (as defined in section 585(a)(2) or to which section 593 applies” for “to which section 585 or 593 applies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s902/e/2"},"text":"Pub. L. 99–514, § 902(e)(2)","children":[],"tail":", substituted “section 265(a)(5)” for “section 265(5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1899A/31"},"text":"Pub. L. 99–514, § 1899A(31)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":"” for “the date of the enactment of this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44db8037-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44db8038-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1995-12-31"},"text":"Dec. 31, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1616/c"},"text":"section 1616(c) of Pub. L. 104–188","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s593"},"text":"section 593 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44db8039-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" applicable to obligations purchased (within the meaning of section 1272(d)(1) [now 1272(c)(1)] of this title) after "},{"tag":"date","attrib":{"date":"1993-04-30"},"text":"Apr. 30, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13206/b/3"},"text":"section 13206(b)(3) of Pub. L. 103–66","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1276"},"text":"section 1276 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44db803a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44db803b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s901/d/4/F"},"text":"section 901(d)(4)(F) of Pub. L. 99–514","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s901/e"},"text":"section 901(e) of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s166"},"text":"section 166 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s902/e/2"},"text":"section 902(e)(2) of Pub. L. 99–514","children":[],"tail":" applicable to taxable years ending after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", with certain exceptions and qualifications, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s902/f"},"text":"section 902(f) of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s265"},"text":"section 265 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44db803c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years ending after ","children":[{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", and applicable to obligations acquired after "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", in taxable years ending after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s44"},"text":"section 44 of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1271"},"text":"section 1271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id44db803d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1800–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
