{"tag":"section","attrib":{"id":"id46ac96e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6112"},"text":null,"children":[{"tag":"num","attrib":{"value":"6112"},"text":"§ 6112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Material advisors of reportable transactions must keep lists of advisees, etc.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46ac96e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each material advisor (as defined in section 6111) with respect to any reportable transaction (as defined in section 6707A(c)) shall (whether or not required to file a return under section 6111 with respect to such transaction) maintain (in such manner as the Secretary may by regulations prescribe) a list—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46ac96e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying each person with respect to whom such advisor acted as a material advisor with respect to such transaction, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ac96e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" containing such other information as the Secretary may by regulations require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46ac96ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46ac96eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability for inspection; retention of information on list","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who is required to maintain a list under subsection (a) (or was required to maintain a list under subsection (a) as in effect before the enactment of the American Jobs Creation Act of 2004)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46ac96ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6112/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall make such list available to the Secretary for inspection upon written request by the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46ac96ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6112/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as otherwise provided under regulations prescribed by the Secretary, shall retain any information which is required to be included on such list for 7 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ac96ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lists which would be required to be maintained by 2 or more persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prescribe regulations which provide that, in cases in which 2 or more persons are required under subsection (a) to maintain the same list (or portion thereof), only 1 person shall be required to maintain such list (or portion).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46ac96ef-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s142/a"},"text":"Pub. L. 98–369, div. A, title I, § 142(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/681"},"text":"98 Stat. 681","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s815/b/2"},"text":"Pub. L. 108–357, title VIII, § 815(b)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1582"},"text":"118 Stat. 1582","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s403/z"},"text":"Pub. L. 109–135, title IV, § 403(z)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2629"},"text":"119 Stat. 2629","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46ac96f0-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46ac96f1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id46ac96f2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of the American Jobs Creation Act of 2004, referred to in subsec. (b)(1), means enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46ac96f3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6112 was renumbered 6116 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46ac96f4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":", in introductory provisions, inserted “(or was required to maintain a list under subsection (a) as in effect before the enactment of the American Jobs Creation Act of 2004)” after “a list under subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s815/b/2"},"text":"Pub. L. 108–357, § 815(b)(2)","children":[],"tail":", substituted “Material advisors of reportable transactions must keep lists of advisees, etc.” for “Organizers and sellers of potentially abusive tax shelters must keep lists of investors” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s815/b/2"},"text":"Pub. L. 108–357, § 815(b)(2)","children":[],"tail":", reenacted heading without change and amended text of subsec. (a) generally, substituting provisions requiring each material advisor to maintain a list identifying each person with respect to whom such advisor acted as a material advisor with respect to a reportable transaction and containing such other information as required by regulations, for provisions requiring any person who organized any potentially abusive tax shelter or sold any interest in such a shelter to maintain a list identifying each person who had been sold an interest in such shelter and containing such other information as required by regulations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s815/b/2"},"text":"Pub. L. 108–357, § 815(b)(2)","children":[],"tail":", (3)(A), redesignated subsec. (c) as (b) and struck out former subsec. (b), which defined “potentially abusive tax shelter” for purposes of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s815/b/3/B"},"text":"Pub. L. 108–357, § 815(b)(3)(B)","children":[],"tail":", inserted “written” before “request”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s815/b/3/C"},"text":"Pub. L. 108–357, § 815(b)(3)(C)","children":[],"tail":", substituted “may prescribe” for “shall prescribe”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s815/b/3/A"},"text":"Pub. L. 108–357, § 815(b)(3)(A)","children":[],"tail":", redesignated subsec. (c) as (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46ac96f5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46ac96f6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" effective as if included in the provision of the American Jobs Creation Act of 2004, "},{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/nn"},"text":"section 403(nn) of Pub. L. 109–135","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s26"},"text":"section 26 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46ac96f7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" applicable to transactions with respect to which material aid, assistance, or advice referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6111/b/1/A/i"},"text":"section 6111(b)(1)(A)(i) of this title","children":[],"tail":" is provided after "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s815/c"},"text":"section 815(c) of Pub. L. 108–357","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6111"},"text":"section 6111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46ac96f8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s142/d"},"text":"Pub. L. 98–369, div. A, title I, § 142(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/682"},"text":"98 Stat. 682","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tI/s142/d"},"text":"“The amendments made by this section [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6708"},"text":"section 6708 of this title","children":[],"tail":" and renumbering former section 6112 as "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6113"},"text":"section 6113 of this title","children":[],"tail":"] shall apply to any interest which is first sold to any investor after "},{"tag":"date","attrib":{"date":"1984-08-31"},"text":"August 31, 1984","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
