{"tag":"section","attrib":{"id":"id4651f3f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5841"},"text":null,"children":[{"tag":"num","attrib":{"value":"5841"},"text":"§ 5841.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration of firearms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4651f3f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5841/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Central registry","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall maintain a central registry of all firearms in the United States which are not in the possession or under the control of the United States. This registry shall be known as the National Firearms Registration and Transfer Record. The registry shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4651f3f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5841/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of the firearm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4651f3f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5841/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" date of registration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4651f3f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5841/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification and address of person entitled to possession of the firearm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4651f3f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5841/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By whom registered","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each manufacturer, importer, and maker shall register each firearm he manufactures, imports, or makes. Each firearm transferred shall be registered to the transferee by the transferor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4651f3f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5841/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" How registered","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each manufacturer shall notify the Secretary of the manufacture of a firearm in such manner as may by regulations be prescribed and such notification shall effect the registration of the firearm required by this section. Each importer, maker, and transferor of a firearm shall, prior to importing, making, or transferring a firearm, obtain authorization in such manner as required by this chapter or regulations issued thereunder to import, make, or transfer the firearm, and such authorization shall effect the registration of the firearm required by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4651f3fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5841/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Firearms registered on effective date of this Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person shown as possessing a firearm by the records maintained by the Secretary pursuant to the National Firearms Act in force on the day immediately prior to the effective date of the National Firearms Act of 1968 ","children":[{"tag":"ref","attrib":{"idref":"fn002270"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002270"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. See References in Text notes below."}],"tail":" shall be considered to have registered under this section the firearms in his possession which are disclosed by that record as being in his possession."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4651f3fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5841/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proof of registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person possessing a firearm registered as required by this section shall retain proof of registration which shall be made available to the Secretary upon request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4651f3fc-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/618/tII/s201"},"text":"Pub. L. 90–618, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1229"},"text":"82 Stat. 1229","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4651f3fd-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4651f3fe-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4651f3ff-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Firearms Act in force prior to the effective date of the National Firearms Act of 1968, referred to in subsec. (d), probably means the National Firearms Act in force prior to the effective date of the National Firearms Act Amendments of 1968, which is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/721"},"text":"68A Stat. 721","children":[],"tail":", and which was classified generally to prior chapter 53 (prior § 5801 et seq.) of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The effective date of this Act and the effective date of the National Firearms Act of 1968, referred to in subsec. (d) catchline and text, probably means the effective date of the National Firearms Act Amendments of 1968, which is ","children":[{"tag":"date","attrib":{"date":"1968-11-01"},"text":"Nov. 1, 1968","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/pl/90/618/s207/a"},"text":"section 207(a) of Pub. L. 90–618","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5801"},"text":"section 5801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4651f400-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5841, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/725"},"text":"68A Stat. 725","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/90/618"},"text":"Pub. L. 90–618","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4651f401-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4651f402-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4651f403-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of first month following October 1968, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/618/s207"},"text":"section 207 of Pub. L. 90–618","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5801"},"text":"section 5801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
