{"tag":"section","attrib":{"id":"id47773a0f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7604"},"text":null,"children":[{"tag":"num","attrib":{"value":"7604"},"text":"§ 7604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of summons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47773a10-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of district court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any person is summoned under the internal revenue laws to appear, to testify, or to produce books, papers, records, or other data, the United States district court for the district in which such person resides or is found shall have jurisdiction by appropriate process to compel such attendance, testimony, or production of books, papers, records, or other data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47773a11-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever any person summoned under section 6420(e)(2), 6421(g)(2), 6427(j)(2), or 7602 neglects or refuses to obey such summons, or to produce books, papers, rec­ords, or other data, or to give testimony, as required, the Secretary may apply to the judge of the district court or to a United States magistrate judge for the district within which the person so summoned resides or is found for an attachment against him as for a contempt. It shall be the duty of the judge or magistrate judge to hear the application, and, if satisfactory proof is made, to issue an attachment, directed to some proper officer, for the arrest of such person, and upon his being brought before him to proceed to a hearing of the case; and upon such hearing the judge or the United States magistrate judge shall have power to make such order as he shall deem proper, not inconsistent with the law for the punishment of contempts, to enforce obedience to the requirements of the summons and to punish such person for his default or disobedience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47773a12-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7604/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47773a13-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7604/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to issue orders, processes, and judgments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For authority of district courts generally to enforce the provisions of this title, see section 7402.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47773a14-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7604/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For penalties applicable to violation of section 6420(e)(2), 6421(g)(2), 6427(j)(2), or 7602, see section 7210.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"ta