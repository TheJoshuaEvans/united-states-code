{"tag":"section","attrib":{"id":"id44c1427a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234A"},"text":null,"children":[{"tag":"num","attrib":{"value":"1234A"},"text":"§ 1234A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gains or losses from certain terminations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Gain or loss attributable to the cancellation, lapse, expiration, or other termination of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44c1427b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234A/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a right or obligation (other than a securities futures contract, as defined in section 1234B) with respect to property which is (or on acquisition would be) a capital asset in the hands of the taxpayer, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c1427c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234A/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a section 1256 contract (as defined in section 1256) not described in paragraph (1) which is a capital asset in the hands of the taxpayer,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be treated as gain or loss from the sale of a capital asset. The preceding sentence shall not apply to the retirement of any debt instrument (whether or not through a trust or other participation arrangement).","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44c1427d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/tV/s507/a"},"text":"Pub. L. 97–34, title V, § 507(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/333"},"text":"95 Stat. 333","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tI/s105/e"},"text":"Pub. L. 97–448, title I, § 105(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2387"},"text":"96 Stat. 2387","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s102/e/4"},"text":"Pub. L. 98–369, div. A, title I, § 102(e)(4)","children":[],"tail":", (9), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/624"},"text":"98 Stat. 624","children":[],"tail":", 625; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1003/a/1"},"text":"Pub. L. 105–34, title X, § 1003(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/909"},"text":"111 Stat. 909","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIV/s401/b"},"text":"Pub. L. 106–554, § 1(a)(7) [title IV, § 401(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–648; "},{"tag":"ref","attrib":{"href":"/us/pl/107/147/tIV/s412/d/1/A"},"text":"Pub. L. 107–147, title IV, § 412(d)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-09"},"text":"Mar. 9, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/53"},"text":"116 Stat. 53","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44c1427e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":