{"tag":"section","attrib":{"id":"id462e18df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5211"},"text":null,"children":[{"tag":"num","attrib":{"value":"5211"},"text":"§ 5211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production and entry of distilled spirits","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Distilled spirits in the process of production in a distilled spirits plant may be held prior to the production gauge only for so long as is reasonably necessary to complete the process of production. Under such regulations as the Secretary shall prescribe, all distilled spirits produced in a distilled spirits plant shall be gauged and a record made of such gauge within a reasonable time after the production thereof has been completed. The proprietor shall, pursuant to such production gauge and in accordance with such regulations as the Secretary shall prescribe, make appropriate entry for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id462e18e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5211/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposit of such spirits on bonded premises for storage or processing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id462e18e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5211/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdrawal upon determination of tax as authorized by law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463088e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5211/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdrawal under the provisions of section 5214; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463088e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5211/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer for redistillation under the provisions of section 5223.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id463088e4-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1362"},"text":"72 Stat. 1362","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/26"},"text":"Pub. L. 96–39, title VIII, § 807(a)(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/284"},"text":"93 Stat. 284","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id463088e5-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id463088e6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id463088e7-3a70-1