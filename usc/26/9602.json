{"tag":"section","attrib":{"id":"id47c38577-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9602"},"text":null,"children":[{"tag":"num","attrib":{"value":"9602"},"text":"§ 9602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of Trust Funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47c38578-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be the duty of the Secretary of the Treasury to hold each Trust Fund established by subchapter A, and (after consultation with any other trustees of the Trust Fund) to report to the Congress each year on the financial condition and the results of the operations of each such Trust Fund during the preceding fiscal year and on its expected condition and operations during the next 5 fiscal years. Such report shall be printed as a House document of the session of the Congress to which the report is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c38579-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c3857a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9602/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be the duty of the Secretary of the Treasury to invest such portion of any Trust Fund established by subchapter A as is not, in his judgment, required to meet current withdrawals. Such investments may be made only in interest-bearing obligations of the United States. For such purpose, such obligations may be acquired—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c3857b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9602/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on original issue at the issue price, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c3857c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9602/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by purchase of outstanding obligations at the market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c3857d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9602/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any obligation acquired by a Trust Fund established by subchapter A may be sold by the Secretary of the Treasury at the market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c3857e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9602/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest on certain proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interest on, and the proceeds from the sale or redemption of, any obligations held in a Trust Fund established by subchapter A shall be credited to and form a part of the Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47c3857f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/119/tI/s103/a"},"text":"Pub. L. 97–119, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1638"},"text":"95 Stat. 1638","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
