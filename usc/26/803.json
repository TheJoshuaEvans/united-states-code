{"tag":"section","attrib":{"id":"id4409b1b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s803"},"text":null,"children":[{"tag":"num","attrib":{"value":"803"},"text":"§ 803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Life insurance gross income","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4409b1b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, the term “life insurance gross income” means the sum of the following amounts:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4409b1b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s803/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premiums","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4409b1b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s803/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The gross amount of premiums and other consideration on insurance and annuity contracts, less","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4409b1b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s803/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" return premiums, and premiums and other consideration arising out of indemnity reinsurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4409b1b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s803/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decreases in certain reserves","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each net decrease in reserves which is required by section 807(a) to be taken into account under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4409b1b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s803/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All amounts not includible under paragraph (1) or (2) which under this subtitle are includible in gross income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4409b1ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for premiums","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4409b1bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s803/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain items included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)(1)(A), the term “gross amount of premiums and other consideration” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4409b1bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s803/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance premiums,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4409b1bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s803/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposits,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4409b1be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s803/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fees,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4409b1bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s803/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessments,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4409b1c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s803/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consideration in respect of assuming liabilities under contracts not issued by the taxpayer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4409b1c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s803/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of policyholder dividends reimbursable to the taxpayer by a reinsurer in respect of reinsured policies,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"on insurance and annuity contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4409b1c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s803/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policyholder dividends excluded from return premiums","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)(1)(B)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4409b1c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s803/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the term “return premiums” does not include any policyholder dividends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4409b1c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s803/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for indemnity reinsurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply to amounts of premiums or other consideration returned to another life insurance company in respect of indemnity reinsurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4409b1c5-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tII/s211/a"},"text":"Pub. L. 98–369, div. A, title II, § 211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/721"},"text":"98 Stat. 721","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes"