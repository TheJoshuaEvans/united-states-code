{"tag":"section","attrib":{"id":"id440285d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s737"},"text":null,"children":[{"tag":"num","attrib":{"value":"737"},"text":"§ 737.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition of precontribution gain in case of certain distributions to contributing partner","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id440285d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s737/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any distribution by a partnership to a partner, such partner shall be treated as recognizing gain in an amount equal to the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id440285d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s737/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the excess (if any) of (A) the fair market value of property (other than money) received in the distribution over (B) the adjusted basis of such partner’s interest in the partnership immediately before the distribution reduced (but not below zero) by the amount of money received in the distribution, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440285d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s737/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the net precontribution gain of the partner.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Gain recognized under the preceding sentence shall be in addition to any gain recognized under section 731. The character of such gain shall be determined by reference to the proportionate character of the net precontribution gain.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id440285d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s737/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net precontribution gain","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “net precontribution gain” means the net gain (if any) which would have been recognized by the distributee partner under section 704(c)(1)(B) if all property which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id440285d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s737/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had been contributed to the partnership by the distributee partner within 7 years of the distribution, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440285d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s737/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is held by such partnership immediately before the distribution,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"had been distributed by such partnership to another partner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id440285d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s737/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id440285da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s737/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partner’s interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The adjusted basis of a partner’s interest in a partnership shall be increased by the amount of any gain recognized by such partner under subsection (a). For purposes of determining the basis of the distributed property (other than money), such increase shall be treated as occurring immediately before the distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440285db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s737/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership’s basis in contributed property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appropriate adjustments shall be made to the adjusted basis of the partnership in the contributed property referred to in subsection (b) to reflect gain recognized under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id440285dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s737/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id440285dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s737/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions of previously contributed property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any portion of the property distributed consists of property which had been contributed by the distributee partner to the partnership, such property shall not be taken into account under subsection (a)(1) and shall not be taken into account in determining the amount of the net precontribution gain. If the property distributed consists of an interest in an entity, the preceding sentence shall not apply to the extent that the value of such interest is attributable to property contributed to such entity after such interest had been contributed to the partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440285de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s737/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with section 751","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to the extent section 751(b) applies to such distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id440285df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s737/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marketable securities treated as money","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For treatment of marketable securities as money for purposes of this section, see section 731(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id440285e0-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s1937/a"},"text":"Pub. L. 102–486, title XIX, § 1937(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3032"},"text":"106 Stat. 3032","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tVII/s741/b"},"text":"Pub. L. 103–465, title VII, § 741(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/5009"},"text":"108 Stat. 5009","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1704/j/8"},"text":"Pub. L. 104–188, title I, § 1704(j)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1882"},"text":"110 Stat. 1882","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1063/a"},"text":"Pub. L. 105–34, title X, § 1063(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/947"},"text":"111 Stat. 947","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id440285e1-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id440285e2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id440285e3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" substituted “7 years” for “5 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" provided that "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/s1937/a"},"text":"section 1937(a) of Pub. L. 102–486","children":[],"tail":", shall be applied as if “Subpart B” appeared instead of “Subpart C”. "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/s1937/a"},"text":"Section 1937(a) of Pub. L. 102–486","children":[],"tail":" directed amendment of subpart C of this part by adding this section at the end thereof."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s741/b/1"},"text":"Pub. L. 103–465, § 741(b)(1)","children":[],"tail":", amended last sentence generally. Prior to amendment, last sentence read as follows: “Except for purposes of determining the amount recognized under subsection (a), such increase shall be treated as occurring immediately before the distribution.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s741/b/2"},"text":"Pub. L. 103–465, § 741(b)(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id440285e4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id440285e5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" applicable to property contributed to a partnership after "},{"tag":"date","attrib":{"date":"1997-06-08"},"text":"June 8, 1997","children":[],"tail":", but not applicable to any property contributed pursuant to a written binding contract in effect on "},{"tag":"date","attrib":{"date":"1997-06-08"},"text":"June 8, 1997","children":[],"tail":", and at all times thereafter before such contribution if such contract provides for the contribution of a fixed amount of property, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1063/b"},"text":"section 1063(b) of Pub. L. 105–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s704"},"text":"section 704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id440285e6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" applicable to distributions after "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", and not applicable to certain distributions before "},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":", distributions in liquidation of partner’s interest, or distributions in complete liquidation of publicly traded partnerships, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s741/c"},"text":"section 741(c) of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s731"},"text":"section 731 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id440285e7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to distributions on or after ","children":[{"tag":"date","attrib":{"date":"1992-06-25"},"text":"June 25, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/s1937/c"},"text":"section 1937(c) of Pub. L. 102–486","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s704"},"text":"section 704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
