{"tag":"section","attrib":{"id":"id474777c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7214"},"text":null,"children":[{"tag":"num","attrib":{"value":"7214"},"text":"§ 7214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offenses by officers and employees of the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id474777c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7214/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful acts of revenue officers or agents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any officer or employee of the United States acting in connection with any revenue law of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id474777c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7214/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is guilty of any extortion or willful oppression under color of law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474777c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7214/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who knowingly demands other or greater sums than are authorized by law, or receives any fee, compensation, or reward, except as by law prescribed, for the performance of any duty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474777c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7214/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who with intent to defeat the application of any provision of this title fails to perform any of the duties of his office or employment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474777c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7214/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who conspires or colludes with any other person to defraud the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474777ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7214/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who knowingly makes opportunity for any person to defraud the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474777cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7214/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who does or omits to do any act with intent to enable any other person to defraud the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474777cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7214/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who makes or signs any fraudulent entry in any book, or makes or signs any fraudulent certificate, return, or statement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474777cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7214/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, having knowledge or information of the violation of any revenue law by any person, or of fraud committed by any person against the United States under any revenue law, fails to report, in writing, such knowledge or information to the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474777ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7214/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who demands, or accepts, or attempts to collect, directly or indirectly as payment or gift, or otherwise, any sum of money or other thing of value for the compromise, adjustment, or settlement of any charge or complaint for any violation or alleged violation of law, except as expressly authorized by law so to do;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be dismissed from office or discharged from employment and, upon conviction thereof, shall be fined not more than $10,000, or imprisoned not more than 5 years, or both. The court may in its discretion award out of the fine so imposed an amount, not in excess of one-half thereof, for the use of the informer, if any, who shall be ascertained by the judgment of the court. The court also shall render judgment against the said officer or employee for the amount of damages sustained in favor of the party injured, to be collected by execution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id474777cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7214/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest of internal revenue officer or employee in tobacco or liquor production","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any internal revenue officer or employee interested, directly or indirectly, in the manufacture of tobacco, snuff, or cigarettes, or in the production, rectification, or redistillation of distilled spirits, shall be dismissed from office; and each such officer or employee so interested in any such manufacture or production, rectification, or redistillation or production of fermented liquors shall be fined not more than $5,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id474777d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7214/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For penalty on collecting or disbursing officers trading in public funds or debts or property, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1901"},"text":"18 U.S.C. 1901","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id474777d1-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/856"},"text":"68A Stat. 856","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s204/5"},"text":"Pub. L. 85–859, title II, § 204(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1429"},"text":"72 Stat. 1429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id474777d2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id474777d3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id474777d4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" struck out a cross reference that related to penalty imposed for unlawfully removing or permitting to be removed distilled spirits from a bonded warehouse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id474777d5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id474777d6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1958-09-03"},"text":"Sept. 3, 1958","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/s210/a/1"},"text":"section 210(a)(1) of Pub. L. 85–859","children":[],"tail":", set out as Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
