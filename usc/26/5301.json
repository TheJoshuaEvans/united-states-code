{"tag":"section","attrib":{"id":"id46354445-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5301"},"text":null,"children":[{"tag":"num","attrib":{"value":"5301"},"text":"§ 5301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46354446-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever in his judgment such action is necessary to protect the revenue, the Secretary is authorized, by the regulations prescribed by him and permits issued thereunder if required by him—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46354447-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to regulate the kind, size, branding, marking, sale, resale, possession, use, and reuse of containers (of a capacity of not more than 5 wine gallons) designed or intended for use for the sale of distilled spirits (within the meaning of such term as it is used in section 5002(a)(8) for other than industrial use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46354448-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require, of persons manufacturing, dealing in, or using any such containers, the submission to such inspection, the keeping of such records, and the filing of such reports as may be deemed by him reasonably necessary in connection therewith.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any requirements imposed under this section shall be in addition to any other requirements imposed by, or pursuant to, law and shall apply as well to persons not liable for tax under the internal revenue laws as to persons so liable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46354449-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person disposing of containers of the character used for the packaging of distilled spirits shall, when required by the Secretary for protection of the revenue, render a correct return, in such form and manner as the Secretary may by regulations prescribe, showing the name and address of the person to whom each disposition was made, with such details as to the quantities so disposed of or other information which the Secretary may require as to each such disposition. Every person required to render a return under this section shall keep such records as will enable such person to render a correct return. Such records shall be preserved for such period as the Secretary shall by regulations prescribe, and shall be kept available for inspection by any internal revenue officer during business hours.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4635444a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refilling of liquor bottles","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person who sells, or offers for sale, distilled spirits, or agent or employee of such person, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4635444b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5301/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" place in any liquor bottle any distilled spirits whatsoever other than those contained in such bottle at the time of tax determination under the provisions of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4635444c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5301/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possess any liquor bottle in which any distilled spirits have been placed in violation of the provisions of paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4635444d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5301/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the addition of any substance whatsoever to any liquor bottle, in any manner alter or increase any portion of the original contents contained in such bottle at the time of tax determination under the provisions of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4635444e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5301/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possess any liquor bottle, any portion of the contents of which has been altered or increased in violation of the provisions of paragraph (3);","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that the Secretary may by regulations authorize the reuse of liquor bottles, under such conditions as he may by regulations prescribe. When used in this subsection the term “liquor bottle” shall mean a liquor bottle or other container which has been used for the bottling or packaging of distilled spirits under regulations issued pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4635444f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5301/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The immediate container of distilled spirits withdrawn from bonded premises, or from customs custody, on determination of tax shall bear a closure or other device which is designed so as to require breaking in order to gain access to the contents of such container. The preceding sentence shall not apply to containers of bulk distilled spirits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46354450-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5301/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For penalty for violation of this section, see section 5606.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46354451-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1374"},"text":"72 Stat. 1374","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/41"},"text":"Pub. L. 96–39, title VIII, § 807(a)(41)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/287"},"text":"93 Stat. 287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s454/b"},"text":"Pub. L. 98–369, div. A, title IV, § 454(b)","children":[],"tail":", (c)(9), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/820"},"text":"98 Stat. 820","children":[],"tail":", 821.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46354452-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46354453-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46354454-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5301, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/654"},"text":"68A Stat. 654","children":[],"tail":", related to establishment of industrial alcohol plants, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See sections 5171(a), (b)(1), 5172, 5173(a), (b) of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising subsecs. (a), (c), and (d) of this section were contained in prior section 5214, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/639"},"text":"68A Stat. 639","children":[],"tail":", prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5302, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/645"},"text":"68A Stat. 645","children":[],"tail":", related to the establishment of industrial alcohol warehouses, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See sections 5171(a), (b)(1), 5172, 5173(a), (c), 5178(a)(3)(A), (B), 5201(a), and 5206(a) of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5303, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/655"},"text":"68A Stat. 655","children":[],"tail":", related to establishment of industrial alcohol denaturing plants, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See sections 5171(a), (b)(1), 5172, 5173(a), (c), 5178(a)(5), 5241, 5242, and 5273(b)(1), (2), (d) of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5304, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/655"},"text":"68A Stat. 655","children":[],"tail":", related to alcohol permits, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See sections 5171(b)(1), 5173(a), (e)(1), 5271(a) to (c), (e), (f), (h), and 5272(a) of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5305, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/657"},"text":"68A Stat. 657","children":[],"tail":", related to regulations for establishing, bonding, and operations of plants and warehouses, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See sections 5171, 5172, 5173(a), 5178(a)(1)(A), (5), 5201(a), (b), 5207(a), (c), (d), 5211, 5223(a), 5235, 5273(b)(1), (2), (d), 5275, and 5312(b) of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5306, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/657"},"text":"68A Stat. 657","children":[],"tail":", related to exemption of industrial alcohol plants and warehouses from certain laws, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See sections 5025(d), (e)(1), 5173(c), 5201(a), (c), 5204(c), 5234(a)(1)(A), 5306, and 5312(c) of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5307, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/657"},"text":"68A Stat. 657","children":[],"tail":", related to production, use, or sale of alcohol, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See sections 5178(a)(2)(A) and 5201(a) of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5308, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/657"},"text":"68A Stat. 657","children":[],"tail":", related to transfer of alcohol to other plants or warehouses, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See sections 5212 and 5223(a) of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5309, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/658"},"text":"68A Stat. 658","children":[],"tail":", related to withdrawal of fermented liquors to industrial alcohol plants, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5222/b"},"text":"section 5222(b) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5310, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/658"},"text":"68A Stat. 658","children":[],"tail":", related to withdrawal of alcohol free of tax, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See sections 5214(a), (a)(1) to (3), 5241, 5242, 5272(b), 5273(b)(1), (2), (d), and 5313 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46354455-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s454/c/9"},"text":"Pub. L. 98–369, § 454(c)(9)","children":[],"tail":", substituted “tax determination” for “stamping” in pars. (1) and (3), and struck out “, if the liquor bottles are to be again stamped under the provisions of this chapter” after “by regulations prescribe” in provisions following par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s454/b"},"text":"Pub. L. 98–369, § 454(b)","children":[],"tail":", added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" substituted “section 5002(a)(8)” for “section 5002(a)(6)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46354456-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46354457-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-07-01"},"text":"July 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s456/b"},"text":"section 456(b) of Pub. L. 98–369","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5101"},"text":"section 5101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46354458-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-01-01"},"text":"Jan. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/s810"},"text":"section 810 of Pub. L. 96–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46354459-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1959-07-01"},"text":"July 1, 1959","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/s210/a/1"},"text":"section 210(a)(1) of Pub. L. 85–859","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
