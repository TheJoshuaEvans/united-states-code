{"tag":"section","attrib":{"id":"id43ed014e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s645"},"text":null,"children":[{"tag":"num","attrib":{"value":"645"},"text":"§ 645.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain revocable trusts treated as part of estate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43ed014f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s645/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subtitle, if both the executor (if any) of an estate and the trustee of a qualified revocable trust elect the treatment provided in this section, such trust shall be treated and taxed as part of such estate (and not as a separate trust) for all taxable years of the estate ending after the date of the decedent’s death and before the applicable date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43ed0150-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s645/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43ed0151-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s645/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified revocable trust","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified revocable trust” means any trust (or portion thereof) which was treated under section 676 as owned by the decedent of the estate referred to in subsection (a) by reason of a power in the grantor (determined without regard to section 672(e)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43ed0152-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s645/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable date","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable date” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43ed0153-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s645/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if no return of tax imposed by chapter 11 is required to be filed, the date which is 2 years after the date of the decedent’s death, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43ed0154-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s645/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such a return is required to be filed, the date which is 6 months after the date of the final determination of the liability for tax imposed by chapter 11.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43ed0155-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s645/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The election under subsection (a) shall be made not later than the time prescribed for filing the return of tax imposed by this chapter for the first taxable year of the estate (determined with regard to extensions) and, once made, shall be irrevocable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43ed0156-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIII/s1305/a"},"text":"Pub. L. 105–34, title XIII, § 1305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1040"},"text":"111 Stat. 1040","children":[],"tail":", § 646; renumbered § 645, "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tVI/s6013/a/1"},"text":"Pub. L. 105–206, title VI, § 6013(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/819"},"text":"112 Stat. 819","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43ed0157-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43ed0158-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id43ed0159-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 645 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s644"},"text":"section 644 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43ed015a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s646"},"text":"section 646 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43ed015b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id43ed015c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIII/s1305/d"},"text":"Pub. L. 105–34, title XIII, § 1305(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1041"},"text":"111 Stat. 1041","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tXIII/s1305/d"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s2652"},"text":"section 2652 of this title","children":[],"tail":"] shall apply with respect to estates of decedents dying after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
