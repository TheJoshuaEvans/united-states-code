801(a)(14)","children":[],"tail":", struck out subsec. (d) which related to application of section to taxable years beginning after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"Dec. 31, 1976","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1983-01-01"},"text":"Jan. 1, 1983","children":[],"tail":", and to taxable years beginning after "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"Dec. 31, 1983","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “1983” for “1983, and before "},{"tag":"date","attrib":{"date":"1986-01-01"},"text":"January 1, 1986","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1062/b"},"text":"Pub. L. 98–369, § 1062(b)","children":[],"tail":", substituted “$35,000” for “$25,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1062/a/1"},"text":"Pub. L. 98–369, § 1062(a)(1)","children":[],"tail":", amended subsec. (d) generally, substituting provisions that this section shall apply to taxable years beginning after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1983-01-01"},"text":"January 1, 1983","children":[],"tail":", and to taxable years beginning after "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1986-01-01"},"text":"January 1, 1986","children":[],"tail":" for provisions which had required the Secretary to prescribe such regulations as might be necessary to carry out this section within 180 days after "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"October 4, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4219c8d1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4219c8d2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11611/c"},"text":"section 11611(c) of Pub. L. 101–508","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11611/e/2"},"text":"section 11611(e)(2) of Pub. L. 101–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4219c8d3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1062/c"},"text":"Pub. L. 98–369, div. A, title X, § 1062(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1047"},"text":"98 Stat. 1047","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tX/s1062/c"},"text":"“The amendment made by subsection (b) [amending this section] shall apply t