{"tag":"section","attrib":{"id":"id4219c8c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s190"},"text":null,"children":[{"tag":"num","attrib":{"value":"190"},"text":"§ 190.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures to remove architectural and transportation barriers to the handicapped and elderly","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4219c8c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s190/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4219c8c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s190/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A taxpayer may elect to treat qualified architectural and transportation barrier removal expenses which are paid or incurred by him during the taxable year as expenses which are not chargeable to capital account. The expenditures so treated shall be allowed as a deduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4219c8c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s190/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under paragraph (1) shall be made at such time and in such manner as the Secretary prescribes by regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4219c8c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s190/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4219c8c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s190/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Architectural and transportation barrier removal expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “architectural and transportation barrier removal expenses” means an expenditure for the purpose of making any facility or public transportation vehicle owned or leased by the taxpayer for use in connection with his trade or business more accessible to, and usable by, handicapped and elderly individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4219c8ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s190/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified architectural and transportation barrier removal expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified architectural and transportation barrier removal expense” means, with respect to any such facility or public transportation vehicle, an architectural or transportation barrier removal expense with respect to which the taxpayer establishes, to the satisfaction of the Secretary, that the resulting removal of any such barrier meets the standards promulgated by the Secretary with the concurrence of the Architectural and Transportation Barriers Compliance Board and set forth in regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4219c8cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s190/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Handicapped individual","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “handicapped individual” means any individual who has a physical or mental disability (including, but not limited to, blindness or deafness) which for such individual constitutes or results in a functional limitation to employment, or who has any physical or mental impairment (including, but not limited to, a sight or hearing impairment) which substantially limits one or more major life activities of such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4219c8cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s190/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The deduction allowed by subsection (a) for any taxable year shall not exceed $15,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4219c8cd-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXXI/s2122/a"},"text":"Pub. L. 94–455, title XXI, § 2122(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1914"},"text":"90 Stat. 1914","children":[],"tail":"; amended "},{"tag":"ref","attri