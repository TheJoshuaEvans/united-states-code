{"tag":"section","attrib":{"id":"id457687d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3232"},"text":null,"children":[{"tag":"num","attrib":{"value":"3232"},"text":"§ 3232.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The several district courts of the United States shall have jurisdiction to entertain an application by the Attorney General on behalf of the Secretary to compel an employee or other person residing within the jurisdiction of the court or an employer subject to service of process within its jurisdiction to comply with any obligations imposed on such employee, employer, or other person under the provisions of this chapter. The jurisdiction herein specifically conferred upon such Federal courts shall not be held exclusive of any jurisdiction otherwise possessed by such courts to entertain civil actions, whether legal or equitable in nature, in aid of the enforcement of rights or obligations arising under the provisions of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id457687d8-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/437"},"text":"68A Stat. 437","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id457687d9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id457687da-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id457687db-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
