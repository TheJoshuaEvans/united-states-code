{"tag":"section","attrib":{"id":"id4669c19f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039C"},"text":null,"children":[{"tag":"num","attrib":{"value":"6039C"},"text":"§ 6039C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns with respect to foreign persons holding direct investments in United States real property interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4669c1a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent provided in regulations, any foreign person holding direct investments in United States real property interests for the calendar year shall make a return setting forth—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4669c1a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039C/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of such person,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c1a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039C/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of all United States real property interests held by such person at any time during the calendar year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c1a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039C/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4669c1a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of foreign persons holding direct investments in United States real property interests","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a foreign person shall be treated as holding direct investments in United States real property interests during any calendar year if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4669c1a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039C/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person did not engage in a trade or business in the United States at any time during such calendar year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c1a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039C/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of the United States real property interests held directly by such person at any time during such year equals or exceeds $50,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4669c1a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4669c1a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039C/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States real property interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States real property interest” has the meaning given to such term by section 897(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c1a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039C/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign person” means any person who is not a United States person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c1aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039C/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attribution of ownership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (b)(2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4669c1ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039C/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interests held by partnerships, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"United States real property interests held by a partnership, trust, or estate shall be treated as owned proportionately by its partners or beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4669c1ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039C/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interests held by family members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"United States real property interests held by the spouse or any minor child of an individual shall be treated as owned by such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c1ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039C/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time and manner of filing return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All returns required to be made under this section shall be made at such time and in such manner as the Secretary shall by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4669c1ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039C/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for United States interest and Virgin Islands interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A nonresident alien individual or foreign corporation subject to tax under section 897(a) (and any person required to withhold tax under section 1445) shall pay any tax and file any return required by this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4669c1af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039C/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the United States, in the case of any interest in real property located in the United States and an interest (other than an interest solely as a creditor) in a domestic corporation (with respect to the United States) described in section 897(c)(1)(A)(ii), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c1b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039C/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Virgin Islands, in the case of any interest in real property located in the Virgin Islands and an interest (other than an interest solely as a creditor) in a domestic corporation (with respect to the Virgin Islands) described in section 897(c)(1)(A)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4669c1b1-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/499/tXI/s1123/a"},"text":"Pub. L. 96–499, title XI, § 1123(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-05"},"text":"Dec. 5, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2687"},"text":"94 Stat. 2687","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tVIII/s831/a/3"},"text":"Pub. L. 97–34, title VIII, § 831(a)(3)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/352"},"text":"95 Stat. 352","children":[],"tail":", 354; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s129/b/1"},"text":"Pub. L. 98–369, div. A, title I, § 129(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/659"},"text":"98 Stat. 659","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1810/f/7"},"text":"Pub. L. 99–514, title XVIII, § 1810(f)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2828"},"text":"100 Stat. 2828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4669c1b2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4669c1b3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4669c1b4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" inserted “(and any person required to withhold tax under section 1445)” after “section 897(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" amended section generally, inserting in section catchline “foreign persons holding direct investments in” and substituting in text provisions concerning returns with respect to foreign persons holding direct investments in United States real property for provisions concerning returns with respect to United States real property interests."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s831/e"},"text":"Pub. L. 97–34, § 831(e)","children":[],"tail":", substituted “For purposes of determining whether an entity to which this subsection applies has a substantial investor in United States real property, the assets of any person shall include the person’s pro rata share of the United States real property interest held by any corporation (whether domestic or foreign) if the person’s pro rata share of the United States real property interests exceeded $50,000” for “The assets of any entity to which this subsection applies shall include its pro rata share of the United States real property interests held by any corporation in which the entity is a substantial investor in United States real property”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s831/a/3"},"text":"Pub. L. 97–34, § 831(a)(3)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4669c1b5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4669c1b6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4669c1b7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s129/c/2"},"text":"Pub. L. 98–369, div. A, title I, § 129(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/660"},"text":"98 Stat. 660","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tI/s129/c/2"},"text":"“The amendments made by subsection (b) [amending this section] shall apply to calendar year 1980 and subsequent calendar years.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4669c1b8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" applicable to dispositions after "},{"tag":"date","attrib":{"date":"1980-06-18"},"text":"June 18, 1980","children":[],"tail":", in taxable years ending after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/s831/i"},"text":"section 831(i) of Pub. L. 97–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s897"},"text":"section 897 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4669c1b9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to 1980 and subsequent calendar years, with 1980 being treated as beginning on ","children":[{"tag":"date","attrib":{"date":"1980-06-19"},"text":"June 19, 1980","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1980-12-31"},"text":"Dec. 31, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/499/s1125/b"},"text":"section 1125(b) of Pub. L. 96–499","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s897"},"text":"section 897 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
