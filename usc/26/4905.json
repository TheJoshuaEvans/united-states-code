{"tag":"section","attrib":{"id":"id45e43d78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4905"},"text":null,"children":[{"tag":"num","attrib":{"value":"4905"},"text":"§ 4905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability in case of death or change of location","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45e43d79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When any person who has paid the special tax for any trade or business dies, his spouse or child, or executors or administrators or other legal representatives, may occupy the house or premises, and in like manner carry on, for the residue of the term for which the tax is paid, the same trade or business as the deceased before carried on, in the same house and upon the same premises, without the payment of any additional tax. When any person removes from the house or premises for which any trade or business was taxed to any other place, he may carry on the trade or business specified in the register kept in the office of the official in charge of the internal revenue district at the place to which he removes, without the payment of any additional tax: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That all cases of death, change, or removal, as aforesaid, with the name of the successor to any person deceased, or of the person making such change or removal, shall be registered with the Secretary, under regulations to be prescribed by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45e43d7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For registration in case of wagering, see section 4412.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45e43d7b-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/594"},"text":"68A Stat. 594","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tIV/s405/c"},"text":"Pub. L. 89–44, title IV, § 405(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/149"},"text":"79 Stat. 149","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/513/tIII/s1102/b"},"text":"Pub. L. 91–513, title III, § 1102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1292"},"text":"84 Stat. 1292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1904(a)(20), (b)(8)(A), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1814"},"text":"90 Stat. 1814","children":[],"tail":", 1816, 1834.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45e43d7c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45e43d7d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attri