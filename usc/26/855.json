{"tag":"section","attrib":{"id":"id4428ab51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s855"},"text":null,"children":[{"tag":"num","attrib":{"value":"855"},"text":"§ 855.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dividends paid by regulated investment company after close of taxable year","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4428ab52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s855/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, if a regulated investment company—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4428ab53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s855/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" declares a dividend on or before the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4428ab54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s855/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 15th day of the 9th month following the close of the taxable year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4428ab55-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s855/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an extension of time for filing the company’s return for the taxable year, the due date for filing such return taking into account such extension, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4428ab56-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s855/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributes the amount of such dividend to shareholders in the 12-month period following the close of such taxable year and not later than the date of the first dividend payment of the same type of dividend made after such declaration,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the amount so declared and distributed shall, to the extent the company elects in such return in accordance with regulations prescribed by the Secretary, be considered as having been paid during such taxable year, except as provided in subsections (b) and (c). For purposes of paragraph (2), a dividend attributable to any short-term capital gain with respect to which a notice is required under the Investment Company Act of 1940 shall be treated as the same type of dividend as a capital gain dividend.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4428ab57-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s855/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt by shareholder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in section 852(b)(7), amounts to which subsection (a) is applicable shall be treated as received by the shareholder in the taxable year in which the distribution is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4428ab58-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s855/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign tax election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an investment company to which section 853 is applicable for the taxable year makes a distribution as provided in subsection (a) of this section, the shareholders shall consider the amounts described in section 853(b)(2) allocable to such distribution as paid or received, as the case may be, in the taxable year in which the distribution is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4428ab59-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/274"},"text":"68A Stat. 274","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/779/s10/b/2"},"text":"Pub. L. 86–779, § 10(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-14"},"text":"Sept. 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/1009"},"text":"74 Stat. 1009","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s229/a/5"},"text":"Pub. L. 88–272, title II, § 229(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/99"},"text":"78 Stat. 99","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI"},"text":"Pub. L. 99–514, title VI","children":[],"tail":", §§ 651(b)(1)(B), 655(a)(5), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2296"},"text":"100 Stat. 2296","children":[],"tail":", 2299; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006"},"text":"Pub. L. 100–647, title I, § 1006","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1)(B), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3413"},"text":"102 Stat. 3413","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/325/tIII"},"text":"Pub. L. 111–325, title III","children":[],"tail":", §§ 301(g), 304(a)–(c), "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3547-3549"},"text":"124 Stat. 3547–3549","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s205/b"},"text":"Pub. L. 113–295, div. A, title II, § 205(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4026"},"text":"128 Stat. 4026","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4428ab5a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4428ab5b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4428ab5c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Investment Company Act of 1940, referred to in subsec. (a), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"act Aug. 22, 1940, ch. 686","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/789"},"text":"54 Stat. 789","children":[],"tail":", which is classified generally to subchapter I (§ 80a–1 et seq.) of chapter 2D of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–51"},"text":"section 80a–51 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4428ab5d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" inserted “on or” before “before” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325/s304/c"},"text":"Pub. L. 111–325, § 304(c)","children":[],"tail":", in concluding provisions, inserted at end “For purposes of paragraph (2), a dividend attributable to any short-term capital gain with respect to which a notice is required under the Investment Company Act of 1940 shall be treated as the same type of dividend as a capital gain dividend.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325/s301/g/2"},"text":"Pub. L. 111–325, § 301(g)(2)","children":[],"tail":", substituted “and (c)” for “, (c) and (d)” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325/s304/a"},"text":"Pub. L. 111–325, § 304(a)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “declares a dividend prior to the time prescribed by law for the filing of its return for a taxable year (including the period of any extension of time granted for filing such return), and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325/s304/b"},"text":"Pub. L. 111–325, § 304(b)","children":[],"tail":", substituted “the first dividend payment of the same type of dividend” for “the first regular dividend payment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325/s301/g/1"},"text":"Pub. L. 111–325, § 301(g)(1)","children":[],"tail":", redesignated subsec. (d) as (c) and struck out former subsec. (c). Text of former subsec. (c) read as follows: “In the case of amounts to which subsection (a) is applicable, any notice to shareholders required under this part with respect to such amounts shall be made not later than 60 days after the close of the taxable year in which the distribution is made.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" substituted “section 852(b)(7)” for “section 852(b)(6)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s651/b/1/B"},"text":"Pub. L. 99–514, § 651(b)(1)(B)","children":[],"tail":", substituted “Except as provided in section 852(b)(6), amounts” for “Amounts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s655/a/5"},"text":"Pub. L. 99–514, § 655(a)(5)","children":[],"tail":", substituted “60 days” for “45 days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272"},"text":"Pub. L. 88–272","children":[],"tail":" substituted “45 days” for “30 days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/779"},"text":"Pub. L. 86–779","children":[],"tail":" substituted “this part” for “this subchapter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4428ab5e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4428ab5f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" effective as if included in the provision of the Regulated Investment Company Modernization Act of 2010, "},{"tag":"ref","attrib":{"href":"/us/pl/111/325"},"text":"Pub. L. 111–325","children":[],"tail":", to which such amendment relates, with savings provision in certain cases of an election by a regulated investment company under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s852/b/8"},"text":"section 852(b)(8) of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s205/f"},"text":"section 205(f) of Pub. L. 113–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s852"},"text":"section 852 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4428ab60-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325/s301/g"},"text":"section 301(g) of Pub. L. 111–325","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/325/s301/h"},"text":"section 301(h) of Pub. L. 111–325","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s852"},"text":"section 852 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325/tIII/s304/d"},"text":"Pub. L. 111–325, title III, § 304(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3549"},"text":"124 Stat. 3549","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/325/tIII/s304/d"},"text":"“The amendments made by this section [amending this section] shall apply to distributions in taxable years beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4428ab61-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4428ab62-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s651/b/1/B"},"text":"section 651(b)(1)(B) of Pub. L. 99–514","children":[],"tail":" applicable to calendar years beginning after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s651/d"},"text":"section 651(d) of Pub. L. 99–514","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4982"},"text":"section 4982 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s655/a/5"},"text":"section 655(a)(5) of Pub. L. 99–514","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s655/b"},"text":"section 655(b) of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s852"},"text":"section 852 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4428ab63-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1964 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272"},"text":"Pub. L. 88–272","children":[],"tail":" applicable to taxable years of regulated investment companies ending on or after "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/88/272/s229/c"},"text":"section 229(c) of Pub. L. 88–272","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s852"},"text":"section 852 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4428ab64-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1960 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/779"},"text":"Pub. L. 86–779","children":[],"tail":" applicable with respect to taxable years of real estate investment trusts beginning after "},{"tag":"date","attrib":{"date":"1960-12-31"},"text":"Dec. 31, 1960","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/86/779/s10/k"},"text":"section 10(k) of Pub. L. 86–779","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s856"},"text":"section 856 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
