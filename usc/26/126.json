{"tag":"section","attrib":{"id":"id417068ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126"},"text":null,"children":[{"tag":"num","attrib":{"value":"126"},"text":"§ 126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain cost-sharing payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id417068ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Gross income does not include the excludable portion of payments received under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id417068f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rural clean water program authorized by section 208(j) of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1288/j"},"text":"33 U.S.C. 1288(j)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417068f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rural abandoned mine program authorized by section 406 of the Surface Mining Control and Reclamation Act of 1977 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1236"},"text":"30 U.S.C. 1236","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417068f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The water bank program authorized by the Water Bank Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1301"},"text":"16 U.S.C. 1301","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417068f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The emergency conservation measures program authorized by title IV of the Agricultural Credit Act of 1978.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417068f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The agricultural conservation program authorized by the Soil Conservation and Domestic Allotment Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590a"},"text":"16 U.S.C. 590a","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417068f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The resource conservation and development program authorized by the Bankhead-Jones Farm Tenant Act and by the Soil Conservation and Domestic Allotment Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1010"},"text":"7 U.S.C. 1010","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s590a"},"text":"16 U.S.C. 590a","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417068f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any small watershed program administered by the Secretary of Agriculture which is determined by the Secretary of the Treasury or his delegate to be substantially similar to the type of programs described in paragraphs (1) through (8).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417068f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any program of a State, possession of the United States, a political subdivision of any of the foregoing, or the District of Columbia under which payments are made to individuals primarily for the purpose of conserving soil, protecting or restoring the environment, improving forests, or providing a habitat for wildlife.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417068f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excludable portion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id417068f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “excludable portion” means that portion (or all) of a payment made to any person under any program described in subsection (a) which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id417068fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined by the Secretary of Agriculture to be made primarily for the purpose of conserving soil and water resources, protecting or restoring the environment, improving forests, or providing a habitat for wildlife, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417068fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined by the Secretary of the Treasury or his delegate as not increasing substantially the annual income derived from the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417068fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments not chargeable to capital account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “excludable portion” does not include that portion of any payment which is properly associated with an amount which is allowable as a deduction for the taxable year in which such amount is paid or incurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417068fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election for section not to apply","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id417068fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The taxpayer may elect not to have this section (and section 1255) apply to any excludable portion (or portion thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417068ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner and time for making election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any election under paragraph (1) shall be made in the manner prescribed by the Secretary by regulations and shall be made not later than the due date prescribed by law (including extensions) for filing the return of tax under this chapter for the taxable year in which the payment was received or accrued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41706900-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of double benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction or credit shall be allowed with respect to any expenditure which is properly associated with any amount excluded from gross income under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4172da01-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s126/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis of property not increased by reason of excludable payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any provision of section 1016 to the contrary, no adjustment to basis shall be made with respect to property acquired or improved through the use of any payment, to the extent that such adjustment would reflect any amount which is excluded from gross income under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4172da02-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/tV/s543/a"},"text":"Pub. L. 95–600, title V, § 543(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2888"},"text":"92 Stat. 2888","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/222/tI/s105/a/7/A"},"text":"Pub. L. 96–222, title I, § 105(a)(7)(A)","children":[],"tail":", (C), (E), "},{"tag":"date","attrib":{"date":"1980-04-01"},"text":"Apr. 1, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/220"},"text":"94 Stat. 220","children":[],"tail":", 221; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/22"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4040"},"text":"128 Stat. 4040","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/b/9"},"text":"Pub. L. 115–141, div. U, title IV, § 401(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1202"},"text":"132 Stat. 1202","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4172da03-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4172da04-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4172da05-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Water Bank Act, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/559"},"text":"Pub. L. 91–559","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-19"},"text":"Dec. 19, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1468"},"text":"84 Stat. 1468","children":[],"tail":", which is classified generally to chapter 29 (§ 1301 et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1301"},"text":"section 1301 of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Agricultural Credit Act of 1978, referred to in subsec. (a)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/334"},"text":"Pub. L. 95–334","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-04"},"text":"Aug. 4, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/420"},"text":"92 Stat. 420","children":[],"tail":". Title IV of the Agricultural Credit Act of 1978 is classified generally to chapter 42 (§ 2201 et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Soil Conservation and Domestic Allotment Act, referred to in subsec. (a)(5), (6), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-04-27/ch85"},"text":"act Apr. 27, 1935, ch. 85","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/163"},"text":"49 Stat. 163","children":[],"tail":", which is classified generally to chapter 3B (§ 590a et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s590q"},"text":"section 590q of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Bankhead-Jones Farm Tenant Act, referred to in subsec. (a)(6), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-07-22/ch517"},"text":"act July 22, 1937, ch. 517","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/522"},"text":"50 Stat. 522","children":[],"tail":", which is classified generally to chapter 33 (§ 1000 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1000"},"text":"section 1000 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4172da06-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 126 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s140"},"text":"section 140 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4172da07-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(7) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" redesignated pars. (8) and (9) as (7) and (8), respectively, and struck out former par. (7) which read as follows: “The forestry incentives program authorized by section 4 of the Cooperative Forestry Assistance Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2103"},"text":"16 U.S.C. 2103","children":[],"tail":").”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(6) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" redesignated pars. (7) to (10) as (6) to (9), respectively, and struck out former par. (6) which read as follows: “The great plains conservation program authorized by section 16 of the Soil Conservation and Domestic Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s590p/b"},"text":"16 U.S.C. 590p(b)","children":[],"tail":").”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/222/s105/a/7/C"},"text":"Pub. L. 96–222, § 105(a)(7)(C)","children":[],"tail":", (E), inserted in par. (9) “or his delegate” after “Secretary of the Treasury” and substituted in par. (10) “Any program of a State, possession of the United States, a political subdivision of any of the foregoing, or the District of Columbia” for “Any State program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/222/s105/a/7/A"},"text":"Pub. L. 96–222, § 105(a)(7)(A)","children":[],"tail":", inserted provisions relating to payments not chargeable to capital account."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/222/s105/a/7/A"},"text":"Pub. L. 96–222, § 105(a)(7)(A)","children":[],"tail":", substituted provisions allowing the taxpayer to elect not to have this section apply to any excludable portion for provisions relating to the application of subsec. (a) of this section with other sections."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/222/s105/a/7/A"},"text":"Pub. L. 96–222, § 105(a)(7)(A)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4172da08-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4172da09-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/b"},"text":"section 221(b) of Pub. L. 113–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4172da0a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/222"},"text":"Pub. L. 96–222","children":[],"tail":" effective, except as otherwise provided, as if it had been included in provisions of the Revenue Act of 1978, "},{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/222/s201"},"text":"section 201 of Pub. L. 96–222","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s32"},"text":"section 32 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4172da0b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/tV/s543/d"},"text":"Pub. L. 95–600, title V, § 543(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2890"},"text":"92 Stat. 2890","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/600/tV/s543/d"},"text":"“The amendments made by this section [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1255"},"text":"section 1255 of this title","children":[],"tail":"] shall apply with respect to grants made under the programs after "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id4172da0c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that nothing in amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" be construed to affect treatment of certain transactions occurring, property acquired, or items of income, loss, deduction, or credit taken into account prior to "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", for purposes of determining liability for tax for periods ending after "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/e"},"text":"section 401(e) of Pub. L. 115–141","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s23"},"text":"section 23 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
