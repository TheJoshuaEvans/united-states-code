{"tag":"section","attrib":{"id":"id449d8d59-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s997"},"text":null,"children":[{"tag":"num","attrib":{"value":"997"},"text":"§ 997.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special subchapter C rules","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of applying the provisions of subchapter C of chapter 1, any distribution in property to a corporation by a DISC or former DISC which is made out of previously taxed income or accumulated DISC income shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id449d8d5a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s997/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be treated as a distribution in the same amount as if such distribution of property were made to an individual, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id449d8d5b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s997/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a basis, in the hands of the recipient corporation, equal to the amount determined under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id449d8d5c-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/178/tV/s501"},"text":"Pub. L. 92–178, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/549"},"text":"85 Stat. 549","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
