{"tag":"section","attrib":{"id":"id473e0188-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6805"},"text":null,"children":[{"tag":"num","attrib":{"value":"6805"},"text":"§ 6805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redemption of stamps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id473e0189-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6805/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, subject to regulations prescribed by him, may, upon receipt of satisfactory evidence of the facts, make allowance for or redeem such of the stamps, issued under authority of any internal revenue law, as may have been spoiled, destroyed, or rendered useless or unfit for the purpose intended, or for which the owner may have no use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id473e018a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6805/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method and conditions of allowance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such allowance or redemption may be made, either by giving other stamps in lieu of the stamps so allowed for or redeemed, or by refunding the amount or value to the owner thereof, deducting therefrom, in case of repayment, the percentage, if any, allowed to the purchaser thereof; but no allowance or redemption shall be made in any case until the stamps so spoiled or rendered useless shall have been returned to the Secretary, or until satisfactory proof has been made showing the reason why the same cannot be returned; or, if so required by the Secretary, when the person presenting the same cannot satisfactorily trace the history of said stamps from their issuance to the presentation of his claim as aforesaid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id473e018b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6805/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for filing claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No claim for the redemption of, or allowance for, stamps shall be allowed under this section unless presented within 3 years after the purchase of such stamps from the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id473e018c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6805/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality of decisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The findings of fact in and the decision of the Secretary upon the merits of any claim presented under or authorized by this section shall, in the absence of fraud or mistake in mathematical calculation, be final and not subject to revision by any accounting officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id473e018d-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/830"},"text":"68A Stat. 830","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tI/s165/b"},"text":"Pub. L. 85–859, title I, § 165(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1313"},"text":"72 Stat. 1313","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id473e018e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id473e018f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id473e0190-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/s165/b"},"text":"Pub. L. 85–859, § 165(b)","children":[],"tail":", struck out provisions which authorized the Secretary to make allowances for or redeem stamps which through mistake may have been improperly or unnecessarily used, or where the rates or duties represented thereby have been excessive in amount, paid in error, or in any manner wrongfully collected."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/s165/c"},"text":"Pub. L. 85–859, § 165(c)","children":[],"tail":", inserted “under this section” after “shall be allowed”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id473e0191-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id473e0192-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" effective on first day of first calendar quarter which begins more than 60 days after "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/s1/c"},"text":"section 1(c) of Pub. L. 85–859","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1275"},"text":"72 Stat. 1275","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
