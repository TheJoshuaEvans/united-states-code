{"tag":"section","attrib":{"id":"id46439c74-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5684"},"text":null,"children":[{"tag":"num","attrib":{"value":"5684"},"text":"§ 5684.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties relating to the payment and collection of liquor taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46439c75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5684/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to pay tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever fails to pay any tax imposed by part I of subchapter A at the time prescribed shall, in addition to any other penalty provided in this title, be liable to a penalty of 5 percent of the tax due but unpaid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46439c76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5684/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of section 6665","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalties imposed by subsection (a) shall be assessed, collected, and paid in the same manner as taxes, as provided in section 6665(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46439c77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5684/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46439c78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5684/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions relating to interest in the case of taxes not paid when due, see section 6601.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46439c79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5684/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For penalty for failure to file tax return or pay tax, see section 6651.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46439c7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5684/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For additional penalties for failure to pay tax, see section 6653.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46439c7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5684/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For penalty for failure to make deposits or for overstatement of deposits, see section 6656.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46439c7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5684/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For penalty for attempt to evade or defeat any tax imposed by this title, see section 7201.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46439c7d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5684/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For penalty for willful failure to file return, supply information, or pay tax, see section 7203.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46439c7e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1410"},"text":"72 Stat. 1410","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIX/s943/c/4"},"text":"Pub. L. 91–172, title IX, § 943(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/728"},"text":"83 Stat. 728","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tVII"},"text":"Pub. L. 97–34, title VII","children":[],"tail":", §§ 722(a)(3), 724(b)(4), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/342"},"text":"95 Stat. 342","children":[],"tail":", 345; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII"},"text":"Pub. L. 98–369, div. A, title VII","children":[],"tail":", §§ 714(h)(1), 722(a)(5), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/962"},"text":"98 Stat. 962","children":[],"tail":", 973; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7721/c/3"},"text":"Pub. L. 101–239, title VII, § 7721(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2399"},"text":"103 Stat. 2399","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscN