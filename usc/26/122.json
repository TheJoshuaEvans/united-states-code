":"quotedContent","attrib":{"origin":"/us/pl/93/406/tII/s2007/c"},"text":"“The amendments made by this section [amending this section and sections 72, 101, and 2039 of this title] apply to taxable years ending on or after ","children":[{"tag":"date","attrib":{"date":"1972-09-21"},"text":"September 21, 1972","children":[],"tail":". The amendments made by paragraphs (3) and (4) of subsection (b) [amending sections 101 and 2039 of this title] apply with respect to individuals dying on or after such date”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id416df85f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/365/s1/d"},"text":"Pub. L. 89–365, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-10"},"text":"Mar. 10, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/33"},"text":"80 Stat. 33","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/365/s1/d"},"text":"“The amendments made by subsections (a) and (b) [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s72"},"text":"section 72 of this title","children":[],"tail":"] shall apply with respect to taxable years ending after "},{"tag":"date","attrib":{"date":"1965-12-31"},"text":"December 31, 1965","children":[],"tail":". The amendment made by subsection (c) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s101"},"text":"section 101 of this title","children":[],"tail":"] shall apply with respect to individuals making an election under chapter 73 of title 10 of the United States Code who die after "},{"tag":"date","attrib":{"date":"1965-12-31"},"text":"December 31, 1965","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":n