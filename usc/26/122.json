{"tag":"section","attrib":{"id":"id416df850-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s122"},"text":null,"children":[{"tag":"num","attrib":{"value":"122"},"text":"§ 122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain reduced uniformed services retirement pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id416df851-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a member or former member of the uniformed services of the United States, gross income does not include the amount of any reduction in his retired or retainer pay pursuant to the provisions of chapter 73 of title 10, United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id416df852-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id416df853-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s122/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount excluded from gross income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any individual referred to in subsection (a), all amounts received as retired or retainer pay shall be excluded from gross income until there has been so excluded an amount equal to the consideration for the contract. The preceding sentence shall apply only to the extent that the amounts received would, but for such sentence, be includible in gross income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id416df854-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s122/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration for the contract","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1) and section 72(n), the term “consideration for the contract” means, in respect of any individual, the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id416df855-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s122/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of the reductions before ","children":[{"tag":"date","attrib":{"date":"1966-01-01"},"text":"January 1, 1966","children":[],"tail":", in his retired or retainer pay by reason of an election under chapter 73 of title 10 of the United States Code, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id416df856-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s122/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts deposited at any time by him pursuant to section 1438 or 1452(d) of such title 10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id416df857-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/365/s1/a/1"},"text":"Pub. L. 89–365, § 1(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-08"},"text":"Mar. 8, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/32"},"text":"80 Stat. 32","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/406/tII"},"text":"Pub. L. 93–406, title II","children":[],"tail":", §§ 2005(c)(10), 2007(a), (b)(1), "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/992"},"text":"88 Stat. 992","children":[],"tail":", 994; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/21"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4040"},"text":"128 Stat. 4040","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id416df858-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id416df859-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id416df85a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 122 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s140"},"text":"section 140 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id416df85b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" struck out “after "},{"tag":"date","attrib":{"date":"1965-12-31"},"text":"December 31, 1965","children":[],"tail":",” after “all amounts received”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/s2007/a"},"text":"Pub. L. 93–406, § 2007(a)","children":[],"tail":", substituted “United States, gross income does not include the amount of any reduction in his retired or retainer pay pursuant to the provisions of chapter 73 of title 10, United States Code” for “United States who has made an election under chapter 73 of title 10 of the United States Code to receive a reduced amount of retired or retainer pay, gross income does not include the amount of any reduction after "},{"tag":"date","attrib":{"date":"1965-12-31"},"text":"December 31, 1965","children":[],"tail":", in his retired or retainer pay by reason of such election”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/s2005/c/10"},"text":"Pub. L. 93–406, § 2005(c)(10)","children":[],"tail":", substituted “72(n)” for “72("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/s2007/b/1"},"text":"Pub. L. 93–406, § 2007(b)(1)","children":[],"tail":", inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1452/d"},"text":"section 1452(d) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id416df85c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id416df85d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 201