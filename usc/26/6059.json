{"tag":"section","attrib":{"id":"id4688bb45-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6059"},"text":null,"children":[{"tag":"num","attrib":{"value":"6059"},"text":"§ 6059.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic report of actuary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4688bb46-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6059/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The actuarial report described in subsection (b) shall be filed by the plan administrator (as defined in section 414(g) of each defined benefit plan to which section 412 applies, for the first plan year for which section 412 applies to the plan and for each third plan year thereafter (or more frequently if the Secretary determines that more frequent reports are necessary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4688bb47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6059/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actuarial report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The actuarial report of a plan required by subsection (a) shall be prepared and signed by an enrolled actuary (within the meaning of section 7701(a)(35)) and shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4688bb48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6059/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the funding method and actuarial assumptions used to determine costs under the plan,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4688bb49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6059/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification of the contribution necessary to reduce the minimum required contribution determined under section 430, the accumulated funding deficiency under section 433, or the accumulated funding deficiency determined under section 431, to zero,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4688bb4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6059/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a statement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4688bb4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6059/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that to the best of his knowledge the report is complete and accurate, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4688bb4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6059/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the requirements for reasonable actuarial assumptions under section 430(h)(1), 431(c)(3), or 433(c)(3), whichever are applicable, have been complied with,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4688bb4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6059/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as may be necessary to fully and fairly disclose the actuarial position of the plan, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4688bb4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6059/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information regarding the plan as the Secretary may by regulations require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4688bb4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6059/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time and manner of filing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The actuarial report and statement required by this section shall be filed at the time and in the manner provided by regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4688bb50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6059/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For coordination between the Department of the Treasury and the Department of Labor with respect to the report required to be filed under this section, see section 3004 of title III of the Employee Retirement Income Security Act of 1974.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4688bb51-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tII/s1033/a"},"text":"Pub. L. 93–406, title II, § 1033(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/947"},"text":"88 Stat. 947","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tI/s114/f"},"text":"Pub. L. 109–280, title I, § 114(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/855"},"text":"120 Stat. 855","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/97/tII/s202/c/10"},"text":"Pub. L. 113–97, title II, § 202(c)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-04-07"},"text":"Apr. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1138"},"text":"128 Stat. 1138","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/265"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(265)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1197"},"text":"132 Stat. 1197","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4688bb52-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4688bb53-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4688bb54-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3004 of title III of the Employee Retirement Income Security Act of 1974, referred to in subsec. (d), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1204"},"text":"section 1204 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4688bb55-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “that the requirements” for “the requirements” and “with,” for “with.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/97/s202/c/10/A"},"text":"Pub. L. 113–97, § 202(c)(10)(A)","children":[],"tail":", substituted “430, the accumulated funding deficiency under section 433,” for “430,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/97/s202/c/10/B"},"text":"Pub. L. 113–97, § 202(c)(10)(B)","children":[],"tail":", substituted “430(h)(1), 431(c)(3), or 433(c)(3)” for “430(h)(1) or 431(c)(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s114/f/1"},"text":"Pub. L. 109–280, § 114(f)(1)","children":[],"tail":", substituted “the minimum required contribution determined under section 430, or the accumulated funding deficiency determined under section 431,” for “the accumulated funding deficiency (as defined in section 412(a))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s114/f/2"},"text":"Pub. L. 109–280, § 114(f)(2)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “the requirements of section 412(c) (relating to reasonable actuarial assumptions) have been complied with,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4688bb56-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4688bb57-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/97"},"text":"Pub. L. 113–97","children":[],"tail":" applicable to years beginning after "},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"Dec. 31, 2013","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/97/s3"},"text":"section 3 of Pub. L. 113–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4688bb58-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" applicable to plan years beginning after 2007, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/s114/g/1"},"text":"section 114(g)(1) of Pub. L. 109–280","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/110/458"},"text":"Pub. L. 110–458","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4688bb59-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Requirements of section applicable only with respect to plan years to which part I of subtitle A of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406"},"text":"Pub. L. 93–406","children":[],"tail":" applies, see "},{"tag":"ref","attrib":{"href":"/us/pl/93/406/s1034/1"},"text":"section 1034(1) of Pub. L. 93–406","children":[],"tail":", set out as an note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6057"},"text":"section 6057 of this title","children":[],"tail":". For a description of the plan years to which part 1 applies, see "},{"tag":"ref","attrib":{"href":"/us/pl/93/406/s1017"},"text":"section 1017 of Pub. L. 93–406","children":[],"tail":", set out as an Effective Date; Transitional Rules note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s410"},"text":"section 410 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4688bb5a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability of Amendments by Subtitles A and B of Title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"For special rules on applicability of amendments by subtitles A (§§ 101–108) and B (§§ 111–116) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" to certain eligible cooperative plans, PBGC settlement plans, and eligible government contractor plans, see sections 104, 105, and 106 of "},{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":", set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4688bb5b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Consolidation of Actuarial Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tX/s1033/c"},"text":"Pub. L. 93–406, title X, § 1033(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/948"},"text":"88 Stat. 948","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"“The Secretary of the Treasury and the Secretary of Labor shall take such steps as may be necessary to assure coordination to the maximum extent feasible between the actuarial reports required by section 6059 of the Internal Revenue Code of 1986 and by section 103(d) of title I of the Employee Retirement Income Security Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1023/d"},"text":"section 1023(d) of Title 29","children":[],"tail":", Labor].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
