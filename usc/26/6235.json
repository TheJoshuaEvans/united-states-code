{"tag":"section","attrib":{"id":"id46c1f3fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6235"},"text":null,"children":[{"tag":"num","attrib":{"value":"6235"},"text":"§ 6235.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of limitations on making adjustments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46c1f3fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6235/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section or section 905(c), no adjustment under this subchapter for any partnership taxable year may be made after the later of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46c1f3fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6235/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the date which is 3 years after the latest of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46c1f3fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6235/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the partnership return for such taxable year was filed,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c1f3ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6235/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the return due date for the taxable year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c1f400-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6235/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the partnership filed an administrative adjustment request with respect to such year under section 6227, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f401-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6235/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any modification of an imputed underpayment under section 6225(c), the date that is 270 days (plus the number of days of any extension consented to by the Secretary under paragraph (7) thereof) after the date on which everything required to be submitted to the Secretary pursuant to such section is so submitted, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f402-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6235/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any notice of a proposed partnership adjustment under section 6231(a)(2), the date that is 330 days (plus the number of days of any extension consented to by the Secretary under section 6225(c)(7)) after the date of such notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46c1f403-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6235/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension by agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The period described in subsection (a) (including an extension period under this subsection) may be extended by an agreement entered into by the Secretary and the partnership before the expiration of such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46c1f404-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6235/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule in case of fraud, etc.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46c1f405-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6235/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a false or fraudulent partnership return with intent to evade tax, the adjustment may be made at any time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f406-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6235/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial omission of income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any partnership omits from gross income an amount properly includible therein and such amount is described in subparagraph (A) or (C) of section 6501(e)(1), subsection (a) shall be applied by substituting “6 years” for “3 years”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f407-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6235/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a failure by a partnership to file a return for any taxable year, the adjustment may be made at any time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f408-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6235/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return filed by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, a return executed by the Secretary under subsection (b) of section 6020 on behalf of the partnership shall not be treated as a return of the partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f409-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6235/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information required to be reported","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a partnership that is required to report any information described in section 6501(c)(8), the time for making any adjustment under this subchapter with respect to any tax return, event, or period to which such information relates shall not expire before the date that is determined under section 6501(c)(8).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f40a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6235/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Listed transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a partnership fails to include on any return or statement any information with respect to a listed transaction as described in section 6501(c)(10), the time for making any adjustment under this subchapter with respect to such transaction shall not expire before the date that is determined under section 6501(c)(10).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46c1f40b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/74/tXI/s1101/c/1"},"text":"Pub. L. 114–74, title XI, § 1101(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/635"},"text":"129 Stat. 635","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tIV/s411/c"},"text":"Pub. L. 114–113, div. Q, title IV, § 411(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3122"},"text":"129 Stat. 3122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tII/s206/k"},"text":"Pub. L. 115–141, div. U, title II, § 206(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1180"},"text":"132 Stat. 1180","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46c1f40c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46c1f40d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46c1f40e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/k/1"},"text":"Pub. L. 115–141, § 206(k)(1)","children":[],"tail":", inserted “or section 905(c)” after “Except as otherwise provided in this section” and substituted “subchapter” for “subpart” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/k/2"},"text":"Pub. L. 115–141, § 206(k)(2)","children":[],"tail":", substituted “section 6225(c)(7))” for “section 6225(c)(7)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/k/3"},"text":"Pub. L. 115–141, § 206(k)(3)","children":[],"tail":", substituted “subparagraph (A) or (C) of section 6501(e)(1)” for “section 6501(e)(1)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/k/4"},"text":"Pub. L. 115–141, § 206(k)(4)","children":[],"tail":", added pars. (5) and (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/k/5"},"text":"Pub. L. 115–141, § 206(k)(5)","children":[],"tail":", struck out subsec. (d). Text read as follows: “If notice of a final partnership adjustment with respect to any taxable year is mailed under section 6231, the running of the period specified in subsection (a) (as modified by the other provisions of this section) shall be suspended—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) for the period during which an action may be brought under section 6234 (and, if a petition is filed under such section with respect to such notice, until the decision of the court becomes final), and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) for 1 year thereafter.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s411/c/1"},"text":"Pub. L. 114–113, § 411(c)(1)","children":[],"tail":", substituted “paragraph (7)” for “paragraph (4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s411/c/2"},"text":"Pub. L. 114–113, § 411(c)(2)","children":[],"tail":", substituted “330 days (plus the number of days of any extension consented to by the Secretary under section 6225(c)(7)” for “270 days”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46c1f40f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46c1f410-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" effective as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/114/74/s1101"},"text":"section 1101 of Pub. L. 114–74","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/s207"},"text":"section 207 of Pub. L. 115–141","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6031"},"text":"section 6031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46c1f411-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":" effective as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/114/74/s1101"},"text":"section 1101 of Pub. L. 114–74","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/s411/e"},"text":"section 411(e) of Pub. L. 114–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6031"},"text":"section 6031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46c1f412-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to returns filed for partnership taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/74/s1101/g"},"text":"section 1101(g) of Pub. L. 114–74","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6221"},"text":"section 6221 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
