{"tag":"section","attrib":{"id":"id415d5611-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s107"},"text":null,"children":[{"tag":"num","attrib":{"value":"107"},"text":"§ 107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rental value of parsonages","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In the case of a minister of the gospel, gross income does not include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id415d5612-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s107/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rental value of a home furnished to him as part of his compensation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id415d5613-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s107/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rental allowance paid to him as part of his compensation, to the extent used by him to rent or provide a home and to the extent such allowance does not exceed the fair rental value of the home, including furnishings and appurtenances such as a garage, plus the cost of utilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id415d5614-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/32"},"text":"68A Stat. 32","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/181/s2/a"},"text":"Pub. L. 107–181, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-20"},"text":"May 20, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/583"},"text":"116 Stat. 583","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id415d5615-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id415d5616-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id415d5617-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/181"},"text":"Pub. L. 107–181","children":[],"tail":" inserted “and to the extent such allowance does not exceed the fair rental value of the home, including furnishings and appurtenances such as a garage, plus the cost of utilities” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id415d5618-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id415d5619-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/181/s2/b"},"text":"Pub. L. 107–181, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-20"},"text":"May 20, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/583"},"text":"116 Stat. 583","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/181/s2/b"},"text"