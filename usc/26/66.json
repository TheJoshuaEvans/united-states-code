{"tag":"section","attrib":{"id":"id4132757b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s66"},"text":null,"children":[{"tag":"num","attrib":{"value":"66"},"text":"§ 66.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of community income","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4132757c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s66/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of community income where spouses live apart","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4132757d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s66/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 individuals are married to each other at any time during a calendar year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4132757e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s66/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such individuals—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4132757f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s66/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" live apart at all times during the calendar year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41327580-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s66/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not file a joint return under section 6013 with each other for a taxable year beginning or ending in the calendar year;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41327581-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s66/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or both of such individuals have earned income for the calendar year which is community income; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41327582-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s66/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no portion of such earned income is transferred (directly or indirectly) between such individuals before the close of the calendar year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then, for purposes of this title, any community income of such individuals for the calendar year shall be treated in accordance with the rules provided by section 879(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41327583-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s66/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary may disregard community property laws where spouse not notified of community income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may disallow the benefits of any community property law to any taxpayer with respect to any income if such taxpayer acted as if solely entitled to such income and failed to notify the taxpayer’s spouse before the due date (including extensions) for filing the return for the taxable year in which the income was derived of the nature and amount of such income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41327584-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s66/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spouse relieved of liability in certain other cases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Secretary, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41327585-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s66/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual does not file a joint return for any taxable year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41327586-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s66/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individual does not include in gross income for such taxable year an item of community income properly includible therein which, in accordance with the rules contained in section 879(a), would be treated as the income of the other spouse,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41327587-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s66/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual establishes that he or she did not know of, and had no reason to know of, such item of community income, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41327588-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s66/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taking into account all facts and circumstances, it is inequitable to include such item of community income in such individual’s gross income,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then, for purposes of this title, such item of community income shall be included in the gross income of the other spouse (and not in the gross income of the individual). Under procedures prescribed by the Secretary, if, taking into account all the facts and circumstances, it is inequitable to hold the individual liable for any unpaid tax or any deficiency (or any portion of either) attributable to any item for which relief is not available under the preceding sentence, the Secretary may relieve such individual of such liability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41327589-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s66/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4132758a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s66/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Earned income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “earned income” has the meaning given to such term by section 911(d)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4132758b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s66/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community income” means income which, under applicable community property laws, is treated as community income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4132758c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s66/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community property laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community property laws” means the community property laws of a State, a foreign country, or a possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4132758d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/605/tI/s101/a"},"text":"Pub. L. 96–605, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3521"},"text":"94 Stat. 3521","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s424/b/1"},"text":"Pub. L. 98–369, div. A, title IV, § 424(b)(1)","children":[],"tail":"–(2)(B), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/802"},"text":"98 Stat. 802","children":[],"tail":", 803; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7841/d/8"},"text":"Pub. L. 101–239, title VII, § 7841(d)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2428"},"text":"103 Stat. 2428","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3201/b"},"text":"Pub. L. 105–206, title III, § 3201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/739"},"text":"112 Stat. 739","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4132758e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4132758f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id41327590-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" inserted at end “Under procedures prescribed by the Secretary, if, taking into account all the facts and circumstances, it is inequitable to hold the individual liable for any unpaid tax or any deficiency (or any portion of either) attributable to any item for which relief is not available under the preceding sentence, the Secretary may relieve such individual of such liability.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" substituted “section 911(d)(2)” for “section 911(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s424/b/2/A"},"text":"Pub. L. 98–369, § 424(b)(2)(A)","children":[],"tail":", struck out “where spouses live apart” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s424/b/2/B"},"text":"Pub. L. 98–369, § 424(b)(2)(B)","children":[],"tail":", substituted “Treatment of community income where spouses live apart” for “General rule” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s424/b/1"},"text":"Pub. L. 98–369, § 424(b)(1)","children":[],"tail":", added subsecs. (b) and (c) and redesignated former subsec. (b) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id41327591-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41327592-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" applicable to any liability for tax arising after "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", and any liability for tax arising on or before such date but remaining unpaid as of such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3201/g/1"},"text":"section 3201(g)(1) of Pub. L. 105–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6015"},"text":"section 6015 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41327593-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" applicable to all taxable years to which the Internal Revenue Code of 1986 [formerly I.R.C. 1954] applies with corresponding provisions deemed to be included in the Internal Revenue Code of 1939 and applicable to all taxable years to which such Code applies, except subsection (b) of this section is applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1984-12-31"},"text":"December 31, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s424/c"},"text":"section 424(c) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6013"},"text":"section 6013 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id41327594-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/605/tI/s101/c"},"text":"Pub. L. 96–605, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3522"},"text":"94 Stat. 3522","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/605/tI/s101/c"},"text":"“The amendments made by this section [enacting this section] shall apply to calendar years beginning after ","children":[{"tag":"date","attrib":{"date":"1980-12-31"},"text":"December 31, 1980","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
