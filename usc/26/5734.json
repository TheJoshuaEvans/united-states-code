{"tag":"section","attrib":{"id":"id464d11fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5734"},"text":null,"children":[{"tag":"num","attrib":{"value":"5734"},"text":"§ 5734.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of State laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The payment of any tax imposed by this subchapter for carrying on any trade or business shall not be held to exempt any person from any penalty or punishment provided by the laws of any State for carrying on such trade or business within such State, or in any manner to authorize the commencement or continuance of such trade or business contrary to the laws of such State or in places prohibited by municipal law; nor shall the payment of any such tax be held to prohibit any State from placing a duty or tax on the same trade or business, for State or other purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id464d11fd-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1348"},"text":"72 Stat. 1348","children":[],"tail":", § 5145; renumbered § 5734 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11125/b/20/A"},"text":"Pub. L. 109–59, title XI, § 11125(b)(20)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1956"},"text":"119 Stat. 1956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id464d11fe-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id464d11ff-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id464d1200-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5145"},"text":"section 5145 of this title","children":[],"tail":" as this section, transferred section to this subchapter, and substituted “this subchapter” for “this part” in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id464d1201-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464d1202-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-07-01"},"text":"July 1, 2008","children":[],"tail":", but inapplicable to taxes imposed for periods before such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11125/c"},"text":"section 11125(c) of Pub. L. 109–59","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5002"},"text":"section 5002 of this title","children":[],"tail":"."}],"tail":"\n"}],"ta