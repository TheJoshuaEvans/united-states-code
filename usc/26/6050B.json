-31"},"text":"Dec. 31, 1978","children":[],"tail":", in taxable years ending after such date, but not applicable to payments made for weeks of unemployment ending before "},{"tag":"date","attrib":{"date":"1978-12-01"},"text":"Dec. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/s112/d"},"text":"section 112(d) of Pub. L. 95–600","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s85"},"text":"section 85 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id467a63c6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Waiver of Statute of Limitations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to credit or refund of overpayment of tax resulting from 1984 amendment to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s112/d"},"text":"section 112(d) of Pub. L. 95–600","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1075/b"},"text":"section 1075(b) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s85"},"text":"section 85 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
