{"tag":"section","attrib":{"id":"id45afc00a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052"},"text":null,"children":[{"tag":"num","attrib":{"value":"4052"},"text":"§ 4052.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45afc00b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First retail sale","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45afc00c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “first retail sale” means the first sale, for a purpose other than for resale or leasing in a long-term lease, after production, manufacture, or importation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afc00d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leases considered as sales","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of section 4217 shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afc00e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use treated as sale","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45afc00f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any person uses an article taxable under section 4051 before the first retail sale of such article, then such person shall be liable for tax under section 4051 in the same manner as if such article were sold at retail by him.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afc010-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for use in further manufacture","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply to use of an article as material in the manufacture or production of, or as a component part of, another article to be manufactured or produced by him.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afc011-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any person made liable for tax by subparagraph (A), the tax shall be computed on the price at which similar articles are sold at retail in the ordinary course of trade, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45afc012-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of price","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45afc013-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining price for purposes of this subchapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45afc014-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there shall be included any charge incident to placing the article in condition ready for use,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afc015-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" there shall be excluded—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45afc016-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the tax imposed by this subchapter,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45afc017-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if stated as a separate charge, the amount of any retail sales tax imposed by any State or political subdivision thereof or the District of Columbia, whether the liability for such tax is imposed on the vendor or vendee, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45afc018-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the value of any component of such article if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id45afc019-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/1/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such component is furnished by the first user of such article, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id45afc01a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/1/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such component has been used before such furnishing, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afc01b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the price shall be determined without regard to any trade-in.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afc01c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sales not at arm’s length","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any article sold (otherwise than through an arm’s-length transaction) at less than the fair market price, the tax under this subchapter shall be computed on the price for which similar articles are sold at retail in the ordinary course of trade, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afc01d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term lease","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45afc01e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any long-term lease of an article which is treated as the first retail sale of such article, the tax under this subchapter shall be computed on a price equal to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45afc01f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id45afc020-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the price (determined under this subchapter but without regard to paragraph (4)) at which such article was sold to the lessor, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id45afc021-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of any parts and accessories installed by the lessor on such article before the first use by the lessee or leased in connection with such long-term lease, plus","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45afc022-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the presumed markup percentage of the sum described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afc023-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumed markup percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the term “presumed markup percentage” means the average markup percentage of retailers of articles of the type involved, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afc024-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions under regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent provided in regulations prescribed by the Secretary, subparagraph (A) shall not apply to specified types of leases where its application is not necessary to carry out the purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afc025-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule where tax paid by manufacturer, producer, or importer","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45afc026-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case where the manufacturer, producer, or importer of any article (or a related person) is liable for tax imposed by this subchapter with respect to such article, the tax under this subchapter shall be computed on a price equal to the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45afc027-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the price which would (but for this paragraph) be determined under this subchapter, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45afc028-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product of the price referred to in clause (i) and the presumed markup percentage determined under paragraph (3)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afc029-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45afc02a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), the term “related person” means any person who is a member of the same controlled group (within the meaning of section 5061(e)(3)) as the manufacturer, producer, or importer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45afc02b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for retail establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent provided in regulations prescribed by the Secretary, a person shall not be treated as a related person with respect to the sale of any article if such article is sold through a permanent retail establishment in the normal course of the trade or business of being a retailer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45afc02c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain combinations not treated as manufacture","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45afc02d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter (other than subsection (a)(3)(B)), a person shall not be treated as engaged in the manufacture of any article by reason of merely combining such article with any item listed in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afc02e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Items","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The items listed in this paragraph are any coupling device (including any fifth wheel), wrecker crane, loading and unloading equipment (including any crane, hoist, winch, or power liftgate), aerial ladder or tower, snow and ice control equipment, earthmoving, excavation and construction equipment, spreader, sleeper cab, cab shield, or wood or metal floor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45afc02f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain other rules made applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary, rules similar to the rules of subsections (c) and (d) of section 4216 (relating to partial payments) shall apply for purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45afc030-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term lease","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “long-term lease” means any lease with a term of 1 year or more. In determining a lease term for purposes of the preceding sentence, the rules of section 168(i)(3)(A) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45afc031-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain repairs and modifications not treated as manufacture","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45afc032-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An article described in section 4051(a)(1) shall not be treated as manufactured or produced solely by reason of repairs or modifications to the article (including any modification which changes the transportation function of the article or restores a wrecked article to a functional condition) if the cost of such repairs and modifications does not exceed 75 percent of the retail price of a comparable new article.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afc033-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply if the article (as repaired or modified) would, if new, be taxable under section 4051 and the article when new was not taxable under such section or the corresponding provision of prior law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45afc034-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4052/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe regulations which permit, in lieu of any other certification, persons who are purchasing articles taxable under this subchapter for resale or leasing in a long-term lease to execute a statement (made under penalties of perjury) on the sale invoice that such sale is for resale. The Secretary shall not impose any registration requirement as a condition of using such procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45afc035-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/424/tV/s512/b/1"},"text":"Pub. L. 97–424, title V, § 512(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-06"},"text":"Jan. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2175"},"text":"96 Stat. 2175","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII"},"text":"Pub. L. 98–369, div. A, title VII","children":[],"tail":", §§ 731, 735(b)(2), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/976"},"text":"98 Stat. 976","children":[],"tail":", 981; "},{"tag":"ref","attrib":{"href":"/us/pl/100/17/tV"},"text":"Pub. L. 100–17, title V","children":[],"tail":", §§ 505(a)–(c), 506(a), "},{"tag":"date","attrib":{"date":"1987-04-02"},"text":"Apr. 2, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/258"},"text":"101 Stat. 258","children":[],"tail":", 259; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6111/a"},"text":"Pub. L. 100–647, title VI, § 6111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3713"},"text":"102 Stat. 3713","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIV"},"text":"Pub. L. 105–34, title XIV","children":[],"tail":", §§ 1402(b), 1434(a), (b), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1046"},"text":"111 Stat. 1046","children":[],"tail":", 1052; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tVI/s6014/c"},"text":"Pub. L. 105–206, title VI, § 6014(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/820"},"text":"112 Stat. 820","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45afc036-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"edi