{"tag":"section","attrib":{"id":"id452cad95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2035"},"text":null,"children":[{"tag":"num","attrib":{"value":"2035"},"text":"§ 2035.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments for certain gifts made within 3 years of decedent’s death","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id452cad96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2035/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of certain property in gross estate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id452cad97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2035/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the decedent made a transfer (by trust or otherwise) of an interest in any property, or relinquished a power with respect to any property, during the 3-year period ending on the date of the decedent’s death, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id452cad98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2035/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of such property (or an interest therein) would have been included in the decedent’s gross estate under section 2036, 2037, 2038, or 2042 if such transferred interest or relinquished power had been retained by the decedent on the date of his death,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the value of the gross estate shall include the value of any property (or interest therein) which would have been so included.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id452cad99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2035/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of gift tax on gifts made during 3 years before decedent’s death","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the gross estate (determined without regard to this subsection) shall be increased by the amount of any tax paid under chapter 12 by the decedent or his estate on any gift made by the decedent or his spouse during the 3-year period ending on the date of the decedent’s death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id452cad9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2035/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other rules relating to transfers within 3 years of death","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id452cad9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2035/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id452cad9c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2035/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 303(b) (relating to distributions in redemption of stock to pay death taxes),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id452cad9d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2035/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 2032A (relating to special valuation of certain farms, etc., real property), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id452cad9e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2035/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter C of chapter 64 (relating to lien for taxes),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the value of the gross estate shall include the value of all property to the extent of any interest therein of which the decedent has at any time made a transfer, by trust or otherwise, during the 3-year period ending on the date of the decedent’s death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id452cad9f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2035/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with section 6166","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An estate shall be treated as meeting the 35 percent of adjusted gross estate requirement of section 6166(a)(1) only if the estate meets such requirement both with and without the application of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id452cada0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2035/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marital and small transfers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to any transfer (other than a transfer with respect to a life insurance policy) made during a calendar year to any donee if the decedent was not required by section 6019 (other than by reason of section 6019(2)) to file any gift tax return for such year with respect to transfers to such donee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id452cada1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2035/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) and paragraph (1) of subsection (c) shall not apply to any bona fide sale for an adequate and full consideration in money or money’s worth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id452cada2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2035/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain transfers from revocable trusts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section and section 2038, any transfer from any portion of a trust during any period that such portion was treated under section 676 as owned by the decedent by reason of a power in the grantor (determined without regard to section 672(e)) shall be treated as a transfer made directly by the decedent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id452cada3-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/381"},"text":"68A Stat. 381","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/834/s18/a/2/C"},"text":"Pub. L. 87–834, § 18(a)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-16"},"text":"Oct. 16, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1052"},"text":"76 Stat. 1052","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2001/a/5"},"text":"Pub. L. 94–455, title XX, § 2001(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1848"},"text":"90 Stat. 1848","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s702/f/1"},"text":"Pub. L. 95–600, title VII, § 702(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2930"},"text":"92 Stat. 2930","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV"},"text":"Pub. L. 97–34, title IV","children":[],"tail":", §§ 403(b)(3)(B), 424(a), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/301"},"text":"95 Stat. 301","children":[],"tail":", 317; "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tI/s104/a/9"},"text":"Pub. L. 97–448, title I, § 104(a)(9)","children":[],"tail":", (d)(1)(A), (C), (2), "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2381"},"text":"96 Stat. 2381","children":[],"tail":", 2383; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIII/s1310/a"},"text":"Pub. L. 105–34, title XIII, § 1310(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1043"},"text":"111 Stat. 1043","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s319/14"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 319(14)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–646.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id452cada4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id452cada5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id452cada6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s319/14/A"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 319(14)(A)]","children":[],"tail":", substituted “subsection (a)” for “paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s319/14/B"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 319(14)(B)]","children":[],"tail":", inserted “and paragraph (1) of subsection (c)” after “Subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" amended section catchline and text generally. Prior to amendment, section consisted of subsecs. (a) to (d) relating to adjustments for gifts made within 3 years of decedent’s death."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448/s104/a/9"},"text":"Pub. L. 97–448, § 104(a)(9)","children":[],"tail":", substituted “section 6019(2)” for “section 6019(a)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448/s104/d/2"},"text":"Pub. L. 97–448, § 104(d)(2)","children":[],"tail":", inserted “of this subsection and paragraph (2) of subsection (b)” after “Paragraph (1)”, and struck out “2041,” after “2038,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448/s104/d/1/C"},"text":"Pub. L. 97–448, § 104(d)(1)(C)","children":[],"tail":", redesignated subpar. (D) as (C). Former subpar. (C), which referred to section 6166 (relating to extension of time for payment of estate tax where estate consists largely of interest in closely held business), was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448/s104/d/1/A"},"text":"Pub. L. 97–448, § 104(d)(1)(A)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s403/b/3/B"},"text":"Pub. L. 97–34, § 403(b)(3)(B)","children":[],"tail":", inserted “(other than by reason of section 6019(a)(2))” after “section 6019”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s424/a"},"text":"Pub. L. 97–34, § 424(a)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" substituted in par. (2) provisions relating to gifts for which donee was not required by section 6019 to file gift tax returns for provisions relating to gifts excludable in computing taxable gifts by reason of section 2503(b) and inserted provisions following par. (2) relating to inapplicability of par. (2) to transfers respecting life insurance policies."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted provisions covering adjustments for gifts made within 3 years of decedent’s death for provisions under which transfers by the decedent within 3 years of the decedent’s death were deemed to have been made in contemplation of death and included in the value of the gross estate."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/834"},"text":"Pub. L. 87–834","children":[],"tail":" struck out provisions which excepted real property situated outside of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id452cada7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id452cada8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIII/s1310/c"},"text":"Pub. L. 105–34, title XIII, § 1310(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1044"},"text":"111 Stat. 1044","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tXIII/s1310/c"},"text":"“The amendments made by this section [amending this section] shall apply to the estates of decedents dying after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id452cada9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448"},"text":"Pub. L. 97–448","children":[],"tail":" effective, except as otherwise provided, as if it had been included in the provision of the Economic Recovery Tax Act of 1981, "},{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/s109"},"text":"section 109 of Pub. L. 97–448","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id452cadaa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s403/b/3/B"},"text":"section 403(b)(3)(B) of Pub. L. 97–34","children":[],"tail":" applicable to estates of decedents dying after "},{"tag":"date","attrib":{"date":"1981-12-31"},"text":"Dec. 31, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/s403/e"},"text":"section 403(e) of Pub. L. 97–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2056"},"text":"section 2056 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV/s424/b"},"text":"Pub. L. 97–34, title IV, § 424(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/317"},"text":"95 Stat. 317","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/34/tIV/s424/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to the estates of decedents dying after ","children":[{"tag":"date","attrib":{"date":"1981-12-31"},"text":"December 31, 1981","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id452cadab-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s702/f/2"},"text":"Pub. L. 95–600, title VII, § 702(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2930"},"text":"92 Stat. 2930","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/600/tVII/s702/f/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall apply to the estates of decedents dying after ","children":[{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":", except that it shall not apply to transfers made before "},{"tag":"date","attrib":{"date":"1977-01-01"},"text":"January 1, 1977","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id452cadac-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" applicable to estates of decedents dying after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"Dec. 31, 1976","children":[],"tail":", but not to transfers made before "},{"tag":"date","attrib":{"date":"1977-01-01"},"text":"Jan. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s2001/d/1"},"text":"section 2001(d)(1) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id452cadad-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1962 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/834"},"text":"Pub. L. 87–834","children":[],"tail":" applicable to estates of decedents dying after "},{"tag":"date","attrib":{"date":"1962-10-16"},"text":"Oct. 16, 1962","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/87/834/s18/b"},"text":"section 18(b) of Pub. L. 87–834","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2031"},"text":"section 2031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id452cadae-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfers Made by Decedent During 1977; Election Available to Executor On or Before Due Date for Filing Estate Tax Return","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/222/tI/s107/a/2/F"},"text":"Pub. L. 96–222, title I, § 107(a)(2)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-01"},"text":"Apr. 1, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/223"},"text":"94 Stat. 223","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the executor elects the benefits of this subparagraph with respect to any estate, section 2035(b) of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] (relating to adjustments for gifts made within 3 years of decedent’s death) shall be applied with respect to transfers made by the decedent during 1977 as if paragraph (2) of such section 2035(b) read as follows:","children":[{"tag":"p","attrib":{},"text":"“ ‘(2) to any gift to a donee made during 1977 to the extent of the amount of such gift which was excludable in computing taxable gifts by reason of section 2503(b) (relating to $3,000 annual exclusion for purposes of the gift tax) determined without regard to section 2513(a).’","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The election under clause (i) with respect to any estate shall be made on or before the later of—","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"“(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the due date for filing the estate tax return, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"“(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the day which is 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1980-04-01"},"text":"Apr. 1, 1980","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
