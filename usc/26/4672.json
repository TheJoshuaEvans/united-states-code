{"tag":"section","attrib":{"id":"id45df83da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4672"},"text":null,"children":[{"tag":"num","attrib":{"value":"4672"},"text":"§ 4672.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45df83db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4672/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable substance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45df83dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4672/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “taxable substance” means any substance which, at the time of sale or use by the importer, is listed as a taxable substance by the Secretary for purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45df83dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4672/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of substances on list","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A substance shall be listed under paragraph (1) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45df83de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4672/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the substance is contained in the list under paragraph (3), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45df83df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4672/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines, in consultation with the Administrator of the Environmental Protection Agency and the Commissioner of U.S. Customs and Border Protection, that taxable chemicals constitute more than 20 percent of the weight (or more than 20 percent of the value) of the materials used to produce such substance (determined on the basis of the predominant method of production).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If an importer or exporter of any substance requests that the Secretary determine whether such substance be listed as a taxable substance under paragraph (1) or be removed from such listing, the Secretary shall make such determination within 180 days after the date the request was filed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45df83e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4672/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial list of taxable substances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"html:table","attrib":{"width":"50%","id":"id45df83e1-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:td","attrib":{}