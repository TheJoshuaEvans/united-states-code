xt":"Pub. L. 103–465, title I, § 136(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4841"},"text":"108 Stat. 4841","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id461b0591-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id461b0592-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id461b0593-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5005, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/599"},"text":"68A Stat. 599","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s206/d"},"text":"Pub. L. 85–859, title II, § 206(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1431"},"text":"72 Stat. 1431","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising subsec. (c)(1), (2) of this section were contained in prior sections 5194(f), 5217(a), and 5232(a), ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/634"},"text":"68A Stat. 634","children":[],"tail":", 641, 643, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id461b0594-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s136/c/2/A"},"text":"Pub. L. 103–465, § 136(c)(2)(A)","children":[],"tail":", substituted “section 5001(a)(5) and (6)” for “section 5001(a)(6) and (7)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s136/c/2/B"},"text":"Pub. L. 103–465, § 136(c)(2)(B)","children":[],"tail":", substituted “section 5001(a)(4)” for “section 5001(a)(5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s455/b/1"},"text":"Pub. L. 98–369, § 455(b)(1)","children":[],"tail":", substituted “(10), or (13)” for “or (10)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s455/b/2"},"text":"Pub. L. 98–369, § 455(b)(2)","children":[],"tail":", inserted “used in the production of nonbeverage wine or wine products,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223"},"text":"Pub. L. 96–223","children":[],"tail":" substituted “(11), or (12),” for “or (11),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/s807/a/3/A"},"text":"Pub. L. 96–39, § 807(a)(3)(A)","children":[],"tail":", struck out par. (3) which related to liability for taxes with regard to withdrawals of distilled spirits from the bonded premises of a distilled spirits plant."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/s807/a/3/B"},"text":"Pub. L. 96–39, § 807(a)(3)(B)","children":[],"tail":", substituted “(3), or (11)” for “or (3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/s807/a/3/C"},"text":"Pub. L. 96–39, § 807(a)(3)(C)","children":[],"tail":", substituted “requiring bond covering operations at, and withdrawals from, distilled spirits plants” for “conditioning warehousing bonds on the payment of the tax” and “5173” for “5173(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/s807/a/3/D"},"text":"Pub. L. 96–39, § 807(a)(3)(D)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/176/s4/d/1"},"text":"Pub. L. 95–176, § 4(d)(1)","children":[],"tail":", struck out reference to par. (9) of section 5214(a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/176/s4/d/2"},"text":"Pub. L. 95–176, § 4(d)(2)","children":[],"tail":", inserted reference to pars. (9) and (10) of section 5214(a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/176/s4/b"},"text":"Pub. L. 95–176, § 4(b)","children":[],"tail":", substituted “customs bonded warehouses” for “customs manufacturing bonded warehouses” and provided for relief from liability for tax on distilled spirits used in certain research, development, or testing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted “Such relief from liability shall be effective from the time of removal from the transferor’s bonded premises, or from the time of divestment of interest, whichever is later.” for “Such liability for the tax on distilled spirits shall continue until the distilled spirits are transferred or withdrawn from bonded premises as authorized by law, or until such liability for tax is relieved by reason of the provisions of section 5008(a). Nothing in this paragraph shall relieve any person from any liability imposed by subsection (a) or (b).”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id461b0595-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id461b0596-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s136/d"},"text":"section 136(d) of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id461b0597-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":