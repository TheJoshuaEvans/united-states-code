{"tag":"section","attrib":{"id":"id461b057d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5005"},"text":null,"children":[{"tag":"num","attrib":{"value":"5005"},"text":"§ 5005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons liable for tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id461b057e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5005/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The distiller or importer of distilled spirits shall be liable for the taxes imposed thereon by section 5001(a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id461b057f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5005/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic distilled spirits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id461b0580-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5005/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of persons interested in distilling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every proprietor or possessor of, and every person in any manner interested in the use of, any still, distilling apparatus, or distillery, shall be jointly and severally liable for the taxes imposed by law on the distilled spirits produced therefrom.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461b0581-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5005/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person owning or having the right of control of not more than 10 percent of any class of stock of a corporate proprietor of a distilled spirits plant shall not be deemed to be a person liable for the tax for which such proprietor is liable under the provisions of paragraph (1). This exception shall not apply to an officer or director of such corporate proprietor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id461b0582-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5005/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proprietors of distilled spirits plants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id461b0583-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5005/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bonded storage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person operating bonded premises of a distilled spirits plant shall be liable for the internal revenue tax on all distilled spirits while the distilled spirits are stored on such premises, and on all distilled spirits which are in transit to such premises (from the time of removal from the transferor’s bonded premises) pursuant to application made by him. Such liability for the tax on distilled spirits shall continue until the distilled spirits are transferred or withdrawn from bonded premises as authorized by law, or until such liability for tax is relieved by reason of the provisions of section 5008(a). Nothing in this paragraph shall relieve any person from any liability imposed by subsection (a) or (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461b0584-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5005/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers in bond","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When distilled spirits are transferred in bond in accordance with the provisions of section 5212, persons liable for the tax on such spirits under subsection (a) or (b), or under any similar prior provisions of internal revenue law, shall be relieved of such liability, if proprietors of transferring and receiving premises are independent of each other and neither has a proprietary interest, directly or indirectly, in the business of the other, and all persons liable for the tax under subsection (a) or (b), or under any similar prior provisions of internal revenue law, have divested themselves of all interest in the spirits so transferred. Such relief from liability shall be effective from the time of removal from the transferor’s bonded premises, or from the time of divestment of interest, whichever is later.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id461b0585-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5005/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawals free of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All persons liable for the tax under subsection (a) or (b), or under any similar prior provisions of internal revenue law, shall be relieved of such liability as to distilled spirits withdrawn free of tax under the provisions of section 5214(a)(1), (2), (3), (11), or (12), or under section 7510, at the time such spirits are so withdrawn from bonded premises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id461b0586-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5005/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawals without payment of tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id461b0587-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5005/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who withdraws distilled spirits from the bonded premises of a distilled spirits plant without payment of tax, as provided in section 5214(a)(4), (5), (6), (7), (8), (9), (10), or (13), shall be liable for the internal revenue tax on such distilled spirits, from the time of such withdrawal; and all persons liable for the tax on such distilled spirits under subsection (a) or (b), or under any similar prior provisions of internal revenue law, shall, at the time of such withdrawal, be relieved of any such liability on the distilled spirits so withdrawn if the person withdrawing such spirits and the person, or persons, liable for the tax under subsection (a) or (b), or under any similar prior provisions of internal revenue law, are independent of each other and neither has a proprietary interest, directly or indirectly, in the business of the other, and all persons liable for the tax under subsection (a) or (b), or under any similar prior provisions of internal revenue law, have divested themselves of all interest in the spirits so withdrawn.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461b0588-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5005/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief from liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All persons liable for the tax on distilled spirits under paragraph (1) of this subsection, or under subsection (a) or (b), or under any similar prior provisions of internal revenue law, shall be relieved of any such liability at the time, as the case may be, the distilled spirits are exported, deposited in a foreign-trade zone, used in the production of wine, used in the production of nonbeverage wine or wine products, deposited in customs bonded warehouses, laden as supplies upon, or used in the maintenance or repair of, certain vessels or aircraft, or used in certain research, development, or testing, as provided by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id461b0589-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5005/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id461b058a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5005/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions requiring bond covering operations at, and withdrawals from, distilled spirits plants, see section 5173.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461b058b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5005/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions relating to transfer of tax liability to redistiller in case of redistillation, see section 5223.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461b058c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5005/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For liability for tax on denatured distilled spirits, articles, and volatile fruit-flavor concentrates, see section 5001(a)(5) and (6).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461b058d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5005/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For liability for tax on distilled spirits withdrawn free of tax, see section 5001(a)(4).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461b058e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5005/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For liability of wine producer for unlawfully using wine spirits withdrawn for the production of wine, see section 5391.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461b058f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5005/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions relating to transfer of tax liability for wine, see section 5043(a)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id461b0590-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"hr