{"tag":"section","attrib":{"id":"id43ed0142-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s644"},"text":null,"children":[{"tag":"num","attrib":{"value":"644"},"text":"§ 644.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable year of trusts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43ed0143-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s644/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subtitle, the taxable year of any trust shall be the calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43ed0144-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s644/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for trusts exempt from tax and charitable trusts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to a trust exempt from taxation under section 501(a) or to a trust described in section 4947(a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43ed0145-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIV/s1403/a"},"text":"Pub. L. 99–514, title XIV, § 1403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2713"},"text":"100 Stat. 2713","children":[],"tail":", § 645; renumbered § 644, "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tV/s507/b/1"},"text":"Pub. L. 105–34, title V, § 507(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/856"},"text":"111 Stat. 856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43ed0146-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43ed0147-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id43ed0148-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 644, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tVII/s701/e/1"},"text":"Pub. L. 94–455, title VII, § 701(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1578"},"text":"90 Stat. 1578","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s701/p/1"},"text":"Pub. L. 95–600, title VII, § 701(p)(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2908"},"text":"92 Stat. 2908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/471/s2/b/4"},"text":"Pub. L. 96–471, § 2(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-19"},"text":"Oct. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2254"},"text":"94 Stat. 2254","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1511/c/5"},"text":"Pub. L. 99–514, title XV, § 1511(c)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2745"},"text":"100 Stat. 2745","children":[],"tail":", related to special rule for gain on property transferred to trust at less than fair market value, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tV/s507/b/1"},"text":"Pub. L. 105–34, title V, § 507(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/856"},"text":"111 Stat. 856","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43ed0149-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s645"},"text":"section 645 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43ed014a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43ed014b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tV/s507/c/2"},"text":"Pub. L. 105–34, title V, § 507(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/857"},"text":"111 Stat. 857","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tV/s507/c/2"},"text":"“The amendments made by subsection (b) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s706"},"text":"section 706 of this title","children":[],"tail":", repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s644"},"text":"section 644 of this title","children":[],"tail":", and renumbering "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s645"},"text":"section 645 of this title","children":[],"tail":" as this section] shall apply to sales or exchanges after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id43ed014c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date; Transition Rule","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIV/s1403/c"},"text":"Pub. L. 99–514, title XIV, § 1403(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2713"},"text":"100 Stat. 2713","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXIV/s1403/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transition rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to any trust beneficiary who is required to include in gross income amounts under sections 652(a) or 662(a) of the Internal Revenue Code of 1986 in the 1st taxable year of the beneficiary beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", by reason of any short taxable year of the trust required by the amendments made by this section, such income shall be ratably included in the income of the trust beneficiary over the 4-taxable year period beginning with such taxable year.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id43ed014d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application of Transition Rules to Trust Beneficiaries to Which Section 664 Applies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1014/c"},"text":"Pub. L. 100–647, title I, § 1014(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3559"},"text":"102 Stat. 3559","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1014/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a beneficiary of a trust to which section 664 of the 1986 Code applies elects (at such time and in such manner as the Secretary of the Treasury or his delegate may prescribe) to have this paragraph apply, such beneficiary shall be entitled to the benefits of section 1403(c)(2) of the Reform Act [","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", set out as an Effective Date; Transition Rule note above] with respect to amounts included in gross income under section 664(b) of the 1986 Code in the same manner as if such amounts were included in gross income under section 652(a) of the 1986 Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any trust beneficiary may elect (at such time and in such manner as the Secretary of the Treasury or his delegate may prescribe) to waive the benefits of section 1403(c)(2) of the Reform Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of determining the gross income of any pass-thru entity, such pass-thru entity shall not be allowed the benefits of section 806(e)(2)(C) [","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", set out as an Effective Date of 1986 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1378"},"text":"section 1378 of this title","children":[],"tail":"] (other than with respect to income from a common trust fund) or 1403(c)(2) of the Reform Act if such pass-thru entity is required to change its taxable year by reason of the amendments made by section 806 or 1403 of the Reform Act ["},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", which enacted this section and amended sections 267, 441, 706, and 1378 of this title]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of subparagraph (A), the term ‘pass-thru entity’ means any trust, partnership, S corporation, or common trust fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any trust was required to change its taxable year by the amendments made by section 1403 of the Reform Act [","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", which enacted this section], such change shall be treated as initiated by such trust and approved by the Secretary of the Treasury or his delegate.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
