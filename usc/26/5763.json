{"tag":"section","attrib":{"id":"id464f8281-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5763"},"text":null,"children":[{"tag":"num","attrib":{"value":"5763"},"text":"§ 5763.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeitures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id464f8282-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5763/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tobacco products and cigarette papers and tubes unlawfully possessed","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id464f8283-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5763/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tobacco products and cigarette papers and tubes possessed with intent to defraud","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All tobacco products and cigarette papers and tubes which, after removal, are possessed with intent to defraud the United States shall be forfeited to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464f8284-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5763/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tobacco products and cigarette papers and tubes not property packaged","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All tobacco products and cigarette papers and tubes not in packages as required under section 5723 or which are in packages not bearing the marks, labels, and notices, as required under such section, which, after removal, are possessed otherwise than with intent to defraud the United States, shall be forfeited to the United States. This paragraph shall not apply to tobacco products or cigarette papers or tubes sold or delivered directly to consumers from proper packages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464f8285-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5763/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal property of qualified manufacturers, qualified importers, and export warehouse proprietors, acting with intent to defraud","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All tobacco products and cigarette papers and tubes, packages, machinery, fixtures, equipment, and all other materials and personal property on the premises of any qualified manufacturer or importer of tobacco products or cigarette papers and tubes, or export warehouse proprietor, who, with intent to defraud the United States, fails to keep or make any record, return, report, or inventory, or keeps or makes any false or fraudulent record, return, report, or inventory, required by this chapter; or refuses to pay any tax imposed by this chapter, or attempts in any manner to evade or defeat the tax or the payment thereof; or removes, contrary to any provision of this chapter, any article subject to tax under this chapter, shall be forfeited to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464f8286-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5763/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real and personal property of illicit operators","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All tobacco products, cigarette papers and tubes, machinery, fixtures, equipment, and other materials and personal property on the premises of any person engaged in business as a manufacturer or importer of tobacco products or cigarette papers and tubes, or export warehouse proprietor, without filing the bond or obtaining the permit, as required by this chapter, together with all his right, title, and interest in the building in which such business is conducted, and the lot or tract of ground on which the building is located, shall be forfeited to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464f8287-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5763/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All property intended for use in violating the provisions of this chapter, or regulations thereunder, or which has been so used, shall be forfeited to the United States as provided in section 7302.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id464f8288-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/718"},"text":"68A Stat. 718","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s202"},"text":"Pub. L. 85–859, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1426"},"text":"72 Stat. 1426","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tV/s502/b/13"},"text":"Pub. L. 89–44, title V, § 502(b)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/152"},"text":"79 Stat. 152","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1905/b/7/C"},"text":"Pub. L. 94–455, title XIX, § 1905(b)(7)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1823"},"text":"90 Stat. 1823","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIX/s9302/h/2/A"},"text":"Pub. L. 105–33, title IX, § 9302(h)(2)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/674"},"text":"111 Stat. 674","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id464f8289-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id464f828a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id464f828b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" inserted “qualified importers,” after “manufacturers,” in heading and “or importer” after “manufacturer” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s9302/h/2/A"},"text":"Pub. L. 105–33, § 9302(h)(2)(A)","children":[],"tail":", inserted “or importer” after “manufacturer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1905/b/7/C/i"},"text":"Pub. L. 94–455, § 1905(b)(7)(C)(i)","children":[],"tail":", substituted “and notices” for “notices, and stamps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1905/b/7/C/ii"},"text":"Pub. L. 94–455, § 1905(b)(7)(C)(ii)","children":[],"tail":", struck out “internal revenue stamps,” after “packages,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s502/b/13/A"},"text":"Pub. L. 89–44, § 502(b)(13)(A)","children":[],"tail":", struck out references to tobacco materials, dealers in tobacco materials, and statements."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s502/b/13/B"},"text":"Pub. L. 89–44, § 502(b)(13)(B)","children":[],"tail":", struck out references to tobacco materials and dealers in tobacco materials."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" substituted “tobacco products and cigarette papers and tubes” for “articles” wherever appearing and inserted provisions making par. (2) inapplicable to tobacco products or cigarette papers for tubes delivered directly to consumers from proper packages."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" included property of export warehouse proprietors."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" included property intended for use, or used, in violating regulations under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id464f828c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464f828d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" applicable to articles removed, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5702/j"},"text":"section 5702(j) of this title","children":[],"tail":", after "},{"tag":"date","attrib":{"date":"1999-12-31"},"text":"Dec. 31, 1999","children":[],"tail":", with transition rule, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/s9302/i"},"text":"section 9302(i) of Pub. L. 105–33","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5701"},"text":"section 5701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464f828e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" effective on first day of first month which begins more than 90 days after "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1905/d"},"text":"section 1905(d) of Pub.