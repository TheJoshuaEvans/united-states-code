{"tag":"section","attrib":{"id":"id464f826f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5762"},"text":null,"children":[{"tag":"num","attrib":{"value":"5762"},"text":"§ 5762.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id464f8270-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5762/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraudulent offenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever, with intent to defraud the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id464f8271-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5762/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Engaging in business unlawfully","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Engages in business as a manufacturer or importer of tobacco products or cigarette papers and tubes, or as an export warehouse proprietor, without filing the bond and obtaining the permit where required by this chapter or regulations thereunder; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464f8272-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5762/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failing to furnish information or furnishing false information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fails to keep or make any record, return, report, or inventory, or keeps or makes any false or fraudulent record, return, report, or inventory, required by this chapter or regulations thereunder; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464f8273-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5762/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refusing to pay or evading tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Refuses to pay any tax imposed by this chapter, or attempts in any manner to evade or defeat the tax or the payment thereof; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464f8274-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5762/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removing tobacco products or cigarette papers or tubes unlawfully","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Removes, contrary to this chapter or regulations thereunder, any tobacco products or cigarette papers or tubes subject to tax under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464f8275-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5762/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchasing, receiving, possessing, or selling tobacco products or cigarette papers or tubes unlawfully","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Violates any provision of section 5751(a)(1) or (a)(2); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464f8276-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5762/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Destroying, obliterating, or detaching marks, labels, or notices before packages are emptied","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Violates any provision of section 5752;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall, for each such offense, be fined not more than $10,000, or imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464f8277-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5762/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other offenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever, otherwise than as provided in subsection (a), violates any provision of this chapter, or of regulations prescribed thereunder, shall, for each such offense, be fined not more than $1,000, or imprisoned not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id464f8278-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/717"},"text":"68A Stat. 717","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s202"},"text":"Pub. L. 85–859, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1425"},"text":"72 Stat. 1425","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tV/s502/b/12"},"text":"Pub. L. 89–44, title V, § 502(b)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/152"},"text":"79 Stat. 152","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1905/b/7/B/ii"},"text":"Pub. L. 94–455, title XIX, § 1905(b)(7)(B)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1823"},"text":"90 Stat. 1823","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIX/s9302/h/2/A"},"text":"Pub. L. 105–33, title IX, § 9302(h)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/674"},"text":"111 Stat. 674","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id464f8279-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id464f827a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id464f827b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" inserted “or importer” after “manufacturer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" redesignated par. (7) as (6), and in par. (6) as so redesignated substituted “or notices” for “notices, or stamps” and “section 5752;” for “section 5752(a); or”. Former par. (6), relating to the affixing of improper stamps, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" redesignated par. (7) as (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8) to (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out pars. (8) to (11) which related to emptying packages without destroying stamps, possessing emptied packages bearing stamps, refilling packages bearing stamps, and detaching stamps or possessing used stamps."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s502/b/12/A"},"text":"Pub. L. 89–44, § 502(b)(12)(A)","children":[],"tail":", struck out reference to a dealer in tobacco materials."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s502/b/12/B"},"text":"Pub. L. 89–44, § 502(b)(12)(B)","children":[],"tail":", struck out reference to statements."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" included export warehouse proprietors in par. (1), struck out provisions in pars. (6) and (9) to (11) which related to labels and notices, and added pars. (7) and (8)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id464f827c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"t