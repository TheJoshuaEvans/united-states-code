{"tag":"section","attrib":{"id":"id44f8308f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1379"},"text":null,"children":[{"tag":"num","attrib":{"value":"1379"},"text":"§ 1379.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transitional rules on enactment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44f83090-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1379/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Old elections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any election made under section 1372(a) (as in effect before the enactment of the Subchapter S Revision Act of 1982) shall be treated as an election made under section 1362.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f83091-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1379/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References to prior law included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any references in this title to a provision of this subchapter shall, to the extent not inconsistent with the purposes of this subchapter, include a reference to the corresponding provision as in effect before the enactment of the Subchapter S Revision Act of 1982.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f83092-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1379/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions of undistributed taxable income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a corporation was an electing small business corporation for the last preenactment year, subsections (f) and (d) of section 1375 (as in effect before the enactment of the Subchapter S Revision Act of 1982) shall continue to apply with respect to distributions of undistributed taxable income for any taxable year beginning before ","children":[{"tag":"date","attrib":{"date":"1983-01-01"},"text":"January 1, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f83093-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1379/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryforwards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a corporation was an electing small business corporation for the last preenactment year and is an S corporation for the 1st postenactment year, any carryforward to the 1st post­enactment year which arose in a taxable year for which the corporation was an electing small business corporation shall be treated as arising in the 1st postenactment year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f83094-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1379/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preenactment and postenactment years defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f83095-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1379/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Last preenactment year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “last preenactment year” means the last taxable year of a corporation which begins before ","children":[{"tag":"date","attrib":{"date":"1983-01-01"},"text":"January 1, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f83096-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1379/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1st postenactment year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “1st postenactment year” means the 1st taxable year of a corporation which begins after ","children":[{"tag":"date","attrib":{"date":"1982-12-31"},"text":"December 31, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44f83097-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/354/s2"},"text":"Pub. L. 97–354, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"Oct. 19, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1686"},"text":"96 Stat. 1686","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII/s721/n"},"text":"Pub. L. 98–369, div. A, title VII, § 721(n)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/969"},"text":"98 Stat. 969","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44f83098-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44f83099-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id44f8309a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The enactment of the Subchapter S Revision Act of 1982, referred to in subsecs. (a) to (c), is the enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/354"},"text":"Pub. L. 97–354","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"Oct. 19, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id44f8309b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1379, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tV/s531/a"},"text":"Pub. L. 91–172, title V, § 531(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/654"},"text":"83 Stat. 654","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/406/tII/s2001/b"},"text":"Pub. L. 93–406, title II, § 2001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/952"},"text":"88 Stat. 952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIII/s312/c/6"},"text":"Pub. L. 97–34, title III, § 312(c)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/284"},"text":"95 Stat. 284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tII/s238/c"},"text":"Pub. L. 97–248, title II, § 238(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/513"},"text":"96 Stat. 513","children":[],"tail":", related to certain qualified pension, etc., plans, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/97/354/s2"},"text":"section 2 of Pub. L. 97–354","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44f8309c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" struck out “In applying this subchapter to any taxable year beginning after "},{"tag":"date","attrib":{"date":"1982-12-31"},"text":"December 31, 1982","children":[],"tail":",” and substituted “Any references in this title to a provision” for “any reference in this subchapter to another provision”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44f8309d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44f8309e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail"