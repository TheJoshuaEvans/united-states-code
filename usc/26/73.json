{"tag":"section","attrib":{"id":"id414317da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s73"},"text":null,"children":[{"tag":"num","attrib":{"value":"73"},"text":"§ 73.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services of child","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id414317db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s73/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of amounts received","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts received in respect of the services of a child shall be included in his gross income and not in the gross income of the parent, even though such amounts are not received by the child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id414317dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s73/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All expenditures by the parent or the child attributable to amounts which are includible in the gross income of the child (and not of the parent) solely by reason of subsection (a) shall be treated as paid or incurred by the child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id414317dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s73/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parent defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “parent” includes an individual who is entitled to the services of a child by reason of having parental rights and duties in respect of the child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id414317de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s73/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For assessment of tax against parent in certain cases, see section 6201(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id414317df-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/24"},"text":"68A Stat. 24","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
