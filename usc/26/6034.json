{"tag":"section","attrib":{"id":"id4665064c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034"},"text":null,"children":[{"tag":"num","attrib":{"value":"6034"},"text":"§ 6034.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns by certain trusts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4665064d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Split-interest trusts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every trust described in section 4947(a)(2) shall furnish such information with respect to the taxable year as the Secretary may by forms or regulations require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4665064e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trusts claiming certain charitable deductions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4665064f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every trust not required to file a return under subsection (a) but claiming a deduction under section 642(c) for the taxable year shall furnish such information with respect to such taxable year as the Secretary may by forms or regulations prescribe, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46650650-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the deduction taken under section 642(c) within such year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46650651-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount paid out within such year which represents amounts for which deductions under section 642(c) have been taken in prior years,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46650652-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount for which such deductions have been taken in prior years but which has not been paid out at the beginning of such year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46650653-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount paid out of principal in the current and prior years for the purposes described in section 642(c),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46650654-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total income of the trust within such year and the expenses attributable thereto, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46650655-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a balance sheet showing the assets, liabilities, and net worth of the trust as of the beginning of such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46650656-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to a trust for any taxable year if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46650657-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all the net income for such year, determined under the applicable principles of the law of trusts, is required to be distributed currently to the beneficiaries, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46650658-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trust is described in section 4947(a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46650659-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/742"},"text":"68A Stat. 742","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tI/s101/j/32"},"text":"Pub. L. 91–172, title I, § 101(j)(32)","children":[],"tail":"–(34), "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/529"},"text":"83 Stat. 529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/603/s1/d/1"},"text":"Pub. L. 96–603, § 1(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3504"},"text":"94 Stat. 3504","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1501/d/1/C"},"text":"Pub. L. 99–514, title XV, § 1501(d)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2740"},"text":"100 Stat. 2740","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1201/b/1"},"text":"Pub. L. 109–280, title XII, § 1201(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1064"},"text":"120 Stat. 1064","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4665065a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4665065b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4665065c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":", which directed the general amendment of section 6034 without specifying the act to be amended, was executed to this section, which is section 6034 of the Internal Revenue Code of 1986, to reflect the probable intent of Congress. Prior to amendment, this section consisted of subsecs. (a) to (c) stating a general rule requiring certain trusts to furnish information as the Secretary may by forms and regulations prescribe, allowing for exceptions to the rule, and providing a cross reference relating to penalties for failure to file a return."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “section 6652(c)” for “section 6652(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/603/s1/d/1/D"},"text":"Pub. L. 96–603, § 1(d)(1)(D)","children":[],"tail":", substituted “section 4947(a)(2)” for “section 4947(a)” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/603/s1/d/1/A"},"text":"Pub. L. 96–603, § 1(d)(1)(A)","children":[],"tail":", substituted “section 4947(a)(2)” for “section 4947(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/603/s1/d/1/B"},"text":"Pub. L. 96–603, § 1(d)(1)(B)","children":[],"tail":", (C), substituted in heading “Exceptions” for “Exception” and in text inserted provision that this section not apply in the case of a trust described in section 4947(a)(1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/s101/j/32"},"text":"Pub. L. 91–172, § 101(j)(32)","children":[],"tail":", (33), inserted, in section catchline and in subsec. (a), reference to trusts described in section 4947(a), and, in par. (1), struck out provisions requiring the separate showing of the amount of deduction paid out, and the amount permanently set aside for charitable, etc., purposes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/s101/j/34"},"text":"Pub. L. 91–172, § 101(j)(34)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4665065d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4665065e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1201/c/2"},"text":"Pub. L. 109–280, title XII, § 1201(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1066"},"text":"120 Stat. 1066","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/280/tXII/s1201/c/2"},"text":"“The amendments made by subsection (b) [amending this section and sections 6104 and 6652 of this title] shall apply to returns for taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2006-12-31"},"text":"December 31, 2006","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4665065f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" applicable to returns the due date for which (determined without regard to extensions) is after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1501/e"},"text":"section 1501(e) of Pub. L. 99–514","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6721"},"text":"section 6721 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46650660-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/603"},"text":"Pub. L. 96–603","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1980-12-31"},"text":"Dec. 31, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/603/s1/f"},"text":"section 1(f) of Pub. L. 96–603","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6033"},"text":"section 6033 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id466506