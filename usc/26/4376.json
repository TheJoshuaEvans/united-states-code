{"tag":"section","attrib":{"id":"id45d375ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376"},"text":null,"children":[{"tag":"num","attrib":{"value":"4376"},"text":"§ 4376.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Self-insured health plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45d375ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any applicable self-insured health plan for each plan year ending after ","children":[{"tag":"date","attrib":{"date":"2012-09-30"},"text":"September 30, 2012","children":[],"tail":", there is hereby imposed a fee equal to $2 ($1 in the case of plan years ending during fiscal year 2013) multiplied by the average number of lives covered under the plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d375ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for fee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d375af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fee imposed by subsection (a) shall be paid by the plan sponsor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d375b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan sponsor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1) the term “plan sponsor” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45d375b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer in the case of a plan established or maintained by a single employer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d375b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee organization in the case of a plan established or maintained by an employee organization,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d375b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45d5e5b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan established or maintained by 2 or more employers or jointly by 1 or more employers and 1 or more employee organizations,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45d5e5b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a multiple employer welfare arrangement, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45d5e5b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a voluntary employees’ beneficiary association described in section 501(c)(9), the association, committee, joint board of trustees, or other similar group of representatives of the parties who establish or maintain the plan, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d5e5b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cooperative or association described in subsection (c)(2)(F) in the case of a plan established or maintained by such a cooperative or association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d5e5b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable self-insured health plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “applicable self-insured health plan” means any plan for providing accident or health coverage if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d5e5b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any portion of such coverage is provided other than through an insurance policy, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e5ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such plan is established or maintained—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45d5e5bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by 1 or more employers for the benefit of their employees or former employees,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d5e5bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by 1 or more employee organizations for the benefit of their members or former members,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d5e5bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" jointly by 1 or more employers and 1 or more employee organizations for the benefit of employees or former employees,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d5e5be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a voluntary employees’ beneficiary association described in section 501(c)(9),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d5e5bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any organization described in section 501(c)(6), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d5e5c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a plan not described in the preceding subparagraphs, by a multiple employer welfare arrangement (as defined in section 3(40) of Employee Retirement Income Security Act of 1974), a rural electric cooperative (as defined in section 3(40)(B)(iv) of such Act), or a rural telephone cooperative association (as defined in section 3(40)(B)(v) of such Act).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d5e5c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments for increases in health care spending","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any plan year ending in any fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2014-09-30"},"text":"September 30, 2014","children":[],"tail":", the dollar amount in effect under subsection (a) for such plan year shall be equal to the sum of such dollar amount for plan years ending in the previous fiscal year (determined after the application of this subsection), plus an amount equal to the product of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d5e5c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dollar amount for plan years ending in the previous fiscal year, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e5c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage increase in the projected per capita amount of National Health Expenditures, as most recently published by the Secretary before the beginning of the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d5e5c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4376/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to plan years ending after ","children":[{"tag":"date","attrib":{"date":"2029-09-30"},"text":"September 30, 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d5e5c5-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6301/e/2/A"},"text":"Pub. L. 111–148, title VI, § 6301(e)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/744"},"text":"124 Stat. 744","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dN/tI/s104/c"},"text":"Pub. L. 116–94, div. N, title I, § 104(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3098"},"text":"133 Stat. 3098","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45d5e5c6-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45d5e5c7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id45d5e5c8-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3(40) of Employee Retirement Income Security Act of 1974, referred to in subsec. (c)(2)(F), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002/40"},"text":"section 1002(40) of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45d5e5c9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" substituted “2029” for “2019”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
