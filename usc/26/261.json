{"tag":"section","attrib":{"id":"id4246f35c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s261"},"text":null,"children":[{"tag":"num","attrib":{"value":"261"},"text":"§ 261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule for disallowance of deductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In computing taxable income no deduction shall in any case be allowed in respect of the items specified in this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4246f35d-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/76"},"text":"68A Stat. 76","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
