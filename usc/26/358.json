"attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":", and any securities of Corporation held by Association transferred to Secretary of Transportation on "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1341"},"text":"section 1341 of Title 45","children":[],"tail":", Railroads."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id42c571f2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application of Comparable Rules to Partnerships and S Corporations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s309/c"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 309(c)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–638, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/554/s1/a/7/tIII/s309/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary of the Treasury or his delegate—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall prescribe rules which provide appropriate adjustments under subchapter K of chapter 1 of the Internal Revenue Code of 1986 to prevent the acceleration or duplication of losses through the assumption of (or transfer of assets subject to) liabilities described in section 358(h)(3) of such Code (as added by subsection (a)) in transactions involving partnerships, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"