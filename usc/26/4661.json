sHeading","topic":"editorialNotes","id":"id45dd1243-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id45dd1244-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tVIII/s8031/d/2"},"text":"Pub. L. 99–509, title VIII, § 8031(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1956"},"text":"100 Stat. 1956","children":[],"tail":", to subsec. (c) of this section was not executed to text pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tVIII/s8031/e/2"},"text":"Pub. L. 99–509, title VIII, § 8031(e)(2)","children":[],"tail":", which provided that the amendments made by section 8031 shall not take effect if the Superfund Amendments and Reauthorization Act of 1986 is enacted. The Superfund Amendments and Reauthorization Act of 1986 was enacted as "},{"tag":"ref","attrib":{"href":"/us/pl/99/499"},"text":"Pub. L. 99–499","children":[],"tail":", approved "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45dd1245-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s80201/b/1"},"text":"Pub. L. 117–58, § 80201(b)(1)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) set out the amount of tax on certain taxable chemicals."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s80201/a/1"},"text":"Pub. L. 117–58, § 80201(a)(1)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, text read as follows: “No tax shall be imposed under this section during any period during which the Hazardous Substance Superfund financing rate under section 4611 does not apply.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499"},"text":"Pub. L. 99–499","children":[],"tail":" inserted at end “For periods before 1992, the item relating to xylene in the preceding table shall be applied by substituting ‘10.13’ for ‘4.87’.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509"},"text":"Pub. L. 99–509","children":[],"tail":" substituted “the Hazardous Substance Superfund financing rate under section 4611 does not apply” for “no tax is imposed under section 4611(a)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45dd1246-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45dd1247-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dH/tII/s80201/d"},"text":"Pub. L. 117–58, div. H, title II, § 80201(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1330"},"text":"135 Stat. 1330","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/58/dH/tII/s80201/d"},"text":"“The amendments made by this section [amending this section and sections 4671 and 4672 of this title] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2022-07-01"},"text":"July 1, 2022","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45dd1248-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509"},"text":"Pub. L. 99–509","children":[],"tail":" effective on commencement date as defined in former section 4611(f)(2), see "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/s8032/d"},"text":"section 8032(d) of Pub. L. 99–509","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4611"},"text":"section 4611 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499/tV/s513/h"},"text":"Pub. L. 99–499, title V, § 513(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1765"},"text":"100 Stat. 1765","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this subsection, the amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4662"},"text":"section 4662 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repeal of tax on xylene for periods before ","children":[{"tag":"date","attrib":{"date":"1985-10-01"},"text":"october 1, 1985","children":[],"tail":".—"}],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Refund of tax previously imposed.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of any tax imposed by section 4661 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] on the sale or use of xylene before ","children":[{"tag":"date","attrib":{"date":"1985-10-01"},"text":"October 1, 1985","children":[],"tail":", such tax (including interest, additions to tax, and additional amounts) shall not be assessed, and if assessed, the assessment shall be abated, and if collected shall be credited or refunded (with interest) as an overpayment."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Condition to allowance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Clause (i) shall not apply to a sale of xylene unless the person who (but for clause (i)) would be liable for the tax imposed by section 4661 on such sale meets requirements similar to the requirements of paragraph (1) of section 6416(a) of such Code. For purposes of the preceding sentence, subparagraph (A) of section 6416(a)(1) of such Code shall be applied without regard to the material preceding ‘has not collected’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver of statute of limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":"] (or at any time within 1 year after such date of enactment) refund or credit of any overpayment of tax resulting from the application of subparagraph (A) is barred by any law or rule of law, refund or credit of such overpayment shall, nevertheless, be made or allowed if claim therefor is filed before the date 1 year after the date of the enactment of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Xylene to include isomers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this paragraph, the term ‘xylene’ shall include any isomer of xylene whether or not separated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inventory exchanges.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this paragraph, the amendment made by subsection (f) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4662"},"text":"section 4662 of this title","children":[],"tail":"] shall apply as if included in the amendments made by section 211 of the Hazardous Substance Response Revenue Act of 1980 ["},{"tag":"ref","attrib":{"href":"/us/pl/96/510"},"text":"Pub. L. 96–510","children":[],"tail":", enacting this chapter]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recipient must agree to treatment as manufacturer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of any inventory exchange before ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":", the amendment made by subsection (f) shall apply only if the person receiving the chemical from the manufacturer, producer, or importer in the exchange agrees to be treated as the manufacturer, producer, or importer of such chemical for purposes of subchapter B of chapter 38 of the Internal Revenue Code of 1986."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception where manufacturer paid tax","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of any inventory exchange before ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":", the amendment made by subsection (f) shall not apply if the manufacturer, producer, or importer treated such exchange as a sale for purposes of section 4661 of such Code and paid the tax imposed by such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Registration requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 4662(c)(2)(B) of such Code (as added by subsection (f)) shall apply to exchanges made after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exports of taxable substances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subclause (II) of section 4662(e)(2)(A)(ii) of such Code (as added by this section) shall not apply to the export of any taxable substance (as defined in section 4672(a) of such Code) before ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sales of intermediate hydrocarbon streams.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this paragraph, the amendment made by subsection (g) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4662"},"text":"section 4662 of this title","children":[],"tail":"] shall apply as if included in the amendments made by section 211 of the Hazardous Substances Response Revenue Act of 1980."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purchaser must agree to treatment as manufacturer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of any sale before ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":", of any intermediate hydrocarbon stream, the amendment made by subsection (g) shall apply only if the purchaser agrees to be treated as the manufacturer, producer, or importer for purposes of subchapter B of chapter 38 of such Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception where manufacturer paid tax","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of any sale before ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":", of any intermediate hydrocarbon stream, the amendment made by subsection (g) shall not apply if the manufacturer, producer, or importer of such stream paid the tax imposed by section 4661 with respect to such sale on all taxable chemicals contained in such stream."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Registration requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 4662(b)(10)(C) of such Code (as added by subsection (g)) shall apply to exchanges made after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45df8349-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter effective ","children":[{"tag":"date","attrib":{"date":"1981-04-01"},"text":"Apr. 1, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/510/s211/c"},"text":"section 211(c) of Pub. L. 96–510","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4611"},"text":"section 4611 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
