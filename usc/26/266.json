{"tag":"section","attrib":{"id":"id428e8352-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s266"},"text":null,"children":[{"tag":"num","attrib":{"value":"266"},"text":"§ 266.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carrying charges","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowed for amounts paid or accrued for such taxes and carrying charges as, under regulations prescribed by the Secretary, are chargeable to capital account with respect to property, if the taxpayer elects, in accordance with such regulations, to treat such taxes or charges as so chargeable.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id428e8353-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/78"},"text":"68A Stat. 78","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id428e8354-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id428e8355-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id428e8356-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
