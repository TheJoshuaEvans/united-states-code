{"tag":"section","attrib":{"id":"id44e03af0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1288"},"text":null,"children":[{"tag":"num","attrib":{"value":"1288"},"text":"§ 1288.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of original issue discount on tax-exempt obligations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44e03af1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1288/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Original issue discount on any tax-exempt obligation shall be treated as accruing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e03af2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1288/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of section 163, in the manner provided by section 1272(a) (determined without regard to paragraph (7) thereof), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e03af3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1288/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of determining the adjusted basis of the holder, in the manner provided by section 1272(a) (determined with regard to paragraph (7) thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e03af4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1288/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e03af5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1288/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Original issue discount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “original issue discount” has the meaning given to such term by section 1273(a) without regard to paragraph (3) thereof. In applying section 483 or 1274, under regulations prescribed by the Secretary, appropriate adjustments shall be made to the applicable Federal rate to take into account the tax exemption for interest on the obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e03af6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1288/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax-exempt obligation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tax-exempt obligation” has the meaning given to such term by section 1275(a)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e03af7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1288/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short-term obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying this section to obligations with maturity of 1 year or less, rules similar to the rules of section 1283(b) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44e03af8-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s41/a"},"text":"Pub. L. 98–369, div. A, title I, § 41(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/553"},"text":"98 Stat. 553","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/u/3"},"text":"Pub. L. 100–647, title I, § 1006(u)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3427"},"text":"102 Stat. 3427","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44e03af9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44e03afa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44e03afb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" substituted “paragraph (7)” for “paragraph (6)” in pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44e03afc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiv