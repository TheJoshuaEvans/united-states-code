{"tag":"section","attrib":{"id":"id443973a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s859"},"text":null,"children":[{"tag":"num","attrib":{"value":"859"},"text":"§ 859.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption of annual accounting period","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id443973a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s859/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subtitle—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443973a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s859/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a real estate investment trust shall not change to any accounting period other than the calendar year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443973a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s859/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation, trust, or association may not elect to be a real estate investment trust for any taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"1976-10-04"},"text":"October 4, 1976","children":[],"tail":", unless its accounting period is the calendar year."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Paragraph (2) shall not apply to a corporation, trust, or association which was considered to be a real estate investment trust for any taxable year beginning on or before ","children":[{"tag":"date","attrib":{"date":"1976-10-04"},"text":"October 4, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443973a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s859/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change of accounting period without approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 442, an entity which has not engaged in any active trade or business may change its accounting period to a calendar year without the approval of the Secretary if such change is in connection with an election under section 856(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id443973a7-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXVI/s1604/i/1"},"text":"Pub. L. 94–455, title XVI, § 1604(i)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1752"},"text":"90 Stat. 1752","children":[],"tail":", § 860; renumbered § 859 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tIII/s362/d/6"},"text":"Pub. L. 95–600, title III, § 362(d)(6)","children":[],"tail":", title VII, § 701(t)(1), "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2852"},"text":"92 Stat. 2852","children":[],"tail":", 2911; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s661/c"},"text":"Pub. L. 99–514, title VI, § 661(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2300"},"text":"100 Stat. 2300","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id443973a8-3a70-11f1-a967-d35dac11796a"},"t