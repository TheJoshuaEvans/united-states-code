{"tag":"section","attrib":{"id":"id45f295a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4959"},"text":null,"children":[{"tag":"num","attrib":{"value":"4959"},"text":"§ 4959.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxes on failures by hospital organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If a hospital organization to which section 501(r) applies fails to meet the requirement of section 501(r)(3) for any taxable year, there is imposed on the organization a tax equal to $50,000.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id45f295a6-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIX/s9007/b/1"},"text":"Pub. L. 111–148, title IX, § 9007(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/857"},"text":"124 Stat. 857","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45f295a7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45f295a8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45f295a9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to failures occurring after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s9007/f/3"},"text":"section 90