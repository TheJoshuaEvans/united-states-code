{"tag":"section","attrib":{"id":"id44abe4fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1041"},"text":null,"children":[{"tag":"num","attrib":{"value":"1041"},"text":"§ 1041.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of property between spouses or incident to divorce","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44abe4fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1041/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No gain or loss shall be recognized on a transfer of property from an individual to (or in trust for the benefit of)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44abe4fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1041/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a spouse, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44abe4fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1041/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a former spouse, but only if the transfer is incident to the divorce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44abe4fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1041/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer treated as gift; transferee has transferor’s basis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any transfer of property described in subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44abe4ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1041/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of this subtitle, the property shall be treated as acquired by the transferee by gift, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44abe500-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1041/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis of the transferee in the property shall be the adjusted basis of the transferor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44abe501-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1041/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incident to divorce","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)(2), a transfer of property is incident to the divorce if such transfer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44abe502-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1041/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occurs within 1 year after the date on which the marriage ceases, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44abe503-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1041/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is related to the cessation of the marriage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44abe504-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1041/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule where spouse is nonresident alien","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply if the spouse (or former spouse) of the individual making the transfer is a nonresident alien.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44abe505-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1041/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers in trust where liability exceeds basis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to the transfer of property in trust to the extent that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44abe506-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1041/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the amount of the liabilities assumed, plus the amount of the liabilities to which the property is subject, exceeds","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44abe507-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1041/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total of the adjusted basis of the property transferred.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Proper adjustment shall be made under subsection (b) in the basis of the transferee in such property to take into account gain recognized by reason of the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44abe508-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s421/a"},"text":"Pub. L. 98–369, div. A, title IV, § 421(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/793"},"text":"98 Stat. 793","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1842/b"},"text":"Pub. L. 99–514, title XVIII, § 1842(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2853"},"text":"100 Stat. 2853","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1018"},"text":"Pub. L. 100–647, title I, § 1018","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3584"},"text":"102 Stat. 3584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44abe509-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44abe50a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44abe50b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" substituted “Subsection (a)” for “Paragraph (1) of subsection (a)” and “the spouse (or former spouse)” for “the spouse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44abe50c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44abe50d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1018"},"text":"Pub. L. 100–647, title I, § 1018","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3584"},"text":"102 Stat. 3584","children":[],"tail":", provided that the amendment made by that section is effective with respect to transfers after "},{"tag":"date","attrib":{"date":"1988-06-21"},"text":"June 21, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44abe50e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44abe50f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s421/d"},"text":"Pub. L. 98–369, div. A, title IV, § 421(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/795"},"text":"98 Stat. 795","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tIV/s421/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this subsection, the amendments made by this section [enacting this section and amending sections 47, 72, 101, 453, 453B, 1001, 1015, and 1239 of this title] shall apply to transfers after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":"] in taxable years ending after such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election to have amendments apply to transfers after 1983","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If both spouses or former spouses make an election under this paragraph, the amendments made by this section shall apply to all transfers made by such spouses (or former spouses) after ","children":[{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for transfers pursuant to existing decrees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except in the case of an election under paragraph (2), the amendments made by this section shall not apply to transfers under any instrument in effect on or before the date of the enactment of this Act unless both spouses (or former spouses) elect to have such amendments apply to transfers under such instrument.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any election under paragraph (2) or (3) shall be made in such manner, at such time, and subject to such conditions, as the Secretary of the Treasury or his delegate may by regulations prescribe.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id44abe510-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1800–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
