{"tag":"section","attrib":{"id":"id439740db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468"},"text":null,"children":[{"tag":"num","attrib":{"value":"468"},"text":"§ 468.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for mining and solid waste reclamation and closing costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id439740dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of reserves for reclamation and closing costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id439740dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of deduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a taxpayer elects the application of this section with respect to any mining or solid waste disposal property, the amount of any deduction for qualified reclamation or closing costs for any taxable year to which such election applies shall be equal to the current reclamation or closing costs allocable to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439740de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of qualified reclamation costs, the portion of the reserve property which was disturbed during such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439740df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of qualified closing costs, the production from the reserve property during such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439740e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opening balance and adjustments to reserve","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439740e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opening balance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The opening balance of any reserve for its first taxable year shall be zero.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439740e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase for interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A reserve shall be increased each taxable year by an amount equal to the amount of interest which would have been earned during such taxable year on the opening balance of such reserve for such taxable year if such interest were computed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id439740e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the Federal short-term rate or rates (determined under section 1274) in effect, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439740e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by compounding semiannually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439740e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve to be charged for amounts paid","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount paid by the taxpayer during any taxable year for qualified reclamation or closing costs allocable to portions of the reserve property for which the election under paragraph (1) was in effect shall be charged to the appropriate reserve as of the close of the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439740e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve increased by amount deducted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A reserve shall be increased each taxable year by the amount allowable as a deduction under paragraph (1) for such taxable year which is allocable to such reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439740e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of deduction for excess amounts paid","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be allowed as a deduction for any taxable year the excess of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439740e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts described in paragraph (2)(C) paid during such taxable year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439740e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the closing balance of the reserve for such taxable year (determined without regard to paragraph (2)(C)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439740ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on balance as of the close of any taxable year","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439740eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reclamation reserves","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any reserve for qualified reclamation costs, there shall be included in gross income for any taxable year an amount equal to the excess of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id439740ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the closing balance of the reserve for such taxable year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439740ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current reclamation costs of the taxpayer for all portions of the reserve property disturbed during any taxable year to which the election under paragraph (1) applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439740ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closing costs reserves","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any reserve for qualified closing costs, there shall be included in gross income for any taxable year an amount equal to the excess of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id439740ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the closing balance of the reserve for such taxable year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439740f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current closing cost of the taxpayer with respect to the reserve property, determined as if all production with respect to the reserve property for any taxable year to which the election under paragraph (1) applies had occurred in such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439740f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This paragraph shall be applied after all adjustments to the reserve have been made for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439740f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income inclusions on completion or disposition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Proper inclusion in income shall be made upon—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439740f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the revocation of an election under paragraph (1), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439740f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completion of the closing, or disposition of any portion, of a reserve property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439740f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation for property where election not in effect for all taxable years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the election under subsection (a)(1) is not in effect for 1 or more taxable years in which the reserved property is disturbed (or production occurs), items with respect to the reserve property shall be allocated to the reserve in such manner as the Secretary may prescribe by regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439740f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation of election; separate reserves","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id439740f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation of election","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439740f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The taxpayer may revoke an election under subsection (a)(1) with respect to any property. Such revocation, once made, shall be irrevocable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439740f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time and manner of revocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any revocation under subparagraph (A) shall be made at such time and in such manner as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439740fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate reserves required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a taxpayer makes an election under subsection (a)(1), the taxpayer shall establish with respect to the property for which the election was made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439740fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a separate reserve for qualified reclamation costs, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439740fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a separate reserve for qualified closing costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439740fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules relating to reclamation and closing costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id439740fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current reclamation and closing costs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439740ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current reclamation costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “current reclamation costs” means the amount which the taxpayer would be required to pay for qualified reclamation costs if the reclamation activities were performed currently.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43974100-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current closing costs","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43974101-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “current closing costs” means the amount which the taxpayer would be required to pay for qualified closing costs if the closing activities were performed currently.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43974102-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs computed on unit-of-production or capacity method","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Estimated closing costs shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id43974103-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the closing of any mine site, be computed on the unit-of-production method of accounting, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id43974104-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the closing of any solid waste disposal site, be computed on the unit-of-capacity method.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43974105-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified reclamation or closing costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified reclamation or closing costs” means any of the following expenses:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43974106-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mining reclamation and closing costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any expenses incurred for any land reclamation or closing activity which is conducted in accordance with a reclamation plan (including an amendment or modification thereof)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43974107-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id43974108-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is submitted pursuant to the provisions of section 511 or 528 of the Surface Mining Control and Reclamation Act of 1977 (as in effect on ","children":[{"tag":"date","attrib":{"date":"1984-01-01"},"text":"January 1, 1984","children":[],"tail":"), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id43974109-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is part of a surface mining and reclamation permit granted under the provisions of title V of such Act (as so in effect), or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4397410a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is submitted pursuant to any other Federal or State law which imposes surface mining reclamation and permit requirements substantially similar to the requirements imposed by title V of such Act (as so in effect).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4397410b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solid waste disposal and closing costs","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4397410c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any expenses incurred for any land reclamation or closing activity in connection with any solid waste disposal site which is conducted in accordance with any permit issued pursuant to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4397410d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any provision of the Solid Waste Disposal Act (as in effect on ","children":[{"tag":"date","attrib":{"date":"1984-01-01"},"text":"January 1, 1984","children":[],"tail":") requiring such activity, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4397410e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Federal, State, or local law which imposes requirements substantially similar to the requirements imposed by the Solid Waste Disposal Act (as so in effect).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4397410f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain hazardous waste sites","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Clause (i) shall not apply to that portion of any property which is disturbed after the property is listed in the national contingency plan established under section 105 of the Comprehensive Environmental Response, Compensation, and Liability Act of 1980.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43974110-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “property” has the meaning given such term by section 614.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43974111-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “reserve property” means any property with respect to which a reserve is established under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43974112-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s91/b/1"},"text":"Pub. L. 98–369, div. A, title I, § 91(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/601"},"text":"98 Stat. 601","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII"},"text":"Pub. L. 99–514, title XVIII","children":[],"tail":", §§ 1807(a)(3)(A), (C), 1899A(14), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2811"},"text":"100 Stat. 2811","children":[],"tail":", 2959; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11802/c"},"text":"Pub. L. 101–508, title XI, § 11802(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-529"},"text":"104 Stat. 1388–529","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43974113-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43974114-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id43974115-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Surface Mining Control and Reclamation Act of 1977, referred to in subsec. (d)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87"},"text":"Pub. L. 95–87","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/445"},"text":"91 Stat. 445","children":[],"tail":". Title V of that Act is classified