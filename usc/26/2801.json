{"tag":"section","attrib":{"id":"id455062c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801"},"text":null,"children":[{"tag":"num","attrib":{"value":"2801"},"text":"§ 2801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id455062c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, during any calendar year, any United States citizen or resident receives any covered gift or bequest, there is hereby imposed a tax equal to the product of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id455062c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the highest rate of tax specified in the table contained in section 2001(c) as in effect on the date of such receipt, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id455062c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of such covered gift or bequest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id455062ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax to be paid by recipient","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by subsection (a) on any covered gift or bequest shall be paid by the person receiving such gift or bequest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id455062cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain gifts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall apply only to the extent that the value of covered gifts and bequests received by any person during the calendar year exceeds the dollar amount in effect under section 2503(b) for such calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id455062cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax reduced by foreign gift or estate tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by subsection (a) on any covered gift or bequest shall be reduced by the amount of any gift or estate tax paid to a foreign country with respect to such covered gift or bequest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id455062cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered gift or bequest","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id455062ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the term “covered gift or bequest” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id455062cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property acquired by gift directly or indirectly from an individual who, at the time of such acquisition, is a covered expatriate, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id455062d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property acquired directly or indirectly by reason of the death of an individual who, immediately before such death, was a covered expatriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id455062d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions for transfers otherwise subject to estate or gift tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such term shall not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id455062d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property shown on a timely filed return of tax imposed by chapter 12 which is a taxable gift by the covered expatriate, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id455062d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property included in the gross estate of the covered expatriate for purposes of chapter 11 and shown on a timely filed return of tax imposed by chapter 11 of the estate of the covered expatriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id455062d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions for transfers to spouse or charity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such term shall not include any property with respect to which a deduction would be allowed under section 2055, 2056, 2522, or 2523, whichever is appropriate, if the decedent or donor were a United States person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id455062d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers in trust","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id455062d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic trusts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a covered gift or bequest made to a domestic trust—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id455062d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/e/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a) shall apply in the same manner as if such trust were a United States citizen, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id455062d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/e/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax imposed by subsection (a) on such gift or bequest shall be paid by such trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id455062d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign trusts","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id455062da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/e/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a covered gift or bequest made to a foreign trust, subsection (a) shall apply to any distribution attributable to such gift or bequest from such trust (whether from income or corpus) to a United States citizen or resident in the same manner as if such distribution were a covered gift or bequest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id455062db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/e/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deduction for tax paid by recipient","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be allowed as a deduction under section 164 the amount of tax imposed by this section which is paid or accrued by a United States citizen or resident by reason of a distribution from a foreign trust, but only to the extent such tax is imposed on the portion of such distribution which is included in the gross income of such citizen or resident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id455062dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/e/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to be treated as domestic trust","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Solely for purposes of this section, a foreign trust may elect to be treated as a domestic trust. Such an election may be revoked with the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id455062dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2801/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered expatriate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “covered expatriate” has the meaning given to such term by section 877A(g)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id455062de-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/245/tIII/s301/b/1"},"text":"Pub. L. 110–245, title III, § 301(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-17"},"text":"June 17, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1644"},"text":"122 Stat. 1644","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s206/b/1"},"text":"Pub. L. 113–295, div. A, title II, § 206(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4027"},"text":"128 Stat. 4027","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id455062df-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id455062e0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id455062e1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" struck out “(or, if greater, the highest rate of tax specified in the table applicable under section 2502(a) as in effect on the date)” after “such receipt”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id455062e2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id455062e3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" effective as if included in the provisions of the Tax Relief, Unemployment Insurance Reauthorization, and Job Creation Act of 2010, "},{"tag":"ref","attrib":{"href":"/us/pl/111/312"},"text":"Pub. L. 111–312","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s206/d"},"text":"section 206(d) of Pub. L. 113–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s32"},"text":"section 32 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id455062e4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/245/tIII/s301/g"},"text":"Pub. L. 110–245, title III, § 301(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-17"},"text":"June 17, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1647"},"text":"122 Stat. 1647","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/245/tIII/s301/g"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in this subsection, the amendments made by this section [enacting this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s877A"},"text":"section 877A of this title","children":[],"tail":" and amending sections 877, 6039G, and 7701 of this title] shall apply to any individual whose expatriation date (as so defined) is on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2008-06-17"},"text":"June 17, 2008","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Gifts and bequests","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Chapter 15 of the Internal Revenue Code of 1986 (as added by subsection (b)) shall apply to covered gifts and bequests (as defined in section 2801 of such Code, as so added) received on or after the date of the enactment of this Act from transferors (or from the estates of transferors) whose expatriation date is on or after such date of enactment.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
