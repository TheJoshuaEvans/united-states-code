{"tag":"section","attrib":{"id":"id422cdb47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217"},"text":null,"children":[{"tag":"num","attrib":{"value":"217"},"text":"§ 217.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Moving expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id422cdb48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deduction allowed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be allowed as a deduction moving expenses paid or incurred during the taxable year in connection with the commencement of work by the taxpayer as an employee or as a self-employed individual at a new principal place of work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id422cdb49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of moving expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id422cdb4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “moving expenses” means only the reasonable expenses—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id422cdb4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of moving household goods and personal effects from the former residence to the new residence, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id422cdb4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of traveling (including lodging) from the former residence to the new place of residence.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term shall not include any expenses for meals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id422cdb4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals other than taxpayer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any individual other than the taxpayer, expenses referred to in paragraph (1) shall be taken into account only if such individual has both the former residence and the new residence as his principal place of abode and is a member of the taxpayer’s household.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id422cdb4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for allowance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No deduction shall be allowed under this section unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id422cdb4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the taxpayer’s new principal place of work—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id422cdb50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at least 50 miles farther from his former residence than was his former principal place of work, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id422cdb51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if he had no former principal place of work, is at least 50 miles from his former residence, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id422cdb52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id422cdb53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the 12-month period immediately following his arrival in the general location of his new principal place of work, the taxpayer is a full-time employee, in such general location, during at least 39 weeks, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id422cdb54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the 24-month period immediately following his arrival in the general location of his new principal place of work, the taxpayer is a full-time employee or performs services as a self-employed individual on a full-time basis, in such general location, during at least 78 weeks, of which not less than 39 weeks are during the 12-month period referred to in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of paragraph (1), the distance between two points shall be the shortest of the more commonly traveled routes between such two points.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id422cdb55-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules for application of subsection (c)(2)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id422cdb56-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The condition of subsection (c)(2) shall not apply if the taxpayer is unable to satisfy such condition by reason of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id422cdb57-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" death or disability, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id422cdb58-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involuntary separation (other than for willful misconduct) from the service of, or transfer for the benefit of, an employer after obtaining full-time employment in which the taxpayer could reasonably have been expected to satisfy such condition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id422cdb59-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a taxpayer has not satisfied the condition of subsection (c)(2) before the time prescribed by law (including extensions thereof) for filing the return for the taxable year during which he paid or incurred moving expenses which would otherwise be deductible under this section, but may still satisfy such condition, then such expenses may (at the election of the taxpayer) be deducted for such taxable year notwithstanding subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id422cdb5a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id422cdb5b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any taxable year moving expenses have been deducted in accordance with the rule provided in paragraph (2), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id422cdb5c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the condition of subsection (c)(2) cannot be satisfied at the close of a subsequent taxable year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then an amount equal to the expenses which were so deducted shall be included in gross income for the first such subsequent taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id422f254d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"[(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13213/a/2/A"},"text":"Pub. L. 103–66, title XIII, § 13213(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/473"},"text":"107 Stat. 473","children":[],"tail":"]"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id422f254e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Self-employed individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “self-employed individual” means an individual who performs personal services—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id422f254f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as the owner of the entire interest in an unincorporated trade or business, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id422f2550-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a partner in a partnership carrying on a trade or business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id422f2551-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules for members of the Armed Forces of the United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a member of the Armed Forces of the United States on active duty who moves pursuant to a military order and incident to a permanent change of station—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id422f2552-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the limitations under subsection (c) shall not apply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id422f2553-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any moving and storage expenses which are furnished in kind (or for which reimbursement or an allowance is provided, but only to the extent of the expenses paid or incurred) to such member, his spouse, or his dependents, shall not be includible in gross income, and no reporting with respect to such expenses shall be required by the Secretary of Defense or the Secretary of Transportation, as the case may be; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id422f2554-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if moving and storage expenses are furnished in kind (or if reimbursement or an allowance for such expenses is provided) to such member’s spouse and his dependents with regard to moving to a location other than the one to which such member moves (or from a location other than the one from which such member moves), this section shall apply with respect to the moving expenses of his spouse and dependents—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id422f2555-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as if his spouse commenced work as an employee at a new principal place of work at such location; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id422f2556-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to the limitations under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id422f2557-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for foreign moves","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id422f2558-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of certain storage fees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a foreign move, for purposes of this section, the moving expenses described in subsection (b)(1)(A) include the reasonable expenses—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id422f2559-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of moving household goods and personal effects to and from storage, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id422f255a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of storing such goods and effects for part or all of the period during which the new place of work continues to be the taxpayer’s principal place of work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id422f255b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign move","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “foreign move” means the commencement of work by the taxpayer at a new principal place of work located outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id422f255c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection and subsection (i), the term “United States” includes the possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id422f255d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of deductions in case of retirees or decedents who were working abroad","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id422f255e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any qualified retiree moving expenses or qualified survivor moving expenses—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id422f255f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section (other than subsection (h)) shall be applied with respect to such expenses as if they were incurred in connection with the commencement of work by the taxpayer as an employee at a new principal place of work located within the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id422f2560-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the limitations of subsection (c)(2) shall not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id422f2561-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified retiree moving expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the term “qualified retiree moving expenses” means any moving expenses—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id422f2562-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are incurred by an individual whose former principal place of work and former residence were outside the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id422f2563-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are incurred for a move to a new residence in the United States in connection with the bona fide retirement of the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id422f2564-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified survivor moving expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the term “qualified survivor moving expenses” means moving expenses—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id422f2565-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are paid or incurred by the spouse or any dependent of any decedent who (as of the time of his death) had a principal place of work outside the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id422f2566-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are incurred for a move which begins within 6 months after the death of such decedent and which is to a residence in the United States from a former residence outside the United States which (as of the time of the decedent’s death) was the residence of such decedent and the individual paying or incurring the expense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id422f2567-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id422f2568-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of deduction for taxable years beginning after 2017","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id422f2569-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except in the case of an individual to whom subsection (g) applies, this section shall not apply to any taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id422f256a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s217/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of the intelligence community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employee or new appointee of the intelligence community (as defined in section 3 of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"50 U.S.C. 3003","children":[],"tail":")) (other than a member of the Armed Forces of the United States) who moves pursuant to a change in assignment which requires relocation shall be treated for purposes of this section in the same manner as an individual to whom subsection (g) applies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id422f256b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s213/a/1"},"text":"Pub. L. 88–272, title II, § 213(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/50"},"text":"78 Stat. 50","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tII/s231/a"},"text":"Pub. L. 91–172, title II, § 231(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/577"},"text":"83 Stat. 577","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tV/s506"},"text":"Pub. L. 94–455, title V, § 506","children":[],"tail":" (a)–(c), title XIX, § 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1568"},"text":"90 Stat. 1568","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/95/615/tII/s204"},"text":"Pub. L. 95–615, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-08"},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3106"},"text":"92 Stat. 3106","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13213/a/1"},"text":"Pub. L. 103–66, title XIII, § 13213(a)(1)","children":[],"tail":"–(2)(D), (b), "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/473"},"text":"107 Stat. 473","children":[],"tail":", 474; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s11049/a"},"text":"Pub. L. 115–97, title I, § 11049(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2088"},"text":"131 Stat. 2088","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70113/a"},"text":"Pub. L. 119–21, title VII, § 70113(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/165"},"text":"139 Stat. 165","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id422f256c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id422f256d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id422f256e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 217 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s226"},"text":"section 226 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id422f256f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70113/b"},"text":"Pub. L. 119–21, § 70113(b)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70113/a"},"text":"Pub. L. 119–21, § 70113(a)","children":[],"tail":", substituted “beginning after 2017” for “2018 through 2025” in heading and struck out “, and before "},{"tag":"date","attrib":{"date":"2026-01-01"},"text":"January 1, 2026","children":[],"tail":"” after “"},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":"” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" added subsec. (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13213/a/1"},"text":"Pub. L. 103–66, § 13213(a)(1)","children":[],"tail":", amended subsec. (b) generally, restating former par. (1)(A) and (B) as par. (1) and former par. (3)(C) as par. (2) and striking out former par. (1)(C) to (E) which included certain traveling, meals, lodging, and residence sale, purchase, and lease expenses in the term “moving expenses”, par. (2) which defined “qualified residence sale, purchase, or lease expenses”, and par. (3)(A) and (B) which placed dollar limits on the amount allowed to be deducted as moving expenses."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13213/b"},"text":"Pub. L. 103–66, § 13213(b)","children":[],"tail":", substituted “50 miles” for “35 miles” in subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13213/a/2/A"},"text":"Pub. L. 103–66, § 13213(a)(2)(A)","children":[],"tail":", struck out heading and text of subsec. (e). Text read as follows: “The amount realized on the sale of the residence described in subparagraph (A) of subsection (b)(2) shall not be decreased by the amount of any expenses described in such subparagraph which are allowed as a deduction under subsection (a), and the basis of a residence described in subparagraph (B) of subsection (b)(2) shall not be increased by the amount of any expenses described in such subparagraph which are allowed as a deduction under subsection (a). This subsection shall not apply to any expenses with respect to which an amount is included in gross income under subsection (d)(3).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13213/a/2/B"},"text":"Pub. L. 103–66, § 13213(a)(2)(B)","children":[],"tail":", amended heading and text of subsec. (f) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—For purposes of this section, the term ‘self-employed individual’ means an individual who performs personal services—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) as the owner of the entire interest in an unincorporated trade or business, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) as a partner in a partnership carrying on a trade or business.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Rule for application of subsections","children":[],"tail":" (b)(1)"},{"tag":"inline","attrib":{},"text":"(c) and (d)","children":[],"tail":".—For purposes of subparagraphs (C) and (D) of subsection (b)(1), an individual who commences work at a new principal place of work as a self-employed individual shall be treated as having obtained employment when he has made substantial arrangements to commence such work.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13213/a/2/C"},"text":"Pub. L. 103–66, § 13213(a)(2)(C)","children":[],"tail":", inserted “and” at end of subpar. (A), redesignated subpar. (C) as (B), and struck out former subpar. (B) which read as follows: “for purposes of subsection (b)(3), as if such place of work was within the same general location as the member’s new principal place of work, and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13213/a/2/D"},"text":"Pub. L. 103–66, § 13213(a)(2)(D)","children":[],"tail":", redesignated pars. (2) to (4) as (1) to (3), respectively, and struck out heading and text of former par. (1). Text read as follows: “In the case of a foreign move—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) subsection (b)(1)(D) shall be applied by substituting ‘90 consecutive days’ for ‘30 consecutive days’,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) subsection (b)(3)(A) shall be applied by substituting ‘$4,500’ for ‘$1,500’ and by substituting ‘$6,000’ for ‘$3,000’, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) subsection (b)(3)(B) shall be applied as if the last sentence of such subsection read as follows: ‘In the case of a husband and wife filing separate returns, subparagraph (A) shall be applied by substituting “$2,250” for “$4,500”, and by substituting “$3,000” for “$6,000”.’ ”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsecs. (h) to (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/615"},"text":"Pub. L. 95–615","children":[],"tail":" added subsecs. (h) and (i) and redesignated former subsec. (h) as (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s506/b/1"},"text":"Pub. L. 94–455, § 506(b)(1)","children":[],"tail":", (2), substituted “$1,500” for “$1,000” after “(1) shall not exceed” and “$3,000” for “$2,500” after “lease expenses shall not exceed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s506/b/3"},"text":"Pub. L. 94–455, § 506(b)(3)","children":[],"tail":", substituted “ ‘$750’ for ‘$1,500’ ” for “ ‘$500’ for ‘$1,000’ ” after “applied by substituting” and “ ‘$1,500’ for ‘$3,000’ ” for “ ‘$1,250’ for ‘$2,500’ ” after “and by substituting”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s506/a"},"text":"Pub. L. 94–455, § 506(a)","children":[],"tail":", substituted “35” for “50” after “at least”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 506(c), 1906(b)(13)(A), added subsec. (g), redesignated former subsec. (g) as (h) and struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" substantially reenacted existing provisions and extended the coverage to self-employed persons working at the new location for 78 weeks, made it a requirement that the new principal place of work be located 50 miles from the former residence, and redefined the deduction to include costs of house-hunting trips, temporary living expenses prior to locating a new home, and expenses of selling an old home or buying a new one."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id422f2570-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id422f2571-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2025-12-31"},"text":"Dec. 31, 2025","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70113/e"},"text":"section 70113(e) of Pub. L. 119–21","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s132"},"text":"section 132 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id422f2572-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s11049/b"},"text":"Pub. L. 115–97, title I, § 11049(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2089"},"text":"131 Stat. 2089","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/97/tI/s11049/b"},"text":"“The amendment made by this section [amending this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id422f2573-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" applicable to expenses incurred after "},{"tag":"date","attrib":{"date":"1993-12-31"},"text":"Dec. 31, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13213/e"},"text":"section 13213(e) of Pub. L. 103–66","children":[],"tail":" set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s62"},"text":"section 62 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id422f2574-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment; Election of Prior Law","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/615"},"text":"Pub. L. 95–615","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1977-12-31"},"text":"Dec. 31, 1977","children":[],"tail":", with provision for election of prior law, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/615/s209"},"text":"section 209 of Pub. L. 95–615","children":[],"tail":", set out as an Effective Date of 1978 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s911"},"text":"section 911 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id422f2575-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tV/s506/d"},"text":"Pub. L. 94–455, title V, § 506(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1569"},"text":"90 Stat. 1569","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/455/tV/s506/d"},"text":"“The amendments made by subsections (a) and (b) [amending this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id422f2576-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1969 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tII/s231/d"},"text":"Pub. L. 91–172, title II, § 231(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/580"},"text":"83 Stat. 580","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/91/642/s2"},"text":"Pub. L. 91–642, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1880"},"text":"84 Stat. 1880","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s82"},"text":"section 82 of this title","children":[],"tail":" and amending this section and sections 1001 and 1016 of this title] shall apply to taxable years beginning after "},{"tag":"date","attrib":{"date":"1969-12-31"},"text":"December 31, 1969","children":[],"tail":", except that—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 217 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] (as amended by subsection (a)) shall not apply to any item to the extent that the taxpayer received or accrued reimbursement or other expense allowance for such item in a taxable year beginning on or before ","children":[{"tag":"date","attrib":{"date":"1969-12-31"},"text":"December 31, 1969","children":[],"tail":", which was not included in his gross income; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amendments made by this section shall not apply (at the election of the taxpayer made at such time and manner as the Secretary of the Treasury or his delegate prescribes) with respect to moving expenses paid or incurred before ","children":[{"tag":"date","attrib":{"date":"1971-01-01"},"text":"January 1, 1971","children":[],"tail":", in connection with the commencement of work by the taxpayer as an employee at a new principal place of work of which the taxpayer had been notified by his employer on or before "},{"tag":"date","attrib":{"date":"1969-12-19"},"text":"December 19, 1969","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id422f2577-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to expenses incurred after ","children":[{"tag":"date","attrib":{"date":"1963-12-31"},"text":"Dec. 31, 1963","children":[],"tail":", in taxable years ending after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/88/272/s213/d"},"text":"section 213(d) of Pub. L. 88–272","children":[],"tail":", set out as an Effective Date of 1964 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s62"},"text":"section 62 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id422f2578-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Moving Expenses of Members of the Uniformed Services","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/490/s2"},"text":"Pub. L. 93–490, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-26"},"text":"Oct. 26, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1466"},"text":"88 Stat. 1466","children":[],"tail":", authorized the Secretary of the Treasury, applicable with respect to taxable years ending before "},{"tag":"date","attrib":{"date":"1976-01-01"},"text":"January 1, 1976","children":[],"tail":", to:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(1) enter into an agreement with the Secretary concerned under which the Secretary concerned would not be required to withhold tax on, or to report, moving expense reimbursements made to members of the armed forces;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(2) permit any taxpayer who was a member of the armed forces not to include in adjusted gross income the amount of any reimbursement in kind of moving expenses made by the Secretary concerned; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(3) permit any taxpayer who was a member of the armed forces to deduct any amount paid by him as moving expenses in connection with any move required by the Secretary concerned, in excess of any reimbursement received for such expenses, without regard to the provisions of subsec. (c) of this section, to the extent it was otherwise deductible under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
