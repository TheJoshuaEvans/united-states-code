{"tag":"section","attrib":{"id":"id46818fd7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y"},"text":null,"children":[{"tag":"num","attrib":{"value":"6050Y"},"text":"§ 6050Y.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns relating to certain life insurance contract transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46818fd8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of reporting of certain payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46818fd9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every person who acquires a life insurance contract or any interest in a life insurance contract in a reportable policy sale during any taxable year shall make a return for such taxable year (at such time and in such manner as the Secretary shall prescribe) setting forth—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46818fda-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and TIN of such person,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46818fdb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and TIN of each recipient of payment in the reportable policy sale,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46818fdc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of such sale,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46818fdd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the issuer of the life insurance contract sold and the policy number of such contract, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46818fde-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of each payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46818fdf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement to be furnished to persons with respect to whom information is required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every person required to make a return under this subsection shall furnish to each person whose name is required to be set forth in such return a written statement showing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46818fe0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and phone number of the information contact of the person required to make such return, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46818fe1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information required to be shown on such return with respect to such person, except that in the case of an issuer of a life insurance contract, such statement is not required to include the information specified in paragraph (1)(E).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46818fe2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of reporting of seller’s basis in life insurance contracts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46818fe3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon receipt of the statement required under subsection (a)(2) or upon notice of a transfer of a life insurance contract to a foreign person, each issuer of a life insurance contract shall make a return (at such time and in such manner as the Secretary shall prescribe) setting forth—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46818fe4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and TIN of the seller who transfers any interest in such contract in such sale,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46818fe5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the investment in the contract (as defined in section 72(e)(6)) with respect to such seller, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46818fe6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the policy number of such contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46818fe7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement to be furnished to persons with respect to whom information is required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every person required to make a return under this subsection shall furnish to each person whose name is required to be set forth in such return a written statement showing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46818fe8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and phone number of the information contact of the person required to make such return, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46818fe9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information required to be shown on such return with respect to each seller whose name is required to be set forth in such return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46818fea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of reporting with respect to reportable death benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46818feb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every person who makes a payment of reportable death benefits during any taxable year shall make a return for such taxable year (at such time and in such manner as the Secretary shall prescribe) setting forth—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46818fec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and TIN of the person making such payment,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46818fed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and TIN of each recipient of such payment,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46818fee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of each such payment,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46818fef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross amount of each such payment, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46818ff0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person’s estimate of the investment in the contract (as defined in section 72(e)(6)) with respect to the buyer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46818ff1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement to be furnished to persons with respect to whom information is required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every person required to make a return under this subsection shall furnish to each person whose name is required to be set forth in such return a written statement showing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46818ff2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and phone number of the information contact of the person required to make such return, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46818ff3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information required to be shown on such return with respect to each recipient of payment whose name is required to be set forth in such return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46818ff4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46818ff5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “payment” means, with respect to any reportable policy sale, the amount of cash and the fair market value of any consideration transferred in the sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46818ff6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reportable policy sale","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “reportable policy sale” has the meaning given such term in section 101(a)(3)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46818ff7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “issuer” means any life insurance company that bears the risk with respect to a life insurance contract on the date any return or statement is required to be made under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46818ff8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Y/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reportable death benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “reportable death benefits” means amounts paid by reason of the death of the insured under a life insurance contract that has been transferred in a reportable policy sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46818ff9-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13520/a"},"text":"Pub. L. 115–97, title I, § 13520(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2149"},"text":"131 Stat. 2149","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46818ffa-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46818ffb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46818ffc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to reportable policy sales (as defined in subsection (d)(2) of this section) after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", and reportable death benefits (as defined in subsection (d)(4) of this section) paid after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13520/d"},"text":"section 13520(d) of Pub. L. 115–97","children":[],"tail":", set out as an Effective Date of 2017 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6047"},"text":"section 6047 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
