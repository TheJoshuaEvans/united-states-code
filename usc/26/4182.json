{"tag":"section","attrib":{"id":"id45c062af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4182"},"text":null,"children":[{"tag":"num","attrib":{"value":"4182"},"text":"§ 4182.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45c062b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4182/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Machine guns and short barrelled firearms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by section 4181 shall not apply to any firearm on which the tax provided by section 5811 has been paid. For purposes of the preceding sentence, any firearm described in section 5811(a)(2) shall be deemed to be a firearm on which the tax provided by section 5811 has been paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45c062b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4182/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sales to defense department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No firearms, pistols, revolvers, shells, and cartridges purchased with funds appropriated for the military department shall be subject to any tax imposed on the sale or transfer of such articles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45c062b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4182/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small manufacturers, etc.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45c062b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4182/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by section 4181 shall not apply to any pistol, revolver, or firearm described in such section if manufactured, produced, or imported by a person who manufactures, produces, and imports less than an aggregate of 50 of such articles during the calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45c062b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4182/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All persons treated as a single employer for purposes of subsection (a) or (b) of section 52 shall be treated as one person for purposes of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45c062b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4182/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of sections 922(b)(5) and 923(g) of title 18, United States Code, no person holding a Federal license under chapter 44 of title 18, United States Code, shall be required to record the name, address, or other information about the purchaser of shotgun ammunition, ammunition suitable for use only in rifles generally available in commerce, or component parts for the aforesaid types of ammunition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45c062b6-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/490"},"text":"68A Stat. 490","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/128/s5"},"text":"Pub. L. 91–128, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-11-26"},"text":"Nov. 26, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/269"},"text":"83 Stat. 269","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11131/a"},"text":"Pub. L. 109–59, title XI, § 11131(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1959"},"text":"119 Stat. 1959","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70436/c"},"text":"Pub. L. 119–21, title VII, § 70436(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/247"},"text":"139 Stat. 247","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45c062b7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45c062b8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45c062b9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" inserted at end “For purposes of the preceding sentence, any firearm described in section 5811(a)(2) shall be deemed to be a firearm on which the tax provided by section 5811 has been paid.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/128"},"text":"Pub. L. 91–128","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45c062ba-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45c062bb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70436/d"},"text":"Pub. L. 119–21, title VII, § 70436(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/248"},"text":"139 Stat. 248","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70436/d"},"text":"“The amendments made by this section [amending this section and sections 5811 and 5821 of this title] shall apply to calendar quarters beginning more than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45c062bc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11131/b"},"text":"Pub. L. 109–59, title XI, § 11131(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1959"},"text":"119 Stat. 1959","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/59/tXI/s11131/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section] shall apply to articles sold by the manufacturer, producer, or importer after ","children":[{"tag":"date","attrib":{"date":"2005-09-30"},"text":"September 30, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No inference","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in the amendments made by this section shall be construed to create any inference with respect to the proper tax treatment of any sales before the effective date of such amendments.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id45c062bd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1969 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/128/s1/a"},"text":"Pub. L. 91–128, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-11-26"},"text":"Nov. 26, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/261"},"text":"83 Stat. 261","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/128/s1/a"},"text":"“This Act [amending this section and sections 4911, 4912, 4914, 4915, 4919, 4920, 6011, and 6680 of this title and enacting provisions set out as notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6680"},"text":"section 6680 of this title","children":[],"tail":"] may be cited as the ‘Interest Equalization Tax Extension Act of 1969’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
