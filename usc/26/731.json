{"tag":"section","attrib":{"id":"id44003c31-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731"},"text":null,"children":[{"tag":"num","attrib":{"value":"731"},"text":"§ 731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extent of recognition of gain or loss on distribution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44003c32-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partners","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a distribution by a partnership to a partner—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44003c33-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gain shall not be recognized to such partner, except to the extent that any money distributed exceeds the adjusted basis of such partner’s interest in the partnership immediately before the distribution, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44003c34-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" loss shall not be recognized to such partner, except that upon a distribution in liquidation of a partner’s interest in a partnership where no property other than that described in subparagraph (A) or (B) is distributed to such partner, loss shall be recognized to the extent of the excess of the adjusted basis of such partner’s interest in the partnership over the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44003c35-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any money distributed, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44003c36-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis to the distributee, as determined under section 732, of any unrealized receivables (as defined in section 751(c)) and inventory (as defined in section 751(d)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any gain or loss recognized under this subsection shall be considered as gain or loss from the sale or exchange of the partnership interest of the distributee partner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44003c37-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No gain or loss shall be recognized to a partnership on a distribution to a partner of property, including money.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44003c38-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of marketable securities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44003c39-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)(1) and section 737—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44003c3a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “money” includes marketable securities, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44003c3b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such securities shall be taken into account at their fair market value as of the date of the distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44003c3c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marketable securities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44003c3d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “marketable securities” means financial instruments and foreign currencies which are, as of the date of the distribution, actively traded (within the meaning of section 1092(d)(1)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44003c3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such term includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44003c3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any interest in—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id44003c40-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a common trust fund, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44003c41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regulated investment company which is offering for sale or has outstanding any redeemable security (as defined in section 2(a)(32) of the Investment Company Act of 1940) of which it is the issuer,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44003c42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any financial instrument which, pursuant to its terms or any other arrangement, is readily convertible into, or exchangeable for, money or marketable securities,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44003c43-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any financial instrument the value of which is determined substantially by reference to marketable securities,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44003c44-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except to the extent provided in regulations prescribed by the Secretary, any interest in a precious metal which, as of the date of the distribution, is actively traded (within the meaning of section 1092(d)(1)) unless such metal was produced, used, or held in the active conduct of a trade or business by the partnership,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44003c45-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as otherwise provided in regulations prescribed by the Secretary, interests in any entity if substantially all of the assets of such entity consist (directly or indirectly) of marketable securities, money, or both, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44003c46-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent provided in regulations prescribed by the Secretary, any interest in an entity not described in clause (v) but only to the extent of the value of such interest which is attributable to marketable securities, money, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44003c47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial instrument","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial instrument” includes stocks and other equity interests, evidences of indebtedness, options, forward or futures contracts, notional principal contracts, and derivatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44003c48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44003c49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to the distribution from a partnership of a marketable security to a partner if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44003c4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the security was contributed to the partnership by such partner, except to the extent that the value of the distributed security is attributable to marketable securities or money contributed (directly or indirectly) to the entity to which the distributed security relates,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44003c4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent provided in regulations prescribed by the Secretary, the property was not a marketable security when acquired by such partnership, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44003c4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such partnership is an investment partnership and such partner is an eligible partner thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44003c4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on gain recognized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a distribution of marketable securities to a partner, the amount taken into account under paragraph (1) shall be reduced (but not below zero) by the excess (if any) of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44003c4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such partner’s distributive share of the net gain which would be recognized if all of the marketable securities of the same class and issuer as the distributed securities held by the partnership were sold (immediately before the transaction to which the distribution relates) by the partnership for fair market value, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44003c4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such partner’s distributive share of the net gain which is attributable to the marketable securities of the same class and issuer as the distributed securities held by the partnership immediately after the transaction, determined by using the same fair market value as used under clause (i).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Under regulations prescribed by the Secretary, all marketable securities held by the partnership may be treated as marketable securities of the same class and issuer as the distributed securities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44003c50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions relating to investment partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A)(iii):","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44003c51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment partnership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “investment partnership” means any partnership which has never been engaged in a trade or business and substantially all of the assets (by value) of which have always consisted of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id44003c52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" money,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44003c53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stock in a corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44003c54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notes, bonds, debentures, or other evidences of indebtedness,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44003c55-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/C/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest rate, currency, or equity notional principal contracts,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44003c56-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/C/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign currencies,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44003c57-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/C/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interests in or derivative financial instruments (including options, forward or futures contracts, short positions, and similar financial instruments) in any asset described in any other subclause of this clause or in any commodity traded on or subject to the rules of a board of trade or commodity exchange,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44003c58-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/C/i/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other assets specified in regulations prescribed by the Secretary, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44003c59-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/C/i/VIII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VIII"},"text":"(VIII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of the foregoing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44003c5a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A partnership shall not be treated as engaged in a trade or business by reason of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id44003c5b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity undertaken as an investor, trader, or dealer in any asset described in clause (i), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44003c5c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activity specified in regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44003c5d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible partner","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id44003c5e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible partner” means any partner who, before the date of the distribution, did not contribute to the partnership any property other than assets described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44003c5f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain nonrecognition transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible partner” shall not include the transferor or transferee in a nonrecognition transaction involving a transfer of any portion of an interest in a partnership with respect to which the transferor was not an eligible partner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44003c60-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Look-thru of partnership tiers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in regulations prescribed by the Secretary—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id44003c61-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/C/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership shall be treated as engaged in any trade or business engaged in by, and as holding (instead of a partnership interest) a proportionate share of the assets of, any other partnership in which the partnership holds a partnership interest, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44003c62-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/3/C/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partner who contributes to a partnership an interest in another partnership shall be treated as contributing a proportionate share of the assets of the other partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" If the preceding sentence does not apply under such regulations with respect to any interest held by a partnership in another partnership, the interest in such other partnership shall be treated as if it were specified in a subclause of clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44003c63-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis of securities distributed","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44003c64-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The basis of marketable securities with respect to which gain is recognized by reason of this subsection shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44003c65-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" their basis determined under section 732, increased by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44003c66-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such gain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44003c67-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of basis increase","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any increase in basis attributable to the gain described in subparagraph (A)(ii) shall be allocated to marketable securities in proportion to their respective amounts of unrealized appreciation before such increase.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44003c68-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsection disregarded in determining basis of partner’s interest in partnership and of basis of partnership property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sections 733 and 734 shall be applied as if no gain were recognized, and no adjustment were made to the basis of property, under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44003c69-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Character of gain recognized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a distribution of a marketable security which is an unrealized receivable (as defined in section 751(c)) or an inventory item (as defined in section 751(d)), any gain recognized under this subsection shall be treated as ordinary income to the extent of any increase in the basis of such security attributable to the gain described in paragraph (4)(A)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44003c6a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary or appropriate to carry out the purposes of this subsection, including regulations to prevent the avoidance of such purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44003c6b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s731/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to the extent otherwise provided by section 736 (relating to payments to a retiring partner or a deceased partner’s successor in interest), section 751 (relating to unrealized receivables and inventory items), and section 737 (relating to recognition of precontribution gain in case of certain distributions).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44003c6c-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/245"},"text":"68A Stat. 245","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s1937/b/2"},"text":"Pub. L. 102–486, title XIX, § 1937(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3033"},"text":"106 Stat. 3033","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tVII/s741/a"},"text":"Pub. L. 103–465, title VII, § 741(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/5006"},"text":"108 Stat. 5006","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1062/b/3"},"text":"Pub. L. 105–34, title X, § 1062(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/947"},"text":"111 Stat. 947","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44003c6d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44003c6e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id44003c6f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2(a)(32) of the Investment Company Act of 1940, referred to in subsec. (c)(2)(B)(i)(II), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–2/a/32"},"text":"section 80a–2(a)(32) of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44003c70-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsecs. (a)(2)(B), (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" substituted “section 751(d)” for “section 751(d)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":" substituted “, section 751” for “and section 751” and inserted before period at end “, and section 737 (relating to recognition of precontribution gain in case of certain distributions)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44003c71-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44003c72-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" applicable to sales, exchanges, and distributions after "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", but not applicable to any sale or exchange pursuant to a written binding contract in effect on "},{"tag":"date","attrib":{"date":"1997-06-08"},"text":"June 8, 1997","children":[],"tail":", and at all times thereafter before such sale or exchange, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1062/c"},"text":"section 1062(c) of Pub. L. 105–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s724"},"text":"section 724 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44003c73-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tVII/s741/c"},"text":"Pub. L. 103–465, title VII, § 741(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/5009"},"text":"108 Stat. 5009","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/465/tVII/s741/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this subsection, the amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s737"},"text":"section 737 of this title","children":[],"tail":"] shall apply to distributions after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain distributions before ","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"january 1, 1995","children":[],"tail":null}],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section shall not apply to any marketable security distributed before ","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"January 1, 1995","children":[],"tail":", by the partnership which held such security on "},{"tag":"date","attrib":{"date":"1994-07-27"},"text":"July 27, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distributions in liquidation of partner’s interest","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amendments made by this section shall not apply to the distribution of a marketable security in liquidation of a partner’s interest in a partnership if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such liquidation is pursuant to a written contract which was binding on ","children":[{"tag":"date","attrib":{"date":"1994-07-15"},"text":"July 15, 1994","children":[],"tail":", and at all times thereafter before the distribution, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such contract provides for the purchase of such interest not later than a date certain for—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fixed value of marketable securities that are specified in the contract, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The preceding sentence shall not apply if the partner has the right to elect that such distribution be made other than in marketable securities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distributions in complete liquidation of publicly traded partnerships.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amendments made by this section shall not apply to the distribution of a marketable security in a qualified partnership liquidation if—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the marketable securities were received by the partnership in a nonrecognition transaction in exchange for substantially all of the assets of the partnership,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the marketable securities are distributed by the partnership within 90 days after their receipt by the partnership, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the partnership is liquidated before the beginning of the 1st taxable year of the partnership beginning after ","children":[{"tag":"date","attrib":{"date":"1997-12-31"},"text":"December 31, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified partnership liquidation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the term ‘qualified partnership liquidation’ means—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a complete liquidation of a publicly traded partnership (as defined in section 7704(b) of the Internal Revenue Code of 1986) which is an existing partnership (as defined in section 10211(c)(2) of the Revenue Act of 1987 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7704"},"text":"section 7704 of this title","children":[],"tail":"]), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a complete liquidation of a partnership which is related to a partnership described in clause (i) if such liquidation is related to a complete liquidation of the partnership described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Marketable securities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this subsection, the term ‘marketable securities’ has the meaning given such term by section 731(c) of the Internal Revenue Code of 1986, as added by this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44028564-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":" applicable to distributions on or after "},{"tag":"date","attrib":{"date":"1992-06-25"},"text":"June 25, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/s1937/c"},"text":"section 1937(c) of Pub. L. 102–486","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s704"},"text":"section 704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
