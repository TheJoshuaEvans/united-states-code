{"tag":"section","attrib":{"id":"id471320cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6622"},"text":null,"children":[{"tag":"num","attrib":{"value":"6622"},"text":"§ 6622.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest compounded daily","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id471320d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6622/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In computing the amount of any interest required to be paid under this title or sections 1961(c)(1) or 2411 of title 28, United States Code, by the Secretary or by the taxpayer, or any other amount determined by reference to such amount of interest, such interest and such amount shall be compounded daily.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id471320d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6622/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for penalty for failure to file estimated tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply for purposes of computing the amount of any addition to tax under section 6654 or 6655.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id471320d2-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s344/a"},"text":"Pub. L. 97–248, title III, § 344(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/635"},"text":"96 Stat. 635","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id471320d3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id471320d4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id471320d5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s344/c"},"text":"Pub. L. 97–248, title III, § 344(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/636"},"text":"96 Stat. 636","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/248/tIII/s344/c"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6601"},"text":"section 6601 of this title","children":[],"tail":"] shall apply to interest accruing after "},{"tag":"date","attrib":{"date":"1982-12-31"},"text":"December 31, 1982","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
