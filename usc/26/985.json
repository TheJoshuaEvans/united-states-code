{"tag":"section","attrib":{"id":"id4493f078-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s985"},"text":null,"children":[{"tag":"num","attrib":{"value":"985"},"text":"§ 985.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functional currency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4493f079-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s985/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless otherwise provided in regulations, all determinations under this subtitle shall be made in the taxpayer’s functional currency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4493f07a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s985/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functional currency","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4493f07b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s985/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subtitle, the term “functional currency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4493f07c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s985/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subparagraph (B), the dollar, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4493f07d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s985/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a qualified business unit, the currency of the economic environment in which a significant part of such unit’s activities are conducted and which is used by such unit in keeping its books and records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4493f07e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s985/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functional currency where activities primarily conducted in dollars","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The functional currency of any qualified business unit shall be the dollar if activities of such unit are primarily conducted in dollars.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4493f07f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s985/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent provided in regulations, the taxpayer may elect to use the dollar as the functional currency for any qualified business unit if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4493f080-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s985/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such unit keeps its books and records in dollars, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4493f081-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s985/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer uses a method of accounting that approximates a separate transactions method.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any such election shall apply to the taxable year for which made and all subsequent taxable years unless revoked with the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4493f082-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s985/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change in functional currency treated as a change in method of accounting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any change in the functional currency shall be treated as a change in the taxpayer’s method of accounting for purposes of section 481 under procedures to be established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4493f083-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1261/a"},"text":"Pub. L. 99–514, title XII, § 1261(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2585"},"text":"100 Stat. 2585","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4493f084-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4493f085-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4493f086-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1261/e"},"text":"Pub. L. 99–514, title XII, § 1261(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2591"},"text":"100 Stat. 2591","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXII/s1261/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the amendments made by this section [enacting this subpart and amending sections 1092 and 1256 of this title] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rules for purposes of sections 902 and 960","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of applying sections [former] 902 and 960 of the Internal Revenue Code of 1986, the amendments made by this section shall apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" earnings and profits of the foreign corporation for taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign taxes paid or accrued by the foreign corporation with respect to such earnings and profits.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
