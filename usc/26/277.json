{"tag":"section","attrib":{"id":"id42982026-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s277"},"text":null,"children":[{"tag":"num","attrib":{"value":"277"},"text":"§ 277.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deductions incurred by certain membership organizations in transactions with members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42982027-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s277/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a social club or other membership organization which is operated primarily to furnish services or goods to members and which is not exempt from taxation, deductions for the taxable year attributable to furnishing services, insurance, goods, or other items of value to members shall be allowed only to the extent of income derived during such year from members or transactions with members (including income derived during such year from institutes and trade shows which are primarily for the education of members). If for any taxable year such deductions exceed such income, the excess shall be treated as a deduction attributable to furnishing services, insurance, goods, or other items of value to members paid or incurred in the succeeding taxable year. The deductions provided by sections 243 and 245 (relating to dividends received by corporations) shall not be allowed to any organization to which this section applies for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42982028-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s277/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to any organization—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42982029-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s277/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which for the taxable year is subject to taxation under subchapter H or L,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4298202a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s277/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has made an election before ","children":[{"tag":"date","attrib":{"date":"1969-10-09"},"text":"October 9, 1969","children":[],"tail":", under section 456(c) or which is affiliated with such an organization,"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4298202b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s277/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which for each day of any taxable year is a national securities exchange subject to regulation under the Securities Exchange Act of 1934 or a contract market subject to regulation under the Commodity Exchange Act, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id429a6a1c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s277/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is engaged primarily in the gathering and distribution of news to its members for publication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id429a6a1d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tI/s121/b/3/A"},"text":"Pub. L. 91–172, title I, § 121(b)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/540"},"text":"83 Stat. 540","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/568/s1/c"},"text":"Pub. L. 94–568, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-20"},"text":"Oct. 20, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2697"},"text":"90 Stat. 2697","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVI/s1604/a"},"text":"Pub. L. 99–514, title XVI, § 1604(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2769"},"text":"100 Stat. 2769","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/41/G"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(41)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4044"},"text":"128 Stat. 4044","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id429a6a1e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id429a6a1f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id429a6a20-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{