{"tag":"section","attrib":{"id":"id464ac89b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5713"},"text":null,"children":[{"tag":"num","attrib":{"value":"5713"},"text":"§ 5713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id464ac89c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person shall not engage in business as a manufacturer or importer of tobacco products or processed tobacco or as an export warehouse proprietor without a permit to engage in such business. Such permit, conditioned upon compliance with this chapter and regulations issued thereunder, shall be issued in such form and in such manner as the Secretary shall by regulation prescribe, to every person properly qualified under sections 5711 and 5712. A new permit may be required at such other time as the Secretary shall by regulation prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464ac89d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or revocation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id464ac89e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5713/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Show cause hearing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary has reason to believe that any person holding a permit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id464ac89f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5713/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not in good faith complied with this chapter, or with any other provision of this title involving intent to defraud,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id464ac8a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5713/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has violated the conditions of such permit,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id464ac8a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5713/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has failed to disclose any material information required or made any material false statement in the application for such permit,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id464ac8a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5713/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has failed to maintain his premises in such manner as to protect the revenue,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id464ac8a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5713/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is, by reason of previous or current legal proceedings involving a felony violation of any other provision of Federal criminal law relating to tobacco products, processed tobacco, cigarette paper, or cigarette tubes, not likely to maintain operations in compliance with this chapter, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id464ac8a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5713/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been convicted of a felony violation of any provision of Federal or State criminal law relating to tobacco products, processed tobacco, cigarette paper, or cigarette tubes,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary shall issue an order, stating the facts charged, citing such person to show cause why his permit should not be suspended or revoked.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464ac8a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5713/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action following hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, after hearing, the Secretary finds that such person has not shown cause why his permit should not be suspended or revoked, such permit shall be suspended for such period as the Secretary deems proper or shall be revoked.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id464ac8a6-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/712"},"text":"68A Stat. 712","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s202"},"text":"Pub. L. 85–859, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1421"},"text":"72 Stat. 1421","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIX/s9302/h/2/A"},"text":"Pub. L. 105–33, title IX, § 9302(h)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/674"},"text":"111 Stat. 674","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/3/tVII/s702/a/1/B"},"text":"Pub. L. 111–3, title VII, § 702(a)(1)(B)","children":[],"tail":", (b)(2), "},{"tag":"date","attrib":{"date":"2009-02-04"},"text":"Feb. 4, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/108"},"text":"123 Stat. 108","children":[],"tail":", 109.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id464ac8a7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id464ac8a8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id464ac8a9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/3/s702/a/1/B"},"text":"Pub. L. 111–3, § 702(a)(1)(B)","children":[],"tail":", inserted “or processed tobacco” after “tobacco products”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/3/s702/b/2"},"text":"Pub. L. 111–3, § 702(b)(2)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, text read as follows: “If the Secretary has reason to believe that any person holding a permit has not in good faith complied with this chapter, or with any other provision of this title involving intent to defraud, or has violated the conditions of such permit, or has failed to disclose any material information required or made any material false statement in the application for such permit, or has failed to maintain his premises in such manner as to protect the revenue, the Secretary shall issue an order, stating the facts charged, citing such person to show cause why his permit should not be suspended or revoked. If, after hearing, the Secretary finds that such person has not in good faith complied with this chapter or with any other provision of this title involving intent to defraud, has violated the conditions of such permit, has failed to disclose any material information required or made any material false statement in the application therefor, or has failed to maintain his premises in such manner as to protect the revenue, such permit shall be suspended for such period as the Secretary deems proper or shall be revoked.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" inserted “or importer” after “manufacturer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" substituted “manufacturer of tobacco products” for “manufacturer of articles”, included export warehouse proprietors, and struck out provisions which related to dealers in tobacco materials."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" redesignated subsec. (c) as (b) and struck out former subsec. (b) that required permits to be posted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id464d119a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464d119b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/3/s702/b/2"},"text":"section 702(b)(2) of Pub. L. 111–3","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-02-04"},"text":"Feb. 4, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/3/s702/b/3"},"text":"section 702(b)(3) of Pub. L. 111–3","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5712"},"text":"section 5712 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/3/s702/a/1/B"},"text":"section 702(a)(1)(B) of Pub. L. 111–3","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-04-01"},"text":"Apr. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/3/s702/a/6"},"text":"section 702(a)(6) of Pub. L. 111–3","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5702"},"text":"section 5702 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464d119c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" applicable to articles removed, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5702/j"},"text":"section 5702(j) of this title","children":[],"tail":", after "},{"tag":"date","attrib":{"date":"1999-12-31"},"text":"Dec. 31, 1999","children":[],"tail":", with transition rule, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/s9302/i"},"text":"section 9302(i) of Pub. L. 105–33","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5701"},"text":"section 5701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464d119d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1958-09-03"},"text":"Sept. 3, 1958","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/s210/a/1"},"text":"section 210(a)(1) of Pub. L. 85–859","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"