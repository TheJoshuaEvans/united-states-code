{"tag":"section","attrib":{"id":"id464856e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702"},"text":null,"children":[{"tag":"num","attrib":{"value":"5702"},"text":"§ 5702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When used in this chapter—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id464856ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cigar","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“Cigar” means any roll of tobacco wrapped in leaf tobacco or in any substance containing tobacco (other than any roll of tobacco which is a cigarette within the meaning of subsection (b)(2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464856eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cigarette","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“Cigarette” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id464856ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any roll of tobacco wrapped in paper or in any substance not containing tobacco, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464856ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any roll of tobacco wrapped in any substance containing tobacco which, because of its appearance, the type of tobacco used in the filler, or its packaging and labeling, is likely to be offered to, or purchased by, consumers as a cigarette described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464856ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tobacco products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“Tobacco products” means cigars, cigarettes, smokeless tobacco, pipe tobacco, and roll-your-own tobacco.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464856ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturer of tobacco products","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“Manufacturer of tobacco products” means any person who manufactures cigars, cigarettes, smokeless tobacco, pipe tobacco, or roll-your-own tobacco, except that such term shall not include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id464856f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who produces cigars, cigarettes, smokeless tobacco, pipe tobacco, or roll-your-own tobacco solely for the person’s own personal consumption or use, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464856f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proprietor of a customs bonded manufacturing warehouse with respect to the operation of such warehouse.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term shall include any person who for commercial purposes makes available for consumer use (including such consumer’s personal consumption or use under paragraph (1)) a machine capable of making cigarettes, cigars, or other tobacco products. A person making such a machine available for consumer use shall be deemed the person making the removal as defined by subsection (j) with respect to any tobacco products manufactured by such machine. A person who sells a machine directly to a consumer at retail for a consumer’s personal home use is not making a machine available for commercial purposes if such machine is not used at a retail premises and is designed to produce tobacco products only in personal use quantities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464856f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cigarette paper","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“Cigarette paper” means paper, or any other material except tobacco, prepared for use as a cigarette wrapper.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464856f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cigarette tube","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“Cigarette tube” means cigarette paper made into a hollow cylinder for use in making cigarettes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464856f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturer of cigarette papers and tubes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“Manufacturer of cigarette papers and tubes” means any person who manufactures cigarette paper, or makes up cigarette paper into tubes, except for his own personal use or consumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464856f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export warehouse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“Export warehouse” means a bonded internal revenue warehouse for the storage of tobacco products or cigarette papers or tubes or any processed tobacco, upon which the internal revenue tax has not been paid, for subsequent shipment to a foreign country, Puerto Rico, the Virgin Islands, or a possession of the United States, or for consumption beyond the jurisdiction of the internal revenue laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464856f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export warehouse proprietor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“Export warehouse proprietor” means any person who operates an export warehouse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464856f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal or remove","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“Removal” or “remove” means the removal of tobacco products or cigarette papers or tubes, or any processed tobacco, from the factory or from internal revenue bond under section 5704, as the Secretary shall by regulation prescribe, or release from customs custody, and shall also include the smuggling or other unlawful importation of such articles into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464856f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“Importer” means any person in the United States to whom nontaxpaid tobacco products or cigarette papers or tubes, or any processed tobacco, manufactured in a foreign country, Puerto Rico, the Virgin Islands, or a possession of the United States are shipped or consigned; any person who removes cigars or cigarettes for sale or consumption in the United States from a customs bonded manufacturing warehouse; and any person who smuggles or otherwise unlawfully brings tobacco products or cigarette papers or tubes, or any processed tobacco, into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464856f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of price on cigars","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining price for purposes of section 5701(a)(2)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id464856fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there shall be included any charge incident to placing the article in condition ready for use,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464856fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" there shall be excluded—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id464856fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/l/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the tax imposed by this chapter or section 7652, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id464856fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/l/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if stated as a separate charge, the amount of any retail sales tax imposed by any State or political subdivision thereof or the District of Columbia, whether the liability for such tax is imposed on the vendor or vendee, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464856fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules similar to the rules of section 4216(b) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464856ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions relating to smokeless tobacco","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46485700-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/m/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Smokeless tobacco","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “smokeless tobacco” means any snuff or chewing tobacco.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46485701-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/m/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Snuff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “snuff” means any finely cut, ground, or powdered tobacco that is not intended to be smoked.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46485702-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/m/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chewing tobacco","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “chewing tobacco” means any leaf tobacco that is not intended to be smoked.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46485703-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pipe tobacco","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “pipe tobacco” means any tobacco which, because of its appearance, type, packaging, or labeling, is suitable for use and likely to be offered to, or purchased by, consumers as tobacco to be smoked in a pipe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46485704-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/o"},"text":null,"children":[{"tag":"num","attrib":{"value":"o"},"text":"(o)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Roll-your-own tobacco","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “roll-your-own tobacco” means any tobacco which, because of its appearance, type, packaging, or labeling, is suitable for use and likely to be offered to, or purchased by, consumers as tobacco for making cigarettes or cigars, or for use as wrappers thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46485705-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/p"},"text":null,"children":[{"tag":"num","attrib":{"value":"p"},"text":"(p)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturer of processed tobacco","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46485706-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/p/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “manufacturer of processed tobacco” means any person who processes any tobacco other than tobacco products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46485707-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5702/p/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Processed tobacco","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The processing of tobacco shall not include the farming or growing of tobacco or the handling of tobacco solely for sale, shipment, or delivery to a manufacturer of tobacco products or processed tobacco.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46485708-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/706"},"text":"68A Stat. 706","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s202"},"text":"Pub. L. 85–859, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1415"},"text":"72 Stat. 1415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tV/s502/b/3"},"text":"Pub. L. 89–44, title V, § 502(b)(3)","children":[],"tail":", title VIII, § 808(a), "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/151"},"text":"79 Stat. 151","children":[],"tail":", 164; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", title XXI, § 2128(b), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":", 1921; "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIII/s13202/b/2"},"text":"Pub. L. 99–272, title XIII, § 13202(b)(2)","children":[],"tail":"–(4), "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/312"},"text":"100 Stat. 312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tV/s5061/b"},"text":"Pub. L. 100–647, title V, § 5061(b)","children":[],"tail":"–(c)(2), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3679"},"text":"102 Stat. 3679","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11202/g"},"text":"Pub. L. 101–508, title XI, § 11202(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-419"},"text":"104 Stat. 1388–419","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIX/s9302/g/2"},"text":"Pub. L. 105–33, title IX, § 9302(g)(2)","children":[],"tail":"–(3)(B), (h)(4), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/672"},"text":"111 Stat. 672","children":[],"tail":", 674; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s315/a/2"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 315(a)(2)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–644; "},{"tag":"ref","attrib":{"href":"/us/pl/111/3/tVII/s702/a/4"},"text":"Pub. L. 111–3, title VII, § 702(a)(4)","children":[],"tail":", (5), (d)(1), "},{"tag":"date","attrib":{"date":"2009-02-04"},"text":"Feb. 4, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/108"},"text":"123 Stat. 108","children":[],"tail":", 110; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dF/tI/s100122/a"},"text":"Pub. L. 112–141, div. F, title I, § 100122(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/914"},"text":"126 Stat. 914","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46485709-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4648570a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4648570b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" inserted concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/3/s702/a/5/A"},"text":"Pub. L. 111–3, § 702(a)(5)(A)","children":[],"tail":", substituted “tobacco products or cigarette papers or tubes or any processed tobacco” for “tobacco products and cigarette papers and tubes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/3/s702/a/5/B"},"text":"Pub. L. 111–3, § 702(a)(5)(B)","children":[],"tail":", inserted “, or any processed tobacco,” after “tobacco products or cigarette papers or tubes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/3/s702/a/5/B"},"text":"Pub. L. 111–3, § 702(a)(5)(B)","children":[],"tail":", which directed insertion of “, or any processed tobacco,” after “tobacco products or cigarette papers or tubes”, was executed by making the insertion after “tobacco products or cigarette papers or tubes” both places it appeared to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/111/3/s702/d/1"},"text":"Pub. L. 111–3, § 702(d)(1)","children":[],"tail":", inserted “or cigars, or for use as wrappers thereof” before period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (p). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/3/s702/a/4"},"text":"Pub. L. 111–3, § 702(a)(4)","children":[],"tail":", added subsec. (p)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s315/a/2/B"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 315(a)(2)(B)]","children":[],"tail":", redesignated subsec. (g) as (f) and struck out former subsec. (f), which defined “cigarette papers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s315/a/2/B"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 315(a)(2)(B)]","children":[],"tail":", redesignated subsec. (h) as (g). Former subsec. (g) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s315/a/2/B"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 315(a)(2)(B)]","children":[],"tail":", redesignated subsec. (i) as (h). Former subsec. (h) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s315/a/2/A"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 315(a)(2)(A)]","children":[],"tail":", amended heading and text of subsec. (h) generally. Prior to amendment, text read as follows: “ ‘Manufacturer of cigarette papers and tubes’ means any person who makes up cigarette paper into books or sets containing more than 25 papers each, or into tubes, except for his own personal use or consumption.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (i) to (p). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s315/a/2/B"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 315(a)(2)(B)]","children":[],"tail":", redesignated subsecs. (i) to (p) as (h) to ("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s9302/g/3/A"},"text":"Pub. L. 105–33, § 9302(g)(3)(A)","children":[],"tail":", substituted “pipe tobacco, and roll-your-own tobacco” for “and pipe tobacco”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s9302/g/3/B/i"},"text":"Pub. L. 105–33, § 9302(g)(3)(B)(i)","children":[],"tail":", substituted “pipe tobacco, or roll-your-own tobacco” for “or pipe tobacco” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s9302/g/3/B/ii"},"text":"Pub. L. 105–33, § 9302(g)(3)(B)(ii)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “a person who produces cigars, cigarettes, smokeless tobacco, or pipe tobacco solely for his own personal consumption or use; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s9302/h/4"},"text":"Pub. L. 105–33, § 9302(h)(4)","children":[],"tail":", inserted “under section 5704” after “internal revenue bond”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (p). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s9302/g/2"},"text":"Pub. L. 105–33, § 9302(g)(2)","children":[],"tail":", added subsec. (p)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (m). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted heading for one which read: “Wholesale price” and amended text generally. Prior to amendment, text read as follows: “ ‘Wholesale price’ means the manufacturer’s, or importer’s, suggested delivered price at which the cigars are to be sold to retailers, inclusive of the tax imposed by this chapter or section 7652, but exclusive of any State or local taxes imposed on cigars as a commodity, and before any trade, cash, or other discounts, or any promotion, advertising, display, or similar allowances. Where the manufacturer’s or importer’s suggested delivered price to retailers is not adequately supported by bona fide arm’s length sales, or where the manufacturer or importer has no suggested delivered price to retailers, the wholesale price shall be the price for which cigars of comparable retail price are sold to retailers in the ordinary course of trade as determined by the Secretary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s5061/c/1"},"text":"Pub. L. 100–647, § 5061(c)(1)","children":[],"tail":", inserted reference to pipe tobacco."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s5061/c/2"},"text":"Pub. L. 100–647, § 5061(c)(2)","children":[],"tail":", inserted reference to pipe tobacco in introductory provisions and in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s5061/b"},"text":"Pub. L. 100–647, § 5061(b)","children":[],"tail":", added subsec. ("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s13202/b/2"},"text":"Pub. L. 99–272, § 13202(b)(2)","children":[],"tail":", inserted reference to smokeless tobacco."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s13202/b/3"},"text":"Pub. L. 99–272, § 13202(b)(3)","children":[],"tail":", inserted references to smokeless tobacco."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (n). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s13202/b/4"},"text":"Pub. L. 99–272, § 13202(b)(4)","children":[],"tail":", added subsec. (n)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (m). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s2128/b"},"text":"Pub. L. 94–455, § 2128(b)","children":[],"tail":", added subsec. (m)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":", §§ 502(b)(3)(A), 808(a), redesignated subsec. (b) as (a), repealed former subsec. (a) which related to manufactured tobacco and, in subsec. (a) as so redesignated, allowed the use of any substance containing tobacco (other than any roll of tobacco which is a cigarette within the meaning of subsec. (b)(2) as a wrapper in addition to the leaf tobacco previously allowed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":", §§ 502(b)(3)(A), 808(a), redesignated subsec. (c) as (b) and permitted the use, as a wrapper for cigarettes in addition to paper and substances other than tobacco as previously allowed, any substance containing tobacco, which, because of the finished product’s appearance, tobacco type, labeling, and packaging, is likely to be offered to or purchased by consumers as cigarettes. Former subsec. (b) redesignated (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s502/b/3/A"},"text":"Pub. L. 89–44, § 502(b)(3)(A)","children":[],"tail":", (B), redesignated subsec. (d) as (c) and struck out reference to manufactured tobacco. Former subsec. (c) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s502/b/3/A"},"text":"Pub. L. 89–44, § 502(b)(3)(A)","children":[],"tail":", (C), redesignated subsec. (e) as (d), and simplified the definition of manufacturer of tobacco products to include only persons who manufacture cigars or cigarettes and reduced the area of excluded activities so as to exclude only persons producing cigars and cigarettes solely for their own personal use and proprietors of customs bonded manufacturing warehouses with respect to the operation of such warehouses. Former subsec. (d) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e) to (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s502/b/3/A"},"text":"Pub. L. 89–44, § 502(b)(3)(A)","children":[],"tail":" redesignated subsecs. (f) to (k) and (n) as (e) to (j) and (k), respectively. Former subsec. (e) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/s502/b/3/A"},"text":"Pub. L. 89–44, § 502(b)(3)(A)","children":[],"tail":", redesignated subsec. ("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":") as ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") and repealed former subsec. ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") which related to tobacco materials."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (m). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s502/b/3/A"},"text":"Pub. L. 89–44, § 502(b)(3)(A)","children":[],"tail":", repealed subsec. (m) which related to tobacco dealers."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (n), (","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/s502/b/3/A"},"text":"Pub. L. 89–44, § 502(b)(3)(A)","children":[],"tail":", redesignated subsec. (n) and ("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":") as (k) and ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" inserted the term “for removal, or merely removed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" redesignated subsecs. (c), (d), and (f) as (b), (c), and (d), respectively. Former subsecs. (b), (c), and (d) redesignated (e), (b), and (c), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" consolidated the definitions “manufacturer of tobacco” and “manufacturer of cigars and cigarettes”, inserted the phrase “for removal, or merely removes”, excluded from the definition a proprietor of a customs bonded manufacturing warehouse with respect to the operation of the warehouse, and required bona fide associations of farmers or growers to maintain records of leaf tobacco."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" redesignated subsec. (g) as (f) and former subsec. (f) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" added subsec. (g) and redesignated former subsec. (g) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" substituted “into books or sets containing more than 25 papers each, or into tubes” for “into packages, books, sets, or tubes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" substituted provisions defining “export warehouse” for provisions which defined “article” as manufactured tobacco, cigars, cigarettes, and cigarette papers and tubes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" added subsec. (k) and redesignated former subsec. (k) as ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" redesignated former subsec. (k) as ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") and substituted “other than manufactured tobacco, cigars, and cigarettes” for “in process, leaf tobacco, and tobacco scraps, cuttings, clippings, siftings, dust, stems, and waste”. Former subsec. ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") redesignated (m)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (m). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" redesignated former subsec. ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") as (m) and included within the definition persons who receive tobacco materials, other than stems and waste, for use in the production of fertilizer, insecticide, or nicotine, required associations of farmers or growers of tobacco to maintain records of all leaf tobacco acquired or received and sold or otherwise disposed of, and excluded from the definition persons who buy leaf tobacco without taking physical possession of the tobacco and qualified manufacturers of tobacco products. Former subsec. (m) redesignated (n)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (n). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" redesignated former subsec. (m) as (n) and substituted “tobacco products or cigarette papers or tubes” for “articles”. Former subsec. (n) redesignated ("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" redesignated former subsec. (n) as ("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":") and substituted “tobacco products or cigarette papers or tubes” for “articles” in two places, and inserted provisions to include within the definition persons who remove cigars or cigarettes for sale or consumption in the United States from a customs bonded manufacturing warehouse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4648570c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4648570d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dF/tI/s100122/b"},"text":"Pub. L. 112–141, div. F, title I, § 100122(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/915"},"text":"126 Stat. 915","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/141/dF/tI/s100122/b"},"text":"“The amendment made by this section [amending this section] shall apply to articles removed after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4648570e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise provided, amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/3"},"text":"Pub. L. 111–3","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-04-01"},"text"