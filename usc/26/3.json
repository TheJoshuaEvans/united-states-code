{"tag":"section","attrib":{"id":"id40466824-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"§ 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax tables for individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40466825-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax table tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40466826-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In lieu of the tax imposed by section 1, there is hereby imposed for each taxable year on the taxable income of every individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40466827-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who does not itemize his deductions for the taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40466828-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose taxable income for such taxable year does not exceed the ceiling amount,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"a tax determined under tables, applicable to such taxable year, which shall be prescribed by the Secretary and which shall be in such form as he determines appropriate. In the table so prescribed, the amounts of the tax shall be computed on the basis of the rates prescribed by section 1.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40466829-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ceiling amount defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the term “ceiling amount” means, with respect to any taxpayer, the amount (not less than $20,000) determined by the Secretary for the tax rate category in which such taxpayer falls.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4046682a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to prescribe tables for taxpayers who itemize deductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide that this section shall apply also for any taxable year to individuals who itemize their deductions. Any tables prescribed under the preceding sentence shall be on the basis of taxable income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4046682b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section inapplicable to certain individuals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4046682c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual making a return under section 443(a)(1) for a period of less than 12 months on account of a change in annual accounting period, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4046682d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estate or trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4046682e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax treated as imposed by section 1","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this title, the tax imposed by this section shall be treated as tax imposed by section 1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4046682f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever it is necessary to determine the taxable income of an individual to whom this section applies, the taxable income shall be determined under section 63.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40466830-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For computation of tax by Secretary, see section 6014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id40466831-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/8"},"text":"68A Stat. 8","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/272/tIII/s301/a"},"text":"Pub. L. 88–272, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/129"},"text":"78 Stat. 129","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tVIII/s803/c"},"text":"Pub. L. 91–172, title VIII, § 803(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/684"},"text":"83 Stat. 684","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/12/tII/s201/c"},"text":"Pub. L. 94–12, title II, § 201(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-03-29"},"text":"Mar. 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/29"},"text":"89 Stat. 29","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tV/s501/a"},"text":"Pub. L. 94–455, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1558"},"text":"90 Stat. 1558","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/30/tI/s101/b"},"text":"Pub. L. 95–30, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-23"},"text":"May 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/131"},"text":"91 Stat. 131","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tIV/s401/b/1"},"text":"Pub. L. 95–600, title IV, § 401(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2867"},"text":"92 Stat. 2867","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/615/tII/s202/f"},"text":"Pub. L. 95–615, title II, § 202(f)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/222/tI/s108/a/1/A"},"text":"Pub. L. 96–222, title I, § 108(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-01"},"text":"Apr. 1, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/223"},"text":"94 Stat. 223","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/222/tI/s108/a/1/E"},"text":"Pub. L. 96–222, title I, § 108(a)(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-01"},"text":"Apr. 1, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/225"},"text":"94 Stat. 225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tI"},"text":"Pub. L. 97–34, title I","children":[],"tail":", §§ 101(b)(2)(B), (C), (c)(2)(A), 121(c)(3), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/183"},"text":"95 Stat. 183","children":[],"tail":", 197; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tI"},"text":"Pub. L. 99–514, title I","children":[],"tail":", §§ 102(b), 141(b)(1), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2102"},"text":"100 Stat. 2102","children":[],"tail":", 2117.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4048b222-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4048b223-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4048b224-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s102/b"},"text":"Pub. L. 99–514, § 102(b)","children":[],"tail":", substituted subsec. (a) for former subsec. (a) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—In lieu of the tax imposed by section 1, there is hereby imposed for each taxable year on the tax table income of every individual whose tax table income for such year does not exceed the ceiling amount, a tax determined under tables, applicable to such taxable year, which shall be prescribed by the Secretary and which shall be in such form as he determines appropriate. In the tables so prescribed, the amounts of tax shall be computed on the basis of the rates prescribed by section 1."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Ceiling amount defined","children":[],"tail":".—For purposes of paragraph (1), the term ‘ceiling amount’ means, with respect to any taxpayer, the amount (not less than $20,000) determined by the Secretary for the tax rate category in which such taxpayer falls."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) ","children":[{"tag":"inline","attrib":{},"text":"Certain taxpayers with large number of exemptions","children":[],"tail":".—The Secretary may exclude from the application of this section taxpayers in any tax rate category having more than the number of exemptions for that category determined by the Secretary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) ","children":[{"tag":"inline","attrib":{},"text":"Tax table income defined","children":[],"tail":".—For purposes of this section, the term ‘tax table income’ means adjusted gross income—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) reduced by the sum of—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the excess itemized deductions, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the direct charitable deduction, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) increased (in the case of an individual to whom section 63(e) applies) by the unused zero bracket amount.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) ","children":[{"tag":"inline","attrib":{},"text":"Section may be applied on the basis of taxable income","children":[],"tail":".—The Secretary may provide that this section shall be applied for any taxable year on the basis of taxable income in lieu of tax table income.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s141/b/1"},"text":"Pub. L. 99–514, § 141(b)(1)","children":[],"tail":", struck out par. (1) which read: “an individual to whom section 1301 (relating to income averaging) applies for the taxable year,” and redesignated pars. (2) and (3) as (1) and (2), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s101/b/2/B"},"text":"Pub. L. 97–34, § 101(b)(2)(B)","children":[],"tail":", inserted “and which shall be in such form as he determines appropriate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s121/c/3"},"text":"Pub. L. 97–34, § 121(c)(3)","children":[],"tail":", substituted “reduced by the sum of (i) the excess itemized deductions, and (ii) the direct charitable deduction” for “reduced by the excess itemized deductions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s101/b/2/C"},"text":"Pub. L. 97–34, § 101(b)(2)(C)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s101/c/2/A"},"text":"Pub. L. 97–34, § 101(c)(2)(A)","children":[],"tail":", substituted “an individual to whom section 1301 (relating to income averaging) applies for the taxable year” for “an individual to whom (A) section 1301 (relating to income averaging), or (B) section 1348 (relating to maximum rate on personal service income), applies for the taxable year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/222/s108/a/1/E"},"text":"Pub. L. 96–222, § 108(a)(1)(E)","children":[],"tail":", redesignated subpars. (B) and (C) as (A) and (B), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/615/s202/f"},"text":"Pub. L. 95–615, § 202(f)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/96/222/s108/a/1/A"},"text":"Pub. L. 96–222, § 108(a)(1)(A)","children":[],"tail":", struck out subpar. (A) which related to earned income from sources without the United States under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s911"},"text":"section 911 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" redesignated subpars. (C) and (D) as (B) and (C), respectively, and struck out former subpar. (B) which related to the alternative capital gains tax under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1201"},"text":"section 1201 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/30"},"text":"Pub. L. 95–30","children":[],"tail":" struck out “having taxable income of less than $20,000” after “individuals” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/30"},"text":"Pub. L. 95–30","children":[],"tail":" designated existing provisions as par. (1), substituted “tax table income” for “taxable income” and “does not exceed the ceiling amount” for “does not exceed $20,000”, and added pars. (2) to (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/30"},"text":"Pub. L. 95–30","children":[],"tail":" added subsec. (b), redesignated former subsec. (b) as (c), and added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" designated existing provisions as subsec. (a), substituted provision relating to taxable income for such year does not exceed $20,000 for provision relating to adjusted gross income for such year is less than $15,000 and who has elected for such year to pay the tax imposed by this section, struck out “or his delegate” after “Secretary”, “beginning after "},{"tag":"date","attrib":{"date":"1969-12-31"},"text":"Dec. 31, 1969","children":[],"tail":"” after “each taxable year”, struck out provision requiring computation of taxable income by using standard deduction, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/12"},"text":"Pub. L. 94–12","children":[],"tail":" substituted “$15,000” for “$10,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" raised the individual gross income limit of $5,000 to $10,000 for exercising the option and substituted provision that the tax has to be determined under tables to be prescribed by the Secretary or his delegate for tables of tax rates for single persons, heads of household, married persons filing joint returns, married persons filing separate returns with 10 per cent standard deduction and married persons filing separate returns with minimum standard deduction."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272"},"text":"Pub. L. 88–272","children":[],"tail":" substituted optional tax tables covering five categories for taxable years beginning on or after "},{"tag":"date","attrib":{"date":"1964-01-01"},"text":"Jan. 1, 1964","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1965-01-01"},"text":"Jan. 1, 1965","children":[],"tail":", and for years beginning after "},{"tag":"date","attrib":{"date":"1964-12-31"},"text":"Dec. 31, 1964","children":[],"tail":", for a single general table."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4048b225-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4048b226-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by "