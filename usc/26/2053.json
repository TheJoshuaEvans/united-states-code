{"tag":"section","attrib":{"id":"id45316854-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053"},"text":null,"children":[{"tag":"num","attrib":{"value":"2053"},"text":"§ 2053.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses, indebtedness, and taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45316855-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of the tax imposed by section 2001, the value of the taxable estate shall be determined by deducting from the value of the gross estate such amounts—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45316856-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for funeral expenses,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45316857-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for administration expenses,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45316858-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for claims against the estate, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45316859-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for unpaid mortgages on, or any indebtedness in respect of, property where the value of the decedent’s interest therein, undiminished by such mortgage or indebtedness, is included in the value of the gross estate,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as are allowable by the laws of the jurisdiction, whether within or without the United States, under which the estate is being administered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4531685a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other administration expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the limitations in paragraph (1) of subsection (c), there shall be deducted in determining the taxable estate amounts representing expenses incurred in administering property not subject to claims which is included in the gross estate to the same extent such amounts would be allowable as a deduction under subsection (a) if such property were subject to claims, and such amounts are paid before the expiration of the period of limitation for assessment provided in section 6501.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4531685b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4531685c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations applicable to subsections (a) and (b)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4531685d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration for claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The deduction allowed by this section in the case of claims against the estate, unpaid mortgages, or any indebtedness shall, when founded on a promise or agreement, be limited to the extent that they were contracted bona fide and for an adequate and full consideration in money or money’s worth; except that in any case in which any such claim is founded on a promise or agreement of the decedent to make a contribution or gift to or for the use of any donee described in section 2055 for the purposes specified therein, the deduction for such claims shall not be so limited, but shall be limited to the extent that it would be allowable as a deduction under section 2055 if such promise or agreement constituted a bequest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4531685e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any income taxes on income received after the death of the decedent, or property taxes not accrued before his death, or any estate, succession, legacy, or inheritance taxes, shall not be deductible under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4531685f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain claims by remaindermen","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowed under this section for a claim against the estate by a remainderman relating to any property described in section 2044.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45316860-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 6166 interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowed under this section for any interest payable under section 6601 on any unpaid portion of the tax imposed by section 2001 for the period during which an extension of time for payment of such tax is in effect under section 6166.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45316861-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations applicable only to subsection (a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of the amounts described in subsection (a), there shall be disallowed the amount by which the deductions specified therein exceed the value, at the time of the decedent’s death, of property subject to claims, except to the extent that such deductions represent amounts paid before the date prescribed for the filing of the estate tax return. For purposes of this section, the term “property subject to claims” means property includible in the gross estate of the decedent which, or the avails of which, would under the applicable law, bear the burden of the payment of such deductions in the final adjustment and settlement of the estate, except that the value of the property shall be reduced by the amount of the deduction under section 2054 attributable to such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45316862-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain foreign death taxes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45316863-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of subsection (c)(1)(B), for purposes of the tax imposed by section 2001, the value of the taxable estate may be determined, if the executor so elects before the expiration of the period of limitation for assessment provided in section 6501, by deducting from the value of the gross estate the amount (as determined in accordance with regulations prescribed by the Secretary) of any estate, succession, legacy, or inheritance tax imposed by and actually paid to any foreign country, in respect of any property situated within such foreign country and included in the gross estate of a citizen or resident of the United States, upon a transfer by the decedent for public, charitable, or religious uses described in section 2055. The determination under this paragraph of the country within which property is situated shall be made in accordance with the rules applicable under subchapter B (sec. 2101 and following) in determining whether property is situated within or without the United States. Any election under this paragraph shall be exercised in accordance with regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45316864-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition for allowance of deduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowed under paragraph (1) for a foreign death tax specified therein unless the decrease in the tax imposed by section 2001 which results from the deduction provided in paragraph (1) will inure solely for the benefit of the public, charitable, or religious transferees described in section 2055 or section 2106(a)(2). In any case where the tax imposed by section 2001 is equitably apportioned among all the transferees of property included in the gross estate, including those described in sections 2055 and 2106(a)(2) (taking into account any exemptions, credits, or deductions allowed by this chapter), in determining such decrease, there shall be disregarded any decrease in the Federal estate tax which any transferees other than those described in sections 2055 and 2106(a)(2) are required to pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45316865-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on credit for foreign death taxes of deduction under this subsection","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45316866-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under this subsection shall be deemed a waiver of the right to claim a credit, against the Federal estate tax, under a death tax convention with any foreign country for any tax or portion thereof in respect of which a deduction is taken under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45316867-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"See section 2014(f) for the effect of a deduction taken under this paragraph on the credit for foreign death taxes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45316868-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2053/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marital rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions treating certain relinquishments of marital rights as consideration in money or money’s worth, see section 2043(b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45316869-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/389"},"text":"68A Stat. 389","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-02-20/ch63/s2"},"text":"Feb. 20, 1956, ch. 63, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/23"},"text":"70 Stat. 23","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s102/c/3"},"text":"Pub. L. 85–866, title I, § 102(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1674"},"text":"72 Stat. 1674","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/175/s1"},"text":"Pub. L. 86–175, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-08-21"},"text":"Aug. 21, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/396"},"text":"73 Stat. 396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1902(a)(12)(B), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1806"},"text":"90 Stat. 1806","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s425/a/2"},"text":"Pub. L. 98–369, div. A, title IV, § 425(a)(2)","children":[],"tail":", title X, § 1027(b), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/804"},"text":"98 Stat. 804","children":[],"tail":", 1031; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1011A/g/11"},"text":"Pub. L. 100–647, title I, § 1011A(g)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3482"},"text":"102 Stat. 3482","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tV/s503/b/1"},"text":"Pub. L. 105–34, title V, § 503(b)(1)","children":[],"tail":", title X, § 1073(b)(3), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/853"},"text":"111 Stat. 853","children":[],"tail":", 948; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tV/s532/c/5"},"text":"Pub. L. 107–16, title V, § 532(c)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/74"},"text":"115 Stat. 74","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/134/tI/s103/b/2"},"text":"Pub. L. 107–134, title I, § 103(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2431"},"text":"115 Stat. 2431","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4531686a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4531686b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4531686c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/134"},"text":"Pub. L. 107–134","children":[],"tail":" substituted “section 2011(d)” for “section 2011(e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16"},"text":"Pub. L. 107–16","children":[],"tail":" substituted “Certain foreign death taxes” for “Certain State and foreign death taxes” in heading and amended text generally, revising and restating provisions of pars. (1) to (3) so as to eliminate provisions relating to deduction for State death taxes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1073/b/3"},"text":"Pub. L. 105–34, § 1073(b)(3)","children":[],"tail":", struck out at end “This subparagraph shall not apply to any increase in the tax imposed by this chapter by reason of section 4980A(d).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s503/b/1"},"text":"Pub. L. 105–34, § 503(b)(1)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":", inserted at end “This subparagraph shall not apply to any increase in the tax imposed by this chapter by reason of section 4980A(d).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1027/b"},"text":"Pub. L. 98–369, § 1027(b)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s425/a/2"},"text":"Pub. L. 98–369, § 425(a)(2)","children":[],"tail":", substituted “For provisions treating certain relinquishments of marital rights as consideration in money or money’s worth, see section 2043(b)(2)” for “For provisions that relinquishment of marital rights shall not be deemed a consideration ‘in money or money’s worth,’ see section 2043(b).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” in provisions preceding subpar. (A) and following subpar. (B) and struck out “or Territory” after “a State” in subpar. (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/175"},"text":"Pub. L. 86–175","children":[],"tail":" inserted a reference to foreign death taxes in heading of subsection and par. (3) and in text of par. (2), redesignated provisions of par. (1) as par. (1)(A) and sentence pertaining to exercise of privilege of election, added par. (2) and sentence for determining location of property, redesignated provisions of par. (3) as par. (3)(B) in part, and added par. (3)(A) and the part of (B) relating to foreign death taxes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866"},"text":"Pub. L. 85–866","children":[],"tail":" struck out “or any possession of the United States,” after “District of Columbia,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Subsecs. (d), (e). Act ","children":[{"tag":"date","attrib":{"date":"1956-02-20"},"text":"Feb. 20, 1956","children":[],"tail":", added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4531686d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4531686e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/134/tI/s103/d"},"text":"Pub. L. 107–134, title I, § 103(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2431"},"text":"115 Stat. 2431","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/134/tI/s103/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amendments made by this section [amending this section and sections 2011 and 2201 of this title] shall apply to estates of decedents—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dying on or after ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of individuals dying as a result of the ","children":[{"tag":"date","attrib":{"date":"1995-04-19"},"text":"April 19, 1995","children":[],"tail":", terrorist attack, dying on or after "},{"tag":"date","attrib":{"date":"1995-04-19"},"text":"April 19, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver of limitat