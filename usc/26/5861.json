{"tag":"section","attrib":{"id":"id4651f47b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5861"},"text":null,"children":[{"tag":"num","attrib":{"value":"5861"},"text":"§ 5861.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any person—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4651f47c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5861/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to engage in business as a manufacturer or importer of, or dealer in, firearms without having paid the special (occupational) tax required by section 5801 for his business or having registered as required by section 5802; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4651f47d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5861/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive or possess a firearm transferred to him in violation of the provisions of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4651f47e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5861/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive or possess a firearm made in violation of the provisions of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4651f47f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5861/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive or possess a firearm which is not registered to him in the National Firearms Registration and Transfer Record; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4651f480-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5861/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to transfer a firearm in violation of the provisions of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4651f481-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5861/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make a firearm in violation of the provisions of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4651f482-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5861/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obliterate, remove, change, or alter the serial number or other identification of a firearm required by this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4651f483-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5861/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive or possess a firearm having the serial number or other identification required by this chapter obliterated, removed, changed, or altered; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4651f484-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5861/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive or possess a firearm which is not identified by a serial number as required by this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4651f485-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5861/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to transport, deliver, or receive any firearm in interstate commerce which has not been registered as required by this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4651f486-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5861/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive or possess a firearm which has been imported or brought into the United States in violation of section 5844; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4651f487-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5861/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make, or cause the making of, a false entry on any application, return, or record required by this chapter, knowing such entry to be false.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4651f488-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/618/tII/s201"},"text":"Pub. L. 90–618, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1234"},"text":"82 Stat. 1234","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4651f489-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id465