uthority to determine under subsections (a) and (b) of section 3121 whether any such service constitutes employment, the periods of such employment, and whether remuneration paid for any such service constitutes wages.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Pub. L. 99–272","children":[],"tail":" substituted “including such service which is medicare qualified government employment (as defined in section 3121(u)(3))” for “including service which is medicare qualified Federal employment (as defined in section 3121(u)(2))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" inserted “including service which is medicare qualified Federal employment (as defined in section 3121(u)(2)),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted “Secretary of Transportation” for “Secretary” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/233/s5/b/3"},"text":"Pub. L. 93–233, § 5(b)(3)","children":[],"tail":", effective with respect to remuneration paid after 1973, substituted “$13,200” for “$12,600”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/233/s5/d"},"text":"Pub. L. 93–233, § 5(d)","children":[],"tail":", applicable only with respect to remuneration paid after, and taxable year beginning after, 1973 (as provided in "},{"tag":"ref","attrib":{"href":"/us/pl/93/233/s5/e"},"text":"section 5(e) of Pub. L. 93–233","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s409"},"text":"section 409 of Title 42","children":[],"tail":"), amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/336/s203/b/3/C"},"text":"section 203(b)(3)(C) of Pub. L. 92–336","children":[],"tail":" (set out as 1973 Amendment note hereunder) substituting “$13,200” for “$12,600”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/66/s203/b/3"},"text":"Pub. L. 93–66, § 203(b)(3)","children":[],"tail":", effective with respect to remuneration paid after 1973, substituted “$12,600” for “$12,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/66/s203/d"},"text":"Pub. L. 93–66, § 203(d)","children":[],"tail":", applicable only with respect to remuneration paid after, and taxable years beginning after, 1973 (as provided in "},{"tag":"ref","attrib":{"href":"/us/pl/93/66/s203/e"},"text":"section 203(e) of Pub. L. 93–66","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s409"},"text":"section 409 of Title 42","children":[],"tail":"), amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/336/s203/b/3/C"},"text":"section 203(b)(3)(C) of Pub. L. 92–336","children":[],"tail":" (set out as 1972 Amendment note hereunder) substituting “$12,600” for “$12,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/336/s203/b/3/A"},"text":"Pub. L. 92–336, § 203(b)(3)(A)","children":[],"tail":", substituted “$10,800” for “$9,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/336/s203/b/3/B"},"text":"Pub. L. 92–336, § 203(b)(3)(B)","children":[],"tail":", effective with respect to remuneration paid after 1973, substituted “$12,000” for “$10,800”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/336/s203/b/3/C"},"text":"Pub. L. 92–336, § 203(b)(3)(C)","children":[],"tail":", effective with respect to remuneration paid after 1974, substituted “contribution and benefit base” for “$12,000”."}],"tail":"\n"},{"t