{"tag":"section","attrib":{"id":"id45d85709-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4482"},"text":null,"children":[{"tag":"num","attrib":{"value":"4482"},"text":"§ 4482.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45d8570a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4482/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Highway motor vehicle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter, the term “highway motor vehicle” means any motor vehicle which is a highway vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d8570b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4482/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable gross weight","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the term “taxable gross weight”, when used with respect to any highway motor vehicle, means the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45daa0fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4482/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the actual unloaded weight of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45daa0fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4482/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such highway motor vehicle fully equipped for service, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45daa0fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4482/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the semitrailers and trailers (fully equipped for service) customarily used in connection with highway motor vehicles of the same type as such highway motor vehicle, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45daa0ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4482/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the weight of the maximum load customarily carried on highway motor vehicles of the same type as such highway motor vehicle and on the semitrailers and trailers referred to in paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Taxable gross weight shall be determined under regulations prescribed by the Secretary (which regulations may include formulas or other methods for determining the taxable gross weight of vehicles by classes, specifications, or otherwise).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45daa100-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4482/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions and special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45daa101-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4482/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means a State and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45daa102-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4482/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “year” means the one-year period beginning on July 1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45daa103-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4482/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “use” means use in the United States on the public highways.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45daa104-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4482/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “taxable period” means any year beginning before ","children":[{"tag":"date","attrib":{"date":"2029-07-01"},"text":"July 1, 2029","children":[],"tail":", and the period which begins on "},{"tag":"date","attrib":{"date":"2029-07-01"},"text":"July 1, 2029","children":[],"tail":", and ends at the close of "},{"tag":"date","attrib":{"date":"2029-09-30"},"text":"September 30, 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45daa105-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4482/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customary use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A semitrailer or trailer shall be treated as customarily used in connection with a highway motor vehicle if such vehicle is equipped to tow such semitrailer or trailer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45daa106-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4482/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for taxable period in which termination date occurs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of the taxable period which ends on ","children":[{"tag":"date","attrib":{"date":"2029-09-30"},"text":"September 30, 2029","children":[],"tail":", the amount of the tax imposed by section 4481 with respect to any highway motor vehicle shall be determined by reducing each dollar amount in the table contained in section 4481(a) by 75 percent."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45daa107-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-06-29/ch462"},"text":"June 29, 1956, ch. 462","children":[],"tail":", title II, § 206(a), "},{"tag":"ref","attrib":{"href":"/us/stat/70/390"},"text":"70 Stat. 390","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/87/61/tII/s203/b/2/C"},"text":"Pub. L. 87–61, title II, § 203(b)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-06-29"},