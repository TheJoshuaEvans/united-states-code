{"tag":"section","attrib":{"id":"id47727f5b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528"},"text":null,"children":[{"tag":"num","attrib":{"value":"7528"},"text":"§ 7528.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internal Revenue Service user fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47727f5c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program requiring the payment of user fees for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47727f5d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requests to the Internal Revenue Service for ruling letters, opinion letters, and determination letters, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47727f5e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other similar requests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47727f5f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47727f60-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The fees charged under the program required by subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47727f61-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall vary according to categories (or subcategories) established by the Secretary,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47727f62-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be determined after taking into account the average time for (and difficulty of) complying with requests in each category (and subcategory), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47727f63-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be payable in advance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47727f64-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions, etc.","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47727f65-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for such exemptions (and reduced fees) under such program as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47727f66-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for certain requests regarding pension plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not require payment of user fees under such program for requests for determination letters with respect to the qualified status of a pension benefit plan maintained solely by 1 or more eligible employers or any trust which is part of the plan. The preceding sentence shall not apply to any request—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47727f67-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" made after the later of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id47727f68-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fifth plan year the pension benefit plan is in existence, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id47727f69-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the end of any remedial amendment period with respect to the plan beginning within the first 5 plan years, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47727f6a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made by the sponsor of any prototype or similar plan which the sponsor intends to market to participating employers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47727f6b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (B)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47727f6c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pension benefit plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “pension benefit plan” means a pension, profit-sharing, stock bonus, annuity, or employee stock ownership plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47727f6d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible employer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible employer” means an eligible employer (as defined in section 408(p)(2)(C)(i)(I)) which has at least 1 employee who is not a highly compensated employee (as defined in section 414(q)) and is participating in the plan. The determination of whether an employer is an eligible employer under subparagraph (B) shall be made as of the date of the request described in such subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47727f6e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of average fees charged","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of any determination of average fees charged, any request to which subparagraph (B) applies shall not be taken into account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47727f6f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Average fee requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The average fee charged under the program required by subsection (a) shall not be less than the amount determined under the following table:","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id47727f70-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":"Average","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":"Category","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":"Fee","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Employee plan ruling and opinion","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$250  ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Exempt organization ruling","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$350  ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Employee plan determination","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$300  ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Exempt organization determination","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$275  ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Chief counsel ruling","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$200.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47727f71-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7528/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified professional employer organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fee charged under the program in connection with the certification by the Secretary of a professional employer organization under section 7705 shall be an annual fee not to exceed $1,000 per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47727f72-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/89/tII/s202/a"},"text":"Pub. L. 108–89, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-01"},"text":"Oct. 1, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1132"},"text":"117 Stat. 1132","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s891/a"},"text":"Pub. L. 108–357, title VIII, § 891(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1644"},"text":"118 Stat. 1644","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/28/tVIII/s8244"},"text":"Pub. L. 110–28, title VIII, § 8244","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-25"},"text":"May 25, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/200"},"text":"121 Stat. 200","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dB/tII/s206/f"},"text":"Pub. L. 113–295, div. B, title II, § 206(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4071"},"text":"128 Stat. 4071","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47727f73-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47727f74-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47727f75-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28"},"text":"Pub. L. 110–28","children":[],"tail":" struck out heading and text of subsec. (c). Text read as follows: “No fee shall be imposed under this section with respect to requests made after "},{"tag":"date","attrib":{"date":"2014-09-30"},"text":"September 30, 2014","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2014-09-30"},"text":"September 30, 2014","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4774c866-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4774c867-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" applicable with respect to wages for services performed on or after January 1 of the first calendar year beginning more than 12 months after "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s206/g/1"},"text":"section 206(g)(1) of Pub. L. 113–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3302"},"text":"section 3302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4774c868-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s891/b"},"text":"Pub. L. 108–357, title VIII, § 891(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1644"},"text":"118 Stat. 1644","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tVIII/s891/b"},"text":"“The amendment made by this section [amending this section] shall apply to requests after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4774c869-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/89/tII/s202/d"},"text":"Pub. L. 108–89, title II, § 202(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-01"},"text":"Oct. 1, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1133"},"text":"117 Stat. 1133","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/89/tII/s202/d"},"text":"“The amendments made by this section [enacting this section, enacting provisions set out as a note under this section, and repealing provisions set out as notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7801"},"text":"section 7801 of this title","children":[],"tail":"] shall apply to requests made after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2003-10-01"},"text":"Oct. 1, 2003","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4774c86a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/89/tII/s202/c"},"text":"Pub. L. 108–89, title II, § 202(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-01"},"text":"Oct. 1, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1133"},"text":"117 Stat. 1133","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/89/tII/s202/c"},"text":"“Notwithstanding any other provision of law, any fees collected pursuant to section 7528 of the Internal Revenue Code of 1986, as added by subsection (a), shall not be expended by the Internal Revenue Service unless provided by an appropriations Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
