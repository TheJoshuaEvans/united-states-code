"attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/194"},"text":"95 Stat. 194","children":[],"tail":", 195; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1272/d/10"},"text":"Pub. L. 99–514, title XII, § 1272(d)(10)","children":[],"tail":", title XVIII, § 1879(r)(1), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2594"},"text":"100 Stat. 2594","children":[],"tail":", 2912; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10713/b/2/A"},"text":"Pub. L. 100–203, title X, § 10713(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-470"},"text":"101 Stat. 1330–470","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7841/f"},"text":"Pub. L. 101–239, title VII, § 7841(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2429"},"text":"103 Stat. 2429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/266"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(266)","children":[],"tail":", (d)(1)(D)(xviii), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1197"},"text":"132 Stat. 1197","children":[],"tail":", 1208.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id468b2d06-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id468b2d07-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id468b2d08-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(2)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/d/1/D/xviii"},"text":"Pub. L. 115–141, § 401(d)(1)(D)(xviii)","children":[],"tail":", redesignated cl. (iii) as (ii) and struck out former cl. (ii) which read as follows: “corporations which claim the benefits of section 936 (relating to possession tax credit),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/266"},"text":"Pub. L. 115–141, § 401(a)(266)","children":[],"tail":", struck out “and” after “credit),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B)(iii), (iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/d/1/D/xviii"},"text":"Pub. L. 115–141, § 401(d)(1)(D)(xviii)","children":[],"tail":", redesignated cl. (iv) as (iii). Former cl. (iii) redesignated (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" inserted “section 4181 or” before “subtitle E”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (b)(1)(B)(v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" inserted reference to section 6852(a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(1)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1272/d/10"},"text":"Pub. L. 99–514, § 1272(d)(10)","children":[],"tail":", substituted “Guam, American Samoa, or the Northern Mariana Islands” for “possessions of the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1879/r/1"},"text":"Pub. L. 99–514, § 1879(r)(1)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b)(1)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" substituted “section 911 (relating to citizens or residents of the United States living abroad)” for “section 911 (relating to income earned by employees in certain camps)” and struck out “section 913 (relating to deduction for certain expenses of living abroad)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b)(1)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/615"},"text":"Pub. L. 95–615","children":[],"tail":" substituted “(relating to income earned by employees in certain camps)” for “(relating to earned income from sources without the United States)” and inserted “section 913 (relating to deduction for certain expenses of living abroad),” before “section 931”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 1204(c)(3)(A), 1906(b)(13)(A), added cl. (v) and struck out in provision following cl. (v) “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1503/d/4"},"text":"Pub. L. 94–455, § 1503(d)(4)","children":[],"tail":", in cl. (ii), struck out provision which permitted returns of a corporation claiming the benefits of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s941"},"text":"section 941 of this title","children":[],"tail":", relating to the special deduction for China Trade corporations, to be made at such place as the Secretary may designate by regulation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 1052(c)(6), struck out provision which permitted returns of a corporation claiming the benefits of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s922"},"text":"section 922 of this title","children":[],"tail":", relating to the special deduction for Western Hemisphere trade corporations to be made at such place as the Secretary may designate by regulation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 1051(h)(4), 1204(c)(3)(B), 1906(b)(13)(A), substituted “section 936 (relating to possession tax credit)” for “section 931 (relating to income from sources within possessions of the United States),” for taxable years beginning after "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", added cl. (iv), and struck out in provision following cl. (iv) “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614/s101/i/1"},"text":"Pub. L. 91–614, § 101(i)(1)","children":[],"tail":", substituted provisions requiring an estate tax return to be filed in the internal revenue district in which the decedent was domiciled at the time of his death or at a service center serving that district, as the Secretary or his delegate may determine by regulations, and in the case of a decedent who was not domiciled in an internal revenue district, or who had no domicile, his return is to be filed at such place as the Secretary or his delegate designates for provisions requiring estate tax returns to be filed in the internal revenue district in which the decedent was domiciled at the time of his death or, if there was no such domicile in an internal revenue district, then at such place as the Secretary or his delegate by regulations designates."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614/s101/i/2"},"text":"Pub. L. 91–614, § 101(i)(2)","children":[],"tail":", permitted the executor, who desires to file an estate tax return in person, to do so by hand carrying it to the appropriate internal revenue district office."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/713/s1/a/1"},"text":"Pub. L. 89–713, § 1(a)(1)","children":[],"tail":", authorized the Secretary to promulgate regulations allowing individuals to file tax returns either in the internal revenue district in which the taxpayer’s legal residence or principal place of business is located or at a service center serving that district, designated as subpar. (B)(1) the existing provisions which authorized the Secretary to prescribe the place without limitations as to the Secretary’s range of alternative choices for the filing of returns of persons who have no legal residence or principal place of business in any internal revenue district, and added subpar. (B)(ii) to (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/713/s1/a/1"},"text":"Pub. L. 89–713, § 1(a)(1)","children":[],"tail":", authorized the Secretary to promulgate regulations allowing corporations to file tax returns either in the internal revenue district in which is located the principal place of business or principal office or agency of the corporation or at a service center serving that district, designated as subpar. (B)(i) the existing provisions which authorized the Secretary to prescribe the place without limitations as to the Secretary’s range of alternative choices for the filing of returns of corporations having no principal place of business or principal office or agency of the corporation, and added subpar. (B)(ii), (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/713/s1/a/2"},"text":"Pub. L. 89–713, § 1(a)(2)","children":[],"tail":", (3), added par. (4), redesignated former par. (4) as (5), and, in par. (5), substituted “paragraph (1), (2), (3), or (4)” for “paragraph (1), (2), or (3)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id468d75f9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468d75fa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10713/c"},"text":"Pub. L. 100–203, title X, § 10713(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-470"},"text":"101 Stat. 1330–470","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/203/tX/s10713/c"},"text":"“The amendments made by this section [enacting sections 6852 and 7409 of this title and amending this section and sections 6211 to 6213, 6863, 7429, and 7611 of this title] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468d75fb-