{"tag":"section","attrib":{"id":"id468b2ce8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091"},"text":null,"children":[{"tag":"num","attrib":{"value":"6091"},"text":"§ 6091.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Place for filing returns or other documents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id468b2ce9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When not otherwise provided for by this title, the Secretary shall by regulations prescribe the place for the filing of any return, declaration, statement, or other document, or copies thereof, required by this title or by regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id468b2cea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax returns","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of returns of tax required under authority of part II of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id468b2ceb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons other than corporations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id468b2cec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), a return (other than a corporation return) shall be made to the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id468b2ced-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the internal revenue district in which is located the legal residence or principal place of business of the person making the return, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id468b2cee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a service center serving the internal revenue district referred to in clause (i),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as the Secretary may by regulations designate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id468b2cef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Returns of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id468b2cf0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons who have no legal residence or principal place of business in any internal revenue district,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id468b2cf1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" citizens of the United States whose principal place of abode for the period with respect to which the return is filed is outside the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id468b2cf2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons who claim the benefits of section 911 (relating to citizens or residents of the United States living abroad), section 931 (relating to income from sources within Guam, American Samoa, or the Northern Mariana Islands), or section 933 (relating to income from sources within Puerto Rico),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id468b2cf3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonresident alien persons, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id468b2cf4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons with respect to whom an assessment was made under section 6851(a) or 6852(a) (relating to termination assessments) with respect to the taxable year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be made at such place as the Secretary may by regulations designate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id468b2cf5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id468b2cf6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), a return of a corporation shall be made to the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id468b2cf7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the internal revenue district in which is located the principal place of business or principal office or agency of the corporation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id468b2cf8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a service center serving the internal revenue district referred to in clause (i), as the Secretary may by regulations designate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id468b2cf9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Returns of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id468b2cfa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" corporations which have no principal place of business or principal office or agency in any internal revenue district,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id468b2cfb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign corporations, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id468b2cfc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" corporations with respect to which an assessment was made under section 6851(a) (relating to termination assessments) with respect to the taxable year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be made at such place as the Secretary may by regulations designate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id468b2cfd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estate tax returns","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id468b2cfe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), returns of estate tax required under section 6018 shall be made to the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id468b2cff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the internal revenue district in which was the domicile of the decedent at the time of his death, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id468b2d00-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a service center serving the internal revenue district referred to in clause (i), as the Secretary may by regulations designate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id468b2d01-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the domicile of the decedent was not in an internal revenue district, or if he had no domicile, the estate tax return required under section 6018 shall be made at such place as the Secretary may by regulations designate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id468b2d02-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hand-carried returns","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), (2), or (3), a return to which paragraph (1)(A), (2)(A), or (3)(A) would apply, but for this paragraph, which is made to the Secretary by handcarrying shall, under regulations prescribed by the Secretary, be made in the internal revenue district referred to in paragraph (1)(A)(i), (2)(A)(i), or (3)(A)(i), as the case may be.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id468b2d03-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptional cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), (2), (3), or (4) of this subsection, the Secretary may permit a return to be filed in any internal revenue district, and may require the return of any officer or employee of the Treasury Department to be filed in any internal revenue district selected by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id468b2d04-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6091/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alcohol, tobacco, and firearms returns, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any return of tax imposed by section 4181 or subtitle E (relating to taxes on alcohol, tobacco, and firearms), subsection (a) shall apply (and this subsection shall not apply).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id468b2d05-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"ta