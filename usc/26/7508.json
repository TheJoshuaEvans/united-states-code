en":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2027"},"text":"119 Stat. 2027","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dC/tXXXII/s32101/d"},"text":"Pub. L. 114–94, div. C, title XXXII, § 32101(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1732"},"text":"129 Stat. 1732","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tIII/s309/a"},"text":"Pub. L. 114–113, div. Q, title III, § 309(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3089"},"text":"129 Stat. 3089","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dH/tV/s80502/a"},"text":"Pub. L. 117–58, div. H, title V, § 80502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1335"},"text":"135 Stat. 1335","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id476b530b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id476b530c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id476b530d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s80502/a/1"},"text":"Pub. L. 117–58, § 80502(a)(1)","children":[],"tail":", added subpar. (C) and struck out former subpa