{"tag":"section","attrib":{"id":"id460337e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4977"},"text":null,"children":[{"tag":"num","attrib":{"value":"4977"},"text":"§ 4977.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on certain fringe benefits provided by an employer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id460337e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4977/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an employer to whom an election under this section applies for any calendar year, there is hereby imposed a tax for such calendar year equal to 30 percent of the excess fringe benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460337e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4977/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess fringe benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the term “excess fringe benefits” means, with respect to any calendar year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460337e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4977/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate value of the fringe benefits provided by the employer during the calendar year which were not includible in gross income under paragraphs (1) and (2) of section 132(a), over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460337e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4977/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 1 percent of the aggregate amount of compensation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460337e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4977/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which was paid by the employer during such calendar year to employees, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460337e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4977/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was includible in gross income for purposes of chapter 1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460337e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4977/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of election on section 132(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460337ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4977/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an election under this section is in effect with respect to an employer for any calendar year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460337eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4977/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at all times on or after ","children":[{"tag":"date","attrib":{"date":"1984-01-01"},"text":"January 1, 1984","children":[],"tail":", and before the close of the calendar year involved, substantially all of the employees of the employer were entitled to employee discounts on goods or services provided by the employer in 1 line of business,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for purposes of paragraphs (1) and (2) of section 132(a) (but not for purposes of section 132(h)), all employees of any line of business of the employer which was in existence on ","children":[{"tag":"date","attrib":{"date":"1984-01-01"},"text":"January 1, 1984","children":[],"tail":", shall be treated as employees of the line of business referred to in paragraph (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460337ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4977/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under this section shall apply to the calendar year for which made and all subsequent calendar years unless revoked by the employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460337ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4977/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of controlled groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All employees treated as employed by a single employer under subsection (b), (c), or (m) of section 414 shall be treated as employed by a single employer for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460337ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4977/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section to apply only to employment within the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in regulations, this section shall apply only with respect to employment within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id460337ef-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tV/s531/e/1"},"text":"Pub. L. 98–369, div. A, title V, § 531(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/885"},"text":"98 Stat. 885","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1853/c/1"},"text":"Pub. L. 99–514, title XVIII, § 1853(c)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2871"},"text":"100 Stat. 2871","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13213/d/3/D"},"text":"Pub. L. 103–66, title XIII, § 13213(d)(3)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/474"},"text":"107 Stat. 474","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1704/t/66"},"text":"Pub. L. 104–188, title I, § 1704(t)(66)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1890"},"text":"110 Stat. 1890","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id460337f0-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id460337f1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id460337f2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" substituted “section 132(h)” for “section 132(i)(2)” in closing provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" substituted “section 132(i)(2)” for “section 132(g)(2)” in closing provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1853/c/1"},"text":"Pub. L. 99–514, § 1853(c)(1)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “as of "},{"tag":"date","attrib":{"date":"1984-01-01"},"text":"January 1, 1984","children":[],"tail":", substantially all of the employees of the employer were entitled to employee discounts or services provided by the employer in 1 line of business,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1853/c/2"},"text":"Pub. L. 99–514, § 1853(c)(2)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4605a8f3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4605a8f4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" applicable to reimbursements or other payments in respect of expenses incurred after "},{"tag":"date","attrib":{"date":"1993-12-31"},"text":"Dec. 31, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13213/e"},"text":"section 13213(e) of Pub. L. 103–66","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s62"},"text":"section 62 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4605a8f5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4605a8f6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1985-01-01"},"text":"Jan. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s531/h"},"text":"section 531(h) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s132"},"text":"section 132 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4605a8f7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1800–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4605a8f8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application of Subsection (c) of this Section to Agricultural Cooperatives Incorporated in 1964","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1853/c/3"},"text":"Pub. L. 99–514, title XVIII, § 1853(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2871"},"text":"100 Stat. 2871","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXVIII/s1853/c/3"},"text":"“For purposes of determining whether the requirements of section 4977(c) of the Internal Revenue Code of 1954 [now 1986] are met in the case of an agricultural cooperative incorporated in 1964, there shall not be taken into account employees of a member of the same controlled group as such cooperative which became a member during July 1980.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
