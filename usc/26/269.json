{"tag":"section","attrib":{"id":"id4290f4de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269"},"text":null,"children":[{"tag":"num","attrib":{"value":"269"},"text":"§ 269.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisitions made to evade or avoid income tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4290f4df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4290f4e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person or persons acquire, directly or indirectly, control of a corporation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4290f4e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any corporation acquires, directly or indirectly, property of another corporation, not controlled, directly or indirectly, immediately before such acquisition, by such acquiring corporation or its stockholders, the basis of which property, in the hands of the acquiring corporation, is determined by reference to the basis in the hands of the transferor corporation,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and the principal purpose for which such acquisition was made is evasion or avoidance of Federal income tax by securing the benefit of a deduction, credit, or other allowance which such person or corporation would not otherwise enjoy, then the Secretary may disallow such deduction, credit, or other allowance. For purposes of paragraphs (1) and (2), control means the ownership of stock possessing at least 50 percent of the total combined voting power of all classes of stock entitled to vote or at least 50 percent of the total value of shares of all classes of stock of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4290f4e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain liquidations after qualified stock purchases","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4290f4e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4290f4e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a qualified stock purchase by a corporation of another corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4290f4e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an election is not made under section 338 with respect to such purchase,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4290f4e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquired corporation is liquidated pursuant to a plan of liquidation adopted not more than 2 years after the acquisition date, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4290f4e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the principal purpose for such liquidation is the evasion or avoidance of Federal income tax by securing the benefit of a deduction, credit, or other allowance which the acquiring corporation would not otherwise enjoy,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then the Secretary may disallow such deduction, credit, or other allowance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4290f4e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meaning of terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the terms “qualified stock purchase” and “acquisition date” have the same respective meanings as when used in section 338.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4290f4e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power of Secretary to allow deduction, etc., in part","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case to which subsection (a) or (b) applies the Secretary is authorized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4290f4ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allow as a deduction, credit, or allowance any part of any amount disallowed by such subsection, if he determines that such allowance will not result in the evasion or avoidance of Federal income tax for which the acquisition was made; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4290f4eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to distribute, apportion, or allocate gross income, and distribute, apportion, or allocate the deductions, credits, or allowances the benefit of which was sought to be secured, between or among the corporations, or properties, or parts thereof, involved, and to allow such deductions, credits, or allowances so distributed, apportioned, or allocated, but to give effect to such allowance only to such extent as he determines will not result in the evasion or avoidance of Federal income tax for which the acquisition was made; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4290f4ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to exercise his powers in part under paragraph (1) and in part under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4290f4ed-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/80"},"text":"68A Stat. 80","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s235/c/2"},"text":"Pub. L. 88–272, title II, § 235(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/126"},"text":"78 Stat. 126","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1901(a)(38), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1771"},"text":"90 Stat. 1771","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII/s712/k/8/A"},"text":"Pub. L. 98–369, div. A, title VII, § 712(k)(8)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/952"},"text":"98 Stat. 952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/45"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(45)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4045"},"text":"128 Stat. 4045","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4290f4ee-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4290f4ef-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4290f4f0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" struck out “or acquired on or after "},{"tag":"date","attrib":{"date":"1940-10-08"},"text":"October 8, 1940","children":[],"tail":",” after “persons acquire,” in par. (1) and after “corporation acquires,” in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" added subsec. (b), redesignated former subsec. (b) as (c) and inserted reference to subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/a/38"},"text":"Pub. L. 94–455, § 1901(a)(38)","children":[],"tail":", struck out subsec. (c) relating to presumptions in the case of disproportionate purchase price."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272"},"text":"Pub. L. 88–272","children":[],"tail":" substituted “the Secretary or his delegate may disallow such deduction, credit, or other allowance” for “such deduction, credit or other allowance shall not be allowed”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4290f4f1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4290f4f2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/b"},"text":"section 221(b) of Pub. L. 113–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4290f4f3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII/s712/k/8/C"},"text":"Pub. L. 98–369, div. A, title VII, § 712(k)(8)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/952"},"text":"98 Stat. 952","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tVII/s712/k/8/C"},"text":"“The amendments made by this paragraph [amending this section] shall apply to liquidations after ","children":[{"tag":"date","attrib":{"date":"1983-10-20"},"text":"October 20, 1983","children":[],"tail":", in taxable years ending after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4290f4f4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1964 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s235/d"},"text":"Pub. L. 88–272, title II, § 235(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/127"},"text":"78 Stat. 127","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/88/272/tII/s235/d"},"text":"“The amendments made by subsections (a) and (c) [enacting sections 1561 to 1563 of this title and amending this section and sections 441 and 802 of this title] shall apply with respect to taxable years ending after ","children":[{"tag":"date","attrib":{"date":"1963-12-31"},"text":"December 31, 1963","children":[],"tail":". The amendment made by subsection (b) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1551"},"text":"section 1551 of this title","children":[],"tail":"] shall apply with respect to transfers made after "},{"tag":"date","attrib":{"date":"1963-06-12"},"text":"June 12, 1963","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
