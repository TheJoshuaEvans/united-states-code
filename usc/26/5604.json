{"tag":"section","attrib":{"id":"id463ee192-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5604"},"text":null,"children":[{"tag":"num","attrib":{"value":"5604"},"text":"§ 5604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties relating to marks, brands, and containers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id463ee193-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id463ee194-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5604/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transport, possess, buy, sell, or transfer any distilled spirits unless the immediate container bears the type of closure or other device required by section 5301(d),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee195-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5604/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to defraud the United States, empty a container bearing the closure or other device required by section 5301(d) without breaking such closure or other device,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee196-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5604/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" empty, or cause to be emptied, any distilled spirits from an immediate container bearing any mark or brand required by law without effacing and obliterating such mark or brand as required by section 5206(d),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee197-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5604/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" place any distilled spirits in any bottle, or reuse any bottle for the purpose of containing distilled spirits, which has once been filled and fitted with a closure or other device under the provisions of this chapter, without removing and destroying such closure or other device,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee198-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5604/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully and unlawfully remove, change, or deface any mark, brand, label, or seal affixed to any case of distilled spirits, or to any bottle contained therein,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee199-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5604/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to defraud the United States, purchase, sell, receive with intent to transport, or transport any empty cask or package having thereon any mark or brand required by law to be affixed to any cask or package containing distilled spirits, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46412a8a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5604/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" change or alter any mark or brand on any cask or package containing distilled spirits, or put into any cask or package spirits of greater strength than is indicated by the inspection mark thereon, or fraudulently use any cask or package having any inspection mark thereon, for the purpose of selling other spirits, or spirits of quantity or quality different from the spirits previously inspected,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined not more than $10,000 or imprisoned not more than 5 years, or both, for each such offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46412a8b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions relating to the authority of internal revenue officers to enforce provisions of this section, see sections 5203, 5557, and 7608.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46412a8c-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1401"},"text":"72 Stat. 1401","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/53"},"text":"Pub. L. 96–39, title VIII, § 807(a)(53)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/289"},"text":"93 Stat. 289","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s454/c/11/A"},"t