"href":"/us/pl/98/369/s454/c/11/A"},"text":"Pub. L. 98–369, § 454(c)(11)(A)","children":[],"tail":", in amending subsec. (b) generally, substituted provisions relating to cross references for provisions relating to officers authorized to enforce this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/s807/a/53/A"},"text":"Pub. L. 96–39, § 807(a)(53)(A)","children":[],"tail":", substituted “section 5205(a)(1)” for “section 5205(a)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/s807/a/53/B"},"text":"Pub. L. 96–39, § 807(a)(53)(B)","children":[],"tail":", substituted “section 5205(a)(1)” for “section 5205(a)(1) or (2)” and “section 5205(a)(2)” for “section 5205(a)(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/s807/a/53/C"},"text":"Pub. L. 96–39, § 807(a)(53)(C)","children":[],"tail":", substituted “section 5205(f)” for “section 5205(g)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/s807/a/53/D"},"text":"Pub. L. 96–39, § 807(a)(53)(D)","children":[],"tail":", substituted “section 5205(a)(2)” for “section 5205(a)(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/s807/a/53/E"},"text":"Pub. L. 96–39, § 807(a)(53)(E)","children":[],"tail":", substituted “section 5205(a)” for “section 5205(a)(2) and (3)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46412a92-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"ef