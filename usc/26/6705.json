{"tag":"section","attrib":{"id":"id47321b1a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6705"},"text":null,"children":[{"tag":"num","attrib":{"value":"6705"},"text":"§ 6705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure by broker to provide notice to payors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47321b1b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person required under section 3406(d)(2)(B) to provide notice to any payor who willfully fails to provide such notice to such payor shall pay a penalty of $500 for each such failure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47321b1c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty in addition to other penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any penalty imposed by this section shall be in addition to any other penalty provided by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47321b1d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/67/tI/s104/c/1"},"text":"Pub. L. 98–67, title I, § 104(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-05"},"text":"Aug. 5, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/379"},"text":"97 Stat. 379","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47321b1e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47321b1f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47321b20-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective with respect to payments made after ","children":[{"tag":"date","attrib":{"date":"1983-12-31"},"text":"Dec. 31, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/67/s110/a"},"text":"section 110(a) of Pub. L. 98–67","children":[],"tail":", set out as an Effective Date of 1983 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s31"},"text":"section 31 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
