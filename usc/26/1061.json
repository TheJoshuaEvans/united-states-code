{"tag":"section","attrib":{"id":"id44b31176-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061"},"text":null,"children":[{"tag":"num","attrib":{"value":"1061"},"text":"§ 1061.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership interests held in connection with performance of services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44b31177-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If one or more applicable partnership interests are held by a taxpayer at any time during the taxable year, the excess (if any) of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44b31178-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer’s net long-term capital gain with respect to such interests for such taxable year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b31179-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer’s net long-term capital gain with respect to such interests for such taxable year computed by applying paragraphs (3) and (4) of sections ","children":[{"tag":"ref","attrib":{"idref":"fn002168"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002168"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 1222 by substituting “3 years” for “1 year”,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be treated as short-term capital gain, notwithstanding section 83 or any election in effect under section 83(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44b3117a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent provided by the Secretary, subsection (a) shall not apply to income or gain attributable to any asset not held for portfolio investment on behalf of third party investors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44b3117b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable partnership interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44b3117c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in this paragraph or paragraph (4), the term “applicable partnership interest” means any interest in a partnership which, directly or indirectly, is transferred to (or is held by) the taxpayer in connection with the performance of substantial services by the taxpayer, or any other related person, in any applicable trade or business. The previous sentence shall not apply to an interest held by a person who is employed by another entity that is conducting a trade or business (other than an applicable trade or business) and only provides services to such other entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b3117d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable trade or business","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable trade or business” means any activity conducted on a regular, continuous, and substantial basis which, regardless of whether the activity is conducted in one or more entities, consists, in whole or in part, of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44b3117e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" raising or returning capital, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44b3117f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44b31180-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investing in (or disposing of) specified assets (or identifying specified assets for such investing or disposition), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44b31181-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing specified assets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b31182-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified asset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “specified asset” means securities (as defined in section 475(c)(2) without regard to the last sentence thereof), commodities (as defined in section 475(e)(2)), real estate held for rental or investment, cash or cash equivalents, options or derivative contracts with respect to any of the foregoing, and an interest in a partnership to the extent of the partnership’s proportionate interest in any of the foregoing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b31183-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable partnership interest” shall not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44b31184-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any interest in a partnership directly or indirectly held by a corporation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44b31185-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any capital interest in the partnership which provides the taxpayer with a right to share in partnership capital commensurate with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44b31186-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of capital contributed (determined at the time of receipt of such partnership interest), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44b31187-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of such interest subject to tax under section 83 upon the receipt or vesting of such interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b31188-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third party investor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “third party investor” means a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44b31189-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holds an interest in the partnership which does not constitute property held in connection with an applicable trade or business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44b3118a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not (and has not been) actively engaged, and is (and was) not related to a person so engaged, in (directly or indirectly) providing substantial services described in paragraph (1) for such partnership or any applicable trade or business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44b3118b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of applicable partnership interest to related person","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44b3118c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a taxpayer transfers any applicable partnership interest, directly or indirectly, to a person related to the taxpayer, the taxpayer shall include in gross income (as short term capital gain) the excess (if any) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44b3118d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" so much of the taxpayer’s long-term capital gains with respect to such interest for such taxable year attributable to the sale or exchange of any asset held for not more than 3 years as is allocable to such interest, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44b3118e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount treated as short term capital gain under subsection (a) with respect to the transfer of such interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b3118f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph, a person is related to the taxpayer if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44b31190-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person is a member of the taxpayer’s family within the meaning of section 318(a)(1), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44b31191-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person performed a service within the current calendar year or the preceding three calendar years in any applicable trade or business in which or for which the taxpayer performed a service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44b31192-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require such reporting (at the time and in the manner prescribed by the Secretary) as is necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44b31193-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1061/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue such regulations or other guidance as is necessary or appropriate to carry out the purposes of this section ","children":[{"tag":"ref","attrib":{"idref":"fn002169"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002169"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44b31194-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13309/a/2"},"text":"Pub. L. 115–97, title I, § 13309(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2130"},"text":"131 Stat. 2130","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44b31195-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44b31196-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id44b31197-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1061 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1063"},"text":"section 1063 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44b31198-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44b31199-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13309/c"},"text":"Pub. L. 115–97, title I, § 13309(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2131"},"text":"131 Stat. 2131","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/97/tI/s13309/c"},"text":"“The amendments made by this section [enacting this section and renumbering former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1061"},"text":"section 1061 of this title","children":[],"tail":" as section 1062] shall apply to taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
