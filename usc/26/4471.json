{"tag":"section","attrib":{"id":"id45d856b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4471"},"text":null,"children":[{"tag":"num","attrib":{"value":"4471"},"text":"§ 4471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45d856b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4471/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed a tax of $3 per passenger on a covered voyage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d856b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4471/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By whom paid","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by this section shall be paid by the person providing the covered voyage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d856b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4471/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time of imposition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by this section shall be imposed only once for each passenger on a covered voyage, either at the time of first embarkation or disembarkation in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d856b7-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7504/a"},"text":"Pub. L. 101–239, title VII, § 7504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2362"},"text":"103 Stat. 2362","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45d856b8-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45d856b9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id45d856ba-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4471 was contained in subchapter C of this chapter prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/tIV/s404"},"text":"Pub. L. 89–44, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/149"},"text":"79 Stat. 149","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45d856bb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45d856bc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7504/c"},"text":"Pub. L. 101–239, title VII, § 7504(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2363"},"text":"103 Stat. 2363","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tVII/s7504/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting this subchapter] shall apply to voyages beginning after ","children":[{"tag":"date","attrib":{"date":"1989-12-31"},"text":"December 31, 1989","children":[],"tail":", which were not paid for before such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No deposits required before ","children":[{"tag":"date","attrib":{"date":"1990-04-01"},"text":"april 1, 1990","children":[],"tail":null}],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No deposit of any tax imposed by subchapter B of chapter 36 of the Internal Revenue Code of 1986, as added by this section, shall be required to be made before ","children":[{"tag":"date","attrib":{"date":"1990-04-01"},"text":"April 1, 1990","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
