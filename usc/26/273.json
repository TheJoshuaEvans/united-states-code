{"tag":"section","attrib":{"id":"id4293653b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s273"},"text":null,"children":[{"tag":"num","attrib":{"value":"273"},"text":"§ 273.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Holders of life or terminable interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Amounts paid under the laws of a State, the District of Columbia, a possession of the United States, or a foreign country as income to the holder of a life or terminable interest acquired by gift, bequest, or inheritance shall not be reduced or diminished by any deduction for shrinkage (by whatever name called) in the value of such interest due to the lapse of time.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4293653c-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/83"},"text":"68A Stat. 83","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1901/c/2"},"text":"Pub. L. 94–455, title XIX, § 1901(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1803"},"text":"90 Stat. 1803","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4293653d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4293653e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4293653f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":