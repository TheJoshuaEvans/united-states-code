{"tag":"section","attrib":{"id":"id4397411c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A"},"text":null,"children":[{"tag":"num","attrib":{"value":"468A"},"text":"§ 468A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for nuclear decommissioning costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4397411d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the taxpayer elects the application of this section, there shall be allowed as a deduction for any taxable year the amount of payments made by the taxpayer to a Nuclear Decommissioning Reserve Fund (hereinafter referred to as the “Fund”) during such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4397411e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on amounts paid into Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount which a taxpayer may pay into the Fund for any taxable year shall not exceed the ruling amount applicable to such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4397411f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income and deductions of the taxpayer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43974120-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of amounts distributed","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be includible in the gross income of the taxpayer for any taxable year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43974121-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount distributed from the Fund during such taxable year, other than any amount distributed to pay costs described in subsection (e)(4)(B), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43974122-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except to the extent provided in regulations, amounts properly includible in gross income in the case of any deemed distribution under subsection (e)(6), any termination under subsection (e)(7), or the disposition of any interest in the nuclear powerplant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43974123-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deduction when economic performance occurs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any deduction under subsection (a), there shall be allowable as a deduction for any taxable year the amount of the nuclear decommissioning costs with respect to which economic performance (within the meaning of section 461(h)(2)) occurs during such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43974124-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ruling amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43974125-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowed for any payment to the Fund unless the taxpayer requests, and receives, from the Secretary a schedule of ruling amounts. For purposes of the preceding sentence, the taxpayer shall request a schedule of ruling amounts upon each renewal of the operating license of the nuclear powerplant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43974126-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ruling amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “ruling amount” means, with respect to any taxable year, the amount which the Secretary determines under paragraph (1) to be necessary to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43974127-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fund the total nuclear decommissioning costs with respect to such power plant over the estimated useful life of such power plant, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43974128-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent any excessive funding of such costs or the funding of such costs at a rate more rapid than level funding, taking into account such discount rates as the Secretary deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43974129-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall at least once during the useful life of the nuclear powerplant (or, more frequently, upon the request of the taxpayer) review, and revise if necessary, the schedule of ruling amounts determined under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4397412a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nuclear Decommissioning Reserve Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4397412b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each taxpayer who elects the application of this section shall establish a Nuclear Decommissioning Reserve Fund with respect to each nuclear powerplant to which such election applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4397412c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxation of Fund","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4397412d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby imposed on the gross income of the Fund for any taxable year a tax at the rate of 20 percent, except that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4397412e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there shall not be included in the gross income of the Fund any payment to the Fund with respect to which a deduction is allowable under subsection (a), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4397412f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there shall be allowed as a deduction to the Fund any amount paid by the Fund which is described in paragraph (4)(B) (other than an amount paid to the taxpayer) and which would be deductible under this chapter for purposes of determining the taxable income of a corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43974130-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax in lieu of other taxation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by subparagraph (A) shall be in lieu of any other taxation under this subtitle of the income from assets in the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43974131-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund treated as corporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subtitle F—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43974132-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Fund shall be treated as if it were a corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43974133-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any tax imposed by this paragraph shall be treated as a tax imposed by section 11.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43974134-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions to Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (f), the Fund shall not accept any payments (or other amounts) other than payments with respect to which a deduction is allowable under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43974135-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Fund shall be used exclusively for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43974136-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfying, in whole or in part, any liability of any person contributing to the Fund for the decommissioning of a nuclear powerplant (or unit thereof),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43974137-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay administrative costs (including taxes) and other incidental expenses of the Fund (including legal, accounting, actuarial, and trustee expenses) in connection with the operation of the Fund, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43974138-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that a portion of the Fund is not currently needed for purposes described in subparagraph (A) or (B), making investments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43974139-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions against self-dealing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary, for purposes of section 4951 (and so much of this title as relates to such section), the Fund shall be treated in the same manner as a trust described in section 501(c)(21).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4397413a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualification of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which the Fund violates any provision of this section or section 4951, the Secretary may disqualify such Fund from the application of this section. In any case to which this paragraph applies, the Fund shall be treated as having distributed all of its funds on the date such determination takes effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4397413b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination upon completion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon substantial completion of the nuclear decommissioning of the nuclear powerplant with respect to which a Fund relates, the taxpayer shall terminate such Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4397413c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers into qualified funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4397413d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (b), any taxpayer maintaining a Fund to which this section applies with respect to a nuclear power plant may transfer into such Fund not more than an amount equal to the present value of the portion of the total nuclear decommissioning costs with respect to such nuclear power plant previously excluded for such nuclear power plant under subsection (d)(2)(A) as in effect immediately before the date of the enactment of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4397413e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deduction for amounts transferred","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4397413f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (C), the deduction allowed by subsection (a) for any transfer permitted by this subsection shall be allowed ratably over the remaining estimated useful life (within the meaning of subsection (d)(2)(A)) of the nuclear power plant beginning with the taxable year during which the transfer is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43974140-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of deduction for previously deducted amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowed for any transfer under this subsection of an amount for which a deduction was previously allowed to the taxpayer (or a predecessor) or a corresponding amount was not included in gross income of the taxpayer (or a predecessor). For purposes of the preceding sentence, a ratable portion of each transfer shall be treated as being from previously deducted or excluded amounts to the extent thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43974141-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of qualified funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43974142-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/f/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any transfer permitted by this subsection is made to any Fund to which this section applies, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43974143-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/f/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such Fund is transferred thereafter,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"any deduction under this subsection for taxable years ending after the date that such Fund is transferred shall be allowed to the transferor for the taxable year which includes such date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43974144-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43974145-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/f/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gain or loss not recognized on transfers to Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No gain or loss shall be recognized on any transfer described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43974146-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/f/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of appreciated property to Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If appreciated property is transferred in a transfer described in paragraph (1), the amount of the deduction shall not exceed the adjusted basis of such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43974147-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New ruling amount required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to any transfer unless the taxpayer requests from the Secretary a new schedule of ruling amounts in connection with such transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43974148-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No basis in qualified funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the taxpayer’s basis in any Fund to which this section applies shall not be increased by reason of any transfer permitted by this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43974149-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nuclear powerplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “nuclear powerplant” includes any unit thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4397414a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468A/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time when payments deemed made","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, a taxpayer shall be deemed to have made a payment to the Fund on the last day of a taxable year if such payment is made on account of such taxable year and is made within 2½ months after the close of such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4397414b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s91/c/1"},"text":"Pub. L. 98–369, div. A, title I, § 91(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/604"},"text":"98 Stat. 604","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1807/a/4/A/i"},"text":"Pub. L. 99–514, title XVIII, § 1807(a)(4)(A)(i)","children":[],"tail":", (B)–(E)(vi), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2812"},"text":"100 Stat. 2812","children":[],"tail":", 2813; "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s1917/a"},"text":"Pub. L. 102–486, title XIX, § 1917(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3024"},"text":"106 Stat. 3024","children":[],"tail":", 3025; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1704/j/6"},"text":"Pub. L. 104–188, title I, § 1704(j)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1882"},"text":"110 Stat. 1882","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXIII/s1310/a"},"text":"Pub. L. 109–58, title XIII, § 1310(a)","children":[],"tail":"–(e), "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1007-1009"},"text":"119 Stat. 1007–1009","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4397414c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4397414d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4397414e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this subsection, referred to in subsec. (f)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4397414f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1310/a"},"text":"Pub. L. 109–58, § 1310(a)","children":[],"tail":", reenacted heading without change and amended text of subsec. (b) generally. Prior to amendment, text read as follows: “The amount which a taxpayer may pay into the Fund for any taxable year shall not exceed the lesser of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the amount of nuclear decommissioning costs allocable to the Fund which is included in the taxpayer’s cost of service for ratemaking purposes for such taxable year, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the ruling amount applicable to such taxable year.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1310/c"},"text":"Pub. L. 109–58, § 1310(c)","children":[],"tail":", inserted at end “For purposes of the preceding sentence, the taxpayer shall request a schedule of ruling amounts upon each renewal of the operating license of the nuclear powerplant.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1310/b/2"},"text":"Pub. L. 109–58, § 1310(b)(2)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “fund that portion of the nuclear decommissioning costs of the taxpayer with respect to the nuclear powerplant which bears the same ratio to the total nuclear decommissioning costs with respect to such nuclear powerplant as the period for which the Fund is in effect bears to the estimated useful life of such nuclear powerplant, and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1310/e/1"},"text":"Pub. L. 109–58, § 1310(e)(1)","children":[],"tail":", substituted “rate of 20 percent” for “rate set forth in subparagraph (B)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(B) to (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1310/e/2"},"text":"Pub. L. 109–58, § 1310(e)(2)","children":[],"tail":", (3), redesignated subpars. (C) and (D) as (B) and (C), respectively, and struck out heading and text of former subpar. (B). Text read as follows: “For purposes of subparagraph (A), the rate set forth in this subparagraph is—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) 22 percent in the case of taxable years beginning in calendar year 1994 or 1995, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) 20 percent in the case of taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1310/d"},"text":"Pub. L. 109–58, § 1310(d)","children":[],"tail":", substituted “Except as provided in subsection (f), the Fund” for “The Fund”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1310/b/1"},"text":"Pub. L. 109–58, § 1310(b)(1)","children":[],"tail":", added subsec. (f) and redesignated former subsecs. (f) and (g) as (g) and (h), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" provided that the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/s1917/b/1"},"text":"section 1917(b)(1) of Pub. L. 102–486","children":[],"tail":" shall be applied as if “at a rate” appeared instead of “at the rate” in the material proposed to be stricken. See 1992 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/s1917/b/1"},"text":"Pub. L. 102–486, § 1917(b)(1)","children":[],"tail":", which directed that subpar. (A) be amended by striking “at the rate equal to the highest rate of tax specified in section 11(b)” and inserting “at the rate set forth in subparagraph (B)”, was executed by making the substitution for “at a rate equal to the highest rate of tax specified in section 11(b)”. See 1996 Amendment note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(B) to (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/s1917/b/2"},"text":"Pub. L. 102–486, § 1917(b)(2)","children":[],"tail":", added subpar. (B) and redesignated former subpars. (B) and (C) as (C) and (D), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/s1917/a"},"text":"Pub. L. 102–486, § 1917(a)","children":[],"tail":", struck out before period at end “described in section 501(c)(21)(B)(ii)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1807/a/4/E/i"},"text":"Pub. L. 99–514, § 1807(a)(4)(E)(i)","children":[],"tail":", substituted “this section” for “this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1807/a/4/B"},"text":"Pub. L. 99–514, § 1807(a)(4)(B)","children":[],"tail":", substituted “subsection (e)(4)(B)” for “subsection (e)(2)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1807/a/4/E/ii"},"text":"Pub. L. 99–514, § 1807(a)(4)(E)(ii)","children":[],"tail":", substituted “this section” for “this subsection” in introductory text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1807/a/4/E/iii"},"text":"Pub. L. 99–514, § 1807(a)(4)(E)(iii)","children":[],"tail":", substituted “Reserve Fund” for “Trust Fund” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1807/a/4/E/iv"},"text":"Pub. L. 99–514, § 1807(a)(4)(E)(iv)","children":[],"tail":", substituted “this section” for “this subsection” and “Reserve Fund” for “Trust Fund”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1807/a/4/C"},"text":"Pub. L. 99–514, § 1807(a)(4)(C)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “There is imposed on the gross income of the Fund for any taxable year a tax at a rate equal to the maximum rate in effect under section 11(b), except that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) there shall not be included in the gross income of the Fund any payment to the Fund with respect to which a deduction is allowable under subsection (a), and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) there shall be allowed as a deduction any amount paid by the Fund described in paragraph (4)(B) (other than to the taxpayer).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1807/a/4/D"},"text":"Pub. L. 99–514, § 1807(a)(4)(D)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1807/a/4/E/v"},"text":"Pub. L. 99–514, § 1807(a)(4)(E)(v)","children":[],"tail":", substituted “this section” for “this subsection” in two places and “this paragraph” for “this subparagraph”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1807/a/4/E/vi"},"text":"Pub. L. 99–514, § 1807(a)(4)(E)(vi)","children":[],"tail":", substituted “For purposes of this section, the” for “The”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1807/a/4/A/i"},"text":"Pub. L. 99–514, § 1807(a)(4)(A)(i)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43974150-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43974151-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXIII/s1310/f"},"text":"Pub. L. 109–58, title XIII, § 1310(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1009"},"text":"119 Stat. 1009","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/58/tXIII/s1310/f"},"text":"“The amendments made by this section [amending this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2005-12-31"},"text":"December 31, 2005","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43974152-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s1917/c"},"text":"Pub. L. 102–486, title XIX, § 1917(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3025"},"text":"106 Stat. 3025","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/486/tXIX/s1917/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsection","children":[],"tail":" (a).—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by subsection (a) [amending this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1992-12-31"},"text":"December 31, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsection","children":[],"tail":" (b).—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsection (b) [amending this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1993-12-31"},"text":"December 31, 1993","children":[],"tail":". Section 15 of the Internal Revenue Code of 1986 shall not apply to any change in rate resulting from the amendment made by subsection (b).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43974153-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id43974154-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", with respect to taxable years ending after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s91/g/5"},"text":"section 91(g)(5) of Pub. L. 98–369","children":[],"tail":", as amended, set out as an Effective Date of 1984 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s461"},"text":"section 461 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id43974155-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1800–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id43974156-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transitional Rule","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1807/a/4/A/ii"},"text":"Pub. L. 99–514, title XVIII, § 1807(a)(4)(A)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2812"},"text":"100 Stat. 2812","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXVIII/s1807/a/4/A/ii"},"text":"“To the extent provided in regulations prescribed by the Secretary of the Treasury or his delegate, subsection (g) of section 468A of the Internal Revenue Code of 1954 [now 1986] (as added by clause (i)) shall be applied with respect to any payment on account of a taxable year beginning before ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":", as if it did not contain the requirement that the payment be made within 2½ months after the close of the taxable year. Such regulations may provide that, to the extent such payment to the Fund is made more than 2½ months after the close of the taxable year, any adjustment to the tax attributable to such payment shall not affect the amount of interest payable with respect to periods before the payment is made. Such regulations may provide appropriate adjustments to the deduction allowed under such section 468A for any such taxable year to take into account the fact that the payment to the Fund is made more than 2½ months after the close of the taxable year.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
