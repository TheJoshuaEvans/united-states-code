{"tag":"section","attrib":{"id":"id4747787e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7272"},"text":null,"children":[{"tag":"num","attrib":{"value":"7272"},"text":"§ 7272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for failure to register or reregister","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4747787f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7272/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person (other than persons required to register under subtitle E, or persons engaging in a trade or business on which a special tax is imposed by such subtitle) who fails to register with the Secretary as required by this title or by regulations issued thereunder shall be liable to a penalty of $50 ($10,000 in the case of a failure to register or reregister under section 4101).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47477880-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7272/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions relating to persons required by this title to register, see sections 4101, 4412, and 7011.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47477881-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/866"},"text":"68A Stat. 866","children":[],"tail":"; "},