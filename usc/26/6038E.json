{"tag":"section","attrib":{"id":"id4669c179-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038E"},"text":null,"children":[{"tag":"num","attrib":{"value":"6038E"},"text":"§ 6038E.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information with respect to assignment of lower rates or refunds by foreign producers of beer, wine, and distilled spirits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any foreign producer that elects to make an assignment described in section 5001(c), 5041(c), or 5051(a) shall provide such information, at such time and in such manner, as the Secretary may prescribe in order to make such assignment, including information about the controlled group structure of such foreign producer.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4669c17a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/tI/s107/d/1"},"text":"Pub. L. 116–260, div. EE, title I, § 107(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3048"},"text":"134 Stat. 3048","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4669c17b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4669c17c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4669c17d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/tI/s107/d/3"},"text":"Pub. L. 116–260, div. EE, title I, § 107(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3048"},"text":"134 Stat. 3048","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dEE/tI/s107/d/3"},"text":"“The amendments made by this subsection [enacting ths section] shall apply to elections to make an assignment under section 5001(c), 5041(c), or 5051(a) of the Internal Revenue Code of 1986 after ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
