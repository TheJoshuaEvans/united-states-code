{"tag":"section","attrib":{"id":"id4779aac2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7610"},"text":null,"children":[{"tag":"num","attrib":{"value":"7610"},"text":"§ 7610.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees and costs for witnesses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4779aac3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7610/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall by regulations establish the rates and conditions under which payment may be made of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4779aac4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7610/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fees and mileage to persons who are summoned to appear before the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4779aac5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7610/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimbursement for such costs that are reasonably necessary which have been directly incurred in searching for, reproducing, or transporting books, papers, records, or other data required to be produced by summons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4779aac6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7610/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No payment may be made under paragraph (2) of subsection (a) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4779aac7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7610/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person with respect to whose liability the summons is issued has a proprietary interest in the books, papers, records or other data required to be produced, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4779aac8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7610/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person summoned is the person with respect to whose liability the summons is issued or an officer, employee, agent, accountant, or attorney of such person who, at the time the summons is served, is acting as such.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4779aac9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7610/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summons to which section applies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section applies with respect to any summons authorized under section 6420(e)(2), 6421(g)(2), 6427(j)(2), or 7602.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4779aaca-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXII/s1205/a"},"text":"Pub. L. 94–455, title XII, § 1205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":