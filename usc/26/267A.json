{"tag":"section","attrib":{"id":"id4290f4c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A"},"text":null,"children":[{"tag":"num","attrib":{"value":"267A"},"text":"§ 267A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain related party amounts paid or accrued in hybrid transactions or with hybrid entities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4290f4c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowed under this chapter for any disqualified related party amount paid or accrued pursuant to a hybrid transaction or by, or to, a hybrid entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4290f4c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualified related party amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4290f4c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualified related party amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “disqualified related party amount” means any interest or royalty paid or accrued to a related party to the extent that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4290f4c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount is not included in the income of such related party under the tax law of the country of which such related party is a resident for tax purposes or is subject to tax, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4290f4c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such related party is allowed a deduction with respect to such amount under the tax law of such country.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term shall not include any payment to the extent such payment is included in the gross income of a United States shareholder under section 951(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4290f4c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related party","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “related party” means a related person as defined in section 954(d)(3), except that such section shall be applied with respect to the person making the payment described in paragraph (1) in lieu of the controlled foreign corporation otherwise referred to in such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4290f4c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hybrid transaction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “hybrid transaction” means any transaction, series of transactions, agreement, or instrument one or more payments with respect to which are treated as interest or royalties for purposes of this chapter and which are not so treated for purposes the tax law of the foreign country of which the recipient of such payment is resident for tax purposes or is subject to tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4290f4ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hybrid entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “hybrid entity” means any entity which is either—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4290f4cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treated as fiscally transparent for purposes of this chapter but not so treated for purposes of the tax law of the foreign country of which the entity is resident for tax purposes or is subject to tax, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4290f4cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treated as fiscally transparent for purposes of such tax law but not so treated for purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4290f4cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall issue such regulations or other guidance as may be necessary or appropriate to carry out the purposes of this section, including regulations or other guidance providing for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4290f4ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules for treating certain conduit arrangements which involve a hybrid transaction or a hybrid entity as subject to subsection (a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4290f4cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules for the application of this section to branches or domestic entities,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4290f4d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules for treating certain structured transactions as subject to subsection (a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4290f4d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules for treating a tax preference as an exclusion from income for purposes of applying subsection (b)(1) if such tax preference has the effect of reducing the generally applicable statutory rate by 25 percent or more,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4290f4d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules for treating the entire amount of interest or royalty paid or accrued to a related party as a disqualified related party amount if such amount is subject to a participation exemption system or other system which provides for the exclusion or deduction of a substantial portion of such amount,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4290f4d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules for determining the tax residence of a foreign entity if the entity is otherwise considered a resident of more than one country or of no country,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4290f4d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" exceptions from subsection (a) with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4290f4d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/e/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cases in which the disqualified related party amount is taxed under the laws of a foreign country other than the country of which the related party is a resident for tax purposes, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4290f4d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/e/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other cases which the Secretary determines do not present a risk of eroding the Federal tax base,","children":[{"tag":"ref","attrib":{"idref":"fn002097"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002097"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “and”."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4290f4d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s267A/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements for record keeping and information reporting in addition to any requirements imposed by section 6038A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4290f4d8-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s14222/a"},"text":"Pub. L. 115–97, title I, § 14222(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2219"},"text":"131 Stat. 2219","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4290f4d9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4290f4da-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4290f4db-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s14222/c"},"text":"Pub. L. 115–97, title I, § 14222(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2220"},"text":"131 Stat. 2220","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/97/tI/s14222/c"},"text":"“The amendments made by this section [enacting this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
