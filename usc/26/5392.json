{"tag":"section","attrib":{"id":"id4639ff03-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5392"},"text":null,"children":[{"tag":"num","attrib":{"value":"5392"},"text":"§ 5392.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4639ff04-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5392/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard wine","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter the term “standard wine” means natural wine, specially sweetened natural wine, special natural wine, and standard agricultural wine, produced in accordance with the provisions of sections 5381, 5385, 5386, and 5387, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4639ff05-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5392/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Heavy bodied blending wine","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter the term “heavy bodied blending wine” means wine made from fruit without added sugar, and with or without added wine spirits, and conforming to the definition of natural wine in all respects except as to maximum total solids content.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4639ff06-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5392/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pure sugar","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter the term “pure sugar” means pure refined sugar, suitable for human consumption, having a dextrose equivalent of not less than 95 percent on a dry basis, and produced from cane, beets, or fruit, or from grain or other sources of starch. Invert sugar syrup produced from such pure sugar by recognized methods of inversion may be used to prepare any sugar syrup, or solution of water and pure sugar, authorized in this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4639ff07-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5392/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total solids","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter the term “total solids”, in the case of wine, means the degrees Brix of the dealcoholized wine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4639ff08-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5392/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Same kind of fruit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter the term “same kind of fruit” includes, in the case of grapes, all of the several species and varieties of grapes. In the case of fruits other than grapes, this term includes all of the several species and varieties of any given kind; except that this shall not preclude a more precise identification of the composition of the product for the purpose of its designation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4639ff09-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5392/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Own production","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter the term “own production”, when used with reference to wine in a bonded wine cellar, means wine produced by fermentation in the same bonded wine cellar, whether or not produced by a predecessor in interest at such bonded wine cellar. This term may also include, under regulations, wine produced by fermentation in bonded wine cellars owned or controlled by the same or affiliated persons or firms when located within the same State; the term “affiliated” shall be deemed to include any one or more bonded wine cellar proprietors associated as members of any farm cooperative, or any one or more bonded wine cellar proprietors affiliated within the meaning of section 117(a)(5) of the Federal Alcohol Administration Act, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t27/s211"},"text":"27 U.S.C. 211","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4639ff0a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5392/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liquid sugar","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter the term “liquid sugar” means a substantially colorless pure sugar and water solution containing not less than 60 percent pure sugar by weight (60 degrees Brix.)","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4639ff0b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1387"},"text":"72 Stat. 1387","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tVIII/s806/b/3"},"text":"Pub. L. 89–44, title VIII, § 806(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/163"},"text":"79 Stat. 163","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1905/a/21"},"text":"Pub. L. 94–455, title XIX, § 1905(a)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1820"},"text":"90 Stat. 1820","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/246"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(246)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1195"},"text":"132 Stat. 1195","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4639ff0c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4639ff0d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4639ff0e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5392, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/672"},"text":"68A Stat. 672","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4639ff0f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “section 117(a)(5)” for “section 17(a)(5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “"},{"tag":"ref","attrib":{"href":"/us/stat/49/990"},"text":"49 Stat. 990","children":[],"tail":";” before “"},{"tag":"ref","attrib":{"href":"/us/usc/t27/s211"},"text":"27 U.S.C. 211","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s806/b/3/A"},"text":"Pub. L. 89–44, § 806(b)(3)(A)","children":[],"tail":", added fruit, grain, or other sources of starch to cane and beets as sources of “pure sugar”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s806/b/3/B"},"text":"Pub. L. 89–44, § 806(b)(3)(B)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4639ff10-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"headin