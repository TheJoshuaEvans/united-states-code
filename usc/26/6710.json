{"tag":"section","attrib":{"id":"id4734646b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6710"},"text":null,"children":[{"tag":"num","attrib":{"value":"6710"},"text":"§ 6710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to disclose that contributions are nondeductible","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4734646c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6710/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If there is a failure to meet the requirement of section 6113 with respect to a fundraising solicitation by (or on behalf of) an organization to which section 6113 applies, such organization shall pay a penalty of $1,000 for each day on which such a failure occurred. The maximum penalty imposed under this subsection on failures by any organization during any calendar year shall not exceed $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4734646d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6710/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable cause exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed under this section with respect to any failure if it is shown that such failure is due to reasonable cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4734646e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6710/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" $10,000 limitation not to apply where intentional disregard","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any failure to which subsection (a) applies is due to intentional disregard of the requirement of section 6113—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4734646f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6710/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the penalty under subsection (a) for the day on which such failure occurred shall be the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47346470-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6710/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47346471-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6710/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the aggregate cost of the solicitations which occurred on such day and with respect to which there was such a failure,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47346472-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6710/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the $10,000 limitation of subsection (a) shall not apply to any penalty under subsection (a) for the day on which such failure occurred, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47346473-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6710/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such penalty shall not be taken into account in applying such limitation to other penalties under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47346474-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6710/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Day on which failure occurs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, any failure to meet the requirement of section 6113 with respect to a solicitation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47346475-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6710/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by television or radio, shall be treated as occurring when the solicitation was telecast or broadcast,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47346476-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6710/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by mail, shall be treated as occurring when the solicitation was mailed,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47346477-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6710/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not by mail but in written or printed form, shall be treated as occurring when the solicitation was distributed, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47346478-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6710/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by telephone, shall be treated as occurring when the solicitation was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47346479-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10701/b"},"text":"Pub. L. 100–203, title X, § 10701(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-458"},"text":"101 Stat. 1330–458","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4734647a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4734647b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4734647c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to solicitations after ","children":[{"tag":"date","attrib":{"date":"1988-01-31"},"text":"Jan. 31, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/s10701/d"},"text":"section 10701(d) of Pub. L. 100–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6113"},"text":"section 6113 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
