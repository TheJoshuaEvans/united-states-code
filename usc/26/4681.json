{"tag":"section","attrib":{"id":"id45e1cce5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4681"},"text":null,"children":[{"tag":"num","attrib":{"value":"4681"},"text":"§ 4681.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45e1cce6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4681/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby imposed a tax on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45e1cce7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4681/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any ozone-depleting chemical sold or used by the manufacturer, producer, or importer thereof, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e1cce8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4681/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any imported taxable product sold or used by the importer thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45e1cce9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4681/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45e1ccea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4681/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ozone-depleting chemicals","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45e1cceb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4681/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the tax imposed by subsection (a) on each pound of ozone-depleting chemical shall be an amount equal to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45e1ccec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4681/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the base tax amount, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45e1cced-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4681/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ozone-depletion factor for such chemical.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45e1ccee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4681/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Base tax amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The base tax amount for purposes of subparagraph (A) with respect to any sale or use during any calendar year after 1995 shall be $5.35 increased by 45 cents for each year after 1995.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e1ccef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4681/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imported taxable product","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45e1ccf0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4681/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the tax imposed by subsection (a) on any imported taxable product shall be the amount of tax which would have been imposed by subsection (a) on the ozone-depleting chemicals used as materials in the manufacture or production of such product if such ozone-depleting chemicals had been sold in the United States on the date of the sale of such imported taxable product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45e1ccf1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4681/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain rules to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of paragraphs (2) and (3) of section 4671(b) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45e1ccf2-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7506/a"},"text":"Pub. L. 101–239, title VII, § 7506(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2364"},"text":"103 Stat. 2364","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11203/c"},"text":"Pub. L. 101–508, title XI, § 11203(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-422"},"text":"104 Stat. 1388–422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s1931/a"},"text":"Pub. L. 102–486, title XIX, § 1931(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3029"},"text":"106 Stat. 3029","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIV/s1432/c/1"},"text":"Pub. L. 105–34, title XIV, § 1432(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1050"},"text":"111 Stat. 1050","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45e1ccf3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45e1ccf4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id45e1ccf5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4681, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/510/tII/s231/a"},"text":"Pub. L. 96–510, title II, § 231(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2804"},"text":"94 Stat. 2804","children":[],"tail":", was contained in subchapter C of this chapter prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/tV/s514/a/1"},"text":"Pub. L. 99–499, title V, § 514(a)(1)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1767"},"text":"100 Stat. 1767","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"Oct. 1, 1983","children":[],"tail":", with provision for waiver of statute of limitations on claims for overpayment."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45e1ccf6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" added subpar. (B) and struck out heading and text of former subpar. (B). Text read as follows: “The base tax amount for purposes of subparagraph (A) with respect to any sale or use during a calendar year before 1996 with respect to any ozone-depleting chemical is the amount determined under the following table for such calendar year:"}],"tail":"\n"},{"tag":"html:table","attrib":{"width":"50%","id":"id45e1ccf7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":"“Calendar year:","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":"Base tax amount:","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" 1993","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"3.35 ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" 1994","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"4.35 ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" 1995","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5.35.”","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" struck out heading and text of subpar. (C). Text read as follows: “The base tax amount for purposes of subparagraph (A) with respect to any sale or use of an ozone-depleting chemical during a calendar year after the last year specified in the table under subparagraph (B) applicable to such chemical shall be the base tax amount for such last year increased by 45 cents for each year after such last year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":" amended subpar. (B) generally, substituting present provisions for former provisions which provided for base tax amounts in cl. (i) of initially listed chemicals for 1990 to 1994 and in cl. (ii) of newly listed chemicals for 1991 to 1995."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" amended subpar. (B) generally, designating existing provision as cl. (i), inserting “with respect to any ozone-depleting chemical other than a newly listed chemical (as defined in section 4682(d)(3)(C))”, and adding cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" amended subpar. (C) generally. Prior to amendment, subpar. (C) read as follows: “The base tax amount for purposes of subparagraph (A) with respect to any sale or use during a calendar year after 1994 shall be the base tax amount for 1994 increased by 45 cents for each year after 1994.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45e1ccf8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45e1ccf9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s1931/d"},"text":"Pub. L. 102–486, title XIX, § 1931(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3029"},"text":"106 Stat. 3029","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/486/tXIX/s1931/d"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4682"},"text":"section 4682 of this title","children":[],"tail":"] shall apply to taxable chemicals sold or used on or after "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45e1ccfa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11203/e"},"text":"Pub. L. 101–508, title XI, § 11203(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-423"},"text":"104 Stat. 1388–423","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/508/tXI/s11203/e"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4682"},"text":"section 4682 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"1991-01-01"},"text":"January 1, 1991","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45e1ccfb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7506/c"},"text":"Pub. L. 101–239, title VII, § 7506(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2369"},"text":"103 Stat. 2369","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tVII/s7506/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting this subchapter] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1990-01-01"},"text":"January 1, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No deposits required before ","children":[{"tag":"date","attrib":{"date":"1990-04-01"},"text":"april 1, 1990","children":[],"tail":null}],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No deposit of any tax imposed by subchapter D of chapter 38 of the Internal Revenue Code of 1986, as added by this section, shall be required to be made before ","children":[{"tag":"date","attrib":{"date":"1990-04-01"},"text":"April 1, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of changes in international agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury or his delegate shall notify the Committee on Ways and Means of the House of Representatives and the Committee on Finance of the Senate of changes in the Montreal Protocol and of other international agreements to which the United States is a signatory relating to ozone-depleting chemicals.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
