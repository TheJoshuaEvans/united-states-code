{"tag":"section","attrib":{"id":"id41458864-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s80"},"text":null,"children":[{"tag":"num","attrib":{"value":"80"},"text":"§ 80.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration of value of certain securities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id41458865-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s80/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a domestic corporation subject to the tax imposed by section 11 or 801, if the value of any security (as defined in section 165(g)(2))—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41458866-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s80/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which became worthless by reason of the expropriation, intervention, seizure, or similar taking by the government of any foreign country, any political subdivision thereof, or any agency or instrumentality of the foregoing of property to which such security was related, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41458867-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s80/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which was taken into account as a loss from the sale or exchange of a capital asset or with respect to which a deduction for a loss was allowed under section 165,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is restored in whole or in part during any taxable year by reason of any recovery of money or other property in respect of the property to which such security was related, the value so restored (to the extent that, when added to the value so restored during prior taxable years, it does not exceed the amount of the loss described in paragraph (2)) shall, except as provided in subsection (b), be included in gross income for the taxable year in which such restoration occurs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41458868-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s80/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction for failure to receive tax benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount otherwise includible in gross income under subsection (a) in respect of any security shall be reduced by an amount equal to the amount (if any) of the loss described in subsection (a)(2) which did not result in a reduction of the taxpayer’s tax under this subtitle for any taxable year, determined under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41458869-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s80/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Character of income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subtitle—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4145886a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s80/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the amount included in gross income under this section shall be treated as ordinary income.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4145886b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s80/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the loss described in subsection (a)(2) was taken into account as a loss from the sale or exchange of a capital asset, the amount included in gross income under this section shall be treated as long-term capital gain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4145886c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s80/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment under foreign expropriation loss recovery provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to any recovery of a foreign expropriation loss to which section 1351 applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4145886d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/384/s1/b/1"},"text":"Pub. L. 89–384, § 1(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-04-08"},"text":"Apr. 8, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/101"},"text":"80 Stat. 101","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1901(b)(3)(K), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1793"},"text":"90 Stat. 1793","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tII/s211/b/2"},"text":"Pub. L. 98–369, div. A, title II, § 211(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/754"},"text":"98 Stat. 754","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4145886e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4145886f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id41458870-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “801” for “802”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/b/3/K"},"text":"Pub. L. 94–455, § 1901(b)(3)(K)","children":[],"tail":", substituted “ordinary income” for “gain from the sale or exchange of property which is neither a capital asset nor property described in section 1231”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id41458871-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41458872-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"Dec. 31, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s215"},"text":"section 215 of Pub. L. 98–369","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41458873-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/b/3/K"},"text":"section 1901(b)(3)(K) of Pub. L. 94–455","children":[],"tail":" applicable with respect to taxable years beginning after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"Dec. 31, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/d"},"text":"section 1901(d) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id41458874-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/384/s1/b/3"},"text":"Pub. L. 89–384, § 1(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-04-08"},"text":"Apr. 8, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/102"},"text":"80 Stat. 102","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"“The amendments made by this subsection [enacting this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1965-12-31"},"text":"December 31, 1965","children":[],"tail":", but only with respect to losses described in section 80(a)(2) of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] (as added by paragraph (1) of this subsection) which were sustained after "},{"tag":"date","attrib":{"date":"1958-12-31"},"text":"December 31, 1958","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
