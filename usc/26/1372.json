{"tag":"section","attrib":{"id":"id44f5bee2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1372"},"text":null,"children":[{"tag":"num","attrib":{"value":"1372"},"text":"§ 1372.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership rules to apply for fringe benefit purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44f5bee3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1372/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of applying the provisions of this subtitle which relate to employee fringe benefits—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f5bee4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1372/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the S corporation shall be treated as a partnership, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f5bee5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1372/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any 2-percent shareholder of the S corporation shall be treated as a partner of such partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f5bee6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1372/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2-percent shareholder defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “2-percent shareholder” means any person who owns (or is considered as owning within the meaning of section 318) on any day during the taxable year of the S corporation more than 2 percent of the outstanding stock of such corporation or stock possessing more than 2 percent of the total combined voting power of all stock of such corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44f5bee7-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/354/s2"},"text":"Pub. L. 97–354, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"Oct. 19, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1682"},"text":"96 Stat. 1682","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44f5bee8-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44f5bee9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id44f5beea-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1372, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s64/a"},"text":"Pub. L. 85–866, title I, § 64(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1650"},"text":"72 Stat. 1650","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/87/29/s2"},"text":"Pub. L. 87–29, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-05-04"},"text":"May 4, 1961","children":[],"ta