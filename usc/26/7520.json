{"tag":"section","attrib":{"id":"id47700e36-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7520"},"text":null,"children":[{"tag":"num","attrib":{"value":"7520"},"text":"§ 7520.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Valuation tables","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47700e37-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7520/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this title, the value of any annuity, any interest for life or a term of years, or any remainder or reversionary interest shall be determined—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47700e38-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7520/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under tables prescribed by the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700e39-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7520/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by using an interest rate (rounded to the nearest 2/10ths of 1 percent) equal to 120 percent of the Federal midterm rate in effect under section 1274(d)(1) for the month in which the valuation date falls.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If an income, estate, or gift tax charitable contribution is allowable for any part of the property transferred, the taxpayer may elect to use such Federal midterm rate for either of the 2 months preceding the month in which the valuation date falls for purposes of paragraph (2). In the case of transfers of more than 1 interest in the same property with respect to which the taxpayer may use the same rate under paragraph (2), the taxpayer shall use the same rate with respect to each such interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47700e3a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7520/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section not to apply for certain purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply for purposes of part I of subchapter D of chapter 1 or any other provision specified in regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47700e3b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7520/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tables","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47700e3c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7520/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tables prescribed by the Secretary for purposes of subsection (a) shall contain valuation factors for a series of interest rate categories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700e3d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7520/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision for recent mortality charges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall revise the initial tables prescribed for purposes of subsection (a) to take into account the most recent mortality experience available as of the time of such revision. Such tables shall be revised not less frequently than once each 10 years to take into account the most recent mortality experience available as of the time of the revision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47700e3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7520/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Valuation date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “valuation date” means the date as of which the valuation is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47700e3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7520/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tables to include formulas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “tables” includes formulas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47700e40-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tV/s5031/a"},"text":"Pub. L. 100–647, title V, § 5031(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3668"},"text":"102 Stat. 3668","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/118"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(118)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4054"},"text":"128 Stat. 4054","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47700e41-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47700e42-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id47700e43-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 7520 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7521"},"text":"section 7521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47700e44-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" redesignated par. (3) as (2), substituted “The Secretary” for “Not later than "},{"tag":"date","attrib":{"date":"1989-12-31"},"text":"December 31, 1989","children":[],"tail":", the Secretary” and struck out “thereafter” after “once each 10 years”, and struck out former par. (2). Prior to amendment, text of par. (2) read as follows: “Not later than the day 3 months after the date of the enactment of this section, the Secretary shall prescribe initial tables for purposes of subsection (a). Such tables may be based on the same mortality experience as used for purposes of section 2031 on the date of the enactment of this section.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47700e45-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47700e46-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/b"},"text":"section 221(b) of Pub. L. 113–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47700e47-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tV/s5031/c"},"text":"Pub. L. 100–647, title V, § 5031(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3669"},"text":"102 Stat. 3669","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tV/s5031/c"},"text":"“The amendments made by this section [enacting this section] shall apply in cases where the date as of which the valuation is to be made occurs on or after the 1st day of the 6th calendar month beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
