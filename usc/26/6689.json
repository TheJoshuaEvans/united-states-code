{"tag":"section","attrib":{"id":"id472d38a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6689"},"text":null,"children":[{"tag":"num","attrib":{"value":"6689"},"text":"§ 6689.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to file notice of redetermination of foreign tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id472d38a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6689/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the taxpayer fails to notify the Secretary (on or before the date prescribed by regulations for giving such notice) of a foreign tax redetermination, unless it is shown that such failure is due to reasonable cause and not due to willful neglect, there shall be added to the deficiency attributable to such redetermination an amount (not in excess of 25 percent of the deficiency) determined as follows—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472d38a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6689/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 percent of the deficiency if the failure is for not more than 1 month, with","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472d38a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6689/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an additional 5 percent of the deficiency for each month (or fraction thereof) during which the failure continues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472d38a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6689/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign tax redetermination defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “foreign tax redetermination” means any redetermination for which a notice is required under subsection (c) of section 905 or paragraph (2) of section 404A(g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id472d38aa-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/603/s2/c/2"},"text":"Pub. L. 96–603, § 2(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3509"},"text":"94 Stat. 3509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id472d38ab-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id472d38ac-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id472d38ad-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6689, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/17/s3/d/2"},"text":"Pub. L. 93–17, § 3(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-04-10"},"text":"Apr. 10, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/16"},"text":"87 Stat. 16","children":[],"tail":", related to failure by certain foreign issuers and obligors to comply with United States investment equalization tax requirements, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1904/b/10/E/i"},"text":"Pub. L. 94–455, title XIX, § 1904(b)(10)(E)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1817"},"text":"90 Stat. 1817","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id472d38ae-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id472d38af-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For applicability of section with respect to employer contributions or accruals for taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1979-12-31"},"text":"Dec. 31, 1979","children":[],"tail":", election to apply amendments retroactively with respect to foreign subsidiaries, allowance of prior deductions in case of certain funded branch plans, and time and manner for making elections, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/603/s2/e"},"text":"section 2(e) of Pub. L. 96–603","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s404A"},"text":"section 404A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
