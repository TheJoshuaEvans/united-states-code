{"tag":"section","attrib":{"id":"id474ea321-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426"},"text":null,"children":[{"tag":"num","attrib":{"value":"7426"},"text":"§ 7426.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil actions by persons other than taxpayers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id474ea322-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions permitted","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id474ea323-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wrongful levy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a levy has been made on property or property has been sold pursuant to a levy, any person (other than the person against whom is assessed the tax out of which such levy arose) who claims an interest in or lien on such property and that such property was wrongfully levied upon may bring a civil action against the United States in a district court of the United States. Such action may be brought without regard to whether such property has been surrendered to or sold by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474ea324-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surplus proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If property has been sold pursuant to a levy, any person (other than the person against whom is assessed the tax out of which such levy arose) who claims an interest in or lien on such property junior to that of the United States and to be legally entitled to the surplus proceeds of such sale may bring a civil action against the United States in a district court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474ea325-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substituted sale proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If property has been sold pursuant to an agreement described in section 6325(b)(3) (relating to substitution of proceeds of sale), any person who claims to be legally entitled to all or any part of the amount held as a fund pursuant to such agreement may bring a civil action against the United States in a district court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474ea326-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substitution of value","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a certificate of discharge is issued to any person under section 6325(b)(4) with respect to any property, such person may, within 120 days after the day on which such certificate is issued, bring a civil action against the United States in a district court of the United States for a determination of whether the value of the interest of the United States (if any) in such property is less than the value determined by the Secretary. No other action may be brought by such person for such a determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id474ea327-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjudication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The district court shall have jurisdiction to grant only such of the following forms of relief as may be appropriate in the circumstances:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id474ea328-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a levy or sale would irreparably injure rights in property which the court determines to be superior to rights of the United States in such property, the court may grant an injunction to prohibit the enforcement of such levy or to prohibit such sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474ea329-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the court determines that such property has been wrongfully levied upon, the court may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id474ea32a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" order the return of specific property if the United States is in possession of such property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id474ea32b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant a judgment for the amount of money levied upon; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id474ea32c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if such property was sold, grant a judgment for an amount not exceeding the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4751142d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount received by the United States from the sale of such property, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4751142e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of such property immediately before the levy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For the purposes of subparagraph (C), if the property was declared purchased by the United States at a sale pursuant to section 6335(e) (relating to manner and conditions of sale), the United States shall be treated as having received an amount equal to the minimum price determined pursuant to such section or (if larger) the amount received by the United States from the resale of such property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4751142f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surplus proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the court determines that the interest or lien of any party to an action under this section was transferred to the proceeds of a sale of such property, the court may grant a judgment in an amount equal to all or any part of the amount of the surplus proceeds of such sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47511430-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substituted sale proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the court determines that a party has an interest in or lien on the amount held as a fund pursuant to an agreement described in section 6325(b)(3) (relating to substitution of proceeds of sale), the court may grant a judgment in an amount equal to all or any part of the amount of such fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47511431-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substitution of value","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the court determines that the Secretary’s determination of the value of the interest of the United States in the property for purposes of section 6325(b)(4) exceeds the actual value of such interest, the court shall grant a judgment ordering a refund of the amount deposited, and a release of the bond, to the extent that the aggregate of the amounts thereof exceeds such value determined by the court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47511432-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Validity of assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of an adjudication under this section, the assessment of tax upon which the interest or lien of the United States is based shall be conclusively presumed to be valid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47511433-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on rights of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No action may be maintained against any officer or employee of the United States (or former officer or employee) or his personal representative with respect to any acts for which an action could be maintained under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47511434-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substitution of United States as party","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an action, which could be brought against the United States under this section, is improperly brought against any officer or employee of the United States (or former officer or employee) or his personal representative, the court shall order, upon such terms as are just, that the pleadings be amended to substitute the United States as a party for such officer or employee as of the time such action was commenced upon proper service of process on the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47511435-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision inapplicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of section 7422(a) (relating to prohibition of suit prior to filing claim for refund) shall not apply to actions under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47511436-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Interest shall be allowed at the overpayment rate established under section 6621—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47511437-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a judgment pursuant to subsection (b)(2)(B), from the date the Secretary receives the money wrongfully levied upon to the date of payment of such judgment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47511438-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a judgment pursuant to subsection (b)(2)(C), from the date of the sale of the property wrongfully levied upon to the date of payment of such judgment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47511439-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a judgment pursuant to subsection (b)(5) which orders a refund of any amount, from the date the Secretary received such amount to the date of payment of such judgment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4751143a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of damages permitted in certain cases","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4751143b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (b), if, in any action brought under this section, there is a finding that any officer or employee of the Internal Revenue Service recklessly or intentionally, or by reason of negligence, disregarded any provision of this title the defendant shall be liable to the plaintiff in an amount equal to the lesser of $1,000,000 ($100,000 in the case of negligence) or the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4751143c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actual, direct economic damages sustained by the plaintiff as a proximate result of the reckless or intentional or negligent disregard of any provision of this title by the officer or employee (reduced by any amount of such damages awarded under subsection (b)); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4751143d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4751143e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement that administrative remedies be exhausted; mitigation; period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rules of section 7433(d) shall apply for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4751143f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Claims pursuant to this section shall be payable out of funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1304"},"text":"section 1304 of title 31","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47511440-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7426/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For period of limitation, see section 6532(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47511441-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/719/tI/s110/a"},"text":"Pub. L. 89–719, title I, § 110(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1142"},"text":"80 Stat. 1142","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/625/s7/a/2/E"},"text":"Pub. L. 93–625, § 7(a)(2)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2115"},"text":"88 Stat. 2115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s350/a"},"text":"Pub. L. 97–248, title III, § 350(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/639"},"text":"96 Stat. 639","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1511/c/16"},"text":"Pub. L. 99–514, title XV, § 1511(c)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2745"},"text":"100 Stat. 2745","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII"},"text":"Pub. L. 105–206, title III","children":[],"tail":", §§ 3102(b), 3106(b)(1), (2), "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/730"},"text":"112 Stat. 730","children":[],"tail":", 733.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47511442-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47511443-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47511444-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3106/b/1"},"text":"Pub. L. 105–206, § 3106(b)(1)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3106/b/2/A"},"text":"Pub. L. 105–206, § 3106(b)(2)(A)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3106/b/2/B"},"text":"Pub. L. 105–206, § 3106(b)(2)(B)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h), (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3102/b"},"text":"Pub. L. 105–206, § 3102(b)","children":[],"tail":", added subsec. (h) and redesignated former subsec. (h) as (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “the overpayment rate established under section 6621” for “an annual rate established under section 6621”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" inserted “if such property was sold,” before “grant a judgment” and “the greater of—” after “not exceeding”, redesignated remaining provisions as cl. (i), and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/625"},"text":"Pub. L. 93–625","children":[],"tail":" substituted “an annual rate established under section 6621” for “the rate of 6 percent per annum”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47511445-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47511446-3a70-11f1-a967-d35dac11796a"},"tex