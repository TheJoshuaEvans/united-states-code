{"tag":"section","attrib":{"id":"id42b719c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s337"},"text":null,"children":[{"tag":"num","attrib":{"value":"337"},"text":"§ 337.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonrecognition for property distributed to parent in complete liquidation of subsidiary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42b719c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s337/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No gain or loss shall be recognized to the liquidating corporation on the distribution to the 80-percent distributee of any property in a complete liquidation to which section 332 applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42b719c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s337/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of indebtedness of subsidiary, etc.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42b719c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s337/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indebtedness of subsidiary to parent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42b719c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s337/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation is liquidated in a liquidation to which section 332 applies, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42b719c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s337/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the date of the adoption of the plan of liquidation, such corporation was indebted to the 80-percent distributee,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for purposes of this section and section 336, any transfer of property to the 80-percent distributee in satisfaction of such indebtedness shall be treated as a distribution to such distributee in such liquidation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42b719c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s337/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of tax-exempt distributee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42b719c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s337/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), paragraph (1) and subsection (a) shall not apply where the 80-percent distributee is an organization (other than a cooperative described in section 521) which is exempt from the tax imposed by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42b719c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s337/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception where property will be used in unrelated business","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42b719ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s337/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply to any distribution of property to an organization described in section 511(a)(2) if, immediately after such distribution, such organization uses such property in an activity the income from which is subject to tax under section 511(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42b719cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s337/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Later disposition or change in use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any property to which clause (i) applied is disposed of by the organization acquiring such property, notwithstanding any other provision of law, any gain (not in excess of the amount not recognized by reason of clause (i)) shall be included in such organization’s unrelated business taxable income. For purposes of the preceding sentence, if such property ceases to be used in an activity referred to in clause (i), such organization shall be treated as having disposed of such property on the date of such cessation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42b719cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s337/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 80-percent distributee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “80-percent distributee” means only the corporation which meets the 80-percent stock ownership requirements specified in section 332(b). For purposes of this section, the determination of whether any corporation is an 80-percent distributee shall be made without regard to any consolidated return regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42b719cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s337/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary or appropriate to carry out the purposes of the amendments made by subtitle D of title VI of the Tax Reform Act of 1986, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42b719ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s337/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations to ensure that such purposes may not be circumvented through the use of any provision of law or regulations (including the consolidated return regulations and part III of this subchapter) or through the use of a regulated investment company, real estate investment trust, or tax-exempt entity, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42b719cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s337/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations providing for appropriate coordination of the provisions of this section with the provisions of this title relating to taxation of foreign corporations and their shareholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id42b719d0-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s631/a"},"text":"Pub. L. 99–514, title VI, § 631(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2271"},"text":"100 Stat. 2271","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10223/a"},"text":"Pub. L. 100–203, title X, § 10223(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-411"},"text":"101 Stat. 1330–411","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/e/4"},"text":"Pub. L. 100–647, title I, § 1006(e)(4)","children":[],"tail":", (5)(A), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3400"},"text":"102 Stat. 3400","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id42b719d1-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id42b719d2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id42b719d3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Tax Reform Act of 1986, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2085"},"text":"100 Stat. 2085","children":[],"tail":". Subtitle D (§§ 631–634) of title VI of the Tax Reform Act of 1986 enacted sections 336 and 337 of this title, amended sections 26, 311, 312, 332, 334, 338, 341, 346, 367, 453, 453B, 467, 852, 897, 1056, 1248, 1255, 1276, 1363, 1366, 1374, and 1375 of this title, and repealed former sections 333, 336, and 337 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id42b719d4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 337, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/106"},"text":"68A Stat. 106","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s19"},"text":"Pub. L. 85–866, title I, § 19","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1615"},"text":"72 Stat. 1615","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1901(a)(46), 1906(b)(13)(A), title XXI, § 2118(a), "},{"tag":"ref","attrib":{"href":"/us/stat/90/1772"},"text":"90 Stat. 1772","children":[],"tail":", 1834, 1912; "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s701/i/1"},"text":"Pub. L. 95–600, title VII, § 701(i)(1)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2904"},"text":"92 Stat. 2904","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/628/s4/a"},"text":"Pub. L. 95–628, § 4(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3628"},"text":"92 Stat. 3628","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1980-04-02"},"text":"Apr. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/223/tIV/s403/b/2/A"},"text":"Pub. L. 96–223, title IV, § 403(b)(2)(A)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/304"},"text":"94 Stat. 304","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1980-10-19"},"text":"Oct. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/471/s2/c/2"},"text":"Pub. L. 96–471, § 2(c)(2)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2254"},"text":"94 Stat. 2254","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/589/s5/c"},"text":"Pub. L. 96–589, § 5(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3405"},"text":"94 Stat. 3405","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tII/s224/c/5"},"text":"Pub. L. 97–248, title II, § 224(c)(5)","children":[],"tail":", (6), "},{"tag":"ref","attrib":{"href":"/us/stat/96/489"},"text":"96 Stat. 489","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1804/e/7/A"},"text":"Pub. L. 99–514, title XVIII, § 1804(e)(7)(A)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2803"},"text":"100 Stat. 2803","children":[],"tail":", related to gain or loss on sales or exchanges in connection with certain liquidations, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s631/a"},"text":"Pub. L. 99–514, § 631(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id42b719d5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/e/4/A"},"text":"Pub. L. 100–647, § 1006(e)(4)(A)","children":[],"tail":", (B), substituted “described in section 511(a)(2)” for “described in section 511(a)(2) or 511(b)(2)” and “in an activity the income from which is subject to tax under section 511(a)” for “in an unrelated trade or business (as defined in section 513)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/e/4/C"},"text":"Pub. L. 100–647, § 1006(e)(4)(C)","children":[],"tail":", substituted “an activity referred to in clause (i)” for “an unrelated trade or business of such organization”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/e/5/A"},"text":"Pub. L. 100–647, § 1006(e)(5)(A)","children":[],"tail":", in introductory provisions, substituted “amendments made by subtitle D of title VI of the Tax Reform Act of 1986” for “amendments made to this subpart by the Tax Reform Act of 1986”, and in par. (1), substituted “this subchapter) or through the use of a regulated investment company, real estate investment trust, or tax-exempt entity” for “this subchapter)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" inserted at end “For purposes of this section, the determination of whether any corporation is an 80-percent distributee shall be made without regard to any consolidated return regulation.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id42b719d6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42b719d7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/e/5/B"},"text":"Pub. L. 100–647, title I, § 1006(e)(5)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3401"},"text":"102 Stat. 3401","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1006/e/5/B"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendment made by subparagraph (A)(ii) [amending this section] shall not apply to any reorganization if before ","children":[{"tag":"date","attrib":{"date":"1987-06-10"},"text":"June 10, 1987","children":[],"tail":"—"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the board of directors of a party to the reorganization adopted a resolution to solicit shareholder approval for the transaction, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the shareholders or the board of directors of a party to the reorganization approved the transaction.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42b98ad8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" applicable to distributions or transfers after "},{"tag":"date","attrib":{"date":"1987-12-15"},"text":"Dec. 15, 1987","children":[],"tail":", with exceptions for certain distributee corporations and distributions covered by prior transition rule, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/s10223/d"},"text":"section 10223(d) of Pub. L. 100–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s304"},"text":"section 304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id42b98ad9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any distribution in complete liquidation, and any sale or exchange, made by a corporation after ","children":[{"tag":"date","attrib":{"date":"1986-07-31"},"text":"July 31, 1986","children":[],"tail":", unless such corporation is completely liquidated before "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":", any transaction described in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s338"},"text":"section 338 of this title","children":[],"tail":" for which the acquisition date occurs after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", and any distribution, not in complete liquidation, made after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", with exceptions and special and transitional rules, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s633"},"text":"section 633 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s336"},"text":"section 336 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
