{"tag":"section","attrib":{"id":"id464d11e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5733"},"text":null,"children":[{"tag":"num","attrib":{"value":"5733"},"text":"§ 5733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions relating to liability for occupational taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id464d11ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5733/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any number of persons doing business in partnership at any one place shall be required to pay but one special tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464d11eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5733/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Different businesses of same ownership and location","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever more than one of the pursuits or occupations described in this subchapter are carried on in the same place by the same person at the same time, except as otherwise provided in this subchapter, the tax shall be paid for each according to the rates severally prescribed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464d11ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5733/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Businesses in more than one location","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id464d11ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5733/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The payment of a special tax imposed by this subchapter shall not exempt from an additional special tax the person carrying on a trade or business in any other place than that stated in the register kept in the office of the official in charge of the internal revenue district.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464d11ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5733/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Storage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing contained in paragraph (1) shall require a special tax for the storage of tobacco products and cigarette papers and tubes at a location other than the place where tobacco products and cigarette papers and tubes are sold or offered for sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464d11ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5733/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of place","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “place” as used in this section means the entire office, plant or area of the business in any one location under the same proprietorship; and passageways, streets, highways, rail crossings, waterways, or partitions dividing the premises, shall not be deemed sufficient separation to require additional special tax, if the various divisions are otherwise contiguous.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464d11f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5733/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Death or change of location","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Certain persons, other than the person who has paid the special tax under this subchapter for the carrying on of any business at any place, may secure the right to carry on, without incurring additional special tax, the same business at the same place for the remainder of the taxable period for which the special tax was paid. The persons who may secure such right are:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id464d11f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5733/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the surviving spouse or child, or executor or administrator or other legal representative, of a deceased taxpayer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464d11f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5733/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a husband or wife succeeding to the business of his or her living spouse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464d11f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5733/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a receiver or trustee in bankruptcy, or an assignee for benefit of creditors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464d11f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5733/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the partner or partners remaining after death or withdrawal of a member of a partnership.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"When any person moves to any place other than the place for which special tax was paid for the carrying on of any business, he may secure the right to carry on, without incurring additional special tax, the same business at his new location for the remainder of the taxable period for which the special tax was paid. To secure the right to carry on the business without incurring additional special tax, the successor, or the person relocating his business, must register the succession or relocation with the Secretary in accordance with regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464d11f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5733/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agencies or instrumentalities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any tax imposed by this subchapter shall apply to any agency or instrumentality of the United States unless such agency or instrumentality is granted by statute a specific exemption from such tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id464d11f6-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1347"},"text":"72 Stat. 1347","children":[],"tail":", § 5143; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; renumbered § 5733 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11125/b/20/A"},"text":"Pub. L. 109–59, title XI, § 11125(b)(20)(A)","children":[],"tail":", (C), "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1956"},"text":"119 Stat. 1956","children":[],"tail":", 1957.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id464d11f7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id464d11f8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id464d11f9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11125/b/20/A"},"text":"Pub. L. 109–59, § 11125(b)(20)(A)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5143"},"text":"section 5143 of this title","children":[],"tail":" as this section, transferred section to this subchapter, and substituted “this subchapter” for “this part” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11125/b/20/C"},"text":"Pub. L. 109–59, § 11125(b)(20)(C)","children":[],"tail":", substituted “tobacco products and cigarette papers and tubes” for “liquors” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id464d11fa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464d11fb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-07-01"},"text":"July 1, 2008","children":[],"tail":", but inapplicable to taxes imposed for periods before such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11125/c"},"text":"section 11125(c) of Pub. L. 109–59","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5002"},"text":"section 5002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
