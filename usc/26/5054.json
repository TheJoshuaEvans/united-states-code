{"tag":"section","attrib":{"id":"id46223130-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5054"},"text":null,"children":[{"tag":"num","attrib":{"value":"5054"},"text":"§ 5054.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination and collection of tax on beer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46223131-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5054/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time of determination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46223132-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5054/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beer produced in the United States; certain imported beer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3), the tax imposed by section 5051 on beer produced in the United States, or imported into the United States and transferred to a brewery free of tax under section 5418, shall be determined at the time it is removed for consumption or sale, and shall be paid by the brewer thereof in accordance with section 5061.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46223133-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5054/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beer imported into the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (4), the tax imposed by section 5051 on beer imported into the United States and not transferred to a brewery free of tax under section 5418 shall be determined at the time of the importation thereof, or, if entered for warehousing, at the time of removal from the 1st such warehouse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46223134-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5054/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Illegally produced beer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The tax on any beer produced in the United States shall be due and payable immediately upon production unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46223135-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5054/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such beer is produced in a brewery qualified under the provisions of subchapter G, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46223136-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5054/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such production is exempt from tax under section 5053(e) (relating to beer for personal or family use).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46223137-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5054/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawfully imported beer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beer smuggled or brought into the United States unlawfully shall, for purposes of this chapter, be held to be imported into the United States, and the internal revenue tax shall be due and payable at the time of such importation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46223138-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5054/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on returned beer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beer which has been removed for consumption or sale and is thereafter returned to the brewery shall be subject to all provisions of this chapter relating to beer prior to removal for consumption or sale, including the tax imposed by section 5051. The tax on any such returned beer which is again removed for consumption or sale shall be determined and paid without respect to the tax which was determined at the time of prior removal of the beer for consumption or sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46223139-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5054/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of other provisions of law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All administrative and penal provisions of this title, insofar as applicable, shall apply to any tax imposed by section 5051.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4622313a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1334"},"text":"72 Stat. 1334","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1905(a)(5), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1818"},"text":"90 Stat. 1818","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/95/458/s2/b/2/B"},"text":"Pub. L. 95–458, § 2(b)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-14"},"text":"Oct. 14, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1256"},"text":"92 Stat. 1256","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tVIII/s8011/b/2"},"text":"Pub. L. 99–509, title VIII, § 8011(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1953"},"text":"100 Stat. 1953","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1018/u/19"},"text":"Pub. L. 100–647, title I, § 1018(u)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3591"},"text":"102 Stat. 3591","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tVI/s6014/a/1"},"text":"Pub. L. 105–206, title VI, § 6014(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/820"},"text":"112 Stat. 820","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/239"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(239)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1195"},"text":"132 Stat. 1195","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4622313b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4622313c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4622313d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5054, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/613"},"text":"68A Stat. 613","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising subsecs. (a)(1), (2) and (b) to (d) of this section were contained in prior sections 5055 and 5057(a), ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/613"},"text":"68A Stat. 613","children":[],"tail":", prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4622313e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “section” for “sections”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6014/a/1"},"text":"Pub. L. 105–206, § 6014(a)(1)","children":[],"tail":", in heading inserted “; certain imported beer” after “United States” and in text inserted “, or imported into the United States and transferred to a brewery free of tax under section 5418,” after “United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6014/a/2"},"text":"Pub. L. 105–206, § 6014(a)(2)","children":[],"tail":", inserted “and not transferred to a brewery free of tax under section 5418” after “United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" added period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509"},"text":"Pub. L. 99–509","children":[],"tail":" substituted “if entered for warehousing, at the time of removal from the 1st such warehouse” for “if entered into customs custody, at the time of removal from such custody, and shall be paid under such regulations as the Secretary shall prescribe.”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/458"},"text":"Pub. L. 95–458","children":[],"tail":" inserted provision excluding from tax the beer exempt from tax under section 5053(e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1905/a/5"},"text":"Pub. L. 94–455, § 1905(a)(5)","children":[],"tail":", redesignated subsec. (d) as (c) and struck out former subsec. (c) respecting stamps or other devices as evidence of payment of tax."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4622313f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46223140-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Taxpayer Relief Act of 1997, "},{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":", to which such amendment relates (see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1421/c"},"text":"section 1421(c) of Pub. L. 105–34","children":[],"tail":" set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5418"},"text":"section 5418 of this title","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6024"},"text":"section 6024 of Pub. L. 105–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"not