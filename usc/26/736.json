{"tag":"section","attrib":{"id":"id440285bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s736"},"text":null,"children":[{"tag":"num","attrib":{"value":"736"},"text":"§ 736.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to a retiring partner or a deceased partner’s successor in interest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id440285c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s736/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments considered as distributive share or guaranteed payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Payments made in liquidation of the interest of a retiring partner or a deceased partner shall, except as provided in subsection (b), be considered—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id440285c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s736/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a distributive share to the recipient of partnership income if the amount thereof is determined with regard to the income of the partnership, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440285c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s736/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a guaranteed payment described in section 707(c) if the amount thereof is determined without regard to the income of the partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id440285c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s736/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments for interest in partnership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id440285c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s736/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments made in liquidation of the interest of a retiring partner or a deceased partner shall, to the extent such payments (other than payments described in paragraph (2)) are determined, under regulations prescribed by the Secretary, to be made in exchange for the interest of such partner in partnership property, be considered as a distribution by the partnership and not as a distributive share or guaranteed payment under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440285c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s736/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, payments in exchange for an interest in partnership property shall not include amounts paid for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id440285c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s736/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unrealized receivables of the partnership (as defined in section 751(c)), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id440285c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s736/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" good will of the partnership, except to the extent that the partnership agreement provides for a payment with respect to good will.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440285c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s736/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on application of paragraph (2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (2) shall apply only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id440285c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s736/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capital is not a material income-producing factor for the partnership, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id440285ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s736/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retiring or deceased partner was a general partner in the partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id440285cb-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/248"},"text":"68A Stat. 248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s701/u/13/B"},"text":"Pub. L. 95–600, title VII, § 701(u)(13)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2918"},"text":"92 Stat. 2918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13262/a"},"text":"Pub. L. 103–66, title XIII, § 13262(a)","children":[],"tail":", (b)(2)(B), "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/541"},"text":"107 Stat. 541","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id440285cc-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id440285cd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id440285ce-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13262/a"},"text":"Pub. L. 103–66, § 13262(a)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13262/b/2/B"},"text":"Pub. L. 103–66, § 13262(b)(2)(B)","children":[],"tail":", struck out heading and text of subsec. (c). Text read as follows: “For limitation on the tax attributable to certain gain connected with section 1248 stock, see section 751(e).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id440285cf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id440285d0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13262/c"},"text":"Pub. L. 103–66, title XIII, § 13262(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/541"},"text":"107 Stat. 541","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/66/tXIII/s13262/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s751"},"text":"section 751 of this title","children":[],"tail":"] shall apply in the case of partners retiring or dying on or after "},{"tag":"date","attrib":{"date":"1993-01-05"},"text":"January 5, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Binding contract exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section shall not apply to any partner retiring on or after ","children":[{"tag":"date","attrib":{"date":"1993-01-05"},"text":"January 5, 1993","children":[],"tail":", if a written contract to purchase such partner’s interest in the partnership was binding on "},{"tag":"date","attrib":{"date":"1993-01-04"},"text":"January 4, 1993","children":[],"tail":", and at all times thereafter before such purchase.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id440285d1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" applicable to transfers beginning after "},{"tag":"date","attrib":{"date":"1975-10-09"},"text":"Oct. 9, 1975","children":[],"tail":", and to sales, exchanges, and distributions taking place after "},{"tag":"date","attrib":{"date":"1975-10-09"},"text":"Oct. 9, 1975","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/s701/u/13/C"},"text":"section 701(u)(13)(C) of Pub. L. 95–600","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s751"},"text":"section 751 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
