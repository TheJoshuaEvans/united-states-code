{"tag":"section","attrib":{"id":"id467a640e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H"},"text":null,"children":[{"tag":"num","attrib":{"value":"6050H"},"text":"§ 6050H.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns relating to mortgage interest received in trade or business from individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id467a640f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mortgage interest of $600 or more","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467a6410-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is engaged in a trade or business, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467a6411-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, in the course of such trade or business, receives from any individual interest aggregating $600 or more for any calendar year on any mortgage,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall make the return described in subsection (b) with respect to each individual from whom such interest was received at such time as the Secretary may by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467a6412-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and manner of returns","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A return is described in this subsection if such return—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467a6413-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in such form as the Secretary may prescribe,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467a6414-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contains—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467a6415-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the individual from whom the interest described in subsection (a)(2) was received,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467a6416-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such interest (other than points) received for the calendar year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467a6417-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of points on the mortgage received during the calendar year and whether such points were paid directly by the borrower,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467a6418-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of outstanding principal on the mortgage as of the beginning of such calendar year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467a6419-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the origination of the mortgage,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467a641a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the address (or other description in the case of property without an address) of the property which secures the mortgage, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467a641b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467a641c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to governmental units","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467a641d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treated as persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” includes any governmental unit (and any agency or instrumentality thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467a641e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a governmental unit or any agency or instrumentality thereof—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467a641f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a) shall be applied without regard to the trade or business requirement contained therein, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467a6420-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any return required under subsection (a) shall be made by the officer or employee appropriately designated for the purpose of making such return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467a6421-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements to be furnished to individuals with respect to whom information is required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every person required to make a return under subsection (a) shall furnish to each individual whose name is required to be set forth in such return a written statement showing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467a6422-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and phone number of the information contact of the person required to make such return, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467a6423-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of interest described in subsection (a)(2) (other than points) received by the person required to make such return from the individual to whom the statement is required to be furnished (and the information required under subparagraphs (C), (D), (E), and (F) of subsection (b)(2)).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The written statement required under the preceding sentence shall be furnished on or before January 31 of the year following the calendar year for which the return under subsection (a) was required to be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467a6424-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mortgage defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, except as provided in regulations prescribed by the Secretary, the term “mortgage” means any obligation secured by real property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467a6425-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns which would be required to be made by 2 or more persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except to the extent provided in regulations prescribed by the Secretary, in the case of interest received by any person on behalf of another person, only the person first receiving such interest shall be required to make the return under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467a6426-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for cooperative housing corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), an amount received by a cooperative housing corporation from a tenant-stockholder shall be deemed to be interest received on a mortgage in the course of a trade or business engaged in by such corporation, to the extent of the tenant-stockholder’s proportionate share of interest described in section 216(a)(2). Terms used in the preceding sentence shall have the same meanings as when used in section 216.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467a6427-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns relating to mortgage insurance premiums","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467a6428-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prescribe, by regulations, that any person who, in the course of a trade or business, receives from any individual premiums for mortgage insurance aggregating $600 or more for any calendar year, shall make a return with respect to each such individual. Such return shall be in such form, shall be made at such time, and shall contain such information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467a6429-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement to be furnished to individuals with respect to whom information is required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person required to make a return under paragraph (1) shall furnish to each individual with respect to whom a return is made a written statement showing such information as the Secretary may prescribe. Such written statement shall be furnished on or before January 31 of the year following the calendar year for which the return under paragraph (1) was required to be made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467a642a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467a642b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules similar to the rules of subsection (c) shall apply, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467a642c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “mortgage insurance” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id467a642d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/h/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mortgage insurance provided by the Department of Veterans Affairs, the Federal Housing Administration, or the Rural Housing Service, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id467a642e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050H/h/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private mortgage insurance (as defined by section 2 of the Homeowners Protection Act of 1998 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4901"},"text":"12 U.S.C. 4901","children":[],"tail":"), as in effect on the date of the enactment of this subsection)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id467a642f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s145/a"},"text":"Pub. L. 98–369, div. A, title I, § 145(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/684"},"text":"98 Stat. 684","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1501/c/11"},"text":"Pub. L. 99–514, title XV, § 1501(c)(11)","children":[],"tail":", title XVIII, § 1811(a)(1), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2739"},"text":"100 Stat. 2739","children":[],"tail":", 2832; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7646/a"},"text":"Pub. L. 101–239, title VII, § 7646(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2382"},"text":"103 Stat. 2382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/168/tXII/s1201/a/8"},"text":"Pub. L. 104–168, title XII, § 1201(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1469"},"text":"110 Stat. 1469","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1704/t/23"},"text":"Pub. L. 104–188, title I, § 1704(t)(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1888"},"text":"110 Stat. 1888","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s419/c"},"text":"Pub. L. 109–432, div. A, title IV, § 419(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2968"},"text":"120 Stat. 2968","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/41/tII/s2003/a"},"text":"Pub. L. 114–41, title II, § 2003(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2015-07-31"},"text":"July 31, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/454"},"text":"129 Stat. 454","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/2/C"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(2)(C)","children":[],"tail":", (263), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1184"},"text":"132 Stat. 1184","children":[],"tail":", 1196.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id467a6430-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id467a6431-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id467a6432-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this subsection, referred to in subsec. (h)(3)(B)(ii), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id467a6433-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (h)(3)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “Department of Veterans Affairs” for “Veterans Administration” and “Rural Housing Service” for “Rural Housing Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(2)(D) to (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/41/s2003/a"},"text":"Pub. L. 114–41, § 2003(a)","children":[],"tail":", added subpars. (D) to (F) and redesignated former subpar. (D) as (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/41/s2003/b"},"text":"Pub. L. 114–41, § 2003(b)","children":[],"tail":", substituted “subparagraphs (C), (D), (E), and (F) of subsection (b)(2)” for “subsection (b)(2)(C)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7646/b/1"},"text":"Pub. L. 101–239, § 7646(b)(1)","children":[],"tail":". See 1989 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168"},"text":"Pub. L. 104–168","children":[],"tail":" substituted “name, address, and phone number of the information contact” for “name and address”."}],"tail":"\n"},{"tag":