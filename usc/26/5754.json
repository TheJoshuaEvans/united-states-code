{"tag":"section","attrib":{"id":"id464d1235-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5754"},"text":null,"children":[{"tag":"num","attrib":{"value":"5754"},"text":"§ 5754.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on importation of previously exported tobacco products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id464d1236-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5754/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export-labeled tobacco products","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id464d1237-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5754/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Tobacco products and cigarette papers and tubes manufactured in the United States and labeled for exportation under this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id464d1238-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5754/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be transferred to or removed from the premises of a manufacturer or an export warehouse proprietor only if such articles are being transferred or removed without tax in accordance with section 5704;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id464d1239-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5754/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be imported or brought into the United States, after their exportation, only if such articles either are eligible to be released from customs custody with the partial duty exemption provided in section 5704(d) or are returned to the original manufacturer of such article as provided in section 5704(c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id464d123a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5754/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be sold or held for sale for domestic consumption in the United States unless such articles are removed from their export packaging and repackaged by the original manufacturer into new packaging that does not contain an export label.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464d123b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5754/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alterations by persons other than original manufacturer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to articles labeled for export even if the packaging or the appearance of such packaging to the consumer of such articles has been modified or altered by a person other than the original manufacturer so as to remove or conceal or attempt to remove or conceal (including by the placement of a sticker over) any export label.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464d123c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5754/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exports include shipments to Puerto Rico","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, section 5704(d), section 5761, and such other provisions as the Secretary may specify by regulations, references to exportation shall be treated as including a reference to shipment to the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464d123d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5754/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export label","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, an article is labeled for export or contains an export label if it bears the mark, label, or notice required under section 5704(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464d123e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5754/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id464d123f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5754/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For exception to this section for personal use, see section 5761(d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464d1240-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5754/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For civil penalties related to violations of this section, see section 5761(c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464d1241-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5754/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For a criminal penalty applicable to any violation of this section, see section 5762(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464d1242-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5754/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For forfeiture provisions related to violations of this section, see section 5761(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id464d1243-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIX/s9302/h/1/E/i"},"text":"Pub. L. 105–33, title IX, § 9302(h)(1)(E)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/673"},"text":"111 Stat. 673","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/476/tIV/s4002/a"},"text":"Pub. L. 106–476, title IV, § 4002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2176"},"text":"114 Stat. 2176","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dC/tIV/s401/f/2/B"},"text":"Pub. L. 109–432, div. C, title IV, § 401(f)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3050"},"text":"120 Stat. 3050","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id464d1244-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id464d1245-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id464d1246-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" substituted “5761(d)” for “5761(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/476"},"text":"Pub. L. 106–476","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—Tobacco products and cigarette papers and tubes previously exported from the United States may be imported or brought into the United States only as provided in section 5704(d). For purposes of this section, section 5704(d), section 5761, and such other provisions as the Secretary may specify by regulations, references to exportation shall be treated as including a reference to shipment to the Commonwealth of Puerto Rico."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Cross Reference.—","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“For penalty for the sale of tobacco products and cigarette papers and tubes in the United States which are labeled for export, see section 5761(c).”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id464f8247-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464f8248-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" applicable with respect to goods entered, or withdrawn from warehouse for consumption, on or after the 15th day after "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/s401/g"},"text":"section 401(g) of Pub. L. 109–432","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1681"},"text":"section 1681 of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464f8249-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/476"},"text":"Pub. L. 106–476","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/476/s4002/d"},"text":"section 4002(d) of Pub. L. 106–476","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5704"},"text":"section 5704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id464f824a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to articles removed, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s5702/j"},"text":"section 5702(j) of this title","children":[],"tail":", after "},{"tag":"date","attrib":{"date":"1999-12-31"},"text":"Dec. 31, 1999","children":[],"tail":", with transition rule, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/s9302/i"},"text":"section 9302(i) of Pub. L. 105–33","children":[],"tail":", set out as an Effective Date of 1997 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5701"},"text":"section 5701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
