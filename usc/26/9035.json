{"tag":"section","attrib":{"id":"id47abb82c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9035"},"text":null,"children":[{"tag":"num","attrib":{"value":"9035"},"text":"§ 9035.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified campaign expense limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47abb82d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9035/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No candidate shall knowingly incur qualified campaign expenses in excess of the expenditure limitation applicable under section 315(b)(1)(A) of the Federal Election Campaign Act of 1971, and no candidate shall knowingly make expenditures from his personal funds, or the personal funds of his immediate family, in connection with his campaign for nomination for election to the office of President in excess of, in the aggregate, $50,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47abb82e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9035/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of immediate family","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “immediate family” means a candidate’s spouse, and any child, parent, grandparent, brother, half-brother, sister, or half-sister of the candidate, and the spouses of such persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47abb82f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443/tIV/s408/c"},"text":"Pub. L. 93–443, title IV, § 408(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-15"},"text":"Oct. 15, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1300"},"text":"88 Stat. 1300","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/283/tIII"},"text":"Pub. L. 94–283, title III","children":[],"tail":", §§ 305(a), 307(c), "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/499"},"text":"90 Stat. 499","children":[],"tail":", 501; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s220/z"},"text":"Pub. L. 113–295, div. A, title II, § 220(z)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4037"},"text":"128 Stat. 4037","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47abb830-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47abb831-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id47abb832-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 315 of The Federal Election Campaign Act of 1971, referred to in subsec. (a), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30116"},"text":"section 30116 of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47abb833-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" substituted “section 315(b)(1)(A)” for “section 320(b)(1)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/283"},"text":"Pub. L. 94–283","children":[],"tail":" substituted “limitations” for “limitation” in section catchline, designated existing provisions as subsec. (a), inserted “Expenditure limitations” as heading of subsec. (a) as so redesignated and substituted “section 320(b)(1)(A) of the Federal Election Campaign Act of 1971, and no candidate shall knowingly make expenditures from his personal funds, or the personal funds of his immediate family, in connection with his campaign for nomination for election to the office of President in excess of, in the aggregate, $50,000” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t18/s608/c/1/A"},"text":"section 608(c)(1)(A) of title 18","children":[],"tail":", United States Code”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47abb834-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47abb835-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/283/tIII/s305/d"},"text":"Pub. L. 94–283, title III, § 305(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/499"},"text":"90 Stat. 499","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"“For purposes of applying section 9035(a) of the Internal Revenue Code of 1986 [formerly I.R.C. 1954], as amended by subsection (a), expenditures made by an individual after ","children":[{"tag":"date","attrib":{"date":"1976-01-29"},"text":"January 29, 1976","children":[],"tail":", and before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":"] shall not be taken into account.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47abb836-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/s410/c/1"},"text":"section 410(c)(1) of Pub. L. 93–443","children":[],"tail":", set out as an Effective Date of 1974 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
