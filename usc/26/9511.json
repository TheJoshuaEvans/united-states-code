{"tag":"section","attrib":{"id":"id47c11441-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511"},"text":null,"children":[{"tag":"num","attrib":{"value":"9511"},"text":"§ 9511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patient-Centered Outcomes Research Trust Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47c11442-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of Trust Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a trust fund to be known as the “Patient-Centered Outcomes Research Trust Fund” (hereafter in this section referred to as the “PCORTF”), consisting of such amounts as may be appropriated or credited to such Trust Fund as provided in this section and section 9602(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c11443-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers to Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c11444-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are hereby appropriated to the Trust Fund the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c11445-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2010, $10,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c11446-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2011, $50,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c11447-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2012, $150,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c11448-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For fiscal year 2013—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47c11449-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equivalent to the net revenues received in the Treasury from the fees imposed under subchapter B of chapter 34 (relating to fees on health insurance and self-insured plans) for such fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47c1144a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $150,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c1144b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each of fiscal years 2014, 2015, 2016, 2017, 2018, and 2019—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47c1144c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equivalent to the net revenues received in the Treasury from the fees imposed under subchapter B of chapter 34 (relating to fees on health insurance and self-insured plans) for such fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47c1144d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $150,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c1144e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each of fiscal years 2020 through 2029—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47c1144f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equivalent to the net revenues received in the Treasury from the fees imposed under subchapter B of chapter 34 (relating to fees on health insurance and self-insured plans) for such fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47c11450-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable amount (as defined in paragraph (4)) for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The amounts appropriated under subparagraphs (A), (B), (C), (D)(ii), (E)(ii), and (F)(ii) shall be transferred from the general fund of the Treasury, from funds not otherwise appropriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c11451-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust Fund transfers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the amounts appropriated under paragraph (1), there shall be credited to the PCORTF the amounts transferred under section 1183 of the Social Security Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c11452-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on transfers to PCORTF","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No amount may be appropriated or transferred to the PCORTF on and after the date of any expenditure from the PCORTF which is not an expenditure permitted under this section. The determination of whether an expenditure is so permitted shall be made without regard to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c11453-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any provision of law which is not contained or referenced in this chapter or in a revenue Act, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c11454-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether such provision of law is a subsequently enacted provision or directly or indirectly seeks to waive the application of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c11455-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable amount defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In paragraph (1)(F)(ii), the term “applicable amount” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c11456-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2020, $275,500,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c11457-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2021, $285,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c11458-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2022, $293,500,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c11459-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2023, $311,500,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c1145a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2024, $320,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c1145b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2025, $338,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c1145c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2026, $355,500,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c1145d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/4/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2027, $363,500,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c1145e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/4/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2028, $381,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c1145f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/b/4/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2029, $399,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c11460-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trustee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall be a trustee of the PCORTF.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c11461-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures from Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c11462-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts available to the Patient-Centered Outcomes Research Institute","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), amounts in the PCORTF are available, without further appropriation, to the Patient-Centered Outcomes Research Institute established under section 1181(b) of the Social Security Act for carrying out part D of title XI of the Social Security Act (as in effect on the date of enactment of such Act).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c11463-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c11464-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The trustee of the PCORTF shall provide for the transfer from the PCORTF of 20 percent of the amounts appropriated or credited to the PCORTF for each of fiscal years 2011 through 2029 to the Secretary of Health and Human Services to carry out section 937 of the Public Health Service Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c11465-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts transferred under subparagraph (A) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c11466-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts transferred under subparagraph (A) with respect to a fiscal year, the Secretary of Health and Human Services shall distribute—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47c11467-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 80 percent to the Office of Communication and Knowledge Transfer of the Agency for Healthcare Research and Quality (or any other relevant office designated by Agency for Healthcare Research and Quality) to carry out the activities described in section 937 of the Public Health Service Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47c38568-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 20 percent to the Secretary to carry out the activities described in such section 937.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c38569-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net revenues","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “net revenues” means the amount estimated by the Secretary of the Treasury based on the excess of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c3856a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fees received in the Treasury under subchapter B of chapter 34, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c3856b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the decrease in the tax imposed by chapter 1 resulting from the fees imposed by such subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c3856c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9511/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No amounts shall be available for expenditure from the PCORTF after ","children":[{"tag":"date","attrib":{"date":"2029-09-30"},"text":"September 30, 2029","children":[],"tail":", and any amounts in such Trust Fund after such date shall be transferred to the general fund of the Treasury."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47c3856d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6301/e/1/A"},"text":"Pub. L. 111–148, title VI, § 6301(e)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/742"},"text":"124 Stat. 742","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/59/dB/tIV/s1403"},"text":"Pub. L. 116–59, div. B, title IV, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-09-27"},"text":"Sept. 27, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1107"},"text":"133 Stat. 1107","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/69/dB/tIV/s1403"},"text":"Pub. L. 116–69, div. B, title IV, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-11-21"},"text":"Nov. 21, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1139"},"text":"133 Stat. 1139","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dN/tI/s104/a"},"text":"Pub. L. 116–94, div. N, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3097"},"text":"133 Stat. 3097","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47c3856e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47c3856f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id47c38570-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsecs. (b)(2) and (d)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Part D of title XI of the Act is classified generally to part D (§ 1320e et seq.) of subchapter XI of chapter 7 of Title 42, The Public Health and Welfare. Sections 1181(b) and 1183 of the Act are classified to sections 1320e(b) and 1320e–2, respectively, of Title 42. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of such Act, referred to in subsec. (d)(1), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", which enacted part D of title XI of the Social Security Act and was approved "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 937 of the Public Health Service Act, referred to in subsec. (d)(2)(A), (C), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s299b–37"},"text":"section 299b–37 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id47c38571-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 9511, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240/tVIII/s8003/a"},"text":"Pub. L. 102–240, title VIII, § 8003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2205"},"text":"105 Stat. 2205","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/130/s9/c"},"text":"Pub. L. 105–130, § 9(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-01"},"text":"Dec. 1, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2561"},"text":"111 Stat. 2561","children":[],"tail":", related to National Recreational Trails Trust Fund, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIX/s9011/a"},"text":"Pub. L. 105–178, title IX, § 9011(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","childr