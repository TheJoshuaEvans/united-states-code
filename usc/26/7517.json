{"tag":"section","attrib":{"id":"id476d9d7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7517"},"text":null,"children":[{"tag":"num","attrib":{"value":"7517"},"text":"§ 7517.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Furnishing on request of statement explaining estate or gift valuation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id476d9d7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7517/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary makes a determination or a proposed determination of the value of an item of property for purposes of the tax imposed under chapter 11, 12, or 13, he shall furnish, on the written request of the executor, donor, or the person required to make the return of the tax imposed by chapter 13 (as the case may be), to such executor, donor, or person a written statement containing the material required by subsection (b). Such statement shall be furnished not later than 45 days after the later of the date of such request or the date of such determination or proposed determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id476d9d7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7517/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of statement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A statement required to be furnished under subsection (a) with respect to the value of an item of property shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id476d9d7d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7517/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explain the basis on which the valuation was determined or proposed,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id476d9d7e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7517/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth any computation used in arriving at such value, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id476d9d7f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7517/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain a copy of any expert appraisal made by or for the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id476d9d80-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7517/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of statement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except to the extent otherwise provided by law, the value determined or proposed by the Secretary with respect to which a statement is furnished under this section, and the method used in arriving at such value, shall not be binding on the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id476d9d81-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2008/a/1"},"text":"Pub. L. 94–455, title XX, § 2008(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1891"},"text":"90 Stat. 1891","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id476d9d82-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id476d9d83-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id476d9d84-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2008/d/1"},"text":"Pub. L. 94–455, title XX, § 2008(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1892"},"text":"90 Stat. 1892","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendments made by subsection (a) [enacting this section and amending sections 2031 and 2512 of this title]—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insofar as they relate to the tax imposed under chapter 11 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954, section 2001 et seq. of this title], shall apply to the estates of decedents dying after ","children":[{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insofar as they relate to the tax imposed under chapter 12 of such Code [section 2501 et seq. of this title], shall apply to gifts made after ","children":[{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
