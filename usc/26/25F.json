{"tag":"section","attrib":{"id":"id4071488d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F"},"text":null,"children":[{"tag":"num","attrib":{"value":"25F"},"text":"§ 25F.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified elementary and secondary education scholarships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4071488e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual who is a citizen or resident of the United States (within the meaning of section 7701(a)(9)), there shall be allowed as a credit against the tax imposed by this chapter for the taxable year an amount equal to the aggregate amount of qualified contributions made by the taxpayer during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4071488f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40714890-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The credit allowed under subsection (a) to any taxpayer for any taxable year shall not exceed $1,700.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40714891-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction based on State credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount allowed as a credit under subsection (a) for a taxable year shall be reduced by the amount allowed as a credit on any State tax return of the taxpayer for qualified contributions made by the taxpayer during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40714892-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40714893-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered State” means one of the States, or the District of Columbia, that, for a calendar year, voluntarily elects to participate under this section and to identify scholarship granting organizations in the State, in accordance with subsection (g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40714894-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible student","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible student” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40714895-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of a household with an income which, for the calendar year prior to the date of the application for a scholarship, is not greater than 300 percent of the area median gross income (as such term is used in section 42), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40714896-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible to enroll in a public elementary or secondary school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40714897-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified contribution” means a charitable contribution of cash to a scholarship granting organization that uses the contribution to fund scholarships for eligible students solely within the State in which the organization is listed pursuant to subsection (g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40714898-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified elementary or secondary education expense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified elementary or secondary education expense” means any expense of an eligible student which is described in section 530(b)(3)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40714899-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarship granting organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “scholarship granting organization” means any organization—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4071489a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4071489b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/c/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is described in section 501(c)(3) and exempt from tax under section 501(a), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4071489c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/c/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a private foundation,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4071489d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which prevents the co-mingling of qualified contributions with other amounts by maintaining one or more separate accounts exclusively for qualified contributions,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4071489e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which satisfies the requirements of subsection (d), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4071489f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is included on the list submitted for the applicable covered State under subsection (g) for the applicable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id407148a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for scholarship granting organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id407148a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An organization meets the requirements of this subsection if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id407148a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such organization provides scholarships to 10 or more students who do not all attend the same school,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id407148a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such organization spends not less than 90 percent of the income of the organization on scholarships for eligible students,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id407148a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such organization does not provide scholarships for any expenses other than qualified elementary or secondary education expenses,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id407148a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such organization provides a scholarship to eligible students with a priority for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id407148a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/d/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" students awarded a scholarship the previous school year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id407148a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/d/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after application of clause (i), any eligible students who have a sibling who was awarded a scholarship from such organization,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id407148a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such organization does not earmark or set aside contributions for scholarships on behalf of any particular student, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id407148a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such organization—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id407148aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/d/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verifies the annual household income and family size of eligible students who apply for scholarships to ensure such students meet the requirement of subsection (c)(2)(A), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id407148ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/d/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limits the awarding of scholarships to eligible students who are a member of a household for which the income does not exceed the amount established under subsection (c)(2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id407148ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on self-dealing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id407148ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A scholarship granting organization may not award a scholarship to any disqualified person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id407148ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualified person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, a disqualified person shall be determined pursuant to rules similar to the rules of section 4946.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id407148af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of double benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any qualified contribution for which a credit is allowed under this section shall not be taken into account as a charitable contribution for purposes of section 170.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id407148b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryforward of unused credit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id407148b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the credit allowable under subsection (a) for any taxable year exceeds the limitation imposed by section 26(a) for such taxable year reduced by the sum of the credits allowable under this subpart (other than this section, section 23, and section 25D), such excess shall be carried to the succeeding taxable year and added to the credit allowable under subsection (a) for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id407148b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No credit may be carried forward under this subsection to any taxable year following the fifth taxable year after the taxable year in which the credit arose. For purposes of the preceding sentence, credits shall be treated as used on a first-in first-out basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id407148b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State list of scholarship granting organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id407148b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id407148b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than January 1 of each calendar year (or, with respect to the first calendar year for which this section applies, as early as practicable), a State that voluntarily elects to participate under this section shall provide to the Secretary a list of the scholarship granting organizations that meet the requirements described in subsection (c)(5) and are located in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id407148b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The election under this paragraph shall be made by the Governor of the State or by such other individual, agency, or entity as is designated under State law to make such elections on behalf of the State with respect to Federal tax benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id407148b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each list submitted under paragraph (1) shall include a certification that the individual, agency, or entity submitting such list on behalf of the State has the authority to perform this function.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id407148b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall issue such regulations or other guidance as the Secretary determines necessary to carry out the purposes of this section, including regulations or other guidance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id407148b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for enforcement of the requirements under subsections (d) and (g), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id407148ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25F/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to recordkeeping or information reporting for purposes of administering the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id407148bb-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70411/a/1"},"text":"Pub. L. 119–21, title VII, § 70411(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/215"},"text":"139 Stat. 215","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id407148bc-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id407148bd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Delayed Effective Date of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For delayed effective date of section, see Effective Date note below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id407148be-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id407148bf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years ending after ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"Dec. 31, 2026","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70411/c/1"},"text":"section 70411(c)(1) of Pub. L. 119–21","children":[],"tail":", set out in an Effective Date of 2025 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s25"},"text":"section 25 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
