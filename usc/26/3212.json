{"tag":"section","attrib":{"id":"id4571cd72-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3212"},"text":null,"children":[{"tag":"num","attrib":{"value":"3212"},"text":"§ 3212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The compensation of an employee representative for the purpose of ascertaining the tax thereon shall be determined in the same manner and with the same effect as if the employee organization by which such employee representative is employed were an employer as defined in section 3231(a).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4571cd73-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/432"},"text":"68A Stat. 432","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
