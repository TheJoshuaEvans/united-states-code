{"tag":"section","attrib":{"id":"id4472ac33-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s908"},"text":null,"children":[{"tag":"num","attrib":{"value":"908"},"text":"§ 908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of credit for participation in or cooperation with an international boycott","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4472ac34-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a person, or a member of a controlled group (within the meaning of section 993(a)(3)) which includes such person, participates in or cooperates with an international boycott during the taxable year (within the meaning of section 999(b)), the amount of the credit allowable under section 901 to such person, or under section 960 to United States shareholders of such person, for foreign taxes paid during the taxable year shall be reduced by an amount equal to the product of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4472ac35-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s908/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the credit which, but for this section, would be allowed under section 901 for the taxable year, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4472ac36-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s908/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the international boycott factor (determined under section 999).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4472ac37-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application with sections 275(a)(4) and 78","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 275(a)(4) and section 78 shall not apply to any amount of taxes denied credit under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4472ac38-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tX/s1061/a"},"text":"Pub. L. 94–455, title X, § 1061(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1649"},"text":"90 Stat. 1649","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s14301/c/28"},"text":"Pub. L. 115–97, title I, § 14301(c)(28)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2224"},"text":"131 Stat. 2224","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4472ac39-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4472ac3a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4472ac3b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" struck out “902 or” after “or under section” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4472ac3c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4472ac3d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" applicable to taxable years of foreign corporations beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", and to taxable years of United States shareholders in which or with which such taxable years of foreign corporations end, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s14301/d"},"text":"section 14301(d) of Pub. L. 115–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s78"},"text":"section 78 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4472ac3e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tX/s1066/a"},"text":"Pub. L. 94–455, title X, § 1066(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1654"},"text":"90 Stat. 1654","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/455/tX/s1066/a"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this part (other than by section 1065) [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s999"},"text":"section 999 of this title","children":[],"tail":" and amending sections 952 and 995 of this title] apply to participation in or cooperation with an international boycott more than 30 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existing contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of operations which constitute participation in or cooperation with an international boycott and which are carried out in accordance with the terms of a binding contract entered into before ","children":[{"tag":"date","attrib":{"date":"1976-09-02"},"text":"September 2, 1976","children":[],"tail":", the amendments made by this part (other than by section 1065) apply to such participation or cooperation after "},{"tag":"date","attrib":{"date":"1977-12-31"},"text":"December 31, 1977","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
