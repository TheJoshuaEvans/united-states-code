{"tag":"section","attrib":{"id":"id472aef8b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6684"},"text":null,"children":[{"tag":"num","attrib":{"value":"6684"},"text":"§ 6684.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessable penalties with respect to liability for tax under chapter 42","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If any person becomes liable for tax under any section of chapter 42 (relating to private foundations and certain other tax-exempt organizations) by reason of any act or failure to act which is not due to reasonable cause and either—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472aef8c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6684/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person has theretofore been liable for tax under such chapter, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472aef8d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6684/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such act or failure to act is both willful and flagrant,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then such person shall be liable for a penalty equal to the amount of such tax.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id472aef8e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tI/s101/c"},"text":"Pub. L. 91–172, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/519"},"text":"83 Stat. 519","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10712/c/4"},"text":"Pub. L. 100–203, title X, § 10712(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-467"},"text":"101 Stat. 1330–467","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id472aef8f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id472aef90-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id472aef91-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" inserted “and certain other tax-exempt organizations” after “private foundations” in parenthetical."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id472aef92-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id472aef93-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/s10712/d"},"text":"section 10712(d) of Pub. L. 100–203","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4955"},"text":"section 4955 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id472aef94-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/s101/k/1"},"text":"section 101(k)(1) of Pub. L. 91–172","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4940"},"text":"section 4940 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
