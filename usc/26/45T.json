{"tag":"section","attrib":{"id":"id40dc8d50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45T"},"text":null,"children":[{"tag":"num","attrib":{"value":"45T"},"text":"§ 45T.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Auto-enrollment option for retirement savings options provided by small employers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40dc8d51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45T/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of section 38, in the case of an eligible employer, the retirement auto-enrollment credit determined under this section for any taxable year is an amount equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40dc8d52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45T/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500 for any taxable year occurring during the credit period, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45T/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" zero for any other taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40dc8d54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45T/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40dc8d55-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45T/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The credit period with respect to any eligible employer is the 3-taxable-year period beginning with the first taxable year for which the employer includes an eligible automatic contribution arrangement (as defined in section 414(w)(3)) in a qualified employer plan (as defined in section 4972(d)) sponsored by the employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d56-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45T/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of arrangement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No taxable year with respect to an employer shall be treated as occurring within the credit period unless the arrangement described in paragraph (1) is included in the plan for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40dc8d57-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45T/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible employer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “eligible employer” has the meaning given such term in section 408(p)(2)(C)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id40dc8d58-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dO/tI/s105/a"},"text":"Pub. L. 116–94, div. O, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3148"},"text":"133 Stat. 3148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id40dc8d59-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id40dc8d5a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id40dc8d5b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2019-12-31"},"text":"Dec. 31, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/s105/d"},"text":"section 105(d) of Pub. L. 116–94","children":[],"tail":", set out as an Effective Date of 2019 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
