{"tag":"section","attrib":{"id":"id47583fe9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7446"},"text":null,"children":[{"tag":"num","attrib":{"value":"7446"},"text":"§ 7446.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Times and places of sessions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The times and places of the sessions of the Tax Court and of its divisions shall be prescribed by the chief judge with a view to securing reasonable opportunity to taxpayers to appear before the Tax Court or any of its divisions, with as little inconvenience and expense to taxpayers as is practicable.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id47583fea-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/880"},"text":"68A Stat. 880","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
