{"tag":"section","attrib":{"id":"id44ae2f6a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1043"},"text":null,"children":[{"tag":"num","attrib":{"value":"1043"},"text":"§ 1043.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of property to comply with conflict-of-interest requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44ae2f6b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1043/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonrecognition of gain","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an eligible person sells any property pursuant to a certificate of divestiture, at the election of the taxpayer, gain from such sale shall be recognized only to the extent that the amount realized on such sale exceeds the cost (to the extent not previously taken into account under this subsection) of any permitted property purchased by the taxpayer during the 60-day period beginning on the date of such sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ae2f6c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1043/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ae2f6d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1043/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ae2f6e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1043/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer or employee of the executive branch, or a judicial officer, of the Federal Government, but does not mean a special Government employee as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s202"},"text":"section 202 of title 18","children":[],"tail":", United States Code, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ae2f6f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1043/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any spouse or minor or dependent child whose ownership of any property is attributable under any statute, regulation, rule, judicial canon, or executive order referred to in paragraph (2) to a person referred to in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ae2f70-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1043/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificate of divestiture","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “certificate of divestiture” means any written determination—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ae2f71-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1043/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that states that divestiture of specific property is reasonably necessary to comply with any Federal conflict of interest statute, regulation, rule, judicial canon, or executive order (including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s208"},"text":"section 208 of title 18","children":[],"tail":", United States Code), or requested by a congressional committee as a condition of confirmation,"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ae2f72-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1043/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has been issued by the President or the Director of the Office of Government Ethics, in the case of executive branch officers or employees, or by the Judicial Conference of the United States (or its designee), in the case of judicial officers, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ae2f73-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1043/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that identifies the specific property to be divested.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ae2f74-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1043/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “permitted property” means any obligation of the United States or any diversified investment fund approved by regulations issued by the Office of Government Ethics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ae2f75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1043/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The taxpayer shall be considered to have purchased any permitted property if, but for subsection (c), the unadjusted basis of such property would be its cost within the meaning of section 1012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ae2f76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1043/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for trusts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the trustee of a trust shall be treated as an eligible person with respect to property which is held in the trust if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ae2f77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1043/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person referred to in paragraph (1)(A) has a beneficial interest in the principal or income of the trust, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ae2f78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1043/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person referred to in paragraph (1)(B) has a beneficial interest in the principal or income of the trust and such interest is attributable under any statute, regulation, rule, judicial canon, or executive order referred to in paragraph (2) to a person referred to in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ae2f79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1043/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “judicial officer” means the Chief Justice of the United States, the Associate Justices of the Supreme Court, and the judges of the United States courts of appeals, United States district courts, including the district courts in Guam, the Northern Mariana Islands, and the Virgin Islands, Court of Appeals for the Federal Circuit, Court of International Trade, Tax Court, Court of Federal Claims, Court of Appeals for Veterans Claims, United States Court of Appeals for the Armed Forces, and any court created by Act of Congress, the judges of which are entitled to hold office during good behavior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ae2f7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1043/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If gain from the sale of any property is not recognized by reason of subsection (a), such gain shall be applied to reduce (in the order acquired) the basis for determining gain or loss of any permitted property which is purchased by the taxpayer during the 60-day period described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44ae2f7b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194/tV/s502/a"},"text":"Pub. L. 101–194, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1754"},"text":"103 Stat. 1754","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/280/s6/a/1"},"text":"Pub. L. 101–280, § 6(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-04"},"text":"May 4, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/160"},"text":"104 Stat. 160","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11703/a/1"},"text":"Pub. L. 101–508, title XI, § 11703(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-516"},"text":"104 Stat. 1388–516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s418/a"},"text":"Pub. L. 109–432, div. A, title IV, § 418(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2966"},"text":"120 Stat. 2966","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44ae2f7c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44ae2f7d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44ae2f7e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s418/a/1/A"},"text":"Pub. L. 109–432, § 418(a)(1)(A)","children":[],"tail":", inserted “, or a judicial officer,” after “executive branch”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B), (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s418/a/1/B"},"text":"Pub. L. 109–432, § 418(a)(1)(B)","children":[],"tail":", (2)(A), inserted “judicial canon,” after “rule,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s418/a/2/B"},"text":"Pub. L. 109–432, § 418(a)(2)(B)","children":[],"tail":", inserted “in the case of executive branch officers or employees, or by the Judicial Conference of the United States (or its designee), in the case of judicial officers,” after “Ethics,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s418/a/3"},"text":"Pub. L. 109–432, § 418(a)(3)","children":[],"tail":", inserted “judicial canon,” after “rule,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s418/b"},"text":"Pub. L. 109–432, § 418(b)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted “to the extent not previously taken into account under this subsection” for “reduced by any basis adjustment under subsection (c) attributable to a prior sale”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/280"},"text":"Pub. L. 101–280","children":[],"tail":" added par. (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44ae2f7f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44ae2f80-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s418/c"},"text":"Pub. L. 109–432, div. A, title IV, § 418(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2967"},"text":"120 Stat. 2967","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/432/dA/tIV/s418/c"},"text":"“The amendments made by this section [amending this section] shall apply to sales after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44ae2f81-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11703/a/2"},"text":"Pub. L. 101–508, title XI, § 11703(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-517"},"text":"104 Stat. 1388–517","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/508/tXI/s11703/a/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall apply to sales after ","children":[{"tag":"date","attrib":{"date":"1989-11-30"},"text":"November 30, 1989","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/280/s6/a/3"},"text":"Pub. L. 101–280, § 6(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-04"},"text":"May 4, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/160"},"text":"104 Stat. 160","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/280/s6/a/3"},"text":"“The amendment made by paragraph (1) [amending this section] and the provisions of paragraph (2) [set out below] shall apply to sales after ","children":[{"tag":"date","attrib":{"date":"1989-11-30"},"text":"November 30, 1989","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44ae2f82-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to sales after ","children":[{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/s502/c"},"text":"section 502(c) of Pub. L. 101–194","children":[],"tail":", set out as an Effective Date of 1989 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1016"},"text":"section 1016 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id44ae2f83-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Property Sold Before ","children":[{"tag":"date","attrib":{"date":"1990-06-19"},"text":"June 19, 1990","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/280/s6/a/2"},"text":"Pub. L. 101–280, § 6(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-04"},"text":"May 4, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/160"},"text":"104 Stat. 160","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/280/s6/a/2"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of section 1043 of such Code—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property sold before ","children":[{"tag":"date","attrib":{"date":"1990-06-19"},"text":"June 19, 1990","children":[],"tail":", shall be treated as sold pursuant to a certificate of divestiture (as defined in subsection (b)(2) thereof) if such a certificate is issued with respect to such sale before such date, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any such case, the 60-day period referred to in subsection (a) thereof shall not expire before the end of the 60-day period beginning on the date on which the certificate of divestiture was issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding subparagraph (A), section 1043 of such Code shall not apply to any sale before ","children":[{"tag":"date","attrib":{"date":"1990-04-19"},"text":"April 19, 1990","children":[],"tail":", unless—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale was made in order to comply with an ethics agreement or pursuant to specific direction from the appropriate agency or confirming committee, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the justification for the sale meets the criteria set forth in subsection (b)(2)(A) thereof as implemented by the interim regulations implementing such section 1043, published on ","children":[{"tag":"date","attrib":{"date":"1990-04-18"},"text":"April 18, 1990","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
