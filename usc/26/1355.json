{"tag":"section","attrib":{"id":"id44e9d8b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355"},"text":null,"children":[{"tag":"num","attrib":{"value":"1355"},"text":"§ 1355.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44e9d8b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e9d8b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electing corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “electing corporation” means any corporation for which an election is in effect under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e9d8b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electing group; controlled group","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44e9d8b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electing group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “electing group” means a controlled group of which one or more members is an electing corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44e9d8b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “controlled group” means any group which would be treated as a single employer under subsection (a) or (b) of section 52 if paragraphs (1) and (2) of section 52(a) did not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e9d8b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying vessel operator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualifying vessel operator” means any corporation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44e9d8b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who operates one or more qualifying vessels, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44e9d8b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who meets the shipping activity requirement in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e9d8ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying vessel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualifying vessel” means a self-propelled (or a combination self-propelled and non-self-propelled) United States flag vessel of not less than 6,000 deadweight tons used exclusively in the United States foreign trade during the period that the election under this subchapter is in effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e9d8bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States flag vessel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States flag vessel” means any vessel documented under the laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e9d8bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States domestic trade","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States domestic trade” means the transportation of goods or passengers between places in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e9d8bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States foreign trade","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States foreign trade” means the transportation of goods or passengers between a place in the United States and a foreign place or between foreign places.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e9d8be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operating a vessel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e9d8bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), a person is treated as operating any vessel during any period if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44e9d8c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44e9d8c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such vessel is owned by, or chartered (including a time charter) to, the person, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44e9d8c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person provides services for such vessel pursuant to an operating agreement, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44e9d8c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such vessel is in use as a qualifying vessel during such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e9d8c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bareboat charters","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person is treated as operating and using a vessel that it has chartered out on bareboat charter terms only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44e9d8c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44e9d8c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is temporarily surplus to the person’s requirements and the term of the charter does not exceed 3 years, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44e9d8c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is bareboat chartered to a member of a controlled group which includes such person or to an unrelated person who sub-bareboats or time charters the vessel to such a member (including the owner of the vessel), and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44e9d8c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is used as a qualifying vessel by the person to whom ultimately chartered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e9d8c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shipping activity requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e9d8ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subsection, a corporation meets the shipping activity requirement of this subsection for any taxable year only if the requirement of paragraph (4) is met for each of the 2 preceding taxable years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e9d8cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for 1st year of election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A corporation meets the shipping activity requirement of this subsection for the first taxable year for which the election under section 1354(a) is in effect only if the requirement of paragraph (4) is met for the preceding taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e9d8cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A corporation who is a member of a controlled group meets the shipping activity requirement of this subsection only if such requirement is met determined by treating all members of such group as 1 person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e9d8cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirement of this paragraph is met for any taxable year if, on average during such year, at least 25 percent of the aggregate tonnage of qualifying vessels used by the corporation were owned by such corporation or chartered to such corporation on bareboat charter terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e9d8ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities carried on partnerships, etc.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In applying this subchapter to a partner in a partnership—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e9d8cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each partner shall be treated as operating vessels operated by the partnership,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e9d8d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each partner shall be treated as conducting the activities conducted by the partnership, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e9d8d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of a partner’s ownership, charter, or operating agreement interest in any vessel operated by the partnership shall be determined on the basis of the partner’s interest in the partnership.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A similar rule shall apply with respect to other pass-thru entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e9d8d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of temporarily ceasing to operate a qualifying vessel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e9d8d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsections (b) and (c), an electing corporation shall be treated as continuing to use a qualifying vessel during any period of temporary cessation if the electing corporation gives timely notice to the Secretary stating—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44e9d8d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that it has temporarily ceased to operate the qualifying vessel, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44e9d8d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its intention to resume operating the qualifying vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e9d8d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notice shall be deemed timely if given not later than the due date (including extensions) for the corporation’s tax return for the taxable year in which the temporary cessation begins.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e9d8d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period disregard in effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The period of temporary cessation under paragraph (1) shall continue until the earlier of the date on which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44e9d8d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the electing corporation abandons its intention to resume operation of the qualifying vessel, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44e9d8d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the electing corporation resumes operation of the qualifying vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e9d8da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of temporarily operating a qualifying vessel in the United States domestic trade","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e9d8db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, an electing corporation shall be treated as continuing to use a qualifying vessel in the United States foreign trade during any period of temporary use in the United States domestic trade if the electing corporation gives timely notice to the Secretary stating—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ec48dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that it temporarily operates or has operated in the United States domestic trade a qualifying vessel which had been used in the United States foreign trade, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ec48dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its intention to resume operation of the vessel in the United States foreign trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ec48de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notice shall be deemed timely if given not later than the due date (including extensions) for the corporation’s tax return for the taxable year in which the temporary cessation begins.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ec48df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period disregard in effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The period of temporary use under paragraph (1) continues until the earlier of the date on which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ec48e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the electing corporation abandons its intention to resume operations of the vessel in the United States foreign trade, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ec48e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the electing corporation resumes operation of the vessel in the United States foreign trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ec48e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No disregard if domestic trade use exceeds 30 days","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to any qualifying vessel which is operated in the United States domestic trade for more than 30 days during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ec48e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lakes domestic shipping to not disqualify vessel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ec48e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the electing corporation elects (at such time and in such manner as the Secretary may require) to apply this subsection for any taxable year to any qualifying vessel which is used in qualified zone domestic trade during the taxable year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ec48e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solely for purposes of subsection (a)(4), such use shall be treated as use in United States foreign trade (and not as use in United States domestic trade), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ec48e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (f) shall not apply with respect to such vessel for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ec48e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of temporarily operating vessel in United States domestic trade","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a qualifying vessel to which this subsection applies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ec48e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An electing corporation shall be treated as using such vessel in qualified zone domestic trade during any period of temporary use in the United States domestic trade (other than qualified zone domestic trade) if the electing corporation gives timely notice to the Secretary stating—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44ec48e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/g/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that it temporarily operates or has operated in the United States domestic trade (other than qualified zone domestic trade) a qualifying vessel which had been used in the United States foreign trade or qualified zone domestic trade, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44ec48ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/g/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its intention to resume operation of the vessel in the United States foreign trade or qualified zone domestic trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ec48eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notice shall be deemed timely if given not later than the due date (including extensions) for the corporation’s tax return for the taxable year in which the temporary cessation begins.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ec48ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period disregard in effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The period of temporary use under subparagraph (A) continues until the earlier of the date of which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44ec48ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/g/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the electing corporation abandons its intention to resume operations of the vessel in the United States foreign trade or qualified zone domestic trade, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44ec48ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/g/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the electing corporation resumes operation of the vessel in the United States foreign trade or qualified zone domestic trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ec48ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No disregard if domestic trade use exceeds 30 days","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply to any qualifying vessel which is operated in the United States domestic trade (other than qualified zone domestic trade) for more than 30 days during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ec48f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of income and deductions to qualifying shipping activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a qualifying vessel to which this subsection applies, the Secretary shall prescribe rules for the proper allocation of income, expenses, losses, and deductions between the qualified shipping activities and the other activities of such vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ec48f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified zone domestic trade","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ec48f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/g/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified zone domestic trade” means the transportation of goods or passengers between places in the qualified zone if such transportation is in the United States domestic trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ec48f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/g/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified zone","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified zone” means the Great Lakes Waterway and the St. Lawrence Seaway.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ec48f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1355/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary or appropriate to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44ec48f5-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tII/s248/a"},"text":"Pub. L. 108–357, title II, § 248(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1452"},"text":"118 Stat. 1452","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s403/g/1/B"},"text":"Pub. L. 109–135, title IV, § 403(g)(1)(B)","children":[],"tail":"–(2), "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2624"},"text":"119 Stat. 2624","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/222/tII/s205/a"},"text":"Pub. L. 109–222, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-05-17"},"text":"May 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/350"},"text":"120 Stat. 350","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV"},"text":"Pub. L. 109–432, div. A, title IV","children":[],"tail":", §§ 413(a), 415(a), "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2963"},"text":"120 Stat. 2963","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/187"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(187)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1193"},"text":"132 Stat. 1193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44ec48f6-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44ec48f7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44ec48f8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “on which” for “of which” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s413/a"},"text":"Pub. L. 109–432, § 413(a)","children":[],"tail":", substituted “6,000” for “10,000 (6,000, in the case of taxable years beginning after "},{"tag":"date","attrib":{"date":"2005-12-31"},"text":"December 31, 2005","children":[],"tail":", and ending before "},{"tag":"date","attrib":{"date":"2011-01-01"},"text":"January 1, 2011","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/222"},"text":"Pub. L. 109–222","children":[],"tail":" inserted “(6,000, in the case of taxable years beginning after "},{"tag":"date","attrib":{"date":"2005-12-31"},"text":"December 31, 2005","children":[],"tail":", and ending before "},{"tag":"date","attrib":{"date":"2011-01-01"},"text":"January 1, 2011","children":[],"tail":")” after “10,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s415/a"},"text":"Pub. L. 109–432, § 415(a)","children":[],"tail":", added subsec. (g) and redesignated former subsec. (g) as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/g/1/B"},"text":"Pub. L. 109–135, § 403(g)(1)(B)","children":[],"tail":", struck out heading and text of par. (8). Text read as follows: “The term ‘charter’ includes an operating agreement.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/g/1/C"},"text":"Pub. L. 109–135, § 403(g)(1)(C)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “Except as provided in paragraph (2), a person is treated as operating any vessel during any period if such vessel is—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) owned by, or chartered (including a time charter) to, the person, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) is in use as a qualifying vessel during such period.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/g/2"},"text":"Pub. L. 109–135, § 403(g)(2)","children":[],"tail":", substituted “determined by treating all members of such group as 1 person.” for “determined—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) by treating all members of such group as 1 person, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) by disregarding vessel charters between members of such group.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/g/1/D"},"text":"Pub. L. 109–135, § 403(g)(1)(D)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “the extent of a partner’s ownership or charter interest in any vessel owned by or chartered to the partnership shall be determined on the basis of the partner’s interest in the partnership.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44ec48f9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44ec48fa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s413/b"},"text":"Pub. L. 109–432, div. A, title IV, § 413(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2963"},"text":"120 Stat. 2963","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/432/dA/tIV/s413/b"},"text":"“The amendment made by this section [amending this section] shall take effect as if included in section 205 of the Tax Increase Prevention and Reconciliation Act of 2005 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/222"},"text":"Pub. L. 109–222","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s415/b"},"text":"Pub. L. 109–432, div. A, title IV, § 415(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2965"},"text":"120 Stat. 2965","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/432/dA/tIV/s415/b"},"text":"“The amendments made by this section [amending this section] shall apply to taxable years beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/222/tII/s205/b"},"text":"Pub. L. 109–222, title II, § 205(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-05-17"},"text":"May 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/350"},"text":"120 Stat. 350","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/222/tII/s205/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2005-12-31"},"text":"December 31, 2005","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44ec48fb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" effective as if included in the provisions of the American Jobs Creation Act of 2004, "},{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":", to which they relate, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/nn"},"text":"section 403(nn) of Pub. L. 109–135","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s26"},"text":"section 26 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44ec48fc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s248/c"},"text":"section 248(c) of Pub. L. 108–357","children":[],"tail":", set out as an Effective Date of 2004 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s56"},"text":"section 56 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
