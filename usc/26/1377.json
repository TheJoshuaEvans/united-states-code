{"tag":"section","attrib":{"id":"id44f83061-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377"},"text":null,"children":[{"tag":"num","attrib":{"value":"1377"},"text":"§ 1377.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rule","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44f83062-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pro rata share","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f83063-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), each shareholder’s pro rata share of any item for any taxable year shall be the sum of the amounts determined with respect to the shareholder—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44f83064-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by assigning an equal portion of such item to each day of the taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f83065-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" then by dividing that portion pro rata among the shares outstanding on such day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f83066-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to terminate year","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44f83067-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary, if any shareholder terminates the shareholder’s interest in the corporation during the taxable year and all affected shareholders and the corporation agree to the application of this paragraph, paragraph (1) shall be applied to the affected shareholders as if the taxable year consisted of 2 taxable years the first of which ends on the date of the termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f83068-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affected shareholders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the term “affected shareholders” means the shareholder whose interest is terminated and all shareholders to whom such shareholder has transferred shares during the taxable year. If such shareholder has transferred shares to the corporation, the term “affected shareholders” shall include all persons who are shareholders during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f83069-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post-termination transition period","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f8306a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the term “post-termination transition period” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44f8306b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the period beginning on the day after the last day of the corporation’s last taxable year as an S corporation and ending on the later of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44f8306c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the day which is 1 year after such last day, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44f8306d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the due date for filing the return for such last year as an S corporation (including extensions),","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f8306e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 120-day period beginning on the date of any determination pursuant to an audit of the taxpayer which follows the termination of the corporation’s election and which adjusts a subchapter S item of income, loss, or deduction of the corporation arising during the S period (as defined in section 1368(e)(2)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f8306f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 120-day period beginning on the date of a determination that the corporation’s election under section 1362(a) had terminated for a previous taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f83070-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the term “determination” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44f83071-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a determination as defined in section 1313(a), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f83072-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement between the corporation and the Secretary that the corporation failed to qualify as an S corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f83073-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for audit related post-termination transition periods","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44f83074-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No application to carryovers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1)(B) shall not apply for purposes of section 1366(d)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f83075-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on application to distributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1)(B) shall apply to a distribution described in section 1371(e) only to the extent that the amount of such distribution does not exceed the aggregate increase (if any) in the accumulated adjustments account (within the meaning of section 1368(e)) by reason of the adjustments referred to in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f83076-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1377/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of making elections, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any election under this subchapter, and any revocation under section 1362(d)(1), shall be made in such manner as the Secretary shall by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44f83077-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/354/s2"},"text":"Pub. L. 97–354, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"Oct. 19, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1685"},"text":"96 Stat. 1685","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI"},"text":"Pub. L. 104–188, title I","children":[],"tail":", §§ 1306–1307(b), "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1780"},"text":"110 Stat. 1780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/311/tIV/s407/a"},"text":"Pub. L. 108–311, title IV, § 407(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-04"},"text":"Oct. 4, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1190"},"text":"118 Stat. 1190","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44f83078-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44f83079-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id44f8307a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1377, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s64/a"},"text":"Pub. L. 85–866, title I, § 64(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1656"},"text":"72 Stat. 1656","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tIX/s902/b/1"},"text":"Pub. L. 94–455, title IX, § 902(b)(1)","children":[],"tail":", title XIX, § 1901(b)(32)(B)(iv), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1608"},"text":"90 Stat. 1608","children":[],"tail":", 1800, related to special rules applicable to earnings and profits of electing small business corporations, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/97/354/s2"},"text":"section 2 of Pub. L. 97–354","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44f8307b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311"},"text":"Pub. L. 108–311","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1306"},"text":"Pub. L. 104–188, § 1306","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “Under regulations prescribed by the Secretary, if any shareholder terminates his interest in the corporation during the taxable year and all persons who are shareholders during the taxable year agree to the application of this paragraph, paragraph (1) shall be applied as if the taxable year consisted of 2 taxable years the first of which ends on the date of the termination.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A) to (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1307/a"},"text":"Pub. L. 104–188, § 1307(a)","children":[],"tail":", struck out “and” at end of subpar. (A)(ii), added subpar. (B), and redesignated former subpar. (B) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A) to (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1307/b"},"text":"Pub. L. 104–188, § 1307(b)","children":[],"tail":", added subpar. (A), redesignated subpar. (C) as (B), and struck out former subpars. (A) and (B) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) a court decision which becomes final,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) a closing agreement, or”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44f8307c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44f8307d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311"},"text":"Pub. L. 108–311","children":[],"tail":" effective as if included in the provisions of the Small Business Job Protection Act of 1996, "},{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/311/s407/c"},"text":"section 407(c) of Pub. L. 108–311","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44f8307e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXVI/s1601/c/2"},"text":"Pub. L. 105–34, title XVI, § 1601(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1087"},"text":"111 Stat. 1087","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tXVI/s1601/c/2"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding section 1317 of the Small Business Job Protection Act of 1996 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":", enacting provisions set out as notes under sections 641 and 1362 of this title], the amendments made by subsections (a) and (b) of section 1307 of such Act [amending this section] shall apply to determinations made after "},{"tag":"date","attrib":{"date":"1996-12-31"},"text":"December 31, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In no event shall the 120-day period referred to in section 1377(b)(1)(B) of the Internal Revenue Code of 1986 (as added by such section 1307) expire before the end of the 120-day period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1996-12-31"},"text":"Dec. 31, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1317/a"},"text":"section 1317(a) of Pub. L. 104–188","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s641"},"text":"section 641 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44f8307f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1982-12-31"},"text":"Dec. 31, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/354/s6/a"},"text":"section 6(a) of Pub. L. 97–354","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1361"},"text":"section 1361 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
