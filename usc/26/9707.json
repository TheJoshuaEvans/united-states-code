{"tag":"section","attrib":{"id":"id47c8408f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9707"},"text":null,"children":[{"tag":"num","attrib":{"value":"9707"},"text":"§ 9707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to pay premium","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47c84090-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failures to pay","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c84091-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9707/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premiums for eligible beneficiaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed a penalty on the failure of any assigned operator to pay any premium required to be paid under section 9704 with respect to any eligible beneficiary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c84092-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9707/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions required under the mining laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed a penalty on the failure of any person to make a contribution required under section 402(h)(5)(B)(ii) of the Surface Mining Control and Reclamation Act of 1977 to a plan referred to in section 402(h)(2)(C) of such Act. For purposes of applying this section, each such required monthly contribution for the hours worked of any individual shall be treated as if it were a premium required to be paid under section 9704 with respect to an eligible beneficiary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c84093-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the penalty imposed by subsection (a) on any failure with respect to any eligible beneficiary shall be $100 per day in the noncompliance period with respect to any such failure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c84094-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9707/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “noncompliance period” means, with respect to any failure to pay any premium or installment thereof, the period—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c84095-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9707/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning on the due date for such premium or installment, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c84096-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9707/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ending on the date of payment of such premium or installment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c84097-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9707/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on amount of penalty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c84098-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9707/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed by subsection (a) on any failure during any period for which it is established to the satisfaction of the Secretary of the Treasury that none of the persons responsible for such failure knew, or exercising reasonable diligence would have known, that such failure existed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c84099-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9707/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corrections","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No penalty shall be imposed by subsection (a) on any failure if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c8409a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9707/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such failure was due to reasonable cause and not to willful neglect, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c8409b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9707/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such failure is corrected during the 30-day period beginning on the 1st date that any of the persons responsible for such failure knew, or exercising reasonable diligence would have known, that such failure existed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c8409c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9707/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a failure that is due to reasonable cause and not to willful neglect, the Secretary of the Treasury may waive all or part of the penalty imposed by subsection (a) for failures to the extent that the Secretary determines, in his sole discretion, that the payment of such penalty would be excessive relative to the failure involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c8409d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9707/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The person failing to meet the requirements of section 9704 shall be liable for the penalty imposed by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c8409e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9707/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this title, the penalty imposed by this section shall be treated in the same manner as the tax imposed by section 4980B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47c8409f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s19143/a"},"text":"Pub. L. 102–486, title XIX, § 19143(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3050"},"text":"106 Stat. 3050","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1704/t/65"},"text":"Pub. L. 104–188, title I, § 1704(t)(65)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1890"},"text":"110 Stat. 1890","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dC/tII/s213/b/1"},"text":"Pub. L. 109–432, div. C, title II, § 213(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3027"},"text":"120 Stat. 3027","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47c840a0-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47c840a1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id47c840a2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 402 of the Surface Mining Control and Reclamation Act of 1977, referred to in subsec. (a)(2), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1232"},"text":"section 1232 of Title 30","children":[],"tail":", Mineral Lands and Mining."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47c840a3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" amended heading and text of subsec. (a) generally. Prior to amendment, text read as follows: “There is hereby imposed a penalty on the failure of any assigned operator to pay any premium required to be paid under section 9704 with respect to any eligible beneficiary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" struck out comma after “diligence”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
