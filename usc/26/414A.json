{"tag":"section","attrib":{"id":"id4343c94a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A"},"text":null,"children":[{"tag":"num","attrib":{"value":"414A"},"text":"§ 414A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements related to automatic enrollment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4343c94b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4343c94c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an arrangement shall not be treated as a qualified cash or deferred arrangement described in section 401(k) unless such arrangement meets the automatic enrollment requirements of subsection (b), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4343c94d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annuity contract otherwise described in section 403(b) which is purchased under a salary reduction agreement shall not be treated as described in such section unless such agreement meets the automatic enrollment requirements of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4343c94e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automatic enrollment requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4343c94f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An arrangement or agreement meets the requirements of this subsection if such arrangement or agreement is an eligible automatic contribution arrangement (as defined in section 414(w)(3)) which meets the requirements of paragraphs (2) through (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4343c950-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of permissible withdrawals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible automatic contribution arrangement meets the requirements of this paragraph if such arrangement allows employees to make permissible withdrawals (as defined in section 414(w)(2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4343c951-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum contribution percentage","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4343c952-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible automatic contribution arrangement meets the requirements of this paragraph if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4343c953-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the uniform percentage of compensation contributed by the participant under such arrangement during the first year of participation is not less than 3 percent and not more than 10 percent (unless the participant specifically elects not to have such contributions made or to have such contributions made at a different percentage), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4343c954-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective for the first day of each plan year starting after each completed year of participation under such arrangement such uniform percentage is increased by 1 percentage point (to at least 10 percent, but not more than 15 percent) unless the participant specifically elects not to have such contributions made or to have such contributions made at a different percentage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4343c955-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial reduced ceiling for certain plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any eligible automatic contribution arrangement (other than an arrangement that meets the requirements of paragraph (12) or (13) of section 401(k)), for plan years ending before ","children":[{"tag":"date","attrib":{"date":"2025-01-01"},"text":"January 1, 2025","children":[],"tail":", subparagraph (A)(ii) shall be applied by substituting “10 percent” for “15 percent”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4343c956-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible automatic contribution arrangement meets the requirements of this paragraph if amounts contributed pursuant to such arrangement, and for which no investment is elected by the participant, are invested in accordance with the requirements of section 2550.404c-5 of title 29, Code of Federal Regulations (or any successor regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4343c957-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4343c958-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simple plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to any simple plan (within the meaning of section 401(k)(11)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4343c959-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for plans or arrangements established before enactment of section","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4343c95a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4343c95b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any qualified cash or deferred arrangement established before the date of the enactment of this section, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4343c95c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any annuity contract purchased under a plan established before the date of the enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4343c95d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post-enactment adoption of multiple employer plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply in the case of an employer adopting after such date of enactment a plan maintained by more than one employer, and subsection (a) shall apply with respect to such employer as if such plan were a single plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4343c95e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for governmental and church plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to any governmental plan (within the meaning of section 414(d)) or any church plan (within the meaning of section 414(e)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4343c95f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for new and small businesses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4343c960-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to any qualified cash or deferred arrangement, or any annuity contract purchased under a plan, while the employer maintaining such plan (and any predecessor employer) has been in existence for less than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4343c961-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small businesses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to any qualified cash or deferred arrangement, or any annuity contract purchased under a plan, earlier than the date that is 1 year after the close of the first taxable year with respect to which the employer maintaining the plan normally employed more than 10 employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4343c962-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s414A/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of multiple employer plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a plan maintained by more than 1 employer, subparagraphs (A) and (B) shall be applied separately with respect to each such employer, and all such employers to which subsection (a) applies (after the application of this paragraph) shall be treated as maintaining a separate plan for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4343c963-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dT/tI/s101/a"},"text":"Pub. L. 117–328, div. T, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5275"},"text":"136 Stat. 5275","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4343c964-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4343c965-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4343c966-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, and such date of enactment, referred to in subsec. (c)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4343c967-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4343c968-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dT/tI/s101/c"},"text":"Pub. L. 117–328, div. T, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5277"},"text":"136 Stat. 5277","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dT/tI/s101/c"},"text":"“The amendments made by this section [enacting this section] shall apply to plan years beginning after ","children":[{"tag":"date","attrib":{"date":"2024-12-31"},"text":"December 31, 2024","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
