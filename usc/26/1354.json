{"tag":"section","attrib":{"id":"id44e9d897-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1354"},"text":null,"children":[{"tag":"num","attrib":{"value":"1354"},"text":"§ 1354.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative tax election; revocation; termination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44e9d898-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1354/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualifying vessel operator may elect the application of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e9d899-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1354/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time and manner; years for which effective","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An election under this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e9d89a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1354/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made in such form as prescribed by the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e9d89b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1354/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be effective for the taxable year for which made and all succeeding taxable years until terminated under subsection (d).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such election may be effective for any taxable year only if made on or before the due date (including extensions) for filing the corporation’s return for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e9d89c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1354/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistent elections by members of controlled groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under subsection (a) by a member of a controlled group shall apply to all qualifying vessel operators that are members of such group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e9d89d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1354/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e9d89e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1354/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By revocation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44e9d89f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1354/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under subsection (a) may be terminated by revocation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44e9d8a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1354/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" When effective","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (C)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44e9d8a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1354/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a revocation made during the taxable year and on or before the 15th day of the 4th month thereof shall be effective on the 1st day of such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44e9d8a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1354/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a revocation made during the taxable year but after such 15th day shall be effective on the 1st day of the following taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44e9d8a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1354/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation may specify prospective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the revocation specifies a date for revocation which is on or after the day on which the revocation is made, the revocation shall be effective for taxable years beginning on and after the date so specified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e9d8a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1354/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By person ceasing to be qualifying vessel operator","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44e9d8a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1354/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under subsection (a) shall be terminated whenever (at any time on or after the 1st day of the 1st taxable year for which the corporation is an electing corporation) such corporation ceases to be a qualifying vessel operator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44e9d8a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1354/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" When effective","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any termination under this paragraph shall be effective on and after the date of cessation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44e9d8a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1354/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annualization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such annualization and other rules as are appropriate in the case of a termination under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e9d8a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1354/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election after termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a qualifying vessel operator has made an election under subsection (a) and if such election has been terminated under subsection (d), such operator (and any successor operator) shall not be eligible to make an election under subsection (a) for any taxable year before its 5th taxable year which begins after the 1st taxable year for which such termination is effective, unless the Secretary consents to such election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44e9d8a9-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tII/s248/a"},"text":"Pub. L. 108–357, title II, § 248(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1451"},"text":"118 Stat. 1451","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s403/g/4"},"text":"Pub. L. 109–135, title IV, § 403(g)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2624"},"text":"119 Stat. 2624","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/41/tII/s2006/a/2/C"},"text":"Pub. L. 114–41, title II, § 2006(a)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-07-31"},"text":"July 31, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/457"},"text":"129 Stat. 457","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44e9d8aa-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44e9d8ab-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44e9d8ac-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (d)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/41"},"text":"Pub. L. 114–41","children":[],"tail":" substituted “4th month” for “3d month”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" inserted “on or” after “only if made” in concluding provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44e9d8ad-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44e9d8ae-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/41"},"text":"Pub. L. 114–41","children":[],"tail":" applicable to returns for taxable years beginning after "},{"tag":"date","attrib":{"date":"2015-12-31"},"text":"Dec. 31, 2015","children":[],"tail":", with special rule for certain C corporations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/41/s2006/a/3"},"text":"section 2006(a)(3) of Pub. L. 114–41","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s170"},"text":"section 170 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44e9d8af-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" effective as if included in the provision of the American Jobs Creation Act of 2004, "},{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/nn"},"text":"section 403(nn) of Pub. L. 109–135","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s26"},"text":"section 26 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44e9d8b0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s248/c"},"text":"section 248(c) of Pub. L. 108–357","children":[],"tail":", set out as an Effective Date of 2004 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s56"},"text":"section 56 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":