:[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4221"},"text":"section 4221 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45c78e8b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" struck out “4001(c), 4001(d),” after “provided by sections”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" substituted “4053(6)” for “4053(a)(6)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" substituted “Under regulations” for “Export” in heading and struck out “in the case of any sale or resale for export,” after “this paragraph,” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" substituted “4001(d)” for “4002(b), 4003(c), 4004(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11212/b/2"},"text":"Pub. L. 101–508, § 11212(b)(2)","children":[],"tail":", substituted “Denial, revocation, or suspension” for “Revocation or suspension” in heading, “denied, revoked, or suspended” for “revoked or suspended” in introductory provisions, and “denial, revocation, or suspension” for “revocation or suspension” in par. (2) and concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11221/d/3"},"text":"Pub. L. 101–508, § 11221