{"tag":"section","attrib":{"id":"id45c5448a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4222"},"text":null,"children":[{"tag":"num","attrib":{"value":"4222"},"text":"§ 4222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45c5448b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4222/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), section 4221 shall not apply with respect to the sale of any article unless the manufacturer, the first purchaser, and the second purchaser (if any) are all registered under this section. Registration under this section shall be made at such time, in such manner and form, and subject to such terms and conditions, as the Secretary may by regulations prescribe. A registration under this section may be used only in accordance with regulations prescribed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45c5448c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4222/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45c5448d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4222/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchases by State and local governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to any State or local government in connection with the purchase by it of any article if such State or local government complies with such regulations relating to the use of exemption certificates in lieu of registration as the Secretary shall prescribe to carry out the purpose of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45c78e7e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4222/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to such regulations as the Secretary may prescribe for the purpose of this paragraph, the Secretary may relieve the purchaser or the second purchaser, or both, from the requirement of registering under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45c78e7f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4222/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain purchases and sales by the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall apply to purchases and sales by the United States only to the extent provided by regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45c78e80-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4222/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"[(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/tII/s208/e"},"text":"Pub. L. 89–44, title II, § 208(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/141"},"text":"79 Stat. 141","children":[],"tail":"]"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45c78e81-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4222/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplies for vessels or aircraft","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to a sale of an article for use by the purchaser as supplies for any vessel or aircraft if such purchaser complies with such regulations relating to the use of exemption certificates in lieu of registration as the Secretary shall prescribe to carry out the purpose of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45c78e82-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4222/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial, revocation, or suspension of registration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Secretary, the registration of any person under this section may be denied, revoked, or suspended if the Secretary determines—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45c78e83-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4222/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such person has used such registration to avoid the payment of any tax imposed by this chapter, or to postpone or in any manner to interfere with the collection of any such tax, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45c78e84-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4222/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such denial, revocation, or suspension is necessary to protect the revenue.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The denial, revocation, or suspension under this subsection shall be in addition to any penalty provided by law for any act or failure to act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45c78e85-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4222/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration in the case of certain other exemptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section may be extended to, and made applicable with respect to, the exemptions provided by sections 4053(6), 4064(b)(1)(C), 4101, and 4182(b), and the exemptions authorized under section 4293 in respect of the taxes imposed by this chapter, to the extent provided by regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45c78e86-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4222/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Terms used in this section which are defined in section 4221(d) shall have the meaning given to them by section 4221(d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45c78e87-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tI/s119/a"},"text":"Pub. L. 85–859, title I, § 119(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1284"},"text":"72 Stat. 1284","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tII/s208/e"},"text":"Pub. L. 89–44, title II, § 208(e)","children":[],"tail":", title VIII, § 802(c), "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/141"},"text":"79 Stat. 141","children":[],"tail":", 159; "},{"tag":"ref","attrib":{"href":"/us/pl/92/178/tIV/s401/a/3/B"},"text":"Pub. L. 92–178, title IV, § 401(a)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/531"},"text":"85 Stat. 531","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s701/ff/2/B"},"text":"Pub. L. 95–600, title VII, § 701(ff)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2925"},"text":"92 Stat. 2925","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/618/tII"},"text":"Pub. L. 95–618, title II","children":[],"tail":", §§ 201(e), 231(f)(2), "},{"tag":"date","attrib"