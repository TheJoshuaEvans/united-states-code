{"tag":"section","attrib":{"id":"id4675a90c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048"},"text":null,"children":[{"tag":"num","attrib":{"value":"6048"},"text":"§ 6048.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information with respect to certain foreign trusts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4675a90d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of certain events","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4675a90e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On or before the 90th day (or such later day as the Secretary may prescribe) after any reportable event, the responsible party shall provide written notice of such event to the Secretary in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4675a90f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notice required by paragraph (1) shall contain such information as the Secretary may prescribe, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4675a910-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of money or other property (if any) transferred to the trust in connection with the reportable event, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4675a911-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of the trust and of each trustee and beneficiary (or class of beneficiaries) of the trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4675a912-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reportable event","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4675a913-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “reportable event” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4675a914-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creation of any foreign trust by a United States person,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4675a915-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer of any money or property (directly or indirectly) to a foreign trust by a United States person, including a transfer by reason of death, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4675a916-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the death of a citizen or resident of the United States if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4675a917-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/3/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the decedent was treated as the owner of any portion of a foreign trust under the rules of subpart E of part I of subchapter J of chapter 1, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4675a918-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/3/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any portion of a foreign trust was included in the gross estate of the decedent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4675a919-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4675a91a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fair market value sales","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A)(ii) shall not apply to any transfer of property to a trust in exchange for consideration of at least the fair market value of the transferred property. For purposes of the preceding sentence, consideration other than cash shall be taken into account at its fair market value and the rules of section 679(a)(3) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4675a91b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferred compensation and charitable trusts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraph (A) shall not apply with respect to a trust which is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4675a91c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described in section 402(b), 404(a)(4), or 404A, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4675a91d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined by the Secretary to be described in section 501(c)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4675a91e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsible party","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “responsible party” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4675a91f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grantor in the case of the creation of an inter vivos trust,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4675a920-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transferor in the case of a reportable event described in paragraph (3)(A)(ii) other than a transfer by reason of death, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4675a921-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the executor of the decedent’s estate in any other case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4675a922-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States owner of foreign trust","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4675a923-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, at any time during any taxable year of a United States person, such person is treated as the owner of any portion of a foreign trust under the rules of subpart E of part I of subchapter J of chapter 1, such person shall submit such information as the Secretary may prescribe with respect to such trust for such year and shall be responsible to ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4675a924-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such trust makes a return for such year which sets forth a full and complete accounting of all trust activities and operations for the year, the name of the United States agent for such trust, and such other information as the Secretary may prescribe, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4675a925-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such trust furnishes such information as the Secretary may prescribe to each United States person (i) who is treated as the owner of any portion of such trust or (ii) who receives (directly or indirectly) any distribution from the trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4675a926-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trusts not having United States agent","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4675a927-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the rules of this paragraph apply to any foreign trust, the determination of amounts required to be taken into account with respect to such trust by a United States person under the rules of subpart E of part I of subchapter J of chapter 1 shall be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4675a928-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States agent required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rules of this paragraph shall apply to any foreign trust to which paragraph (1) applies unless such trust agrees (in such manner, subject to such conditions, and at such time as the Secretary shall prescribe) to authorize a United States person to act as such trust’s limited agent solely for purposes of applying sections 7602, 7603, and 7604 with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4675a929-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any request by the Secretary to examine records or produce testimony related to the proper treatment of amounts required to be taken into account under the rules referred to in subparagraph (A), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4675a92a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any summons by the Secretary for such records or testimony.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The appearance of persons or production of records by reason of a United States person being such an agent shall not subject such persons or records to legal process for any purpose other than determining the correct treatment under this title of the amounts required to be taken into account under the rules referred to in subparagraph (A). A foreign trust which appoints an agent described in this subparagraph shall not be considered to have an office or a permanent establishment in the United States, or to be engaged in a trade or business in the United States, solely because of the activities of such agent pursuant to this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4675a92b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other rules to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of paragraphs (2) and (4) of section 6038A(e) shall apply for purposes of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4675a92c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting by United States beneficiaries of foreign trusts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4675a92d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any United States person receives (directly or indirectly) during any taxable year of such person any distribution from a foreign trust, such person shall make a return with respect to such trust for such year which includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4675a92e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of such trust,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4675a92f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of the distributions so received from such trust during such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4675a930-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4675a931-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion in income if records not provided","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4675a932-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If adequate records are not provided to the Secretary to determine the proper treatment of any distribution from a foreign trust, such distribution shall be treated as an accumulation distribution includible in the gross income of the distributee under chapter 1. To the extent provided in regulations, the preceding sentence shall not apply if the foreign trust elects to be subject to rules similar to the rules of subsection (b)(2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4675a933-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of accumulation distribution rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of applying section 668 in a case to which subparagraph (A) applies, the applicable number of years for purposes of section 668(a) shall be ½ of the number of years the trust has been in existence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4675a934-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4675a935-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of whether United States person makes transfer or receives distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, in determining whether a United States person makes a transfer to, or receives a distribution from, a foreign trust, the fact that a portion of such trust is treated as owned by another person under the rules of subpart E of part I of subchapter J of chapter 1 shall be disregarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4675a936-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic trusts with foreign activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent provided in regulations, a trust which is a United States person shall be treated as a foreign trust for purposes of this section and section 6677 if such trust has substantial activities, or holds substantial property, outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4675a937-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time and manner of filing information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any notice or return required under this section shall be made at such time and in such manner as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4675a938-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of return requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to suspend or modify any requirement of this section if the Secretary determines that the United States has no significant tax interest in obtaining the required information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4675a939-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6048/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States person’s return must be consistent with trust return or Secretary notified of inconsistency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of section 6034A(c) shall apply to items reported by a trust under subsection (b)(1)(B) and to United States persons referred to in such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4675a93a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/834/s7/f"},"text":"Pub. L. 87–834, § 7(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-16"},"text":"Oct. 16, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/987"},"text":"76 Stat. 987","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tX/s1013/d/1"},"text":"Pub. L. 94–455, title X, § 1013(d)(1)","children":[],"tail":", (e)(3), (4), title XIX, § 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1616"},"text":"90 Stat. 1616","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s341/b"},"text":"Pub. L. 97–248, title III, § 341(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/635"},"text":"96 Stat. 635","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1901/a"},"text":"Pub. L. 104–188, title I, § 1901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1904"},"text":"110 Stat. 1904","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1027/b"},"text":"Pub. L. 105–34, title X, § 1027(b)","children":[],"tail":", title XVI, § 1601(i)(1), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/926"},"text":"111 Stat. 926","children":[],"tail":", 1092; "},{"tag":"ref","attrib":{"href":"/us/pl/111/147/tV/s534/a"},"text":"Pub. L. 111–147, title V, § 534(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-18"},"text":"Mar. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/114"},"text":"124 Stat. 114","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4675a93b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4675a93c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4675a93d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/147"},"text":"Pub. L. 111–147","children":[],"tail":" inserted “shall submit such information as the Secretary may prescribe with respect to such trust for such year and” before “shall be responsible to ensure” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1601/i/1"},"text":"Pub. L. 105–34, § 1601(i)(1)","children":[],"tail":", substituted “owner” for “grantor” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1027/b"},"text":"Pub. L. 105–34, § 1027(b)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" amended section generally, substituting provisions calling for improved information reporting on foreign trusts for provisions calling for the filing of returns as to foreign trusts, prescribing the form and contents of such returns, and requiring annual returns for foreign trusts with one or more United States beneficiaries."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" inserted “(or on or before such later day as the Secretary may by regulations prescribe)” after “the 90th day”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1013/e/4"},"text":"Pub. L. 94–455, § 1013(e)(4)","children":[],"tail":", struck out “creation of or transfer to” after “Returns as to” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1013/d/1"},"text":"Pub. L. 94–455, § 1013(d)(1)","children":[],"tail":", (e)(3), added subsec. (c), redesignated former subsec. (c) as (d), and in subsec. (d) struck out cross reference to section 643(d) for definition of “foreign trust created by a United States person”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4678193e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4678193f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/147/tV/s534/b"},"text":"Pub. L. 111–147, title V, § 534(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-18"},"text":"Mar. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/115"},"text":"124 Stat. 115","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/147/tV/s534/b"},"text":"“The amendment made by this section [amending this section] shall apply to taxable years beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-03-18"},"text":"Mar. 18, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46781940-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1027/b"},"text":"section 1027(b) of Pub. L. 105–34","children":[],"tail":" applicable to returns of beneficiaries and owners filed after "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1027/c"},"text":"section 1027(c) of Pub. L. 105–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6034A"},"text":"section 6034A of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1601/i/1"},"text":"section 1601(i)(1) of Pub. L. 105–34","children":[],"tail":" effective as if included in the provisions of the Small Business Job Protection Act of 1996, "},{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":", to which it relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1601/j"},"text":"section 1601(j) of Pub. L. 105–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s23"},"text":"section 23 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46781941-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1901/d"},"text":"Pub. L. 104–188, title I, § 1901(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1908"},"text":"110 Stat. 1908","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/188/tI/s1901/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reportable events","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent related to subsection (a) of section 6048 of the Internal Revenue Code of 1986, as amended by this section, the amendments made by this section [amending this section and sections 6677 and 6724 of this title] shall apply to reportable events (as defined in such section 6048) occurring after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grantor trust reporting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent related to subsection (b) of such section 6048, the amendments made by this section shall apply to taxable years of United States persons beginning after ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting by united states beneficiaries","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent related to subsection (c) of such section 6048, the amendments made by this section shall apply to distributions received after the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46781942-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" applicable to returns filed after "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/s341/c"},"text":"section 341(c) of Pub. L. 97–248","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6046"},"text":"section 6046 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
