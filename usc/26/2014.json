{"tag":"section","attrib":{"id":"id45258248-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014"},"text":null,"children":[{"tag":"num","attrib":{"value":"2014"},"text":"§ 2014.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit for foreign death taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45258249-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by section 2001 shall be credited with the amount of any estate, inheritance, legacy, or succession taxes actually paid to any foreign country in respect of any property situated within such foreign country and included in the gross estate (not including any such taxes paid with respect to the estate of a person other than the decedent). The determination of the country within which property is situated shall be made in accordance with the rules applicable under subchapter B (sec. 2101 and following) in determining whether property is situated within or without the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4525824a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on credit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The credit provided in this section with respect to such taxes paid to any foreign country—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4525824b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall not, with respect to any such tax, exceed an amount which bears the same ratio to the amount of such tax actually paid to such foreign country as the value of property which is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4525824c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" situated within such foreign country,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4525824d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subjected to such tax, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4525824e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" included in the gross estate","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"bears to the value of all property subjected to such tax; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4525824f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall not, with respect to all such taxes, exceed an amount which bears the same ratio to the tax imposed by section 2001 (after deducting from such tax the credits provided by sections 2010 and 2012) as the value of property which is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45258250-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" situated within such foreign country,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45258251-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subjected to the taxes of such foreign country, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45258252-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" included in the gross estate","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"bears to the value of the entire gross estate reduced by the aggregate amount of the deductions allowed under sections 2055 and 2056.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45258253-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Valuation of property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45258254-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The values referred to in the ratio stated in subsection (b)(1) are the values determined for purposes of the tax imposed by such foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45258255-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The values referred to in the ratio stated in subsection (b)(2) are the values determined under this chapter; but, in applying such ratio, the value of any property described in subparagraphs (A), (B), and (C) thereof shall be reduced by such amount as will properly reflect, in accordance with regulations prescribed by the Secretary, the deductions allowed in respect of such property under sections 2055 and 2056 (relating to charitable and marital deductions).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45258256-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proof of credit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The credit provided in this section shall be allowed only if the taxpayer establishes to the satisfaction of the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45258257-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of taxes actually paid to the foreign country,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45258258-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and date of each payment thereof,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45258259-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the description and value of the property in respect of which such taxes are imposed, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4525825a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other information necessary for the verification and computation of the credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4525825b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The credit provided in this section shall be allowed only for such taxes as were actually paid and credit therefor claimed within 4 years after the filing of the return required by section 6018, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4525825c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a petition for redetermination of a deficiency has been filed with the Tax Court within the time prescribed in section 6213(a), then within such 4-year period or before the expiration of 60 days after the decision of the Tax Court becomes final.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4525825d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, under section 6161, an extension of time has been granted for payment of the tax shown on the return, or of a deficiency, then within such 4-year period or before the date of the expiration of the period of the extension.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Refund based on such credit may (despite the provisions of sections 6511 and 6512) be made if claim therefor is filed within the period above provided. Any such refund shall be made without interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4525825e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional limitation in cases involving a deduction under section 2053(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case where a deduction is allowed under section 2053(d) for an estate, succession, legacy, or inheritance tax imposed by and actually paid to any foreign country upon a transfer by the decedent for public, charitable, or religious uses described in section 2055, the property described in subparagraphs (A), (B), and (C) of paragraphs (1) and (2) of subsection (b) of this section shall not include any property in respect of which such deduction is allowed under section 2053(d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4525825f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Possession of United States deemed a foreign country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of the credits authorized by this section, each possession of the United States shall be deemed to be a foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45258260-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Similar credit required for certain alien residents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the President finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45258261-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign country, in imposing estate, inheritance, legacy, or succession taxes, does not allow to citizens of the United States resident in such foreign country at the time of death a credit similar to the credit allowed under subsection (a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45258262-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such foreign country, when requested by the United States to do so has not acted to provide such a similar credit in the case of citizens of the United States resident in such foreign country at the time of death, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45258263-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2014/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the public interest to allow the credit under subsection (a) in the case of citizens or subjects of such foreign country only if it allows such a similar credit in the case of citizens of the United States resident in such foreign country at the time of death,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the President shall proclaim that, in the case of citizens or subjects of such foreign country dying while the proclamation remains in effect, the credit under subsection (a) shall be allowed only if such foreign country allows such a similar credit in the case of citizens of the United States resident in such foreign country at the time of death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45258264-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/378"},"text":"68A Stat. 378","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s102/c/2"},"text":"Pub. L. 85–866, title I, § 102(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1674"},"text":"72 Stat. 1674","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/175/s2"},"text":"Pub. L. 86–175, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-08-21"},"text":"Aug. 21, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/397"},"text":"73 Stat. 397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/tI/s106/b/3"},"text":"Pub. L. 89–809, title I, § 106(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1570"},"text":"80 Stat. 1570","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", title XX, § 2001(c)(1)(G), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":", 1852; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tV/s532/c/3"},"text":"Pub. L. 107–16, title V, § 532(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/74"},"text":"115 Stat. 74","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45258265-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45258266-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45258267-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16"},"text":"Pub. L. 107–16","children":[],"tail":" struck out “, 2011,” after “sections 2010” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s2001/c/1/G"},"text":"Pub. L. 94–455, § 2001(c)(1)(G)","children":[],"tail":", inserted reference to section 2010 in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809"},"text":"Pub. L. 89–809","children":[],"tail":" struck out provision that, if the decedent at the time of his death was not a citizen of the United States, credit would not be allowed under this section unless the foreign country of which the decedent was a citizen or subject, in imposing estate, inheritance, legacy, or succession taxes, allows a similar credit in the case of a citizen of the United States resident in such country."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809"},"text":"Pub. L. 89–809","children":[],"tail":" added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/175"},"text":"Pub. L. 86–175","children":[],"tail":" added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866"},"text":"Pub. L. 85–866","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4527cb58-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4527cb59-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16"},"text":"Pub. L. 107–16","children":[],"tail":" applicable to estates of decedents dying, and generation-skipping transfers, after "},{"tag":"date","attrib":{"date":"2004-12-31"},"text":"Dec. 31, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/s532/d"},"text":"section 532(d) of Pub. L. 107–16","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2012"},"text":"section 2012 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4527cb5a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809"},"text":"Pub. L. 89–809","children":[],"tail":" applicable with respect to estates of decedents dying after "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/s106/b/4"},"text":"section 106(b)(4) of Pub. L. 89–809","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s901"},"text":"section 901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4527cb5b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1959 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/175"},"text":"Pub. L. 86–175","children":[],"tail":" applicable with respect to estates of decedents dying on or after "},{"tag":"date","attrib":{"date":"1955-07-01"},"text":"July 1, 1955","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/86/175/s4"},"text":"section 4 of Pub. L. 86–175","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2053"},"text":"section 2053 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4527cb5c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s102/d"},"text":"Pub. L. 85–866, title I, § 102(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1675"},"text":"72 Stat. 1675","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/85/866/tI/s102/d"},"text":"“The amendments made by this section (other than by subsection (b)) [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s2208"},"text":"section 2208 of this title","children":[],"tail":" and amending this section and sections 2011 and 2053 of this title] shall apply to the estates of decedents dying after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":"]. The amendment made by subsection (b) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2501"},"text":"section 2501 of this title","children":[],"tail":"] shall apply to gifts made after the date of the enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
