{"tag":"section","attrib":{"id":"id467f457e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V"},"text":null,"children":[{"tag":"num","attrib":{"value":"6050V"},"text":"§ 6050V.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns relating to applicable insurance contracts in which certain exempt organizations hold interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id467f457f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each applicable exempt organization which makes a reportable acquisition shall make the return described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467f4580-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for making return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any applicable exempt organization required to make a return under subsection (a) shall file such return at such time as may be established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467f4581-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and manner of returns","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A return is described in this subsection if such return—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467f4582-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in such form as the Secretary prescribes,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f4583-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains the name, address, and taxpayer identification number of the applicable exempt organization and the issuer of the applicable insurance contract, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f4584-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains such other information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467f4585-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467f4586-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reportable acquisition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “reportable acquisition” means the acquisition by an applicable exempt organization of a direct or indirect interest in any applicable insurance contract in any case in which such acquisition is a part of a structured transaction involving a pool of such contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f4587-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable insurance contract","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467f4588-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “applicable insurance contract” means any life insurance, annuity, or endowment contract with respect to which both an applicable exempt organization and a person other than an applicable exempt organization have directly or indirectly held an interest in the contract (whether or not at the same time).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467f4589-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such term shall not include a life insurance, annuity, or endowment contract if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id467f458a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all persons directly or indirectly holding any interest in the contract (other than applicable exempt organizations) have an insurable interest in the insured under the contract independent of any interest of an applicable exempt organization in the contract,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id467f458b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sole interest in the contract of an applicable exempt organization or each person other than an applicable exempt organization is as a named beneficiary, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id467f458c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sole interest in the contract of each person other than an applicable exempt organization is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id467f458d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/d/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a beneficiary of a trust holding an interest in the contract, but only if the person’s designation as such beneficiary was made without consideration and solely on a purely gratuitous basis, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id467f458e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/d/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a trustee who holds an interest in the contract in a fiduciary capacity solely for the benefit of applicable exempt organizations or persons otherwise described in subclause (I) or clause (i) or (ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f458f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable exempt organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable exempt organization” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467f4590-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization described in section 170(c),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467f4591-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization described in section 168(h)(2)(A)(iv), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467f4592-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization not described in paragraph (1) or (2) which is described in section 2055(a) or section 2522(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467f4593-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050V/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to reportable acquisitions occurring after the date which is 2 years after the date of the enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id467f4594-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1211/a/1"},"text":"Pub. L. 109–280, title XII, § 1211(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1072"},"text":"120 Stat. 1072","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id467f4595-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id467f4596-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id467f4597-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (e), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id467f4598-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1211/a/1"},"text":"Section 1211(a)(1) of Pub. L. 109–280","children":[],"tail":", which directed the addition of section 6050V at the end of subpart B of part III of subchapter A of chapter 61, without specifying the act to be amended, was executed by adding section 6050V at the end of subpart B of part III of subchapter A of chapter 61 of this title, which consists of the Internal Revenue Code of 1986, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id467f4599-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id467f459a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1211/d"},"text":"Pub. L. 109–280, title XII, § 1211(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1074"},"text":"120 Stat. 1074","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/280/tXII/s1211/d"},"text":"“The amendments made by this section [enacting this section and amending sections 6721 and 6724 of this title] shall apply to acquisitions of contracts after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
