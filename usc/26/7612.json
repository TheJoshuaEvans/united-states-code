{"tag":"section","attrib":{"id":"id477bf52d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612"},"text":null,"children":[{"tag":"num","attrib":{"value":"7612"},"text":"§ 7612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special procedures for summonses for computer software","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id477bf52e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id477bf52f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subsection (b), no summons may be issued under this title, and the Secretary may not begin any action under section 7604 to enforce any summons to produce or analyze any tax-related computer software source code; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id477bf530-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any software and related materials which are provided to the Secretary under this title shall be subject to the safeguards under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id477bf531-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Circumstances under which computer software source code may be provided","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id477bf532-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a)(1) shall not apply to any portion, item, or component of tax-related computer software source code if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id477bf533-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary is unable to otherwise reasonably ascertain the correctness of any item on a return from—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id477bf534-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer’s books, papers, records, or other data; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id477bf535-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the computer software executable code (and any modifications thereof) to which such source code relates and any associated data which, when executed, produces the output to ascertain the correctness of the item;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id477bf536-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary identifies with reasonable specificity the portion, item, or component of such source code needed to verify the correctness of such item on the return; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id477bf537-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the need for the portion, item, or component of such source code with respect to such item outweighs the risks of unauthorized disclosure of trade secrets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id477bf538-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a)(1) shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id477bf539-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any inquiry into any offense connected with the administration or enforcement of the internal revenue laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id477bf53a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any tax-related computer software source code acquired or developed by the taxpayer or a related person primarily for internal use by the taxpayer or such person rather than for commercial distribution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id477bf53b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any communications between the owner of the tax-related computer software source code and the taxpayer or related persons; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id477bf53c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any tax-related computer software source code which is required to be provided or made available pursuant to any other provision of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id477bf53d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the Secretary shall be treated as meeting the requirements of subparagraphs (A) and (B) of such paragraph if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id477bf53e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that it is not feasible to determine the correctness of an item without access to the computer software executable code and associated data described in paragraph (1)(A)(ii);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id477bf53f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary makes a formal request to the taxpayer for such code and data and to the owner of the computer software source code for such executable code; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id477bf540-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such code and data is not provided within 180 days of such request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id477bf541-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to contest summons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any proceeding brought under section 7604 to enforce a summons issued under the authority of this subsection, the court shall, at the request of any party, hold a hearing to determine whether the applicable requirements of this subsection have been met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id477bf542-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safeguards to ensure protection of trade secrets and other confidential information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id477bf543-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entry of protective order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any court proceeding to enforce a summons for any portion of software, the court may receive evidence and issue any order necessary to prevent the disclosure of trade secrets or other confidential information with respect to such software, including requiring that any information be placed under seal to be opened only as directed by the court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id477bf544-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of software","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this section, and in addition to any protections ordered pursuant to paragraph (1), in the case of software that comes into the possession or control of the Secretary in the course of any examination with respect to any taxpayer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id477bf545-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the software may be used only in connection with the examination of such taxpayer’s return, any appeal by the taxpayer to the Internal Revenue Service Independent Office of Appeals, any judicial proceeding (and any appeals therefrom), and any inquiry into any offense connected with the administration or enforcement of the internal revenue laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id477bf546-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall provide, in advance, to the taxpayer and the owner of the software a written list of the names of all individuals who will analyze or otherwise have access to the software;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id477bf547-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the software shall be maintained in a secure area or place, and, in the case of computer software source code, shall not be removed from the owner’s place of business unless the owner permits, or a court orders, such removal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id477bf548-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the software may not be copied except as necessary to perform such analysis, and the Secretary shall number all copies made and certify in writing that no other copies have been (or will be) made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id477bf549-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at the end of the period during which the software may be used under subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id477bf54a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/c/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the software and all copies thereof shall be returned to the person from whom they were obtained and any copies thereof made under subparagraph (D) on the hard drive of a machine or other mass storage device shall be permanently deleted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id477bf54b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/c/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall obtain from any person who analyzes or otherwise had access to such software a written certification under penalty of perjury that all copies and related materials have been returned and that no copies were made of them;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id477bf54c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the software may not be decompiled or disassembled;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id477bf54d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary shall provide to the taxpayer and the owner of any interest in such software, as the case may be, a written agreement, between the Secretary and any person who is not an officer or employee of the United States and who will analyze or otherwise have access to such software, which provides that such person agrees not to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id477bf54e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/c/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disclose such software to any person other than persons to whom such information could be disclosed for tax administration purposes under section 6103; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id477bf54f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/c/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate for 2 years in the development of software which is intended for a similar purpose as the software examined; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id477bf550-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the software shall be treated as return information for purposes of section 6103.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of subparagraph (C), the owner shall make available any necessary equipment or materials for analysis of computer software source code required to be conducted on the owner’s premises. The owner of any interest in the software shall be considered a party to any agreement described in subparagraph (G).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id477bf551-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id477bf552-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Software","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “software” includes computer software source code and computer software executable code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id477bf553-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computer software source code","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “computer software source code” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id477bf554-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the code written by a programmer using a programming language which is comprehensible to appropriately trained persons and is not capable of directly being used to give instructions to a computer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id477bf555-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related programmers’ notes, design documents, memoranda, and similar documentation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id477bf556-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related customer communications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id477bf557-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computer software executable code","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “computer software executable code” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id477bf558-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any object code, machine code, or other code readable by a computer when loaded into its memory and used directly by such computer to execute instructions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id477bf559-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any related user manuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id477bf55a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Owner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “owner” shall, with respect to any software, include the developer of the software.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id477bf55b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person shall be treated as related to another person if such persons are related persons under section 267 or 707(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id477bf55c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7612/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax-related computer software source code","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tax-related computer software source code” means the computer source code for any computer software program intended for accounting, tax return preparation or compliance, or tax planning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id477bf55d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3413/a"},"text":"Pub. L. 105–206, title III, § 3413(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/751"},"text":"112 Stat. 751","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/25/tI/s1001/b/1/J"},"text":"Pub. L. 116–25, title I, § 1001(b)(1)(J)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/985"},"text":"133 Stat. 985","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id477bf55e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id477bf55f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id477bf560-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7612 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7613"},"text":"section 7613 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id477bf561-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25"},"text":"Pub. L. 116–25","children":[],"tail":" substituted “Internal Revenue Service Independent Office of Appeals” for “Internal Revenue Service Office of Appeals”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id477bf562-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id477bf563-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3413/e"},"text":"Pub. L. 105–206, title III, § 3413(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/754"},"text":"112 Stat. 754","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/206/tIII/s3413/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting this section, amending sections 7213 and 7603 of this title, and renumbering former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7612"},"text":"section 7612 of this title","children":[],"tail":" as 7613] shall apply to summonses issued, and software acquired, after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Software protection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of any software acquired on or before such date of enactment, the requirements of section 7612(a)(2) of the Internal Revenue Code of 1986 (as added by such amendments) shall apply after the 90th day after such date. The preceding sentence shall not apply to the requirement under section 7612(c)(2)(G)(ii) of such Code (as so added).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
