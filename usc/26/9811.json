{"tag":"section","attrib":{"id":"id47ccfac5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811"},"text":null,"children":[{"tag":"num","attrib":{"value":"9811"},"text":"§ 9811.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards relating to benefits for mothers and newborns","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47ccfac6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for minimum hospital stay following birth","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47ccfac7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A group health plan may not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47ccfac8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except as provided in paragraph (2)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47ccfac9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restrict benefits for any hospital length of stay in connection with childbirth for the mother or newborn child, following a normal vaginal delivery, to less than 48 hours, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47ccfaca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restrict benefits for any hospital length of stay in connection with childbirth for the mother or newborn child, following a caesarean section, to less than 96 hours; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47ccfacb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that a provider obtain authorization from the plan or the issuer for prescribing any length of stay required under subparagraph (A) (without regard to paragraph (2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47ccfacc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1)(A) shall not apply in connection with any group health plan in any case in which the decision to discharge the mother or her newborn child prior to the expiration of the minimum length of stay otherwise required under paragraph (1)(A) is made by an attending provider in consultation with the mother.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47ccfacd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A group health plan may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47ccface-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny to the mother or her newborn child eligibility, or continued eligibility, to enroll or to renew coverage under the terms of the plan, solely for the purpose of avoiding the requirements of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47ccfacf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide monetary payments or rebates to mothers to encourage such mothers to accept less than the minimum protections available under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47ccfad0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" penalize or otherwise reduce or limit the reimbursement of an attending provider because such provider provided care to an individual participant or beneficiary in accordance with this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47ccfad1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide incentives (monetary or otherwise) to an attending provider to induce such provider to provide care to an individual participant or beneficiary in a manner inconsistent with this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47ccfad2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (c)(3), restrict benefits for any portion of a period within a hospital length of stay required under subsection (a) in a manner which is less favorable than the benefits provided for any preceding portion of such stay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47ccfad3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47ccfad4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in this section shall be construed to require a mother who is a participant or beneficiary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47ccfad5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to give birth in a hospital; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47ccfad6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to stay in the hospital for a fixed period of time following the birth of her child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47ccfad7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall not apply with respect to any group health plan which does not provide benefits for hospital lengths of stay in connection with childbirth for a mother or her newborn child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47ccfad8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be construed as preventing a group health plan from imposing deductibles, coinsurance, or other cost-sharing in relation to benefits for hospital lengths of stay in connection with childbirth for a mother or newborn child under the plan, except that such coinsurance or other cost-sharing for any portion of a period within a hospital length of stay required under subsection (a) may not be greater than such coinsurance or cost-sharing for any preceding portion of such stay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47ccfad9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Level and type of reimbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to prevent a group health plan from negotiating the level and type of reimbursement with a provider for care provided in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47ccfada-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption; exception for health insurance coverage in certain States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of this section shall not apply with respect to health insurance coverage if there is a State law (including a decision, rule, regulation, or other State action having the effect of law) for a State that regulates such coverage that is described in any of the following paragraphs:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47ccfadb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such State law requires such coverage to provide for at least a 48-hour hospital length of stay following a normal vaginal delivery and at least a 96-hour hospital length of stay following a caesarean section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47ccfadc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such State law requires such coverage to provide for maternity and pediatric care in accordance with guidelines established by the American College of Obstetricians and Gynecologists, the American Academy of Pediatrics, or other established professional medical associations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47ccfadd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9811/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such State law requires, in connection with such coverage for maternity care, that the hospital length of stay for such care is left to the decision of (or required to be made by) the attending provider in consultation with the mother.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47ccfade-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXV/s1531/a/4"},"text":"Pub. L. 105–34, title XV, § 1531(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1081"},"text":"111 Stat. 1081","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tVI/s6015/e"},"text":"Pub. L. 105–206, title VI, § 6015(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/821"},"text":"112 Stat. 821","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47ccfadf-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47ccfae0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47ccfae1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" redesignated subsec. (f) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47ccfae2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47ccfae3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Taxpayer Relief Act of 1997, "},{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6024"},"text":"section 6024 of Pub. L. 105–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47ccfae4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to group health plans for plan years beginning on or after ","children":[{"tag":"date","attrib":{"date":"1998-01-01"},"text":"Jan. 1, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1531/c"},"text":"section 1531(c) of Pub. L. 105–34","children":[],"tail":", set out as an Effective Date of 1997 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4980D"},"text":"section 4980D of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
