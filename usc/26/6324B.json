{"tag":"section","attrib":{"id":"id46cb9146-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324B"},"text":null,"children":[{"tag":"num","attrib":{"value":"6324B"},"text":"§ 6324B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special lien for additional estate tax attributable to farm, etc., valuation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46cb9147-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any interest in qualified real property (within the meaning of section 2032A(b)), an amount equal to the adjusted tax difference attributable to such interest (within the meaning of section 2032A(c)(2)(B)) shall be a lien in favor of the United States on the property in which such interest exists.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46cb9148-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of lien","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The lien imposed by this section shall arise at the time an election is filed under section 2032A and shall continue with respect to any interest in the qualified real property—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46cb9149-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" until the liability for tax under subsection (c) of section 2032A with respect to such interest has been satisfied or has become unenforceable by reason of lapse of time, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46cb914a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" until it is established to the satisfaction of the Secretary that no further tax liability may arise under section 2032A(c) with respect to such interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46cb914b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain rules and definitions made applicable","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46cb914c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rule set forth in paragraphs (1), (3), and (4) of section 6324A(d) shall apply with respect to the lien imposed by this section as if it were a lien imposed by section 6324A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46cb914d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified real property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “qualified real property” includes qualified replacement property (within the meaning of section 2032A(h)(3)(B)) and qualified exchange property (within the meaning of section 2032A(i)(3)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46cb914e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substitution of security for lien","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent provided in regulations prescribed by the Secretary, the furnishing of security may be substituted for the lien imposed by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46cb914f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2003/b"},"text":"Pub. L. 94–455, title XX, § 2003(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1861"},"text":"90 Stat. 1861","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s702/r/4"},"text":"Pub. L. 95–600, title VII, § 702(r)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2939"},"text":"92 Stat. 2939","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/222/tI/s108/d"},"text":"Pub. L. 96–222, title I, § 108(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-01"},"text":"Apr. 1, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/228"},"text":"94 Stat. 228","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV/s421/d/2/B"},"text":"Pub. L. 97–34, title IV, § 421(d)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/309"},"text":"95 Stat. 309","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46cb9150-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46cb9151-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46cb9152-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" defined “qualified real property” to include qualified exchange property (within the meaning of section 2032A(i)(3))."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/222"},"text":"Pub. L. 96–222","children":[],"tail":" designated existing provisions as par. (1), substituted “The rule” for “The rules”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" substituted “qualified real property” for “qualified farm real property”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46cb9153-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"no