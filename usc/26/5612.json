{"tag":"section","attrib":{"id":"id46412ac9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5612"},"text":null,"children":[{"tag":"num","attrib":{"value":"5612"},"text":"§ 5612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture of taxpaid distilled spirits remaining on bonded premises","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46412aca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No distilled spirits on which tax has been paid or determined shall be stored or allowed to remain on the bonded premises of any distilled spirits plant, under the penalty of forfeiture of all spirits so found.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46412acb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply in the case of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46412acc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5612/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distilled spirits in the process of prompt removal from bonded premises on payment or determination of the tax; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46412acd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5612/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distilled spirits returned to bonded premises in accordance with the provisions of section 5215.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46412ace-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1404"},"text":"72 Stat. 1404","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/55"},"text":"Pub. L. 96–39, title VIII, § 807(a)(55)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/289"},"text":"93 Stat. 289","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46412acf-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46412ad0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46412ad1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5612, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/685"},"text":"68A Stat. 685","children":[],"tail":", related to penalty for using material or removing spirits without supervision, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5687"},"text":"section 5687 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising subsec. (a) of this section were contained in prior section 5625, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/688"},"text":"68A Stat. 688","children":[],"tail":", prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46412ad2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" redesignated subpars. (2) and (3) as (1) and (2), respectively, and struck out former subpars. (1) and (4) which excepted distilled spirits which were bottled in bond under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5233"},"text":"section 5233 of this title","children":[],"tail":" and which were returned to bonded premises for rebottling, relabeling, or restamping in accordance with subsec. (d) of section 5233, and excepted such spirits, held on bonded premises, on which the tax had become payable by operation of law, but on which the tax had not been paid."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46412ad3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","chi