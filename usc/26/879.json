{"tag":"section","attrib":{"id":"id4455fd95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s879"},"text":null,"children":[{"tag":"num","attrib":{"value":"879"},"text":"§ 879.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax treatment of certain community income in the case of nonresident alien individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4455fd96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s879/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a married couple 1 or both of whom are nonresident alien individuals and who have community income for the taxable year, such community income shall be treated as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4455fd97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s879/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Earned income (within the meaning of section 911(d)(2)), other than trade or business income and a partner’s distributive share of partnership income, shall be treated as the income of the spouse who rendered the personal services,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4455fd98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s879/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Trade or business income, and a partner’s distributive share of partnership income, shall be treated as provided in section 1402(a)(5),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4455fd99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s879/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Community income not described in paragraph (1) or (2) which is derived from the separate property (as determined under the applicable community property law) of one spouse shall be treated as the income of such spouse, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4455fd9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s879/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All other such community income shall be treated as provided in the applicable community property law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4455fd9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s879/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception where election under section 6013(g) is in effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply for any taxable year for which an election under subsection (g) or (h) of section 6013 (relating to election to treat nonresident alien individual as resident of the United States) is in effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4455fd9c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s879/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4455fd9d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s879/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community income” means income which, under applicable community property laws, is treated as community income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4455fd9e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s879/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community property laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community property laws” means the community property laws of a State, a foreign country, or a possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4455fd9f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s879/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of marital status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The determination of marital status shall be made under section 7703(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4455fda0-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tX/s1012/b/1"},"text":"Pub. L. 94–455, title X, § 1012(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1613"},"text":"90 Stat. 1613","children":[],"tail":"; amend