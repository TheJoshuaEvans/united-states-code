{"tag":"section","attrib":{"id":"id47ae016b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9042"},"text":null,"children":[{"tag":"num","attrib":{"value":"9042"},"text":"§ 9042.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47ae016c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9042/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess campaign expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who violates the provisions of section 9035 shall be fined not more than $25,000, or imprisoned not more than 5 years, or both. Any officer or member of any political committee who knowingly consents to any expenditure in violation of the provisions of section 9035 shall be fined not more than $25,000, or imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47ae016d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9042/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful use of payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47ae016e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9042/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It is unlawful for any person who receives any payment under section 9037, or to whom any portion of any such payment is transferred, knowingly and willfully to use, or authorize the use of, such payment or such portion for any purpose other than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47ae016f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9042/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to defray qualified campaign expenses, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47ae0170-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9042/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to repay loans the proceeds of which were used, or otherwise to restore funds (other than contributions to defray qualified campaign expenses which were received and expended) which were used, to defray qualified campaign expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47ae0171-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9042/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who violates the provisions of paragraph (1) shall be fined not more than $10,000, or imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47ae0172-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9042/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False statements, etc.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47ae0173-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9042/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It is unlawful for any person knowingly and willfully—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47ae0174-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9042/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to furnish any false, fictitious, or fraudulent evidence, books, or information to the Commission under this chapter, or to include in any evidence, books, or information so furnished any misrepresentation of a material fact, or to falsify or conceal any evidence, books, or information relevant to a certification by the Commission or an examination and audit by the Commission under this chapter, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47ae0175-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9042/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fail to furnish to the Commission any records, books, or information requested by it for purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47ae0176-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9042/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who violates the provisions of paragraph (1) shall be fined not more than $10,000, or imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47ae0177-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9042/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Kickbacks and illegal payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47ae0178-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9042/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is unlawful for any person knowingly and willfully to give or accept any kickback or any illegal payment in connection with any qualified campaign expense of a candidate, or his authorized committees, who receives payments under section 9037.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47ae0179-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9042/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who violates the provisions of paragraph (1) shall be fined not more than $10,000, or imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47ae017a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9042/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the penalty provided by paragraph (2), any person who accepts any kickback or illegal payment in connection with any qualified campaign expense of a candidate or his authorized committees shall pay to the Secretary for deposit in the matching payment account, an amount equal to 125 percent of the kickback or payment received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47ae017b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443/tIV/s408/c"},"text":"Pub. L. 93–443, title IV, § 408(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-15"},"text":"Oct. 15, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1302"},"text":"88 Stat. 1302","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47ae017c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47ae017d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47ae017e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/s410/c/1"},"text":"section 410(c)(1) of Pub. L. 93–443","children":[],"tail":", set out as an Effective Date of 1974 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
