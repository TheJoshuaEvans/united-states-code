{"tag":"section","attrib":{"id":"id40d561aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L"},"text":null,"children":[{"tag":"num","attrib":{"value":"45L"},"text":"§ 45L.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New energy efficient home credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40d561ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of credit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d561ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of section 38, in the case of an eligible contractor, the new energy efficient home credit for the taxable year is the applicable amount for each qualified new energy efficient home which is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d561ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constructed by the eligible contractor, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d561ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquired by a person from such eligible contractor for use as a residence during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d561af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the applicable amount is an amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d561b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a dwelling unit which is eligible to participate in the Energy Star Residential New Construction Program or the Energy Star Manufactured New Homes program—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40d561b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which meets the requirements of subsection (c)(1)(A) (and which does not meet the requirements of subsection (c)(1)(B)), $2,500, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d561b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which meets the requirements of subsection (c)(1)(B), $5,000, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d561b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a dwelling unit which is part of a building eligible to participate in the Energy Star Multifamily New Construction Program—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40d561b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which meets the requirements of subsection (c)(1)(A) (and which does not meet the requirements of subsection (c)(1)(B)), $500, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d561b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which meets the requirements of subsection (c)(1)(B), $1,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d561b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d561b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible contractor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible contractor” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d561b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person who constructed the qualified new energy efficient home, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d561b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a qualified new energy efficient home which is a manufactured home, the manufactured home producer of such home.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d561ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified new energy efficient home","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified new energy efficient home” means a dwelling unit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d561bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located in the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d561bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction of which is substantially completed after the date of the enactment of this section, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d561bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which meets the energy saving requirements of subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d561be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “construction” includes substantial reconstruction and rehabilitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d561bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquire","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “acquire” includes purchase.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d561c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy saving requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d561c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d561c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A dwelling unit meets the requirements of this subparagraph if such dwelling unit meets the requirements of paragraph (2) or (3) (whichever is applicable).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d561c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Zero energy ready home program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A dwelling unit meets the requirements of this subparagraph if such dwelling unit is certified as a zero energy ready home under the zero energy ready home program of the Department of Energy as in effect on ","children":[{"tag":"date","attrib":{"date":"2023-01-01"},"text":"January 1, 2023","children":[],"tail":" (or any successor program determined by the Secretary)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d561c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single-family home requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A dwelling unit meets the requirements of this paragraph if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d561c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such dwelling unit meets—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40d561c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id40d561c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/c/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a dwelling unit acquired before ","children":[{"tag":"date","attrib":{"date":"2025-01-01"},"text":"January 1, 2025","children":[],"tail":", the Energy Star Single-Family New Homes National Program Requirements 3.1, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id40d561c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/c/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a dwelling unit acquired after ","children":[{"tag":"date","attrib":{"date":"2024-12-31"},"text":"December 31, 2024","children":[],"tail":", the Energy Star Single-Family New Homes National Program Requirements 3.2, and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d561c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most recent Energy Star Single-Family New Homes Program Requirements applicable to the location of such dwelling unit (as in effect on the latter of ","children":[{"tag":"date","attrib":{"date":"2023-01-01"},"text":"January 1, 2023","children":[],"tail":", or January 1 of two calendar years prior to the date the dwelling unit was acquired), or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d561ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dwelling unit meets the most recent Energy Star Manufactured Home National program requirements as in effect on the latter of ","children":[{"tag":"date","attrib":{"date":"2023-01-01"},"text":"January 1, 2023","children":[],"tail":", or January 1 of two calendar years prior to the date such dwelling unit is acquired."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d561cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multi-family home requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A dwelling unit meets the requirements of this paragraph if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d561cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dwelling unit meets the most recent Energy Star Multifamily New Construction National Program Requirements (as in effect on either ","children":[{"tag":"date","attrib":{"date":"2023-01-01"},"text":"January 1, 2023","children":[],"tail":", or January 1 of three calendar years prior to the date the dwelling was acquired, whichever is later), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d561cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dwelling unit meets the most recent Energy Star Multifamily New Construction Regional Program Requirements applicable to the location of such dwelling unit (as in effect on either ","children":[{"tag":"date","attrib":{"date":"2023-01-01"},"text":"January 1, 2023","children":[],"tail":", or January 1 of three calendar years prior to the date the dwelling was acquired, whichever is later)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d561ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d561cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A certification described in subsection (c) shall be made in accordance with guidance prescribed by the Secretary, after consultation with the Secretary of Energy. Such guidance shall specify procedures and methods for calculating energy and cost savings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d561d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any certification described in subsection (c) shall be made in writing in a manner which specifies in readily verifiable fashion the energy efficient building envelope components and energy efficient heating or cooling equipment installed and their respective rated energy efficiency performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d561d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subtitle, if a credit is allowed under this section in connection with any expenditure for any property, the increase in the basis of such property which would (but for this subsection) result from such expenditure shall be reduced by the amount of the credit so determined. This subsection shall not apply for purposes of determining the adjusted basis of any building under section 42.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d561d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with investment credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, expenditures taken into account under section 47 or 48(a) shall not be taken into account under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d561d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevailing wage requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d561d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a qualifying residence described in subsection (a)(2)(B) meeting the prevailing wage requirements of paragraph (2)(A), the credit amount allowed with respect to such residence shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d561d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,500 in the case of a residence which meets the requirements of subparagraph (A) of subsection (c)(1) (and which does not meet the requirements of subparagraph (B) of such subsection), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d561d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000 in the case of a residence which meets the requirements of subsection (c)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d561d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevailing wage requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d561d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements described in this subparagraph with respect to any qualified residence are that the taxpayer shall ensure that any laborers and mechanics employed by the taxpayer or any contractor or subcontractor in the construction of such residence shall be paid wages at rates not less than the prevailing rates for construction, alteration, or repair of a similar character in the locality in which such residence is located as most recently determined by the Secretary of Labor, in accordance with subchapter IV of chapter 31 of title 40, United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d561d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction and penalty related to failure to satisfy wage requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of section 45(b)(7)(B) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d561da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue such regulations or other guidance as the Secretary determines necessary to carry out the purposes of this subsection, including regulations or other guidance which provides for requirements for recordkeeping or information reporting for purposes of administering the requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d561db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45L/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"