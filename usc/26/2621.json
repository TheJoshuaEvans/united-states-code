{"tag":"section","attrib":{"id":"id4549369c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2621"},"text":null,"children":[{"tag":"num","attrib":{"value":"2621"},"text":"§ 2621.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable amount in case of taxable distribution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4549369d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2621/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the taxable amount in the case of any taxable distribution shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4549369e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2621/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of the property received by the transferee, reduced by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4549369f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2621/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any expense incurred by the transferee in connection with the determination, collection, or refund of the tax imposed by this chapter with respect to such distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454936a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2621/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of GST tax treated as taxable distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, if any of the tax imposed by this chapter with respect to any taxable distribution is paid out of the trust, an amount equal to the portion so paid shall be treated as a taxable distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id454936a1-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2006/a"},"text":"Pub. L. 94–455, title XX, § 2006(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1887"},"text":"90 Stat. 1887","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV/s422/e/4"},"text":"Pub. L. 97–34, title IV, § 422(e)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/316"},"text":"95 Stat. 316","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIV/s1431/a"},"text":"Pub. L. 99–514, title XIV, § 1431(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2720"},"text":"100 Stat. 2720","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id454936a2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id454936a3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id454936a4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children