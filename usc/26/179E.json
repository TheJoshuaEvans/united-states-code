{"tag":"section","attrib":{"id":"id4214e60c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179E"},"text":null,"children":[{"tag":"num","attrib":{"value":"179E"},"text":"§ 179E.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to expense advanced mine safety equipment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4214e60d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179E/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A taxpayer may elect to treat 50 percent of the cost of any qualified advanced mine safety equipment property as an expense which is not chargeable to capital account. Any cost so treated shall be allowed as a deduction for the taxable year in which the qualified advanced mine safety equipment property is placed in service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4214e60e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179E/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4214e60f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179E/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under this section for any taxable year shall be made on the taxpayer’s return of the tax imposed by this chapter for the taxable year. Such election shall specify the advanced mine safety equipment property to which the election applies and shall be made in such manner as the Secretary may by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4214e610-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179E/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election irrevocable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any election made under this section may not be revoked except with the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4214e611-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179E/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified advanced mine safety equipment property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified advanced mine safety equipment property” means any advanced mine safety equipment property for use in any underground mine located in the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4214e612-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179E/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the original use of which commences with the taxpayer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4214e613-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179E/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is placed in service by the taxpayer after the date of the enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4214e614-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179E/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced mine safety equipment property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “advanced mine safety equipment property” means any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4214e615-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179E/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Emergency communication technology or device which is used to allow a miner to maintain constant communication with an individual who is not in the mine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4214e616-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179E/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Electronic identification and location device which allows an individual who is not in the mine to track at all times the movements and location of miners working in or at the mine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4214e617-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179E/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Emergency oxygen-generating, self-rescue device which provides oxygen for at least 90 minutes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4214e618-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179E/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pre-positioned supplies of oxygen which (in combination with self-rescue devices) can be used to provide each miner on a shift, in the event of an accident or other event which traps the miner in the mine or otherwise necessitates the use of such a self-rescue device, the ability to survive for at least 48 hours.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4214e619-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179E/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Comprehensive atmospheric monitoring system which monitors the levels of carbon monoxide, methane, and oxygen that are present in all areas of the mine and which can detect smoke in the case of a fire in a mine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4214e61a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179E/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with section 179","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No expenditures shall be taken into account under subsection (a) with respect to the portion of the cost of any property specified in an election under section 179.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4214e61b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179E/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowed under subsection (a) to any taxpayer for any taxable year unless such taxpayer files with the Secretary a report containing such information with respect to the operation of the mines of the taxpayer as the Secretary shall require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4214e61c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179E/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to property placed in service after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4214e61d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s404/a"},"text":"Pub. L. 109–432, div. A, title IV, § 404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2955"},"text":"120 Stat. 2955","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dC/tIII/s311"},"text":"Pub. L. 110–343, div. C, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3869"},"text":"122 Stat. 3869","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/312/tVII/s743/a"},"text":"Pub. L. 111–312, title VII, § 743(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-17"},"text":"Dec. 17, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3319"},"text":"124 Stat. 3319","children":[],"tail":"; "},{"tag":"ref"