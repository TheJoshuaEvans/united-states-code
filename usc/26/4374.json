{"tag":"section","attrib":{"id":"id45d3758f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4374"},"text":null,"children":[{"tag":"num","attrib":{"value":"4374"},"text":"§ 4374.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The tax imposed by this chapter shall be paid, on the basis of a return, by any person who makes, signs, issues, or sells any of the documents and instruments subject to the tax, or for whose use or benefit the same are made, signed, issued, or sold. The United States or any agency or instrumentality thereof shall not be liable for the tax.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id45d37590-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/522"},"text":"68A Stat. 522","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tI/s141/a"},"text":"Pub. L. 85–859, title I, § 141(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1301"},"text":"72 Stat. 1301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tVIII/s804/a/1"},"text":"Pub. L. 89–44, title VIII, § 804(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/160"},"text":"79 Stat. 160","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1904/a/12"},"text":"Pub. L. 94–455, title XIX, § 1904(a)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1813"},"text":"90 Stat. 1813","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45d37591-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45d37592-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id45d37593-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions of prior sections 4375, 4381 to 4384, see Prior Provisions note preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4371"},"text":"section 4371 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45d37594-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted in section catchline “Liability for tax” for “Payment of tax” and in text provisions relating to payment of tax on basis of a return and to tax-exempt status of United States and its agencies and instrumentalities for provisions relating to placing of stamps on any policy, indemnity bond, or annuity contract referred to in section 4371 and to regulation by Secretary that tax be paid on basis of a return."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" substituted “Payment of tax” for “Affixing of stamps” in section catchline, and inserted sentence authorizing Secretary or his delegate to provide by regulation for payment on basis of a return of tax imposed by section 4371."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" reenacted section without change."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45d37595-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45d37596-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" effective on first day of first month which begins more than 90 days after "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1904/d"},"text":"section 1904(d) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4041"},"text":"section 4041 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45d37597-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1965 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/tVIII/s804/c"},"text":"Pub. L. 89–44, title VIII, § 804(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/160"},"text":"79 Stat. 160","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/44/tVIII/s804/c"},"text":"“The amendments made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1965-07-01"},"text":"July 1, 1965","children":[],"tail":". The amendments made by subsection (b) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4371"},"text":"section 4371 of this title","children":[],"tail":"] shall apply with respect to policies, bonds, and contracts with respect to which the tax imposed by section 4371 of the Code is required to be paid on the basis of a return.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id45d37598-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Determination of Partnership as Continuing or Terminated Partnership","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tI/s141/b"},"text":"Pub. L. 85–859, title I, § 141(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1304"},"text":"72 Stat. 1304","children":[],"tail":", mandated that only changes in the partnership occurring on or after the effective date specified in "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/s1/c"},"text":"section 1(c) of Pub. L. 85–859","children":[],"tail":" shall be taken into account in the determination of whether a partnership is a continuing or terminated one."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
