{"tag":"section","attrib":{"id":"id44fcebcf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393"},"text":null,"children":[{"tag":"num","attrib":{"value":"1393"},"text":"§ 1393.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44fcebd0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44fcebd1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate Secretary” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44fcebd2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Housing and Urban Development in the case of any nominated area which is located in an urban area, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44fcebd3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture in the case of any nominated area which is located in a rural area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fcebd4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural area","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “rural area” means any area which is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44fcebd5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outside of a metropolitan statistical area (within the meaning of section 143(k)(2)(B)), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44fcebd6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined by the Secretary of Agriculture, after consultation with the Secretary of Commerce, to be a rural area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fcebd7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Urban area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “urban area” means an area which is not a rural area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fcebd8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for Indian reservations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44fcebd9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No empowerment zone or enterprise community may include any area within an Indian reservation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44fcebda-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian reservation defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian reservation” has the meaning given such term by section 168(j)(6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fcebdb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local government","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “local government” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44fcebdc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any county, city, town, township, parish, village, or other general purpose political subdivision of a State, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44fcebdd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of political subdivisions described in subparagraph (A) recognized by the appropriate Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fcebde-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nominated area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nominated area” means an area which is nominated by 1 or more local governments and the State or States in which it is located for designation under section 1391.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fcebdf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If more than 1 State or local government seeks to nominate an area under this part, any reference to, or requirement of, this subchapter shall apply to all such governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fcebe0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An area shall be treated as nominated by a State and a local government if it is nominated by an economic development corporation chartered by the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fcebe1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of census data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Population and poverty rate shall be determined by the most recent decennial census data available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44fcebe2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1393/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Empowerment zone; enterprise community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this title, the terms “empowerment zone” and “enterprise community” mean areas designated as such under section 1391.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44fcebe3-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13301/a"},"text":"Pub. L. 103–66, title XIII, § 13301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/547"},"text":"107 Stat. 547","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44fcebe4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44fcebe5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id44fcebe6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1393, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVI/s601/a"},"text":"Pub. L. 95–600, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2894"},"text":"92 Stat. 2894","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/595/s3/a/5"},"text":"Pub. L. 96–595, § 3(a)(5)","children":[],"tail":", (6), (8), "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3465"},"text":"94 Stat. 3465","children":[],"tail":", related to taxation of general stock ownership corporation taxable income to shareholders, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIII/s1303/a"},"text":"Pub. L. 99–514, title XIII, § 1303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2658"},"text":"100 Stat. 2658","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
