{"tag":"section","attrib":{"id":"id46650684-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6035"},"text":null,"children":[{"tag":"num","attrib":{"value":"6035"},"text":"§ 6035.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis information to persons acquiring property from decedent","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46650685-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6035/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information with respect to property acquired from decedents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46650686-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6035/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The executor of any estate required to file a return under section 6018(a) shall furnish to the Secretary and to each person acquiring any interest in property included in the decedent’s gross estate for Federal estate tax purposes a statement identifying the value of each interest in such property as reported on such return and such other information with respect to such interest as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46650687-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6035/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements by beneficiaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each person required to file a return under section 6018(b) shall furnish to the Secretary and to each other person who holds a legal or beneficial interest in the property to which such return relates a statement identifying the information described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46650688-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6035/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for furnishing statement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46650689-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6035/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each statement required to be furnished under paragraph (1) or (2) shall be furnished at such time as the Secretary may prescribe, but in no case at a time later than the earlier of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4665068a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6035/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date which is 30 days after the date on which the return under section 6018 was required to be filed (including extensions, if any), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4665068b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6035/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date which is 30 days after the date such return is filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4665068c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6035/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which there is an adjustment to the information required to be included on a statement filed under paragraph (1) or (2) after such statement has been filed, a supplemental statement under such paragraph shall be filed not later than the date which is 30 days after such adjustment is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4665068d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6035/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe such regulations as necessary to carry out this section, including regulations relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4665068e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6035/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application of this section to property with regard to which no estate tax return is required to be filed, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4665068f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6035/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" situations in which the surviving joint tenant or other recipient may have better information than the executor regarding the basis or fair market value of the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46650690-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/41/tII/s2004/b/1"},"text":"Pub. L. 114–41, title II, § 2004(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-07-31"},"text":"July 31, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/455"},"text":"129 Stat. 455","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46650691-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46650692-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46650693-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6035, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/743"},"text":"68A Stat. 743","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s340/a"},"text":"Pub. L. 97–248, title III, § 340(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/633"},"text":"96 Stat. 633","children":[],"tail":", related to information returns of officers, directors, and shareholders of foreign personal holding companies, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIV/s413/c/26"},"text":"Pub. L. 108–357, title IV, § 413(c)(26)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1509"},"text":"118 Stat. 1509","children":[],"tail":", 1510, applicable to taxable years of foreign corporations beginning after "},{"tag":"date","attrib":{"date":"2004-12-31"},"text":"Dec. 31, 2004","children":[],"tail":", and to taxable years of United States shareholders with or within which such taxable years of foreign corporations end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46650694-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46650695-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to property with respect to which an estate tax return is filed after ","children":[{"tag":"date","attrib":{"date":"2015-07-31"},"text":"July 31, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/41/s2004/d"},"text":"section 2004(d) of Pub. L. 114–41","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1014"},"text":"section 1014 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
