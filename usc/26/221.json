{"tag":"section","attrib":{"id":"id4238c1be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221"},"text":null,"children":[{"tag":"num","attrib":{"value":"221"},"text":"§ 221.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest on education loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4238c1bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of deduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual, there shall be allowed as a deduction for the taxable year an amount equal to the interest paid by the taxpayer during the taxable year on any qualified education loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4238c1c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum deduction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4238c1c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the deduction allowed by subsection (a) for the taxable year shall not exceed $2,500.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4238c1c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation based on modified adjusted gross income","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4238c1c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount which would (but for this paragraph) be allowable as a deduction under this section shall be reduced (but not below zero) by the amount determined under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4238c1c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of reduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount determined under this subparagraph is the amount which bears the same ratio to the amount which would be so taken into account as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4238c1c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the excess of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4238c1c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer’s modified adjusted gross income for such taxable year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4238c1c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000 ($100,000 in the case of a joint return), bears to","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4238c1c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000 ($30,000 in the case of a joint return).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4238c1c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modified adjusted gross income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “modified adjusted gross income” means adjusted gross income determined—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4238c1ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to this section and sections 85(c) ","children":[{"tag":"ref","attrib":{"idref":"fn002088"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002088"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" 911, 931, and 933, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4238c1cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after application of sections 86, 135, 137, 219, and 469.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4238c1cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dependents not eligible for deduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowed by this section to an individual for the taxable year if a deduction under section 151 with respect to such individual is allowed to another taxpayer for the taxable year beginning in the calendar year in which such individual’s taxable year begins.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4238c1cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4238c1ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified education loan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified education loan” means any indebtedness incurred by the taxpayer solely to pay qualified higher education expenses—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4238c1cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are incurred on behalf of the taxpayer, the taxpayer’s spouse, or any dependent of the taxpayer as of the time the indebtedness was incurred,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4238c1d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are paid or incurred within a reasonable period of time before or after the indebtedness is incurred, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4238c1d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are attributable to education furnished during a period during which the recipient was an eligible student.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term includes indebtedness used to refinance indebtedness which qualifies as a qualified education loan. The term “qualified education loan” shall not include any indebtedness owed to a person who is related (within the meaning of section 267(b) or 707(b)(1)) to the taxpayer or to any person by reason of a loan under any qualified employer plan (as defined in section 72(p)(4)) or under any contract referred to in section 72(p)(5).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4238c1d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified higher education expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified higher education expenses” means the cost of attendance (as defined in section 472 of the Higher Education Act of 1965, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087"},"text":"20 U.S.C. 1087","children":[],"tail":null},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":", as in effect on the day before the date of the enactment of the Taxpayer Relief Act of 1997) at an eligible educational institution, reduced by the sum of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4238c1d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount excluded from gross income under section 127, 135, 529, or 530 by reason of such expenses, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4238c1d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any scholarship, allowance, or payment described in section 25A(g)(2).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of the preceding sentence, the term “eligible educational institution” has the same meaning given such term by section 25A(f)(2), except that such term shall also include an institution conducting an internship or residency program leading to a degree or certificate awarded by an institution of higher education, a hospital, or a health care facility which offers postgraduate training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4238c1d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible student","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible student” has the meaning given such term by section 25A(b)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4238c1d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dependent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “dependent” has the meaning given such term by section 152 (determined without regard to subsections (b)(1), (b)(2), and (d)(1)(B) thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4238c1d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4238c1d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of double benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowed under this section for any amount for which a deduction is allowable under any other provision of this chapter, or for which an exclusion is allowable under section 127 to the taxpayer by reason of the payment by the taxpayer’s employer of any indebtedness on a qualified education loan of the taxpayer. The deduction otherwise allowable under subsection (a) (prior to the application of subsection (b)) to the taxpayer for any taxable year shall be reduced (but not below zero) by so much of the distributions treated as a qualified higher education expense under section 529(c)(9) with respect to loans of the taxpayer as would be includible in gross income under section 529(c)(3)(A) for such taxable year but for such treatment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4238c1d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Married couples must file joint return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the taxpayer is married at the close of the taxable year, the deduction shall be allowed under subsection (a) only if the taxpayer and the taxpayer’s spouse file a joint return for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4238c1da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marital status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Marital status shall be determined in accordance with section 7703.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4238c1db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4238c1dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a taxable year beginning after 2002, the $50,000 and $100,000 amounts in subsection (b)(2) shall each be increased by an amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4238c1dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dollar amount, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4238c1de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost-of-living adjustment determined under section 1(f)(3) for the calendar year in which the taxable year begins, determined by substituting “calendar year 2001” for “calendar year 2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4238c1df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s221/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rounding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any amount as adjusted under paragraph (1) is not a multiple of $5,000, such amount shall be rounded to the next lowest multiple of $5,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4238c1e0-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tII/s202/a"},"text":"Pub. L. 105–34, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05