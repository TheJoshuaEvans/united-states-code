{"tag":"section","attrib":{"id":"id449d8de2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1013"},"text":null,"children":[{"tag":"num","attrib":{"value":"1013"},"text":"§ 1013.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis of property included in inventory","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If the property should have been included in the last inventory, the basis shall be the last inventory value thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id449d8de3-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/296"},"text":"68A Stat. 296","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
