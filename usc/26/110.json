{"tag":"section","attrib":{"id":"id416481ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s110"},"text":null,"children":[{"tag":"num","attrib":{"value":"110"},"text":"§ 110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified lessee construction allowances for short-term leases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id416481f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Gross income of a lessee does not include any amount received in cash (or treated as a rent reduction) by a lessee from a lessor—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id416481f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s110/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a short-term lease of retail space, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id416481f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s110/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purpose of such lessee’s constructing or improving qualified long-term real property for use in such lessee’s trade or business at such retail space,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but only to the extent that such amount does not exceed the amount expended by the lessee for such construction or improvement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id416481f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistent treatment by lessor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Qualified long-term real property constructed or improved in connection with any amount excluded from a lessee’s income by reason of subsection (a) shall be treated as nonresidential real property of the lessor (including for purposes of section 168(i)(8)(B)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id416481f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s110/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id416481f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s110/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified long-term real property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified long-term real property” means nonresidential real property which is part of, or otherwise present at, the retail space referred to in subsection (a) and which reverts to the lessor at the termination of the lease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id416481f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s110/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short-term lease","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “short-term lease” means a lease (or other agreement for occupancy or use) of retail space for 15 years or less (as determined under the rules of section 168(i)(3)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id416481f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s110/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retail space","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “retail space” means real property leased, occupied, or otherwise used by a lessee in its trade or business of selling tangible personal property or services to the general public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id416481f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s110/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information required to be furnished to Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations, the lessee and lessor described in subsection (a) shall, at such times and in such manner as may be provided in such regulations, furnish to the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id416481f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s110/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information concerning the amounts received (or treated as a rent reduction) and expended as described in subsection (a), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id416481fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s110/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information which the Secretary deems necessary to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id416481fb-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXII/s1213/a"},"text":"Pub. L. 105–34, title XII, § 1213(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1000"},"text":"111 Stat. 1000","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id416481fc-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id416481fd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id416481fe-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 110, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/33"},"text":"68A Stat. 33","children":[],"tail":", related to income taxes paid by lessee corporations, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11801/a/6"},"text":"Pub. L. 101–508, title XI, § 11801(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-520"},"text":"104 Stat. 1388–520","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id416481ff-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id41648200-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXII/s1213/e"},"text":"Pub. L. 105–34, title XII, § 1213(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1001"},"text":"111 Stat. 1001","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tXII/s1213/e"},"text":"“The amendments made by this section [enacting this section and amending sections 168 and 6724 of this title] shall apply to leases entered into after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
