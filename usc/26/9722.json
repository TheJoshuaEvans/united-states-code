{"tag":"section","attrib":{"id":"id47c8410c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9722"},"text":null,"children":[{"tag":"num","attrib":{"value":"9722"},"text":"§ 9722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sham transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If a principal purpose of any transaction is to evade or avoid liability under this chapter, this chapter shall be applied (and such liability shall be imposed) without regard to such transaction.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id47c8410d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s19143/a"},"text":"Pub. L. 102–486, title XIX, § 19143(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3056"},"text":"106 Stat. 3056","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
