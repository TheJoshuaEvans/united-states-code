{"tag":"section","attrib":{"id":"id464ac83c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5704"},"text":null,"children":[{"tag":"num","attrib":{"value":"5704"},"text":"§ 5704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id464ac83d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tobacco products furnished for employee use or experimental purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Tobacco products may be furnished by a manufacturer of such products, without payment of tax, for use or consumption by employees or for experimental purposes, in such quantities, and in such manner as the Secretary shall by regulation prescribed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464ac83e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tobacco products and cigarette papers and tubes transferred or removed in bond from domestic factories and export warehouses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A manufacturer or export warehouse proprietor may transfer tobacco products and cigarette papers and tubes, without payment of tax, to the bonded premises of another manufacturer or export warehouse proprietor, or remove such articles, without payment of tax, for shipment to a foreign country, Puerto Rico, the Virgin Islands, or a possession of the United States, or for consumption beyond the jurisdiction of the internal revenue laws of the United States; and manufacturers may similarly remove such articles for use of the United States; in accordance with such regulations and under such bonds as the Secretary shall prescribe. Tobacco products and cigarette papers and tubes may not be transferred or removed under this subsection unless such products or papers and tubes bear such marks, labels, or notices as the Secretary shall by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464ac83f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tobacco products and cigarette papers and tubes released in bond from customs custody","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Tobacco products and cigarette papers and tubes, imported or brought into the United States, may be released from customs custody, without payment of tax, for delivery to the proprietor of an export warehouse, or to a manufacturer of tobacco products or cigarette papers and tubes if such articles are not put up in packages, in accordance with such regulations and under such bond as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464ac840-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tobacco products and cigarette papers and tubes exported and returned","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Tobacco products and cigarette papers and tubes classifiable under item 804.00 of title I of the Tariff Act of 1930 (relating to duty on certain articles previously exported and returned) may be released from customs custody, without payment of that part of the duty attributable to the internal revenue tax for delivery to the original manufacturer of such tobacco products or cigarette papers and tubes or to the proprietor of an export warehouse authorized by such manufacturer to receive such articles, in accordance with such regulations and under such bond as the Secretary shall prescribe. Upon such release such products, papers, and tubes shall be subject to this chapter as if they had not been exported or otherwise removed from internal-revenue bond.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id464ac841-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/708"},"text":"68A Stat. 708","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s202"},"text":"Pub. L. 85–859, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1418"},"text":"72 Stat. 1418","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/342/s1/b"},"text":"Pub. L. 88–342, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-06-30"},"text":"June 30, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/234"},"text":"78 Stat. 234","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tV/s502/b/4"},"text":"Pub. L. 89–44, title V, § 502(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/151"},"text":"79 Stat. 151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1905(a)(26), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1821"},"text":"90 Stat. 1821","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tVIII/s8011/a/2"},"text":"Pub. L. 99–509, title VIII, § 8011(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1952"},"text":"100 Stat. 1952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7508/a"},"text":"Pub. L. 101–239, title VII, § 7508(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2370"},"text":"103 Stat. 2370","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIX/s9302/h/1/A"},"text":"Pub. L. 105–33, title IX, § 9302(h)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/673"},"text":"111 Stat. 673","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/476/tIV/s4002/b"},"text":"Pub. L. 106–476, title IV, § 4002(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2177"},"text":"114 Stat. 2177","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id464ac842-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id464ac843-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id464ac844-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Item 804.00 of title I of the Tariff Act of 1930, referred to in subsec. (d), was classified to item 804.00 of the Tariff Schedules of the United States. The Tariff Schedules of the United States were replaced by the Harmonized Tariff Schedule of the United States. The Harmonized Tariff Schedule of the United States is not set out in the Code. See Publication of Harmonized Tariff Schedule note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id464ac845-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/476"},"text":"Pub. L. 106–476","children":[],"tail":" substituted “the original manufacturer of such” for “a manufacturer of” and inserted “authorized by such manufacturer to receive such articles” after “proprietor of an export warehouse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" inserted at end “Tobacco products and cigarette papers and tubes may not be transferred or removed under this subsection unless such products or papers and tubes bear such marks, labels, or notices as the Secretary shall by regulations prescribe.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" inserted “or to a manufacturer of tobacco products or cigarette papers and tubes if such articles are not put up in packages,” after “export warehouse,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509"},"text":"Pub. L. 99–509","children":[],"tail":" struck out “to a manufacturer of tobacco products or cigarette papers and tubes or” after “for delivery”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 1905(a)(26), 1906(b)(13)(A), inserted “or to the proprietor of an export warehouse” after “to a manufacturer of tobacco products or cigarette papers and tubes” and struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s502/b/4"},"text":"Pub. L. 89–44, § 502(b)(4)","children":[],"tail":", redesignated subsec. (d) as (c), struck out all references to tobacco materials, and repealed former subsec. (c) which related to tobacco materials shipped or delivered in bond."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s502/b/4/A"},"text":"Pub. L. 89–44, § 502(b)(4)(A)","children":[],"tail":", redesignated subsec. (e) as (d). Former subsec. (d) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/342"},"text":"Pub. L. 88–342","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" included transfers by export warehouse proprietors, and substituted “tobacco products and cigarette papers and tubes” for “articles”, before “without payment of tax”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" authorized shipments without payment of tax of tobacco stems and waste only, to any person for use by him as fertilizer or insecticide or in the production of fertilizer, insecticide, or nicotine."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" substituted “tobacco products, cigarette papers and tubes” for “articles” wherever appearing, and struck out provisions which related to delivery to bonded premises of manufacturers and dealers."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id464ac846-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464ac847-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/476/tIV/s4002/d"},"text":"Pub. L. 106–476, title IV, § 4002(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2177"},"text":"114 Stat. 2177","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/476/tIV/s4002/d"},"text":"“The amendments made by this section [amending this section and sections 5754 and 5761 of this title] shall take effect 90 days after the date of the enactment of this Act [Nov 9, 2000].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464ac848-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" applicable to articles removed, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5702/j"},"text":"section 5702(j) of this title","children":[],"tail":", after "},{"tag":"date","attrib":{"date":"1999-12-31"},"text":"Dec. 31, 1999","children":[],"tail":", with transition rule, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/s9302/i"},"text":"section 9302(i) of Pub. L. 105–33","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5701"},"text":"section 5701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464ac849-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7508/b"},"text":"Pub. L. 101–239, title VII, § 7508(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2370"},"text":"103 Stat. 2370","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tVII/s7508/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to articles imported or brought into the United States after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464ac84a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509"},"text":"Pub. L. 99–509","children":[],"tail":" applicable to articles imported, entered for warehousing, or brought into the United States or a foreign trade zone after "},{"tag":"date","attrib":{"date":"1986-12-15"},"text":"Dec. 15, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/s8011/c"},"text":"section 8011(c) of Pub. L. 99–509","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5061"},"text":"section 5061 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464ac84b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1905/a/26"},"text":"section 1905(a)(26) of Pub. L. 94–455","children":[],"tail":" effective on first day of first month which begins more than 90 days after "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1905/d"},"text":"section 1905(d) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5005"},"text":"section 5005 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464ac84c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1965 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" applicable on and after "},{"tag":"date","attrib":{"date":"1966-01-01"},"text":"January 1, 1966","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/s701/d"},"text":"section 701(d) of Pub. L. 89–44","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5701"},"text":"section 5701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464ac84d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1964 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/342/s2"},"text":"Pub. L. 88–342, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-06-30"},"text":"June 30, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/234"},"text":"78 Stat. 234","children":[],"tail":", provided that the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/88/342/s2"},"text":"section 2 of Pub. L. 88–342","children":[],"tail":" shall apply with respect to articles entered, or withdrawn from warehouse, for consumption after "},{"tag":"date","attrib":{"date":"1964-06-30"},"text":"June 30, 1964","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464ac84e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1958-09-03"},"text":"Sept. 3, 1958","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/s210/a/1"},"text":"section 210(a)(1) of Pub. L. 85–859","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id464ac84f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/476/tI/s4002/e"},"text":"Pub. L. 106–476, title I, § 4002(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2177"},"text":"114 Stat. 2177","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/476/tI/s4002/e"},"text":"“The Secretary of the Treasury shall report to Congress on the impact of requiring export warehouses to be authorized by the original manufacturer to receive relanded export-labeled cigarettes.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
