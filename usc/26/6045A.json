{"tag":"section","attrib":{"id":"id46735ea4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6045A"},"text":null,"children":[{"tag":"num","attrib":{"value":"6045A"},"text":"§ 6045A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information required in connection with transfers of covered securities to brokers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46735ea5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6045A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Furnishing of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every applicable person which transfers to a broker (as defined in section 6045(c)(1)) a covered security (as defined in section 6045(g)(3)) in the hands of such applicable person shall furnish to such broker a written statement in such manner and setting forth such information as the Secretary may by regulations prescribe for purposes of enabling such broker to meet the requirements of section 6045(g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46735ea6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6045A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the term “applicable person” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46735ea7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6045A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any broker (as defined in section 6045(c)(1)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46735ea8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6045A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person as provided by the Secretary in regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46735ea9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6045A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for furnishing statement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided by the Secretary, any statement required by subsection (a) shall be furnished not later than 15 days after the date of the transfer described in such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46735eaa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6045A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return requirement for certain transfers of digital assets not otherwise subject to reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any broker, with respect to any transfer (which is not part of a sale or exchange executed by such broker) during a calendar year of a covered security which is a digital asset from an account maintained by such broker to an account which is not maintained by, or an address not associated with, a person that such broker knows or has reason to know is also a broker, shall make a return for such calendar year, in such form as determined by the Secretary, showing the information otherwise required to be furnished with respect to transfers subject to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46735eab-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dB/tIV/s403/c/1"},"text":"Pub. L. 110–343, div. B, title IV, § 403(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3858"},"text":"122 Stat. 3858","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dH/tVI/s80603/b/2/A"},"text":"Pub. L. 117–58, div. H, title VI, § 80603(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1340"},"text":"135 Stat. 1340","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46735eac-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46735ead-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46735eae-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s80603/b/2/A/i"},"text":"Pub. L. 117–58, § 80603(b)(2)(A)(i)","children":[],"tail":", struck out “a security which is” after “section 6045(c)(1))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s80603/b/2/A/ii"},"text":"Pub. L. 117–58, § 80603(b)(2)(A)(ii)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46735eaf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46735eb0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" applicable to returns required to be filed, and statements required to be furnished, after "},{"tag":"date","attrib":{"date":"2023-12-31"},"text":"Dec. 31, 2023","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s80603/c"},"text":"section 80603(c) of Pub. L. 117–58","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6045"},"text":"section 6045 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46735eb1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2011-01-01"},"text":"Jan. 1, 2011","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/s403/e/1"},"text":"section 403(e)(1) of Pub. L. 110–343","children":[],"tail":", set out as an Effective Date of 2008 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1012"},"text":"section 1012 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
