{"tag":"section","attrib":{"id":"id44f34e72-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367"},"text":null,"children":[{"tag":"num","attrib":{"value":"1367"},"text":"§ 1367.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments to basis of stock of shareholders, etc.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44f34e73-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f34e74-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increases in basis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The basis of each shareholder’s stock in an S corporation shall be increased for any period by the sum of the following items determined with respect to that shareholder for such period:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44f34e75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the items of income described in subparagraph (A) of section 1366(a)(1),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f34e76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any nonseparately computed income determined under subparagraph (B) of section 1366(a)(1), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f34e77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the excess of the deductions for depletion over the basis of the property subject to depletion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f34e78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decreases in basis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The basis of each shareholder’s stock in an S corporation shall be decreased for any period (but not below zero) by the sum of the following items determined with respect to the shareholder for such period:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44f34e79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributions by the corporation which were not includible in the income of the shareholder by reason of section 1368,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f34e7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the items of loss and deduction described in subparagraph (A) of section 1366(a)(1),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f34e7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any nonseparately computed loss determined under subparagraph (B) of section 1366(a)(1),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f34e7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any expense of the corporation not deductible in computing its taxable income and not properly chargeable to capital account, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f34e7d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the shareholder’s deduction for depletion for any oil and gas property held by the S corporation to the extent such deduction does not exceed the proportionate share of the adjusted basis of such property allocated to such shareholder under section 613A(c)(11)(B).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The decrease under subparagraph (B) by reason of a charitable contribution (as defined in section 170(c)) of property shall be the amount equal to the shareholder’s pro rata share of the adjusted basis of such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f34e7e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f34e7f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income items","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An amount which is required to be included in the gross income of a shareholder and shown on his return shall be taken into account under subparagraph (A) or (B) of subsection (a)(1) only to the extent such amount is included in the shareholder’s gross income on his return, increased or decreased by any adjustment of such amount in a redetermination of the shareholder’s tax liability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f34e80-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments in basis of indebtedness","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44f34e81-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If for any taxable year the amounts specified in subparagraphs (B), (C), (D), and (E) of subsection (a)(2) exceed the amount which reduces the shareholder’s basis to zero, such excess shall be applied to reduce (but not below zero) the shareholder’s basis in any indebtedness of the S corporation to the shareholder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f34e82-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration of basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If for any taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"1982-12-31"},"text":"December 31, 1982","children":[],"tail":", there is a reduction under subparagraph (A) in the shareholder’s basis in the indebtedness of an S corporation to a shareholder, any net increase (after the application of paragraphs (1) and (2) of subsection (a)) for any subsequent taxable year shall be applied to restore such reduction in basis before any of it may be used to increase the shareholder’s basis in the stock of the S corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f34e83-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with sections 165(g) and 166(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section and section 1366 shall be applied before the application of sections 165(g) and 166(d) to any taxable year of the shareholder or the corporation in which the security or debt becomes worthless.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f34e84-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments in case of inherited stock","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44f34e85-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any person acquires stock in an S corporation by reason of the death of a decedent or by bequest, devise, or inheritance, section 691 shall be applied with respect to any item of income of the S corporation in the same manner as if the decedent had held directly his pro rata share of such item.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f34e86-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1367/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments to basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The basis determined under section 1014 of any stock in an S corporation shall be reduced by the portion of the value of the stock which is attributable to items constituting income in respect of the decedent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44f34e87-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/354/s2"},"text":"Pub. L. 97–354, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"Oct. 19, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1679"},"text":"96 Stat. 1679","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII"},"text":"Pub. L. 98–369, div. A, title VII","children":[],"tail":", §§ 721(d), (w), 722(e)(2), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/967"},"text":"98 Stat. 967","children":[],"tail":", 971, 974; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI"},"text":"Pub. L. 104–188, title I","children":[],"tail":", §§ 1313(a), 1702(h)(14), "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1785"},"text":"110 Stat. 1785","children":[],"tail":", 1874; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1203/a"},"text":"Pub. L. 109–280, title XII, § 1203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1066"},"text":"120 Stat. 1066","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dC/tIII/s307/a"},"text":"Pub. L. 110–343, div. C, title III, § 307(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3869"},"text":"122 Stat. 3869","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/312/tVII/s752/a"},"text":"Pub. L. 111–312, title VII, § 752(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-17"},"text":"Dec. 17, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3321"},"text":"124 Stat. 3321","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/tIII/s325/a"},"text":"Pub. L. 112–240, title III, § 325(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2333"},"text":"126 Stat. 2333","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tI/s137/a"},"text":"Pub. L. 113–295, div. A, title I, § 137(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4019"},"text":"128 Stat. 4019","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tI/s115/a"},"text":"Pub. L. 114–113, div. Q, title I, § 115(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3049"},"text":"129 Stat. 3049","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44f34e88-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44f34e89-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44f34e8a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":" struck out “The preceding sentence shall not apply to contributions made in taxable years beginning after "},{"tag":"date","attrib":{"date":"2014-12-31"},"text":"December 31, 2014","children":[],"tail":".” at end of concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2014-12-31"},"text":"December 31, 2014","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"December 31, 2013","children":[],"tail":"” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/240"},"text":"Pub. L. 112–240","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"December 31, 2013","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":"” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312"},"text":"Pub. L. 111–312","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":"” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343"},"text":"Pub. L. 110–343","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2007-12-31"},"text":"December 31, 2007","children":[],"tail":"” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":", which directed the addition of concluding provisions to section 1367(a)(2), without specifying the act to be amended, was executed to subsec. (a)(2) of this section, which is section 1367 of the Internal Revenue Code of 1986, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1702/h/14"},"text":"Pub. L. 104–188, § 1702(h)(14)","children":[],"tail":", substituted “section 613A(c)(11)(B)” for “section 613A(c)(13)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1313/a"},"text":"Pub. L. 104–188, § 1313(a)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s722/e/2"},"text":"Pub. L. 98–369, § 722(e)(2)","children":[],"tail":", substituted “for any oil and gas p