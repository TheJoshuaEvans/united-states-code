{"tag":"section","attrib":{"id":"id43f69f6c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s684"},"text":null,"children":[{"tag":"num","attrib":{"value":"684"},"text":"§ 684.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition of gain on certain transfers to certain foreign trusts and estates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43f90f6d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s684/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in regulations, in the case of any transfer of property by a United States person to a foreign estate or trust, for purposes of this subtitle, such transfer shall be treated as a sale or exchange for an amount equal to the fair market value of the property transferred, and the transferor shall recognize as gain the excess of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43f90f6e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s684/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of the property so transferred, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f90f6f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s684/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjusted basis (for purposes of determining gain) of such property in the hands of the transferor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f90f70-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s684/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to a transfer to a trust by a United States person to the extent that any person is treated as the owner of such trust under section 671.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f90f71-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s684/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of trusts which become foreign trusts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a trust which is not a foreign trust becomes a foreign trust, such trust shall be treated for purposes of this section as having transferred, immediately before becoming a foreign trust, all of its assets to a foreign trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43f90f72-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXI/s1131/b"},"text":"Pub. L. 105–34, title XI, § 1131(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/978"},"text":"111 Stat. 978","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tV/s542/e/1/A"},"text":"Pub. L. 107–16, title V, § 542(e)(1)(A)","children":[],"tail":"–(C), "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/84"},"text":"115 Stat. 84","children":[],"tail":", 85; "},{"tag":"ref","attrib":{"href":"/us/pl/111/312/tIII/s301/a"},"text":"Pub. L. 111–312, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-17"},"text":"Dec. 17, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3300"},"text":"124 Stat. 3300","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43f90f73-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43f90f74-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id43f90f75-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1131/b"},"text":"section 1131(b) of Pub. L. 105–34","children":[],"tail":" amended sections 367, 721, and 1035 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43f90f76-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312"},"text":"Pub. L. 111–312","children":[],"tail":" amended catchline, introductory provisions of subsec. (a), and subsec. (b) to read as if amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/s542/e/1/A"},"text":"Pub. L. 107–16, § 542(e)(1)(A)","children":[],"tail":"–(C), had never been enacted. See 2001 Amendment note below. Prior to amendment, subsec. (b) read as follows: “"},{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Transfers to certain trusts","children":[],"tail":".—Subsection (a) shall not apply to a transfer to a trust by a United States person to the extent that any United States person is treated as the owner of such trust under section 671."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Lifetime transfers to nonresident aliens","children":[],"tail":".—Subsection (a) shall not apply to a lifetime transfer to a nonresident alien.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s542/e/1/A"},"text":"Pub. L. 107–16, § 542(e)(1)(A)","children":[],"tail":"–(C), amended section by inserting “and nonresident aliens” after “estates” in section catchline and “or to a nonresident alien” after “or trust” in introductory provisions of subsec. (a) and amending subsec. (b) generally. Prior to amendment, text of subsec. (b) read as follows: “Subsection (a) shall not apply to a transfer to a trust by a United States person to the extent that any person is treated as the owner of such trust under section 671.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43f90f77-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43f90f78-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312"},"text":"Pub. L. 111–312","children":[],"tail":" applicable to estates of decedents dying, and transfers made after "},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"Dec. 31, 2009","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/312/s301/e"},"text":"section 301(e) of Pub. L. 111–312","children":[],"tail":", set out as an Effective and Termination Dates of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s121"},"text":"section 121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43f90f79-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16"},"text":"Pub. L. 107–16","children":[],"tail":" applicable to transfers after "},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"Dec. 31, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/s542/f/2"},"text":"section 542(f)(2) of Pub. L. 107–16","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s121"},"text":"section 121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
