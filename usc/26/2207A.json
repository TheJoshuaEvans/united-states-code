{"tag":"section","attrib":{"id":"id453d4f6d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207A"},"text":null,"children":[{"tag":"num","attrib":{"value":"2207A"},"text":"§ 2207A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of recovery in the case of certain marital deduction property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id453d4f6e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery with respect to estate tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id453d4f6f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any part of the gross estate consists of property the value of which is includible in the gross estate by reason of section 2044 (relating to certain property for which marital deduction was previously allowed), the decedent’s estate shall be entitled to recover from the person receiving the property the amount by which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id453d4f70-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207A/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total tax under this chapter which has been paid, exceeds","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id453d4f71-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207A/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total tax under this chapter which would have been payable if the value of such property had not been included in the gross estate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453d4f72-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decedent may otherwise direct","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply with respect to any property to the extent that the decedent in his will (or a revocable trust) specifically indicates an intent to waive any right of recovery under this subchapter with respect to such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453d4f73-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery with respect to gift tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If for any calendar year tax is paid under chapter 12 with respect to any person by reason of property treated as transferred by such person under section 2519, such person shall be entitled to recover from the person receiving the property the amount by which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id453d4f74-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total tax for such year under chapter 12, exceeds","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453d4f75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total tax which would have been payable under such chapter for such year if the value of such property had not been taken into account for purposes of chapter 12.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453d4f76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" More than one recipient of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, if there is more than one person receiving the property, the right of recovery shall be against each such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453d4f77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxes and interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of penalties and interest attributable to additional taxes described in subsections (a) and (b), rules similar to subsections (a), (b), and (c) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id453d4f78-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV/s403/d/4/A"},"text":"Pub. L. 97–34, title IV, § 403(d)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/304"},"text":"95 Stat. 304","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIII/s1302/a"},"text":"Pub. L. 105–34, title XIII, § 1302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1039"},"text":"111 Stat. 1039","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id453d4f79-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id453d4f7a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id453d4f7b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" amended heading and text of par. (2) generally. Prior to amendment, text read as follows: “Paragraph (1) shall not apply if the decedent otherwise directs by will.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id453d4f7c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id453d4f7d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIII/s1302/c"},"text":"Pub. L. 105–34, title XIII, § 1302(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1039"},"text":"111 Stat. 1039","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tXIII/s1302/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s2207B"},"text":"section 2207B of this title","children":[],"tail":"] shall apply with respect to the estates of decedents dying after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id453d4f7e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to estates of decedents dying after ","children":[{"tag":"date","attrib":{"date":"1981-12-31"},"text":"Dec. 31, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/s403/e"},"text":"section 403(e) of Pub. L. 97–34","children":[],"tail":", set out as an Effective Date of 1981 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2056"},"text":"section 2056 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
