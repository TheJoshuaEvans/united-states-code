{"tag":"section","attrib":{"id":"id4147d2f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s85"},"text":null,"children":[{"tag":"num","attrib":{"value":"85"},"text":"§ 85.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unemployment compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4147d2f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s85/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual, gross income includes unemployment compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4147d2f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s85/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unemployment compensation defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “unemployment compensation” means any amount received under a law of the United States or of a State which is in the nature of unemployment compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4147d2f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s85/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for 2020","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4147d2f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s85/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any taxable year beginning in 2020, if the adjusted gross income of the taxpayer for such taxable year is less than $150,000, the gross income of such taxpayer shall not include so much of the unemployment compensation received by such taxpayer (or, in the case of a joint return, received by each spouse) as does not exceed $10,200.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4147d2f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s85/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the adjusted gross income of the taxpayer shall be determined—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4147d2fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s85/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after application of sections 86, 135, 137, 219, 221, 222, and 469, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4147d2fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s85/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4147d2fc-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/tI/s112/a"},"text":"Pub. L. 95–600, title I, § 112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2777"},"text":"92 Stat. 2777","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tI/s103/c/1"},"text":"Pub. L. 97–34, title I, § 103(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/188"},"text":"95 Stat. 188","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tVI/s611/a"},"text":"Pub. L. 97–248, title VI, § 611(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/706"},"text":"96 Stat. 706","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/21/tI"},"text":"Pub. L. 98–21, title I","children":[],"tail":", §§ 121(f)(1), 122(c)(2), "},{"tag":"date","attrib":{"date":"1983-04-20"},"text":"Apr. 20, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/84"},"text":"97 Stat. 84","children":[],"tail":", 87; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tI/s121"},"text":"Pub. L. 99–514, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2109"},"text":"100 Stat. 2109","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI/s1007/a"},"text":"Pub. L. 111–5, div. B, title I, § 1007(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/317"},"text":"123 Stat. 317","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/15"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4039"},"text":"128 Stat. 4039","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIX/s9042/a"},"text":"Pub. L. 117–2, title IX, § 9042(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/122"},"text":"135 Stat. 122","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4147d2fd-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4147d2fe-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4147d2ff-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Pub. L. 117–2","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" struck out subsec. (c). Text read as follows: “In the case of any taxable year beginning in 2009, gross income shall not include so much of the unemployment compensation received by an individual as does not exceed $2,400.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “General rule” for “In general” in heading and amended text generally. Prior to amendment, text read as follows: “If the sum for the taxable year of the adjusted gross income of the taxpayer (determined without regard to this section, section 86 and section 221) and the unemployment compensation exceeds the base amount, gross income for the taxable year includes unemployment compensation in an amount equal to the lesser of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) one-half of the amount of the excess of such sum over the base amount, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the amount of the unemployment compensation.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", in amending section generally, redesignated former subsec. (c) as (b) and struck out former subsec. (b), “Base amount defined”, which read as follows: “For purposes of this section, the term ‘base amount’ means—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) except as provided in paragraphs (2) and (3), $12,000,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) $18,000, in the case of a joint return under section 6013, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) zero, in the case of a taxpayer who—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) is married at the close of the taxable year (within the meaning of section 143) but does not file a joint return for such year, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) does not live apart from his spouse at all times during the taxable year.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/21/s122/c/2"},"text":"Pub. L. 98–21, § 122(c)(2)","children":[],"tail":", struck out “, section 105(d),” after “section 86”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/21/s121/f/1"},"text":"Pub. L. 98–21, § 121(f)(1)","children":[],"tail":", inserted “section 86,” after “this section,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s611/a/1"},"text":"Pub. L. 97–248, § 611(a)(1)","children":[],"tail":", substituted “$12,000” for “$20,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s611/a/2"},"text":"Pub. L. 97–248, § 611(a)(2)","children":[],"tail":", substituted “$18,000” for “$25,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" substituted “this section, section 105(d), and section 221” for “this section and without regard to section 105(d)” in parenthetical provision preceding par. (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id414a4300-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id414a4301-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Pub. L. 117–2","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2019-12-31"},"text":"Dec. 31, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/s9042/c"},"text":"section 9042(c) of Pub. L. 117–2","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s74"},"text":"section 74 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id414a4302-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/b"},"text":"section 221(b) of Pub. L. 113–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id414a4303-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI/s1007/b"},"text":"Pub. L. 111–5, div. B, title I, § 1007(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/317"},"text":"123 Stat. 317","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/5/dB/tI/s1007/b"},"text":"“The amendment made by this section [amending this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id414a4304-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" applicable to amounts received after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", in taxable years ending after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s151/b"},"text":"section 151(b) of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id414a4305-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/21/s121/f/1"},"text":"section 121(f)(1) of Pub. L. 98–21","children":[],"tail":" applicable to benefits received after "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"Dec. 31, 1983","children":[],"tail":", in taxable years ending after such date, except for any portion of a lump-sum payment of social security benefits received after "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"Dec. 31, 1983","children":[],"tail":", if the generally applicable payment date for such portion was before "},{"tag":"date","attrib":{"date":"1984-01-01"},"text":"Jan. 1, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/21/s121/g"},"text":"section 121(g) of Pub. L. 98–21","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s86"},"text":"section 86 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/21/s122/c/2"},"text":"section 122(c)(2) of Pub. L. 98–21","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"Dec. 31, 1983","children":[],"tail":", except that if an individual’s annuity starting date was deferred under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s105/d/6"},"text":"section 105(d)(6) of this title","children":[],"tail":" as in effect on the day before "},{"tag":"date","attrib":{"date":"1983-04-20"},"text":"Apr. 20, 1983","children":[],"tail":", such deferral shall end on the first day of such individual’s first taxable year beginning after "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"Dec. 31, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/21/s122/d"},"text":"section 122(d) of Pub. L. 98–21","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s22"},"text":"section 22 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id414a4306-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tVI/s611/b"},"text":"Pub. L. 97–248, title VI, § 611(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/706"},"text":"96 Stat. 706","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation paid after 1981","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section] shall apply to payments of unemployment compensation made after ","children":[{"tag":"date","attrib":{"date":"1981-12-31"},"text":"December 31, 1981","children":[],"tail":", in taxable years ending after such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No addition to tax for underpayment of estimated tax attributable to application of amendments to compensation paid in 1982","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No addition to tax shall be made under section 6654 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] with respect to any underpayment to the extent such underpayment is attributable to unemployment compensation which is received during 1982 and which (but for the amendments made by subsection (a)) would not be includable in gross income.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for fiscal year taxpayers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a taxable year (other than a calendar year) which includes ","children":[{"tag":"date","attrib":{"date":"1982-01-01"},"text":"January 1, 1982","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amendments made by this section shall be applied by taking into account the entire amount of unemployment compensation received during such taxable year, but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the increase in gross income for such taxable year as a result of such amendments shall not exceed the amount of unemployment compensation paid after ","children":[{"tag":"date","attrib":{"date":"1981-12-31"},"text":"December 31, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unemployment compensation defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this subsection, the term ‘unemployment compensation’ has the meaning given to such term by section 85(c) [now 85(b)] of the Internal Revenue Code of 1986.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id414a4307-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1981-12-31"},"text":"Dec. 31, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/s103/d"},"text":"section 103(d) of Pub. L. 97–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s62"},"text":"section 62 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id414a4308-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/tI/s112/d"},"text":"Pub. L. 95–600, title I, § 112(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2778"},"text":"92 Stat. 2778","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1075/a"},"text":"Pub. L. 98–369, div. A, title X, § 1075(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1053"},"text":"98 Stat. 1053","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tX/s1075/a"},"text":"“The amendments made by this section [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6050B"},"text":"section 6050B of this title","children":[],"tail":"] shall apply to payments of unemployment compensation made after "},{"tag":"date","attrib":{"date":"1978-12-31"},"text":"December 31, 1978","children":[],"tail":", in taxable years ending after such date, except that such amendments shall not apply to payments made for weeks of unemployment ending before "},{"tag":"date","attrib":{"date":"1978-12-01"},"text":"December 1, 1978","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id414a4309-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Waiver of Statute of Limitations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1075/b"},"text":"Pub. L. 98–369, div. A, title X, § 1075(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1053"},"text":"98 Stat. 1053","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tX/s1075/b"},"text":"“If credit or refund of any overpayment of tax resulting from the amendment made by subsection (a) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s112/d"},"text":"section 112(d) of Pub. L. 95–600","children":[],"tail":", set out as an Effective Date note above] is barred on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":"] or at any time during the 1-year period beginning on the date of the enactment of this Act by the operation of any law or rule of law (including res judicata), refund or credit of such overpayment (to the extent attributable to the amendment made by subsection (a)) may, nevertheless, be made or allowed if claim therefor is filed before the close of such 1-year period.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
