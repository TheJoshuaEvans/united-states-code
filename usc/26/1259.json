{"tag":"section","attrib":{"id":"id44d45451-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259"},"text":null,"children":[{"tag":"num","attrib":{"value":"1259"},"text":"§ 1259.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Constructive sales treatment for appreciated financial positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44d45452-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If there is a constructive sale of an appreciated financial position—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d45453-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer shall recognize gain as if such position were sold, assigned, or otherwise terminated at its fair market value on the date of such constructive sale (and any gain shall be taken into account for the taxable year which includes such date), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d45454-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for purposes of applying this title for periods after the constructive sale—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d45455-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proper adjustment shall be made in the amount of any gain or loss subsequently realized with respect to such position for any gain taken into account by reason of paragraph (1), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d45456-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the holding period of such position shall be determined as if such position were originally acquired on the date of such constructive sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d45457-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appreciated financial position","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d45458-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the term “appreciated financial position” means any position with respect to any stock, debt instrument, or partnership interest if there would be gain were such position sold, assigned, or otherwise terminated at its fair market value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d45459-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appreciated financial position” shall not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d4545a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any position with respect to debt if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44d4545b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the position unconditionally entitles the holder to receive a specified principal amount,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d4545c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interest payments (or other similar amounts) with respect to such position meet the requirements of clause (i) of section 860G(a)(1)(B), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d4545d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such position is not convertible (directly or indirectly) into stock of the issuer or any related person,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d4545e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any hedge with respect to a position described in subparagraph (A), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d4545f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any position which is marked to market under any provision of this title or the regulations thereunder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d45460-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Position","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “position” means an interest, including a futures or forward contract, short sale, or option.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d45461-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Constructive sale","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d45462-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A taxpayer shall be treated as having made a constructive sale of an appreciated financial position if the taxpayer (or a related person)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d45463-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enters into a short sale of the same or substantially identical property,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d45464-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enters into an offsetting notional principal contract with respect to the same or substantially identical property,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d45465-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enters into a futures or forward contract to deliver the same or substantially identical property,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d45466-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an appreciated financial position that is a short sale or a contract described in subparagraph (B) or (C) with respect to any property, acquires the same or substantially identical property, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d45467-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent prescribed by the Secretary in regulations, enters into 1 or more other transactions (or acquires 1 or more positions) that have substantially the same effect as a transaction described in any of the preceding subparagraphs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d45468-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for sales of nonpublicly traded property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A taxpayer shall not be treated as having made a constructive sale solely because the taxpayer enters into a contract for sale of any stock, debt instrument, or partnership interest which is not a marketable security (as defined in section 453(f)) if the contract settles within 1 year after the date such contract is entered into.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d45469-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain closed transactions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d4546a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In applying this section, there shall be disregarded any transaction (which would otherwise cause a constructive sale) during the taxable year if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44d4546b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such transaction is closed on or before the 30th day after the close of such taxable year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d4546c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer holds the appreciated financial position throughout the 60-day period beginning on the date such transaction is closed, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d4546d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at no time during such 60-day period is the taxpayer’s risk of loss with respect to such position reduced by reason of a circumstance which would be described in section 246(c)(4) if references to stock included references to such position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d4546e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain closed transactions where risk of loss on appreciated financial position diminished","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44d4546f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a transaction, which would otherwise cause a constructive sale of an appreciated financial position, is closed during the taxable year or during the 30 days thereafter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d45470-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" another transaction is entered into during the 60-day period beginning on the date the transaction referred to in clause (i) is closed—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id44d45471-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which would (but for this subparagraph) cause the requirement of subparagraph (A)(iii) not to be met with respect to the transaction described in clause (i) of this subparagraph,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44d45472-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is closed on or before the 30th day after the close of the taxable year in which the transaction referred to in clause (i) occurs, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44d45473-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/3/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which meets the requirements of clauses (ii) and (iii) of subparagraph (A),","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the transaction referred to in clause (ii) shall be disregarded for purposes of determining whether the requirements of subparagraph (A)(iii) are met with respect to the transaction described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d45474-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person is related to another person with respect to a transaction if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d45475-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relationship is described in section 267(b) or 707(b), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d45476-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such transaction is entered into with a view toward avoiding the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d45477-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d45478-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forward contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “forward contract” means a contract to deliver a substantially fixed amount of property (including cash) for a substantially fixed price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d45479-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offsetting notional principal contract","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “offsetting notional principal contract” means, with respect to any property, an agreement which includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d4547a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement to pay (or provide credit for) all or substantially all of the investment yield (including appreciation) on such property for a specified period, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d4547b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a right to be reimbursed for (or receive credit for) all or substantially all of any decline in the value of such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d4547c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d4547d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of subsequent sale of position which was deemed sold","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d4547e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a constructive sale of any appreciated financial position,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d4547f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such position is subsequently disposed of, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d45480-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time of such disposition, the transaction resulting in the constructive sale of such position is open with respect to the taxpayer or any related person,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"solely for purposes of determining whether the taxpayer has entered into a constructive sale of any other appreciated financial position held by the taxpayer, the taxpayer shall be treated as entering into such transaction immediately after such disposition. For purposes of the preceding sentence, an assignment or other termination shall be treated as a disposition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d45481-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain trust instruments treated as stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, an interest in a trust which is actively traded (within the meaning of section 1092(d)(1)) shall be treated as stock unless substantially all (by value) of the property held by the trust is debt described in subsection (b)(2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d45482-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple positions in property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a taxpayer holds multiple positions in property, the determination of whether a specific transaction is a constructive sale and, if so, which appreciated financial position is deemed sold shall be made in the same manner as actual sales.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d45483-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1259/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary or appropriate to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44d45484-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1001/a"},"text":"Pub. L. 105–34, title X, § 1001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/903"},"text":"111 Stat. 903","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tVI/s6010/a/1"},"text":"Pub. L. 105–206, title VI, § 6010(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/812"},"text":"112 Stat. 812","children":[],"tail":", 813; "},{"tag":"ref","attrib":{"href":"/us/pl/108/311/tIV/s406/e"},"text":"Pub. L. 108–311, title IV, § 406(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-04"},"text":"Oct. 4, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1189"},"text":"118 Stat. 1189","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44d45485-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44d45486-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44d45487-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311/s406/e/1"},"text":"Pub. L. 108–311, § 406(e)(1)","children":[],"tail":", substituted “A taxpayer shall not be treated as having made a constructive sale solely because the taxpayer enters into a contract” for “The term ‘constructive sale’ shall not include any contract”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311/s406/e/2"},"text":"Pub. L. 108–311, § 406(e)(2)","children":[],"tail":", substituted “cause a constructive sale” for “be treated as a constructive sale” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311/s406/e/3"},"text":"Pub. L. 108–311, § 406(e)(3)","children":[],"tail":", substituted “on or before” for “before the end of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311/s406/e/7"},"text":"Pub. L. 108–311, § 406(e)(7)","children":[],"tail":", substituted “certain closed transactions where risk of loss on appreciated financial position diminished” for “positions which are reestablished” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311/s406/e/2"},"text":"Pub. L. 108–311, § 406(e)(2)","children":[],"tail":", substituted “cause a constructive sale” for “be treated as a constructive sale”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311/s406/e/4"},"text":"Pub. L. 108–311, § 406(e)(4)","children":[],"tail":", struck out “substantially similar” after “another” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(B)(ii)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311/s406/e/5"},"text":"Pub. L. 108–311, § 406(e)(5)","children":[],"tail":", amended subcl. (I) generally. Prior to amendment, subcl. (I) read as follows: “which also would otherwise be treated as a constructive sale of such position,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(B)(ii)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311/s406/e/6"},"text":"Pub. L. 108–311, § 406(e)(6)","children":[],"tail":", inserted “on or” before “before the 30th day”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(2)(A)(i) to (iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6010/a/1/A"},"text":"Pub. L. 105–206, § 6010(a)(1)(A)","children":[],"tail":", substituted “position” for “debt”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6010/a/1/B"},"text":"Pub. L. 105–206, § 6010(a)(1)(B)","children":[],"tail":", (C), added subpar. (B) and redesignated former subpar. (B) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6010/a/2"},"text":"Pub. L. 105–206, § 6010(a)(2)","children":[],"tail":", inserted “(including cash)” after “property”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44d45488-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44d45489-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311"},"text":"Pub. L. 108–311","children":[],"tail":" effective as if included in the provisions of the Taxpayer Relief Act of 1997, "},{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/311/s406/h"},"text":"section 406(h) of Pub. L. 108–311","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s55"},"text":"section 55 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44d4548a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Taxpayer Relief Act of 1997, "},{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6024"},"text":"section 6024 of Pub. L. 105–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44d4548b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any constructive sale after ","children":[{"tag":"date","attrib":{"date":"1997-06-08"},"text":"June 8, 1997","children":[],"tail":", with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1001/d"},"text":"section 1001(d) of Pub. L. 105–34","children":[],"tail":", set out as an Effective Date of 1997 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s475"},"text":"section 475 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
