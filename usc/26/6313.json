{"tag":"section","attrib":{"id":"id46c6af3b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6313"},"text":null,"children":[{"tag":"num","attrib":{"value":"6313"},"text":"§ 6313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fractional parts of a cent","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the payment of any tax imposed by this title, a fractional part of a cent shall be disregarded unless it amounts to one-half cent or more, in which case it shall be increased to 1 cent.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id46c6af3c-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/778"},"text":"68A Stat. 778","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/a/19"},"text":"Pub. L. 94–455, title XIX, § 1906(a)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1825"},"text":"90 Stat. 1825","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46c6af3d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46c6af3e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46c6af3f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “not payable by stamp” after “title”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
