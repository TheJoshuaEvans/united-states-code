{"tag":"section","attrib":{"id":"id46ac971d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6115"},"text":null,"children":[{"tag":"num","attrib":{"value":"6115"},"text":"§ 6115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure related to quid pro quo contributions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46ac971e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an organization described in section 170(c) (other than paragraph (1) thereof) receives a quid pro quo contribution in excess of $75, the organization shall, in connection with the solicitation or receipt of the contribution, provide a written statement which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46ac971f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6115/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informs the donor that the amount of the contribution that is deductible for Federal income tax purposes is limited to the excess of the amount of any money and the value of any property other than money contributed by the donor over the value of the goods or services provided by the organization, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ac9720-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6115/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides the donor with a good faith estimate of the value of such goods or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46ac9721-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quid pro quo contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “quid pro quo contribution” means a payment made partly as a contribution and partly in consideration for goods or services provided to the payor by the donee organization. A quid pro quo contribution does not include any payment made to an organization, organized exclusively for religious purposes, in return for which the taxpayer receives solely an intangible religious benefit that generally is not sold in a commercial transaction outside the donative context.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46ac9722-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13173/a"},"text":"Pub. L. 103–66, title XIII, § 13173(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/456"},"text":"107 Stat. 456","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46ac9723-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46ac9724-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46ac9725-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6115 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6116"},"text":"section 6116 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46ac9726-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46ac9727-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13173/d"},"text":"Pub. L. 103–66, title XIII, § 13173(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/457"},"text":"107 Stat. 457","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/66/tXIII/s13173/d"},"text":"“The provisions of this section [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6714"},"text":"section 6714 of this title","children":[],"tail":" and renumbering former section 6115 as 6116 of this title] shall apply to quid pro quo contributions made on or after "},{"tag":"date","attrib":{"date":"1994-01-01"},"text":"January 1, 1994","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
