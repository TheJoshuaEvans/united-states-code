{"tag":"section","attrib":{"id":"id4736d619-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6720B"},"text":null,"children":[{"tag":"num","attrib":{"value":"6720B"},"text":"§ 6720B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraudulent identification of exempt use property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to any criminal penalty provided by law, any person who identifies applicable property (as defined in section 170(e)(7)(C)) as having a use which is related to a purpose or function constituting the basis for the donee’s exemption under section 501 and who knows that such property is not intended for such a use shall pay a penalty of $10,000.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4736d61a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1215/c/1"},"text":"Pub. L. 109–280, title XII, § 1215(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1079"},"text":"120 Stat. 1079","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4736d61b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4736d61c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4736d61d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1215/c/1"},"text":"Section 1215(c)(1) of Pub. L. 109–280","children":[],"tail":", which directed the addition of section 6720B at the end of part I of subchapter B of chapter 68, without specifying the act to be amended, was executed by adding section 6720B at the end of part I of subchapter B of chapter 68 of this title, which consists of the Internal Revenue Code of 1986, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4736d61e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4736d61f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1215/d/3"},"text":"Pub. L. 109–280, title XII, § 1215(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1079"},"text":"120 Stat. 1079","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/280/tXII/s1215/d/3"},"text":"“The amendments made by subsection (c) [enacting this section] shall apply to identifications made after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
