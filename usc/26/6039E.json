{"tag":"section","attrib":{"id":"id466c32d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039E"},"text":null,"children":[{"tag":"num","attrib":{"value":"6039E"},"text":"§ 6039E.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information concerning resident status","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id466c32d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039E/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, any individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id466c32d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039E/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applies for a United States passport (or a renewal thereof), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id466c32da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039E/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applies to be lawfully accorded the privilege of residing permanently in the United States as an immigrant in accordance with the immigration laws,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall include with any such application a statement which includes the information described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id466c32db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039E/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to be provided","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Information required under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id466c32dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039E/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer’s TIN (if any),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id466c32dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039E/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a passport applicant, any foreign country in which such individual is residing,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id466c32de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039E/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual seeking permanent residence, information with respect to whether such individual is required to file a return of the tax imposed by chapter 1 for such individual’s most recent 3 taxable years, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id466c32df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039E/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id466c32e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039E/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual failing to provide a statement required under subsection (a) shall be subject to a penalty equal to $500 for each such failure, unless it is shown that such failure is due to reasonable cause and not to willful neglect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id466c32e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039E/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to be provided to Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, any agency of the United States which collects (or is required to collect) the statement under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id466c32e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039E/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide any such statement to the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id466c32e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039E/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the Secretary the name (and any other identifying information) of any individual refusing to comply with the provisions of subsection (a).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Nothing in the preceding sentence shall be construed to require the disclosure of information which is subject to section 245A of the Immigration and Nationality Act (as in effect on the date of the enactment of this sentence).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id466c32e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039E/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may by regulations exempt any class of individuals from the requirements of this section if he determines that applying this section to such individuals is not necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id466c32e5-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1234/a/1"},"text":"Pub. L. 99–514, title XII, § 1234(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2565"},"text":"100 Stat. 2565","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012"},"text":"Pub. L. 100–647, title I, § 1012","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3515"},"text":"102 Stat. 3515","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id466c32e6-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id466c32e7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id466c32e8-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 245A of the Immigration and Nationality Act, referred to in subsec. (d), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1255a"},"text":"section 1255a of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this sentence, referred to in subsec. (d), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id466c32e9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" inserted sentence at end relating to disclosure of information subject to section 245A of the Immigration and Nationality Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id466c32ea-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id466c32eb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id466c32ec-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1234/a/3"},"text":"Pub. L. 99–514, title XII, § 1234(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2566"},"text":"100 Stat. 2566","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXII/s1234/a/3"},"text":"“The amendments made by this subsection [enacting this section] shall apply to applications submitted after ","children":[{"tag":"date","attrib":{"date":"1987-12-31"},"text":"December 31, 1987","children":[],"tail":" (or, if earlier, the effective date which shall not be earlier than "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":") of the initial regulations issued under section 6039E of the Internal Revenue Code of 1986 as added by this subsection).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
