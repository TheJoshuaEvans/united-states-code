{"tag":"section","attrib":{"id":"id454ba7a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652"},"text":null,"children":[{"tag":"num","attrib":{"value":"2652"},"text":"§ 2652.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id454ba7a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transferor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454ba7a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in this subsection or section 2653(a), the term “transferor” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454ba7a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any property subject to the tax imposed by chapter 11, the decedent, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454ba7a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any property subject to the tax imposed by chapter 12, the donor.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"An individual shall be treated as transferring any property with respect to which such individual is the transferor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba7a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gift-splitting by married couples","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, under section 2513, one-half of a gift is treated as made by an individual and one-half of such gift is treated as made by the spouse of such individual, such gift shall be so treated for purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba7a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special election for qualified terminable interest property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454ba7a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any trust with respect to which a deduction is allowed to the decedent under section 2056 by reason of subsection (b)(7) thereof, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454ba7a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any trust with respect to which a deduction to the donor spouse is allowed under section 2523 by reason of subsection (f) thereof,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the estate of the decedent or the donor spouse, as the case may be, may elect to treat all of the property in such trust for purposes of this chapter as if the election to be treated as qualified terminable interest property had not been made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454ba7aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust and trustee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454ba7ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “trust” includes any arrangement (other than an estate) which, although not a trust, has substantially the same effect as a trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba7ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trustee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an arrangement which is not a trust but which is treated as a trust under this subsection, the term “trustee” shall mean the person in actual or constructive possession of the property subject to such arrangement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba7ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examples","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Arrangements to which this subsection applies include arrangements involving life estates and remainders, estates for years, and insurance and annuity contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454ba7ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454ba7af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person has an interest in property held in trust if (at the time the determination is made) such person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454ba7b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a right (other than a future right) to receive income or corpus from the trust,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454ba7b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a permissible current recipient of income or corpus from the trust and is not described in section 2055(a), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454ba7b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is described in section 2055(a) and the trust is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id454ba7b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a charitable remainder annuity trust,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id454ba7b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a charitable remainder unitrust within the meaning of section 664, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id454ba7b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pooled income fund within the meaning of section 642(c)(5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba7b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain interests disregarded","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), an interest which is used primarily to postpone or avoid any tax imposed by this chapter shall be disregarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba7b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain support obligations disregarded","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The fact that income or corpus of the trust may be used to satisfy an obligation of support arising under State law shall be disregarded in determining whether a person has an interest in the trust, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454ba7b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such use is discretionary, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454ba7b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such use is pursuant to the provisions of any State law substantially equivalent to the Uniform Gifts to Minors Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454ba7ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2652/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the term “executor” has the meaning given such term by section 2203.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id454ba7bb-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIV/s1431/a"},"text":"Pub. L. 99–514, title XIV, § 1431(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2726"},"text":"100 Stat. 2726","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1014/g/6"},"text":"Pub. L. 100–647, title I, § 1014(g)(6)","children":[],"tail":", (8), (9), (14), (20), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3565-3567"},"text":"102 Stat. 3565–3567","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIII/s1305/b"},"text":"Pub. L. 105–34, title XIII, § 1305(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1040"},"text":"111 Stat. 1040","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tVI/s6013/a/3"},"text":"Pub. L. 105–206, title VI, § 6013(a)(3)","children":[],"tail":", (4)(A), "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/819"},"text":"112 Stat. 819","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id454ba7bc-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id454ba7bd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id454ba7be-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6013/a/4/A"},"text":"Pub. L. 105–206, § 6013(a)(4)(A)","children":[],"tail":", struck out at end “Such term shall not include any trust during any period the trust is treated as part of an estate under section 645.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6013/a/3"},"text":"Pub. L. 105–206, § 6013(a)(3)","children":[],"tail":", substituted “section 645” for “section 646”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" inserted at end “Such term shall not include any trust during any period the trust is treated as part of an estate under section 646.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1014/g/9"},"text":"Pub. L. 100–647, § 1014(g)(9)","children":[],"tail":", substituted “any property” for “a transfer of a kind” in subpars. (A) and (B) and inserted at end “An individual shall be treated as transferring any property with respect to which such individual is the transferor.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1014/g/14"},"text":"Pub. L. 100–647, § 1014(g)(14)","children":[],"tail":", substituted “any trust” for “any property” in subpars. (A) and (B) and “may elect to treat all of the property in such trust” for “may elect to treat such property” in closing provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1014/g/8"},"text":"Pub. L. 100–647, § 1014(g)(8)","children":[],"tail":", struck out “nominal” before “interests” in heading and substituted “any tax” for “the tax” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1014/g/6"},"text":"Pub. L. 100–647, § 1014(g)(6)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1014/g/20"},"text":"Pub. L. 100–647, § 1014(g)(20)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id454ba7bf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id454ba7c0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Taxpayer Relief Act of 1997, "},{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6024"},"text":"section 6024 of Pub. L. 105–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id454ba7c1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" applicable with respect to estates of decedents dying after "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1305/d"},"text":"section 1305(d) of Pub. L. 105–34","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s645"},"text":"section 645 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id454ba7c2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id454ba7c3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to generation-skipping transfers (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s2611"},"text":"section 2611 of this title","children":[],"tail":") made after "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1433"},"text":"section 1433 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2601"},"text":"section 2601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
