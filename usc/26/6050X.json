{"tag":"section","attrib":{"id":"id46818fc1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050X"},"text":null,"children":[{"tag":"num","attrib":{"value":"6050X"},"text":"§ 6050X.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information with respect to certain fines, penalties, and other amounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46818fc2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050X/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46818fc3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050X/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The appropriate official of any government or any entity described in section 162(f)(5) which is involved in a suit or agreement described in paragraph (2) shall make a return in such form as determined by the Secretary setting forth—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46818fc4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050X/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount required to be paid as a result of the suit or agreement to which paragraph (1) of section 162(f) applies,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46818fc5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050X/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount required to be paid as a result of the suit or agreement which constitutes restitution or remediation of property, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46818fc6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050X/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount required to be paid as a result of the suit or agreement for the purpose of coming into compliance with any law which was violated or involved in the investigation or inquiry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46818fc7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050X/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suit or agreement described","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46818fc8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050X/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A suit or agreement is described in this paragraph if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46818fc9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050X/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" it is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id46818fca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050X/a/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a suit with respect to a violation of any law over which the government or entity has authority and with respect to which there has been a court order, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id46818fcb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050X/a/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement which is entered into with respect to a violation of any law over which the government or entity has authority, or with respect to an investigation or inquiry by the government or entity into the potential violation of any law over which such government or entity has authority, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46818fcc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050X/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount involved in all court orders and agreements with respect to the violation, investigation, or inquiry is $600 or more.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46818fcd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050X/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of reporting threshold","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall adjust the $600 amount in subparagraph (A)(ii) as necessary in order to ensure the efficient administration of the internal revenue laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46818fce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050X/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time of filing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The return required under this subsection shall be filed at the time the agreement is entered into, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46818fcf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050X/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements to be furnished to individuals involved in the settlement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every person required to make a return under subsection (a) shall furnish to each person who is a party to the suit or agreement a written statement showing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46818fd0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050X/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the government or entity, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46818fd1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050X/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information supplied to the Secretary under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The written statement required under the preceding sentence shall be furnished to the person at the same time the government or entity provides the Secretary with the information required under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46818fd2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050X/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate official defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “appropriate official” means the officer or employee having control of the suit, investigation, or inquiry or the person appropriately designated for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46818fd3-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13306/b/1"},"text":"Pub. L. 115–97, title I, § 13306(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2128"},"text":"131 Stat. 2128","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46818fd4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46818fd5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46818fd6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13306/b/3"},"text":"Pub. L. 115–97, title I, § 13306(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2129"},"text":"131 Stat. 2129","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/97/tI/s13306/b/3"},"text":"“The amendments made by this subsection [enacting this section] shall apply to amounts paid or incurred on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":"], except that such amendments shall not apply to amounts paid or incurred under any binding order or agreement entered into before such date. Such exception shall not apply to an order or agreement requiring court approval unless the approval was obtained before such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
