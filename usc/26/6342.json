{"tag":"section","attrib":{"id":"id46d50606-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6342"},"text":null,"children":[{"tag":"num","attrib":{"value":"6342"},"text":"§ 6342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of proceeds of levy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46d50607-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6342/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of liability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any money realized by proceedings under this subchapter (whether by seizure, by surrender under section 6332 (except pursuant to subsection (d)(2) thereof), or by sale of seized property) or by sale of property redeemed by the United States (if the interest of the United States in such property was a lien arising under the provisions of this title) shall be applied as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46d50608-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6342/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expense of levy and sale","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"First, against the expenses of the proceedings;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d50609-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6342/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific tax liability on seized property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the property seized and sold is subject to a tax imposed by any internal revenue law which has not been paid, the amount remaining after applying paragraph (1) shall then be applied against such tax liability (and, if such tax was not previously assessed, it shall then be assessed);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d5060a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6342/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of delinquent taxpayer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount, if any, remaining after applying paragraphs (1) and (2) shall then be applied against the liability in respect of which the levy was made or the sale was conducted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46d5060b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6342/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surplus proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any surplus proceeds remaining after the application of subsection (a) shall, upon application and satisfactory proof in support thereof, be credited or refunded by the Secretary to the person or persons legally entitled thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46d5060c-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/789"},"text":"68A Stat. 789","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/719/tI/s104/h"},"text":"Pub. L. 89–719, title I, § 104(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1137"},"text":"80 Stat. 1137","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/284"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(284)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1198"},"text":"132 Stat. 1198","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46d5060d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46d5060e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46d5060f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “subsection (d)(2)” for “subsection (c)(2)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/719"},"text":"Pub. L. 89–719","children":[],"tail":" inserted in introductory provisions, references to an exception in the case of surrender under section 6332(c)(2) and to sale of property redeemed by the United States if the interest of the United States in such property was a lien arising under the provisions of this title, struck out “under this subchapter” after “proceedings” in par. (1), and inserted “or the sale was conducted” after “levy was made” in par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46d50610-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46d50611-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/719"},"text":"Pub. L. 89–719","children":[],"tail":" applicable after "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", regardless of when title or lien of United States arose or when lien or interest of another person was acquired, with certain exceptions, see section 114(a)–(c) of "},{"tag":"ref","attrib":{"href":"/us/pl/89/719"},"text":"Pub. L. 89–719","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6323"},"text":"section 6323 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
