{"tag":"section","attrib":{"id":"id4630892e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5215"},"text":null,"children":[{"tag":"num","attrib":{"value":"5215"},"text":"§ 5215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of tax determined distilled spirits to bonded premises","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4630892f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5215/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under such regulations as the Secretary may prescribe, distilled spirits on which tax has been determined or paid may be returned to the bonded premises of a distilled spirits plant but only for destruction, denaturation, redistillation, reconditioning, or rebottling.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46308930-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5215/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of chapter to distilled spirits returned to a distilled spirits plant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All provisions of this chapter applicable to distilled spirits in bond shall be applicable to distilled spirits returned to bonded premises under the provisions of this section on such return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46308931-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5215/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of bottled distilled spirits for relabeling and reclosing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under such regulations as the Secretary shall prescribe, bottled distilled spirits withdrawn from bonded premises may be returned to bonded premises for relabeling or reclosing, and the tax under section 5001 shall not again be collected on such spirits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46308932-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5215/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions relating to the abatement, credit, or refund of tax on distilled spirits returned to a distilled spirits plant under this section, see section 5008(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46308933-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1364"},"text":"72 Stat. 1364","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tVIII/s805/c"},"text":"Pub. L. 89–44, title VIII, § 805(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/161"},"text":"79 Stat. 161","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/659/s2/c"},"text":"Pub. L. 91–659, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-08"},"text":"Jan. 8, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1964"},"text":"84 Stat. 1964","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/176/s2/a"},"text":"Pub. L. 95–176, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-14"},"text":"Nov. 14, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1363"},"text":"91 Stat. 1363","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/29"},"text":"Pub. L. 96–39, title VIII, § 807(a)(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/285"},"text":"93 Stat. 285","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s454/c/7"},"text":"Pub. L. 98–369, div. A, title IV, § 454(c)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/821"},"text":"98 Stat. 821","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46308934-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46308935-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46308936-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5215, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/640"},"text":"68A Stat. 640","children":[],"tail":", related to exemption of distillers of fruit brandy from certain requirements, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See sections 5201(c), 5312(a), (c), 5373(a) and 5562 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46308937-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “reclosing” for “restamping” in heading and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" amended section generally thereby authorizing the return of distilled spirits to the bonded premises of the distilled spirits plant for certain enumerated purposes except mere storage."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/176"},"text":"Pub. L. 95–176","children":[],"tail":" reenacted existing provisions but struck out last sentence relating to applicability of chapter to distilled spirits returned to bonded premises, which was covered in subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/176"},"text":"Pub. L. 95–176","children":[],"tail":" added subsecs. (b) and (c) and redesignated former subsec. (b) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/176"},"text":"Pub. L. 95–176","children":[],"tail":" redesignated last sentence of former subsec. (a) as subsec. (d) and inserted introductory phrase “Except as otherwise provided in this section,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/176"},"text":"Pub. L. 95–176","children":[],"tail":" redesignated former subsec. (b) as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/659/s2/c/1"},"text":"Pub. L. 91–659, § 2(c)(1)","children":[],"tail":", struck out requirements that withdrawn distilled spirits be returned when found unsuitable, in bulk containers, before processing and before removal from the original container and permitted return of withdrawn distilled spirits other than products to which any alcoholic ingredients other than such distilled spirits have been added and made additional authorization under section 5234(a)(1)(B) for mingling returned distilled spirits."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/659/s2/c/2"},"text":"Pub. L. 91–659, § 2(c)(2)","children":[],"tail":", (3), repealed subsec. (b) which provided for definition of “original container in which such distilled spirits were withdrawn from bonded premises” in the case of distilled spirits withdrawn by pipeline. Former subsec. (c) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" inserted reference to destruction to redistillation, denaturation, and mingling in second sentence on list of options which might be used in disposing of returned distilled spirits."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46308938-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46308939-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-07-01"},"text":"July 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s456/b"},"text":"section 456(b) of Pub. L. 98–369","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5101"},"text":"section 5101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4630893a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-01-01"},"text":"Jan. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/s810"},"text":"section 810 of Pub. L. 96–39","children":[],"tail":", set out as a note under "},{"ta