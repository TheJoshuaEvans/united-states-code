{"tag":"section","attrib":{"id":"id4501a5ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397D"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397D"},"text":"§ 1397D.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified zone property defined","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4501a5cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397D/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4501a5d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397D/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified zone property” means any property to which section 168 applies (or would apply but for section 179) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4501a5d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397D/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such property was acquired by the taxpayer by purchase (as defined in section 179(d)(2)) after the date on which the designation of the empowerment zone took effect,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4501a5d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397D/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the original use of which in an empowerment zone commences with the taxpayer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4501a5d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397D/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially all of the use of which is in an empowerment zone and is in the active conduct of a qualified business by the taxpayer in such zone.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a5d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397D/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for substantial renovations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any property which is substantially renovated by the taxpayer, the requirements of subparagraphs (A) and (B) of paragraph (1) shall be treated as satisfied. For purposes of the preceding sentence, property shall be treated as substantially renovated by the taxpayer if, during any 24-month period beginning after the date on which the designation of the empowerment zone took effect, additions to basis with respect to such property in the hands of the taxpayer exceed the greater of (i) an amount equal to the adjusted basis at the beginning of such 24-month period in the hands of the taxpayer, or (ii) $5,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4501a5d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397D/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for sale-leasebacks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a)(1)(B), if property is sold and leased back by the taxpayer within 3 months after the date such property was originally placed in service, such property shall be treated as originally placed in service not earlier than the date on which such property is used under the leaseback.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4501a5d6-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13301/a"},"text":"Pub. L. 103–66, title XIII, § 13301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/554"},"text":"107 Stat. 554","children":[],"tail":", § 1397C; renumbered § 1397D, "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s116/a/2"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 116(a)(2)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–602.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4501a5d7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4501a5d8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4501a5d9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1397D was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1397F"},"text":"section 1397F of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4501a5da-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1397C"},"text":"section 1397C of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
