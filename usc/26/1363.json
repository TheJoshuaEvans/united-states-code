{"tag":"section","attrib":{"id":"id44f10429-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363"},"text":null,"children":[{"tag":"num","attrib":{"value":"1363"},"text":"§ 1363.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of election on corporation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44f1042a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subchapter, an S corporation shall not be subject to the taxes imposed by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f1042b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of corporation’s taxable income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The taxable income of an S corporation shall be computed in the same manner as in the case of an individual, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f1042c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the items described in section 1366(a)(1)(A) shall be separately stated,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f1042d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deductions referred to in section 703(a)(2) shall not be allowed to the corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f1042e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 248 shall apply, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f1042f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 291 shall apply if the S corporation (or any predecessor) was a C corporation for any of the 3 immediately preceding taxable years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f10430-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elections of the S corporation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f10431-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), any election affecting the computation of items derived from an S corporation shall be made by the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f10432-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an S corporation, elections under the following provisions shall be made by each shareholder separately—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44f10433-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 617 (relating to deduction and recapture of certain mining exploration expenditures), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f10434-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 901 (relating to taxes of foreign countries and possessions of the United States).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f10435-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recapture of LIFO benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f10436-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44f10437-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an S corporation was a C corporation for the last taxable year before the first taxable year for which the election under section 1362(a) was effective, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f10438-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the corporation inventoried goods under the LIFO method for such last taxable year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the LIFO recapture amount shall be included in the gross income of the corporation for such last taxable year (and appropriate adjustments to the basis of inventory shall be made to take into account the amount included in gross income under this paragraph).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f10439-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional tax payable in installments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44f1043a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any increase in the tax imposed by this chapter by reason of this subsection shall be payable in 4 equal installments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f1043b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date for payment of installments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The first installment under subparagraph (A) shall be paid on or before the due date (determined without regard to extensions) for the return of the tax imposed by this chapter for the last taxable year for which the corporation was a C corporation and the 3 succeeding installments shall be paid on or before the due date (as so determined) for the corporation’s return for the 3 succeeding taxable years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f1043c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No interest for period of extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 6601(b), for purposes of section 6601, the date prescribed for the payment of each installment under this paragraph shall be determined under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f1043d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" LIFO recapture amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “LIFO recapture amount” means the amount (if any) by which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44f1043e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inventory amount of the inventory asset under the first-in, first-out method authorized by section 471, exceeds","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f1043f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inventory amount of such assets under the LIFO method.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of the preceding sentence, inventory amounts shall be determined as of the close of the last taxable year referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f10440-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44f10441-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" LIFO method","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “LIFO method” means the method authorized by section 472.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f10442-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory assets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “inventory assets” means stock in trade of the corporation, or other property of a kind which would properly be included in the inventory of the corporation if on hand at the close of the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f10443-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of determining inventory amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The inventory amount of assets under a method authorized by section 471 shall be determined—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44f10444-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/d/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the corporation uses the retail method of valuing inventories under section 472, by using such method, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44f10445-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/d/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if clause (i) does not apply, by using cost or market, whichever is lower.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f10446-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/d/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Not treated as member of affiliated group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in regulations, the corporation referred to in paragraph (1) shall not be treated as a member of an affiliated group with respect to the amount included in gross income under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f10447-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1363/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sections 1367(a)(2)(D) and 1371(c)(1) shall not apply with respect to any increase in the tax imposed by reason of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44f10448-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/354/s2"},"text":"Pub. L. 97–354, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"Oct. 19, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1676"},"text":"96 Stat. 1676","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII/s721/a"},"text":"Pub. L. 98–369, div. A, title VII, § 721(a)","children":[],"tail":", (b)(1), (p), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/966"},"text":"98 Stat. 966","children":[],"tail":", 970; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tV/s511/d/2/C"},"text":"Pub. L. 99–514, title V, § 511(d)(2)(C)","children":[],"tail":", title VI, § 632(b), title VII, § 701(e)(4)(J), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2249"},"text":"100 Stat. 2249","children":[],"tail":", 2277, 2343; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10227/a"},"text":"Pub. L. 100–203, title X, § 10227(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-416"},"text":"101 Stat. 1330–416","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/f/7"},"text":"Pub. L. 100–647, title I, § 1006(f)(7)","children":[],"tail":", title II, § 2004(n), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3407"},"text":"102 Stat. 3407","children":[],"tail":", 3608; "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s411/a"},"text":"Pub. L. 109–135, title IV, § 411(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2636"},"text":"119 Stat. 2636","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44f10449-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44f1044a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44f1044b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/f/7"},"text":"Pub. L. 100–647, § 1006(f)(7)","children":[],"tail":", struck out subsec. (d) which related to distributions of appreciated property."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/n"},"text":"Pub. L. 100–647, § 2004(n)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/f/7"},"text":"Pub. L. 100–647, § 1006(f)(7)","children":[],"tail":", struck out subsec. (e) which provided that subsec. (d) not apply to reorganizations, etc."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" added subsec. (d) relating to recapture of LIFO benefits."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s701/e/4/J"},"text":"Pub. L. 99–514, § 701(e)(4)(J)","children":[],"tail":", struck out “and in section 58(d)” after “this subchapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s511/d/2/C"},"text":"Pub. L. 99–514, § 511(d)(2)(C)","children":[],"tail":", redesignated subpars. (B) and (C) as (A) and (B), respectively, and struck out former subpar. (A) which read as follows: “section 163(d) (relating to limitation on interest on investment indebtedness),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s632/b"},"text":"Pub. L. 99–514, § 632(b)","children":[],"tail":", amended subsec. (e) generally, substituting “reorganizations, etc.” for “complete liquidations and reorganizations”, in heading and in text struck out reference to property in complete liquidation of the corporation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s721/p"},"text":"Pub. L. 98–369, § 721(p)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s721/b/1"},"text":"Pub. L. 98–369, § 721(b)(1)","children":[],"tail":", redesignated subpars. (B) to (D) as (A) to (C), respectively, and struck out subpar. (A) which provided “subsection (b)(5) or (d)(4) of section 108 (relating to income from discharge of indebtedness),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s721/a/2"},"text":"Pub. L. 98–369, § 721(a)(2)","children":[],"tail":", substituted “Except as provided in subsection (e), if” for “If”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s721/a/1"},"text":"Pub. L. 98–369, § 721(a)(1)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44f1044c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44f1044d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s411/b"},"text":"Pub. L. 109–135, title IV, § 411(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2636"},"text":"119 Stat. 2636","children":[],"tail":", provided that: "},{"tag":"quotedContent",