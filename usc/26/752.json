{"tag":"section","attrib":{"id":"id4404f74c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s752"},"text":null,"children":[{"tag":"num","attrib":{"value":"752"},"text":"§ 752.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain liabilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4404f74d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s752/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in partner’s liabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any increase in a partner’s share of the liabilities of a partnership, or any increase in a partner’s individual liabilities by reason of the assumption by such partner of partnership liabilities, shall be considered as a contribution of money by such partner to the partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4404f74e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s752/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decrease in partner’s liabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any decrease in a partner’s share of the liabilities of a partnership, or any decrease in a partner’s individual liabilities by reason of the assumption by the partnership of such individual liabilities, shall be considered as a distribution of money to the partner by the partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4404f74f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s752/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability to which property is subject","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, a liability to which property is subject shall, to the extent of the fair market value of such property, be considered as a liability of the owner of the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4404f750-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s752/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale or exchange of an interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a sale or exchange of an interest in a partnership, liabilities shall be treated in the same manner as liabilities in connection with the sale or exchange of property not associated with partnerships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4404f751-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/251"},"text":"68A Stat. 251","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4404f752-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4404f753-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4404f754-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Overruling of Raphan Case","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s79"},"text":"Pub. L. 98–369, div. A, title I, § 79","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/597"},"text":"98 Stat. 597","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 752 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] (and the regulations prescribed thereunder) shall be applied without regard to the result reached in the case of Raphan vs the United States, 3 Cl. Ct. 457 (1983).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In amending the regulations prescribed under section 752 of such Code to reflect subsection (a), the Secretary of the Treasury or his delegate shall prescribe regulations relating to liabilities, including the treatment of guarantees, assumptions, indemnity agreements, and similar arrangements.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
