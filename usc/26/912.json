{"tag":"section","attrib":{"id":"id447767d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s912"},"text":null,"children":[{"tag":"num","attrib":{"value":"912"},"text":"§ 912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for certain allowances","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The following items shall not be included in gross income, and shall be exempt from taxation under this subtitle:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id447767d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s912/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign areas allowances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of civilian officers and employees of the Government of the United States, amounts received as allowances or otherwise (but not amounts received as post differentials) under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id447767d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s912/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 9 of title I of the Foreign Service Act of 1980,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id447767da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s912/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 4 of the Central Intelligence Agency Act of 1949, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3505"},"text":"50 U.S.C. 3505","children":[],"tail":"),"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id447767db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s912/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title II of the Overseas Differentials and Allowances Act, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id447767dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s912/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (e) or (f) of the first section of the Administrative Expenses Act of 1946, as amended, or section 22 of such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id447767dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s912/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-of-living allowances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of civilian officers or employees of the Government of the United States stationed outside the continental United States (other than Alaska), amounts (other than amounts received under title II of the Overseas Differentials and Allowances Act) received as cost-of-living allowances in accordance with regulations approved by the President (or in the case of judicial officers or employees of the United States, in accordance with rules similar to such regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id447767de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s912/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peace Corps allowances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an individual who is a volunteer or volunteer leader within the meaning of the Peace Corps Act and members of his family, amounts received as allowances under section 5 or 6 of the Peace Corps Act other than amounts received as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id447767df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s912/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" termination payments under section 5(c) or section 6(1) of such Act,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id447767e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s912/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leave allowances,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id447767e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s912/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such individual is a volunteer leader training in the United States, allowances to members of his family, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id447767e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s912/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such portion of living allowances as the President may determine under the Peace Corps Act as constituting basic compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id447767e3-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/290"},"text":"68A Stat. 290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/707/tV/s523/a"},"text":"Pub. L. 86–707, title V, § 523(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-06"},"text":"Sept. 6, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/802"},"text":"74 Stat. 802","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/293/tII/s201/a"},"text":"Pub. L. 87–293, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-22"},"text":"Sept. 22, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/625"},"text":"75 Stat. 625","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII/s2206/e/3"},"text":"Pub. L. 96–465, title II, § 2206(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2163"},"text":"94 Stat. 2163","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6137/a"},"text":"Pub. L. 100–647, title VI, § 6137(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3723"},"text":"102 Stat. 3723","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/161"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(161)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1192"},"text":"132 Stat. 1192","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id447767e4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id447767e5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id447767e6-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Service Act of 1980, referred to in par. (1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465"},"text":"Pub. L. 96–465","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2071"},"text":"94 Stat. 2071","children":[],"tail":". Chapter 9 of title I of the Foreign Service Act of 1980 is classified generally to subchapter IX (§ 4081 et seq.) of chapter 52 of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title II of the Overseas Differentials and Allowances Act, referred to in pars. (1)(C) and (2), was title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/707"},"text":"Pub. L. 86–707","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-06"},"text":"Sept. 6, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/793"},"text":"74 Stat. 793","children":[],"tail":", which was repealed and reenacted as sections 5922 to 5925 of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 1(e) and (f) and 22 of the Administrative Expenses Act of 1946, referred to in par. (1)(D), were repealed and the provisions thereof reenacted as sections 5726(b), 5727(b) to (e), and 5913 of Title 5, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Peace Corps Act, referred to in par. (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/293"},"text":"Pub. L. 87–293","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-22"},"text":"Sept. 22, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/612"},"text":"75 Stat. 612","children":[],"tail":", which is classified principally to chapter 34 (§ 2501 et seq.) of Title 22, Foreign Relations and Intercourse. Sections 5 and 6 of that act are classified to sections 2504 and 2505 of Title 22. For complete classification of this act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2501"},"text":"section 2501 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id447767e7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3505"},"text":"50 U.S.C. 3505","children":[],"tail":")” for “(50 U.S.C., sec. 403e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" inserted “(or in the case of judicial officers or employees of the United States, in accordance with rules similar to such regulations)” after “President”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Par. (1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465"},"text":"Pub. L. 96–465","children":[],"tail":" substituted reference to chapter 9 of title I of the Foreign Service Act of 1980 for reference to title IX of the Foreign Service Act of 1946."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1961—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/293"},"text":"Pub. L. 87–293","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/707"},"text":"Pub. L. 86–707","children":[],"tail":" exempted foreign areas allowances received under section 4 of the Central Intelligence Agency Act of 1949, title II of the Overseas Differentials and Allowances Act, subsection (e) or (f) of the first section of the Administrative Expenses Act of 1946, or section 22 of such Act, provided that amounts received as post differentials shall not be exempt and in provisions relating to cost-of-living allowances excluded Alaska from term “continental United States” and amounts received under title II of the Overseas Differentials and Allowances Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id447767e8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id447767e9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6137/b"},"text":"Pub. L. 100–647, title VI, § 6137(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3723"},"text":"102 Stat. 3723","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tVI/s6137/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to allowances received after ","children":[{"tag":"date","attrib":{"date":"1987-10-12"},"text":"October 12, 1987","children":[],"tail":", in taxable years ending after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id447767ea-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465"},"text":"Pub. L. 96–465","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-02-15"},"text":"Feb. 15, 1981","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/s2403"},"text":"section 2403 of Pub. L. 96–465","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id447767eb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1961 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/293/tII/s201/d"},"text":"Pub. L. 87–293, title II, § 201(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-22"},"text":"Sept. 22, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/625"},"text":"75 Stat. 625","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/87/293/tII/s201/d"},"text":"“The amendments made by subsections (a) and (b) of this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1303"},"text":"section 1303 of this title","children":[],"tail":"] shall apply with respect to taxable years ending after "},{"tag":"date","attrib":{"date":"1961-03-01"},"text":"March 1, 1961","children":[],"tail":". The amendment made by subsection (c) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3401"},"text":"section 3401 of this title","children":[],"tail":"] shall apply with respect to remuneration paid after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1961-09-22"},"text":"Sept. 22, 1961","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/293/s201/d"},"text":"Section 201(d) of Pub. L. 87–293","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/89/572/s5/a"},"text":"Pub. L. 89–572, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-13"},"text":"Sept. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/765"},"text":"80 Stat. 765","children":[],"tail":". Such repeal not deemed to affect amendments contained in such provisions, see sections 5(b) of "},{"tag":"ref","attrib":{"href":"/us/pl/89/572"},"text":"Pub. L. 89–572","children":[],"tail":", set out as a note under former "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2515"},"text":"section 2515 of Title 22","children":[],"tail":", Foreign Relations and Intercourse.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id447767ec-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1960 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/707/tV/s523/b"},"text":"Pub. L. 86–707, title V, § 523(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-06"},"text":"Sept. 6, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/802"},"text":"74 Stat. 802","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"“Paragraphs (1) and (2) of section 912 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954], as amended by subsection (a) of this section, shall apply only with respect to amounts received on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1960-09-06"},"text":"Sept. 6, 1960","children":[],"tail":"] in taxable years ending on or after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"repeals","id":"id447767ed-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeals; Amendments and Application of Amendments Unaffected","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/293/s201/a"},"text":"Section 201(a) of Pub. L. 87–293","children":[],"tail":", cited as a credit to this section, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/89/572/s5/a"},"text":"Pub. L. 89–572, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-13"},"text":"Sept. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/765"},"text":"80 Stat. 765","children":[],"tail":". Such repeal not deemed to affect amendments to this section contained in such provisions, and continuation in full force and effect until modified by appropriate authority of all determinations, authorization, regulations, orders, contracts, agreements, and other actions issued undertaken, or entered into under authority of the repealed provisions, see "},{"tag":"ref","attrib":{"href":"/us/pl/89/572/s5/b"},"text":"section 5(b) of Pub. L. 89–572","children":[],"tail":", set out as a note under former "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2515"},"text":"section 2515 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id447767ee-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Treatment of Employees of Panama Canal Commission and Department of Defense","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1232/b"},"text":"Pub. L. 99–514, title XII, § 1232(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2564"},"text":"100 Stat. 2564","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXII/s1232/b"},"text":"“Employees of the Panama Canal Commission and civilian employees of the Defense Department of the United States stationed in Panama may exclude from gross income allowances which are comparable to the allowances excludable under section 912(1) of the Internal Revenue Code of 1986 by employees of the State Department of the United States stationed in Panama. The preceding sentence shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id447767ef-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id447767f0-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Function of determining the portion of living allowances constituting basic compensation for Peace Corps volunteers or volunteer leaders under par. (3) of this section delegated by President to Director of Peace Corps to be performed in consultation with the Secretary of the Treasury, see section 1–104 of Ex. Ord. No. 12137, ","children":[{"tag":"date","attrib":{"date":"1979-05-16"},"text":"May 16, 1979","children":[],"tail":", 44 F.R. 29023, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2501"},"text":"section 2501 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Authority of President under par. (2) of this section delegated to Secretary of Defense with respect to military departments, and to Secretary of Transportation with respect to Coast Guard when it is not operating as a service in the Navy, concerning civilian employees of nonappropriated fund instrumentalities of the armed forces, see section 201 of Ex. Ord. No. 11137, ","children":[{"tag":"date","attrib":{"date":"1964-01-07"},"text":"Jan. 7, 1964","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5921"},"text":"section 5921 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
