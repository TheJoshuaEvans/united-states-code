{"tag":"section","attrib":{"id":"id4618bb35-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002"},"text":null,"children":[{"tag":"num","attrib":{"value":"5002"},"text":"§ 5002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4618bb36-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4618bb37-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distilled spirits plant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “distilled spirits plant” means an establishment which is qualified under subchapter B to perform any distilled spirits operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4618bb38-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distilled spirits operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “distilled spirits operation” means any operation for which qualification is required under subchapter B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4618bb39-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bonded premises","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bonded premises”, when used with respect to distilled spirits, means the premises of a distilled spirits plant, or part thereof, on which distilled spirits operations are authorized to be conducted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4618bb3a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distiller","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “distiller” includes any person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4618bb3b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produces distilled spirits from any source or substance,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4618bb3c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" brews or makes mash, wort, or wash fit for distillation or for the production of distilled spirits (other than the making or using of mash, wort, or wash in the authorized production of wine or beer, or the production of vinegar by fermentation),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4618bb3d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any process separates alcoholic spirits from any fermented substance, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4618bb3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making or keeping mash, wort, or wash, has a still in his possession or use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4618bb3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Processor","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4618bb40-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “processor”, when used with respect to distilled spirits, means any person who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4618bb41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufactures, mixes, or otherwise processes distilled spirits, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4618bb42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufactures any article.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4618bb43-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rectifier, bottler, etc., included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “processor” includes (but is not limited to) a rectifier, bottler, and denaturer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4618bb44-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain operations not treated as processing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In applying paragraph (5), there shall not be taken into account—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4618bb45-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operations as distiller","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any process which is the operation of a distiller.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4618bb46-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mixing of taxpaid spirits for immediate consumption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any mixing (after determination of tax) of distilled spirits for immediate consumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4618bb47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use by apothecaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any process performed by an apothecary with respect to distilled spirits which such apothecary uses exclusively in the preparation or making up of medicines unfit for use for beverage purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4618bb48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Warehouseman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “warehouseman”, when used with respect to distilled spirits, means any person who stores bulk distilled spirits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4618bb49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distilled spirits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “distilled spirits”, “alcoholic spirits”, and “spirits” mean that substance known as ethyl alcohol, ethanol, or spirits of wine in any form (including all dilutions and mixtures thereof from whatever source or by whatever process produced).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4618bb4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bulk distilled spirits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bulk distilled spirits” means distilled spirits in a container having a capacity in excess of 1 wine gallon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4618bb4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proof spirits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “proof spirits” means that liquid which contains one-half its volume of ethyl alcohol of a specific gravity of 0.7939 at 60 degrees Fahrenheit (referring to water at 60 degrees Fahrenheit as unity).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4618bb4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proof gallon","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “proof gallon” means a United States gallon of proof spirits, or the alcoholic equivalent thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4618bb4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Container","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “container”, when used with respect to distilled spirits, means any receptacle, vessel, or form of package, bottle, tank, or pipeline used, or capable of use, for holding, storing, transferring, or conveying distilled spirits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4618bb4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approved container","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “approved container”, when used with respect to distilled spirits, means a container the use of which is authorized by regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4618bb4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Article","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless another meaning is distinctly expressed or manifestly intended, the term “article” means any substance in the manufacture of which denatured distilled spirits are used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4618bb50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “export”, “exported”, and “exportation” include shipments to a possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4618bb51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4618bb52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For definition of manufacturer of stills, see section 5102.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4618bb53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For definition of dealer, see section 5121(c)(3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4618bb54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For definitions of wholesale dealers, see section 5121(c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4618bb55-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For definitions of retail dealers, see section 5122(c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4618bb56-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5002/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For definitions of general application to this title, see chapter 79.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4618bb57-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1315"},"text":"72 Stat. 1315","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tVIII/s807/a"},"text":"Pub. L. 89–44, title VIII, § 807(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/164"},"text":"79 Stat. 164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s805/e"},"text":"Pub. L. 96–39, title VIII, § 805(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/278"},"text":"93 Stat. 278","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tI/s136/c/1"},"text":"Pub. L. 103–465, title I, § 136(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4841"},"text":"108 Stat. 4841","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11125/b/13"},"text":"Pub. L. 109–59, title XI, § 11125(b)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1956"},"text":"119 Stat. 1956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4618bb58-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4618bb59-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4618bb5a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5002, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/597"},"text":"68A Stat. 597","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising subsec. (a)(6), (9), and (11) of this section were contained in prior sections 5213(a)(1) and 5319(1), (2), and (7), ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/639"},"text":"68A Stat. 639","children":[],"tail":", 661, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4618bb5b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11125/b/13/A"},"text":"Pub. L. 109–59, § 11125(b)(13)(A)","children":[],"tail":", substituted “section 5121(c)(3)” for “section 5112(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11125/b/13/B"},"text":"Pub. L. 109–59, § 11125(b)(13)(B)","children":[],"tail":", substituted “section 5121(c)” for “section 5112”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11125/b/13/C"},"text":"Pub. L. 109–59, § 11125(b)(13)(C)","children":[],"tail":", substituted “section 5122(c)” for “section 5122”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(1) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" redesignated pars. (2) to (6) as (1) to (5), respectively, and struck out former par. (1) which provided a cross reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5041/c"},"text":"section 5041(c) of this title","children":[],"tail":" for definition of “wine gallon”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" substituted “distilled spirits operation” for “operation, or any combination of operations, for which qualification is required under such subchapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" added par. (2) and redesignated former par. (2) as (3). Former pa