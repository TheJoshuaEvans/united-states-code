{"tag":"section","attrib":{"id":"id45d3759b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4375"},"text":null,"children":[{"tag":"num","attrib":{"value":"4375"},"text":"§ 4375.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health insurance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45d3759c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4375/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on each specified health insurance policy for each policy year ending after ","children":[{"tag":"date","attrib":{"date":"2012-09-30"},"text":"September 30, 2012","children":[],"tail":", a fee equal to the product of $2 ($1 in the case of policy years ending during fiscal year 2013) multiplied by the average number of lives covered under the policy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d3759d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4375/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fee imposed by subsection (a) shall be paid by the issuer of the policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d3759e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4375/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified health insurance policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d3759f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4375/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, the term “specified health insurance policy” means any accident or health insurance policy (including a policy under a group health plan) issued with respect to individuals residing in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d375a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4375/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for certain policies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “specified health insurance policy” does not include any insurance if substantially all of its coverage is of excepted benefits described in section 9832(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d375a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4375/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of prepaid health coverage arrangements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45d375a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4375/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any arrangement described in subparagraph (B), such arrangement shall be treated as a specified health insurance policy, and the person referred to in such subparagraph shall be treated as the issuer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d375a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4375/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of arrangements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An arrangement is described in this subparagraph if under such arrangement fixed payments or premiums are received as consideration for any person’s agreement to provide or arrange for the provision of accident or health coverage to residents of the United States, regardless of how such coverage is provided or arranged to be provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d375a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4375/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments for increases in health care spending","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any policy year ending in any fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2014-09-30"},"text":"September 30, 2014","children":[],"tail":", the dollar amount in effect under subsection (a) for such policy year shall be equal to the sum of such dollar amount for policy years ending in the previous fiscal year (determined after the application of this subsection), plus an amount equal to the product of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d375a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4375/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dollar amount for policy years ending in the previous fiscal year, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d375a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4375/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage increase in the projected per capita amount of National Health Expenditures, as most recently published by the Secretary before the beginning of the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d375a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4375/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to policy years ending after ","children":[{"tag":"date","attrib":{"date":"2029-09-30"},"text":"September 30, 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d375a8-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6301/e/2/A"},"text":"Pub. L. 111–148, title VI, § 6301(e)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/743"},"text":"124 Stat. 743","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dN/tI/s104/b"},"text":"Pub. L. 116–94, div. N, title I, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3098"},"text":"133 Stat. 3098","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45d375a9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45d375aa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45d375ab-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" substituted “2029” for “2019”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
