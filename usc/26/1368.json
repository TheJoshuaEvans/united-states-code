{"tag":"section","attrib":{"id":"id44f34e95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368"},"text":null,"children":[{"tag":"num","attrib":{"value":"1368"},"text":"§ 1368.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44f34e96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A distribution of property made by an S corporation with respect to its stock to which (but for this subsection) section 301(c) would apply shall be treated in the manner provided in subsection (b) or (c), whichever applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f34e97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" S corporation having no earnings and profits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a distribution described in subsection (a) by an S corporation which has no accumulated earnings and profits—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f34e98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount applied against basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The distribution shall not be included in gross income to the extent that it does not exceed the adjusted basis of the stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f34e99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount in excess of basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount of the distribution exceeds the adjusted basis of the stock, such excess shall be treated as gain from the sale or exchange of property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f34e9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" S corporation having earnings and profits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a distribution described in subsection (a) by an S corporation which has accumulated earnings and profits—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f34e9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accumulated adjustments account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"That portion of the distribution which does not exceed the accumulated adjustments account shall be treated in the manner provided by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f34e9c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dividend","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"That portion of the distribution which remains after the application of paragraph (1) shall be treated as a dividend to the extent it does not exceed the accumulated earnings and profits of the S corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f34e9d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of remainder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any portion of the distribution remaining after the application of paragraph (2) of this subsection shall be treated in the manner provided by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Except to the extent provided in regulations, if the distributions during the taxable year exceed the amount in the accumulated adjustments account at the close of the taxable year, for purposes of this subsection, the balance of such account shall be allocated among such distributions in proportion to their respective sizes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f34e9e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain adjustments taken into account","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsections (b) and (c) shall be applied by taking into account (to the extent proper)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f34e9f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjustments to the basis of the shareholder’s stock described in section 1367, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f34ea0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjustments to the accumulated adjustments account which are required by subsection (e)(1).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In the case of any distribution made during any taxable year, the adjusted basis of the stock shall be determined with regard to the adjustments provided in paragraph (1) of section 1367(a) for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f34ea1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f34ea2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accumulated adjustments account","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44f34ea3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this paragraph, the term “accumulated adjustments account” means an account of the S corporation which is adjusted for the S period in a manner similar to the adjustments under section 1367 (except that no adjustment shall be made for income (and related expenses) which is exempt from tax under this title and the phrase “(but not below zero)” shall be disregarded in section 1367(a)(2)) and no adjustment shall be made for Federal taxes attributable to any taxable year in which the corporation was a C corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f34ea4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of adjustment in the case of redemptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any redemption which is treated as an exchange under section 302(a) or 303(a), the adjustment in the accumulated adjustments account shall be an amount which bears the same ratio to the balance in such account as the number of shares redeemed in such redemption bears to the number of shares of stock in the corporation immediately before such redemption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f34ea5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net loss for year disregarded","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44f34ea6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/e/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying this section to distributions made during any taxable year, the amount in the accumulated adjustments account as of the close of such taxable year shall be determined without regard to any net negative adjustment for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44f34ea7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/e/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net negative adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of clause (i), the term “net negative adjustment” means, with respect to any taxable year, the excess (if any) of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id44f34ea8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/e/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reductions in the account for the taxable year (other than for distributions), over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44f34ea9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/e/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the increases in such account for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f34eaa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" S period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “S period” means the most recent continuous period during which the corporation has been an S corporation. Such period shall not include any taxable year beginning before ","children":[{"tag":"date","attrib":{"date":"1983-01-01"},"text":"January 1, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f34eab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to distribute earnings first","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44f34eac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An S corporation may, with the consent of all of its affected shareholders, elect to have paragraph (1) of subsection (c) not apply to all distributions made during the taxable year for which the election is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f34ead-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affected shareholder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the term “affected shareholder” means any shareholder to whom a distribution is made by the S corporation during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f34eae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restricted bank director stock","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a director receives a distribution (not in part or full payment in exchange for stock) from an S corporation with respect to any restricted bank director stock (as defined in section 1361(f)), the amount of such distribution—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f34eaf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be includible in gross income of the director, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f34eb0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1368/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be deductible by the corporation for the taxable year of such corporation in which or with which ends the taxable year in which such amount is included in the gross income of the director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44f34eb1-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/354/s2"},"text":"Pub. L. 97–354, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"Oct. 19, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1680"},"text":"96 Stat. 1680","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tIII/s305/d/2"},"text":"Pub. L. 97–448, title III, § 305(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2399"},"text":"96 Stat. 2399","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII/s721/r"},"text":"Pub. L. 98–369, div. A, title VII, § 721(r)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/970"},"text":"98 Stat. 970","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1879/m/1/B"},"text":"Pub. L. 99–514, title XVIII, § 1879(m)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2910"},"text":"100 Stat. 2910","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1309/a/2"},"text":"Pub. L. 104–188, title I, § 1309(a)(2)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1783"},"text":"110 Stat. 1783","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/28/tVIII/s8232/b"},"text":"Pub. L. 110–28, title VIII, § 8232(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-25"},"text":"May 25, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/197"},"text":"121 Stat. 197","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/193"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(193)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1193"},"text":"132 Stat. 1193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44f34eb2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44f34eb3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44f34eb4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “is included” for “in included”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28"},"text":"Pub. L. 110–28","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1309/a/2"},"text":"Pub. L. 104–188, § 1309(a)(2)","children":[],"tail":", inserted at end “In the case of any distribution made during any taxable year, the adjusted basis of the stock shall be determined with regard to the adjustments provided in paragraph (1) of section 1367(a) for the taxable year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1309/c"},"text":"Pub. L. 104–188, § 1309(c)","children":[],"tail":", substituted “as otherwise provided in this paragraph” for “as provided in subparagraph (B)” and “section 1367(a)(2)” for “section 1367(b)(2)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1309/b"},"text":"Pub. L. 104–188, § 1309(b)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (e)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" inserted “and no adjustment shall be made for Federal taxes attributable to any taxable year in which the corporation was a C corporation” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s721/r/2"},"text":"Pub. L. 98–369, § 721(r)(2)","children":[],"tail":", inserted “Except to the extent provided in regulations, if the distributions during the taxable year exceed the amount in the accumulated adjustments account at the close of the taxable year, for purposes of this subsection, the balance of such account shall be allocated among such distributions in proportion to their respective sizes.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s721/r/1"},"text":"Pub. L. 98–369, § 721(r)(1)","children":[],"tail":", substituted “(except that no adjustment shall be made for income (and related expenses) which is exempt from tax under this title and the phrase ‘(but not below zero)’ shall be disregarded in section 1367(b)(2)(A))” for “(except that no adjustment shall be made for income which is exempt from tax under this title and no adjustment shall be made for any expense not deductible in computing the corporation’s taxable income and not properly chargeable to capital account)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448"},"text":"Pub. L. 97–448","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44f34eb5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44f34eb6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28"},"text":"Pub. L. 110–28","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2006-12-31"},"text":"Dec. 31, 2006","children":[],"tail":", with special rule for treatment as second class of stock, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/28/s8232/c"},"text":"section 8232(c) of Pub. L. 110–28","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1361"},"text":"section 1361 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44f34eb7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1996-12-31"},"text":"Dec. 31, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1317/a"},"text":"section 1317(a) of Pub. L. 104–188","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s641"},"text":"section 641 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44f34eb8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attri