"attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11125/b/20/A"},"text":"Pub. L. 109–59, § 11125(b)(20)(A)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5142"},"text":"section 5142 of this title","children":[],"tail":" as this section and transferred section to this subchapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11125/b/20/B"},"text":"Pub. L. 109–59, § 11125(b)(20)(B)","children":[],"tail":", struck out “(except the tax imposed by section 5131)” before “until he has paid” in subsec. (a) and before “shall be imposed” in subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11125/b/20/A"},"text":"Pub. L. 109–59, § 11125(b)(20)(A)","children":[],"tail":", substituted “this subchapter” for “this part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11125/b/20/A"},"text":"Pub. L. 109–59, § 11125(b)(20)(A)","children":[],"tail":", substituted “this subchapter” for “this part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted provisions under which the special taxes would be paid on the basis of a return for provisions under which the special taxes were paid by stamps denoting the tax."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id464d11e6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464d11e7-3a70-11f1-a967-d35dac11796a"},"t