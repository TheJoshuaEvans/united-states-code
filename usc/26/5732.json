{"tag":"section","attrib":{"id":"id464d11db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5732"},"text":null,"children":[{"tag":"num","attrib":{"value":"5732"},"text":"§ 5732.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id464d11dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5732/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition precedent to carrying on business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall be engaged in or carry on any trade or business subject to tax under this subchapter until he has paid the special tax therefor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464d11dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5732/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All special taxes under this subchapter shall be imposed as of on the first day of July in each year, or on commencing any trade or business on which such tax is imposed. In the former case the tax shall be reckoned for 1 year, and in the latter case it shall be reckoned proportionately, from the first day of the month in which the liability to a special tax commenced, to and including the 30th day of June following.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464d11de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5732/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" How paid","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id464d11df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5732/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment by return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The special taxes imposed by this subchapter shall be paid on the basis of a return under such regulations as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464d11e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5732/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stamp denoting payment of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After receiving a properly executed return and remittance of any special tax imposed by this subchapter, the Secretary shall issue to the taxpayer an appropriate stamp as a receipt denoting payment of the tax. This paragraph shall not apply in the case of a return covering liability for a past period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id464d11e1-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1346"},"text":"72 Stat. 1346","children":[],"tail":", § 5142; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1905/a/12"},"text":"Pub. L. 94–455, title XIX, § 1905(a)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1