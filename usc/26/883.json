{"tag":"section","attrib":{"id":"id44586e1f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s883"},"text":null,"children":[{"tag":"num","attrib":{"value":"883"},"text":"§ 883.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions from gross income","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44586e20-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s883/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income of foreign corporations from ships and aircraft","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following items shall not be included in gross income of a foreign corporation, and shall be exempt from taxation under this subtitle:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44586e21-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s883/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ships operated by certain foreign corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross income derived by a corporation organized in a foreign country from the international operation of a ship or ships if such foreign country grants an equivalent exemption to corporations organized in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44586e22-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s883/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aircraft operated by certain foreign corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross income derived by a corporation organized in a foreign country from the international operation of aircraft if such foreign country grants an equivalent exemption to corporations organized in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44586e23-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s883/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Railroad rolling stock of foreign corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Earnings derived from payments by a common carrier for the use on a temporary basis (not expected to exceed a total of 90 days in any taxable year) of railroad rolling stock owned by a corporation of a foreign country which grants an equivalent exemption to corporations organized in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44586e24-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s883/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rules of paragraphs (6), (7), and (8) of section 872(b) shall apply for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44586e25-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s883/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for countries which tax on residence basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, there shall not be taken into account any failure of a foreign country to grant an exemption to a corporation organized in the United States if such corporation is subject to tax by such foreign country on a residence basis pursuant to provisions of foreign law which meets such standards (if any) as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44586e26-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s883/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Earnings derived from communications satellite system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The earnings derived from the ownership or operation of a communications satellite system by a foreign entity designated by a foreign government to participate in such ownership or operation shall be exempt from taxation under this subtitle, if the United States, through its designated entity, participates in such system pursuant to the Communications Satellite Act of 1962 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s701"},"text":"47 U.S.C. 701","children":[],"tail":" and following)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44586e27-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s883/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain foreign corporations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44586e28-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s883/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) or (2) of subsection (a) (as the case may be) shall not apply to any foreign corporation if 50 percent or more of the value of the stock of such corporation is owned by individuals who are not residents of such foreign country or another foreign country meeting the requirements of such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44586e29-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s883/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of controlled foreign corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to any foreign corporation which is a controlled foreign corporation (as defined in section 957(a)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44586e2a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s883/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for publicly traded corporations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44586e2b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s883/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to any corporation which is organized in a foreign country meeting the requirements of paragraph (1) or (2) of subsection (a) (as the case may be) and the stock of which is primarily and regularly traded on an established securities market in such foreign country, another foreign country meeting the requirements of such paragraph, or the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44586e2c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s883/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of stock owned by publicly traded corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any stock in another corporation which is owned (directly or indirectly) by a corporation meeting the requirements of subparagraph (A) shall be treated as owned by individuals who are residents of the foreign country in which the corporation meeting the requirements of subparagraph (A) is organized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44586e2d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s883/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stock ownership through entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), stock owned (directly or indirectly) by or for a corporation, partnership, trust, or estate shall be treated as being owned proportionately by its shareholders, partners, or beneficiaries. Stock considered to be owned by a person by reason of the application of the preceding sentence shall, for purposes of applying such sentence, be treated as actually owned by such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44586e2e-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/283"},"text":"68A Stat. 283","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/622/s1/a"},"text":"Pub. L. 90–622, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1311"},"text":"82 Stat. 1311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/164/s6/a"},"text":"Pub. L. 94–164, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-23"},"text":"Dec. 23, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/975"},"text":"89 Stat. 975","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1212/c/3"},"text":"Pub. L. 99–514, title XII, § 1212(c)(3)","children":[],"tail":"–(5), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2538"},"text":"100 Stat. 2538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/e/1"},"text":"Pub. L. 100–647, title I, § 1012(e)(1)","children":[],"tail":", (2)(A), (5), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3499"},"text":"102 Stat. 3499","children":[],"tail":", 3500; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7811/i/8/D"},"text":"Pub. L. 101–239, title VII, § 7811(i)(8)(D)","children":[],"tail":", (10), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2411"},"text":"103 Stat. 2411","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIV/s419/b"},"text":"Pub. L. 108–357, title IV, § 419(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1513"},"text":"118 Stat. 1513","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44586e2f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44586e30-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id44586e31-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Communications Satellite Act of 1962, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/624"},"text":"Pub. L. 87–624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-08-31"},"text":"Aug. 31, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/419"},"text":"76 Stat. 419","children":[],"tail":", which is classified generally to chapter 6 (§ 701 et seq.) of Title 47, Telecommunications. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s701"},"text":"section 701 of Title 47","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44586e32-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" substituted “(6), (7), and (8)” for “(5), (6), and (7)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7811/i/8/D"},"text":"Pub. L. 101–239, § 7811(i)(8)(D)","children":[],"tail":", substituted “(5), (6), and (7)” for “(5) and (6)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7811/i/10"},"text":"Pub. L. 101–239, § 7811(i)(10)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1012/e/2/A"},"text":"Pub. L. 100–647, § 1012(e)(2)(A)","children":[],"tail":", (5), struck out “to citizens of the United States and” after “exemption” and substituted “international operation” for “operation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1012/e/1/B"},"text":"Pub. L. 100–647, § 1012(e)(1)(B)","children":[],"tail":", substituted “Paragraph (1) or (2) of subsection (a) (as the case may be)” for “Paragraphs (1) and (2) of subsection (a)” and “such paragraph” for “such paragraphs (1) and (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1012/e/1/A"},"text":"Pub. L. 100–647, § 1012(e)(1)(A)","children":[],"tail":", substituted “Special rules” for “Exception” in heading and amended text generally. Prior to amendment, text read as follows: “Paragraph (1) shall not apply to any foreign corporation—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the stock of which is primarily and regularly traded on an established securities market in the foreign country in which such corporation is organized, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) which is wholly owned (either directly or indirectly) by another corporation meeting the requirements of subparagraph (A) and is organized in the same foreign country as such other corporation.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1212/c/3"},"text":"Pub. L. 99–514, § 1212(c)(3)","children":[],"tail":", added par. (1) and struck out former par. (1), ships under foreign flag, which read as follows: “Earnings derived from the operation of a ship or ships documented under the laws of a foreign country which grants an equivalent exemption to citizens of the United States and to corporations organized in the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1212/c/3"},"text":"Pub. L. 99–514, § 1212(c)(3)","children":[],"tail":", added par. (2) and struck out former par. (2), aircraft of foreign registry, which read as follows: “Earnings derived from the operation of aircraft registered under the laws of a foreign country which grants an equivalent exemption to citizens of the United States and to corporations organized in the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1212/c/4"},"text":"Pub. L. 99–514, § 1212(c)(4)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1212/c/5"},"text":"Pub. L. 99–514, § 1212(c)(5)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/164"},"text":"Pub. L. 94–164","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/622"},"text":"Pub. L. 90–622","children":[],"tail":" designated existing provisions as subsec. (a), added subsec. (a) heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44586e33-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44586e34-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" applicable to wagers made after "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s419/c"},"text":"section 419(c) of Pub. L. 108–357","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s872"},"text":"section 872 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44586e35-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Technical and Miscellaneous Revenue Act of 1988, "},{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7817"},"text":"section 7817 of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id