hildren":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1616/b/10"},"text":"section 1616(b)(10) of Pub. L. 104–188","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1995-12-31"},"text":"Dec. 31, 1995","children":[],"tail":", but not applicable to any residual interest held by a taxpayer if such interest has been held by such taxpayer at all times since "},{"tag":"date","attrib":{"date":"1995-10-31"},"text":"Oct. 31, 1995","children":[],"tail":", see section 1616(c)(1), (4) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s593"},"text":"section 593 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1704/h/2"},"text":"Pub. L. 104–188, title I, § 1704(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1881"},"text":"110 Stat. 1881","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/188/tI/s1704/h/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall take effect as if included in the amendments made by section 671 of the Tax Reform Act of 1986 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":"] unless the taxpayer elects to apply such amendment only to taxable years beginning after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id443bbe6e-3a70-11f1-a967-d35dac11796a"},"text":null,"chil