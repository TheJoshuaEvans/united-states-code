children":[{"tag":"num","attrib":{"value":"I"},"text":"“(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocable to an interest in a pass-thru entity acquired after ","children":[{"tag":"date","attrib":{"date":"1988-03-31"},"text":"March 31, 1988","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"“(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocable to an interest in a pass-thru entity acquired on or before ","children":[{"tag":"date","attrib":{"date":"1988-03-31"},"text":"March 31, 1988","children":[],"tail":", but attributable to a residual interest acquired by the pass-thru entity after "},{"tag":"date","attrib":{"date":"1988-03-31"},"text":"March 31, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of the preceding sentence, any interest in a pass-thru entity (or residual interest) acquired after ","children":[{"tag":"date","attrib":{"date":"1988-03-31"},"text":"March 31, 1988","children":[],"tail":", pursuant to a binding written contract in effect on such date shall be treated as acquired before such date."}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"“(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any real estate investment trust, regulated investment company, common trust fund, or publicly traded partnership, no tax shall be imposed under section 860E(e)(6) of the 1986 Code (as added by the amendment made by subparagraph (B)) for any taxable year beginning before ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by section 1006(t)(13), (15), (17), (23), (26), (27)