{"tag":"section","attrib":{"id":"id443bbe2a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E"},"text":null,"children":[{"tag":"num","attrib":{"value":"860E"},"text":"§ 860E.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of income in excess of daily accruals on residual interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id443bbe2b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess inclusions may not be offset by net operating losses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443bbe2c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The taxable income of any holder of a residual interest in a REMIC for any taxable year shall in no event be less than the excess inclusion for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe2d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for affiliated groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All members of an affiliated group filing a consolidated return shall be treated as 1 taxpayer for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe2e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with section 172","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any excess inclusion for any taxable year shall not be taken into account—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbe2f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in determining under section 172 the amount of any net operating loss for such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe30-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in determining taxable income for such taxable year for purposes of subsection (a)(2)(B)(ii)(I) and the second sentence of subsection (b)(2) of section 172.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe31-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with minimum tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of part VI of subchapter A of this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbe32-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reference in section 55(b)(1)(D) to taxable income shall be treated as a reference to taxable income determined without regard to this subsection,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe33-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alternative minimum taxable income of any holder of a residual interest in a REMIC for any taxable year shall in no event be less than the excess inclusion for such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe34-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any excess inclusion shall be disregarded for purposes of computing the alternative tax net operating loss deduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443bbe35-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organizations subject to unrelated business tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the holder of any residual interest in a REMIC is an organization subject to the tax imposed by section 511, the excess inclusion of such holder for any taxable year shall be treated as unrelated business taxable income of such holder for purposes of section 511.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443bbe36-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess inclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443bbe37-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “excess inclusion” means, with respect to any residual interest in a REMIC for any calendar quarter, the excess (if any) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbe38-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount taken into account with respect to such interest by the holder under section 860C(a), over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe39-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the daily accruals with respect to such interest for days during such calendar quarter while held by such holder.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"To the extent provided in regulations, if residual interests in a REMIC do not have significant value, the excess inclusions with respect to such interests shall be the amount determined under subparagraph (A) without regard to subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe3a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of daily accruals","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbe3b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the daily accrual with respect to any residual interest for any day in any calendar quarter shall be determined by allocating to each day in such quarter its ratable portion of the product of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id443bbe3c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjusted issue price of such interest at the beginning of such quarter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id443bbe3d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 120 percent of the long-term Federal rate (determined on the basis of compounding at the close of each calendar quarter and properly adjusted for the length of such quarter).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjusted issue price","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph, the adjusted issue price of any residual interest at the beginning of any calendar quarter is the issue price of the residual interest (adjusted for contributions)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id443bbe3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased by the amount of daily accruals for prior quarters, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id443bbe40-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decreased (but not below zero) by any distribution made with respect to such interest before the beginning of such quarter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal long-term rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the term “Federal long-term rate” means the Federal long-term rate which would have applied to the residual interest under section 1274(d) (determined without regard to paragraph (2) thereof) if it were a debt instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443bbe42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of residual interests held by real estate investment trusts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a residual interest in a REMIC is held by a real estate investment trust, under regulations prescribed by the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443bbe43-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any excess of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbe44-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate excess inclusions determined with respect to such interests, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe45-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the real estate investment trust taxable income (within the meaning of section 857(b)(2), excluding any net capital gain),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be allocated among the shareholders of such trust in proportion to the dividends received by such shareholders from such trust, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe46-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount allocated to a shareholder under paragraph (1) shall be treated as an excess inclusion with respect to a residual interest held by such shareholder.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Rules similar to the rules of the preceding sentence shall apply also in the case of regulated investment companies, common trust funds, and organizations to which part I of subchapter T applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443bbe47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on transfers of residual interests to certain organizations, etc.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443bbe48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A tax is hereby imposed on any transfer of a residual interest in a REMIC to a disqualified organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the tax imposed by paragraph (1) on any transfer of a residual interest shall be equal to the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbe4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount (determined under regulations) equal to the present value of the total anticipated excess inclusions with respect to such interest for periods after such transfer, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the highest rate of tax specified in section 11(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by paragraph (1) on any transfer shall be paid by the transferor; except that, where such transfer is through an agent for a disqualified organization, such tax shall be paid by such agent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transferee furnishes affidavit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The person (otherwise liable for any tax imposed by paragraph (1)) shall be relieved of liability for the tax imposed by paragraph (1) with respect to any transfer if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbe4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transferee furnishes to such person an affidavit that the transferee is not a disqualified organization, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of the time of the transfer, such person does not have actual knowledge that such affidavit is false.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualified organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “disqualified organization” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbe51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States, any State or political subdivision thereof, any foreign government, any international organization, or any agency or instrumentality of any of the foregoing,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organization (other than a cooperative described in section 521) which is exempt from tax imposed by this chapter unless such organization is subject to the tax imposed by section 511, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organization described in section 1381(a)(2)(C).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of subparagraph (A), the rules of section 168(h)(2)(D) (relating to treatment of certain taxable instrumentalities) shall apply; except that, in the case of the Federal Home Loan Mortgage Corporation, clause (ii) of such section shall not apply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of pass-thru entities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbe55-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, at any time during any taxable year of a pass-thru entity, a disqualified organization is the record holder of an interest in such entity, there is hereby imposed on such entity for such taxable year a tax equal to the product of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id443bbe56-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of excess inclusions for such taxable year allocable to the interest held by such disqualified organization, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id443bbe57-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the highest rate of tax specified in section 11(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe58-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pass-thru entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph, the term “pass-thru entity” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id443bbe59-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any regulated investment company, real estate investment trust, or common trust fund,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id443bbe5a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any partnership, trust, or estate, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id443bbe5b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organization to which part I of subchapter T applies.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Except as provided in regulations, a person holding an interest in a pass-thru entity as a nominee for another person shall, with respect to such interest, be treated as a pass-thru entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe5c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax to be deductible","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any tax imposed by this paragraph with respect to any excess inclusion of any pass-thru entity for any taxable year shall, for purposes of this title (other than this subsection), be applied against (and operate to reduce) the amount included in gross income with respect to the residual interest involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe5d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception where holder furnishes affidavit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No tax shall be imposed by subparagraph (A) with respect to any interest in a pass-thru entity for any period if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id443bbe5e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/6/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the record holder of such interest furnishes to such pass-thru entity an affidavit that such record holder is not a disqualified organization, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id443bbe5f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/6/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during such period, the pass-thru entity does not have actual knowledge that such affidavit is false.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe60-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may waive the tax imposed by paragraph (1) on any transfer if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbe61-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within a reasonable time after discovery that the transfer was subject to tax under paragraph (1), steps are taken so that the interest is no longer held by the disqualified organization, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe62-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is paid to the Secretary such amounts as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe63-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subtitle F, the taxes imposed by this subsection shall be treated as excise taxes with respect to which the deficiency procedures of such subtitle apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443bbe64-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860E/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of variable insurance contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in regulations, with respect to any variable contract (as defined in section 817), there shall be no adjustment in the reserve to the extent of any excess inclusion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id443bbe65-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s671/a"},"text":"Pub. L. 99–514, title VI, § 671(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2311"},"text":"100 Stat. 2311","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/t/13"},"text":"Pub. L. 100–647, title I, § 1006(t)(13)","children":[],"tail":", (15), (16)(B), (17), (23), (26), (27), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3423"},"text":"102 Stat. 3423","children":[],"tail":", 3426, 3427; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI"},"text":"Pub. L. 104–188, title I","children":[],"tail":", §§ 1616(b)(10), 1704(h)(1), "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1857"},"text":"110 Stat. 1857","children":[],"tail":", 1881; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13001/b/1/B"},"text":"Pub. L. 115–97, title I, § 13001(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2096"},"text":"131 Stat. 2096","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tII/s2303/a/2/C"},"text":"Pub. L. 116–136, div. A, title II, § 2303(a)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/353"},"text":"134 Stat. 353","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s10101/a/4/B/ii"},"text":"Pub. L. 117–169, title I, § 10101(a)(4)(B)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1822"},"text":"136 Stat. 1822","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id443bbe66-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id443bbe67-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id443bbe68-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":" substituted “55(b)(1)(D)” for “55(b)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":" substituted “subsection (a)(2)(B)(ii)(I) and the second sentence of subsection (b)(2) of section 172.” for “the 2nd sentence of section 172(b)(2).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (e)(2)(B), (6)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" substituted “section 11(b)” for “section 11(b)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1616/b/10/A"},"text":"Pub. L. 104–188, § 1616(b)(10)(A)","children":[],"tail":", substituted “The” for “Except as provided in paragraph (2), the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1616/b/10/B"},"text":"Pub. L. 104–188, § 1616(b)(10)(B)","children":[],"tail":", (C), redesignated par. (3) as (2), struck out “, except that paragraph (2) shall be applied separately with respect to each corporation which is a member of such group and to which section 593 applies” after “of this subsection”, and struck out former par. (2) which read as follows: “"},{"tag":"inline","attrib":{},"text":"Exception for certain financial institutions","children":[],"tail":".—Paragraph (1) shall not apply to any organization to which section 593 applies. The Secretary may by regulations provide that the preceding sentence shall not apply where necessary or appropriate to prevent avoidance of tax imposed by this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1616/b/10/B"},"text":"Pub. L. 104–188, § 1616(b)(10)(B)","children":[],"tail":", redesignated par. (5) as (3). Former par. (3) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1616/b/10/B"},"text":"Pub. L. 104–188, § 1616(b)(10)(B)","children":[],"tail":", (D), redesignated par. (6) as (4), struck out at end “The preceding sentence shall not apply to any organization to which section 593 applies, except to the extent provided in regulations prescribed by the Secretary under paragraph (2).”, and struck out former par. (4) which related to certain subsidiaries being treated as single corporations to which section 593 applied."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1616/b/10/B"},"text":"Pub. L. 104–188, § 1616(b)(10)(B)","children":[],"tail":", redesignated par. (5) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1616/b/10/B"},"text":"Pub. L. 104–188, § 1616(b)(10)(B)","children":[],"tail":", redesignated par. (6) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1704/h/1"},"text":"Pub. L. 104–188, § 1704(h)(1)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/15"},"text":"Pub. L. 100–647, § 1006(t)(15)","children":[],"tail":", added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/27"},"text":"Pub. L. 100–647, § 1006(t)(27)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/13"},"text":"Pub. L. 100–647, § 1006(t)(13)","children":[],"tail":", (17), substituted “issue price of the residual interest (adjusted for contributions)” for “issue price of residual interest” in introductory text, and in cl. (ii) inserted “(but not below zero)” after “decreased”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/23"},"text":"Pub. L. 100–647, § 1006(t)(23)","children":[],"tail":", inserted at end “Rules similar to the rules of the preceding sentence shall apply also in the case of regulated investment companies, common trust funds, and organizations to which part I of subchapter T applies.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/16/B"},"text":"Pub. L. 100–647, § 1006(t)(16)(B)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/26"},"text":"Pub. L. 100–647, § 1006(t)(26)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id443bbe69-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id443bbe6a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2022-12-31"},"text":"Dec. 31, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/169/s10101/f"},"text":"section 10101(f) of Pub. L. 117–169","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s11"},"text":"section 11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id443bbe6b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"tex