{"tag":"section","attrib":{"id":"id449d8dc7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012"},"text":null,"children":[{"tag":"num","attrib":{"value":"1012"},"text":"§ 1012.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis of property—cost","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id449d8dc8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The basis of property shall be the cost of such property, except as otherwise provided in this subchapter and subchapters C (relating to corporate distributions and adjustments), K (relating to partners and partnerships), and P (relating to capital gains and losses).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id449d8dc9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for apportioned real estate taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The cost of real property shall not include any amount in respect of real property taxes which are treated under section 164(d) as imposed on the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id449d8dca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations by account","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id449d8dcb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of the sale, exchange, or other disposition of a specified security on or after the applicable date, the conventions prescribed by regulations under this section shall be applied on an account by account basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id449d8dcc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to certain regulated investment companies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id449d8dcd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), any stock for which an average basis method is permissible under this section which is acquired before ","children":[{"tag":"date","attrib":{"date":"2012-01-01"},"text":"January 1, 2012","children":[],"tail":", shall be treated as a separate account from any such stock acquired on or after such date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id449d8dce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election for treatment as single account","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a regulated investment company described in subparagraph (A) elects to have this subparagraph apply with respect to one or more of its stockholders—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id449d8dcf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraph (A) shall not apply with respect to any stock in such regulated investment company held by such stockholders, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id449d8dd0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all stock in such regulated investment company which is held by such stockholders shall be treated as covered securities described in section 6045(g)(3) without regard to the date of the acquisition of such stock.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A rule similar to the rule of the preceding sentence shall apply with respect to a broker holding such stock as a nominee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id449d8dd1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the terms “specified security” and “applicable date” shall have the meaning given such terms in section 6045(g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id449d8dd2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Average basis for stock acquired pursuant to a dividend reinvestment plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id449d8dd3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any stock acquired after ","children":[{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":", in connection with a dividend reinvestment plan, the basis of such stock while held as part of such plan shall be determined using one of the methods which may be used for determining the basis of stock in a regulated investment company."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id449d8dd4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment after transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of the transfer to another account of stock to which paragraph (1) applies, such stock shall have a cost basis in such other account equal to its basis in the dividend reinvestment plan immediately before such transfer (properly adjusted for any fees or other charges taken into account in connection with such transfer).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id449d8dd5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate accounts; election for treatment as single account","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id449d8dd6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of subsection (c)(2) shall apply for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id449d8dd7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Average basis method","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), in the case of an election under rules similar to the rules of subsection (c)(2)(B) with respect to stock held in connection with a dividend reinvestment plan, the average basis method is permissible with respect to all such stock without regard to the date of the acquisition of such stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id449d8dd8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dividend reinvestment plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id449d8dd9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “dividend reinvestment plan” means any arrangement under which dividends on any stock are reinvested in stock identical to the stock with respect to which the dividends are paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id449d8dda-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1012/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial stock acquisition treated as acquired in connection with plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Stock shall be treated as acquired in connection with a dividend reinvestment plan if such stock is acquired pursuant to such plan or if the dividends paid on such stock are subject to such plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id449d8ddb-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/296"},"text":"68A Stat. 296","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dB/tIV/s403/b"},"text":"Pub. L. 110–343, div. B, title IV, § 403(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3857"},"text":"122 Stat. 3857","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII"},"text":"Pub. L. 113–295, div. A, title II","children":[],"tail":", §§ 210(f)(1)–(3), 220(n), "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4031"},"text":"128 Stat. 4031","children":[],"tail":", 4032, 4036.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id449d8ddc-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id449d8ddd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id449d8dde-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s210/f/1/A"},"text":"Pub. L. 113–295, § 210(f)(1)(A)","children":[],"tail":", substituted “regulated investment companies” for “funds” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s220/n"},"text":"Pub. L. 113–295, § 220(n)","children":[],"tail":", substituted “this section” for “section 1012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s210/f/1/C"},"text":"Pub. L. 113–295, § 210(f)(1)(C)","children":[],"tail":", substituted “regulated investment company” for “fund” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s210/f/1/B"},"text":"Pub. L. 113–295, § 210(f)(1)(B)","children":[],"tail":", struck out “fund” after “Election” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s210/f/2"},"text":"Pub. L. 113–295, § 210(f)(2)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":"” and “a regulated investment company” for “an open-end fund”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s210/f/3"},"text":"Pub. L. 113–295, § 210(f)(3)","children":[],"tail":", amended par. (3) generally. Prior to amendment, text read as follows: “Rules similar to the rules of subsection (c)(2) shall apply for purposes of this subsection.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343"},"text":"Pub. L. 110–343","children":[],"tail":" designated first sentence as subsec. (a) and second sentence as subsec. (b), inserted headings, and added subsecs. (c) and (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id449d8ddf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id449d8de0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 210(f)(1)–(3) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" effective as if included in the provisions of the Energy Improvement and Extension Act of 2008, "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dB"},"text":"Pub. L. 110–343, div. B","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s210/h"},"text":"section 210(h) of Pub. L. 113–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s45"},"text":"section 45 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id449d8de1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dB/tIV/s403/e"},"text":"Pub. L. 110–343, div. B, title IV, § 403(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3860"},"text":"122 Stat. 3860","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/343/dB/tIV/s403/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this subsection, the amendments made by this section [enacting sections 6045A and 6045B of this title and amending this section and sections 6045 and 6724 of this title] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2011-01-01"},"text":"January 1, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension of period for statements sent to customers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsection (a)(3) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6045"},"text":"section 6045 of this title","children":[],"tail":"] shall apply to statements required to be furnished after "},{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
