{"tag":"section","attrib":{"id":"id45d5e5ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4403"},"text":null,"children":[{"tag":"num","attrib":{"value":"4403"},"text":"§ 4403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each person liable for tax under this subchapter shall keep a daily record showing the gross amount of all wagers on which he is so liable, in addition to all other records required pursuant to section 6001(a).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id45d5e600-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/525"},"text":"68A Stat. 525","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
