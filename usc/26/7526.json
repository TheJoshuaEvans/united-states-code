{"tag":"section","attrib":{"id":"id47700ea3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526"},"text":null,"children":[{"tag":"num","attrib":{"value":"7526"},"text":"§ 7526.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income taxpayer clinics","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47700ea4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, subject to the availability of appropriated funds, make grants to provide matching funds for the development, expansion, or continuation of qualified low-income taxpayer clinics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47700ea5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47700ea6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified low-income taxpayer clinic","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47700ea7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified low-income taxpayer clinic” means a clinic that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47700ea8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not charge more than a nominal fee for its services (except for reimbursement of actual costs incurred); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47700ea9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id47700eaa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/b/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represents low-income taxpayers in controversies with the Internal Revenue Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id47700eab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/b/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operates programs to inform individuals for whom English is a second language about their rights and responsibilities under this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700eac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation of low-income taxpayers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A clinic meets the requirements of subparagraph (A)(ii)(I) if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47700ead-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 90 percent of the taxpayers represented by the clinic have incomes which do not exceed 250 percent of the poverty level, as determined in accordance with criteria established by the Director of the Office of Management and Budget; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47700eae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount in controversy for any taxable year generally does not exceed the amount specified in section 7463.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700eaf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clinic","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “clinic” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47700eb0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a clinical program at an accredited law, business, or accounting school in which students represent low-income taxpayers in controversies arising under this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700eb1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization described in section 501(c) and exempt from tax under section 501(a) which satisfies the requirements of paragraph (1) through representation of taxpayers or referral of taxpayers to qualified representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700eb2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified representative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified representative” means any individual (whether or not an attorney) who is authorized to practice before the Internal Revenue Service or the applicable court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47700eb3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules and limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47700eb4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless otherwise provided by specific appropriation, the Secretary shall not allocate more than $6,000,000 per year (exclusive of costs of administering the program) to grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700eb5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on annual grants to a clinic","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The aggregate amount of grants which may be made under this section to a clinic for a year shall not exceed $100,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700eb6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multi-year grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon application of a qualified low-income taxpayer clinic, the Secretary is authorized to award a multi-year grant not to exceed 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700eb7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for awards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether to make a grant under this section, the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47700eb8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the numbers of taxpayers who will be served by the clinic, including the number of taxpayers in the geographical area for whom English is a second language;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700eb9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the existence of other low-income taxpayer clinics serving the same population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700eba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quality of the program offered by the low-income taxpayer clinic, including the qualifications of its administrators and qualified representatives, and its record, if any, in providing service to low-income taxpayers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700ebb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative funding sources available to the clinic, including amounts received from other grants and contributions, and the endowment and resources of the institution sponsoring the clinic.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700ebc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of matching funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A low-income taxpayer clinic must provide matching funds on a dollar-for-dollar basis for all grants provided under this section. Matching funds may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47700ebd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the salary (including fringe benefits) of individuals performing services for the clinic; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700ebe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of equipment used in the clinic.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Indirect expenses, including general overhead of the institution sponsoring the clinic, shall not be counted as matching funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700ebf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of information regarding qualified low-income taxpayer clinics","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, officers and employees of the Department of the Treasury may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47700ec0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise taxpayers of the availability of, and eligibility requirements for receiving, advice and assistance from one or more specific qualified low-income taxpayer clinics receiving funding under this section, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47727ec1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7526/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information regarding the location of, and contact information for, such clinics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47727ec2-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3601/a"},"text":"Pub. L. 105–206, title III, § 3601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/774"},"text":"112 Stat. 774","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/25/tI/s1402/a"},"text":"Pub. L. 116–25, title I, § 1402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/997"},"text":"133 Stat. 997","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47727ec3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47727ec4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47727ec5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25"},"text":"Pub. L. 116–25","children":[],"tail":" added par. (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47727ec6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47727ec7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/tI/s1402/b"},"text":"Pub. L. 116–25, title I, § 1402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/997"},"text":"133 Stat. 997","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/25/tI/s1402/b"},"text":"“The amendment made by this section [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47727ec8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3601/c"},"text":"Pub. L. 105–206, title III, § 3601(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/776"},"text":"112 Stat. 776","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/206/tIII/s3601/c"},"text":"“The amendments made by this section [enacting this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
