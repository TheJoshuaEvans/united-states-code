{"tag":"section","attrib":{"id":"id44b09fda-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1058"},"text":null,"children":[{"tag":"num","attrib":{"value":"1058"},"text":"§ 1058.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of securities under certain agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44b09fdb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1058/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a taxpayer who transfers securities (as defined in section 1236(c)) pursuant to an agreement which meets the requirements of subsection (b), no gain or loss shall be recognized on the exchange of such securities by the taxpayer for an obligation under such agreement, or on the exchange of rights under such agreement by that taxpayer for securities identical to the securities transferred by that taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44b09fdc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1058/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to meet the requirements of this subsection, an agreement shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44b09fdd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1058/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the return to the transferor of securities identical to the securities transferred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b09fde-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1058/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that payments shall be made to the transferor of amounts equivalent to all interest, dividends, and other distributions which the owner of the securities is entitled to receive during the period beginning with the transfer of the securities by the transferor and ending with the transfer of identical securities back to the transferor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b09fdf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1058/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not reduce the risk of loss or opportunity for gain of the transferor of the securities in the securities transferred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b09fe0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1058/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet such other requirements as the Secretary may by regulation prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44b09fe1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1058/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Property acquired by a taxpayer described in subsection (a), in a transaction described in that subsection, shall have the same basis as the property transferred by that taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44b09fe2-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/345/s2/d/1"},"text":"Pub. L. 95–345, § 2(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-15"},"text":"Aug. 15, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/482"},"text":"92 Stat. 482","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44b09fe3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44b09fe4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id44b09fe5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1058 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1063"},"text":"section 1063 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44b09fe6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44b09fe7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to amounts received after ","children":[{"tag":"date","attrib":{"date":"1976-12-31"},"text":"Dec. 31, 1976","children":[],"tail":", as payments with respect to securities loans (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s512/a/5"},"text":"section 512(a)(5) of this title","children":[],"tail":"), and transfers of securities, under agreements described in this section, occurring after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/345/s2/e"},"text":"section 2(e) of Pub. L. 95–345","children":[],"tail":", set out as an Effective Date of 1978 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s509"},"text":"section 509 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
