{"tag":"section","attrib":{"id":"id45a64aeb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3512"},"text":null,"children":[{"tag":"num","attrib":{"value":"3512"},"text":"§ 3512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain persons as employers with respect to motion picture projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45a64aec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3512/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of sections 3121(a)(1) and 3306(b)(1), remuneration paid to a motion picture project worker by a motion picture project employer during a calendar year shall be treated as remuneration paid with respect to employment of such worker by such employer during the calendar year. The identity of such employer for such purposes shall be determined as set forth in this section and without regard to the usual common law rules applicable in determining the employer-employee relationship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a64aed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3512/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45a64aee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3512/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motion picture project employer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “motion picture project employer” means any person if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45a64aef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3512/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such person (directly or through affiliates)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45a64af0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3512/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a party to a written contract covering the services of motion picture project workers with respect to motion picture projects in the course of a client’s trade or business,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45a64af1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3512/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is contractually obligated to pay remuneration to the motion picture project workers without regard to payment or reimbursement by any other person,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45a64af2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3512/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" controls the payment (within the meaning of section 3401(d)(1)) of remuneration to the motion picture project workers and pays such remuneration from its own account or accounts,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45a64af3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3512/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a signatory to one or more collective bargaining agreements with a labor organization (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s152/5"},"text":"29 U.S.C. 152(5)","children":[],"tail":") that represents motion picture project workers, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45a64af4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3512/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has treated substantially all motion picture project workers that such person pays as employees and not as independent contractors during such calendar year for purposes of determining employment taxes under this subtitle, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a64af5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3512/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 80 percent of all remuneration (to which section 3121 applies) paid by such person in such calendar year is paid to motion picture project workers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a64af6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3512/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motion picture project worker","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “motion picture project worker” means any individual who provides services on motion picture projects for clients who are not affiliated with the motion picture project employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a64af7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3512/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motion picture project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “motion picture project” means the production of any property described in section 168(f)(3). Such term does not include property with respect to which records are required to be maintained under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2257"},"text":"section 2257 of title 18","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a64af8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3512/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliate; affiliated","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person shall be treated as an affiliate of, or affiliated with, another person if such persons are treated as a single employer under subsection (b) or (c) of section 414.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45a64af9-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tIII/s346/a"},"text":"Pub. L. 114–113, div. Q, title III, § 346(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3115"},"text":"129 Stat. 3115","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45a64afa-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45a64afb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id45a64afc-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s152"},"text":"29 U.S.C. 152","children":[],"tail":", referred to in subsec. (b)(1)(A)(iv), is section 2 of the National Labor Relations Act, "},{"tag":"ref","attrib":{"href":"/us/act/1935-07-05/ch372"},"text":"act July 5, 1935, ch. 372","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/450"},"text":"49 Stat. 450","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s152"},"text":"section 152 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45a64afd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45a64afe-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tIII/s346/c"},"text":"Pub. L. 114–113, div. Q, title III, § 346(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3116"},"text":"129 Stat. 3116","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/113/dQ/tIII/s346/c"},"text":"“The amendments made by this section [enacting this section] shall apply to remuneration paid after ","children":[{"tag":"date","attrib":{"date":"2015-12-31"},"text":"December 31, 2015","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id45a64aff-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tIII/s346/d"},"text":"Pub. L. 114–113, div. Q, title III, § 346(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3116"},"text":"129 Stat. 3116","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/113/dQ/tIII/s346/d"},"text":"“Nothing in the amendments made by this section [enacting this section] shall be construed to create any inference on the law before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
