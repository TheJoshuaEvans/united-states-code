{"tag":"section","attrib":{"id":"id46308954-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5222"},"text":null,"children":[{"tag":"num","attrib":{"value":"5222"},"text":"§ 5222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production, receipt, removal, and use of distilling materials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46308955-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5222/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production, removal, and use","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46308956-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5222/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No mash, wort, or wash fit for distillation or for the production of distilled spirits shall be made or fermented in any building or on any premises other than on the bonded premises of a distilled spirits plant duly authorized to produce distilled spirits according to law; and no mash, wort, or wash so made or fermented shall be removed from any such premises before being distilled, except as authorized by the Secretary; and no person other than an authorized distiller shall, by distillation or any other process, produce distilled spirits from any mash, wort, wash, or other material.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46308957-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5222/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in this subsection shall be construed to apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46308958-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5222/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized operations performed on the premises of vinegar plants established under part I of subchapter H;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46308959-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5222/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized production and removal of fermented materials produced on authorized brewery or bonded wine cellar premises as provided by law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4630895a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5222/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" products exempt from tax under the provisions of section 5042 or 5053(e); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4630895b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5222/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fermented materials used in the manufacture of vinegar by fermentation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4630895c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5222/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under such regulations as the Secretary may prescribe, fermented materials to be used in the production of distilled spirits may be received on the bonded premises of a distilled spirits plant authorized to produce distilled spirits as follows—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4630895d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5222/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the premises of a bonded wine cellar authorized to remove such material by section 5362(c)(6);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4630895e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5222/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beer conveyed without payment of tax from brewery premises, beer which has been lawfully removed from brewery premises upon determination of tax, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4630895f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5222/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cider exempt from tax under the provisions of section 5042(a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46308960-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5222/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Processing of distilled spirits containing extraneous substances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may by regulations provide for the removal from the distilling system, and the addition to the fermented or unfermented distilling material, of distilled spirits containing substantial quantities of fusel oil or aldehydes, or other extraneous substances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46308961-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5222/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For penalty and forfeiture for unlawful production, removal, or use of material fit for distillation or for the production of distilled spirits, and for penalty and forfeiture for unlawful production of distilled spirits, see sections 5601(a)(7), 5601(a)(8), and 5615(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46308962-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1365"},"text":"72 Stat. 1365","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1905(b)(6)(D), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1823"},"text":"90 Stat. 1823","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/95/458/s2/b/4"},"text":"Pub. L. 95–458, § 2(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-14"},"text":"Oct. 14, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1256"},"text":"92 Stat. 1256","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/30"},"text":"Pub. L. 96–39, title VIII, § 807(a)(30)","children":[],"tail":", "},{"tag":"date","attrib":{"d