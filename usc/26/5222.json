"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", are set out in "},{"tag":"ref","attrib":{"href":"/us/stat/68A/640"},"text":"68A Stat. 640","children":[],"tail":", 641, 658, 665, 675."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46308967-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “conveyed without payment of tax from contiguous brewery premises where produced; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" struck out “, in the production facilities of a distilled spirits plant” after “distilling material”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/458"},"text":"Pub. L. 95–458","children":[],"tail":" inserted reference to section 5053(e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a)(1), (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1905/b/6/D"},"text":"Pub. L. 94–455, § 1905(b)(6)(D)","children":[],"tail":", struck out “5601(b)(3), 5601(b)(4),” after “5601(a)(8),”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46308968-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":