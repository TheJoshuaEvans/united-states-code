{"tag":"section","attrib":{"id":"id45e43d8f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911"},"text":null,"children":[{"tag":"num","attrib":{"value":"4911"},"text":"§ 4911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on excess expenditures to influence legislation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45e43d90-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax imposed","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45e43d91-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on the excess lobbying expenditures of any organization to which this section applies a tax equal to 25 percent of the amount of the excess lobbying expenditures for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e43d92-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organizations to which this section applies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section applies to any organization with respect to which an election under section 501(h) (relating to lobbying expenditures by public charities) is in effect for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45e43d93-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess lobbying expenditures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “excess lobbying expenditures” means, for a taxable year, the greater of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45e43d94-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount by which the lobbying expenditures made by the organization during the taxable year exceed the lobbying nontaxable amount for such organization for such taxable year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e43d95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount by which the grass roots expenditures made by the organization during the taxable year exceed the grass roots nontaxable amount for such organization for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45e43d96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45e43d97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lobbying expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lobbying expenditures” means expenditures for the purpose of influencing legislation (as defined in subsection (d)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e43d98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lobbying nontaxable amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The lobbying nontaxable amount for any organization for any taxable year is the lesser of (A) $1,000,000 or (B) the amount determined under the following table:","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id45e43d99-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":"If the exempt purpose","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":" expenditures are—","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":"The lobbying nontaxable","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":" amount is—","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Not over $500,000","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"20 percent of the exempt purpose expenditures.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Over $500,000 but not over $1,000,000","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$100,000, plus 15 percent of the excess of the exempt purpose expenditures over $500,000.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Over $1,000,000 but not over $1,500,000","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$175,000 plus 10 percent of the excess of the exempt purpose expenditures over $1,000,000.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Over $1,500,000","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$225,000 plus 5 percent of the excess of the exempt purpose expenditures over $1,500,000.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e43d9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grass roots expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “grass roots expenditures” means expenditures for the purpose of influencing legislation (as defined in subsection (d) without regard to paragraph (1)(B) thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e43d9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grass roots nontaxable amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The grass roots nontaxable amount for any organization for any taxable year is 25 percent of the lobbying nontaxable amount (determined under paragraph (2)) for such organization for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45e43d9c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Influencing legislation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45e43d9d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in paragraph (2), for purposes of this section, the term “influencing legislation” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45e43d9e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any attempt to influence any legislation through an attempt to affect the opinions of the general public or any segment thereof, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45e43d9f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any attempt to influence any legislation through communication with any member or employee of a legislative body, or with any government official or employee who may participate in the formulation of the legislation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e43da0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “influencing legislation”, with respect to an organization, does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45e43da1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making available the results of nonpartisan analysis, study, or research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45e43da2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing of technical advice or assistance (where such advice would otherwise constitute the influencing of legislation) to a governmental body or to a committee or other subdivision thereof in response to a written request by such body or subdivision, as the case may be;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45e43da3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appearances before, or communications to, any legislative body with respect to a possible decision of such body which might affect the existence of the organization, its powers and duties, tax-exempt status, or the deduction of contributions to the organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45e43da4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communications between the organization and its bona fide members with respect to legislation or proposed legislation of direct interest to the organization and such members, other than communications described in paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45e43da5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any communication with a governmental official or employee, other than—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45e43da6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/d/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a communication with a member or employee of a legislative body (where such communication would otherwise constitute the influencing of legislation), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45e43da7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/d/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a communication the principal purpose of which is to influence legislation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e43da8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communications with members","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45e43da9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A communication between an organization and any bona fide member of such organization to directly encourage such member to communicate as provided in paragraph (1)(B) shall be treated as a communication described in paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45e43daa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A communication between an organization and any bona fide member of such organization to directly encourage such member to urge persons other than members to communicate as provided in either subparagraph (A) or subparagraph (B) of paragraph (1) shall be treated as a communication described in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45e43dab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45e43dac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempt purpose expenditures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45e43dad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “exempt purpose expenditures” means, with respect to any organization for any taxable year, the total of the amounts paid or incurred by such organization to accomplish purposes described in section 170(c)(2)(B) (relating to religious, charitable, educational, etc., purposes).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45e43dae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain amounts included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “exempt purpose expenditures” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45e43daf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative expenses paid or incurred for purposes described in section 170(c)(2)(B), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45e43db0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts paid or incurred for the purpose of influencing legislation (whether or not for purposes described in section 170(c)(2)(B)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45e43db1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain amounts excluded","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “exempt purpose expenditures” does not include amounts paid or incurred to or for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45e43db2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/e/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a separate fundraising unit of such organization, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45e43db3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/e/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more other organizations, if such amounts are paid or incurred primarily for fundraising.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e43db4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legislation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “legislation” includes action with respect to Acts, bills, resolutions, or similar items by the Congress, any State legislature, any local council, or similar governing body, or by the public in a referendum, initiative, constitutional amendment, or similar procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e43db5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “action” is limited to the introduction, amendment, enactment, defeat, or repeal of Acts, bills, resolutions, or similar items.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e43db6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depreciation, etc., treated as expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In computing expenditures paid or incurred for the purpose of influencing legislation (within the meaning of subsection (b)(1) or (b)(2)) or exempt purpose expenditures (as defined in paragraph (1)), amounts properly chargeable to capital account shall not be taken into account. There shall be taken into account a reasonable allowance for exhaustion, wear and tear, obsolescence, or amortization. Such allowance shall be computed only on the basis of the straight-line method of depreciation. For purposes of this section, a determination of whether an amount is properly chargeable to capital account shall be made on the basis of the principles that apply under subtitle A to amounts which are paid or incurred in a trade or business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45e43db7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliated organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45e43db8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in paragraph (4), if for a taxable year two or more organizations described in section 501(c)(3) are members of an affiliated group of organizations as defined in paragraph (2), and an election under section 501(h) is effective for at least one such organization for such year, then—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45e43db9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination as to whether excess lobbying expenditures have been made and the determination as to whether the expenditure limits of section 501(h)(1) have been exceeded shall be made as though such affiliated group is one organization,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45e43dba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such group has excess lobbying expenditures, each such organization as to which an election under section 501(h) is effective for such year shall be treated as an organization which has excess lobbying expenditures in an amount which equals such organization’s proportionate share of such group’s excess lobbying expenditures,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45e43dbb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the expenditure limits of section 501(h)(1) are exceeded, each such organization as to which an election under section 501(h) is effective for such year shall be treated as an organization which is not described in section 501(c)(3) by reason of the application of 501(h), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45e43dbc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraphs (C) and (D) of subsection (d)(2), paragraph (3) or subsection (d), and clause (i) of subsection (e)(1)(C) shall be applied as if such affiliated group were one organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e43dbd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of affiliation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), two organizations are members of an affiliated group of organizations but only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45e43dbe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the governing instrument of one such organization requires it to be bound by decisions of the other organization on legislative issues, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45e43dbf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the governing board of one such organization includes persons who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45e43dc0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are specifically designated representatives of another such organization or are members of the governing board, officers, or paid executive staff members of such other organization, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45e43dc1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by aggregating their votes, have sufficient voting power to cause or prevent action on legislative issues by the first such organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e43dc2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Different taxable years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If members of an affiliated group of organizations have different taxable years, their expenditures shall be computed for purposes of this section in a manner to be prescribed by regulations promulgated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e43dc3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited control","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If two or more organizations are members of an affiliated group of organizations (as defined in paragraph (2) without regard to subparagraph (B) thereof), no two members of such affiliated group are affiliated (as defined in paragraph (2) without regard to subparagraph (A) thereof), and the governing instrument of no such organization requires it to be bound by decisions of any of the other such organizations on legislative issues other than as to action with respect to Acts, bills, resolutions, or similar items by the Congress, then—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45e43dc4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any organization whose decisions bind one or more members of such affiliated group, directly or indirectly, the determination as to whether such organization has paid or incurred excess lobbying expenditures and the determination as to whether such organization has exceeded the expenditure limits of section 501(h)(1) shall be made as though such organization has paid or incurred those amounts paid or incurred by such members of such affiliated group to influence legislation with respect to Acts, bills, resolutions, or similar items by the Congress, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45e43dc5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4911/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any organization to which subparagraph (A) does not apply, but which is a member of such affiliated group, the determination as to whether such organization has paid or incurred excess lobbying expenditures and the determination as to whether such organization has exceeded the expenditure limits of section 501(h)(1) shall be made as though such organization is not a member of such affiliated group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45e43dc6-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIII/s1307/b"},"text":"Pub. L. 94–455, title XIII, § 1307(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1723"},"text":"90 Stat. 1723","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s703/g/1"},"text":"Pub. L. 95–600, title VII, § 703(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2940"},"text":"92 Stat. 2940","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45e43dc7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45e43dc8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45e43dc9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" substituted “exempt purpose expenditures” for “proposed expenditures” in heading of table."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45e43dca-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45e43dcb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/s703/r"},"text":"section 703(r) of Pub. L. 95–600","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s46"},"text":"section 46 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
