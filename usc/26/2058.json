{"tag":"section","attrib":{"id":"id45389475-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2058"},"text":null,"children":[{"tag":"num","attrib":{"value":"2058"},"text":"§ 2058.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State death taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45389476-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2058/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of deduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of the tax imposed by section 2001, the value of the taxable estate shall be determined by deducting from the value of the gross estate the amount of any estate, inheritance, legacy, or succession taxes actually paid to any State or the District of Columbia, in respect of any property included in the gross estate (not including any such taxes paid with respect to the estate of a person other than the decedent).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45389477-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2058/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The deduction allowed by this section shall include only such taxes as were actually paid and deduction therefor claimed before the later of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45389478-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2058/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 years after the filing of the return required by section 6018, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45389479-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2058/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4538947a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2058/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a petition for redetermination of a deficiency has been filed with the Tax Court within the time prescribed in section 6213(a), the expiration of 60 days after the decision of the Tax Court becomes final,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4538947b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2058/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an extension of time has been granted under section 6161 or 6166 for payment of the tax shown on the return, or of a deficiency, the date of the expiration of the period of the extension, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4538947c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2058/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a claim for refund or credit of an overpayment of tax imposed by this chapter has been filed within the time prescribed in section 6511, the latest of the expiration of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4538947d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2058/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 days from the date of mailing by certified mail or registered mail by the Secretary to the taxpayer of a notice of the disallowance of any part of such claim,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4538947e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2058/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 days after a decision by any court of competent jurisdiction becomes final with respect to a timely suit instituted upon such claim, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4538947f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2058/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 years after a notice of the waiver of disallowance is filed under section 6532(a)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Notwithstanding sections 6511 and 6512, refund based on the deduction may be made if the claim for refund is filed within the period provided in the preceding sentence. Any such refund shall be made without interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45389480-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/tV/s532/b"},"text":"Pub. L. 107–16, title V, § 532(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/73"},"text":"115 Stat. 73","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45389481-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45389482-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45389483-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to estates of decedents dying, and generation-skipping transfers, after ","children":[{"tag":"date","attrib":{"date":"2004-12-31"},"text":"Dec. 31, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/s532/d"},"text":"section 532(d) of Pub. L. 107–16","children":[],"tail":", set out as an Effective Date of 2001 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2012"},"text":"section 2012 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
