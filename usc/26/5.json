t. 586","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendments made by this section [enacting sections 56 to 58 of this title and amending this section and sections 12, 46, 51, 443, 453, 511, 901, 1373, 1375, 6015, and 6654 of this title] shall apply to taxable years ending after ","children":[{"tag":"date","attrib":{"date":"1969-12-31"},"text":"December 31, 1969","children":[],"tail":". In the case of a taxable year beginning in 1969 and ending in 1970, the tax imposed by section 56 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] (as added by subsection (a)) shall be an amount equal to the tax imposed by such section (determined without regard to this sentence) multiplied by a fraction—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the numerator of which is the number of days in the taxable year occurring after ","children":[{"tag":"date","attrib":{"date":"1969-12-31"},"text":"December 31, 1969","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the denominator of which is the number of days in the entire taxable year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/s803/d/6"},"text":"section 803(d)(6) of Pub. L. 91–172","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/s803/f"},"text":"section 803(f) of Pub. L. 91–172","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4048b249-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1964 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s232/g"},"text":"Pub. L. 88–272, title II, § 232(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/112"},"text":"78 Stat. 112","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the amendments made by this section [enacting sections 1301 to 1305, amending this section and sections 4, 72, 144, 402, 403, 6511, and omitting former sections 1301 to 1307 of this title] shall apply with respect to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1963-12-31"},"text":"December 31, 1963","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Income from an employment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, in a taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"1963-12-31"},"text":"December 31, 1963","children":[],"tail":", an individual or partnership receives or accrues compensation from an employment (as defined by section 1301(b) of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] as in effect immediately before the enactment of this Act ["},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":"] and the employment began before "},{"tag":"date","attrib":{"date":"1963-02-06"},"text":"February 6, 1963","children":[],"tail":", the tax attributable to such compensation may, at the election of the taxpayer, be computed under the provisions of sections 1301 and 1307 of such Code as in effect immediately before the enactment of this Act. If a taxpayer so elects (at such time and in such manner as the Secretary of the Treasury or his delegate by regulations prescribes), he may not choose for such taxable year the benefits provided by part I of subchapter Q of chapter 1 of such Code (relating to income averaging) as amended by this Act and (if he elects to have subsection (e) of such section 1307 apply) section 170(b)(5) of such Code as amended by this Act shall not apply to charitable contributions paid in such taxable year.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4048b24a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability of Certain Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" in Relation to Treaty Obligations of United States"}],"tail":null},{"tag":"p","attrib":{},"text":"For applicability of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s701/e/4/A"},"text":"section 701(e)(4)(A) of Pub. L. 99–514","children":[],"tail":" notwithstanding any treaty obligation of the United States in effect on "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1012/aa/2"},"text":"section 1012(aa)(2) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s861"},"text":"section 861 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
