{"tag":"section","attrib":{"id":"id464d122d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5753"},"text":null,"children":[{"tag":"num","attrib":{"value":"5753"},"text":"§ 5753.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of forfeited, condemned, and abandoned tobacco products, and cigarette papers and tubes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If it appears that any forfeited, condemned, or abandoned tobacco products, or cigarette papers and tubes, when offered for sale, will not bring a price equal to the tax due and payable thereon, and the expenses incident to the sale thereof, such articles shall not be sold for consumption in the United States but shall be disposed of in accordance with such regulations as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id464d122e-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/716"},"text":"68A Stat. 716","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s202"},"text":"Pub. L. 85–859, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1425"},"text":"72 Stat. 1425","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tV/s502/b/11"},"text":"Pub. L. 89–44, title V, § 502(b)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/152"},"text":"79 Stat. 152","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id464d122f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id464d1230-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id464d1231-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" struck out references to tobacco materials wherever appearing in heading and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" substituted “tobacco products, cigarette papers and tubes” for “articles” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id464d1232-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464d1233-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"