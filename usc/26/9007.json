{"tag":"section","attrib":{"id":"id47a94659-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9007"},"text":null,"children":[{"tag":"num","attrib":{"value":"9007"},"text":"§ 9007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examinations and audits; repayments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47a9465a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examinations and audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After each presidential election, the Commission shall conduct a thorough examination and audit of the qualified campaign expenses of the candidates of each political party for President and Vice President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a9465b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47a9465c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9007/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Commission determines that any portion of the payments made to the eligible candidates of a political party under section 9006 was in excess of the aggregate payments to which candidates were entitled under section 9004, it shall so notify such candidates, and such candidates shall pay to the Secretary of the Treasury an amount equal to such portion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a9465d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9007/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Commission determines that the eligible candidates of a political party and their authorized committees incurred qualified campaign expenses in excess of the aggregate payments to which the eligible candidates of a major party were entitled under section 9004, it shall notify such candidates of the amount of such excess and such candidates shall pay to the Secretary of the Treasury an amount equal to such amount.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a9465e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9007/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Commission determines that the eligible candidates of a major party or any authorized committee of such candidates accepted contributions (other than contributions to make up deficiencies in payments out of the fund on account of the application of section 9006(c)) to defray qualified campaign expenses (other than qualified campaign expenses with respect to which payment is required under paragraph (2)), it shall notify such candidates of the amount of the contributions so accepted, and such candidates shall pay to the Secretary of the Treasury an amount equal to such amount.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a9465f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9007/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Commission determines that any amount of any payment made to the eligible candidates of a political party under section 9006 was used for any purpose other than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47a94660-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9007/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to defray the qualified campaign expenses with respect to which such payment was made, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47a94661-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9007/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to repay loans the proceeds of which were used, or otherwise to restore funds (other than contributions to defray qualified campaign expenses which were received and expended) which were used to defray such qualified campaign expenses,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"it shall notify such candidates of the amount so used, and such candidates shall pay to the Secretary of the Treasury an amount equal to such amount.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a94662-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9007/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No payment shall be required from the eligible candidates of a political party under this subsection to the extent that such payment, when added to other payments required from such candidates under this subsection, exceeds the amount of payments received by such candidates under section 9006.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a94663-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No notification shall be made by the Commission under subsection (b) with respect to a presidential election more than 3 years after the day of such election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a94664-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9007/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of repayments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All payments received by the Secretary of the Treasury under subsection (b) shall be deposited by him in the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47a94665-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/178/tVIII/s801"},"text":"Pub. L. 92–178, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/568"},"text":"85 Stat. 568","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/53/s6/c"},"text":"Pub. L. 93–53, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-07-01"},"text":"July 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/139"},"text":"87 Stat. 139","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/tIV/s404/c/9"},"text":"Pub. L. 93–443, title IV, § 404(c)(9)","children":[],"tail":"–(11), "},{"tag":"date","attrib":{"date":"1974-10-15"},"text":"Oct. 15, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1292"},"text":"88 Stat. 1292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/283/tIII/s307/e"},"text":"Pub. L. 94–283, title III, § 307(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/502"},"text":"90 Stat. 502","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/B"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(B)","children":[],"tail":", (C), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47a94666-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47a94667-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47a94668-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted “Secretary of the Treasury” for “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/283"},"text":"Pub. L. 94–283","children":[],"tail":" substituted “9006(c)” for “9006(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted “Secretary of the Treasury” for “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443/s404/c/9"},"text":"Pub. L. 93–443, § 404(c)(9)","children":[],"tail":", substituted “Commission” for “Comptroller General”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443/s404/c/10"},"text":"Pub. L. 93–443, § 404(c)(10)","children":[],"tail":", substituted “Commission” and “it” for “Comptroller General” and “he”, respectively, wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443/s404/c/11"},"text":"Pub. L. 93–443, § 404(c)(11)","children":[],"tail":", substituted “Commission” for “Comptroller General”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/53"},"text":"Pub. L. 93–53","children":[],"tail":" substituted section “9006(d)” for “9006(c)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47a94669-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47a9466a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443"},"text":"Pub. L. 93–443","children":[],"tail":" applicable with respect to taxable years beginning after "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/s410/c/1"},"text":"section 410(c)(1) of Pub. L. 93–443","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"