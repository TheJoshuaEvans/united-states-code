{"tag":"section","attrib":{"id":"id467cd4cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M"},"text":null,"children":[{"tag":"num","attrib":{"value":"6050M"},"text":"§ 6050M.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns relating to persons receiving contracts from Federal executive agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id467cd4cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of every Federal executive agency which enters into any contract shall make a return (at such time and in such form as the Secretary may by regulations prescribe) setting forth—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467cd4cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and TIN of each person with which such agency entered into a contract during the calendar year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd4ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467cd4cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal executive agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “Federal executive agency” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467cd4d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Executive agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":", United States Code) other than the Government Accountability Office,"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd4d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any military department (as defined in section 102 of such title), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd4d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Postal Service and the Postal Regulatory Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467cd4d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to extend reporting to licenses and subcontracts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent provided in regulations, this section also shall apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467cd4d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" licenses granted by Federal executive agencies, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd4d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subcontracts under contracts to which subsection (a) applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467cd4d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to prescribe minimum amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to contracts or licenses in any class which are below a minimum amount or value which may be prescribed by the Secretary by regulations for such class.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467cd4d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain classified or confidential contracts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467cd4d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), this section shall not apply in the case of a contract described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd4d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Federal executive agency which has entered into a contract described in paragraph (3) shall, upon a request of the Secretary which identifies a particular person, acknowledge whether such person has entered into such a contract with such agency and, if so, provide to the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467cd4da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information required under this section with respect to such person, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd4db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information with respect to such person which the Secretary and the head of such Federal executive agency agree is appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd4dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of contract","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, a contract between a Federal executive agency and another person is described in this paragraph if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467cd4dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fact of the existence of such contract or the subject matter of such contract has been designated and clearly marked or clearly represented, pursuant to the provisions of Federal law or an Executive order, as requiring a specific degree of protection against unauthorized disclosure for reasons of national security, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd4de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050M/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of such Federal executive agency (or his designee) pursuant to regulations issued by such agency determines, in writing, that filing the required return under this section would interfere with the effective conduct of a confidential law enforcement or foreign counterintelligence activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id467cd4df-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1522/a"},"text":"Pub. L. 99–514, title XV, § 1522(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2747"},"text":"100 Stat. 2747","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1015/f"},"text":"Pub. L. 100–647, title I, § 1015(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3570"},"text":"102 Stat. 3570","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s412/rr/2"},"text":"Pub. L. 109–135, title IV, § 412(rr)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2640"},"text":"119 Stat. 2640","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tVI/s604/f"},"text":"Pub. L. 109–435, title VI, § 604(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3242"},"text":"120 Stat. 3242","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id467cd4e0-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id467cd4e1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id467cd4e2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435"},"text":"Pub. L. 109–435","children":[],"tail":" substituted “Postal Regulatory Commission” for “Postal Rate Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id467cd4e3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id467cd4e4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id467cd4e5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1522/c"},"text":"Pub. L. 99–514, title XV, § 1522(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2747"},"text":"100 Stat. 2747","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXV/s1522/c"},"text":"“The amendments made by this section [enacting this section] shall apply to contracts (and subcontracts) entered into, and licenses granted, before, on, or after ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
