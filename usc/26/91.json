{"tag":"section","attrib":{"id":"id414cb482-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s91"},"text":null,"children":[{"tag":"num","attrib":{"value":"91"},"text":"§ 91.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain foreign branch losses transferred to specified 10-percent owned foreign corporations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id414cb483-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s91/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a domestic corporation transfers substantially all of the assets of a foreign branch (within the meaning of section 367(a)(3)(C), as in effect before the date of the enactment of the Tax Cuts and Jobs Act) to a specified 10-percent owned foreign corporation (as defined in section 245A) with respect to which it is a United States shareholder after such transfer, such domestic corporation shall include in gross income for the taxable year which includes such transfer an amount equal to the transferred loss amount with respect to such transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id414cb484-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s91/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transferred loss amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “transferred loss amount” means, with respect to any transfer of substantially all of the assets of a foreign branch, the excess (if any) of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id414cb485-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s91/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of losses—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id414cb486-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s91/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which were incurred by the foreign branch after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":", and before the transfer, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id414cb487-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s91/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which a deduction was allowed to the taxpayer, over","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id414cb488-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s91/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id414cb489-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s91/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any taxable income of such branch for a taxable year after the taxable year in which the loss was incurred and through the close of the taxable year of the transfer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id414cb48a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s91/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount which is recognized under section 904(f)(3) on account of the transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id414cb48b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s91/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction for recognized gains","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The transferred loss amount shall be reduced (but not below zero) by the amount of gain recognized by the taxpayer on account of the transfer (other than amounts taken into account under subsection (b)(2)(B)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id414cb48c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s91/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source of income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts included in gross income under this section shall be treated as derived from sources within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id414cb48d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s91/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent with such regulations or other guidance as the Secretary shall prescribe, proper adjustments shall be made in the adjusted basis of the taxpayer’s stock in the specified 10-percent owned foreign corporation to which the transfer is made, and in the transferee’s adjusted basis in the property transferred, to reflect amounts included in gross income under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id414cb48e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s14102/d/1"},"text":"Pub. L. 115–97, title I, § 14102(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2193"},"text":"131 Stat. 2193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id414cb48f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id414cb490-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id414cb491-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Tax Cuts and Jobs Act, referred to in subsec. (a), probably means the date of enactment of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":". Prior versions of the bill that was enacted into law as "},{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" included such Short Title, but it was not enacted as part of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id414cb492-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id414cb493-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s14102/d/3"},"text":"Pub. L. 115–97, title I, § 14102(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2194"},"text":"131 Stat. 2194","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/97/tI/s14102/d/3"},"text":"“The amendments made by this subsection [enacting this section] shall apply to transfers after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id414cb494-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transition Rule","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s14102/d/4"},"text":"Pub. L. 115–97, title I, § 14102(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2194"},"text":"131 Stat. 2194","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/97/tI/s14102/d/4"},"text":"“The amount of gain taken into account under section 91(c) of the Internal Revenue Code of 1986, as added by this subsection, shall be reduced by the amount of gain which would be recognized under section 367(a)(3)(C) (determined without regard to the amendments made by subsection (e) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s367"},"text":"section 367 of this title","children":[],"tail":"]) with respect to losses incurred before "},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
