. 95–600, title IV, § 405(c)(5)","children":[],"tail":", title VII, § 701(t)(3)(C), "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2871"},"text":"92 Stat. 2871","children":[],"tail":", 2912; "},{"tag":"ref","attrib":{"href":"/us/pl/96/223/tI/s101/f/1/C"},"text":"Pub. L. 96–223, title I, § 101(f)(1)(C)","children":[],"tail":", (4), (5), "},{"tag":"date","attrib":{"date":"1980-04-02"},"text":"Apr. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/252"},"text":"94 Stat. 252","children":[],"tail":", 253; "},{"tag":"ref","attrib":{"href":"/us/pl/96/589/s6/d/2"},"text":"Pub. L. 96–589, § 6(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3408"},"text":"94 Stat. 3408","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV/s442/d/4"},"text":"Pub. L. 97–34, title IV, § 442(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/323"},"text":"95 Stat. 323","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tI/s104/b/17"},"text":"Pub. L. 99–514, title I, § 104(b)(17)","children":[],"tail":", title XV, § 1562(a), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2106"},"text":"100 Stat. 2106","children":[],"tail":", 2761; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10713/b/2/C"},"text":"Pub. L. 100–203, title X, § 10713(b)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-470"},"text":"101 Stat. 1330–470","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1941/b/2/B/iii"},"text":"Pub. L. 100–418, title I, § 1941(b)(2)(B)(iii)","children":[],"tail":", (E), (F), "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1323"},"text":"102 Stat. 1323","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1015/m"},"text":"Pub. L. 100–647, title I, § 1015(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3572"},"text":"102 Stat. 3572","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tIII/s312/d/12"},"text":"Pub. L. 105–34, title III, § 312(d)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/840"},"text":"111 Stat. 840","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tI/s1102/b"},"text":"Pub. L. 105–206, title I, § 1102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/703"},"text":"112 Stat. 703","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46b87e4b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46b87e4c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46b87e4d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" inserted at end “Such notice shall include a notice to the taxpayer of the taxpayer’s right to contact a local office of the taxpayer advocate and the location and phone number of the appropriate office.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c)(2)(C) to (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":", which directed the amendment of par. (2) by striking out subpar. (C) and redesignating succeeding subpars. accordingly, was executed by redesignating subpar. (E) as (C) and striking out former subpar. (C). Prior to amendment, subpar. (C) read as follows: “Deficiency attributable to gain on sale or exchange of principal residence, see section 1034(j).” Former subpar. (D) was repealed previously."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1941/b/2/B/iii"},"text":"Pub. L. 100–418, § 1941(b)(2)(B)(iii)","children":[],"tail":", substituted “or 44” for “44, or 45”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1941/b/2/E"},"text":"Pub. L. 100–418, § 1941(b)(2)(E)","children":[],"tail":", substituted “or chapter 44” for “chapter 44, or chapter 45” and “chapter 44, and this chapter” for “chapter 44, chapter 45, and this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1941/b/2/F"},"text":"Pub. L. 100–418, § 1941(b)(2)(F)","children":[],"tail":", substituted “or of chapter 42 tax” for “of chapter 42 tax” and struck out “, or of chapter 45 tax for the same taxable period” after “such petition relates”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" inserted sentence at end that nothing in this subsection shall affect suspension of running of period of limitations during period during which rescinded notice was outstanding."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" inserted reference to section 6852."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s104/b/17"},"text":"Pub. L. 99–514, § 104(b)(17)","children":[],"tail":", amended subpar. (A) generally, substituting “, see section 63(e)(3)” for “and zero bracket amount, see section 63(g)(5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1562/a"},"text":"Pub. L. 99–514, § 1562(a)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" substituted “calendar year” for “calendar quarter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223/s101/f/1/C"},"text":"Pub. L. 96–223, § 101(f)(1)(C)","children":[],"tail":", inserted reference to chapter 45."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223/s101/f/4"},"text":"Pub. L. 96–223, § 101(f)(4)","children":[],"tail":", substituted “and certain excise taxes” for “taxes imposed by chapter 42” in section catchline and inserted references to chapter 45 in two places in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223/s101/f/5"},"text":"Pub. L. 96–223, § 101(f)(5)","children":[],"tail":", substituted “of chapter 42 tax” for “or of chapter 42 tax” and inserted “, or of chapter 45 tax for the same taxable period” after “to which such petition relates”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/589"},"text":"Pub. L. 96–589","children":[],"tail":" inserted cross reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s505/a"},"text":"section 505(a) of title 11","children":[],"tail":" for provisions allowing determination of tax in title 11 cases."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s701/t/3/C"},"text":"Pub. L. 95–600, § 701(t)(3)(C)","children":[],"tail":", substituted “same taxable year” for “same taxable years” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s405/c/5"},"text":"Pub. L. 95–600, § 405(c)(5)","children":[],"tail":", substituted “principal residence” for “personal residence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/30"},"text":"Pub. L. 95–30","children":[],"tail":" substituted “change of treatment with respect to itemized deductions and zero bracket amount, see section 63(g)(5)” for “change of election with respect to the standard deduction where taxpayer and his spouse made separate returns, see section 144(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 1307(d)(2)(F)(ii), 1605(b)(5)(A), 1906(b)(13)(A), struck out “or his delegate” after “Secretary”, and substituted “chapter 41, 42, 43, or 44” for “chapter 42 or 43”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 1307(d)(2)(G)(i), 1605(b)(5)(B), (C), 