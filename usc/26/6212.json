tIII/s3463/a"},"text":"“The Secretary of the Treasury or the Secretary’s delegate shall include on each notice of deficiency under section 6212 of the Internal Revenue Code of 1986 the date determined by such Secretary (or delegate) as the last day on which the taxpayer may file a petition with the Tax Court.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3463/a"},"text":"Section 3463(a) of Pub. L. 105–206","children":[],"tail":", set out above, applicable to notices mailed after "},{"tag":"date","attrib":{"date":"1998-12-31"},"text":"Dec. 31, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3463/c"},"text":"section 3463(c) of Pub. L. 105–206","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6213"},"text":"section 6213 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id46b87e5d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Explanations of Appeals and Collection Process","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3504"},"text":"Pub. L. 105–206, title III, § 3504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/771"},"text":"112 Stat. 771","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/206/tIII/s3504"},"text":"“The Secretary of the Treasury or the Secretary’s delegate shall, as soon as practicable, but not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":"], include with any first letter of proposed deficiency which allows the taxpayer an opportunity for administrative review in the Internal Revenue Service Office of Appeals [now Internal Revenue Service Independent Office of Appeals] an explanation of the entire process from examination through collection with respect to such proposed deficiency, including the assistance available to the taxpayer from the National Taxpayer Advocate at various points in the process.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
