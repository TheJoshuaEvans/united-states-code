{"tag":"section","attrib":{"id":"id41810a80-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139C"},"text":null,"children":[{"tag":"num","attrib":{"value":"139C"},"text":"§ 139C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain disability-related first responder retirement payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id41810a81-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual who receives qualified first responder retirement payments for any taxable year, gross income shall not include so much of such payments as do not exceed the annualized excludable disability amount with respect to such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41810a82-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified first responder retirement payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified first responder retirement payments” means, with respect to any taxable year, any pension or annuity which but for this section would be includible in gross income for such taxable year and which is received—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41810a83-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139C/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from a plan described in clause (iii), (iv), (v), or (vi) of section 402(c)(8)(B), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810a84-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139C/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with such individual’s qualified first responder service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41810a85-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annualized excludable disability amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41810a86-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139C/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “annualized excludable disability amount” means, with respect to any individual, the service-connected excludable disability amounts which are properly attributable to the 12-month period immediately preceding the date on which such individual attains retirement age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810a87-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139C/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service-connected excludable disability amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “service-connected excludable disability amount” means periodic payments received by an individual which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41810a88-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139C/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not includible in such individual’s gross income under section 104(a)(1),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41810a89-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139C/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are received in connection with such individual’s qualified first responder service, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41810a8a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139C/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminate when such individual attains retirement age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810a8b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139C/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for partial-year payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual who only receives service-connected excludable disability amounts properly attributable to a portion of the 12-month period described in paragraph (1), such paragraph shall be applied by multiplying such amounts by the ratio of 365 to the number of days in such period to which such amounts were properly attributable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41810a8c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139C/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified first responder service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “qualified first responder service” means service as a law enforcement officer, firefighter, paramedic, or emergency medical technician.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id41810a8d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dT/tIII/s309/a"},"text":"Pub. L. 117–328, div. T, title III, § 309(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5345"},"text":"136 Stat. 5345","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id41810a8e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id41810a8f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id41810a90-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tIII/s3001/a/15/A"},"text":"Pub. L. 111–5, div. B, title III, § 3001(a)(15)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/465"},"text":"123 Stat. 465","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/144/s3/b/5/B"},"text":"Pub. L. 111–144, § 3(b)(5)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-02"},"text":"Mar. 2, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/44"},"text":"124 Stat. 44","children":[],"tail":", related to COBRA premium assistance, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/d/7/C"},"text":"Pub. L. 115–141, div. U, title IV, § 401(d)(7)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1212"},"text":"132 Stat. 1212","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id41810a91-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id41810a92-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dT/tIII/s309/c"},"text":"Pub. L. 117–328, div. T, title III, § 309(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5346"},"text":"136 Stat. 5346","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dT/tIII/s309/c"},"text":"“The amendments made by this section [enacting this section] shall apply to amounts received with respect to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
