{"tag":"section","attrib":{"id":"id454936d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632"},"text":null,"children":[{"tag":"num","attrib":{"value":"2632"},"text":"§ 2632.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for allocation of GST exemption","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id454936d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time and manner of allocation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454936d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any allocation by an individual of his GST exemption under section 2631(a) may be made at any time on or before the date prescribed for filing the estate tax return for such individual’s estate (determined with regard to extensions), regardless of whether such a return is required to be filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454936d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe by forms or regulations the manner in which any allocation referred to in paragraph (1) is to be made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454936d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deemed allocation to certain lifetime direct skips","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454936d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any individual makes a direct skip during his lifetime, any unused portion of such individual’s GST exemption shall be allocated to the property transferred to the extent necessary to make the inclusion ratio for such property zero. If the amount of the direct skip exceeds such unused portion, the entire unused portion shall be allocated to the property transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454936d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unused portion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the unused portion of an individual’s GST exemption is that portion of such exemption which has not previously been allocated by such individual (or treated as allocated under paragraph (1) or subsection (c)(1)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454936d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsection not to apply in certain cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual may elect to have this subsection not apply to a transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454936d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deemed allocation to certain lifetime transfers to GST trusts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454936d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any individual makes an indirect skip during such individual’s lifetime, any unused portion of such individual’s GST exemption shall be allocated to the property transferred to the extent necessary to make the inclusion ratio for such property zero. If the amount of the indirect skip exceeds such unused portion, the entire unused portion shall be allocated to the property transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454936da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unused portion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the unused portion of an individual’s GST exemption is that portion of such exemption which has not previously been—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454936db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocated by such individual,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454936dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treated as allocated under subsection (b) with respect to a direct skip occurring during or before the calendar year in which the indirect skip is made, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454936dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treated as allocated under paragraph (1) with respect to a prior indirect skip.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454936de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454936df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indirect skip","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “indirect skip” means any transfer of property (other than a direct skip) subject to the tax imposed by chapter 12 made to a GST trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454936e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GST trust","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “GST trust” means a trust that could have a generation-skipping transfer with respect to the transferor unless—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id454936e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the trust instrument provides that more than 25 percent of the trust corpus must be distributed to or may be withdrawn by one or more individuals who are non-skip persons—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id454936e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the date that the individual attains age 46,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id454936e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on or before one or more dates specified in the trust instrument that will occur before the date that such individual attains age 46, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id454936e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/3/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon the occurrence of an event that, in accordance with regulations prescribed by the Secretary, may reasonably be expected to occur before the date that such individual attains age 46,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id454936e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trust instrument provides that more than 25 percent of the trust corpus must be distributed to or may be withdrawn by one or more individuals who are non-skip persons and who are living on the date of death of another person identified in the instrument (by name or by class) who is more than 10 years older than such individuals,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id454936e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trust instrument provides that, if one or more individuals who are non-skip persons die on or before a date or event described in clause (i) or (ii), more than 25 percent of the trust corpus either must be distributed to the estate or estates of one or more of such individuals or is subject to a general power of appointment exercisable by one or more of such individuals,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id454936e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trust is a trust any portion of which would be included in the gross estate of a non-skip person (other than the transferor) if such person died immediately after the transfer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id454936e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trust is a charitable lead annuity trust (within the meaning of section 2642(e)(3)(A)) or a charitable remainder annuity trust or a charitable remainder unitrust (within the meaning of section 664(d)), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id454936e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trust is a trust with respect to which a deduction was allowed under section 2522 for the amount of an interest in the form of the right to receive annual payments of a fixed percentage of the net fair market value of the trust property (determined yearly) and which is required to pay principal to a non-skip person if such person is alive when the yearly payments for which the deduction was allowed terminate.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of this subparagraph, the value of transferred property shall not be considered to be includible in the gross estate of a non-skip person or subject to a right of withdrawal by reason of such person holding a right to withdraw so much of such property as does not exceed the amount referred to in section 2503(b) with respect to any transferor, and it shall be assumed that powers of appointment held by non-skip persons will not be exercised.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454936ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automatic allocations to certain GST trusts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, an indirect skip to which section 2642(f) applies shall be deemed to have been made only at the close of the estate tax inclusion period. The fair market value of such transfer shall be the fair market value of the trust property at the close of the estate tax inclusion period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454936eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability and effect","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454936ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id454936ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may elect to have this subsection not apply to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id454936ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/5/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an indirect skip, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id454936ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/5/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any or all transfers made by such individual to a particular trust, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id454936f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may elect to treat any trust as a GST trust for purposes of this subsection with respect to any or all transfers made by such individual to such trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454936f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elections","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id454936f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elections with respect to indirect skips","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under subparagraph (A)(i)(I) shall be deemed to be timely if filed on a timely filed gift tax return for the calendar year in which the transfer was made or deemed to have been made pursuant to paragraph (4) or on such later date or dates as may be prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id454936f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/c/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other elections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under clause (i)(II) or (ii) of subparagraph (A) may be made on a timely filed gift tax return for the calendar year for which the election is to become effective.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454936f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retroactive allocations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454936f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454936f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a non-skip person has an interest or a future interest in a trust to which any transfer has been made,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454936f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id454936f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a lineal descendant of a grandparent of the transferor or of a grandparent of the transferor’s spouse or former spouse, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id454936f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is assigned to a generation below the generation assignment of the transferor, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454936fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person predeceases the transferor,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then the transferor may make an allocation of any of such transferor’s unused GST exemption to any previous transfer or transfers to the trust on a chronological basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454936fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the allocation under paragraph (1) by the transferor is made on a gift tax return filed on or before the date prescribed by section 6075(b) for gifts made within the calendar year within which the non-skip person’s death occurred—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454936fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of such transfer or transfers for purposes of section 2642(a) shall be determined as if such allocation had been made on a timely filed gift tax return for each calendar year within which each transfer was made,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454936fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such allocation shall be effective immediately before such death, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454936fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the transferor’s unused GST exemption available to be allocated shall be determined immediately before such death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454936ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Future interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, a person has a future interest in a trust if the trust may permit income or corpus to be paid to such person on a date or dates in the future.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45493700-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of unused GST exemption","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45493701-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any portion of an individual’s GST exemption which has not been allocated within the time prescribed by subsection (a) shall be deemed to be allocated as follows—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45493702-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first, to property which is the subject of a direct skip occurring at such individual’s death, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45493703-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" second, to trusts with respect to which such individual is the transferor and from which a taxable distribution or a taxable termination might occur at or after such individual’s death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45493704-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation within categories","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45493705-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The allocation under paragraph (1) shall be made among the properties described in subparagraph (A) thereof and the trusts described in subparagraph (B) thereof, as the case may be, in proportion to the respective amounts (at the time of allocation) of the nonexempt portions of such properties or trusts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45493706-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2632/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonexempt portion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the term “nonexempt portion” means the value (at the time of allocation) of the property or trust, multiplied by the inclusion ratio with respect to such property or trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45493707-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIV/s1431/a"},"text":"Pub. L. 99–514, title XIV, § 1431(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2721"},"text":"100 Stat. 2721","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1014/g/16"},"text":"Pub. L. 100–647, title I, § 1014(g)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3566"},"text":"102 Stat. 3566","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tV/s561/a"},"text":"Pub. L. 107–16, title V, § 561(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/86"},"text":"115 Stat. 86","children":[],"tail":", 89.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45493708-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45493709-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4549370a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s561/b"},"text":"Pub. L. 107–16, § 561(b)","children":[],"tail":", substituted “or subsection (c)(1)” for “with respect to a prior direct skip”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s561/a"},"text":"Pub. L. 107–16, § 561(a)","children":[],"tail":", added subsecs. (c) and (d) and redesignated former subsec. (c) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" substituted “paragraph (1) with respect to a prior direct skip)” for “paragraph (1)) with respect to a prior direct skip”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4549370b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":nul