{"tag":"section","attrib":{"id":"id4404f75c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s755"},"text":null,"children":[{"tag":"num","attrib":{"value":"755"},"text":"§ 755.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules for allocation of basis","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4404f75d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s755/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any increase or decrease in the adjusted basis of partnership property under section 734(b) (relating to the optional adjustment to the basis of undistributed partnership property) or section 743(b) (relating to the optional adjustment to the basis of partnership property in the case of a transfer of an interest in a partnership) shall, except as provided in subsection (b), be allocated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4404f75e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s755/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner which has the effect of reducing the difference between the fair market value and the adjusted basis of partnership properties, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4404f75f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s755/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any other manner permitted by regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4404f760-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s755/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In applying the allocation rules provided in subsection (a), increases or decreases in the adjusted basis of partnership property arising from a distribution of, or a transfer of an interest attributable to, property consisting of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4404f761-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s755/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capital assets and property described in section 1231(b), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4404f762-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s755/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other property of the partnership,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be allocated to partnership property of a like character except that the basis of any such partnership property shall not be reduced below zero. If, in the case of a distribution, the adjustment to basis of property described in paragraph (1) or (2) is prevented by the absence of such property or by insufficient adjusted basis for such property, such adjustment shall be applied to subsequently acquired property of a like character in accordance with regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4404f763-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s755/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No allocation of basis decrease to stock of corporate partner","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making an allocation under subsection (a) of any decrease in the adjusted basis of partnership property under section 734(b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4404f764-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s755/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no allocation may be made to stock in a corporation (or any person related (within the meaning of sections 267(b) and 707(b)(1)) to such corporation) which is a partner in the partnership, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4404f765-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s755/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount not allocable to stock by reason of paragraph (1) shall be allocated under subsection (a) to other partnership property.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Gain shall be recognized to the partnership to the extent that the amount required to be allocated under paragraph (2) to other partnership property exceeds the aggregate adjusted basis of such other property immediately before the allocation required by paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4404f766-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/252"},"text":"68A Stat. 252","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s834/a"},"text":"Pub. L. 108–357, title VIII, § 834(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1592"},"text":"118 Stat. 1592","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4404f767-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4404f768-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4404f769-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4404f76a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4404f76b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s834/b"},"text":"Pub. L. 108–357, title VIII, § 834(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1592"},"text":"118 Stat. 1592","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tVIII/s834/b"},"text":"“The amendment made by this section [amending this section] shall apply to distributions after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
