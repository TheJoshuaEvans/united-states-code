{"tag":"section","attrib":{"id":"id4546c546-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2603"},"text":null,"children":[{"tag":"num","attrib":{"value":"2603"},"text":"§ 2603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4546c547-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal liability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4546c548-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2603/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable distributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a taxable distribution, the tax imposed by section 2601 shall be paid by the transferee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4546c549-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2603/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a taxable termination or a direct skip from a trust, the tax shall be paid by the trustee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4546c54a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2603/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct skip","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a direct skip (other than a direct skip from a trust), the tax shall be paid by the transferor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4546c54b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless otherwise directed pursuant to the governing instrument by specific reference to the tax imposed by this chapter, the tax imposed by this chapter on a generation-skipping transfer shall be charged to the property constituting such transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4546c54c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions making estate and gift tax provisions with respect to transferee liability, liens, and related matters applicable to the tax imposed by section 2601, see section 2661.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4546c54d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2006/a"},"text":"Pub. L. 94–455, title XX, § 2006(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1881"},"text":"90 Stat. 1881","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIV/s1431/a"},"text":"Pub. L. 99–514, title XIV, § 1431(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2718"},"text":"100 Stat. 2718","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4546c54e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4546c54f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4546c550-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" amended section generally, substituting tax liability provisions consisting of language placing liability, under different circumstances, on the transferee, the trustee, or the transferor, the source of the tax, and a cross reference to section 2661 for former provisions which covered the question of liability for tax with language covering the trustee and the distributee, the limitation on personal liability of the trustee who relied on certain information furnished by the Secretary, the limitation on personal liability of distributee, and the lien on property transferred until the tax was paid in full or became unenforceable by reason of lapse of time."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4546c551-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4546c552-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to generation-skipping transfers (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s2611"},"text":"section 2611 of this title","children":[],"tail":") made after "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1433"},"text":"section 1433 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2601"},"text":"section 2601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
