{"tag":"section","attrib":{"id":"id46cdda78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6326"},"text":null,"children":[{"tag":"num","attrib":{"value":"6326"},"text":"§ 6326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative appeal of liens","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46cdda79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6326/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In such form and at such time as the Secretary shall prescribe by regulations, any person shall be allowed to appeal to the Secretary after the filing of a notice of a lien under this subchapter on the property or the rights to property of such person for a release of such lien alleging an error in the filing of the notice of such lien.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46cdda7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6326/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificate of release","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that the filing of the notice of any lien was erroneous, the Secretary shall expeditiously (and, to the extent practicable, within 14 days after such determination) issue a certificate of release of such lien and shall include in such certificate a statement that such filing was erroneous.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46cdda7b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6238/a"},"text":"Pub. L. 100–647, title VI, § 6238(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3743"},"text":"102 Stat. 3743","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46cdda7c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46cdda7d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46cdda7e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6326 was renumbered 6327 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46cdda7f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46cdda80-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6238/d"},"text":"Pub. L. 100–647, title VI, § 6238(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3743"},"text":"102 Stat. 3743","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tVI/s6238/d"},"text":"“The amendments made by this section [enacting this section] shall take effect on the date which is 60 days after the date regulations are issued under subsection (b) [set out below].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id46cdda81-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6238/b"},"text":"Pub. L. 100–647, title VI, § 6238(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3743"},"text":"102 Stat. 3743","children":[],"tail":", required Secretary of the Treasury or Secretary’s delegate to prescribe regulations necessary to implement administrative appeal provided for in amendment made by subsection (a) [enacting this section] within 180 days after "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
