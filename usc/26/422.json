7-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/898"},"text":"98 Stat. 898","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1855/a/1"},"text":"Pub. L. 99–514, title XVIII, § 1855(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2882"},"text":"100 Stat. 2882","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXVIII/s1855/a/1"},"text":"“The amendment made by subsection (a)(1) [amending this section] shall apply to options granted after ","children":[{"tag":"date","attrib":{"date":"1984-03-20"},"text":"March 20, 1984","children":[],"tail":", except that such subsection shall not apply to any incentive stock option granted before "},{"tag":"date","attrib":{"date":"1984-09-20"},"text":"September 20, 1984","children":[],"tail":", pursuant to a plan adopted or corporate action taken by the board of directors of the grantor corporation before "},{"tag":"date","attrib":{"date":"1984-05-15"},"text":"May 15, 1984","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s2662"},"text":"section 2662 of Pub. L. 98–369","children":[],"tail":" effective as though included in the enactment of the Social Security Amendments of 1983, "},{"tag":"ref","attrib":{"href":"/us/pl/98/21"},"text":"Pub. L. 98–21","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s2664/a"},"text":"section 2664(a) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s401"},"text":"section 401 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id435b96dd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448"},"text":"Pub. L. 97–448","children":[],"tail":" effective, except as otherwise provided, as if it had been included in the provision of the Economic Recovery Tax Act of 1981, "},{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/s109"},"text":"section 109 of Pub. L. 97–448","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id435b96de-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/tII/s251/c"},"text":"Pub. L. 97–34, title II, § 251(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/259"},"text":"95 Stat. 259","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Options to which section applies.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general.—","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (B), the amendments made by this section [enacting this section and amending sections 421, 425 [now 424], and 6039 of this title] shall apply with respect to options granted on or after ","children":[{"tag":"date","attrib":{"date":"1976-01-01"},"text":"January 1, 1976","children":[],"tail":", and exercised on or after "},{"tag":"date","attrib":{"date":"1981-01-01"},"text":"January 1, 1981","children":[],"tail":", or outstanding on such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election and designation of options.—","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of an option granted before ","children":[{"tag":"date","attrib":{"date":"1981-01-01"},"text":"January 1, 1981","children":[],"tail":", the amendments made by this section shall apply only if the corporation granting such option elects (in the manner and at the time prescribed by the Secretary of the Treasury or his delegate) to have the amendments made by this section apply to such option. The aggregate fair market value (determined at the time the option is granted) of the stock for which any employee was granted options (under all plans of his employer corporation and its parent and subsidiary corporations) to which the amendments made by this section apply by reason of this subparagraph shall not exceed $50,000 per calendar year ans shall not exceed $200,000 in the aggregate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Changes in terms of options.—","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of an option granted on or after ","children":[{"tag":"date","attrib":{"date":"1976-01-01"},"text":"January 1, 1976","children":[],"tail":", and outstanding on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":"], paragraph (1) of section 425(h) of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] shall not apply to any change in the terms of such option (or the terms of the plan under which granted, including shareholder approval) made within 1 year after such date of enactment to permit such option to qualify as a incentive stock option.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id435b96df-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that nothing in amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" be construed to affect treatment of certain transactions occurring, property acquired, or items of income, loss, deduction, or credit taken into account prior to "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", for purposes of determining liability for tax for periods ending after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11821/b"},"text":"section 11821(b) of Pub. L. 101–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s45K"},"text":"section 45K of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id435b96e0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Treatment of Options as Incentive Stock Options","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1003/d/1/B"},"text":"Pub. L. 100–647, title I, § 1003(d)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3384"},"text":"102 Stat. 3384","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1003/d/1/B"},"text":"“In the case of an option granted after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", and on or before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":"], such option shall not be treated as an incentive stock option if the terms of such option are amended before the date 90 days after such date of enactment to provide that such option will not be treated as an incentive stock option.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id435b96e1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1800–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
