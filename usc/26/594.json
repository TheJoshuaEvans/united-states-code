{"tag":"section","attrib":{"id":"id43dc5ff1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s594"},"text":null,"children":[{"tag":"num","attrib":{"value":"594"},"text":"§ 594.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative tax for mutual savings banks conducting life insurance business","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43dc5ff2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s594/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a mutual savings bank not having capital stock represented by shares, authorized under State law to engage in the business of issuing life insurance contracts, and which conducts a life insurance business in a separate department the accounts of which are maintained separately from the other accounts of the mutual savings bank, there shall be imposed in lieu of the tax imposed by section 11, a tax consisting of the sum of the partial taxes determined under paragraphs (1) and (2):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43dc5ff3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s594/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A partial tax computed on the taxable income determined without regard to any items of gross income or deductions properly allocable to the business of the life insurance department, at the rates and in the manner as if this section had not been enacted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43dc5ff4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s594/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partial tax computed on the income of the life insurance department determined without regard to any items of gross income or deductions not properly allocable to such department, at the rates and in the manner provided in subchapter L (sec. 801 and following) with respect to life insurance companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43dc5ff5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s594/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall apply only if the life insurance department would, if it were treated as a separate corporation, qualify as a life insurance company under section 816.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43dc5ff6-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/205"},"text":"68A Stat. 205","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-03-13/ch83/s5/3"},"text":"Mar. 13, 1956, ch. 83, § 5(3)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/49"},"text":"70 Stat. 49","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tII/s211/b/8"},"text":"Pub. L. 98–369, div. A, title II, § 211(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/755"},"text":"98 Stat. 755","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13001/b/2/E"},"text":"Pub. L. 115–97, title I, § 13001(b)(2)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2096"},"text":"131 Stat. 2096","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43dc5ff7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43dc5ff8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43dc5ff9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" substituted “tax imposed by section 11” for “taxes imposed by section 11 or section 1201(a)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “section 816” for “section 801”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Subsec. (a)(2). Act ","children":[{"tag":"date","attrib":{"date":"1956-03-13"},"text":"Mar. 13, 1956","children":[],"tail":", substituted “the income” for “the taxable income (as defined in section 803)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43dc5ffa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43dc5