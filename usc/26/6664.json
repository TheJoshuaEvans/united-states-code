{"tag":"section","attrib":{"id":"id47263396-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664"},"text":null,"children":[{"tag":"num","attrib":{"value":"6664"},"text":"§ 6664.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47263397-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underpayment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, the term “underpayment” means the amount by which any tax imposed by this title exceeds the excess of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47263398-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47263399-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount shown as the tax by the taxpayer on his return, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4726339a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts not so shown previously assessed (or collected without assessment), over","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4726339b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of rebates made.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of paragraph (2), the term “rebate” means so much of an abatement, credit, refund, or other repayment, as was made on the ground that the tax imposed was less than the excess of the amount specified in paragraph (1) over the rebates previously made. A rule similar to the rule of section 6211(b)(4) shall apply for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4726339c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties applicable only where return filed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalties provided in this part shall apply only in cases where a return of tax is filed (other than a return prepared by the Secretary under the authority of section 6020(b)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4726339d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable cause exception for underpayments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4726339e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed under section 6662 or 6663 with respect to any portion of an underpayment if it is shown that there was a reasonable cause for such portion and that the taxpayer acted in good faith with respect to such portion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4726339f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to any portion of an underpayment which is attributable to one or more transactions described in section 6662(b)(6) or to any disallowance of a deduction described in section 6662(b)(10).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472633a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for certain valuation overstatements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any underpayment attributable to a substantial or gross valuation overstatement under chapter 1 with respect to charitable deduction property, paragraph (1) shall not apply. The preceding sentence shall not apply to a substantial valuation overstatement under chapter 1 if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id472633a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claimed value of the property was based on a qualified appraisal made by a qualified appraiser, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id472633a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in addition to obtaining such appraisal, the taxpayer made a good faith investigation of the value of the contributed property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472633a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id472633a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charitable deduction property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “charitable deduction property” means any property contributed by the taxpayer in a contribution for which a deduction was claimed under section 170. For purposes of paragraph (3), such term shall not include any securities for which (as of the date of the contribution) market quotations are readily available on an established securities market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id472633a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified appraisal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified appraisal” has the meaning given such term by section 170(f)(11)(E)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id472633a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified appraiser","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified appraiser” has the meaning given such term by section 170(f)(11)(E)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472633a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable cause exception for reportable transaction understatements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472633a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed under section 6662A with respect to any portion of a reportable transaction understatement if it is shown that there was a reasonable cause for such portion and that the taxpayer acted in good faith with respect to such portion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472633a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to any portion of a reportable transaction understatement which is attributable to one or more transactions described in section 6662(b)(6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472633aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to any reportable transaction understatement unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id472633ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relevant facts affecting the tax treatment of the item are adequately disclosed in accordance with the regulations prescribed under section 6011,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id472633ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is or was substantial authority for such treatment, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id472633ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer reasonably believed that such treatment was more likely than not the proper treatment.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A taxpayer failing to adequately disclose in accordance with section 6011 shall be treated as meeting the requirements of subparagraph (A) if the penalty for such failure was rescinded under section 6707A(d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472633ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules relating to reasonable belief","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (3)(C)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id472633af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A taxpayer shall be treated as having a reasonable belief with respect to the tax treatment of an item only if such belief—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id472633b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is based on the facts and law that exist at the time the return of tax which includes such tax treatment is filed, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id472633b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relates solely to the taxpayer’s chances of success on the merits of such treatment and does not take into account the possibility that a return will not be audited, such treatment will not be raised on audit, or such treatment will be resolved through settlement if it is raised.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id472633b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain opinions may not be relied upon","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id472633b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An opinion of a tax advisor may not be relied upon to establish the reasonable belief of a taxpayer if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id472633b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax advisor is described in clause (ii), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id472633b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the opinion is described in clause (iii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id472633b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualified tax advisors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A tax advisor is described in this clause if the tax advisor—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id472633b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a material advisor (within the meaning of section 6111(b)(1)) and participates in the organization, management, promotion, or sale of the transaction or is related (within the meaning of section 267(b) or 707(b)(1)) to any person who so participates,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id472633b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is compensated directly or indirectly by a material advisor with respect to the transaction,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id472633b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/4/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a fee arrangement with respect to the transaction which is contingent on all or part of the intended tax benefits from the transaction being sustained, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id472633ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/4/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as determined under regulations prescribed by the Secretary, has a disqualifying financial interest with respect to the transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id472633bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualified opinions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of clause (i), an opinion is disqualified if the opinion—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id472633bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/4/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is based on unreasonable factual or legal assumptions (including assumptions as to future events),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id472633bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/4/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unreasonably relies on representations, statements, findings, or agreements of the taxpayer or any other person,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id472633be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/4/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not identify and consider all relevant facts, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id472633bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6664/d/4/B/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to meet any other requirement as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id472633c0-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7721/a"},"text":"Pub. L. 101–239, title VII, § 7721(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2398"},"text":"103 Stat. 2398","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s812/c"},"text":"Pub. L. 108–357, title VIII, § 812(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1579"},"text":"118 Stat. 1579","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1219/a/3"},"text":"Pub. L. 109–280, title XII, § 1219(a)(3)","children":[],"tail":", (c)(2), "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1084"},"text":"120 Stat. 1084","children":[],"tail":", 1085; "},{"tag":"ref","attrib":{"href":"/us/pl/111/152/tI/s1409/c"},"text":"Pub. L. 111–152, title I, § 1409(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-30"},"text":"Mar. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1069"},"text":"124 Stat. 1069","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tII/s209/a"},"text":"Pub. L. 114–113, div. Q, title II, § 209(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3084"},"text":"129 Stat. 3084","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dT/tVI/s605/a/2/C"},"text":"Pub. L. 117–328, div. T, title VI, § 605(a)(2)(C)","children":[],"tail":", "},{"tag":"date",