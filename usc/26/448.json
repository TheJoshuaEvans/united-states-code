{"tag":"section","attrib":{"id":"id437a90c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448"},"text":null,"children":[{"tag":"num","attrib":{"value":"448"},"text":"§ 448.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of cash method of accounting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id437a90c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section, in the case of a—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id437a90c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" C corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id437a90c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partnership which has a C corporation as a partner, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id437a90c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tax shelter,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"taxable income shall not be computed under the cash receipts and disbursements method of accounting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id437a90ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id437a90cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farming business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraphs (1) and (2) of subsection (a) shall not apply to any farming business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id437a90cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified personal service corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraphs (1) and (2) of subsection (a) shall not apply to a qualified personal service corporation, and such a corporation shall be treated as an individual for purposes of determining whether paragraph (2) of subsection (a) applies to any partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id437a90cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entities which meet gross receipts test","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraphs (1) and (2) of subsection (a) shall not apply to any corporation or partnership for any taxable year if such entity (or any predecessor) meets the gross receipts test of subsection (c) for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id437a90ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gross receipts test","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id437a90cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A corporation or partnership meets the gross receipts test of this subsection for any taxable year if the average annual gross receipts of such entity for the 3-taxable-year period ending with the taxable year which precedes such taxable year does not exceed $25,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id437a90d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregation rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All persons treated as a single employer under subsection (a) or (b) of section 52 or subsection (m) or (","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of section 414 shall be treated as one person for purposes of paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id437a90d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id437a90d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Not in existence for entire 3-year period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the entity was not in existence for the entire 3-year period referred to in paragraph (1), such paragraph shall be applied on the basis of the period during which such entity (or trade or business) was in existence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id437a90d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short taxable years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross receipts for any taxable year of less than 12 months shall be annualized by multiplying the gross receipts for the short period by 12 and dividing the result by the number of months in the short period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id437a90d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gross receipts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross receipts for any taxable year shall be reduced by returns and allowances made during such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id437a90d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of predecessors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in this subsection to an entity shall include a reference to any predecessor of such entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id437a90d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment for inflation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":", the dollar amount in paragraph (1) shall be increased by an amount equal to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id437a90d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dollar amount, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id437a90d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost-of-living adjustment determined under section 1(f)(3) for the calendar year in which the taxable year begins, by substituting “calendar year 2017” for “calendar year 2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If any amount as increased under the preceding sentence is not a multiple of $1,000,000, such amount shall be rounded to the nearest multiple of $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id437a90d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id437a90da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farming business","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id437a90db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “farming business” means the trade or business of farming (within the meaning of section 263A(e)(4)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id437a90dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timber and ornamental trees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “farming business” includes the raising, harvesting, or growing of trees to which section 263A(c)(5) applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id437a90dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified personal service corporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified personal service corporation” means any corporation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id437a90de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially all of the activities of which involve the performance of services in the fields of health, law, engineering, architecture, accounting, actuarial science, performing arts, or consulting, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id437a90df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" substantially all of the stock of which (by value) is held directly (or indirectly through 1 or more partnerships, S corporations, or qualified personal service corporations not described in paragraph (2) or (3) of subsection (a)) by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id437a90e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees performing services for such corporation in connection with the activities involving a field referred to in subparagraph (A),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id437a90e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retired employees who had performed such services for such corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id437a90e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estate of any individual described in clause (i) or (ii), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id437a90e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person who acquired such stock by reason of the death of an individual described in clause (i) or (ii) (but only for the 2-year period beginning on the date of the death of such individual).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"To the extent provided in regulations which shall be prescribed by the Secretary, indirect holdings through a trust shall be taken into account under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id437a90e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax shelter defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tax shelter” has the meaning given such term by section 461(i)(3) (determined after application of paragraph (4) thereof). An S corporation shall not be treated as a tax shelter for purposes of this section merely by reason of being required to file a notice of exemption from registration with a State agency described in section 461(i)(3)(A), but only if there is a requirement applicable to all corporations offering securities for sale in the State that to be exempt from such registration the corporation must file such a notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id437a90e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for application of paragraph (2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id437a90e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community property laws shall be disregarded,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id437a90e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stock held by a plan described in section 401(a) which is exempt from tax under section 501(a) shall be treated as held by an employee described in paragraph (2)(B)(i), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id437a90e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the election of the common parent of an affiliated group (within the meaning of section 1504(a)), all members of such group may be treated as 1 taxpayer for purposes of paragraph (2)(B) if 90 percent or more of the activities of such group involve the performance of services in the same field described in paragraph (2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id437a90e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for certain services","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id437a90ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any person using an accrual method of accounting with respect to amounts to be received for the performance of services by such person, such person shall not be required to accrue any portion of such amounts which (on the basis of such person’s experience) will not be collected if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id437a90eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such services are in fields referred to in paragraph (2)(A), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id437a90ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person meets the gross receipts test of subsection (c) for all prior taxable years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id437a90ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This paragraph shall not apply to any amount if interest is required to be paid on such amount or there is any penalty for failure to timely pay such amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id437a90ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe regulations to permit taxpayers to determine amounts referred to in subparagraph (A) using computations or formulas which, based on experience, accurately reflect the amount of income that will not be collected by such person. A taxpayer may adopt, or request consent of the Secretary to change to, a computation or formula that clearly reflects the taxpayer’s experience. A request under the preceding sentence shall be approved if such computation or formula clearly reflects the taxpayer’s experience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id437a90ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain trusts subject to tax on unrelated business income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, a trust subject to tax under section 511(b) shall be treated as a C corporation with respect to its activities constituting an unrelated trade or business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id437a90f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with section 481","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any change in method of accounting made pursuant to this section shall be treated for purposes of section 481 as initiated by the taxpayer and made with the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id437a90f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s448/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of related parties, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to prevent the use of related parties, pass-thru entities, or intermediaries to avoid the application of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id437a90f2-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVIII/s801/a"},"text":"Pub. L. 99–514, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2345"},"text":"100 Stat. 2345","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1008/a/1"},"text":"Pub. L. 100–647, title I, § 1008(a)(1)","children":[],"tail":", (2), (7)–(9), title VI, § 6032(a), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3436"},"text":"102 Stat. 3436","children":[],"tail":", 3437, 3695; "},{"tag":"ref","attrib":{"href":"/us/pl/107/147/tIV/s403/a"},"text":"Pub. L. 107–147, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-09"},"text":"Mar. 9, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/40"},"text":"116 Stat. 40","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13102/a/1"},"text":"Pub. L. 115–97, title I, § 13102(a)(1)","children":[],"tail":"–(4), "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2102"},"text":"131 Stat. 2102","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id437a90f3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id437a90f4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inflation Adjusted Items for Certain Years","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For inflation adjustment of certain items in this section, see Revenue Procedures listed in a table under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id437a90f5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id437a90f6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13102/a/2"},"text":"Pub. L. 115–97, § 13102(a)(2)","children":[],"tail":", amended par. (3) generally. Prior to amendment, text read as follows: “Paragraphs (1) and (2) of subsection (a) shall not apply to any corporation or partnership for any taxable year if, for all prior taxable years beginning after "},{"tag":"date","attrib":{"date":"1985-12-31"},"text":"December 31, 1985","children":[],"tail":", such entity (or any predecessor) met the $5,000,000 gross receipts test of subsection (c).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13102/a/1"},"text":"Pub. L. 115–97, § 13102(a)(1)","children":[],"tail":", substituted “Gross receipts test” for “$5,000,000 gross receipts test” in heading and amended introductory provisions and par. (1) generally. Prior to amendment, text read as follows: “For purposes of this section—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—A corporation or partnership meets the $5,000,000 gross receipts test of this subsection for any prior taxable year if the average annual gross receipts of such entity for the 3-taxable-year period ending with such prior taxable year does not exceed $5,000,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13102/a/3"},"text":"Pub. L. 115–97, § 13102(a)(3)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13102/a/4"},"text":"Pub. L. 115–97, § 13102(a)(4)","children":[],"tail":", amended par. (7) generally. Prior to amendment, par. (7) related to coordination with section 481."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147"},"text":"Pub. L. 107–147","children":[],"tail":" amended heading and text of par. (5) generally. Prior to amendment, text read as follows: “In the case of any person using an accrual method of accounting with respect to amounts to be received for the performance of services by such person, such person shall not be required to accrue any portion of such amounts which (on the basis of experience) will not be collected. This paragraph shall not apply to any amount if interest is required to be paid on such amount or there is any penalty for failure to timely pay such amount.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1008/a/9"},"text":"Pub. L. 100–647, § 1008(a)(9)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s6032/a"},"text":"Pub. L. 100–647, § 6032(a)","children":[],"tail":", inserted at end “To the extent provided in regulations which shall be prescribed by the Secretary, indirect holdings through a trust shall be taken into account under subparagraph (B).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1008/a/1/A"},"text":"Pub. L. 100–647, § 1008(a)(1)(A)","children":[],"tail":", substituted “(or indirectly through 1 or more partnerships, S corporations, or qualified personal service corporations not described in paragraph (2) or (3) of subsection (a))” for “or indirectly”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1008/a/7"},"text":"Pub. L. 100–647, § 1008(a)(7)","children":[],"tail":", inserted sentence at end relating to treatment of S corporation as tax shelter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1008/a/8"},"text":"Pub. L. 100–647, § 1008(a)(8)","children":[],"tail":", substituted “90 percent or more of” for “substantially all of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1008/a/2"},"text":"Pub. L. 100–647, § 1008(a)(2)","children":[],"tail":", substituted “such group” for “all such members”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1008/a/1/B"},"text":"Pub. L. 100–647, § 1008(a)(1)(B)","children":[],"tail":", added par. (8)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id437a90f7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id437a90f8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13102/e"},"text":"section 13102(e) of Pub. L. 115–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s263A"},"text":"section 263A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id437a90f9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147/tIV/s403/b"},"text":"Pub. L. 107–147, title IV, § 403(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-09"},"text":"Mar. 9, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/41"},"text":"116 Stat. 41","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/147/tIV/s403/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section] shall apply to taxable years ending after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-03-09"},"text":"Mar. 9, 2002","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Change in method of accounting","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any taxpayer required by the amendments made by this section to change its method of accounting for its first taxable year ending after the date of the enactment of this Act—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such change shall be treated as initiated by the taxpayer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such change shall be treated as made with the consent of the Secretary of the Treasury, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the net amount of the adjustments required to be taken into account by the taxpayer under section 481 of the Internal Revenue Code of 1986 shall be taken into account over a period of 4 years (or if less, the number of taxable years that the taxpayer used the method permitted under section 448(d)(5) of such Code as in effect before the date of the enactment of this Act) beginning with such first taxable year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id437a90fa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 1008(a)(1), (2), (7)–(9) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6032/b"},"text":"Pub. L. 100–647, title VI, § 6032(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3695"},"text":"102 Stat. 3695","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tVI/s6032/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id437a90fb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVIII/s801/d"},"text":"Pub. L. 99–514, title VIII, § 801(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2348"},"text":"100 Stat. 2348","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1008/a/5"},"text":"Pub. L. 100–647, title I, § 1008(a)(5)","children":[],"tail":", (6), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3437"},"text":"102 Stat. 3437","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1008/a/5"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s461"},"text":"section 461 of this title","children":[],"tail":"] shall apply to taxable years beginning after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election to retain cash method for certain transactions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A taxpayer may elect not to have the amendments made by this section apply to any loan or lease, or any transaction with a related party (within the meaning of section 267(b) of the Internal Revenue Code of 1954, as in effect before the enactment of this Act), entered into on or before ","children":[{"tag":"date","attrib":{"date":"1985-09-25"},"text":"September 25, 1985","children":[],"tail":". Any election under the preceding sentence may be made separately with respect to each transaction."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain contracts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amendments made by this section shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contracts for the acquisition or transfer of real property, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contracts for services related to the acquisition or development of real property,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but only if such contracts were entered into before ","children":[{"tag":"date","attrib":{"date":"1985-09-25"},"text":"September 25, 1985","children":[],"tail":", and the sole element of the contract which has not been performed as of "},{"tag":"date","attrib":{"date":"1985-09-25"},"text":"September 25, 1985","children":[],"tail":", is payment for such property or services."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of affiliated group providing engineering services","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each member of an affiliated group of corporations (within the meaning of section 1504(a) of the Internal Revenue Code of 1986) shall be allowed to use the cash receipts and disbursements method of accounting for any trade or business of providing engineering services with respect to taxable years ending after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", if the common parent of such group—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was incorporated in the State of Delaware in 1970,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was the successor to a corporation that was incorporated in the State of Illinois in 1949, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used a method of accounting for long-term contracts of accounting [sic] for a substantial part of its income from the performance of engineering services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for paragraphs (2) and (3)","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any loan, lease, contract, or evidence of any transaction to which paragraph (2) or (3) applies is transferred after ","children":[{"tag":"date","attrib":{"date":"1987-06-10"},"text":"June 10, 1987","children":[],"tail":", to a person other than a related party (within the meaning of paragraph (2)), paragraph (2) or (3) shall cease to apply on and after the date of such transfer.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
