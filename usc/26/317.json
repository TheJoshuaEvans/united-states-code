{"tag":"section","attrib":{"id":"id42b25f29-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s317"},"text":null,"children":[{"tag":"num","attrib":{"value":"317"},"text":"§ 317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42b25f2a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s317/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this part, the term “property” means money, securities, and any other property; except that such term does not include stock in the corporation making the distribution (or rights to acquire such stock).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42b25f2b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s317/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redemption of stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this part, stock shall be treated as redeemed by a corporation if the corporation acquires its stock from a shareholder in exchange for property, whether or not the stock so acquired is cancelled, retired, or held as treasury stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id42b25f2c-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/99"},"text":"68A Stat. 99","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
