{"tag":"section","attrib":{"id":"id479d5fe9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7809"},"text":null,"children":[{"tag":"num","attrib":{"value":"7809"},"text":"§ 7809.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of collections","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id479d5fea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7809/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsections (b) and (c) and in sections 6306, 7651, 7652, 7654, and 7810, the gross amount of all taxes and revenues received under the provisions of this title, and collections of whatever nature received or collected by authority of any internal revenue law, shall be paid daily into the Treasury of the United States under instructions of the Secretary as internal revenue collections, by the officer or employee receiving or collecting the same, without any abatement or deduction on account of salary, compensation, fees, costs, charges, expenses, or claims of any description. A certificate of such payment, stating the name of the depositor and the specific account on which the deposit was made, signed by the Treasurer of the United States, designated depositary, or proper officer of a deposit bank, shall be transmitted to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id479d5feb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7809/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with instructions of the Secretary, there shall be deposited with the Treasurer of the United States in a deposit fund account—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id479d5fec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7809/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sums offered in compromise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sums offered in compromise under the provisions of section 7122;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479d5fed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7809/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sums offered for purchase of real estate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sums offered for the purchase of real estate under the provisions of section 7506;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479d5fee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7809/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surplus proceeds in sales under levy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Surplus proceeds in any sale under levy, after making allowance for the amount of the tax, interest, penalties, and additions thereto, and for costs and charges of the levy and sale; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479d5fef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7809/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surplus proceeds in sales of redeemed property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Surplus proceeds in any sale under section 7506 of real property redeemed by the United States, after making allowance for the amount of the tax, interest, penalties, and additions thereto, and for the costs of sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Upon the acceptance of such offer in compromise or offer for the purchase of such real estate, the amount so accepted shall be withdrawn from such deposit fund account and deposited in the Treasury of the United States as internal revenue collections. Upon the rejection of any such offer, the Secretary shall refund to the maker of such offer the amount thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id479d5ff0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7809/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of certain receipts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Moneys received in payment for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id479d5ff1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7809/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work or services performed pursuant to section 6103(p) (relating to furnishing of copies of returns or of return information), and section 6108(b) (relating to special statistical studies and compilations);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479d5ff2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7809/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work or services performed (including materials supplied) pursuant to section 7516 (relating to the supplying of training and training aids on request);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479d5ff3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7809/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other work or services performed for a State or a department or agency of the Federal Government (subject to all provisions of law and regulations governing disclosure of information) in supplying copies of, or data from, returns, statements, or other documents filed under authority of this title or records maintained in connection with the administration and enforcement of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479d5ff4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7809/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work or services performed (including materials supplied) pursuant to section 6110 (relating to public inspection of written determinations),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be deposited in a separate account which may be used to reimburse appropriations which bore all or part of the costs of such work or services, or to refund excess sums when necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id479d5ff5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7809/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of funds for law enforcement agency account","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id479d5ff6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7809/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any amounts recovered as the result of information provided to the Internal Revenue Service by State and local law enforcement agencies which substantially contributed to such recovery, an amount equal to 10 percent of such amounts shall be deposited in a separate account which shall be used to make the reimbursements required under section 7624.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479d5ff7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7809/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit in Treasury as internal revenue collections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any amounts remain in such account after payment of any qualified costs incurred under section 7624, such amounts shall be withdrawn from such account and deposited in the Treasury of the United States as internal revenue collections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id479d5ff8-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/918"},"text":"68A Stat. 918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/870/s3/b"},"text":"Pub. L. 87–870, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1161"},"text":"76 Stat. 1161","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/719/tI/s112/b"},"text":"Pub. L. 89–719, title I, § 112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1146"},"text":"80 Stat. 1146","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXII/s1202/h/5"},"text":"Pub. L. 94–455, title XII, § 1202(h)(5)","children":[],"tail":", title XIX, §§ 1906(a)(59), (b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1688"},"text":"90 Stat. 1688","children":[],"tail":", 1833, 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/94/528/s2/d"},"text":"Pub. L. 94–528, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2483"},"text":"90 Stat. 2483","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7602/b"},"text":"Pub. L. 100–690, title VII, § 7602(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4507"},"text":"102 Stat. 4507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s881/a/2/A"},"text":"Pub. L. 108–357, title VIII, § 881(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1626"},"text":"118 Stat. 1626","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/334"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(334)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1200"},"text":"132 Stat. 1200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id479d5ff9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id479d5ffa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id479d5ffb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “work” for “Work”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" inserted “6306,” before “7651”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/a/59"},"text":"Pub. L. 94–455, § 1906(a)(59)","children":[],"tail":", (b)(13)(A), struck out “4735, 4762” after “and in sections”, and “or his delegate” after “Secretary” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1202/h/5"},"text":"Pub. L. 94–455, § 1202(h)(5)","children":[],"tail":", substituted “section 6103(p) (relating to furnishing of copies of returns or of return information), and section 6108(b) (relating to special statistical studies and compilations)” for “section 7515 (relating to special statistical studies and compilations for other services on request)” after “performed pursuant to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/528"},"text":"Pub. L. 94–528","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsecs. (a), (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/719"},"text":"Pub. L. 89–719","children":[],"tail":" inserted reference to section 7810 in subsec. (a) and added subsec. (b)(4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/870/s3/b/1"},"text":"Pub. L. 87–870, § 3(b)(1)","children":[],"tail":", substituted “subsections (b) and (c) and in” for “subsection (b),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/870/s3/b/2"},"text":"Pub. L. 87–870, § 3(b)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id479d5ffc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id479d5ffd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" applicable to information first provided more than 90 days after "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7602/e"},"text":"section 7602(e) of Pub. L. 100–690","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6103"},"text":"section 6103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id479d5ffe-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/528/s2/e"},"text":"Pub. L. 94–528, § 2(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2484"},"text":"90 Stat. 2484","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/528/s2/e"},"text":"“The amendments made by this section [amending this section and provisions set out as notes under sections 6334, 6851, and 7609 of this title] shall take effect on the date of the enactment of the Tax Reform Act of 1976 [","children":[{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1202/h/5"},"text":"section 1202(h)(5) of Pub. L. 94–455","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1977-01-01"},"text":"Jan. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1202/i"},"text":"section 1202(i) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6103"},"text":"section 6103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id479d5fff-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/719"},"text":"Pub. L. 89–719","children":[],"tail":" applicable after "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", regardless of when title or lien of United States arose or when lien or interest of another person was acquired, with certain exceptions, see section 114(a)–(c) of "},{"tag":"ref","attrib":{"href":"/us/pl/89/719"},"text":"Pub. L. 89–719","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6323"},"text":"section 6323 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id479d6000-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7602/f"},"text":"Pub. L. 100–690, title VII, § 7602(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4508"},"text":"102 Stat. 4508","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/690/tVII/s7602/f"},"text":"“There is authorized to be appropriated from the account referred to in section 7809(d) of the Internal Revenue Code of 1986 such sums as may be necessary to make the payments authorized by section 7624 of such Code.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
