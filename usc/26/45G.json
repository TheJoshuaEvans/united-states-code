{"tag":"section","attrib":{"id":"id40d0a699-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G"},"text":null,"children":[{"tag":"num","attrib":{"value":"45G"},"text":"§ 45G.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Railroad track maintenance credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40d0a69a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 38, the railroad track maintenance credit determined under this section for the taxable year is an amount equal to 40 percent (50 percent in the case of any taxable year beginning before ","children":[{"tag":"date","attrib":{"date":"2023-01-01"},"text":"January 1, 2023","children":[],"tail":") of the qualified railroad track maintenance expenditures paid or incurred by an eligible taxpayer during the taxable year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d0a69b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d0a69c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The credit allowed under subsection (a) for any taxable year shall not exceed the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d0a69d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,500, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d0a69e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40d0a69f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of miles of railroad track owned or leased by the eligible taxpayer as of the close of the taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d0a6a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of miles of railroad track assigned for purposes of this subsection to the eligible taxpayer by a Class II or Class III railroad which owns or leases such railroad track as of the close of the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d0a6a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any assignment of a mile of railroad track under paragraph (1)(B)(ii)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d0a6a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such assignment may be made only once per taxable year of the Class II or Class III railroad and shall be treated as made as of the close of such taxable year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d0a6a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such mile may not be taken into account under this section by such railroad for such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d0a6a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such assignment shall be taken into account for the taxable year of the assignee which includes the date that such assignment is treated as effective.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d0a6a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible taxpayer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “eligible taxpayer” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d0a6a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Class II or Class III railroad, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d0a6a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who transports property using the rail facilities of a Class II or Class III railroad or who furnishes railroad-related property or services to a Class II or Class III railroad, but only with respect to miles of railroad track assigned to such person by such Class II or Class III railroad for purposes of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d0a6a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified railroad track maintenance expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “qualified railroad track maintenance expenditures” means gross expenditures (whether or not otherwise chargeable to capital account) for maintaining railroad track (including roadbed, bridges, and related track structures) owned or leased as of ","children":[{"tag":"date","attrib":{"date":"2015-01-01"},"text":"January 1, 2015","children":[],"tail":", by a Class II or Class III railroad (determined without regard to any consideration for such expenditures given by the Class II or Class III railroad which made the assignment of such track)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d0a6a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions and special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d0a6aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Class II or Class III railroad","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the terms “Class II railroad” and “Class III railroad” have the respective meanings given such terms by the Surface Transportation Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d0a6ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of paragraph (1) of section 41(f) shall apply for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d0a6ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45G/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subtitle, if a credit is allowed under this section with respect to any railroad track, the basis of such track shall be reduced by the amount of the credit so allowed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id40d0a6ad-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tII/s245/a"},"text":"Pub. L. 108–357, title II, § 245(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1447"},"text":"118 Stat. 1447","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s403/f"},"text":"Pub. L. 109–135, title IV, § 403(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2623"},"text":"119 Stat. 2623","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s423/a"},"text":"Pub. L. 109–432, div. A, title IV, § 423(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2973"},"text":"120 Stat. 2973","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dC/tIII/s316/a"},"text":"Pub. L. 110–343, div. C, title III, § 316(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3872"},"text":"122 Stat. 3872","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/312/tVII/s734/a"},"text":"Pub. L. 111–312, title VII, § 734(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-17"},"text":"Dec. 17, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3318"},"text":"124 Stat. 3318","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/tIII/s306/a"},"text":"Pub. L. 112–240, title III, § 306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2329"},"text":"126 Stat. 2329","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tI/s116/a"},"text":"Pub. L. 113–295, div. A, title I, § 116(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4014"},"text":"128 Stat. 4014","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tI/s162/a"},"text":"Pub. L. 114–113, div. Q, title I, § 162(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3066"},"text":"129 Stat. 3066","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dD/tI/s40302/a"},"text":"Pub. L. 115–123, div. D, title I, § 40302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/145"},"text":"132 Stat. 145","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dQ/tI/s112/a"},"text":"Pub. L. 116–94, div. Q, title I, § 112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3228"},"text":"133 Stat. 3228","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/tI/s105/a"},"text":"Pub. L. 116–260, div. EE, title I, § 105(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3041"},"text":"134 Stat. 3041","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id40d0a6ae-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id40d0a6af-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id40d0a6b0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s105/b"},"text":"Pub. L. 116–260, § 105(b)","children":[],"tail":", substituted “40 percent (50 percent in the case of any taxable year beginning before "},{"tag":"date","attrib":{"date":"2023-01-01"},"text":"January 1, 2023","children":[],"tail":")” for “50 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s105/a"},"text":"Pub. L. 116–260, § 105(a)","children":[],"tail":", struck out subsec. (f). Text read as follows: “This section shall apply to qualified railroad track maintenance expenditures paid or incurred during taxable years beginning after "},{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2023-01-01"},"text":"January 1, 2023","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2023-01-01"},"text":"January 1, 2023","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2017-01-01"},"text":"January 1, 2017","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s162/b"},"text":"Pub. L. 114–113, § 162(b)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2015-01-01"},"text":"January 1, 2015","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2005-01-01"},"text":"January 1, 2005","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s162/a"},"text":"Pub. L. 114–113, § 162(a)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2017-01-01"},"text":"January 1, 2017","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2015-01-01"},"text":"January 1, 2015","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2015-01-01"},"text":"January 1, 2015","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"January 1, 2014","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/240"},"text":"Pub. L. 112–240","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"January 1, 2014","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2012-01-01"},"text":"January 1, 2012","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312"},"text":"Pub. L. 111–312","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2012-01-01"},"text":"January 1, 2012","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2010-01-01"},"text":"January 1, 2010","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343"},"text":"Pub. L. 110–343","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2010-01-01"},"text":"January 1, 2010","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2008-01-01"},"text":"January 1, 2008","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" inserted “gross” after “means” and “(determined without regard to any consideration for such expenditures given by the Class II or Class III railroad which made the assignment of such track)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/f/1"},"text":"Pub. L. 109–135, § 403(f)(1)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “The credit allowed under subsection (a) for any taxable year shall not exceed the product of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) $3,500, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the number of miles of railroad track owned or leased by the eligible taxpayer as of the close of the taxable year.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A mile of railroad track may be taken into account by a person other than the owner only if such mile is assigned to such person by the owner for purposes of this subsection. Any mile which is so assigned may not be taken into account by the owner for purposes of this subsection.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/f/2"},"text":"Pub. L. 109–135, § 403(f)(2)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “any person who transports property using the rail facilities of a person described in paragraph (1) or who furnishes railroad-related property or services to such a person.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id40d0a6b1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id40d0a6b2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/tI/s105/c"},"text":"Pub. L. 116–260, div. EE, title I, § 105(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3041"},"text":"134 Stat. 3041","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dEE/tI/s105/c"},"text":"“The amendments made by this section [amending this section] shall apply to taxable years ending after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id40d0a6b3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dQ/tI/s112/c"},"text":"Pub. L. 116–94, div. Q, title I, § 112(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"