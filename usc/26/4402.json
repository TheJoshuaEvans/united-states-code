{"tag":"section","attrib":{"id":"id45d5e5f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4402"},"text":null,"children":[{"tag":"num","attrib":{"value":"4402"},"text":"§ 4402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No tax shall be imposed by this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d5e5f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4402/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parimutuels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On any wager placed with, or on any wager placed in a wagering pool conducted by, a parimutuel wagering enterprise licensed under State law,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e5f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4402/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coin-operated devices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On any wager placed in a coin-operated device (as defined in section 4462 as in effect for years beginning before ","children":[{"tag":"date","attrib":{"date":"1980-07-01"},"text":"July 1, 1980","children":[],"tail":"), or on any amount paid, in lieu of inserting a coin, token, or similar object, to operate a device described in section 4462(a)(2) (as so in effect), or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e5f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4402/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State-conducted lotteries, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On any wager placed in a sweepstakes, wagering pool, or lottery which is conducted by an agency of a State acting under authority of State law, but only if such wager is placed with the State agency conducting such sweepstakes, wagering pool, or lottery, or with its authorized employees or agents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d5e5f5-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/525"},"text":"68A Stat. 525","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tI/s152/b"},"text":"Pub. L. 85–859, title I, § 152(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1305"},"text":"72 Stat. 1305","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tIV/s405/a"},"text":"Pub. L. 89–44, title IV, § 405(a)","children":[],"tail":", title VIII, § 813(a), "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/149"},"text":"79 Stat. 149","children":[],"tail":", 170; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXII/s1208/a"},"text":"Pub. L. 94–455, title XII, § 1208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1709"},"text":"90 Stat. 1709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tV/s521/c/1"},"text":"Pub. L. 95–600, title V, § 521(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2884"},"text":"92 Stat. 2884","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45d5e5f6-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45d5e5f7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id45d5e5f8-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 4462, referred to in par. (2), was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/tV/s521/b"},"text":"Pub. L. 95–600, title V, § 521(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2884"},"text":"92 Stat. 2884","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45d5e5f9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" substituted “(as defined in section 4462 as in effect for years beginning before "},{"tag":"date","attrib":{"date":"1980-07-01"},"text":"July 1, 1980","children":[],"tail":")” for “with respect to which an occupational tax is imposed by section 4461” and “(as so in effect), or” for “if an occupational tax is imposed with respect to such device by section 4461, or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", among other changes, substituted in heading “State-conducted lotteries, etc.” for “State-conducted sweepstakes.”, and struck out provision that no tax be imposed on any wager placed in a sweepstakes, wagering pool, or lottery in which the ultimate winners are determined by the results of a horse race."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s405/a"},"text":"Pub. L. 89–44, § 405(a)","children":[],"tail":", substituted “section 4462(a)(2),” for “section 4462(a)(2)(B),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s813/a"},"text":"Pub. L. 89–44, § 813(a)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" inserted provisions exempting from the tax amounts paid to operate a device described in section 4462(a)(2)(B), if an occupational tax is imposed with respect to such device by "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4461"},"text":"section 4461 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45d5e5fa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45d5e5fb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/9