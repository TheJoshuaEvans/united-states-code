,"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/tVII/s701/c/2"},"text":"Pub. L. 89–44, title VII, § 701(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/157"},"text":"79 Stat. 157","children":[],"tail":", provided in part that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/44/tVII/s701/c/2"},"text":"“The amendments made by sections 403 [amending sections 4461 and 4462 of this title] (relating to occupational tax on coin-operated devices) and 404 [repealing sections 4471 to 4474] (relating to occupational tax on bowling alleys, billiard and pool tables), and by subsections (a) [amending this section], (b) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4901"},"text":"section 4901 of this title","children":[],"tail":"] and (d) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4914"},"text":"section 4914 of this title","children":[],"tail":"] of section 405 (relating to technical and conforming changes) shall apply on and after "},{"tag":"date","attrib":{"date":"1965-07-01"},"text":"July 1, 1965","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/tVIII/s813/b"},"text":"Pub. L. 89–44, title VIII, § 813(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/170"},"text":"79 Stat. 170","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/44/tVIII/s813/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply with respect to wagers placed after ","children":[{"tag":"date","attrib":{"date":"1964-03-10"},"text":"March 10, 1964","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45d5e5fe-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tI/s152/c"},"text":"Pub. L. 85–859, title I, § 152(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1305"},"text":"72 Stat. 1305","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendments made by subsections (a) and (b) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4462"},"text":"section 4462 of this title","children":[],"tail":"] shall take effect on the effective date specified in section 1(c) of this Act [the first day of the first calendar quarter beginning more than 60 days after "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":"]. In the case of the year beginning "},{"tag":"date","attrib":{"date":"1958-07-01"},"text":"July 1, 1958","children":[],"tail":", where the trade or business on which the tax is imposed under section 4461 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] was commenced before such effective date, the tax imposed for such year solely by reason of the amendment made by subsection (a)—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be the amount reckoned proportionately from such effective date through ","children":[{"tag":"date","attrib":{"date":"1959-06-30"},"text":"June 30, 1959","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be due on, and payable on or before, the last day of the month the first day of which is such effective date.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
