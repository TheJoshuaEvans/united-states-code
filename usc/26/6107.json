{"tag":"section","attrib":{"id":"id46a56afe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6107"},"text":null,"children":[{"tag":"num","attrib":{"value":"6107"},"text":"§ 6107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax return preparer must furnish copy of return to taxpayer and must retain a copy or list","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46a56aff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Furnishing copy to taxpayer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who is a tax return preparer with respect to any return or claim for refund shall furnish a completed copy of such return or claim to the taxpayer not later than the time such return or claim is presented for such taxpayer’s signature.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46a56b00-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copy or list to be retained by tax return preparer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who is a tax return preparer with respect to a return or claim for refund shall, for the period ending 3 years after the close of the return period—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46a56b01-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6107/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain a completed copy of such return or claim, or retain, on a list, the name and taxpayer identification number of the taxpayer for whom such return or claim was prepared, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46a56b02-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6107/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such copy or list available for inspection upon request by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46a56b03-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe regulations under which, in cases where 2 or more persons are tax return preparers with respect to the same return or claim for refund, compliance with the requirements of subsection (a) or (b), as the case may be, of one such person shall be deemed to be compliance with the requirements of such subsection by the other persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46a56b04-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6107/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the terms “return” and “claim for refund” have the respective meanings given to such terms by section 6696(e), and the term “return period” has the meaning given to such term by section 6060(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46a56b05-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXII/s1203/c"},"text":"Pub. L. 94–455, title XII, § 1203(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1690"},"text":"90 Stat. 1690","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/28/tVIII/s8246/a/2/C/i"},"text":"Pub. L. 110–28, title VIII, § 8246(a)(2)(C)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-25"},"text":"May 25, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/201"},"text":"121 Stat. 201","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46a56b06-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46a56b07-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46a56b08-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6107, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/756"},"text":"68A Stat. 756","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/713/s4/c"},"text":"Pub. L. 89–713, § 4(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1110"},"text":"80 Stat. 1110","children":[],"tail":", authorized an alphabetical list of names of all persons who have paid special taxes under subtitle D or E of this title to be kept for public inspection, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/90/618/tII/s203/a"},"text":"Pub. L. 90–618, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1235"},"text":"82 Stat. 1235","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46a56b09-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28/s8246/a/2/C/i/I"},"text":"Pub. L. 110–28, § 8246(a)(2)(C)(i)(I)","children":[],"tail":", substituted “Tax return preparer” for “Income tax return preparer” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28/s8246/a/2/C/i/II"},"text":"Pub. L. 110–28, § 8246(a)(2)(C)(i)(II)","children":[],"tail":", substituted “a tax return preparer” for “an income tax return preparer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28/s8246/a/2/C/i/II"},"text":"Pub. L. 110–28, § 8246(a)(2)(C)(i)(II)","children":[],"tail":", (III), substituted “tax return preparer” for “income tax return preparer” in heading and “a tax return preparer” for “an income tax return preparer” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28/s8246/a/2/C/i/IV"},"text":"Pub. L. 110–28, § 8246(a)(2)(C)(i)(IV)","children":[],"tail":", substituted “tax return preparers” for “income tax return preparers”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46a56b0a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46a56b0b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28"},"text":"Pub. L. 110–28","children":[],"tail":" applicable to returns prepared after "},{"tag":"date","attrib":{"date":"2007-05-25"},"text":"May 25, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/28/s8246/c"},"text":"section 8246(c) of Pub. L. 110–28","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6060"},"text":"section 6060 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46a56b0c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to documents prepared after ","children":[{"tag":"date","attrib":{"date":"1976-12-31"},"text":"Dec. 31, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1203/j"},"text":"section 1203(j) of Pub. L. 94–455","children":[],"tail":", set out as an Effective Date of 1976 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7701"},"text":"section 7701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
