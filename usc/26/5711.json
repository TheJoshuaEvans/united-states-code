{"tag":"section","attrib":{"id":"id464ac87f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5711"},"text":null,"children":[{"tag":"num","attrib":{"value":"5711"},"text":"§ 5711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bond","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id464ac880-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5711/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" When required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person, before commencing business as a manufacturer of tobacco products or cigarette papers and tubes, or as an export warehouse proprietor, shall file such bond, conditioned upon compliance with this chapter and regulations issued thereunder, in such form, amount, and manner as the Secretary shall by regulation prescribe. A new or additional bond may be required whenever the Secretary considers such action necessary for the protection of the revenue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464ac881-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5711/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval or disapproval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall engage in such business until he receives notice of approval of such bond. A bond may be disapproved, upon notice to the principal on the bond, if the Secretary determines that the bond is not adequate to protect the revenue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464ac882-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5711/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cancellation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any bond filed hereunder may be canceled, upon notice to the principal on the bond, whenever the Secretary determines that the bond no longer adequately protects the revenue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id464ac883-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/711"},"text":"68A Stat. 711","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s202"},"text":"Pub. L. 85–859, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1421"},"text":"72 Stat. 1421","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tV/s502/b/6"},"text":"Pub. L. 89–44, title V, § 502(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/151"},"text":"79 Stat. 151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id464ac884-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id464ac885-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id464ac886-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" struck out reference to dealers in tobacco materials."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" included export warehouse proprietors, and substituted “manufacturer of tobacco products or cigarette papers and tubes” for “manufacturer of articles”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id464ac887-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464ac888-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1965 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" applicable on and after "},{"tag":"date","attrib":{"date":"1966-01-01"},"text":"January 1, 1966","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/s701/d"},"text":"section 701(d) of Pub. L. 89–44","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5701"},"text":"section 5701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464ac889-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1958-09-03"},"text":"Sept. 3, 1958","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/s210/a/1"},"text":"section 210(a)(1) of Pub. L. 85–859","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id464ac88a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transitional Rule","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/3/tVII/s702/g"},"text":"Pub. L. 111–3, title VII, § 702(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-04"},"text":"Feb. 4, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/111"},"text":"123 Stat. 111","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/3/tVII/s702/g"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Any person who—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on ","children":[{"tag":"date","attrib":{"date":"2009-04-01"},"text":"April 1, 2009","children":[],"tail":"[,] is engaged in business as a manufacturer of processed tobacco or as an importer of processed tobacco, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the end of the 90-day period beginning on such date, submits an application under subchapter B of chapter 52 of such Code [this subchapter] to engage in such business, may, notwithstanding such subchapter B, continue to engage in such business pending final action on such application. Pending such final action, all provisions of such chapter 52 [this chapter] shall apply to such applicant in the same manner and to the same extent as if such applicant were a holder of a permit under such chapter 52 to engage in such business.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
