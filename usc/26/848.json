{"tag":"section","attrib":{"id":"id441f359c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848"},"text":null,"children":[{"tag":"num","attrib":{"value":"848"},"text":"§ 848.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capitalization of certain policy acquisition expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id441f359d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an insurance company—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id441f359e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specified policy acquisition expenses for any taxable year shall be capitalized, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441f359f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such expenses shall be allowed as a deduction ratably over the 180-month period beginning with the first month in the second half of such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id441f35a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 5-year amortization for first $5,000,000 of specified policy acquisition expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id441f35a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (2) of subsection (a) shall be applied with respect to so much of the specified policy acquisition expenses of an insurance company for any taxable year as does not exceed $5,000,000 by substituting “60-month” for “180-month”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441f35a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Phase-out","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the specified policy acquisition expenses of an insurance company exceed $10,000,000 for any taxable year, the $5,000,000 amount under paragraph (1) shall be reduced (but not below zero) by the amount of such excess.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441f35a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for members of controlled group","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any controlled group—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id441f35a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all insurance companies which are members of such group shall be treated as 1 company for purposes of this subsection, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id441f35a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount to which paragraph (1) applies shall be allocated among such companies in such manner as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of the preceding sentence, the term “controlled group” means any controlled group of corporations as defined in section 1563(a); except that subsections (a)(4) and (b)(2)(D) of section 1563 shall not apply, and subsection (b)(2)(C) of section 1563 shall not apply to the extent it excludes a foreign corporation to which section 842 applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441f35a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for acquisition expenses attributable to certain reinsurance contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to any specified policy acquisition expenses for any taxable year which are attributable to premiums or other consideration under any reinsurance contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id441f35a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified policy acquisition expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id441f35a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “specified policy acquisition expenses” means, with respect to any taxable year, so much of the general deductions for such taxable year as does not exceed the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id441f35a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2.09 percent of the net premiums for such taxable year on specified insurance contracts which are annuity contracts,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id441f35aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2.45 percent of the net premiums for such taxable year on specified insurance contracts which are group life insurance contracts, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id441f35ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 9.2 percent of the net premiums for such taxable year on specified insurance contracts not described in subparagraph (A) or (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441f35ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General deductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “general deductions” means the deductions provided in part VI of subchapter B (sec. 161 and following, relating to itemized deductions) and in part I of subchapter D (sec. 401 and following, relating to pension, profit sharing, stock bonus plans, etc.).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id441f35ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net premiums","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id441f35ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “net premiums” means, with respect to any category of specified insurance contracts set forth in subsection (c)(1), the excess (if any) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id441f35af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross amount of premiums and other consideration on such contracts, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id441f35b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" return premiums on such contracts and premiums and other consideration incurred for reinsurance of such contracts.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The rules of section 803(b) shall apply for purposes of the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441f35b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts determined on accrual basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an insurance company subject to tax under part II of this subchapter, all computations entering into determinations of net premiums for any taxable year shall be made in the manner required under section 811(a) for life insurance companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441f35b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain policyholder dividends and similar amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Net premiums shall be determined without regard to section 808(e) and without regard to other similar amounts treated as paid to, and returned by, the policyholder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441f35b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for reinsurance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id441f35b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Premiums and other consideration incurred for reinsurance shall be taken into account under paragraph (1)(B) only to the extent such premiums and other consideration are includible in the gross income of an insurance company taxable under this subchapter or are subject to tax under this chapter by reason of subpart F of part III of subchapter N.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id441f35b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe such regulations as may be necessary to ensure that premiums and other consideration with respect to reinsurance are treated consistently by the ceding company and the reinsurer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id441f35b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classification of contracts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id441f35b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified insurance contract","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id441f35b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this paragraph, the term “specified insurance contract” means any life insurance, annuity, or noncancellable accident and health insurance contract (or any combination thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id441f35b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “specified insurance contract” shall not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id441f35ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any pension plan contract (as defined in section 818(a)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id441f35bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any flight insurance or similar contract,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id441f35bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any qualified foreign contract (as defined in section 807(e)(3) without regard to paragraph (5) of this subsection),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id441f35bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/e/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contract which is an Archer MSA (as defined in section 220(d)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id441f35be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/e/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contract which is a health savings account (as defined in section 223(d)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441f35bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Group life insurance contract","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “group life insurance contract” means any life insurance contract—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id441f35c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which covers a group of individuals defined by reference to employment relationship, membership in an organization, or similar factor,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id441f35c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the premiums for which are determined on a group basis, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id441f35c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proceeds of which are payable to (or for the benefit of) persons other than the employer of the insured, an organization to which the insured belongs, or other similar person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441f35c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of annuity contracts combined with noncancellable accident and health insurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any annuity contract combined with noncancellable accident and health insurance shall be treated as a noncancellable accident and health insurance contract and not as an annuity contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441f35c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of guaranteed renewable contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rules of section 816(e) shall apply for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441f35c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of reinsurance contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A contract which reinsures another contract shall be treated in the same manner as the reinsured contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441f35c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain qualified long-term care insurance contract arrangements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An annuity or life insurance contract which includes a qualified long-term care insurance contract as a part of or a rider on such annuity or life insurance contract shall be treated as a specified insurance contract not described in subparagraph (A) or (B) of subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id441f35c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule where negative net premiums","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id441f35c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If for any taxable year there is a negative capitalization amount with respect to any category of specified insurance contracts set forth in subsection (c)(1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id441f35c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount otherwise required to be capitalized under this section for such taxable year with respect to any other category of specified insurance contracts shall be reduced (but not below zero) by such negative capitalization amount, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id441f35ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such negative capitalization amount (to the extent not taken into account under subparagraph (A))—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id441f35cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall reduce (but not below zero) the unamortized balance (as of the beginning of such taxable year) of the amounts previously capitalized under subsection (a) (beginning with the amount capitalized for the most recent taxable year), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id441f35cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent taken into account as such a reduction, shall be allowed as a deduction for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441f35cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negative capitalization amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the term “negative capitalization amount” means, with respect to any category of specified insurance contracts, the percentage (applicable under subsection (c)(1) to such category) of the amount (if any) by which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id441f35ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under subparagraph (B) of subsection (d)(1) with respect to such category, exceeds","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id441f35cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under subparagraph (A) of subsection (d)(1) with respect to such category.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id441f35d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain ceding commissions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in any provision of law (other than this section or section 197) shall require the capitalization of any ceding commission incurred on or after ","children":[{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":", under any contract which reinsures a specified insurance contract."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id441f35d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial authority to adjust capitalization amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id441f35d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the Secretary may provide that a type of insurance contract will be treated as a separate category for purposes of this section (and prescribe a percentage applicable to such category) if the Secretary determines that the deferral of acquisition expenses for such type of contract which would otherwise result under this section is substantially greater than the deferral of acquisition expenses which would have resulted if actual acquisition expenses (including indirect expenses) and the actual useful life for such type of contract had been used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441f35d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s848/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment to other contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary exercises his authority with respect to any type of contract under paragraph (1), the Secretary shall adjust the percentage which would otherwise have applied under subsection (c)(1) to the category which includes such type of contract so that the exercise of such authority does not result in a decrease in the amount of revenue received under this chapter by reason of this section for any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id441f35d4-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11301/a"},"text":"Pub. L. 101–508, title XI, § 11301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-445"},"text":"104 Stat. 1388–445","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13261/d"},"text":"Pub. L. 103–66, title XIII, § 13261(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/539"},"text":"107 Stat. 539","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tIII/s301/h"},"text":"Pub. L. 104–191, title III, § 301(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2052"},"text":"110 Stat. 2052","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tII/s202/a/5"},"text":"Pub. L. 106–554, § 1(a)(7) [title II, § 202(a)(5), (b)(10)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–628, 2763A–629; "},{"tag":"ref","attrib":{"href":"/us/pl/108/173/tXII/s1201/h"},"text":"Pub. L. 108–173, title XII, § 1201(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2479"},"text":"117 Stat. 2479","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tVIII/s844/e"},"text":"Pub. L. 109–280, title VIII, § 844(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1013"},"text":"120 Stat. 1013","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/70"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(70)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4048"},"text":"128 Stat. 4048","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI"},"text":"Pub. L. 115–97, title I","children":[],"tail":", §§ 12001(b)(8)(C), 13517(b)(4), 13519(a), (b), "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2093"},"text":"131 Stat. 2093","children":[],"tail":", 2147, 2148.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id441f35d5-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id441f35d6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id441f35d7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13519/a/1"},"text":"Pub. L. 115–97, § 13519(a)(1)","children":[],"tail":", substituted “180-month” for “120-month”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13519/b"},"text":"Pub. L. 115–97, § 13519(b)","children":[],"tail":", substituted “180-month” for “120-month”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13519/a/2"},"text":"Pub. L. 115–97, § 13519(a)(2)","children":[],"tail":", substituted “2.09 percent” for “1.75 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13519/a/3"},"text":"Pub. L. 115–97, § 13519(a)(3)","children":[],"tail":", which directed substitution of “2.45 percent” for “2.05 percent” in par. (2), was executed to par. (1)(B) to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13519/a/4"},"text":"Pub. L. 115–97, § 13519(a)(4)","children":[],"tail":", which directed substitution of “9.2 percent” for “7.7 percent” in par. (3), was executed to par. (1)(C) to reflect the probable intent of Congress. Subsec. (c) does not contain a par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13517/b/4"},"text":"Pub. L. 115–97, § 13517(b)(4)","children":[],"tail":", substituted “807(e)(3)” for “807(e)(4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s12001/b/8/C"},"text":"Pub. L. 115–97, § 12001(b)(8)(C)","children":[],"tail":", struck out subsec. (i). Text read as follows: “For purposes of determining adjusted current earnings under section 56(g), acquisition expenses with respect to contracts described in clause (iii) of subsection (e)(1)(B) shall be capitalized and amortized in accordance with the treatment generally required under generally accepted accounting principles as if this subsection applied to such contracts for all taxable years.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" struck out subsec. (j). Text read as follows: “In the case of any taxable year which includes "},{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":", the amount taken into account as the net premiums (or negative capitalization amount) with respect to any category of specified insurance contracts shall be the amount which bears the same ratio to the amount which (but for this subsection) would be so taken into account as the number of days in such taxable year on or after "},{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":", bears to the total number of days in such taxable year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (e)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (e)(1)(B)(v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173"},"text":"Pub. L. 108–173","children":[],"tail":" added cl. (v)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (e)(1)(B)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tII/s202/b/10"},"text":"Pub. L. 106–554, § 1(a)(7) [title II, § 202(b)(10)]","children":[],"tail":", substituted “an Archer MSA” for “a Archer MSA”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tII/s202/a/5"},"text":"Pub. L. 106–554, § 1(a)(7) [title II, § 202(a)(5)]","children":[],"tail":", substituted “Archer MSA” for “medical savings account”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e)(1)(B)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Pub. L. 104–191","children":[],"tail":" added cl. (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" substituted “this section or section 197” for “this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id441f35d8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id441f35d9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s12001/b/8/C"},"text":"section 12001(b)(8)(C) of Pub. L. 115–97","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s12001/c"},"text":"section 12001(c) of Pub. L. 115–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s11"},"text":"section 11 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13517/b/4"},"text":"section 13517(b)(4) of Pub. L. 115–97","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", with transition rule and transition relief, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13517/c"},"text":"section 13517(c) of Pub. L. 115–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s807"},"text":"section 807 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13519/c"},"text":"Pub. L. 115–97, title I, § 13519(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2148"},"text":"131 Stat. 2148","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/97/tI/s13519/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section] shall apply to net premiums for taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transition rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Specified policy acquisition expenses first required to be capitalized in a taxable year beginning before ","children":[{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":", will continue to be allowed as a deduction ratably over the 120-month period beginning with the first month in the second half of suc