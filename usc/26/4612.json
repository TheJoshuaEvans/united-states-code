{"tag":"section","attrib":{"id":"id45dd1207-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612"},"text":null,"children":[{"tag":"num","attrib":{"value":"4612"},"text":"§ 4612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45dd1208-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45dd1209-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crude oil","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “crude oil” includes crude oil condensates and natural gasoline.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd120a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic crude oil","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “domestic crude oil” means any crude oil produced from a well located in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd120b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petroleum product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “petroleum product” includes crude oil.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd120c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45dd120d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” means the 50 States, the District of Columbia, the Commonwealth of Puerto Rico, any possession of the United States, the Commonwealth of the Northern Mariana Islands, and the Trust Territory of the Pacific Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45dd120e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States includes continental shelf areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The principles of section 638 shall apply for purposes of the term “United States”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45dd120f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States includes foreign trade zones","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” includes any foreign trade zone of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd1210-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States refinery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States refinery” means any facility in the United States at which crude oil is refined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd1211-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refineries which produce natural gasoline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any United States refinery which produces natural gasoline from natural gas, the gasoline so produced shall be treated as received at such refinery at the time so produced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd1212-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premises","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “premises” has the same meaning as when used for purposes of determining gross income from the property under section 613.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd1213-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Barrel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “barrel” means 42 United States gallons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd1214-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fractional part of barrel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a fraction of a barrel, the tax imposed by section 4611 shall be the same fraction of the amount of such tax imposed on a whole barrel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45dd1215-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Only 1 tax imposed with respect to any product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No tax shall be imposed by section 4611 with respect to any petroleum product if the person who would be liable for such tax establishes that a prior tax imposed by such section has been imposed with respect to such product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45dd1216-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit where crude oil returned to pipeline","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Secretary, if an operator of a United States refinery—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45dd1217-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" removes crude oil from a pipeline, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd1218-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" returns a portion of such crude oil into a stream of other crude oil in the same pipeline,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"there shall be allowed as a credit against the tax imposed by section 4611 to such operator an amount equal to the product of the rate of tax imposed by section 4611 on the crude oil so removed by such operator and the number of barrels of crude oil returned by such operator to such pipeline. Any crude oil so returned shall be treated for purposes of this subchapter as crude oil on which no tax has been imposed by section 4611.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45dd1219-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit against portion of tax attributable to oil spill rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be allowed as a credit against so much of the tax imposed by section 4611 as is attributable to the Oil Spill Liability Trust Fund financing rate for any period an amount equal to the excess of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45dd121a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45dd121b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amounts paid by the taxpayer before ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":", into the Deepwater Port Liability Trust Fund and the Offshore Oil Pollution Compensation Fund, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45dd121c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interest accrued on such amounts before such date, over","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd121d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such payments taken into account under this subsection for all prior periods.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The preceding sentence shall also apply to amounts paid by the taxpayer into the Trans-Alaska Pipeline Liability Fund to the extent of amounts transferred from such Fund into the Oil Spill Liability Trust Fund. For purposes of this subsection, all taxpayers which would be members of the same affiliated group (as defined in section 1504(a)) if section 1504(a)(2) were applied by substituting “100 percent” for “80 percent” shall be treated as 1 taxpayer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45dd121e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income tax credit for unused payments into Trans-Alaska Pipeline Liability Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45dd121f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 38, the current year business credit shall include the credit determined under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd1220-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of credit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45dd1221-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The credit determined under this subsection for any taxable year is an amount equal to the aggregate credit which would be allowed to the taxpayer under subsection (d) for amounts paid into the Trans-Alaska Pipeline Liability Fund had the Oil Spill Liability Trust Fund financing rate not ceased to apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45dd1222-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45dd1223-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the credit determined under this subsection for any taxable year with respect to any taxpayer shall not exceed the excess of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id45dd1224-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/e/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under clause (ii), over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id45dd1225-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/e/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of the credit determined under this subsection for prior taxable years with respect to such taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45dd1226-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overall limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount determined under this clause with respect to any taxpayer is the excess of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id45dd1227-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/e/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of credit which would have been allowed under subsection (d) to the taxpayer for periods before the termination date specified in section 4611(f)(1), if amounts in the Trans-Alaska Pipeline Liability Fund which are actually transferred into the Oil Spill Liability Fund were transferred on ","children":[{"tag":"date","attrib":{"date":"1990-01-01"},"text":"January 1, 1990","children":[],"tail":", and the Oil Spill Liability Trust Fund financing rate did not terminate before such termination date, over"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id45dd1228-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/e/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of the credit allowed under subsection (d) to the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd1229-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost of income tax credit borne by Trust Fund","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45dd122a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall from time to time transfer from the Oil Spill Liability Trust Fund to the general fund of the Treasury amounts equal to the credits allowed by reason of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45dd122b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust Fund balance may not be reduced below $1,000,000,000","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Transfers may be made under subparagraph (A) only to the extent that the unobligated balance of the Oil Spill Liability Trust Fund exceeds $1,000,000,000. If any transfer is not made by reason of the preceding sentence, such transfer shall be made as soon as permitted under such sentence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd122c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No carryback","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No portion of the unused business credit for any taxable year which is attributable to the credit determined under this subsection may be carried to a taxable year beginning on or before the date of the enactment of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45dd122d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4612/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of revenues from Puerto Rico and the Virgin Islands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of subsections (a)(3) and (b)(3) of section 7652 shall not apply to any tax imposed by section 4611.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45dd122e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/510/tII/s211/a"},"text":"Pub. L. 96–510, title II, § 211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2798"},"text":"94 Stat. 2798","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/tV/s512/c"},"text":"Pub. L. 99–499, title V, § 512(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1761"},"text":"100 Stat. 1761","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tVIII/s8032/b"},"text":"Pub. L. 99–509, title VIII, § 8032(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1957"},"text":"100 Stat. 1957","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7505/c"},"text":"Pub. L. 101–239, title VII, § 7505(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2363"},"text":"103 Stat. 2363","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/tIX/s9002"},"text":"Pub. L. 101–380, title IX, § 9002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/574"},"text":"104 Stat. 574","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s1922/a"},"text":"Pub. L. 102–486, title XIX, § 1922(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3028"},"text":"106 Stat. 3028","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/223"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(223)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1194"},"text":"132 Stat. 1194","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45dd122f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45dd1230-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id45dd1231-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this paragraph, referred to in subsec. (e)(4), is the date of the enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id45dd1232-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tVIII/s8031/c"},"text":"Pub. L. 99–509, title VIII, § 8031(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1955"},"text":"100 Stat. 1955","children":[],"tail":", to subsecs. (c) and (d) of this section were not executed to text pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tVIII/s8031/e/2"},"text":"Pub. L. 99–509, title VIII, § 8031(e)(2)","children":[],"tail":", which provided that the amendments made by section 8031 shall not take effect if the Superfund Amendments and Reauthorization Act of 1986 is enacted. The Superfund Amendments and Reauthorization Act of 1986 was enacted as "},{"tag":"ref","attrib":{"href":"/us/pl/99/499"},"text":"Pub. L. 99–499","children":[],"tail":", approved "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45dd1233-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (e)(2)(B)(ii)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “were transferred” for “were tranferred”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":" added subsec. (e) and redesignated former subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":" substituted at end “For purposes of this subsection, all taxpayers which would be members of the same affiliated group (as defined in section 1504(a)) if section 1504(a)(2) were applied by substituting ‘100 percent’ for ‘80 percent’ shall be treated as 1 taxpayer.” for “Amounts may be transferred from the Trans-Alaska Pipeline Liability Fund into the Oil Spill Liability Trust Fund only to the extent the administrators of the Trans-Alaska Pipeline Liability Fund determine that such amounts are not needed to satisfy claims against such Fund.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" inserted at end “The preceding sentence shall also apply to amounts paid by the taxpayer into the Trans-Alaska Pipeline Liability Fund to the extent of amounts transferred from such Fund into the Oil Spill Liability Trust Fund. Amounts may be transferred from the Trans-Alaska Pipeline Liability Fund into the Oil Spill Liability Trust Fund only to the extent the administrators of the Trans-Alaska Pipeline Liability Fund determine that such amounts are not needed to satisfy claims against such Fund.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499"},"text":"Pub. L. 99–499","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509"},"text":"Pub. L. 99–509","children":[],"tail":" added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499"},"text":"Pub. L. 99–499","children":[],"tail":" redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attri