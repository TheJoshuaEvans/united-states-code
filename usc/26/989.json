{"tag":"section","attrib":{"id":"id4496611a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s989"},"text":null,"children":[{"tag":"num","attrib":{"value":"989"},"text":"§ 989.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions and special rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4496611b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s989/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified business unit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subpart, the term “qualified business unit” means any separate and clearly identified unit of a trade or business of a taxpayer which maintains separate books and records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4496611c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s989/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate exchange rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in regulations, for purposes of this subpart, the term “appropriate exchange rate” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4496611d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s989/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an actual distribution of earnings and profits, the spot rate on the date such distribution is included in income,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4496611e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s989/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an actual or deemed sale or exchange of stock in a foreign corporation treated as a dividend under section 1248, the spot rate on the date the deemed dividend is included in income,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4496611f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s989/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any amounts included in income under section 951(a)(1)(A) or 1293(a), the average exchange rate for the taxable year of the foreign corporation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44966120-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s989/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other qualified business unit of a taxpayer, the average exchange rate for the taxable year of such qualified business unit.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of the preceding sentence, any amount included in income under section 951(a)(1)(B) shall be treated as an actual distribution made on the last day of the taxable year for which such amount was so included.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44966121-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s989/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary or appropriate to carry out the purposes of this subpart, including regulations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44966122-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s989/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setting forth procedures to be followed by taxpayers with qualified business units using a net worth method of accounting before the enactment of this subpart,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44966123-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s989/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limiting the recognition of foreign currency loss on certain remittances from qualified business units,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44966124-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s989/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for the recharacterization of interest and principal payments with respect to obligations denominated in certain hyperinflationary currencies,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44966125-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s989/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for alternative adjustments to the application of section 905(c),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44966126-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s989/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for the appropriate treatment of related party transactions (including transactions between qualified business units of the same taxpayer), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44966127-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s989/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setting forth procedures for determining the average exchange rate for any period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44966128-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1261/a"},"text":"Pub. L. 99–514, title XII, § 1261(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2590"},"text":"100 Stat. 2590","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/v/5"},"text":"Pub. L. 100–647, title I, § 1012(v)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3529"},"text":"102 Stat. 3529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13231/c/4/C"},"text":"Pub. L. 103–66, title XIII, § 13231(c)(4)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/499"},"text":"107 Stat. 499","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1501/b/9"},"text":"Pub. L. 104–188, title I, § 1501(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1826"},"text":"110 Stat. 1826","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXI/s1102/b/2"},"text":"Pub. L. 105–34, title XI, § 1102(b)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/966"},"text":"111 Stat. 966","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIV/s413/c/17"},"text":"Pub. L. 108–357, title IV, § 413(c)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1508"},"text":"118 Stat. 1508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44966129-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4496612a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4496612b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The enactment of this subpart, referred to in subsec. (c)(1), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4496612c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" struck out “, 551(a),” after “section 951(a)(1)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1102/b/3"},"text":"Pub. L. 105–34, § 1102(b)(3)","children":[],"tail":", struck out “weighted” before “average exchange rate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1102/b/2"},"text":"Pub. L. 105–34, § 1102(b)(2)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" substituted “section 951(a)(1)(B)” for “subparagraph (B) or (C) of section 951(a)(1)” in closing provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" substituted “subparagraph (B) or (C) of section 951(a)(1)” for “section 951(a)(1)(B)” in last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" substituted in par. (3) “section 951(a)(1)(A)” for “section 951(a)” and inserted at end “For purposes of the preceding sentence, any amount included in income under section 951(a)(1)(B) shall be treated as an actual distribution made on the last day of the taxable year for which such amount was so included.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4496612d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAme