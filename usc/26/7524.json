{"tag":"section","attrib":{"id":"id47700e88-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7524"},"text":null,"children":[{"tag":"num","attrib":{"value":"7524"},"text":"§ 7524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual notice of tax delinquency","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not less often than annually, the Secretary shall send a written notice to each taxpayer who has a tax delinquent account of the amount of the tax delinquency as of the date of the notice.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id47700e89-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/tXII/s1204/a"},"text":"Pub. L. 104–168, title XII, § 1204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1471"},"text":"110 Stat. 1471","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47700e8a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47700e8b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47700e8c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/tXII/s1204/c"},"text":"Pub. L. 104–168, title XII, § 1204(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1471"},"text":"110 Stat. 1471","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/168/tXII/s1204/c"},"text":"“The amendments made by this section [enacting this section] shall apply to calendar years after 1996.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
