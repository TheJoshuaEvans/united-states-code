{"tag":"section","attrib":{"id":"id44a4b89c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017"},"text":null,"children":[{"tag":"num","attrib":{"value":"1017"},"text":"§ 1017.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discharge of indebtedness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44a4b89d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44a4b89e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount is excluded from gross income under subsection (a) of section 108 (relating to discharge of indebtedness), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44a4b89f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under subsection (b)(2)(E), (b)(5), or (c)(1) of section 108, any portion of such amount is to be applied to reduce basis,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then such portion shall be applied in reduction of the basis of any property held by the taxpayer at the beginning of the taxable year following the taxable year in which the discharge occurs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44a4b8a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount and properties determined under regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44a4b8a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of reduction to be applied under subsection (a) (not in excess of the portion referred to in subsection (a)), and the particular properties the bases of which are to be reduced, shall be determined under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44a4b8a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation in title 11 case or insolvency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a discharge to which subparagraph (A) or (B) of section 108(a)(1) applies, the reduction in basis under subsection (a) of this section shall not exceed the excess of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44a4b8a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate of the bases of the property held by the taxpayer immediately after the discharge, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44a4b8a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate of the liabilities of the taxpayer immediately after the discharge.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The preceding sentence shall not apply to any reduction in basis by reason of an election under section 108(b)(5).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44a4b8a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain reductions may only be made in the basis of depreciable property","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44a4b8a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount which under subsection (b)(5) or (c)(1) of section 108 is to be applied to reduce basis shall be applied only to reduce the basis of depreciable property held by the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44a4b8a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depreciable property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “depreciable property” means any property of a character subject to the allowance for depreciation, but only if a basis reduction under subsection (a) will reduce the amount of depreciation or amortization which otherwise would be allowable for the period immediately following such reduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44a4b8a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for partnership interests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, any interest of a partner in a partnership shall be treated as depreciable property to the extent of such partner’s proportionate interest in the depreciable property held by such partnership. The preceding sentence shall apply only if there is a corresponding reduction in the partnership’s basis in depreciable property with respect to such partner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44a4b8a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule in case of affiliated group","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44a4b8aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation holds stock in another corporation (hereinafter in this subparagraph referred to as the “subsidiary”), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44a4b8ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such corporations are members of the same affiliated group which file a consolidated return under section 1501 for the taxable year in which the discharge occurs,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then such stock shall be treated as depreciable property to the extent that such subsidiary consents to a corresponding reduction in the basis of its depreciable property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44a4b8ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to treat certain inventory as depreciable property","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44a4b8ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the election of the taxpayer, for purposes of this section, the term “depreciable property” includes any real property which is described in section 1221(a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44a4b8ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under clause (i) shall be made on the taxpayer’s return for the taxable year in which the discharge occurs or at such other time as may be permitted in regulations prescribed by the Secretary. Such an election, once made, may be revoked only with the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44a4b8af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for qualified real property business indebtedness","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any amount which under section 108(c)(1) is to be applied to reduce basis—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44a4b8b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/3/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depreciable property shall only include depreciable real property for purposes of subparagraphs (A) and (C),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44a4b8b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/3/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraph (E) shall not apply, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44a4b8b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/3/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of property taken into account under section 108(c)(2)(B), the reduction with respect to such property shall be made as of the time immediately before disposition if earlier than the time under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44a4b8b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for qualified farm indebtedness","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44a4b8b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any amount which under subsection (b)(2)(E) of section 108 is to be applied to reduce basis and which is attributable to an amount excluded under subsection (a)(1)(C) of section 108—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44a4b8b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be applied only to reduce the basis of qualified property held by the taxpayer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44a4b8b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be applied to reduce the basis of qualified property in the following order:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id44a4b8b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" First the basis of qualified property which is depreciable property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44a4b8b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Second the basis of qualified property which is land used or held for use in the trade or business of farming.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44a4b8b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/4/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Then the basis of other qualified property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44a4b8ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the term “qualified property” has the meaning given to such term by section 108(g)(3)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44a4b8bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain rules made applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of subparagraphs (C), (D), and (E) of paragraph (3) shall apply for purposes of this paragraph and section 108(g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44a4b8bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44a4b8bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction not to be made in exempt property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an amount excluded from gross income under section 108(a)(1)(A), no reduction in basis shall be made under this section in the basis of property which the debtor treats as exempt property under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s522"},"text":"section 522 of title 11","children":[],"tail":" of the United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44a4b8be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reductions in basis not treated as dispositions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this title, a reduction in basis under this section shall not be treated as a disposition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44a4b8bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recapture of reductions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44a4b8c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of sections 1245 and 1250—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44a4b8c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property the basis of which is reduced under this section and which is neither section 1245 property nor section 1250 property shall be treated as section 1245 property, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44a4b8c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reduction under this section shall be treated as a deduction allowed for depreciation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44a4b8c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1017/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for section 1250","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 1250(b), the determination of what would have been the depreciation adjustments under the straight line method shall be made as if there had been no reduction under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44a4b8c4-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/301"},"text":"68A Stat. 301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1906(b)(13)(A), 1951(c)(1), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":", 1840; "},{"tag":"ref","attrib":{"href":"/us/pl/96/589/s2/b"},"text":"Pub. L. 96–589, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3394"},"text":"94 Stat. 3394","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tIV/s405/b"},"text":"Pub. L. 99–514, title IV, § 405(b)","children":[],"tail":", title VIII, § 822(b)(4), (5), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2224"},"text":"100 Stat. 2224","children":[],"tail":", 2373; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1004/a/5"},"text":"Pub. L. 100–647, title I, § 1004(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3386"},"text":"102 Stat. 3386","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11704/a/12"},"text":"Pub. L. 101–508, title XI, § 11704(a)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-518"},"text":"104 Stat. 1388–518","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13150/c/6"},"text":"Pub. L. 103–66, title XIII, § 13150(c)(6)","children":[],"tail