{"tag":"section","attrib":{"id":"id45d5e63c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4423"},"text":null,"children":[{"tag":"num","attrib":{"value":"4423"},"text":"§ 4423.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection of books","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 7605(b), the books of account of any person liable for tax under this chapter may be examined and inspected as frequently as may be needful to the enforcement of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id45d5e63d-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/528"},"text":"68A Stat. 528","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
