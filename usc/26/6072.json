 patronage dividends in an amount equal to at least 50 percent of its net earnings from business done with or for its patrons, or which paid patronage dividends in such an amount out of the net earnings from business done with or for patrons during the most recent taxable year for which it had such net earnings for provisions which related to returns of exempt cooperative associations taxable under the provisions of section 522."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id468b2cae-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468b2caf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/41"},"text":"Pub. L. 114–41","children":[],"tail":" applicable to returns for taxable years beginning after "},{"tag":"date","attrib":{"date":"2015-12-31"},"text":"Dec. 31, 2015","children":[],"tail":", with special rule for certain C corporations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/41/s2006/a/3"},"text":"section 2006(a)(3) of Pub. L. 114–41","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s170"},"text":"section 170 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468b2cb0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" applicable to transactions after "},{"tag":"date","attrib":{"date":"1984-12-31"},"text":"Dec. 31, 1984","children":[],"tail":", in taxable years ending after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s805/a/1"},"text":"section 805(a)(1) of Pub. L. 98–369","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s245"},"text":"section 245 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468b2cb1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/628/s6/b"},"text":"Pub. L. 95–628, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3630"},"text":"92 Stat. 3630","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/628/s6/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to returns for taxable years beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468b2cb2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1053/d/3"},"text":"section 1053(d)(3) of Pub. L. 94–455","children":[],"tail":" applicable with respect to taxable years beginning after "},{"tag":"date","attrib":{"date":"1977-12-31"},"text":"Dec. 31, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1053/e"},"text":"section 1053(e) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1504"},"text":"section 1504 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468b2cb3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1971 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/178"},"text":"Pub. L. 92–178","children":[],"tail":" applicable with respect to taxable years ending after "},{"tag":"date","attrib":{"date":"1971-12-31"},"text":"Dec. 31, 1971","children":[],"tail":", except that a corporation may not be a DISC for any taxable year beginning before "},{"tag":"date","attrib":{"date":"1972-01-01"},"text":"Jan. 1, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/178/s507"},"text":"section 507 of Pub. L. 92–178","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s991"},"text":"section 991 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468b2cb4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1962 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/834"},"text":"Pub. L. 87–834","children":[],"tail":" applicable to taxable years of organizations described in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1381/a"},"text":"section 1381(a) of this title","children":[],"tail":" beginning after "},{"tag":"date","attrib":{"date":"1962-12-31"},"text":"Dec. 31, 1962","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/87/834/s17/c"},"text":"section 17(c) of Pub. L. 87–834","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1381"},"text":"section 1381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id468b2cb5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Filing of Income Tax Returns for 1958 by Life Insurance Companies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/69/s3/i"},"text":"Pub. L. 86–69, § 3(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-06-25"},"text":"June 25, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/140"},"text":"73 Stat. 140","children":[],"tail":", required every life insurance company subject to the tax imposed by "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s802/a"},"text":"section 802(a) of this title","children":[],"tail":" to make a return after "},{"tag":"date","attrib":{"date":"1959-06-25"},"text":"June 25, 1959","children":[],"tail":", and on or before "},{"tag":"date","attrib":{"date":"1959-09-15"},"text":"Sept. 15, 1959","children":[],"tail":", which return was to constitute the return for such taxable year for all purposes of this title, and no return filed pursuant to section 801 et seq. of this title, relating to life insurance companies, on or before "},{"tag":"date","attrib":{"date":"1959-06-25"},"text":"June 25, 1959","children":[],"tail":", was to be considered for any such purposes as a return for such taxable year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
