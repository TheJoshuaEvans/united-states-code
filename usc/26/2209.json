{"tag":"section","attrib":{"id":"id453d4f95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2209"},"text":null,"children":[{"tag":"num","attrib":{"value":"2209"},"text":"§ 2209.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain residents of possessions considered nonresidents not citizens of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A decedent who was a citizen of the United States and a resident of a possession thereof at the time of his death shall, for purposes of the tax imposed by this chapter, be considered a “nonresident not a citizen of the United States” within the meaning of that term wherever used in this title, but only if such person acquired his United States citizenship solely by reason of (1) his being a citizen of such possession of the United States, or (2) his birth or residence within such possession of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id453d4f96-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/779/s4/b/1"},"text":"Pub. L. 86–779, § 4(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-14"},"text":"Sept. 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/999"},"text":"74 Stat. 999","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id453d4f97-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id453d4f98-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id453d4f99-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to estates of decedents dying after ","children":[{"tag":"date","attrib":{"date":"1960-09-14"},"text":"Sept. 14, 1960","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/86/779/s4/e/2"},"text":"section 4(e)(2) of Pub. L. 86–779","children":[],"tail":", set out as an Effective Date of 1960 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2106"},"text":"section 2106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
