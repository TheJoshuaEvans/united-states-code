{"tag":"section","attrib":{"id":"id474ea2f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7423"},"text":null,"children":[{"tag":"num","attrib":{"value":"7423"},"text":"§ 7423.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayments to officers or employees","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary, subject to regulations prescribed by the Secretary, is authorized to repay—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id474ea2f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7423/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collections recovered","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To any officer or employee of the United States the full amount of such sums of money as may be recovered against him in any court, for any internal revenue taxes collected by him, with the cost and expense of suit; also","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474ea2f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7423/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Damages and costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All damages and costs recovered against any officer or employee of the United States in any suit brought against him by reason of anything done in the due performance of his official duty under this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id474ea2f7-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/877"},"text":"68A Stat. 877","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id474ea2f8-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id474ea2f9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id474ea2fa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” in provisions preceding par. (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
