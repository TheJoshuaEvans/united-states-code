{"tag":"section","attrib":{"id":"id453fc0e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503"},"text":null,"children":[{"tag":"num","attrib":{"value":"2503"},"text":"§ 2503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable gifts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id453fc0ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “taxable gifts” means the total amount of gifts made during the calendar year, less the deductions provided in subchapter C (section 2522 and following).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453fc0eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions from gifts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id453fc0ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of gifts (other than gifts of future interests in property) made to any person by the donor during the calendar year, the first $10,000 of such gifts to such person shall not, for purposes of subsection (a), be included in the total amount of gifts made during such year. Where there has been a transfer to any person of a present interest in property, the possibility that such interest may be diminished by the exercise of a power shall be disregarded in applying this subsection, if no part of such interest will at any time pass to any other person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453fc0ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of gifts made in a calendar year after 1998, the $10,000 amount contained in paragraph (1) shall be increased by an amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id453fc0ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id453fc0ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost-of-living adjustment determined under section 1(f)(3) for such calendar year by substituting “calendar year 1997” for “calendar year 2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If any amount as adjusted under the preceding sentence is not a multiple of $1,000, such amount shall be rounded to the next lowest multiple of $1,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453fc0f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer for the benefit of minor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No part of a gift to an individual who has not attained the age of 21 years on the date of such transfer shall be considered a gift of a future interest in property for purposes of subsection (b) if the property and the income therefrom—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id453fc0f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be expended by, or for the benefit of, the donee before his attaining the age of 21 years, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453fc0f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" will to the extent not so expended—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id453fc0f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pass to the donee on his attaining the age of 21 years, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id453fc0f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the event the donee dies before attaining the age of 21 years, be payable to the estate of the donee or as he may appoint under a general power of appointment as defined in section 2514(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453fc0f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"[(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIII/s311/h/5"},"text":"Pub. L. 97–34, title III, § 311(h)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/282"},"text":"95 Stat. 282","children":[],"tail":"]"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453fc0f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion for certain transfers for educational expenses or medical expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id453fc0f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any qualified transfer shall not be treated as a transfer of property by gift for purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453fc0f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified transfer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “qualified transfer” means any amount paid on behalf of an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id453fc0f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as tuition to an educational organization described in section 170(b)(1)(A)(ii) for the education or training of such individual, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id453fc0fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any person who provides medical care (as defined in section 213(d)) with respect to such individual as payment for such medical care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453fc0fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of certain pension rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any individual waives, before the death of a participant, any survivor benefit, or right to such benefit, under section 401(a)(11) or 417, such waiver shall not be treated as a transfer of property by gift for purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453fc0fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain loans of artworks","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id453fc0fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subtitle, any loan of a qualified work of art shall not be treated as a transfer (and the value of such qualified work of art shall be determined as if such loan had not been made) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id453fc0fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such loan is to an organization described in section 501(c)(3) and exempt from tax under section 501(c) (other than a private foundation), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id453fc0ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of such work by such organization is related to the purpose or function constituting the basis for its exemption under section 501.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453fc100-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id453fc101-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified work of art","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified work of art” means any archaeological, historic, or creative tangible personal property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id453fc102-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2503/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private foundation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “private foundation” has the meaning given such term by section 509, except that such term shall not include any private operating foundation (as defined in section 4942(j)(3)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id453fc103-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/404"},"text":"68A Stat. 404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/614/tI/s102/a/3"},"text":"Pub. L. 91–614, title I, § 102(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1839"},"text":"84 Stat. 1839","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s702/j/2"},"text":"Pub. L. 95–600, title VII, § 702(j)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2931"},"text":"92 Stat. 2931","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIII/s311/h/5"},"text":"Pub. L. 97–34, title III, § 311(h)(5)","children":[],"tail":", title IV, §§ 441(a), (b), 442(a)(3), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/282"},"text":"95 Stat. 282","children":[],"tail":", 319, 320; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1898/h/1/B"},"text":"Pub. L. 99–514, title XVIII, § 1898(h)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2957"},"text":"100 Stat. 2957","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1018/s/2/A"},"text":"Pub. L. 100–647, title I, § 1018(s)(2)(A)","children":[],"tail":", (u)(52), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3586"},"text":"102 Stat. 3586","children":[],"tail":", 3593; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7811/m/1"},"text":"Pub. L. 101–239, title VII, § 7811(m)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2412"},"text":"103 Stat. 2412","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tV/s501/c"},"text":"Pub. L. 105–34, title V, § 501(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/846"},"text":"111 Stat. 846","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s11002/d/1/EE"},"text":"Pub. L. 115–97, title I, § 11002(d)(1)(EE)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2060"},"text":"131 Stat. 2060","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id453fc104-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id453fc105-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inflation Adjusted Items for Certain Years","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For inflation adjustment of certain items in this section, see Revenue Procedures listed in a table under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id453fc106-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id453fc107-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" substituted “for ‘calendar year 2016’ in subparagraph (A)(ii)” for “for ‘calendar year 1992’ in subparagraph (B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" designated existing provisions as par. (1), inserted par. heading, realigned margins, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" redesignated subsec. (f), relating to treatment of certain loans of artworks, as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (e)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1018/u/52"},"text":"Pub. L. 100–647, § 1018(u)(52)","children":[],"tail":", substituted “section 213(d)” for “section 213(e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1018/s/2/A"},"text":"Pub. L. 100–647, § 1018(s)(2)(A)","children":[],"tail":", added subsec. (f) relating to treatment of certain loans of artworks."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s442/a/3/A"},"text":"Pub. L. 97–34, § 442(a)(3)(A)","children":[],"tail":", substituted “the total amount of gifts made during the calendar year, less the deductions provided in subchapter C (section 2522 and following)” for “, in the case of gifts made after "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"December 31, 1970","children":[],"tail":", the total amount of gifts made during calendar quarter, less the deductions provided in subchapter C (sec. 2521 and following” and struck out provision that in the case of gifts made before "},{"tag":"date","attrib":{"date":"1971-01-01"},"text":"Jan. 1, 1971","children":[],"tail":", “taxable gifts” means the total amount of gifts made during the calendar year, less the deductions provided in subchapter C."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s442/a/3/B"},"text":"Pub. L. 97–34, § 442(a)(3)(B)","children":[],"tail":", substituted provision that in the case of gifts, other than gifts of future interests in property, made to any person by the donor during the calendar year, the first $10,000 of such gifts to such person shall not, for purposes of subsec. (a), be included in the total amount of gifts made during such year for provision that in computing taxable gifts for the calendar quarter, in the case of gifts, other than gifts of future interests in property, made to any person by the donor during the calendar year 1971 and subsequent calendar years, $10,000 of such gifts to such person less the aggregate of the amounts of such gifts to such person during all preceding calendar quarters of the calendar year shall not, for purposes of subsec. (a), be included in the total amount of gifts made during such quarter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s441/a"},"text":"Pub. L. 97–34, § 441(a)","children":[],"tail":", substituted “$10,000” for “$3,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s311/h/5"},"text":"Pub. L. 97–34, § 311(h)(5)","children":[],"tail":", repealed subsec. (d) which related to individual retirement accounts, etc., for spouse."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s441/b"},"text":"Pub. L. 97–34, § 441(b)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614/s102/a/3/A"},"text":"Pub. L. 91–614, § 102(a)(3)(A)","children":[],"tail":", divided definition of “taxable gifts” into gifts made after "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", where taxable gifts are based on the total amount of gifts made during the calendar quarter, less the applicable deductions, and gifts made before "},{"tag":"date","attrib":{"date":"1971-01-01"},"text":"Jan. 1, 1971","children":[],"tail":", where taxable gifts are based on the total amount of gifts made during the calendar year, less the applicable deductions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614/s102/a/3/B"},"text":"Pub. L. 91–614, § 102(a)(3)(B)","children":[],"tail":", substituted provisions with regard to computing taxable gifts for the calendar quarter, in the case of gifts made to any persons by the donor during the calendar year 1971 and subsequent calendar years, $3,000 of such gifts to such person less the aggregate of the amounts of such gifts to such person during all preceding calendar quarters of the calendar year shall not be included in the total amount of gifts made during such quarter for provisions requiring in the case of gifts made to any person by the donor during the calendar year 1955 and subsequent calendar years, the first $3,000 of such gifts to such person shall not be included in the total amount of gifts made during such year."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id453fc108-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id453fc109-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us