{"tag":"section","attrib":{"id":"id4630896d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5223"},"text":null,"children":[{"tag":"num","attrib":{"value":"5223"},"text":"§ 5223.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redistillation of spirits, articles, and residues","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4630896e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5223/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spirits on bonded premises","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The proprietor of a distilled spirits plant authorized to produce distilled spirits may, under such regulations as the Secretary shall prescribe, redistill any distilled spirits which have not been withdrawn from bonded premises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4630896f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5223/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distilled spirits returned for redistillation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Distilled spirits which have been lawfully removed from bonded premises free of tax or without payment of tax may, under such regulations as the Secretary may prescribe, be returned for redistillation to the bonded premises of a distilled spirits plant authorized to produce distilled spirits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46308970-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5223/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redistillation of articles and residues","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Articles, containing denatured distilled spirits, which were manufactured under the provisions of subchapter D or on the bonded premises of a distilled spirits plant, and the spirits residues of manufacturing processes related thereto, may be received, and the distilled spirits therein recovered by redistillation, on the bonded premises of a distilled spirits plant authorized to produce distilled spirits, under such regulations as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46308971-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5223/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denatured distilled spirits, articles, and residues","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Distilled spirits recovered by the redistillation of denatured distilled spirits, or by the redistillation of the articles or residues described in subsection (c), may not be withdrawn from bonded premises except for industrial use or after denaturation thereof in the manner prescribed by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46308972-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5223/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Products of redistillation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All distilled spirits redistilled on bonded premises subsequent to production gauge shall be treated the same as if such spirits had been originally produced by the redistiller and all provisions of this chapter applicable to the original production of distilled spirits shall be applicable thereto. Any prior obligation as to taxes, liens, and bonds with respect to such distilled spirits shall be extinguished on redistillation. Nothing in this subsection shall be construed as affecting any provision of law relating to the labeling of distilled spirits or as limiting the authority of the Secretary to regulate the marking, branding, or identification of distilled spirits redistilled under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46308973-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1365"},"text":"72 Stat. 1365","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tVIII/s805/d"},"text":"Pub. L. 89–44, title VIII, § 805(d)","children":[],"tail":", (f)(8), (10), "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/161"},"text":"79 Stat. 161","children":[],"tail":", 162; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/31"},"text":"Pub. L. 96–39, title VIII, § 807(a)(31)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/286"},"text":"93 Stat. 286","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46308974-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46308975-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46308976-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising subsecs. (a) and (d) of this section were contained in prior sections of act ","children":[{"tag":"date","attrib":{"date":"1954-08-16"},"text":"Aug. 16, 1954","children":[],"tail":", prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":", as follows:"},{"tag":"quotedContent","attrib":{},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id46308977-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Present subsecs.:","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Prior sections","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5194(f), 5217(a), 5305, 5308.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5194(f).","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The prior sections, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", are set out in "},{"tag":"ref","attrib":{"href":"/us/stat/68A/635"},"text":"68A Stat. 635","children":[],"tail":", 641, 657."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46308978-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/s807/a/31/A"},"text":"Pub. L. 96–39, § 807(a)(31)(A)","children":[],"tail":", inserted “or on the bonded premises of a distilled spirits plant” after “subchapter D,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/s807/a/31/B"},"text":"Pub. L. 96–39, § 807(a)(31)(B)","children":[],"tail":", struck out provisions relating to the treatment of the processing of distilled spirits, subsequent to production gauge, in the manufacture of vodka in the production facilities of a distilled spirits plant as a redistillation of the spirits for purposes of this subsection, subsection (a), and sections 5025(d) and 5215."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a) to (c), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s805/f/8"},"text":"Pub. L. 89–44, § 805(f)(8)","children":[],"tail":", substituted “spirits, articles, and residues” for “spirits” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s805/d"},"text":"Pub. L. 89–44, § 805(d)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s805/d"},"text":"Pub. L. 89–44, § 805(d)","children":[],"tail":", (f)(10), redesignated subsec. (c) as (d), inserted “, articles, and residues” after “distilled spirits” in heading, and inserted “, or by the redistillation of the articles or residues described in subsection (c),” after “denatured distilled spirits” in text. Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/11/s805/d"},"text":"Pub. L. 89–11, § 805(d)","children":[],"tail":", redesignated former subsec. (d) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4632fa79-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"childr