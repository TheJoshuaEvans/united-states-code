ction 9303 of title 31","children":[],"tail":", United States Code” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t6/s15"},"text":"6 U.S.C. 15","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/310"},"text":"Pub. L. 92–310","children":[],"tail":" struck out reference to section 6803(a)(1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
