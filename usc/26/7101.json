{"tag":"section","attrib":{"id":"id47404bb2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7101"},"text":null,"children":[{"tag":"num","attrib":{"value":"7101"},"text":"§ 7101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of bonds","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whenever, pursuant to the provisions of this title (other than section 7485), or rules or regulations prescribed under authority of this title, a person is required to furnish a bond or security—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47404bb3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such bond or security shall be in such form and with such surety or sureties as may be prescribed by regulations issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47404bb4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States bonds and notes in lieu of surety bonds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The person required to furnish such bond or security may, in lieu thereof, deposit bonds or notes of the United States as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9303"},"text":"section 9303 of title 31","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47404bb5-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/