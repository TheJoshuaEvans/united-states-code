{"tag":"section","attrib":{"id":"id471a2567-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6653"},"text":null,"children":[{"tag":"num","attrib":{"value":"6653"},"text":"§ 6653.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to pay stamp tax","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any person (as defined in section 6671(b)) who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id471a2568-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6653/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully fails to pay any tax imposed by this title which is payable by stamp, coupons, tickets, books, or other devices or methods prescribed by this title or by regulations under the authority of this title, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id471a2569-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6653/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully attempts in any manner to evade or defeat any such tax or the payment thereof,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall, in addition to other penalties provided by law, be liable for a penalty of 50 percent of the total amount of the underpayment of the tax.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id471a256a-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/822"},"text":"68A Stat. 822","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s86"},"text":"Pub. L. 85–866, title I, § 86","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1665"},"text":"72 Stat. 1665","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tI/s101/j/50"},"text":"Pub. L. 91–172, title I, § 101(j)(50)","children":[],"tail":", title IX, § 943(c)(6), "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/531"},"text":"83 Stat. 531","children":[],"tail":", 729; "},{"tag":"ref","attrib":{"href":"/us/pl/91/679/s2"},"text":"Pub. L. 91–679, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-12"},"text":"Jan. 12, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2063"},"text":"84 Stat. 2063","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/406/tII/s1016/a/18"},"text":"Pub. L. 93–406, title II, § 1016(a)(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/931"},"text":"88 Stat. 931","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/223/tI/s101/f/8"},"text":"Pub. L. 96–223, title I, § 101(f)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-02"},"text":"Apr. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/253"},"text":"94 Stat. 253","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tV/s501/b"},"text":"Pub. L. 97–34, title V, § 501(b)","children":[],"tail":", title VII, § 722(b)(1), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/326"},"text":"95 Stat. 326","children":[],"tail":", 342; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s325/a"},"text":"Pub. L. 97–248, title III, § 325(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/616"},"text":"96 Stat. 616","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tI"},"text":"Pub. L. 97–448, title I","children":[],"tail":", §§ 105(a)(1)(D), 107(a)(3), "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2384"},"text":"96 Stat. 2384","children":[],"tail":", 2391; "},{"tag":"ref","attrib":{"href":"/us/pl/98/67/tI/s106"},"text":"Pub. L. 98–67, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-05"},"text":"Aug. 5, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/382"},"text":"97 Stat. 382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s179/b/3"},"text":"Pub. L. 98–369, div. A, title I, § 179(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/718"},"text":"98 Stat. 718","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/44/s1/b"},"text":"Pub. L. 99–44, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-05-24"},"text":"May 24, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/77"},"text":"99 Stat. 77","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1503/a"},"text":"Pub. L. 99–514, title XV, § 1503(a)","children":[],"tail":", (b), (c)(2), (3), (d)(1), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2742"},"text":"100 Stat. 2742","children":[],"tail":", 2743; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1015/b/2/A"},"text":"Pub. L. 100–647, title I, § 1015(b)(2)(A)","children":[],"tail":", (B), (3), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3569"},"text":"102 Stat. 3569","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7721/c/1"},"text":"Pub. L. 101–239, title VII, § 7721(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2399"},"text":"103 Stat. 2399","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id471a256b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id471a256c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id471a256d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" substituted “Failure to pay stamp tax” for “Additions to tax for negligence and fraud” in section catchline and amended text generally, substituting a single par. for former subsecs. (a) to (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1015/b/2/A"},"text":"Pub. L. 100–647, § 1015(b)(2)(A)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “If any part of any underpayment (as defined in subsection (c)) is due to negligence or disregard of rules or regulations, there shall be added to the tax an amount equal to the sum of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) 5 percent of the underpayment, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) an amount equal to 50 percent of the interest payable under section 6601 with respect to the portion of such underpayment which is attributable to negligence for the period beginning on the last date prescribed by law for payment of such underpayment (determined without regard to any extension) and ending on the date of the assessment of the tax (or, if earlier, the date of the payment of the tax).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1015/b/2/B"},"text":"Pub. L. 100–647, § 1015(b)(2)(B)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “If any part of any underpayment (as defined in subsection (c)) of tax required to be shown on a return is due to fraud, there shall be added to the tax an amount equal to the sum of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) 75 percent of the portion of the underpayment which is attributable to fraud, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) an amount equal to 50 percent of the interest payable under section 6601 with respect to such portion for the period beginning on the last day prescribed by law for payment of such underpayment (determined without regard to any extension) and ending on the date of the assessment of the tax or, if earlier, the date of the payment of the tax.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1015/b/3"},"text":"Pub. L. 100–647, § 1015(b)(3)","children":[],"tail":", inserted at end “If any penalty is imposed under subsection (a) by reason of the preceding sentence, only the portion of the underpayment which is attributable to the failure described in the preceding sentence shall be taken into account in determining the amount of the penalty under subsection (a).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1503/d/1"},"text":"Pub. L. 99–514, § 1503(d)(1)","children":[],"tail":", substituted “Additions to tax for negligence and fraud” for “Failure to pay tax” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1503/a"},"text":"Pub. L. 99–514, § 1503(a)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which added percentage to tax due for underpayment of taxes where negligence or intentional disregard of rules and regulations with respect to income, gift, or windfall profit taxes was involved, and also provided additional interest penalty for portion of underpayment attributable to negligence, etc."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1503/b"},"text":"Pub. L. 99–514, § 1503(b)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which added percentage to tax due for underpayment of taxes where fraud was involved, and also provided for additional interest penalty, but stated that there would be no negligence addition where there was addition for fraud, and concluded with special rule for joint returns."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1503/c/2"},"text":"Pub. L. 99–514, § 1503(c)(2)","children":[],"tail":", substituted “portion of the underpayment which is attributable to fraud” for “same underpayment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1503/c/3"},"text":"Pub. L. 99–514, § 1503(c)(3)","children":[],"tail":", struck out “or intentional disregard of rules and regulations (but without intent to defraud)” after “underpayment due to negligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1503/b"},"text":"Pub. L. 99–514, § 1503(b)","children":[],"tail":", amended subsec. (g) generally, substituting provisions relating to special rule for amounts shown on information returns for provisions relating to special rule in case of interest or dividend payments, and struck out provision that penalty was to apply only to portion of underpayment due to failure to include interest or dividend payment."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/44"},"text":"Pub. L. 99–44","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s179/b/3"},"text":"Pub. L. 98–369, § 179(b)(3)","children":[],"tail":", which added subsec. (h), and provided that the Internal Revenue Code of 1954 [now 1986] [this title] shall be applied and administered as if section 179(b)(3) (and the amendments made by such section) had not been enacted. See 1984 Amendment note and Effective Date of 1985 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" added subsec. (h) which provided for a special rule in the case of underpayment attributable to failure to meet the substantiation requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s274/d"},"text":"section 274(d) of this title","children":[],"tail":". See 1985 Amendment note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448/s107/a/3"},"text":"Pub. L. 97–448, § 107(a)(3)","children":[],"tail":", inserted “(or, if earlier, the date of the payment of the tax)” after “assessment of the tax”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448/s105/a/1/D"},"text":"Pub. L. 97–448, § 105(a)(1)(D)","children":[],"tail":", redesignated subsec. (g), added by "},{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":", as (f) and substituted “unrecognized gain” for “unrealized gain” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/67"},"text":"Pub. L. 98–67","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448/s105/a/1/D"},"text":"Pub. L. 97–448, § 105(a)(1)(D)","children":[],"tail":", redesignated subsec. (g), added by "},{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":", as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" designated first sentence of existing provisions as par. (1) with heading “In general”, struck out second sentence which provided that in the case of income taxes and gift taxes, the amount under this subsec. shall be in lieu of any amount determined under subsec. (a), added pars. (2) and (3), designated last sentence as par. (4) with heading “Special rule for joint returns”, and in par. (4) as so designated substituted “of the spouse” for “of a spouse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s722/b/1"},"text":"Pub. L. 97–34, § 722(b)(1)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, struck out “(relating to income taxes and gift taxes)”, and added par. (2) after “subtitle B”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s501/b"},"text":"Pub. L. 97–34, § 501(b)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223"},"text":"Pub. L. 96–223","children":[],"tail":" substituted “, gift, or windfall profit taxes” for “or gift taxes” in heading, and in text substituted “,” for “or” before “by chapter 12” and inserted “, or by chapter 45 (relating to windfall profit tax)” before “is due to negligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406"},"text":"Pub. L. 93–406","children":[],"tail":" substituted “certain excise” for “chapter 42” in heading and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/679"},"text":"Pub. L. 91–679","children":[],"tail":" inserted sentence making subsection inapplicable, in the case of a joint return under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6013"},"text":"section 6013 of this title","children":[],"tail":", with respect to the tax of a spouse unless some part of the underpayment is due to the fraud of such spouse."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/s101/j/50"},"text":"Pub. L. 91–172, § 101(j)(50)","children":[],"tail":", inserted reference to chapter 42 taxes in heading and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/s943/c/6"},"text":"Pub. L. 91–172, § 943(c)(6)","children":[],"tail":", inserted “or pay tax” after “such return”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866"},"text":"Pub. L. 85–866","children":[],"tail":", inserted “on or” after “such return was filed”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id471a256e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"