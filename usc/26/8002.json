{"tag":"section","attrib":{"id":"id47a48ba8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8002"},"text":null,"children":[{"tag":"num","attrib":{"value":"8002"},"text":"§ 8002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47a48ba9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8002/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number and selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Joint Committee shall be composed of 10 members as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47a48baa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8002/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" From Committee on Finance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Five members who are members of the Committee on Finance of the Senate, three from the majority and two from the minority party, to be chosen by such Committee; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48bab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8002/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" From Committee on Ways and Means","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Five members who are members of the Committee on Ways and Means of the House of Representatives, three from the majority and two from the minority party, to be chosen by such Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a48bac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8002/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tenure of office","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47a48bad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8002/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall continue to serve as a member of the Joint Committee after he has ceased to be a member of the Committee by which he was chosen, except that—","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48bae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8002/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members chosen by the Committee on Ways and Means who have been reelected to the House of Representatives may continue to serve as members of the Joint Committee notwithstanding the expiration of the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a48baf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8002/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vacancy in the Joint Committee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47a48bb0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8002/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Shall not affect the power of the remaining members to execute the functions of the Joint Committee; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48bb1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8002/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of filling","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Shall be filled in the same manner as the original selection, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47a48bb2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8002/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjournment or recess of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In case of a vacancy during an adjournment or recess of Congress for a period of more than 2 weeks, the members of the Joint Committee who are members of the Committee entitled to fill such vacancy may designate a member of such Committee to serve until his successor is chosen by such Committee; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47a48bb3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8002/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a vacancy after the expiration of a Congress which would be filled by the Committee on Ways and Means, the members of such Committee who are continuing to serve as members of the Joint Committee may designate a person who, immediately prior to such expiration, was a member of such Committee and who is re-elected to the House of Representatives, to serve until his successor is chosen by such Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a48bb4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s8002/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members shall serve without compensation in addition to that received for their services as members of Congress; but they shall be reimbursed for travel, subsistence, and other necessary expenses incurred by them in the performance of the duties vested in the Joint Committee, other than expenses in connection with meetings of the Joint Committee held in the District of Columbia during such times as the Congress is in session.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47a48bb5-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/925"},"text":"68A Stat. 925","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
