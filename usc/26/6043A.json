{"tag":"section","attrib":{"id":"id4670ee13-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043A"},"text":null,"children":[{"tag":"num","attrib":{"value":"6043A"},"text":"§ 6043A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns relating to taxable mergers and acquisitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4670ee14-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"According to the forms or regulations prescribed by the Secretary, the acquiring corporation in any taxable acquisition shall make a return setting forth—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4670ee15-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the acquisition,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4670ee16-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of each shareholder of the acquired corporation who is required to recognize gain (if any) as a result of the acquisition,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4670ee17-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043A/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of money and the fair market value of other property transferred to each such shareholder as part of such acquisition, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4670ee18-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043A/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"To the extent provided by the Secretary, the requirements of this section applicable to the acquiring corporation shall be applicable to the acquired corporation and not to the acquiring corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4670ee19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nominees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"According to the forms or regulations prescribed by the Secretary:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4670ee1a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who holds stock as a nominee for another person shall furnish in the manner prescribed by the Secretary to such other person the information provided by the corporation under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4670ee1b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting to nominees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of stock held by any person as a nominee, references in this section (other than in subsection (c)) to a shareholder shall be treated as a reference to the nominee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4670ee1c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable acquisition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “taxable acquisition” means any acquisition by a corporation of stock in or property of another corporation if any shareholder of the acquired corporation is required to recognize gain (if any) as a result of such acquisition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4670ee1d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements to be furnished to shareholders","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"According to the forms or regulations prescribed by the Secretary, every person required to make a return under subsection (a) shall furnish to each shareholder whose name is required to be set forth in such return a written statement showing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4670ee1e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and phone number of the information contact of the person required to make such return,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4670ee1f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information required to be shown on such return with respect to such shareholder, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4670ee20-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043A/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The written statement required under the preceding sentence shall be furnished to the shareholder on or before January 31 of the year following the calendar year during which the taxable acquisition occurred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4670ee21-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s805/a"},"text":"Pub. L. 108–357, title VIII, § 805(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1573"},"text":"118 Stat. 1573","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4670ee22-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4670ee23-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4670ee24-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s805/d"},"text":"Pub. L. 108–357, title VIII, § 805(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1574"},"text":"118 Stat. 1574","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tVIII/s805/d"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6724"},"text":"section 6724 of this title","children":[],"tail":"] shall apply to acquisitions after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
