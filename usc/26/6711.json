{"tag":"section","attrib":{"id":"id4734647d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6711"},"text":null,"children":[{"tag":"num","attrib":{"value":"6711"},"text":"§ 6711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure by tax-exempt organization to disclose that certain information or service available from Federal Government","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4734647e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6711/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4734647f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6711/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tax-exempt organization offers to sell (or solicits money for) specific information or a routine service for any individual which could be readily obtained by such individual free of charge (or for a nominal charge) from an agency of the Federal Government,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47346480-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6711/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax-exempt organization, when making such offer or solicitation, fails to make an express statement (in a conspicuous and easily recognizable format) that the information or service can be so obtained, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47346481-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6711/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such failure is due to intentional disregard of the requirements of this subsection,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such organization shall pay a penalty determined under subsection (b) for each day on which such a failure occurred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47346482-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6711/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The penalty under subsection (a) for any day on which a failure referred to in such subsection occurred shall be the greater of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47346483-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6711/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47346484-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6711/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the aggregate cost of the offers and solicitations referred to in subsection (a)(1) which occurred on such day and with respect to which there was such a failure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47346485-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6711/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47346486-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6711/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax-exempt organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “tax-exempt organization” means any organization which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47346487-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6711/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is described in subsection (c) or (d) of section 501 and exempt from taxation under section 501(a), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47346488-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6711/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a political organization (as defined in section 527(e)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47346489-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6711/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Day on which failure occurs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The day on which any failure referred to in subsection (a) occurs shall be determined under rules similar to the rules of section 6710(d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4734648a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10705/a"},"text":"Pub. L. 100–203, title X, § 10705(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-463"},"text":"101 Stat. 1330–463","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4734648b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4734648c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4734648d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10705/c"},"text":"Pub. L. 100–203, title X, § 10705(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-464"},"text":"101 Stat. 1330–464","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/203/tX/s10705/c"},"text":"“The amendments made by this section [enacting this section] shall apply to offers and solicitations after ","children":[{"tag":"date","attrib":{"date":"1988-01-31"},"text":"January 31, 1988","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
