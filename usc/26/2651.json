{"tag":"section","attrib":{"id":"id454ba77e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651"},"text":null,"children":[{"tag":"num","attrib":{"value":"2651"},"text":"§ 2651.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generation assignment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id454ba77f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the generation to which any person (other than the transferor) belongs shall be determined in accordance with the rules set forth in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454ba780-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lineal descendants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454ba781-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual who is a lineal descendant of a grandparent of the transferor shall be assigned to that generation which results from comparing the number of generations between the grandparent and such individual with the number of generations between the grandparent and the transferor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba782-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On spouse’s side","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual who is a lineal descendant of a grandparent of a spouse (or former spouse) of the transferor (other than such spouse) shall be assigned to that generation which results from comparing the number of generations between such grandparent and such individual with the number of generations between such grandparent and such spouse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba783-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of legal adoptions, etc.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454ba784-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal adoptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A relationship by legal adoption shall be treated as a relationship by blood.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454ba785-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationships by half-blood","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A relationship by the half-blood shall be treated as a relationship of the whole-blood.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454ba786-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marital relationship","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454ba787-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marriage to transferor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual who has been married at any time to the transferor shall be assigned to the transferor’s generation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba788-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marriage to other lineal descendants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual who has been married at any time to an individual described in subsection (b) shall be assigned to the generation of the individual so described.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454ba789-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons who are not lineal descendants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual who is not assigned to a generation by reason of the foregoing provisions of this section shall be assigned to a generation on the basis of the date of such individual’s birth with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454ba78a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual born not more than 12½ years after the date of the birth of the transferor assigned to the transferor’s generation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba78b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual born more than 12½ years but not more than 37½ years after the date of the birth of the transferor assigned to the first generation younger than the transferor, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba78c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" similar rules for a new generation every 25 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454ba78d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for persons with a deceased parent","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454ba78e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of determining whether any transfer is a generation-skipping transfer, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454ba78f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual is a descendant of a parent of the transferor (or the transferor’s spouse or former spouse), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454ba790-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individual’s parent who is a lineal descendant of the parent of the transferor (or the transferor’s spouse or former spouse) is dead at the time the transfer (from which an interest of such individual is established or derived) is subject to a tax imposed by chapter 11 or 12 upon the transferor (and if there shall be more than 1 such time, then at the earliest such time),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such individual shall be treated as if such individual were a member of the generation which is 1 generation below the lower of the transferor’s generation or the generation assignment of the youngest living ancestor of such individual who is also a descendant of the parent of the transferor (or the transferor’s spouse or former spouse), and the generation assignment of any descendant of such individual shall be adjusted accordingly.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba791-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited application of subsection to collateral heirs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not apply with respect to a transfer to any individual who is not a lineal descendant of the transferor (or the transferor’s spouse or former spouse) if, at the time of the transfer, such transferor has any living lineal descendant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454ba792-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454ba793-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals assigned to more than 1 generation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in regulations, an individual who, but for this subsection, would be assigned to more than 1 generation shall be assigned to the youngest such generation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba794-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interests through entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3), if an estate, trust, partnership, corporation, or other entity has an interest in property, each individual having a beneficial interest in such entity shall be treated as having an interest in such property and shall be assigned to a generation under the foregoing provisions of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba795-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain charitable organizations and governmental entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454ba796-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organization described in section 511(a)(2),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454ba797-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charitable trust described in section 511(b)(2), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454ba798-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2651/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" governmental entity,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be assigned to the transferor’s generation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id454ba799-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIV/s1431/a"},"text":"Pub. L. 99–514, title XIV, § 1431(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2725"},"text":"100 Stat. 2725","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1014/g/11"},"text":"Pub. L. 100–647, title I, § 1014(g)(11)","children":[],"tail":", (19), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3565"},"text":"102 Stat. 3565","children":[],"tail":", 3567; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tV/s511/a"},"text":"Pub. L. 105–34, title V, § 511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/860"},"text":"111 Stat. 860","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id454ba79a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id454ba79b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id454ba79c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" added subsec. (e) and redesignated former subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1014/g/19"},"text":"Pub. L. 100–647, § 1014(g)(19)","children":[],"tail":", inserted “(or former spouse)” after “a spouse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1014/g/11"},"text":"Pub. L. 100–647, § 1014(g)(11)","children":[],"tail":", amended par. (3) generally, including governmental entities among the organizations to be assigned to transferor’s generation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id454ba79d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id454ba79e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" applicable to terminations, distributions, and transfers occurring after "},{"tag":"date","attrib":{"date":"1997-12-31"},"text":"Dec. 31, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s511/c"},"text":"section 511(c) of Pub. L. 105–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2612"},"text":"section 2612 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id454ba79f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id454ba7a0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to generation-skipping transfers (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s2611"},"text":"section 2611 of this title","children":[],"tail":") made after "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1433"},"text":"section 1433 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2601"},"text":"section 2601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
