{"tag":"section","attrib":{"id":"id4086cc3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s34"},"text":null,"children":[{"tag":"num","attrib":{"value":"34"},"text":"§ 34.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain uses of gasoline and special fuels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4086cc3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s34/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be allowed as a credit against the tax imposed by this subtitle for the taxable year an amount equal to the sum of the amounts payable to the taxpayer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4086cc40-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s34/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under section 6420 (determined without regard to section 6420(g)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4086cc41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s34/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under section 6421 (determined without regard to section 6421(i)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4086cc42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s34/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under section 6427 (determined without regard to section 6427(k)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4086cc43-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s34/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Credit shall not be allowed under subsection (a) for any amount payable under section 6421 or 6427, if a claim for such amount is timely filed and, under section 6421(i) or 6427(k), is payable under such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4086cc44-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/tVIII"},"text":"Pub. L. 89–44, title VIII","children":[],"tail":", 809(c), "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/167"},"text":"79 Stat. 167","children":[],"tail":", § 39; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/258/tII/s207/c"},"text":"Pub. L. 91–258, title II, § 207(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-05-21"},"text":"May 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/248"},"text":"84 Stat. 248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1901(a)(3), 1906(b)(8), (9), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1764"},"text":"90 Stat. 1764","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/94/530/s1/c/1"},"text":"Pub. L. 94–530, § 1(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2487"},"text":"90 Stat. 2487","children":[],"tail":"; "},{"tag":"ref","attri