{"tag":"section","attrib":{"id":"id45a3d9a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510"},"text":null,"children":[{"tag":"num","attrib":{"value":"3510"},"text":"§ 3510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of collection of domestic service employment taxes with collection of income taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45a3d9a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45a3d9a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" returns with respect to domestic service employment taxes shall be made on a calendar year basis,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a3d9a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any such return for any calendar year shall be filed on or before the 15th day of the fourth month following the close of the employer’s taxable year which begins in such calendar year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a3d9a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no requirement to make deposits (or to pay installments under section 6157) shall apply with respect to such taxes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a3d9a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic service employment taxes subject to estimated tax provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45a3d9aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Solely for purposes of section 6654, domestic service employment taxes imposed with respect to any calendar year shall be treated as a tax imposed by chapter 2 for the taxable year of the employer which begins in such calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a3d9ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employers not otherwise required to make estimated payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to any employer for any calendar year if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45a3d9ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no credit for wage withholding is allowed under section 31 to such employer for the taxable year of the employer which begins in such calendar year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a3d9ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no addition to tax would (but for this section) be imposed under section 6654 for such taxable year by reason of section 6654(e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a3d9ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annualization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary, appropriate adjustments shall be made in the application of section 6654(d)(2) in respect of the amount treated as tax under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a3d9af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic service employment taxes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “domestic service employment taxes” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45a3d9b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any taxes imposed by chapter 21 or 23 on remuneration paid for domestic service in a private home of the employer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a3d9b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount withheld from such remuneration pursuant to an agreement under section 3402(p).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of this subsection, the term “domestic service in a private home of the employer” includes domestic service described in section 3121(g)(5).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a3d9b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception where employer liable for other employment taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent provided in regulations prescribed by the Secretary, this section shall not apply to any employer for any calendar year if such employer is liable for any tax under this subtitle with respect to remuneration for services other than domestic service in a private home of the employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a3d9b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General regulatory authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary or appropriate to carry out the purposes of this section. Such regulations may treat domestic service employment taxes as taxes imposed by chapter 1 for purposes of coordinating the assessment and collection of such employment taxes with the assessment and collection of domestic employers’ income taxes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a3d9b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to enter into agreements to collect State unemployment taxes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45a3d9b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is hereby authorized to enter into an agreement with any State to collect, as the agent of such State, such State’s unemployment taxes imposed on remuneration paid for domestic service in a private home of the employer. Any taxes to be collected by the Secretary pursuant to such an agreement shall be treated as domestic service employment taxes for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a3d9b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers to State account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount collected under an agreement referred to in paragraph (1) shall be transferred by the Secretary to the account of the State in the Unemployment Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a3d9b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subtitle F made applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subtitle F, any amount required to be collected under an agreement under paragraph (1) shall be treated as a tax imposed by chapter 23.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a3d9b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3510/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “State” has the meaning given such term by section 3306(j)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45a3d9b9-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/387/s2/b/1"},"text":"Pub. L. 103–387, § 2(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4073"},"text":"108 Stat. 4073","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/102"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(102)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4052"},"text":"128 Stat. 4052","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45a3d9ba-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45a3d9bb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id45a3d9bc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3510, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/21/tI/s123/b/1"},"text":"Pub. L. 98–21, title I, § 123(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-04-20"},"text":"Apr. 20, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/88"},"text":"97 Stat. 88","children":[],"tail":", provided a credit for increased social security employee taxes and railroad retirement tier 1 employee taxes imposed during 1984, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11801/a/42"},"text":"Pub. L. 101–508, title XI, § 11801(a)(42)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-521"},"text":"104 Stat. 1388–521","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45a3d9bd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" struck out par. (4). Text read as follows: “In the case of any taxable year beginning before "},{"tag":"date","attrib":{"date":"1998-01-01"},"text":"January 1, 1998","children":[],"tail":", no addition to tax shall be made under section 6654 with respect to any underpayment to the extent such underpayment was created or increased by this section.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45a3d9be-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45a3d9bf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/b"},"text":"section 221(b) of Pub. L. 113–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45a3d9c0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/387/s2/b/3"},"text":"Pub. L. 103–387, § 2(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4074"},"text":"108 Stat. 4074","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/387/s2/b/3"},"text":"“The amendments made by this subsection [enacting this section] shall apply to remuneration paid in calendar years beginning after ","children":[{"tag":"date","attrib":{"date":"1994-12-31"},"text":"December 31, 1994","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id45a3d9c1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Expanded Information to Employers","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/387/s2/b/4"},"text":"Pub. L. 103–387, § 2(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4074"},"text":"108 Stat. 4074","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/387/s2/b/4"},"text":"“The Secretary of the Treasury or the Secretary’s delegate shall prepare and make available information on the Federal tax obligations of employers with respect to employees performing domestic service in a private home of the employer. Such information shall also include a statement that such employers may have obligations with respect to such employees under State laws relating to unemployment insurance and workers compensation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
