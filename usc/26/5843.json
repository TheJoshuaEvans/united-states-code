{"tag":"section","attrib":{"id":"id4651f40d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5843"},"text":null,"children":[{"tag":"num","attrib":{"value":"5843"},"text":"§ 5843.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and returns","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Importers, manufacturers, and dealers shall keep such records of, and render such returns in relation to, the importation, manufacture, making, receipt, and sale, or other disposition, of firearms as the Secretary may by regulations prescribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4651f40e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/618/tII/s201"},"text":"Pub. L. 90–618, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1230"},"text":"82 Stat. 1230","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4651f40f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4651f410-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4651f411-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"he