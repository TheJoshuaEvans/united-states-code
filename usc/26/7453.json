{"tag":"section","attrib":{"id":"id475cfad9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7453"},"text":null,"children":[{"tag":"num","attrib":{"value":"7453"},"text":"§ 7453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of practice, procedure, and evidence","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except in the case of proceedings conducted under section 7436(c) or 7463, the proceedings of the Tax Court and its divisions shall be conducted in accordance with such rules of practice and procedure (other than rules of evidence) as the Tax Court may prescribe and in accordance with the Federal Rules of Evidence.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id475cfada-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/884"},"text":"68A Stat. 884","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIX/s960/f"},"text":"Pub. L. 91–172, title IX, § 960(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/734"},"text":"83 Stat. 734","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIV/s1454/b/3"},"text":"Pub. L. 105–34, title XIV, § 1454(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1057"},"text":"111 Stat. 1057","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tIV/s425/a"},"text":"Pub. L. 114–113, div. Q, title IV, § 425(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3125"},"text":"129 Stat. 3125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id475cfadb-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id475cfadc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id475cfadd-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Evidence, referred to in text, are set out in the Appendix to Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id475cfade-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":" substituted “the Federal Rules of Evidence” for “the rules of evidence applicable in trials without a jury in the United States District Court of the District of Columbia”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" substituted “section 7436(c) or 7463” for “section 7463”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" inserted reference to the exception in the case of proceedings conducted under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7463"},"text":"section 7463 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id475cfadf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id475cfae0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tIV/s425/b"},"text":"Pub. L. 114–113, div. Q, title IV, § 425(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3125"},"text":"129 Stat. 3125","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/113/dQ/tIV/s425/b"},"text":"“The amendment made by this section [amending this section] shall apply to proceedings commenced after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":"] and, to the extent that it is just and practicable, to all proceedings pending on such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id475cfae1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1969 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" effective one year after "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/s962/e"},"text":"section 962(e) of Pub. L. 91–172","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7463"},"text":"section 7463 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id475cfae2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Tax Court Rule Making Not Affected","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Authority of Tax Court to prescribe rules under this section unaffected by amendments of title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Pub. L. 100–702","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/702/s405"},"text":"section 405 of Pub. L. 100–702","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2071"},"text":"section 2071 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
