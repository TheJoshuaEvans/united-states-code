{"tag":"section","attrib":{"id":"id461fe7de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051"},"text":null,"children":[{"tag":"num","attrib":{"value":"5051"},"text":"§ 5051.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition and rate of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id461fe7df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id461fe7e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id461fe7e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A tax is hereby imposed on all beer brewed or produced, and removed for consumption or sale, within the United States, or imported into the United States. Except as provided in paragraph (2), the rate of such tax shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id461fe7e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" $16 on the first 6,000,000 barrels of beer—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id461fe7e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" brewed by the brewer and removed during the calendar year for consumption or sale, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id461fe7e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imported by the importer into the United States during the calendar year but only if the importer is an electing importer under paragraph (4) and the barrels have been assigned to the importer pursuant to such paragraph, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id461fe7e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $18 on any barrels of beer to which clause (i) does not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id461fe7e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Barrel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, a barrel shall contain not more than 31 gallons of beer, and any tax imposed under this section shall be applied at a like rate for any other quantity or for fractional parts of a barrel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461fe7e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduced rate for certain domestic production","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id461fe7e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" $3.50 a barrel rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a brewer who produces not more than 2,000,000 barrels of beer during the calendar year, the per barrel rate of the tax imposed by this section shall be $3.50 on the first 60,000 barrels of beer which are removed in such year for consumption or sale and which have been brewed or produced by such brewer at qualified breweries in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id461fe7e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prescribe such regulations as may be necessary to prevent the reduced rates provided in this paragraph from benefiting any person who produces more than 2,000,000 barrels of beer during a calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461fe7ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tolerances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where the Secretary or his delegate finds that the revenue will not be endangered thereby, he may by regulations prescribe tolerances for barrels and fractional parts of barrels, and, if such tolerances are prescribed, no assessment shall be made and no tax shall be collected for any excess in any case where the contents of a barrel or a fractional part of a barrel are within the limit of the applicable tolerance prescribed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461fe7eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduced tax rate for foreign manufacturers and importers","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id461fe7ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any barrels of beer which have been brewed or produced outside of the United States and imported into the United States, the rate of tax applicable under clause (i) of paragraph (1)(A) (referred to in this paragraph as the “reduced tax rate”) may be assigned by the brewer (provided that the brewer makes an election described in subparagraph (B)(ii)) to any electing importer of such barrels pursuant to the requirements established by the Secretary under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id461fe7ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, after consultation with the Secretary of the Department of Homeland Security, shall, through such rules, regulations, and procedures as are determined appropriate, establish procedures for assignment of the reduced tax rate provided under this paragraph, which shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id461fe7ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a limitation to ensure that the number of barrels of beer for which the reduced tax rate has been assigned by a brewer—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id461fe7ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any importer does not exceed the number of barrels of beer brewed or produced by such brewer during the calendar year which were imported into the United States by such importer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id461fe7f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to all importers does not exceed the 6,000,000 barrels to which the reduced tax rate applies,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id461fe7f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures that allow the election of a brewer to assign and an importer to receive the reduced tax rate provided under this paragraph,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id461fe7f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements that the brewer provide any information as the Secretary determines necessary and appropriate for purposes of carrying out this paragraph, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id461fe7f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures that allow for revocation of eligibility of the brewer and the importer for the reduced tax rate provided under this paragraph in the case of any erroneous or fraudulent information provided under clause (iii) which the Secretary deems to be material to qualifying for such reduced rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id461fe7f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, any importer making an election described in subparagraph (B)(ii) shall be deemed to be a member of the controlled group of the brewer, as described under paragraph (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461fe7f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled group and single taxpayer rules","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id461fe7f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), in the case of a controlled group, the 6,000,000 barrel quantity specified in paragraph (1)(A)(i) and the 2,000,000 barrel quantity specified in paragraph (2)(A) shall be applied to the controlled group, and the 6,000,000 barrel quantity specified in paragraph (1)(A)(i) and the 60,000 barrel quantity specified in paragraph (2)(A) shall be apportioned among the brewers who are members of such group in such manner as the Secretary or their delegate shall by regulations prescribe. For purposes of the preceding sentence, the term “controlled group” has the meaning assigned to it by subsection (a) of section 1563, except that for such purposes the phrase “more than 50 percent” shall be substituted for the phrase “at least 80 percent” in each place it appears in such subsection. Under regulations prescribed by the Secretary, principles similar to the principles of the preceding two sentences shall be applied to a group of brewers under common control where one or more of the brewers is not a corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id461fe7f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign manufacturers and importers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (4), in the case of a controlled group, the 6,000,000 barrel quantity specified in paragraph (1)(A)(i) shall be applied to the controlled group and apportioned among the members of such group in such manner as the Secretary shall by regulations prescribe. For purposes of the preceding sentence, the term “controlled group” has the meaning given such term under subparagraph (A). Under regulations prescribed by the Secretary, principles similar to the principles of the preceding two sentences shall be applied to a group of brewers under common control where one or more of the brewers is not a corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id461fe7f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single taxpayer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pursuant to rules issued by the Secretary, two or more entities (whether or not under common control) that produce beer under a license, franchise, or other arrangement shall be treated as a single taxpayer for purposes of the application of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461fe7f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refunds in lieu of reduced rates for foreign production removed after ","children":[{"tag":"date","attrib":{"date":"2022-12-31"},"text":"December 31, 2022","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id461fe7fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any barrels of beer which have been produced outside the United States and imported into the United States, if such barrels of beer are removed after ","children":[{"tag":"date","attrib":{"date":"2022-12-31"},"text":"December 31, 2022","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"id461fe7fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (1)(A)(i) shall not apply, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id461fe7fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under subparagraph (B) shall be allowed as a refund, determined for periods not less frequently than quarterly, to the importer in the same manner as if such amount were an overpayment of tax imposed by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id461fe7fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of refund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount determined under this subparagraph with respect to any importer for any period is an amount equal to the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id461fe7fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" excess (if any) of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id461fe7ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/6/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of tax imposed under this section on barrels of beer referred to in subparagraph (A) which were removed during such period, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id461fe800-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/6/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of tax which would have been imposed under this section on such barrels of beer if this section were applied without regard to this paragraph, plus","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id461fe801-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of interest which would be allowed and paid on an overpayment of tax at the overpayment rate established under section 6621(a)(1) (without regard to the second sentence thereof) were such rate applied to the excess (if any) determined under clause (i) for the number of days in the filing period for which the refund under this paragraph is being determined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id461fe802-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of rules related to elections and assignments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A)(ii) shall apply only if the importer is an electing importer under paragraph (4) and the barrels of beer have been assigned to the importer pursuant to such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id461fe803-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/a/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules for refunds within 90 days","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of refunds allowed under this paragraph, section 6611(e) shall be applied by substituting “90 days” for “45 days” each place it appears.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id461fe804-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment on materials used in production in case of fraud","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing contained in this subpart or subchapter G shall be construed to authorize an assessment on the quantity of materials used in producing or purchased for the purpose of producing beer, nor shall the quantity of materials so used or purchased be evidence, for the purpose of taxation, of the quantity of beer produced; but the tax on all beer shall be paid as provided in section 5054, and not otherwise; except that this subsection shall not apply to cases of fraud, and nothing in this subsection shall have the effect to change the rules of law respecting evidence in any prosecution or suit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id461fe805-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Illegally produced beer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The production of any beer at any place in the United States shall be subject to tax at the rate prescribed in subsection (a) and such tax shall be due and payable as provided in section 5054(a)(3) unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id461fe806-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such beer is produced in a brewery qualified under the provisions of subchapter G, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461fe807-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5051/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such production is exempt from tax under section 5053(e) (relating to beer for personal or family use).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id461fe808-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1333"},"text":"72 Stat. 1333","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/75/s3/a/6"},"text":"Pub. L. 86–75