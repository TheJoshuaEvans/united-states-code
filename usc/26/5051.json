dren":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/259"},"text":"72 Stat. 259","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id461fe80c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s106/b/1"},"text":"Pub. L. 116–260, § 106(b)(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) consisted of subpars. (A) to (D) relating to imposition of tax on beer, rate of such tax, special rule for beer removed between "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", and size of a barrel, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A)(i)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s106/b/3/A"},"text":"Pub. L. 116–260, § 106(b)(3)(A)","children":[],"tail":", inserted “but only if the importer is an electing importer under paragraph (4) and the barrels have been assigned to the importer pursuant to such paragraph” after “during the calendar year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s106/b/2"},"text":"Pub. L. 116–260, § 106(b)(2)","children":[],"tail":", inserted “$3.50 a barrel” before “rate” in heading and substituted “$3.50” for “$7 ($3.50 in the case of beer removed after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":")” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s106/b/3/B/i"},"text":"Pub. L. 116–260, § 106(b)(3)(B)(i)","children":[],"tail":", substituted “paragraph (1)(A)” for “paragraph (1)(C)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s106/b/3/B/ii"},"text":"Pub. L. 116–260, § 106(b)(3)(B)(ii)","children":[],"tail":", substituted “The Secretary, after consultation with the Secretary of the Department of Homeland Security,” for “The Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s106/b/4"},"text":"Pub. L. 116–260, § 106(b)(4)","children":[],"tail":", substituted “paragraph (1)(A)(i)” for “paragraph (1)(C)(i)” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s110/a"},"text":"Pub. L. 116–260, § 110(a)","children":[],"tail":", substituted “under a license” for “marketed under a similar brand, license”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s107/b/1"},"text":"Pub. L. 116–260, § 107(b)(1)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1)(C), (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"January 1, 2020","children":[],"tail":"” in introductory provisions of subsec. (a)(1)(C) and in subsec. (a)(2)(A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13802/a"},"text":"Pub. L. 115–97, § 13802(a)","children":[],"tail":", amended par. (1) generally. Prior to amendment, text read as follows: “A tax is hereby imposed on all beer brewed or produced, and removed for consumption or sale, within the United States, or imported into the United States. Except as provided in paragraph (2), the rate of such tax shall be $18 for every barrel containing not more than 31 gallons and at a like rate for any other quantity or for fractional parts of a barrel.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C)(i)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13802/c/1"},"text":"Pub. L. 115–97, § 13802(c)(1)","children":[],"tail":", inserted “but only if the importer is an electing importer under paragraph (4) and the barrels have been assigned to the importer pursuant to such paragraph” after “during the calendar year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13802/b"},"text":"Pub. L. 115–97, § 13802(b)","children":[],"tail":", in heading, struck out “$7 a barrel” before “rate” and in text, inserted “($3.50 in the case of beer removed after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"January 1, 2020","children":[],"tail":")” after “$7”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13802/d/1"},"text":"Pub. L. 115–97, § 13802(d)(1)","children":[],"tail":", redesignated subpar. (C) as (B) and struck out former subpar. (B) which related to application of barrel quantity to controlled groups."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13802/c/2"},"text":"Pub. L. 115–97, § 13802(c)(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13802/d/2"},"text":"Pub. L. 115–97, § 13802(d)(2)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11201/c/1"},"text":"Pub. L. 101–508, § 11201(c)(1)","children":[],"tail":", substituted “$18” for “$9”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11201/c/2"},"text":"Pub. L. 101–508, § 11201(c)(2)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/458"},"text":"Pub. L. 95–458","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/529"},"text":"Pub. L. 94–529","children":[],"tail":" reduced the excise tax on beer for small brewers to $7 per barrel on the first 60,000 barrels produced in the United States and removed for sale or consumption or sale during the calendar year, the reduced rate to be applicable only to brewers producing no more than 2 million barrels of beer in a calendar year, and inserted provision that if several brewers are members of a controlled group, the 2–million barrel limit is to be applied to the controlled group and the 60,000–barrel limit is to be apportioned among the members of the controlled group in accordance with Treasury Department regulations promulgated by the Secretary or his delegate."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" struck out sentence providing for the imposition on and after "},{"tag":"