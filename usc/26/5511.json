{"tag":"section","attrib":{"id":"id463c70cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5511"},"text":null,"children":[{"tag":"num","attrib":{"value":"5511"},"text":"§ 5511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and operation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"This chapter (other than sections 5178(a)(2)(C), 5179, 5203(b), (c), and (d), and 5552) shall not be applicable with respect to the manufacture, by any process which includes evaporations from the mash or juice of any fruit, of any volatile fruit-flavor concentrate if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id463c70cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5511/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such concentrate, and the mash or juice from which it is produced, contains no more alcohol than is reasonably unavoidable in the manufacture of such concentrate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463c70cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5511/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such concentrate is rendered unfit for use as a beverage before removal from the place of manufacture, or (in the case of a concentrate which does not exceed 24 percent alcohol by volume) such concentrate is transferred to a bonded wine cellar for use in production of natural wine as provided in section 5382; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463c70ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5511/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manufacturer thereof makes such application, keeps such records, renders such reports, files such bonds, and complies with such other requirements with respect to the production, removal, sale, transportation, and use of such concentrate and of the mash or juice from which such concentrate is produced, as the Secretary may by regulations prescribe as necessary for the protection of the revenue.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id463c70cf-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1392"},"text":"72 Stat. 1392","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/88/653/s3"},"text":"Pub. L. 88–653, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1085"},"text":"78 Stat. 1085","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id463c70d0-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id463c70d1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id463c70d2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5511, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/677"},"text":"68A Stat. 677","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id463c70d3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/653"},"text":"Pub. L. 88–653","children":[],"tail":" inserted “or (in the case of a concentrate which does not exceed 24 percent alcohol by volume) such concentrate is transferred to a bonded wine cellar for use in production of natural wine as provided in section 5382”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id463c70d4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id463c70d5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1964 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/653"},"text":"Pub. L. 88–653","children":[],"tail":" effective on first day of second month which begins more than 10 days after "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/88/653/s4"},"text":"section 4 of Pub. L. 88–653","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5383"},"text":"section 5383 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id463c70d6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1959-07-01"},"text":"July 1, 1959","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/s210/a/1"},"text":"section 210(a)(1) of Pub. L. 85–859","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
