{"tag":"section","attrib":{"id":"id440285f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s742"},"text":null,"children":[{"tag":"num","attrib":{"value":"742"},"text":"§ 742.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis of transferee partner’s interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The basis of an interest in a partnership acquired other than by contribution shall be determined under part II of subchapter O (sec. 1011 and following).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id440285f3-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/249"},"text":"68A Stat. 249","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
