{"tag":"section","attrib":{"id":"id4736d675-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722"},"text":null,"children":[{"tag":"num","attrib":{"value":"6722"},"text":"§ 6722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to furnish correct payee statements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4736d676-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of penalty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4736d677-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of each failure described in paragraph (2) by any person with respect to a payee statement, such person shall pay a penalty of $250 for each statement with respect to which such a failure occurs, but the total amount imposed on such person for all such failures during any calendar year shall not exceed $3,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d678-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failures subject to penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the failures described in this paragraph are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d679-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any failure to furnish a payee statement on or before the date prescribed therefor to the person to whom such statement is required to be furnished, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d67a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any failure to include all of the information required to be shown on a payee statement or the inclusion of incorrect information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d67b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction where correction in specified period","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4736d67c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction within 30 days","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any failure described in subsection (a)(2) is corrected on or before the day 30 days after the date prescribed for furnishing such statement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d67d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the penalty imposed by subsection (a) shall be $50 in lieu of $250, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d67e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount imposed on the person for all such failures during any calendar year which are so corrected shall not exceed $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d67f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failures corrected on or before August 1","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any failure described in subsection (a)(2) is corrected after the 30th day referred to in paragraph (1) but on or before August 1 of the calendar year in which the date prescribed for furnishing such statement occurs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d680-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the penalty imposed by subsection (a) shall be $100 in lieu of $250, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d681-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount imposed on the person for all such failures during the calendar year which are so corrected shall not exceed $1,500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d682-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for de minimis failures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4736d683-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d684-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a payee statement is furnished to the person to whom such statement is required to be furnished,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d685-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a failure described in subsection (a)(2)(B) (determined after the application of section 6724(a)) with respect to such statement, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d686-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such failure is corrected on or before August 1 of the calendar year in which the date prescribed for furnishing such statement occurs,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for purposes of this section, such statement shall be treated as having been furnished with all of the correct required information.","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d687-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The number of payee statements to which paragraph (1) applies for any calendar year shall not exceed the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d688-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d689-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-half of 1 percent of the total number of payee statements required to be furnished by the person during the calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d68a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe harbor for certain de minimis errors","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d68b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, with respect to any payee statement—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4736d68c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are 1 or more failures described in subsection (a)(2)(B) relating to an incorrect dollar amount,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4736d68d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no single amount in error differs from the correct amount by more than $100, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4736d68e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no single amount reported for tax withheld on the payee statement differs from the correct amount by more than $25,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then no correction shall be required and, for purposes of this section, such statement shall be treated as having been furnished with all of the correct required information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d68f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply to any payee statement if the person to whom such statement is required to be furnished makes an election (at such time and in such manner as the Secretary may prescribe) that subparagraph (A) not apply with respect to such statement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d690-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may issue regulations to prevent the abuse of the safe harbor under this paragraph, including regulations providing that this paragraph shall not apply to the extent necessary to prevent any such abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d691-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lower limitations for persons with gross receipts of not more than $5,000,000","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4736d692-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any person meets the gross receipts test of paragraph (2) with respect to any calendar year, with respect to failures during such calendar year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d693-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a)(1) shall be applied by substituting “$1,000,000” for “$3,000,000”,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d694-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b)(1)(B) shall be applied by substituting “$175,000” for “$500,000”, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d695-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b)(2)(B) shall be applied by substituting “$500,000” for “$1,500,000”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d696-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gross receipts test","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person meets the gross receipts test of this paragraph if such person meets the gross receipts test of section 6721(d)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d697-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty in case of intentional disregard","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If 1 or more failures to which subsection (a) applies are due to intentional disregard of the requirement to furnish a payee statement (or the correct information reporting requirement), then, with respect to each such failure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4736d698-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsections (b), (c), and (d) shall not apply,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d699-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the penalty imposed under subsection (a)(1) shall be $500, or, if greater—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d69a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a payee statement other than a statement required under section 6045(b), 6041A(e) (in respect of a return required under section 6041A(b)), 6050H(d), 6050J(e), 6050K(b), or 6050L(c), 10 percent of the aggregate amount of the items required to be reported correctly, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4739469b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a payee statement required under section 6045(b), 6050K(b), or 6050L(c), 5 percent of the aggregate amount of the items required to be reported correctly, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4739469c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of any penalty determined under paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4739469d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the $3,000,000 limitation under subsection (a) shall not apply, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4739469e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such penalty shall not be taken into account in applying such limitation to penalties not determined under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4739469f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment for inflation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id473946a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any failure relating to a statement required to be furnished in a calendar year beginning after 2014, each of the dollar amounts under subsections (a), (b), (d)(1), and (e) shall be increased by an amount equal to such dollar amount multiplied by the cost-of-living adjustment determined under section 1(f)(3) for the calendar year determined by substituting “calendar year 2011” for “calendar year 2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id473946a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rounding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any amount adjusted under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id473946a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not less than $75,000 and is not a multiple of $500, such amount shall be rounded to the next lowest multiple of $500, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id473946a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6722/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not described in subparagraph (A) and is not a multiple of $10, such amount shall be rounded to the next lowest multiple of $10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id473946a4-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1501/a"},"text":"Pub. L. 99–514, title XV, § 1501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2733"},"text":"100 Stat. 2733","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7711/a"},"text":"Pub. L. 101–239, title VII, § 7711(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"