{"tag":"section","attrib":{"id":"id46c6af4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6315"},"text":null,"children":[{"tag":"num","attrib":{"value":"6315"},"text":"§ 6315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments of estimated income tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Payment of the estimated income tax, or any installment thereof, shall be considered payment on account of the income taxes imposed by subtitle A for the taxable year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id46c6af4d-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/778"},"text":"68A Stat. 778","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
