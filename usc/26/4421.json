{"tag":"section","attrib":{"id":"id45d5e62e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4421"},"text":null,"children":[{"tag":"num","attrib":{"value":"4421"},"text":"§ 4421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d5e62f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4421/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wager","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “wager” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45d5e630-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4421/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any wager with respect to a sports event or a contest placed with a person engaged in the business of accepting such wagers,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d5e631-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4421/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any wager placed in a wagering pool with respect to a sports event or a contest, if such pool is conducted for profit, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d5e632-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4421/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any wager placed in a lottery conducted for profit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e633-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4421/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lottery","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “lottery” includes the numbers game, policy, and similar types of wagering. The term does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45d5e634-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4421/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any game of a type in which usually","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45d5e635-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4421/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the wagers are placed,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45d5e636-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4421/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the winners are determined, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45d5e637-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4421/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distribution of prizes or other property is made, in the presence of all persons placing wagers in such game, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d5e638-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4421/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any drawing conducted by an organization exempt from tax under sections 501 and 521, if no part of the net proceeds derived from such drawing inures to the benefit of any private shareholder or individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d5e639-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/528"},"text":"68A Stat. 528","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
