{"tag":"section","attrib":{"id":"id4147d2e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s84"},"text":null,"children":[{"tag":"num","attrib":{"value":"84"},"text":"§ 84.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of appreciated property to political organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4147d2e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s84/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4147d2e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s84/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person transfers property to a political organization, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4147d2ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s84/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of such property exceeds its adjusted basis,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then for purposes of this chapter the transferor shall be treated as having sold such property to the political organization on the date of the transfer, and the transferor shall be treated as having realized an amount equal to the fair market value of such property on such date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4147d2eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s84/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a transfer of property to a political organization to which subsection (a) applies, the basis of such property in the hands of the political organization shall be the same as it would be in the hands of the transferor, increased by the amount of gain recognized to the transferor by reason of such transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4147d2ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s84/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Political organization defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “political organization” has the meaning given to such term by section 527(e)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4147d2ed-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/625/s13/a/1"},"text":"Pub. L. 93–625, § 13(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2120"},"text":"88 Stat. 2120","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/35"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(35)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1186"},"text":"132 Stat. 1186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4147d2ee-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4147d2ef-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4147d2f0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “political organizations” for “political organization” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4147d2f1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4147d2f2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/625/s13/b"},"text":"Pub. L. 93–625, § 13(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2121"},"text":"88 Stat. 2121","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/625/s13/b"},"text":"“The amendments made by subsection (a) [enacting this section] shall apply to transfers made after ","children":[{"tag":"date","attrib":{"date":"1974-05-07"},"text":"May 7, 1974","children":[],"tail":", in taxable years ending after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4147d2f3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Nonrecognition of Gain or Loss Where Organization Sold Contributed Property Before ","children":[{"tag":"date","attrib":{"date":"1973-08-02"},"text":"August 2, 1973","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/625/s13/c"},"text":"Pub. L. 93–625, § 13(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2121"},"text":"88 Stat. 2121","children":[],"tail":", provided that in the case of the sale or exchange of property before "},{"tag":"date","attrib":{"date":"1973-08-02"},"text":"Aug. 2, 1973","children":[],"tail":", which was acquired by the exempt political organization by contribution, no gain or loss shall be recognized by such organization."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
