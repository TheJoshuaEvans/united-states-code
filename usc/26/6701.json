{"tag":"section","attrib":{"id":"id47321abb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701"},"text":null,"children":[{"tag":"num","attrib":{"value":"6701"},"text":"§ 6701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for aiding and abetting understatement of tax liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47321abc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47321abd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who aids or assists in, procures, or advises with respect to, the preparation or presentation of any portion of a return, affidavit, claim, or other document,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47321abe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who knows (or has reason to believe) that such portion will be used in connection with any material matter arising under the internal revenue laws, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47321abf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who knows that such portion (if so used) would result in an understatement of the liability for tax of another person,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall pay a penalty with respect to each such document in the amount determined under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47321ac0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of penalty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47321ac1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the amount of the penalty imposed by subsection (a) shall be $1,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47321ac2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the return, affidavit, claim, or other document relates to the tax liability of a corporation, the amount of the penalty imposed by subsection (a) shall be $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47321ac3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Only 1 penalty per person per period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any person is subject to a penalty under subsection (a) with respect to any document relating to any taxpayer for any taxable period (or where there is no taxable period, any taxable event), such person shall not be subject to a penalty under subsection (a) with respect to any other document relating to such taxpayer for such taxable period (or event).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47321ac4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities of subordinates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47321ac5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the term “procures” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47321ac6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ordering (or otherwise causing) a subordinate to do an act, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47321ac7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowing of, and not attempting to prevent, participation by a subordinate in an act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47321ac8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subordinate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the term “subordinate” means any other person (whether or not a director, officer, employee, or agent of the taxpayer involved) over whose activities the person has direction, supervision, or control.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47321ac9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxpayer not required to have knowledge","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall apply whether or not the understatement is with the knowledge or consent of the persons authorized or required to present the return, affidavit, claim, or other document.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47321aca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain actions not treated as aid or assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a)(1), a person furnishing typing, reproducing, or other mechanical assistance with respect to a document shall not be treated as having aided or assisted in the preparation of such document by reason of such assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47321acb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty in addition to other penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47321acc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided by paragraphs (2) and (3), the penalty imposed by this section shall be in addition to any other penalty provided by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47321acd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with return preparer penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be assessed under subsection (a) or (b) of section 6694 on any person with respect to any document for which a penalty is assessed on such person under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47321ace-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6701/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with section 6700","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be assessed under section 6700 on any person with respect to any document for which a penalty is assessed on such person under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47321acf-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s324/a"},"text":"Pub. L. 97–248, title III, § 324(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/615"},"text":"96 Stat. 615","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7735/a"},"text":"Pub. L. 101–239, title VII, § 7735(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2403"},"text":"103 Stat. 2403","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47321ad0-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47321ad1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47321ad2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7735/a/1"},"text":"Pub. L. 101–239, § 7735(a)(1)","children":[],"tail":", struck out “in connection with any matter arising under the internal revenue laws” after “other document”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7735/a/2"},"text":"Pub. L. 101–239, § 7735(a)(2)","children":[],"tail":", inserted “(or has reason to believe)” after “who knows”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7735/a/3"},"text":"Pub. L. 101–239, § 7735(a)(3)","children":[],"tail":", substituted “would result” for “will result”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7735/b/2"},"text":"Pub. L. 101–239, § 7735(b)(2)","children":[],"tail":", substituted “paragraphs (2) and (3)” for “paragraph (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7735/b/1"},"text":"Pub. L. 101–239, § 7735(b)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47321ad3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47321ad4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7735/c"},"text":"Pub. L. 101–239, title VII, § 7735(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2404"},"text":"103 Stat. 2404","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tVII/s7735/c"},"text":"“The amendments made by this section [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1989-12-31"},"text":"December 31, 1989","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47321ad5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s324/c"},"text":"Pub. L. 97–248, title III, § 324(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/616"},"text":"96 Stat. 616","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/248/tIII/s324/c"},"text":"“The amendments made by this section [enacting this section] shall take effect on the day after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
