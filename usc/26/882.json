{"tag":"section","attrib":{"id":"id44586df7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882"},"text":null,"children":[{"tag":"num","attrib":{"value":"882"},"text":"§ 882.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on income of foreign corporations connected with United States business","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44586df8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44586df9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A foreign corporation engaged in trade or business within the United States during the taxable year shall be taxable as provided in section 11, 55, or 59A,","children":[{"tag":"ref","attrib":{"idref":"fn002143"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002143"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" on its taxable income which is effectively connected with the conduct of a trade or business within the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44586dfa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of taxable income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining taxable income for purposes of paragraph (1), gross income includes only gross income which is effectively connected with the conduct of a trade or business within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44586dfb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" [Cross reference ","children":[{"tag":"ref","attrib":{"idref":"fn002144"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002144"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" Par. (3) heading editorially supplied."}],"tail":"]"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For special tax treatment of gain or loss from the disposition by a foreign corporation of a United States real property interest, see section 897.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44586dfc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gross income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a foreign corporation, except where the context clearly indicates otherwise, gross income includes only—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44586dfd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gross income which is derived from sources within the United States and which is not effectively connected with the conduct of a trade or business within the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44586dfe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gross income which is effectively connected with the conduct of a trade or business within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44586dff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of deductions and credits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44586e00-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of deductions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44586e01-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a foreign corporation, the deductions shall be allowed only for purposes of subsection (a) and (except as provided by subparagraph (B)) only if and to the extent that they are connected with income which is effectively connected with the conduct of a trade or business within the United States; and the proper apportionment and allocation of the deductions for this purpose shall be determined as provided in regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44586e02-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charitable contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The deduction for charitable contributions and gifts provided by section 170 shall be allowed whether or not connected with income which is effectively connected with the conduct of a trade or business within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44586e03-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deductions and credits allowed only if return filed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A foreign corporation shall receive the benefit of the deductions and credits allowed to it in this subtitle only by filing or causing to be filed with the Secretary a true and accurate return, in the manner prescribed in subtitle F, including therein all the information which the Secretary may deem necessary for the calculation of such deductions and credits. The preceding sentence shall not apply for purposes of the tax imposed by section 541 (relating to personal holding company tax), and shall not be construed to deny the credit provided by section 33 for tax withheld at source or the credit provided by section 34 for certain uses of gasoline.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44586e04-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign tax credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided by section 906, foreign corporations shall not be allowed the credit against the tax for taxes of foreign countries and possessions of the United States allowed by section 901.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44586e05-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For rule that certain foreign taxes are not to be taken into account in determining deduction or credit, see section 906(b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44586e06-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to treat real property income as income connected with United States business","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44586e07-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A foreign corporation which during the taxable year derives any income—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44586e08-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from real property located in the United States, or from any interest in such real property, including (i) gains from the sale or exchange of real property or an interest therein, (ii) rents or royalties from mines, wells, or other natural deposits, and (iii) gains described in section 631(b) or (c), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44586e09-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which, but for this subsection, would not be treated as income effectively connected with the conduct of a trade or business within the United States,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may elect for such taxable year to treat all such income as income which is effectively connected with the conduct of a trade or business within the United States. In such case, such income shall be taxable as provided in subsection (a)(1) whether or not such corporation is engaged in trade or business within the United States during the taxable year. An election under this paragraph for any taxable year shall remain in effect for all subsequent taxable years, except that it may be revoked with the consent of the Secretary with respect to any taxable year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44586e0a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election after revocation, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraphs (2) and (3) of section 871(d) shall apply in respect of elections under this subsection in the same manner and to the same extent as they apply in respect of elections under section 871(d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44586e0b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest on United States obligations received by banks organized in possessions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a corporation created or organized in, or under the law of, a possession of the United States which is carrying on the banking business in a possession of the United States, interest on obligations of the United States which is not portfolio interest (as defined in section 881(c)(2)) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44586e0c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of this subpart, be treated as income which is effectively connected with the conduct of a trade or business within the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44586e0d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be taxable as provided in subsection (a)(1) whether or not such corporation is engaged in trade or business within the United States during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44586e0e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s882/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns of tax by agent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any foreign corporation has no office or place of business in the United States but has an agent in the United States, the return required under section 6012 shall be made by the agent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44586e0f-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/282"},"text":"68A Stat. 282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/tI/s104/b/1"},"text":"Pub. L. 89–809, title I, § 104(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1555"},"text":"80 Stat. 1555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tIII/s301/b/13"},"text":"Pub. L. 95–600, title III, § 301(b)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2822"},"text":"92 Stat. 2822","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/499/tXI/s1122/c/2"},"text":"Pub. L. 96–499, title XI, § 1122(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-05"},"text":"Dec. 5, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2687"},"text":"94 Stat. 2687","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/424/tV/s515/b/6/F"},"text":"Pub. L. 97–424, title V, § 515(b)(6)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-06"},"text":"Jan. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2182"},"text":"96 Stat. 2182","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s474/r/19"},"text":"Pub. L. 98–369, div. A, title IV, § 474(r)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/843"},"text":"98 Stat. 843","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVII/s701/e/4/F"},"text":"Pub. L. 99–514, title VII, § 701(e)(4)(F)","children":[],"tail":", title XII, § 1236(a), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2343"},"text":"100 Stat. 2343","children":[],"tail":", 2576; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/s/2/B"},"text":"Pub. L. 100–647, title I, § 1012(s)(2)(B)","children":[],"tail":", title II, § 2001(c)(2), title VI, § 6133(a), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3527"},"text":"102 Stat. 3527","children":[],"tail":", 3594, 3721; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/12/F"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(12)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4038"},"text":"128 Stat. 4038","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI"},"text":"Pub. L. 115–97, title I","children":[],"tail":", §§ 12001(b)(14), 13001(b)(2)(L), 14401(d)(2), "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2094"},"text":"131 Stat. 2094","children":[],"tail":", 2097, 2233; "},{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s10101/a/4/E"},"text":"Pub. L. 117–169, title I, § 10101(a)(4)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1822"},"text":"136 Stat. 1822","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44586e10-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44586e11-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44586e12-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":" inserted “, 55,” after “section 11”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s14401/d/2"},"text":"Pub. L. 115–97, § 14401(d)(2)","children":[],"tail":", which directed insertion of “or 59A,” after “section 11,”, was executed by making the insertion after “section 11” to reflect the probable intent of Congress and the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s12001/b/14"},"text":"Pub. L. 115–97, § 12001(b)(14)","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13001/b/2/L"},"text":"Pub. L. 115–97, § 13001(b)(2)(L)","children":[],"tail":", struck out “or 1201(a)” before “on its taxable income”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s12001/b/14"},"text":"Pub. L. 115–97, § 12001(b)(14)","children":[],"tail":", struck out “, 55,” after “section 11”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" struck out “, 59A” after “section 11, 55”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2001/c/2"},"text":"Pub. L. 100–647, § 2001(c)(2)","children":[],"tail":", inserted reference to section 59A."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1012/s/2/B"},"text":"Pub. L. 100–647, § 1012(s)(2)(B)","children":[],"tail":", inserted “, except where the context clearly indicates otherwise” after “foreign corporation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s6133/a"},"text":"Pub. L. 100–647, § 6133(a)","children":[],"tail":", substituted “interest on obligations of the United States which is not portfolio interest (as defined in section 881(c)(2))” for “interest on obligations of the United States”, and struck out at end “The preceding sentence shall not apply to any Guam corporation which is treated as not being a foreign corporation by section 881(b)(1) for the taxable year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s701/e/4/F"},"text":"Pub. L. 99–514, § 701(e)(4)(F)","children":[],"tail":", inserted reference to section 55."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1236/a"},"text":"Pub. L. 99–514, § 1236(a)","children":[],"tail":", inserted “The preceding sentence shall not apply to any Guam corporation which is treated as not being a foreign corporation by section 881(b)(1) for the taxable year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted reference to section “33” for “32” and “34” for “39”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/424"},"text":"Pub. L. 97–424","children":[],"tail":" struck out “and lubricating oil” after “gasoline”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/499"},"text":"Pub. L. 96–499","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" substituted in subsec. (a) heading “Imposition of tax” for “Normal tax and surtax” and in par. (1) heading “In general” for “Imposition of tax”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (c)(1)(A), (2), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809"},"text":"Pub. L. 89–809","children":[],"tail":" substantially revised the income tax treatment of foreign corporations, introduced the concept of taxable income effectively connected with the conduct of a trade or business within the United States into provisions dealing with the imposition of tax, substituted a concept of gross income 