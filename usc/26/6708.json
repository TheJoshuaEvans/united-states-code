{"tag":"section","attrib":{"id":"id47346451-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6708"},"text":null,"children":[{"tag":"num","attrib":{"value":"6708"},"text":"§ 6708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to maintain lists of advisees with respect to reportable transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47346452-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of penalty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47346453-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6708/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any person who is required to maintain a list under section 6112(a) fails to make such list available upon written request to the Secretary in accordance with section 6112(b) within 20 business days after the date of such request, such person shall pay a penalty of $10,000 for each day of such failure after such 20th day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47346454-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6708/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable cause exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed by paragraph (1) with respect to the failure on any day if such failure is due to reasonable cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47346455-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty in addition to other penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalty imposed by this section shall be in addition to any other penalty provided by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47346456-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s142/b"},"text":"Pub. L. 98–369, div. A, title I, § 142(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/682"},"text":"98 Stat. 682","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1534/a"},"text":"Pub. L. 99–514, title XV, § 1534(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2750"},"text":"100 Stat. 2750","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII"},"text":"Pub. L. 108–357, title VIII","children":[],"tail":", §§ 815(b)(5)(A), 817(a), "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1583"},"text":"118 Stat. 1583","children":[],"tail":", 1584.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47346457-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47346458-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id47346459-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 6708 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6709"},"text":"section 6709 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4734645a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s815/b/5/A"},"text":"Pub. L. 108–357, § 815(b)(5)(A)","children":[],"tail":", substituted “advisees with respect to reportable transactions” for “investors in potentially abusive tax shelters” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s817/a"},"text":"Pub. L. 108–357, § 817(a)","children":[],"tail":", amended heading and text of subsec. (a) generally. Prior to amendment, text read as follows: “Any person who fails to meet any requirement imposed by section 6112 shall pay a penalty of $50 for each person with respect to whom there is such a failure, unless it is shown that such failure is due to reasonable cause and not due to willful neglect. The maximum penalty imposed under this subsection for any calendar year shall not exceed $100,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “$100,000” for “$50,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4734645b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4734645c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s815/b/5/A"},"text":"section 815(b)(5)(A) of Pub. L. 108–357","children":[],"tail":" applicable to transactions with respect to which material aid, assistance, or advice referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6111/b/1/A/i"},"text":"section 6111(b)(1)(A)(i) of this title","children":[],"tail":" is provided after "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s815/c"},"text":"section 815(c) of Pub. L. 108–357","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6111"},"text":"section 6111 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s817/b"},"text":"Pub. L. 108–357, title VIII, § 817(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1584"},"text":"118 Stat. 1584","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tVIII/s817/b"},"text":"“The amendment made by this section [amending this section] shall apply to requests made after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":"].”"}],"tail":"\n"}