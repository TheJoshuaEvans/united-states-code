{"tag":"section","attrib":{"id":"id440285ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s741"},"text":null,"children":[{"tag":"num","attrib":{"value":"741"},"text":"§ 741.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition and character of gain or loss on sale or exchange","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the case of a sale or exchange of an interest in a partnership, gain or loss shall be recognized to the transferor partner. Such gain or loss shall be considered as gain or loss from the sale or exchange of a capital asset, except as otherwise provided in section 751 (relating to unrealized receivables and inventory items).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id440285ee-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/248"},"text":"68A Stat. 248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/147/tIV/s417/12"},"text":"Pub. L. 107–147, title IV, § 417(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-09"},"text":"Mar. 9, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/56"},"text":"116 Stat. 56","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id440285ef-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id440285f0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id440285f1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147"},"text":"Pub. L. 107–147","children":[],"tail":" struck out “which have appreciated substantially in value” after “inventory items”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
