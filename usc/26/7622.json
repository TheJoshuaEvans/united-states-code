{"tag":"section","attrib":{"id":"id477bf584-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7622"},"text":null,"children":[{"tag":"num","attrib":{"value":"7622"},"text":"§ 7622.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to administer oaths and certify","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id477bf585-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7622/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internal revenue personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every officer or employee of the Treasury Department designated by the Secretary for that purpose is authorized to administer such oaths or affirmations and to certify to such papers as may be necessary under the internal revenue laws or regulations made thereunder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id477bf586-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7622/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Others","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any oath or affirmation required or authorized under any internal revenue law or under any regulations made thereunder may be administered by any person authorized to administer oaths for general purposes by the law of the United States, or of any State or possession of the United States, or of the District of Columbia, wherein such oath or affirmation is administered. This subsection shall not be construed as an exclusive enumeration of the persons who may administer such oaths or affirmations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id477bf587-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/904"},"text":"68A Stat. 904","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", (c)(2), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":", 1835.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id477bf588-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id477bf589-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id477bf58a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/c/2"},"text":"Pub. L. 94–455, § 1906(c)(2)","children":[],"tail":", struck out “Territory” after “any State”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
