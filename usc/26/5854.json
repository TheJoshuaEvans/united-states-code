{"tag":"section","attrib":{"id":"id4651f470-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5854"},"text":null,"children":[{"tag":"num","attrib":{"value":"5854"},"text":"§ 5854.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exportation of firearms exempt from transfer tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A firearm may be exported without payment of the transfer tax imposed under section 5811 provided that proof of the exportation is furnished in such form and manner as the Secretary may by regulations prescribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4651f471-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/618/tII/s201"},"text":"Pub. L. 90–618, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1234"},"text":"82 Stat. 1234","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4651f472-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4651f473-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4651f474-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5854, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s203/i/1"},"text":"Pub. L. 85–859, title II, § 203(i)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1428"},"text":"72 Stat. 1428","children":[],"tail":", related to failure to register and pay special tax, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/90/618"},"text":"Pub. L. 90–618","children":[],"tail":". See section 5861(a), (d) of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s923"},"text":"section 923 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising this section were contained in prior section 5844, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/725"},"text":"68A Stat. 725","children":[],"tail":", prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/90/618"},"text":"Pub. L. 90–618","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5855, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s203/i/1"},"text":"Pub. L. 85–859, title II, § 203(i)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1428"},"text":"72 Stat. 1428","children":[],"tail":", made it unlawful for any person required to comply with the provisions of sections 5814, 5821, and 5841 of this title, to ship, carry or deliver any firearm in interstate commerce if such sections had not been complied with, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/90/618"},"text":"Pub. L. 90–618","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4651f475-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
