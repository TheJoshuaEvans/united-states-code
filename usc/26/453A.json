{"tag":"section","attrib":{"id":"id4381bd18-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A"},"text":null,"children":[{"tag":"num","attrib":{"value":"453A"},"text":"§ 453A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for nondealers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4381bd19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an installment obligation to which this section applies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4381bd1a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest shall be paid on the deferred tax liability with respect to such obligation in the manner provided under subsection (c), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4381bd1b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pledging rules under subsection (d) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4381bd1c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Installment obligations to which section applies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4381bd1d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to any obligation which arises from the disposition of any property under the installment method, but only if the sales price of such property exceeds $150,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4381bd1e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for interest payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)(1), this section shall apply to an obligation described in paragraph (1) arising during a taxable year only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4381bd1f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such obligation is outstanding as of the close of such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4381bd20-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the face amount of all such obligations held by the taxpayer which arose during, and are outstanding as of the close of, such taxable year exceeds $5,000,000.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Except as provided in regulations, all persons treated as a single employer under subsection (a) or (b) of section 52 shall be treated as one person for purposes of this paragraph and subsection (c)(4).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4381bd21-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for personal use and farm property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An installment obligation shall not be treated as described in paragraph (1) if it arises from the disposition—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4381bd22-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an individual of personal use property (within the meaning of section 1275(b)(3)), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4381bd23-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of any property used or produced in the trade or business of farming (within the meaning of section 2032A(e)(4) or (5)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4381bd24-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for timeshares and residential lots","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An installment obligation shall not be treated as described in paragraph (1) if it arises from a disposition described in section 453(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)(B), but the provisions of section 453("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3) (relating to interest payments on timeshares and residential lots) shall apply to such obligation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4381bd25-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sales price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), all sales or exchanges which are part of the same transaction (or a series of related transactions) shall be treated as 1 sale or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4381bd26-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest on deferred tax liability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4381bd27-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an obligation to which this section applies is outstanding as of the close of any taxable year, the tax imposed by this chapter for such taxable year shall be increased by the amount of interest determined in the manner provided under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4381bd28-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the interest for any taxable year shall be an amount equal to the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4381bd29-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable percentage of the deferred tax liability with respect to such obligation, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4381bd2a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the underpayment rate in effect under section 6621(a)(2) for the month with or within which the taxable year ends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4381bd2b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferred tax liability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “deferred tax liability” means, with respect to any taxable year, the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4381bd2c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of gain with respect to an obligation which has not been recognized as of the close of such taxable year, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4381bd2d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum rate of tax in effect under section 1 or 11, whichever is appropriate, for such taxable year.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of applying the preceding sentence with respect to so much of the gain which, when recognized, will be treated as long-term capital gain, the maximum rate on net capital gain under section 1(h) shall be taken into account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4381bd2e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable percentage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “applicable percentage” means, with respect to obligations arising in any taxable year, the percentage determined by dividing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4381bd2f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the portion of the aggregate face amount of such obligations outstanding as of the close of such taxable year in excess of $5,000,000, by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4381bd30-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate face amount of such obligations outstanding as of the close of such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4381bd31-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount payable under this subsection shall be taken into account in computing the amount of any deduction allowable to the taxpayer for interest paid or accrued during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4381bd32-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to carry out the provisions of this subsection including regulations providing for the application of this subsection in the case of contingent payments, short taxable years, and pass-thru entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4381bd33-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pledges, etc., of installment obligations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4381bd34-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of section 453, if any indebtedness (hereinafter in this subsection referred to as “secured indebtedness”) is secured by an installment obligation to which this section applies, the net proceeds of the secured indebtedness shall be treated as a payment received on such installment obligation as of the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4381bd35-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time the indebtedness becomes secured indebtedness, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4381bd36-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time the proceeds of such indebtedness are received by the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4381bd37-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation based on total contract price","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount treated as received under paragraph (1) by reason of any secured indebtedness shall not exceed the excess (if any) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4381bd38-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total contract price, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4381bd39-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any portion of the total contract price received under the contract before the later of the times referred to in subparagraph (A) or (B) of paragraph (1) (including amounts previously treated as received under paragraph (1) but not including amounts not taken into account by reason of paragraph (3)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4381bd3a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Later payments treated as receipt of tax paid amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any amount is treated as received under paragraph (1) with respect to any installment obligation, subsequent payments received on such obligation shall not be taken into account for purposes of section 453 to the extent that the aggregate of such subsequent payments does not exceed the aggregate amount treated as received under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4381bd3b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secured indebtedness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection indebtedness is secured by an installment obligation to the extent that payment of principal or interest on such indebtedness is directly secured (under the terms of the indebtedness or any underlying arrangements) by any interest in such installment obligation. A payment shall be treated as directly secured by an interest in an installment obligation to the extent an arrangement allows the taxpayer to satisfy all or a portion of the indebtedness with the installment obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4381bd3c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to carry out the purposes of this section, including regulations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4381bd3d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disallowing the use of the installment method in whole or in part for transactions in which the rules of this section otherwise would be avoided through the use of related persons, pass-thru entities, or intermediaries, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4381bd3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s453A/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing that the sale of an interest in a partnership or other pass-thru entity will be treated as a sale of the proportionate share of the assets of the partnership or other entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4381bd3f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/471/s2/a"},"text":"Pub. L. 96–471, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-19"},"text":"Oct. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2251"},"text":"94 Stat. 2251","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVIII/s812/b"},"text":"Pub. L. 99–514, title VIII, § 812(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2371"},"text":"100 Stat. 2371","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10202/c/s1"},"text":"Pub. L. 100–203, title X, § 10202(c)[(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-390"},"text":"101 Stat. 1330–390","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1008/g/2"},"text":"Pub. L. 100–647, title I, § 1008(g)(2)","children":[],"tail":", title II, § 2004(d)(2), (7), (8), title V, § 5076(a), (b)(1), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3442"},"text":"102 Stat. 3442","children":[],"tail":", 3599, 3600, 3682; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII"},"text":"Pub. L. 101–239, title VII","children":[],"tail":", §§ 7812(c)(2), 7815(g), 7821(a)(1)–(3), (4)(B), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2412"},"text":"103 Stat. 2412","children":[],"tail":", 2420, 2423, 2424; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13201/b/4"},"text":"Pub. L. 103–66, title XIII, § 13201(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/459"},"text":"107 Stat. 459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/170/tV/s536/b"},"text":"Pub. L. 106–170, title V, § 536(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-17"},"text":"Dec. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1936"},"text":"113 Stat. 1936","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13001/b/2/C"},"text":"Pub. L. 115–97, title I, § 13001(b)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2096"},"text":"131 Stat. 2096","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4381bd40-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4381bd41-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4381bd42-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising this section were contained in former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s453"},"text":"section 453 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4381bd43-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amen