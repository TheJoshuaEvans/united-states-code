{"tag":"section","attrib":{"id":"id44caded4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1249"},"text":null,"children":[{"tag":"num","attrib":{"value":"1249"},"text":"§ 1249.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gain from certain sales or exchanges of patents, etc., to foreign corporations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44caded5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1249/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gain from the sale or exchange of a patent, an invention, model, or design (whether or not patented), a copyright, a secret formula or process, or any other similar property right to any foreign corporation by any United States person (as defined in section 7701(a)(30)) which controls such foreign corporation shall, if such gain would (but for the provisions of this subsection) be gain from the sale or exchange of a capital asset or of property described in section 1231, be considered as ordinary income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44caded6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1249/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Control","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), control means, with respect to any foreign corporation, the ownership, directly or indirectly, of stock possessing more than 50 percent of the total combined voting power of all classes of stock entitled to vote. For purposes of this subsection, the rules for determining ownership of stock prescribed by section 958 shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44caded7-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/834/s16/a"},"text":"Pub. L. 87–834, § 16(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-16"},"text":"Oct. 16, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1045"},"text":"76 Stat. 1045","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/tI/s104/m/3"},"text":"Pub. L. 89–809, title I, § 104(m)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1563"},"text":"80 Stat. 1563","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1901/b/3/K"},"text":"Pub. L. 94–455, title XIX, § 1901(b)(3)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1793"},"text":"90 Stat. 1793","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/84"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(84)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4049"},"text":"128 Stat. 4049","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44caded8-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44caded9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id