{"tag":"section","attrib":{"id":"id4651f43e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5848"},"text":null,"children":[{"tag":"num","attrib":{"value":"5848"},"text":"§ 5848.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictive use of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4651f43f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5848/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No information or evidence obtained from an application, registration, or records required to be submitted or retained by a natural person in order to comply with any provision of this chapter or regulations issued thereunder, shall, except as provided in subsection (b) of this section, be used, directly or indirectly, as evidence against that person in a criminal proceeding with respect to a violation of law occurring prior to or concurrently with the filing of the application or registration, or the compiling of the records containing the information or evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4651f440-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5848/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Furnishing false information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) of this section shall not preclude the use of any such information or evidence in a prosecution or other action under any applicable provision of law with respect to the furnishing of false information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4651f441-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/618/tII/s201"},"text":"Pub. L. 90–618, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1232"},"text":"82 Stat. 1232","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4651f442-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4651f443-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4651f444-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5848, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/727"},"text":"68A Stat. 727","children":[],"tail":", as amended by acts "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s203/f"},"text":"Pub. L. 85–859, title II, § 203(f)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1427"},"text":"72 Stat. 1427","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1960-06-01"},"text":"June 1, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/86/478/s3"},"text":"Pub. L. 86–478, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/149"},"text":"74 Stat. 149","children":[],"tail":", related to definition of a firearm, mach