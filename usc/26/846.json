{"tag":"section","attrib":{"id":"id441cc45d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846"},"text":null,"children":[{"tag":"num","attrib":{"value":"846"},"text":"§ 846.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discounted unpaid losses defined","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id441cc45e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discounted losses determined","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id441cc45f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separately computed for each accident year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the discounted unpaid losses as of the end of any taxable year shall be the sum of the discounted unpaid losses (as of such time) separately computed under this section with respect to unpaid losses in each line of business attributable to each accident year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441cc460-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of discounting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the discounted unpaid losses as of the end of any taxable year attributable to any accident year shall be the present value of such losses (as of such time) determined by using—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id441cc461-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the undiscounted unpaid losses as of such time,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id441cc462-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable interest rate, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id441cc463-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable loss payment pattern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441cc464-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on amount of discounted losses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In no event shall the amount of the discounted unpaid losses with respect to any line of business attributable to any accident year exceed the aggregate amount of unpaid losses with respect to such line of business for such accident year included on the annual statement filed by the taxpayer for the year ending with or within the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441cc465-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of applicable factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the amount of the discounted unpaid losses attributable to any accident year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id441cc466-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable interest rate shall be the interest rate determined under subsection (c) for the calendar year with which such accident year ends, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id441cc467-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable loss payment pattern shall be the loss payment pattern determined under subsection (d) which is in effect for the calendar year with which such accident year ends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id441cc468-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of undiscounted unpaid losses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id441cc469-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subsection, the term “undiscounted unpaid losses” means the unpaid losses shown in the annual statement filed by the taxpayer for the year ending with or within the taxable year of the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441cc46a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment if losses discounted on annual statement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id441cc46b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of unpaid losses shown in the annual statement is determined on a discounted basis, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id441cc46c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the losses were discounted can be determined on the basis of information disclosed on or with the annual statement,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the amount of the unpaid losses shall be determined without regard to any reduction attributable to such discounting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id441cc46d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of interest","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id441cc46e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the rate of interest determined under this subsection shall be the annual rate determined by the Secretary under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441cc46f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of annual rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The annual rate determined by the Secretary under this paragraph for any calendar year shall be a rate determined on the basis of the corporate bond yield curve (as defined in section 430(h)(2)(D)(i), determined by substituting “60-month period” for “24-month period” therein).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id441cc470-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loss payment pattern","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id441cc471-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each determination year, the Secretary shall determine a loss payment pattern for each line of business by reference to the historical loss payment pattern applicable to such line of business. Any loss payment pattern determined by the Secretary shall apply to the accident year ending with the determination year and to each of the 4 succeeding accident years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441cc472-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Determinations under paragraph (1) for any determination year shall be made by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id441cc473-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by using the aggregate experience reported on the annual statements of insurance companies,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id441cc474-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the basis of the most recent published aggregate data from such annual statements relating to loss payment patterns available on the 1st day of the determination year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id441cc475-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as if all losses paid or treated as paid during any year are paid in the middle of such year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id441cc476-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with the computational rules prescribed in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441cc477-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computational rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id441cc478-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this paragraph, the loss payment pattern for any line of business shall be based on the assumption that all losses are paid—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id441cc479-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the accident year and the 3 calendar years following the accident year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id441cc47a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any line of business reported in the schedule or schedules of the annual statement relating to auto liability, other liability, medical malpractice, workers’ compensation, and multiple peril lines, during the accident year and the 10 calendar years following the accident year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id441cc47b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain losses","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id441cc47c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 3-year loss payment pattern","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any line of business not described in subparagraph (A)(ii), losses paid after the 1st year following the accident year shall be treated as paid equally in the 2nd and 3rd year following the accident year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id441cc47d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 10-year loss payment pattern","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id441cc47e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/d/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The period taken into account under subparagraph (A)(ii) shall be extended to the extent required under subclause (II).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id441cc47f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/d/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of losses which would have been treated as paid in the 10th year after the accident year shall be treated as paid in such 10th year and each subsequent year in an amount equal to the amount of the average of the losses treated as paid in the 7th, 8th, and 9th years after the accident year (or, if lesser, the portion of the unpaid losses not theretofore taken into account). To the extent such unpaid losses have not been treated as paid before the 24th year after the accident year, they shall be treated as paid in such 24th year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441cc480-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “determination year” means calendar year 1987 and each 5th calendar year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id441cc481-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id441cc482-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accident year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “accident year” means the calendar year in which the incident occurs which gives rise to the related unpaid loss.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441cc483-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unpaid loss adjustment expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “unpaid losses” includes any unpaid loss adjustment expenses shown on the annual statement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441cc484-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual statement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “annual statement” means the annual statement approved by the National Association of Insurance Commissioners which the taxpayer is required to file with insurance regulatory authorities of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441cc485-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Line of business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “line of business” means a category for the reporting of loss payment patterns determined on the basis of the annual statement for fire and casualty insurance companies for the calendar year ending with or within the taxable year, except that the multiple peril lines shall be treated as a single line of business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441cc486-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple peril lines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “multiple peril lines” means the lines of business relating to farmowners multiple peril, homeowners multiple peril, commercial multiple peril, ocean marine, aircraft (all perils) and boiler and machinery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441cc487-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for certain accident and health insurance lines of business","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any determination under subsection (a) with respect to unpaid losses relating to accident and health insurance lines of businesses (other than credit disability insurance) shall be made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id441cc488-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/e/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of unpaid losses relating to disability income, by using the general rules prescribed under section 807(d) applicable to noncancellable accident and health insurance contracts and using a mortality or morbidity table reflecting the taxpayer’s experience; except that the limitation of subsection (a)(3) shall apply, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id441cc489-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/e/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in all other cases, by using an assumption (in lieu of a loss payment pattern) that unpaid losses are paid in the middle of the year following the accident year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id441cc48a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary or appropriate to carry out the purposes of this section, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id441cc48b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations providing proper treatment of allocated reinsurance, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441cc48c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s846/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations providing appropriate adjustments in the application of this section to a taxpayer having a taxable year which is not the calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id441cc48d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tX/s1023/c"},"text":"Pub. L. 99–514, title X, § 1023(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2399"},"text":"100 Stat. 2399","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1010/e/1"},"text":"Pub. L. 100–647, title I, § 1010(e)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3453"},"text":"102 Stat. 3453","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11305/b"},"text":"Pub. L. 101–508, title XI, § 11305(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-451"},"text":"104 Stat. 1388–451","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI"},"text":"Pub. L. 115–97, title I","children":[],"tail":", §§ 13517(b)(3), 13523(a)–(c), "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2147"},"text":"131 Stat. 2147","children":[],"tail":", 2152.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id441cc48e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id441cc48f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id441cc490-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13523/a"},"text":"Pub. L. 115–97, § 13523(a)","children":[],"tail":", amended par. (2) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—The annual rate determined by the Secretary under this paragraph for any calendar year shall be a rate equal to the average of the applicable Federal mid-term rates (as defined in section 1274(d) but based on annual compounding) effective as of the beginning of each of the calendar months in the test period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) ","children":[{"tag":"inline","attrib":{},"text":"Test period","children":[],"tail":".—For purposes of subparagraph (A), the test period is the most recent 60-calendar-month period ending before the beginning of the calendar year for which the determination is made; except that there shall be excluded from the test period any month beginning before "},{"tag":"date","attrib":{"date":"1986-08-01"},"text":"August 1, 1986","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(B) to (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13523/b"},"text":"Pub. L. 115–97, § 13523(b)","children":[],"tail":", added subpar. (B) and struck out former subpars. (B) to (G) which related to treatment of certain losses, special rule for certain long-tail lines, long-tail line of business, special rule for international and reinsurance lines of business, adjustments if loss experience information available for longer periods, and special rule for 9th year if negative or zero, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13523/c"},"text":"Pub. L. 115–97, § 13523(c)","children":[],"tail":", redesignated subsecs. (f) and (g) as (e) and (f), respectively, and struck out former subsec. (e) which related to election to use company’s historical payment pattern."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(6)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13517/b/3"},"text":"Pub. L. 115–97, § 13517(b)(3)","children":[],"tail":", substituted “except that the limitation of subsection (a)(3) shall apply, and” for “except that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the prevailing State assumed interest rate shall be the rate in effect for the year in which the loss occurred rather than the year in which the contract was issued, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the limitation of subsection (a)(3) shall apply in lieu of the limitation of the last sentence of section 807(d)(1), and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13523/c"},"text":"Pub. L. 115–97, § 13523(c)","children":[],"tail":", redesignated subsec. (g) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" inserted “and” at end of par. (1), redesignated par. (3) as (2), and struck out former par. (2) which required regulations providing proper treatment of salvage and reinsurance recoverable attributable to unpaid losses."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (f)(6)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1010/e/1"},"text":"Pub. L. 100–647, § 1010(e)(1)","children":[],"tail":", substituted “paid in the middle of the year” for “paid during the year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1010/e/2"},"text":"Pub. L. 100–647, § 1010(e)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id441cc491-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id441cc492-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13517/b/3"},"text":"section 13517(b)(3) of Pub. L. 115–97","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", with transition rule and transition relief, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13517/c"},"text":"section 13517(c) of Pub. L. 115–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s807"},"text":"section 807 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13523/d"},"text":"Pub. L. 115–97, title I, § 13523(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2152"},"text":"131 Stat. 2152","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/97/tI/s13523/d"},"text":"“The amendments made by this section [amending this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id441cc493-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1989-12-31"},"text":"Dec. 31, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11305/c/1"},"text":"section 11305(c)(1) of Pub. L. 101–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s832"},"text":"section 832 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id441cc494-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id441cc495-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tX/s1023/e"},"text":"Pub. L. 99–514, title X, § 1023(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2404"},"text":"100 Stat. 2404","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1010/e/3"},"text":"Pub. L. 100–647, title I, § 1010(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3453"},"text":"102 Stat. 3453","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1010/e/3"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting this section and amending sections 807 and 832 of this title] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transitional rule","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the first taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unpaid losses and the expenses unpaid (as defined in paragraphs (5)(B) and (6) of section 832(b) of the Internal Revenue Code of 1986) at the end of the preceding taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unpaid losses as defined in sections 807(c)(2) and 805(a)(1) of such Code at the end of the preceding taxable year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be determined as if the amendments made by this section had applied to such unpaid losses and expenses unpaid in the preceding taxable year and by using the interest rate and loss payment patterns applicable to accident years ending with calendar year 1987. For subsequent taxable years, such amendments shall be applied with respect to such unpaid losses and expenses unpaid by using the interest rate and loss payment patterns applicable to accident years ending with calendar year 1987.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fresh start.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this paragraph, any difference between—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined to be the unpaid losses and expenses unpaid for the year preceding the 1st taxable year of an insurance company beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", determined without regard to paragraph (2), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount determined with regard to paragraph (2),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall not be taken into account for purposes of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reserve strengthening in years after 1985","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subparagraph (A) shall not apply to any reserve strengthening in a taxable year beginning in 1986, and such strengthening shall be treated as occurring in the taxpayer’s 1st taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on earnings and profits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The earnings and profits of any insurance company for its 1st taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", shall be increased by the amount of the difference determined under subparagraph (A) with respect to such company."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of fresh start to companies which become subject to section 831","children":[],"tail":"(a) "},{"tag":"inline","attrib":{},"text":"tax in later taxable year","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an insurance company was not subject to tax under section 831(a) of the Internal Revenue Code of 1986 for its 1st taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", by reason of being—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to tax under section 831(b) of such Code, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described in section 501(c) of such Code and exempt from tax under section 501(a) of such Code, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such company becomes subject to tax under such section 831(a) for any later taxable year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"paragraph (2) and subparagraphs (A) and (C) of paragraph (3) shall be applied by treating such later taxable year as its 1st taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", and by treating the calendar year in which such later taxable year begins as 1987; and paragraph (3)(B) shall not apply.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id441f3596-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transitional Rule","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13523/e"},"text":"Pub. L. 115–97, title I, § 13523(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2152"},"text":"131 Stat. 2152","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/97/tI/s13523/e"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":""},"text":null,"children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“For the first taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unpaid losses and the expenses unpaid (as defined in paragraphs (5)(B) and (6) of section 832(b) of the Internal Revenue Code of 1986) at the end of the preceding taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unpaid losses as defined in sections 807(c)(2) and 805(a)(1) of such Code at the end of the preceding taxable year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be determined as if the amendments made by this section [amending this section] had applied to such unpaid losses and expenses unpaid in the preceding taxable year and by using the interest rate and loss payment patterns applicable to accident years ending with calendar year 2018, and any adjustment shall be taken into account ratably in such first taxable year and the 7 succeeding taxable years. For subsequent taxable years, such amendments shall be applied with respect to such unpaid losses and expenses unpaid by using the interest rate and loss payment patterns applicable to accident years ending with calendar year 2018.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
