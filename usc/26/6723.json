{"tag":"section","attrib":{"id":"id473946b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6723"},"text":null,"children":[{"tag":"num","attrib":{"value":"6723"},"text":"§ 6723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to comply with other information reporting requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the case of a failure by any person to comply with a specified information reporting requirement on or before the time prescribed therefor, such person shall pay a penalty of $50 for each such failure, but the total amount imposed on such person for all such failures during any calendar year shall not exceed $100,000.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id473946b2-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1501/a"},"text":"Pub. L. 99–514, title XV, § 1501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2733"},"text":"100 Stat. 2733","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7711/a"},"text":"Pub. L. 101–239, title VII, § 7711(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2390"},"text":"103 Stat. 2390","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id473946b3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id473946b4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag"