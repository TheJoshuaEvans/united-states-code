{"tag":"section","attrib":{"id":"id465dda67-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6019"},"text":null,"children":[{"tag":"num","attrib":{"value":"6019"},"text":"§ 6019.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gift tax returns","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any individual who in any calendar year makes any transfer by gift other than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id465dda68-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6019/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a transfer which under subsection (b) or (e) of section 2503 is not to be included in the total amount of gifts for such year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id465dda69-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6019/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a transfer of an interest with respect to which a deduction is allowed under section 2523, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id465dda6a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6019/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a transfer with respect to which a deduction is allowed under section 2522 but only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id465dda6b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6019/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id465dda6c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6019/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such transfer is of the donor’s entire interest in the property transferred, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id465dda6d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6019/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no other interest in such property is or has been transferred (for less than adequate and full consideration in money or money’s worth) from the donor to a person, or for a use, not described in subsection (a) or (b) of section 2522, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id465dda6e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6019/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such transfer is described in section 2522(d),","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall make a return for such year with respect to the gift tax imposed by subtitle B.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id465dda6f-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/739"},"text":"68A Stat. 739","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/614/tI/s102/d/3"},"text":"Pub. L. 91–614, title I, § 102(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1841"},"text":"84 Stat. 1841","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV"},"text":"Pub. L. 97–34, title IV","children":[],"tail":", §§ 403(b)(3)(A), (c)(3)(B), 442(d)(2), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/301"},"text":"95 Stat. 301","children":[],"tail":", 302, 322; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIII/s1301/a"},"text":"Pub. L. 105–34, title XIII, § 1301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1039"},"text":"111 Stat. 1039","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tV/s542/b/2"},"text":"Pub. L. 107–16, title V, § 542(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/82"},"text":"115 Stat. 82","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/312/tIII/s301/a"},"text":"Pub. L. 111–312, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-17"},"text":"Dec. 17, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3300"},"text":"124 Stat. 3300","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id465dda70-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id465dda71-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id465dda72-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312"},"text":"Pub. L. 111–312","children":[],"tai