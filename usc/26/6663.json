{"tag":"section","attrib":{"id":"id4726338e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6663"},"text":null,"children":[{"tag":"num","attrib":{"value":"6663"},"text":"§ 6663.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of fraud penalty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4726338f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6663/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any part of any underpayment of tax required to be shown on a return is due to fraud, there shall be added to the tax an amount equal to 75 percent of the portion of the underpayment which is attributable to fraud.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47263390-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6663/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of portion attributable to fraud","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary establishes that any portion of an underpayment is attributable to fraud, the entire underpayment shall be treated as attributable to fraud, except with respect to any portion of the underpayment which the taxpayer establishes (by a preponderance of the evidence) is not attributable to fraud.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47263391-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6663/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for joint returns","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a joint return, this section shall not apply with respect to a spouse unless some part of the underpayment is due to the fraud of such spouse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47263392-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7721/a"},"text":"Pub. L. 101–239, title VII, § 7721(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2397"},"text":"103 Stat. 2397","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47263393-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47263394-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47263395-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to returns the due date for which (determined without regard to extensions) is after ","children":[{"tag":"date","attrib":{"date":"1989-12-31"},"text":"Dec. 31, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7721/d"},"text":"section 7721(d) of Pub. L. 101–239","children":[],"tail":", set out as an Effective Date of 1989 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s461"},"text":"section 461 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
