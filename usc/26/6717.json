{"tag":"section","attrib":{"id":"id4736d5e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6717"},"text":null,"children":[{"tag":"num","attrib":{"value":"6717"},"text":"§ 6717.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refusal of entry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4736d5e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6717/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other penalty provided by law, any person who refuses to admit entry or refuses to permit any other action by the Secretary authorized by section 4083(d)(1) shall pay a penalty of $1,000 for such refusal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d5e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6717/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint and several liability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4736d5e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6717/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a penalty is imposed under this section on any business entity, each officer, employee, or agent of such entity or other contracting party who willfully participated in any act giving rise to such penalty shall be jointly and severally liable with such entity for such penalty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d5e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6717/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliated groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a business entity described in paragraph (1) is part of an affiliated group (as defined in section 1504(a)), the parent corporation of such entity shall be jointly and severally liable with such entity for the penalty imposed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d5ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6717/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable cause exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed under this section with respect to any failure if it is shown that such failure is due to reasonable cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4736d5eb-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s859/a"},"text":"Pub. L. 108–357, title VIII, § 859(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1617"},"text":"118 Stat. 1617","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4736d5ec-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4736d5ed-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4736d5ee-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2005-01-01"},"text":"Jan. 1, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s859/c"},"text":"section 859(c) of Pub. L. 108–357","children":[],"tail":", set out as an Effective Date of 2004 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4083"},"text":"section 4083 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
