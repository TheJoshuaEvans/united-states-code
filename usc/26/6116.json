{"tag":"section","attrib":{"id":"id46ac9728-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6116"},"text":null,"children":[{"tag":"num","attrib":{"value":"6116"},"text":"§ 6116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for prisons located in United States to provide information for tax administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46ac9729-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2012-09-15"},"text":"September 15, 2012","children":[],"tail":", and annually thereafter, the head of the Federal Bureau of Prisons and the head of any State agency charged with the responsibility for administration of prisons shall provide to the Secretary in electronic format a list with the information described in subsection (b) of all the inmates incarcerated within the prison system for any part of the prior 2 calendar years or the current calendar year through August 31."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46ac972a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information with respect to each inmate is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46ac972b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6116/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first, middle, and last name,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ac972c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6116/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" date of birth,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ac972d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6116/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institution of current incarceration or, for released inmates, most recent incarceration,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ac972e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6116/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prison assigned inmate number,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ac972f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6116/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of incarceration,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ac9730-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6116/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of release or anticipated date of release,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ac9731-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6116/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of work release,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ac9732-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6116/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taxpayer identification number and whether the prison has verified such number,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ac9733-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6116/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" last known address, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ac9734-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6116/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional information as the Secretary may request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46ac9735-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6116/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Format","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine the electronic format of the information described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46ac9736-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/41/tV/s502/a"},"text":"Pub. L. 112–41, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/460"},"text":"125 Stat. 460","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46ac9737-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46ac9738-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46ac9739-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6116 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6117"},"text":"section 6117 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
