{"tag":"section","attrib":{"id":"id44003bdd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s709"},"text":null,"children":[{"tag":"num","attrib":{"value":"709"},"text":"§ 709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of organization and syndication fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44003bde-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), no deduction shall be allowed under this chapter to the partnership or to any partner for any amounts paid or incurred to organize a partnership or to promote the sale of (or to sell) an interest in such partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44003bdf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deduction of organization fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44003be0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s709/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of deduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a partnership elects the application of this subsection (in accordance with regulations prescribed by the Secretary) with respect to any organizational expenses—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44003be1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s709/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the partnership shall be allowed a deduction for the taxable year in which the partnership begins business in an amount equal to the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44003be2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s709/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of organizational expenses with respect to the partnership, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44003be3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s709/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000, reduced (but not below zero) by the amount by which such organizational expenses exceed $50,000, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44003be4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s709/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remainder of such organizational expenses shall be allowed as a deduction ratably over the 180-month period beginning with the month in which the partnership begins business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44003be5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s709/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dispositions before close of amortization period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which a partnership is liquidated before the end of the period to which paragraph (1)(B) applies, any deferred expenses attributable to the partnership which were not allowed as a deduction by reason of this section may be deducted to the extent allowable under section 165.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44003be6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s709/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organizational expenses defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The organizational expenses to which paragraph (1) applies, are expenditures which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44003be7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s709/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are incident to the creation of the partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44003be8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s709/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are chargeable to capital account; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44003be9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s709/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are of a character which, if expended incident to the creation of a partnership having an ascertainable life, would be amortized over such life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44003bea-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tII/s213/b/1"},"text":"Pub. L. 94–455, title II, § 213(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1547"},"text":"90 Stat. 1547","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s902/c"},"text":"Pub. L. 108–357, title VIII, § 902(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1651"},"text":"118 Stat. 1651","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s403"},"text":"Pub. L. 109–135, title IV, § 403","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2632"},"text":"119 Stat. 2632","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44003beb-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44003bec-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44003bed-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" substituted “partnership” for “taxpayer” in introductory provisions and before “shall be allowed” in subpar. (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" substituted “Deduction” for “Amortization” in heading, added par. (2), redesignated former par. (2) as (3), and amended heading and text of par. (1) generally. Prior to amendment, text of par. (1) read as follows: “Amounts paid or incurred to organize a partnership may, at the election of the partnership (made in accordance with regulations prescribed by the Secretary), be treated as deferred expenses. Such deferred expenses shall be allowed as a deduction ratably over such period of not less than 60 months as may be selected by the partnership (beginning with the month in which the partnership begins business), or if the partnership is liquidated before the end of such 60-month period, such deferred expenses (to the extent not deducted under this section) may be deducted to the extent provided in section 165.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44003bee-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44003bef-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" effective as if included in the provision of the American Jobs Creation Act of 2004, "},{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/nn"},"text":"section 403(nn) of Pub. L. 109–135","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s26"},"text":"section 26 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44003bf0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" applicable to amounts paid or incurred after "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s902/d"},"text":"section 902(d) of Pub. L. 108–357","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s195"},"text":"section 195 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44003bf1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tII/s213/f"},"text":"Pub. L. 94–455, title II, § 213(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1548"},"text":"90 Stat. 1548","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this subsection, the amendments made by this section [enacting this section and amending sections 179, 704, 706, 707, and 761 of this title] shall apply in the case of partnership taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1975-12-31"},"text":"December 31, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsection","children":[],"tail":" (e).—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by subsection (e) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s704"},"text":"section 704 of this title","children":[],"tail":"] shall apply to liabilities incurred after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Section 709","children":[],"tail":"(b) "},{"tag":"inline","attrib":{},"text":"of the code","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 709(b) of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] (as added by the amendment made by subsection (b)(1) of this section) shall apply in the case of amounts paid or incurred in taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
