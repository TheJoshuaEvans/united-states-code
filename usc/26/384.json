{"tag":"section","attrib":{"id":"id42d3a216-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384"},"text":null,"children":[{"tag":"num","attrib":{"value":"384"},"text":"§ 384.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of preacquisition losses to offset built-in gains","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42d3a217-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42d3a218-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42d3a219-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation acquires directly (or through 1 or more other corporations) control of another corporation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42d3a21a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assets of a corporation are acquired by another corporation in a reorganization described in subparagraph (A), (C), or (D) of section 368(a)(1), and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42d3a21b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" either of such corporations is a gain corporation,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"income for any recognition period taxable year (to the extent attributable to recognized built-in gains) shall not be offset by any preacquisition loss (other than a preacquisition loss of the gain corporation).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42d3a21c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception where corporations under common control","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42d3a21d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to the preacquisition loss of any corporation if such corporation and the gain corporation were members of the same controlled group at all times during the 5-year period ending on the acquisition date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42d3a21e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled group","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “controlled group” means a controlled group of corporations (as defined in section 1563(a)); except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42d3a21f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “more than 50 percent” shall be substituted for “at least 80 percent” each place it appears,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42d3a220-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ownership requirements of section 1563(a) must be met both with respect to voting power and value, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42d3a221-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination shall be made without regard to subsection (a)(4) of section 1563.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42d3a222-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shorter period where corporations not in existence for 5 years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If either of the corporations referred to in paragraph (1) was not in existence throughout the 5-year period referred to in paragraph (1), the period during which such corporation was in existence (or if both, the shorter of such periods) shall be substituted for such 5-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42d3a223-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42d3a224-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognized built-in gain","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42d3a225-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “recognized built-in gain” means any gain recognized during the recognition period on the disposition of any asset except to the extent the gain corporation (or, in any case described in subsection (a)(1)(B), the acquiring corporation) establishes that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42d3a226-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such asset was not held by the gain corporation on the acquisition date, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42d3a227-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such gain exceeds the excess (if any) of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id42d3a228-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of such asset on the acquisition date, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id42d3a229-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjusted basis of such asset on such date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42d3a22a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain income items","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any item of income which is properly taken into account for any recognition period taxable year but which is attributable to periods before the acquisition date shall be treated as a recognized built-in gain for the taxable year in which it is properly taken into account and shall be taken into account in determining the amount of the net unrealized built-in gain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42d3a22b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the recognized built-in gains for any recognition period taxable year shall not exceed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42d3a22c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the net unrealized built-in gain, reduced by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42d3a22d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recognized built-in gains for prior years ending in the recognition period which (but for this section) would have been offset by preacquisition losses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42d3a22e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition date","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “acquisition date” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42d3a22f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any case described in subsection (a)(1)(A), the date on which the acquisition of control occurs, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42d3a230-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any case described in subsection (a)(1)(B), the date of the transfer in the reorganization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42d3a231-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preacquisition loss","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42d3a232-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “preacquisition loss” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42d3a233-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any net operating loss carryforward to the taxable year in which the acquisition date occurs, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42d3a234-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any net operating loss for the taxable year in which the acquisition date occurs to the extent such loss is allocable to the period in such year on or before the acquisition date.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Except as provided in regulations, the net operating loss shall, for purposes of clause (ii), be allocated ratably to each day in the year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42d3a235-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of recognized built-in loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a corporation with a net unrealized built-in loss, the term “preacquisition loss” includes any recognized built-in loss.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42d3a236-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gain corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “gain corporation” means any corporation with a net unrealized built-in gain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42d3a237-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Control","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “control” means ownership of stock in a corporation which meets the requirements of section 1504(a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42d3a238-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of members of same group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in regulations and except for purposes of subsection (b), all corporations which are members of the same affiliated group immediately before the acquisition date shall be treated as 1 corporation. To the extent provided in regulations, section 1504 shall be applied without regard to subsection (b) thereof for purposes of the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42d3a239-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of predecessors and successors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in this section to a corporation shall include a reference to any predecessor or successor thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42d3a23a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in regulations, the terms “net unrealized built-in gain”, “net unrealized built-in loss”, “recognized built-in loss”, “recognition period”, and “recognition period taxable year”, have the same respective meanings as when used in section 382(h), except that the acquisition date shall be taken into account in lieu of the change date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42d3a23b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation also to apply to excess credits or net capital losses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of subsection (a) shall also apply in the case of any excess credit (as defined in section 383(a)(2)) or net capital loss.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42d3a23c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ordering rules for net operating losses, etc.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42d3a23d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryover rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any preacquisition loss may not offset a recognized built-in gain by reason of this section, such gain shall not be taken into account in determining under section 172(b)(2) the amount of such loss which may be carried to other taxable years. A similar rule shall apply in the case of any excess credit or net capital loss limited by reason of subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42d3a23e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ordering rule for losses carried from same taxable year","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case in which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42d3a23f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a preacquisition loss for any taxable year is subject to limitation under subsection (a), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42d3a240-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a net operating loss from such taxable year is not subject to such limitation,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"taxable income shall be treated as having been offset 1st by the loss subject to such limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42d3a241-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to carry out the purposes of this section, including regulations to ensure that the purposes of this section may not be circumvented through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42d3a242-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of any provision of law or regulations (including subchapter K of this chapter), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42d3a243-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s384/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contributions of property to a corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id42d3a244-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10226/a"},"text":"Pub. L. 100–203, title X, § 10226(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-414"},"text":"101 Stat. 1330–414","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tII/s2004/m/1"},"text":"Pub. L. 100–647, title II, § 2004(m)(1)","children":[],"tail":"–(4), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3606"},"text":"102 Stat. 3606","children":[],"tail":", 3607; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7812/c/1"},"text":"Pub. L. 101–239, title VII, § 7812(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2412"},"text":"103 Stat. 2412","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id42d3a245-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id42d3a246-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id42d3a247-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" substituted “built-in gain” for “build-in gain”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/m/1/A"},"text":"Pub. L. 100–647, § 2004(m)(1)(A)","children":[],"tail":", amended subsec. (a) generally, making changes in substance and structure."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/m/3"},"text":"Pub. L. 100–647, § 2004(m)(3)","children":[],"tail":", substituted “corporations under common control” for “50 percent of gain corporation held” in heading and amended text generally. Prior to amendment, text read as follows: “Subsection (a) shall not apply if more than 50 percent of the stock (by vote and value) of the gain corporation was held throughout the 5-year period ending on the acquisition date—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) in any case described in subsection (a)(1), by members of the affiliated group referred to in subsection (a)(1), or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) in any case described in subsection (a)(2), by the acquiring corporation or members of such acquiring corporation’s affiliated group.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For purposes of the preceding sentence, stock described in section 1504(a)(4) shall not be taken into account.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/m/1/D"},"text":"Pub. L. 100–647, § 2004(m)(1)(D)","children":[],"tail":", substituted “subsection (a)(1)(B)” for “subsection (a)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/m/1/C"},"text":"Pub. L. 100–647, § 2004(m)(1)(C)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “The term ‘acquisition date’ means the date on which the gain corporation becomes a member of the affiliated group or, in any case described in subsection (a)(2), the date of the distribution or transfer in the liquidation or reorganization.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/m/1/B"},"text":"Pub. L. 100–647, § 2004(m)(1)(B)","children":[],"tail":", redesignated par. (4) as (8) and added pars. (4) to (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/m/2"},"text":"Pub. L. 100–647, § 2004(m)(2)","children":[],"tail":", (4), substituted “a corporation” for “the gain corporation” in subsec. (e)(2), redesignated subsec. (e) as (f), and added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id42d3a248-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42d3a249-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Technical and Miscellaneous Revenue Act of 1988, "},{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7817"},"text":"section 7817 of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42d3a24a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Revenue Act of 1987, "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX"},"text":"Pub. L. 100–203, title X","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/u"},"text":"section 2004(u) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s56"},"text":"section 56 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id42d3a24b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10226/c"},"text":"Pub. L. 100–203, title X, § 10226(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-416"},"text":"101 Stat. 1330–416","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/203/tX/s10226/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendments made by this section [enacting this section] shall apply in cases where the acquisition date (as defined in section 384(c)(2) of the Internal Revenue Code of 1986 as added by this section) is after ","children":[{"tag":"date","attrib":{"date":"1987-12-15"},"text":"December 15, 1987","children":[],"tail":"; except that such amendments shall not apply in the case of any transaction pursuant to—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a binding written contract in effect on or before ","children":[{"tag":"date","attrib":{"date":"1987-12-15"},"text":"December 15, 1987","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a letter of intent or agreement of merger signed on or before ","children":[{"tag":"date","attrib":{"date":"1987-12-15"},"text":"December 15, 1987","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id42d3a24c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Election To Have Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" Not Apply"}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tII/s2004/m/5"},"text":"Pub. L. 100–647, title II, § 2004(m)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3607"},"text":"102 Stat. 3607","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tII/s2004/m/5"},"text":"“In any case where the acquisition date (as defined in section 384(c)(2) of the 1986 Code as amended by this subsection) is before ","children":[{"tag":"date","attrib":{"date":"1988-03-31"},"text":"March 31, 1988","children":[],"tail":", the acquiring corporation may elect to have the amendments made by this subsection not apply. Such an election shall be made in such manner as the Secretary of the Treasury or his delegate shall prescribe and shall be made not later than the later of the due date (including extensions) for filing the return for the taxable year of the acquiring corporation in which the acquisition date occurs or the date 120 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1989-11-10"},"text":"Nov. 10, 1989","children":[],"tail":"]. Such an election, once made, shall be irrevocable.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
