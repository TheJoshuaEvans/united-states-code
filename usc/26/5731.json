{"tag":"section","attrib":{"id":"id464d11c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5731"},"text":null,"children":[{"tag":"num","attrib":{"value":"5731"},"text":"§ 5731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition and rate of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id464d11ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5731/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every person engaged in business as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id464d11cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5731/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a manufacturer of tobacco products,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464d11cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5731/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a manufacturer of cigarette papers and tubes, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464d11cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5731/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an export warehouse proprietor,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall pay a tax of $1,000 per year in respect of each premises at which such business is carried on.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464d11ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5731/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduced rates for small proprietors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id464d11cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5731/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall be applied by substituting “$500” for “$1,000” with respect to any taxpayer the gross receipts of which (for the most recent taxable year ending before the 1st day of the taxable period to which the tax imposed by subsection (a) relates) are less than $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464d11d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5731/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled group rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All persons treated as 1 taxpayer under section 5061(e)(3) shall be treated as 1 taxpayer for purposes of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464d11d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5731/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain rules to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), rules similar to the rules of subparagraphs (B) and (C) of section 448(c)(3) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464d11d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5731/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for failure to register","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person engaged in a business referred to in subsection (a) who willfully fails to pay the tax imposed by subsection (a) shall be fined not more than $5,000, or imprisoned not more than 2 years, or both, for each such offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id464d11d3-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10512/f/1"},"text":"Pub. L. 100–203, title X, § 10512(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-449"},"text":"101 Stat. 1330–449","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11125/b/20/E"},"text":"Pub. L. 109–59, title XI, § 11125(b)(20)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1957"},"text":"119 Stat. 1957","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id464d11d4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id464d11d5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id464d11d6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5731, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/714"},"text":"68A Stat. 714","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s202"},"text":"Pub. L. 85–859, title II, § 202","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1423"},"text":"72 Stat. 1423","children":[],"tail":", restricted shipment and delivery of tobacco materials to shipment and delivery pursuant to regulations, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tV/s502/b/7"},"text":"Pub. L. 89–44, title V, § 502(b)(7)","children":[],"tail":", title VII, § 701(d), "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/151"},"text":"79 Stat. 151","children":[],"tail":", 157, applicable on and after "},{"tag":"date","attrib":{"date":"1966-01-01"},"text":"Jan. 1, 1966","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id464d11d7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" redesignated subsec. (d) as (c) and struck out former subsec. (c). Text read as follows: “Rules similar to the rules of subpart G of part II of subchapter A of chapter 51 shall apply for purposes of this section.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","at