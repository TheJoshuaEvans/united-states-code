{"tag":"section","attrib":{"id":"id47a48b40-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873"},"text":null,"children":[{"tag":"num","attrib":{"value":"7873"},"text":"§ 7873.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income derived by Indians from exercise of fishing rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47a48b41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47a48b42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income and self-employment taxes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No tax shall be imposed by subtitle A on income derived—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47a48b43-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a member of an Indian tribe directly or through a qualified Indian entity, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47a48b44-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a qualified Indian entity,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"from a fishing rights-related activity of such tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48b45-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No tax shall be imposed by subtitle C on remuneration paid for services performed in a fishing rights-related activity of an Indian tribe by a member of such tribe for another member of such tribe or for a qualified Indian entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a48b46-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47a48b47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishing rights-related activity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fishing rights-related activity” means, with respect to an Indian tribe, any activity directly related to harvesting, processing, or transporting fish harvested in the exercise of a recognized fishing right of such tribe or to selling such fish but only if substantially all of such harvesting was performed by members of such tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48b48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognized fishing rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “recognized fishing rights” means, with respect to an Indian tribe, fishing rights secured as of ","children":[{"tag":"date","attrib":{"date":"1988-03-17"},"text":"March 17, 1988","children":[],"tail":", by a treaty between such tribe and the United States or by an Executive order or an Act of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48b49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified Indian entity","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47a48b4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified Indian entity” means, with respect to an Indian tribe, any entity if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47a48b4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such entity is engaged in a fishing rights-related activity of such tribe,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47a48b4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all of the equity interests in the entity are owned by qualified Indian tribes, members of such tribes, or their spouses,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47a48b4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in regulations, in the case of an entity which engages to any extent in any substantial processing or transporting of fish, 90 percent or more of the annual gross receipts of the entity is derived from fishing rights-related activities of one or more qualified Indian tribes each of which owns at least 10 percent of the equity interests in the entity, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47a48b4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/b/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially all of the management functions of the entity are performed by members of qualified Indian tribes.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of clause (iii), equity interests owned by a member (or the spouse of a member) of a qualified Indian tribe shall be treated as owned by the tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47a48b4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), an Indian tribe is a qualified Indian tribe with respect to an entity if such entity is engaged in a fishing rights-related activity of such tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a48b50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47a48b51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions from qualified Indian entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, any distribution with respect to an equity interest in a qualified Indian entity of an Indian tribe to a member of such tribe shall be treated as derived by such member from a fishing rights-related activity of such tribe to the extent such distribution is attributable to income derived by such entity from a fishing rights-related activity of such tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48b52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" De minimis unrelated amounts may be excluded","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, but for this paragraph, all but a de minimis amount—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47a48b53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" derived by a qualified Indian tribal entity, or by an individual through such an entity, is entitled to the benefits of paragraph (1) of subsection (a), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47a48b54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7873/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid to an individual for services is entitled to the benefits of paragraph (2) of subsection (a),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then the entire amount shall be entitled to the benefits of such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47a48b55-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tIII/s3041/a"},"text":"Pub. L. 100–647, title III, § 3041(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3640"},"text":"102 Stat. 3640","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47a48b56-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47a48b57-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47a48b58-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tIII/s3044"},"text":"Pub. L. 100–647, title III, § 3044","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3642"},"text":"102 Stat. 3642","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tIII/s3044"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this subtitle [subtitle E (§§ 3041–3044) of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":", enacting this section and amending sections 1402 and 3121 of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s71"},"text":"section 71 of Title 25","children":[],"tail":", Indians, and sections 409 and 411 of Title 42, The Public Health and Welfare] shall apply to all periods beginning before, on, or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Inference Created","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in the amendments made by this subtitle shall create any inference as to the existence or non-existence or scope of any exemption from tax for income derived from fishing rights secured as of ","children":[{"tag":"date","attrib":{"date":"1988-03-17"},"text":"March 17, 1988","children":[],"tail":", by any treaty, law, or Executive Order.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
