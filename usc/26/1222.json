{"tag":"section","attrib":{"id":"id44bc86ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1222"},"text":null,"children":[{"tag":"num","attrib":{"value":"1222"},"text":"§ 1222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other terms relating to capital gains and losses","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subtitle—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44bc86ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1222/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short-term capital gain","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “short-term capital gain” means gain from the sale or exchange of a capital asset held for not more than 1 year, if and to the extent such gain is taken into account in computing gross income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bc86ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1222/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short-term capital loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “short-term capital loss” means loss from the sale or exchange of a capital asset held for not more than 1 year, if and to the extent that such loss is taken into account in computing taxable income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bc86af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1222/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term capital gain","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “long-term capital gain” means gain from the sale or exchange of a capital asset held for more than 1 year, if and to the extent such gain is taken into account in computing gross income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bc86b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1222/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term capital loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “long-term capital loss” means loss from the sale or exchange of a capital asset held for more than 1 year, if and to the extent that such loss is taken into account in computing taxable income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bc86b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1222/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net short-term capital gain","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “net short-term capital gain” means the excess of short-term capital gains for the taxable year over the short-term capital losses for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bc86b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1222/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net short-term capital loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “net short-term capital loss” means the excess of short-term capital losses for the taxable year over the short-term capital gains for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bc86b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1222/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net long-term capital gain","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “net long-term capital gain” means the excess of long-term capital gains for the taxable year over the long-term capital losses for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bc86b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1222/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net long-term capital loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “net long-term capital loss” means the excess of long-term capital losses for the taxable year over the long-term capital gains for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bc86b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1222/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital gain net income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “capital gain net income” means the excess of the gains from sales or exchanges of capital assets over the losses from such sales or exchanges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bc86b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1222/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net capital loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “net capital loss” means the excess of the losses from sales or exchanges of capital assets over the sum allowed under section 1211. In the case of a corporation, for the purpose of determining losses under this paragraph, amounts which are short-term capital losses under section 1212(a)(1) shall be excluded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bc86b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1222/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net capital gain","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “net capital gain” means the excess of the net long-term capital gain for the taxable year over the net short-term capital loss for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44bc86b8-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/322"},"text":"68A Stat. 322","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s230/b"},"text":"Pub. L. 88–272, title II, § 230(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/100"},"text":"78 Stat. 100","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tV"},"text":"Pub. L. 91–172, title V","children":[],"tail":", §§ 511(a), 513(c), "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/635"},"text":"83 Stat. 635","children":[],"tail":", 643; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIV/s1402/a/1"},"text":"Pub. L. 94–455, title XIV, § 1402(a)(1)","children":[],"tail":", (2), (d), title XIX, § 1901(a)(136), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1731"},"text":"90 Stat. 1731","children":[],"tail":", 1733, 1787; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1001/a"},"text":"Pub. L. 98–369, div. A, title X, § 1001(a)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1011"},"text":"98 Stat. 1011","children":[],"tail":", 1012; "},{"tag":"ref","attrib":{"href":"/us/pl/111/325/tI/s101/b/2"},"text":"Pub. L. 111–325, title I, § 101(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3538"},"text":"124 Stat. 3538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/79"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(79)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4049"},"text":"128 Stat. 4049","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44bc86b9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44bc86ba-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44bc86bb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" struck out concluding provisions which read as follows: “For purposes of this subtitle, in the case of futures transactions in any commodity subject to the rules of a board of trade or commodity exchange, the length of the holding period taken into account under this section or under any other section amended by section 1402 of the Tax Reform Act of 1976 shall be determined without regard to the amendments made by subsections (a) and (b) of such section 1402.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325"},"text":"Pub. L. 111–325","children":[],"tail":" substituted “section 1212(a)(1)” for “section 1212”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Pars. (1) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “6 months” for “1 year”, applicable to property acquired after "},{"tag":"date","attrib":{"date":"1984-06-22"},"text":"June 22, 1984","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1988-01-01"},"text":"Jan. 1, 1988","children":[],"tail":". See Effective Date of 1984 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Pars. (1) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1402/a/2"},"text":"Pub. L. 94–455, § 1402(a)(2)","children":[],"tail":", provided that “9 months” would be changed to “1 year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1402/a/1"},"text":"Pub. L. 94–455, § 1402(a)(1)","children":[],"tail":", provided that “6 months” would be changed to “9 months” for taxable years beginning in 1977."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/a/136/A"},"text":"Pub. L. 94–455, § 1901(a)(136)(A)","children":[],"tail":", substituted “Capital gain net income” and “capital gain net income” for “Net capital gain” and “net capital gain” in heading and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/a/136/B"},"text":"Pub. L. 94–455, § 1901(a)(136)(B)","children":[],"tail":", substituted “Net capital gain” and “net capital gain” for “Net section 1201 gain” and “net section 1201 gain” in heading and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1402/d"},"text":"Pub. L. 94–455, § 1402(d)","children":[],"tail":", inserted sentence at end relating to length of holding period in case of futures transactions in commodities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/s513/c"},"text":"Pub. L. 91–172, § 513(c)","children":[],"tail":", substituted “The” for “In the case of a corporation, the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/s511/a"},"text":"Pub. L. 91–172, § 511(a)","children":[],"tail":", added par. (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Pars. (9), (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272"},"text":"Pub. L. 88–272","children":[],"tail":" struck out provisions from par. (9) relating to taxpayers other than corporations, and inserted “In the case of a corporation” in par. (10)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statu