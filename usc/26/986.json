{"tag":"section","attrib":{"id":"id4493f087-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986"},"text":null,"children":[{"tag":"num","attrib":{"value":"986"},"text":"§ 986.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of foreign taxes and foreign corporation’s earnings and profits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4493f088-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign income taxes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4493f089-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Translation of accrued taxes","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4493f08a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determining the amount of the foreign tax credit, in the case of a taxpayer who takes foreign income taxes into account when accrued, the amount of any foreign income taxes (and any adjustment thereto) shall be translated into dollars by using the average exchange rate for the taxable year to which such taxes relate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4493f08b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain taxes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraph (A) shall not apply to any foreign income taxes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4493f08c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid after the date 2 years after the close of the taxable year to which such taxes relate, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4493f08d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid before the beginning of the taxable year to which such taxes relate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4493f08e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for inflationary currencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply to any foreign income taxes the liability for which is denominated in any inflationary currency (as determined under regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4493f08f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elective exception for taxes paid other than in functional currency","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4493f090-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the election of the taxpayer, subparagraph (A) shall not apply to any foreign income taxes the liability for which is denominated in any currency other than in the taxpayer’s functional currency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4493f091-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to qualified business units","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under this subparagraph may apply to foreign income taxes attributable to a qualified business unit in accordance with regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4493f092-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any such election shall apply to the taxable year for which made and all subsequent taxable years unless revoked with the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4493f093-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for regulated investment companies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a regulated investment company which takes into account income on an accrual basis, subparagraphs (A) through (D) shall not apply and foreign income taxes paid or accrued with respect to such income shall be translated into dollars using the exchange rate as of the date the income accrues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4493f094-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For adjustments where tax is not paid within 2 years, see section 905(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4493f095-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Translation of taxes to which paragraph (1) does not apply","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of determining the amount of the foreign tax credit, in the case of any foreign income taxes to which subparagraph (A) or (E) of paragraph (1) does not apply—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4493f096-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such taxes shall be translated into dollars using the exchange rates as of the time such taxes were paid to the foreign country or possession of the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4493f097-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any adjustment to the amount of such taxes shall be translated into dollars using—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4493f098-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in clause (ii), the exchange rate as of the time when such adjustment is paid to the foreign country or possession, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4493f099-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any refund or credit of foreign income taxes, using the exchange rate as of the time of the original payment of such foreign income taxes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4493f09a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to permit use of average rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent prescribed in regulations, the average exchange rate for the period (specified in such regulations) during which the taxes or adjustment is paid may be used instead of the exchange rate as of the time of such payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4493f09b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign income taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “foreign income taxes” means any income, war profits, or excess profits taxes paid or accrued to any foreign country or to any possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4493f09c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Earnings and profits and distributions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of determining the tax under this subtitle—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4493f09d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of any shareholder of any foreign corporation, the earnings and profits of such corporation shall be determined in the corporation’s functional currency, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4493f09e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any United States person, the earnings and profits determined under paragraph (1) (when distributed, deemed distributed, or otherwise taken into account under this subtitle) shall (if necessary) be translated into dollars using the appropriate exchange rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4493f09f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Previously taxed earnings and profits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4493f0a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Foreign currency gain or loss with respect to distributions of previously taxed earnings and profits (as described in section 959 or 1293(c)) attributable to movements in exchange rates between the times of deemed and actual distribution shall be recognized and treated as ordinary income or loss from the same source as the associated income inclusion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4493f0a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s986/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions through tiers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe regulations with respect to the treatment of distributions of previously taxed earnings and profits through tiers of foreign corporations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4493f0a2-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1261/a"},"text":"Pub. L. 99–514, title XII, § 1261(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2586"},"text":"100 Stat. 2586","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/v/1/A"},"text":"Pub. L. 100–647, title I, § 1012(v)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3528"},"text":"102 Stat. 3528","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXI/s1102/a/1"},"text":"Pub. L. 105–34, title XI, § 1102(a)(1)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/963"},"text":"111 Stat. 963","children":[],"tail":", 965; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIV/s408/a"},"text":"Pub. L. 108–357, title IV, § 408(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1499"},"text":"118 Stat. 1499","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4493f0a3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4493f0a4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4493f0a5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s408/a"},"text":"Pub. L. 108–357, § 408(a)","children":[],"tail":", added subpar. (D). Former subpar. (D) redesignated (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s408/b/1"},"text":"Pub. L. 108–357, § 408(b)(1)","children":[],"tail":", added subpar. (E). Former subpar. (E) redesignated (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s408/a"},"text":"Pub. L. 108–357, § 408(a)","children":[],"tail":", redesignated subpar. (D) as (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s408/b/1"},"text":"Pub. L. 108–357, § 408(b)(1)","children":[],"tail":", redesignated subpar. (E) as (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s408/b/2"},"text":"Pub. L. 108–357, § 408(b)(2)","children":[],"tail":", inserted “or (E)” after “subparagraph (A)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1102/a/1"},"text":"Pub. L. 105–34, § 1102(a)(1)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Foreign Taxes.—","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—For purposes of determining the amount of the foreign tax credit—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) any foreign income taxes shall be translated into dollars using the exchange rates as of the time such taxes were paid to the foreign country or possession of the United States, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) any adjustment to the amount of foreign income taxes shall be translated into dollars using—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) except as provided in clause (ii), the exchange rate as of the time when such adjustment is paid to the foreign country or possession, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) in the case of any refund or credit of foreign income taxes, using the exchange rate as of the time of original payment of such foreign income taxes.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Foreign income taxes","children":[],"tail":".—For purposes of paragraph (1), ‘foreign income taxes’ means any income, war profits, or excess profits taxes paid to any foreign country or to any possession of the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1102/b/1"},"text":"Pub. L. 105–34, § 1102(b)(1)","children":[],"tail":", added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" substituted “foreign taxes and foreign corporation’s earnings and profits” for “foreign corporation’s earnings and profits and foreign taxes” in heading, and revised and restructured the provisions of subsecs. (a) and (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4493f0a6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4493f0a7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIV/s408/c"},"text":"Pub. L. 108–357, title IV, § 408(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1500"},"text":"118 Stat. 1500","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tIV/s408/c"},"text":"“The amendments made by this section [amending this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4493f0a8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXI/s1102/c/1"},"text":"Pub. L. 105–34, title XI, § 1102(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/966"},"text":"111 Stat. 966","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tXI/s1102/c/1"},"text":"“The amendments made by subsections (a)(1) and (b) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s989"},"text":"section 989 of this title","children":[],"tail":"] shall apply to taxes paid or accrued in taxable years beginning after "},{"tag":"date","attrib":{"date":"1997-12-31"},"text":"December 31, 1997","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4493f0a9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4493f0aa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", with certain exceptions and qualifications, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1261/e"},"text":"section 1261(e) of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s985"},"text":"section 985 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
