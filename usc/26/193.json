{"tag":"section","attrib":{"id":"id4219c8f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s193"},"text":null,"children":[{"tag":"num","attrib":{"value":"193"},"text":"§ 193.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tertiary injectants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4219c8fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s193/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of deduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be allowed as a deduction for the taxable year an amount equal to the qualified tertiary injectant expenses of the taxpayer for tertiary injectants injected during such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4219c8fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s193/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified tertiary injectant expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4219c8fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s193/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified tertiary injectant expenses” means any cost paid or incurred (whether or not chargeable to capital account) for any tertiary injectant (other than a hydrocarbon injectant which is recoverable) which is used as a part of a tertiary recovery method.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4219c8fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s193/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hydrocarbon injectant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “hydrocarbon injectant” includes natural gas, crude oil, and any other injectant which is comprised of more than an insignificant amount of natural gas or crude oil. The term does not include any tertiary injectant which is hydrocarbon-based, or a hydrocarbon-derivative, and which is comprised of no more than an insignificant amount of natural gas or crude oil. For purposes of this paragraph, that portion of a hydrocarbon injectant which is not a hydrocarbon shall not be treated as a hydrocarbon injectant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4219c8fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s193/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tertiary recovery method","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “tertiary recovery method” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4219c8ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s193/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any method which is described in subparagraphs (1) through (9) of section 212.78(c) of the June 1979 energy regulations (as defined by section 4996(b)(8)(C) as in effect before its repeal), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4219c900-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s193/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other method to provide tertiary enhanced recovery which is approved by the Secretary for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4219c901-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s193/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application with other deductions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No deduction shall be allowed under subsection (a) with respect to any expenditure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4219c902-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s193/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which the taxpayer has made an election under section 263(c), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4219c903-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s193/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which a deduction is allowed or allowable to the taxpayer under any other provision of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4219c904-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223/tII/s251/a/1"},"text":"Pub. L. 96–223, title II, § 251(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-02"},"text":"Apr. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/286"},"text":"94 Stat. 286","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tII/s202/b"},"text":"Pub. L. 97–448, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2396"},"text":"96 Stat. 2396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1941/b/7"},"text":"Pub. L. 100–418, title I, § 1941(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1324"},"text":"102 Stat. 1324","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4219c905-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4219c906-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4219c907-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 4996(b)(8)(C), referred to in subsec. (b)(3)(A), was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1941/a"},"text":"Pub. L. 100–418, title I, § 1941(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1322"},"text":"102 Stat. 1322","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4219c908-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" substituted “section 4996(b)(8)(C) as in effect before its repeal” for “section 4996(b)(8)(C)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448"},"text":"Pub. L. 97–448","children":[],"tail":" struck out “during the taxable year” after “any cost paid or incurred”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4219c909-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4219c90a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" applicable to crude oil removed from the premises on or after "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1941/c"},"text":"section 1941(c) of Pub. L. 100–418","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s164"},"text":"section 164 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4219c90b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448"},"text":"Pub. L. 97–448","children":[],"tail":" effective, except as otherwise provided, as if it had been included in the provision of the Crude Oil Windfall Profit Tax Act of 1980, "},{"tag":"ref","attrib":{"href":"/us/pl/96/223"},"text":"Pub. L. 96–223","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/s203/a"},"text":"section 203(a) of Pub. L. 97–448","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6652"},"text":"section 6652 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4219c90c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223/tII/s251/b"},"text":"Pub. L. 96–223, title II, § 251(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-02"},"text":"Apr. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/287"},"text":"94 Stat. 287","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/223/tII/s251/b"},"text":"“The amendments made by this section [enacting this section and amending sections 263, 1245, and 1250 of this title] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1979-12-31"},"text":"December 31, 1979","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
