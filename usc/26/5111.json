{"tag":"section","attrib":{"id":"id4626ec0d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5111"},"text":null,"children":[{"tag":"num","attrib":{"value":"5111"},"text":"§ 5111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person using distilled spirits on which the tax has been determined, in the manufacture or production of medicines, medicinal preparations, food products, flavors, flavoring extracts, or perfume, which are unfit for beverage purposes shall be eligible for drawback at the time when such distilled spirits are used in the manufacture of such products as provided for in this subpart.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4626ec0e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1345"},"text":"72 Stat. 1345","children":[],"tail":", § 5131; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1905/a/11"},"text":"Pub. L. 94–455, title XIX, § 1905(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1819"},"text":"90 Stat. 1819","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10512/d"},"text":"Pub. L. 100–203, title X, § 10512(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-448"},"text":"101 Stat. 1330–448","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tI/s136/b"},"text":"Pub. L. 103–465, title I, § 136(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4841"},"text":"108 Stat. 4841","children":[],"tail":"; renumbered § 5111 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11125/a/2"},"text":"Pub. L. 109–59, title XI, § 11125(a)(2)","children":[],"tail":", (b)(3)(A), (C), "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1953"},"text":"119 Stat. 1953","children":[],"tail":", 1954.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4626ec0f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4626ec10-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4626ec11-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5111, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1340"},"text":"72 Stat. 1340","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1905/b/3/B"},"text":"Pub. L. 94–455, title XIX, § 1905(b)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1822"},"text":"90 Stat. 1822","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10512/b"},"text":"Pub. L. 100–203, title X, § 10512(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-448"},"text":"101 Stat. 1330–448","children":[],"tail":", related to tax on wholesale dealers in liquors or beer, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11125/a/1/C"},"text":"Pub. L. 109–59, title XI, § 11125(a)(1)(C)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1953"},"text":"119 Stat. 1953","children":[],"tail":", 1957, effective "},{"tag":"date","attrib":{"date":"2008-07-01"},"text":"July 1, 2008","children":[],"tail":", but inapplicable to taxes imposed for periods before such date."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 5111, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/618"},"text":"68A Stat. 618","children":[],"tail":", related to tax on wholesale and retail dealers in liquors or beer, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4626ec12-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11125/b/3/C"},"text":"Pub. L. 109–59, § 11125(b)(3)(C)","children":[],"tail":", struck out “and rate of tax” after “Eligibility” in section catchline, struck out “(a) Eligibility for drawback” before “Any person”, and struck out subsec. (b). Text read as follows: “The special tax imposed by subsection (a) shall be $500 per year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11125/b/3/A"},"text":"Pub. L. 109–59, § 11125(b)(3)(A)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5131"},"text":"section 5131 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11125/a/2"},"text":"Pub. L. 109–59, § 11125(a)(2)","children":[],"tail":", struck out “, on payment of a special tax per annum,” after “beverage purposes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" substituted “flavoring extracts, or perfume” for “or flavoring extracts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “The special tax imposed by subsection (a) shall be graduated in amount as follows: (1) for total annual use not exceeding 25 proof gallons, $25 a year; (2) for total annual use not exceeding 50 proof gallons, $50 a year; (3) for total annual use of more than 50 proof gallons, $100 a year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “produced in a domestic registered distillery or industrial alcohol plant and withdrawn from bond, or using distilled spirits withdrawn from the bonded premises of a distilled spirits plant,” after “Any person using distilled spirits”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4626ec13-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4626ec14-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-07-01"},"text":"July 1, 2008","children":[],"tail":", but inapplicable to taxes imposed for periods before such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11125/c"},"text":"section 11125(c) of Pub. L. 109–59","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5002"},"text":"section 5002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4626ec15-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s136/d"},"text":"section 136(d) of Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4626ec16-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10512/h"},"text":"Pub. L. 100–203, title X, § 10512(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-450"},"text":"101 Stat. 1330–450","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/203/tX/s10512/h"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting sections 5081, 5276, and 5731 of this title and amending this section and sections 5091, 5121, 5131, 5691, and 5801 of this title] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1988-01-01"},"text":"January 1, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"All taxpayers treated as commencing in business on ","children":[{"tag":"date","attrib":{"date":"1988-01-01"},"text":"january 1, 1988","children":[],"tail":".—"}],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person engaged on ","children":[{"tag":"date","attrib":{"date":"1988-01-01"},"text":"January 1, 1988","children":[],"tail":", in any trade or business which is subject to an occupational tax shall be treated for purposes of such tax as having 1st engaged in such trade or business on such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on amount of tax","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a taxpayer who paid an occupational tax in respect of any premises for any taxable period which began before ","children":[{"tag":"date","attrib":{"date":"1988-01-01"},"text":"January 1, 1988","children":[],"tail":", and includes such date, the amount of the occupational tax imposed by reason of subparagraph (A) in respect of such premises shall not exceed an amount equal to ½ the excess (if any) of—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of such tax as in effect on ","children":[{"tag":"date","attrib":{"date":"1988-01-01"},"text":"January 1, 1988","children":[],"tail":", over"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of such tax as in effect on ","children":[{"tag":"date","attrib":{"date":"1987-12-31"},"text":"December 31, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Occupational tax","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this paragraph, the term ‘occupational tax’ means any tax imposed under part II of subchapter A of chapter 51, section 5276, section 5731, or section 5801 of the Internal Revenue Code of 1986 (as amended by this section).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Due date of tax","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of any tax required to be paid by reason of this paragraph shall be due on ","children":[{"tag":"date","attrib":{"date":"1988-04-01"},"text":"April 1, 1988","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4626ec17-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" effective on first day of first month which begins more than 90 days after "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1905/d"},"text":"section 1905(d) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5005"},"text":"section 5005 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4626ec18-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1959-07-01"},"text":"July 1, 1959","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/s210/a/1"},"text":"section 210(a)(1) of Pub. L. 85–859","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
