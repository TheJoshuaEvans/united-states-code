{"tag":"section","attrib":{"id":"id454df1a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704"},"text":null,"children":[{"tag":"num","attrib":{"value":"2704"},"text":"§ 2704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain lapsing rights and restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id454df1a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of lapsed voting or liquidation rights","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454df1a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subtitle, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454df1a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a lapse of any voting or liquidation right in a corporation or partnership, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454df1a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual holding such right immediately before the lapse and members of such individual’s family hold, both before and after the lapse, control of the entity,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such lapse shall be treated as a transfer by such individual by gift, or a transfer which is includible in the gross estate of the decedent, whichever is applicable, in the amount determined under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454df1a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of transfer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the amount determined under this paragraph is the excess (if any) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454df1a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of all interests in the entity held by the individual described in paragraph (1) immediately before the lapse (determined as if the voting and liquidation rights were nonlapsing), over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454df1a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of such interests immediately after the lapse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454df1a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Similar rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may by regulations apply this subsection to rights similar to voting and liquidation rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454df1a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain restrictions on liquidation disregarded","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454df1aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subtitle, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454df1ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a transfer of an interest in a corporation or partnership to (or for the benefit of) a member of the transferor’s family, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454df1ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transferor and members of the transferor’s family hold, immediately before the transfer, control of the entity,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"any applicable restriction shall be disregarded in determining the value of the transferred interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454df1ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable restriction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “applicable restriction” means any restriction—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454df1ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which effectively limits the ability of the corporation or partnership to liquidate, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454df1af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to which either of the following applies:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id454df1b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The restriction lapses, in whole or in part, after the transfer referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id454df1b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The transferor or any member of the transferor’s family, either alone or collectively, has the right after such transfer to remove, in whole or in part, the restriction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454df1b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable restriction” shall not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454df1b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any commercially reasonable restriction which arises as part of any financing by the corporation or partnership with a person who is not related to the transferor or transferee, or a member of the family of either, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454df1b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any restriction imposed, or required to be imposed, by any Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454df1b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other restrictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may by regulations provide that other restrictions shall be disregarded in determining the value of the transfer of any interest in a corporation or partnership to a member of the transferor’s family if such restriction has the effect of reducing the value of the transferred interest for purposes of this subtitle but does not ultimately reduce the value of such interest to the transferee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id455062b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id455062b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Control","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “control” has the meaning given such term by section 2701(b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id455062b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Member of the family","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “member of the family” means, with respect to any individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id455062b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individual’s spouse,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id455062ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any ancestor or lineal descendant of such individual or such individual’s spouse,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id455062bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any brother or sister of the individual, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id455062bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any spouse of any individual described in subparagraph (B) or (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id455062bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2704/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rule of section 2701(e)(3) shall apply for purposes of determining the interests held by any individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id455062be-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11602/a"},"text":"Pub. L. 101–508, title XI, § 11602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-498"},"text":"104 Stat. 1388–498","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1702/f/3/C"},"text":"Pub. L. 104–188, title I, § 1702(f)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1871"},"text":"110 Stat. 1871","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id455062bf-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id455062c0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id455062c1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" substituted “section 2701(e)(3)” for “section 2701(e)(3)(A)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id455062c2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id455062c3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" effective, except as otherwise expressly provided, as if included in the provision of the Revenue Reconciliation Act of 1990, "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI"},"text":"Pub. L. 101–508, title XI","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1702/i"},"text":"section 1702(i) of Pub. L. 104–188","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
