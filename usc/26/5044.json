{"tag":"section","attrib":{"id":"id461fe7c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5044"},"text":null,"children":[{"tag":"num","attrib":{"value":"5044"},"text":"§ 5044.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund of tax on wine","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id461fe7c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5044/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any wine removed from a bonded wine cellar and returned to bond under section 5361—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id461fe7c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5044/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any tax imposed by section 5041 shall, if paid, be refunded or credited, without interest, to the proprietor of the bonded wine cellar to which such wine is delivered; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461fe7c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5044/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if any tax so imposed has not been paid, the person liable for the tax may be relieved of liability therefor,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"under such regulations as the Secretary may prescribe. Such regulations may provide that claim for refund or credit under paragraph (1), or relief from liability under paragraph (2), may be made only with respect to minimum quantities specified in such regulations. The burden of proof in all such cases shall be on the applicant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id461fe7ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5044/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date of filing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No claim under subsection (a) shall be allowed unless filed within 6 months after the date of the return of the wine to bond.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id461fe7cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5044/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of wine returned to bond","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All provisions of this chapter applicable to wine in bond on the premises of a bonded wine cellar and to removals thereof shall be applicable to wine returned to bond under the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id461fe7cc-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1332"},"text":"72 Stat. 1332","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIV/s1416/a"},"text":"Pub. L. 105–34, title XIV, § 1416(a)","children":[],"tail":", (b)(2), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1048"},"text":"111 Stat. 1048","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tVI/s6014/b/2"},"text":"Pub. L. 105–206, title VI, § 6014(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/820"},"text":"112 Stat. 820","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id461fe7cd-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id461fe7ce-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id461fe7cf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5044, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/611"},"text":"68A Stat. 611","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id461fe7d0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text