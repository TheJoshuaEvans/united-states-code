{"tag":"section","attrib":{"id":"id45199b56-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1474"},"text":null,"children":[{"tag":"num","attrib":{"value":"1474"},"text":"§ 1474.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45199b57-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1474/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for withheld tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person required to deduct and withhold any tax under this chapter is hereby made liable for such tax and is hereby indemnified against the claims and demands of any person for the amount of any payments made in accordance with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45199b58-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1474/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits and refunds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45199b59-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1474/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the determination of whether any tax deducted and withheld under this chapter results in an overpayment by the beneficial owner of the payment to which such tax is attributable shall be made as if such tax had been deducted and withheld under subchapter A of chapter 3.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45199b5a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1474/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule where foreign financial institution is beneficial owner of payment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45199b5b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1474/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any tax properly deducted and withheld under section 1471 from a specified financial institution payment—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45199b5c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1474/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the foreign financial institution referred to in subparagraph (B) with respect to such payment is entitled to a reduced rate of tax with respect to such payment by reason of any treaty obligation of the United States—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id45199b5d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1474/b/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any credit or refund with respect to such tax shall not exceed the amount of credit or refund attributable to such reduction in rate, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id45199b5e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1474/b/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no interest shall be allowed or paid with respect to such credit or refund, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45199b5f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1474/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such foreign financial institution is not so entitled, no credit or refund shall be allowed or paid with respect to such tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b60-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1474/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified financial institution payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “specified financial institution payment” means any payment if the beneficial owner of such payment is a foreign financial institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45199b61-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1474/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to identify substantial United States owners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No credit or refund shall be allowed or paid with respect to any tax properly deducted and withheld under this chapter unless the beneficial owner of the payment provides the Secretary such information as the Secretary may require to determine whether such beneficial owner is a United States owned foreign entity (as defined in section 1471(d)(3)) and the identity of any substantial United States owners of such entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45199b62-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1474/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45199b63-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1474/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, rules similar to the rules of section 3406(f) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45199b64-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1474/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of list of participating foreign financial institutions permitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The identity of a foreign financial institution which meets the requirements of section 1471(b) shall not be treated as return information for purposes of section 6103.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45199b65-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1474/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other withholding provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the coordination of this chapter with other withholding provisions under this title, including providing for the proper crediting of amounts deducted and withheld under this chapter against amounts required to be deducted and withheld under such other provisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45199b66-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1474/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of withholding under agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any tax deducted and withheld pursuant to an agreement described in section 1471(b) shall be treated for purposes of this title as a tax deducted and withheld by a withholding agent under section 1471(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45199b67-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1474/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations or other guidance as may be necessary or appropriate to carry out the purposes of, and prevent the avoidance of, this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45199b68-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/147/tV/s501/a"},"text":"Pub. L. 111–147, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-18"},"text":"Mar. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/104"},"text":"124 Stat. 104","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45199b69-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45199b6a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id45199b6b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For prior sections 1481 and 1482, see Prior Provisions note preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1471"},"text":"section 1471 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
