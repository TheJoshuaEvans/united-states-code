{"tag":"section","attrib":{"id":"id4768e188-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7501"},"text":null,"children":[{"tag":"num","attrib":{"value":"7501"},"text":"§ 7501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for taxes withheld or collected","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4768e189-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever any person is required to collect or withhold any internal revenue tax from any other person and to pay over such tax to the United States, the amount of tax so collected or withheld shall be held to be a special fund in trust for the United States. The amount of such fund shall be assessed, collected, and paid in the same manner and subject to the same provisions and limitations (including penalties) as are applicable with respect to the taxes from which such fund arose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4768e18a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For penalties applicable to violations of this section, see sections 6672 and 7202.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4768e18b-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/895"},"text":"68A Stat. 895","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
