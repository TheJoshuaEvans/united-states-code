{"tag":"section","attrib":{"id":"id4755cf41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433A"},"text":null,"children":[{"tag":"num","attrib":{"value":"7433A"},"text":"§ 7433A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil damages for certain unauthorized collection actions by persons performing services under qualified tax collection contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4755cf42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the modifications provided by subsection (b), section 7433 shall apply to the acts and omissions of any person performing services under a qualified tax collection contract (as defined in section 6306(b)) to the same extent and in the same manner as if such person were an employee of the Internal Revenue Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cf43-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4755cf44-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any civil action brought under section 7433 by reason of this section shall be brought against the person who entered into the qualified tax collection contract with the Secretary and shall not be brought against the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4755cf45-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such person and not the United States shall be liable for any damages and costs determined in such civil action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4755cf46-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433A/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such civil action shall not be an exclusive remedy with respect to such person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4755cf47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433A/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsections (c), (d)(1), and (e) of section 7433 shall not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4755cf48-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s881/b/1"},"text":"Pub. L. 108–357, title VIII, § 881(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1626"},"text":"118 Stat. 1626","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
