{"tag":"section","attrib":{"id":"id45316826-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2044"},"text":null,"children":[{"tag":"num","attrib":{"value":"2044"},"text":"§ 2044.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain property for which marital deduction was previously allowed","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45316827-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2044/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The value of the gross estate shall include the value of any property to which this section applies in which the decedent had a qualifying income interest for life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45316828-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2044/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property to which this section applies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies to any property if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45316829-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2044/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a deduction was allowed with respect to the transfer of such property to the decedent—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4531682a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2044/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under section 2056 by reason of subsection (b)(7) thereof, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4531682b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2044/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under section 2523 by reason of subsection (f) thereof, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4531682c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2044/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 2519 (relating to dispositions of certain life estates) did not apply with respect to a disposition by the decedent of part or all of such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4531682d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2044/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property treated as having passed from decedent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter and chapter 13, property includible in the gross estate of the decedent under subsection (a) shall be treated as property passing from the decedent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4531682e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV/s403/d/3/A/i"},"text":"Pub. L. 97–34, title IV, § 403(d)(3)(A)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/304"},"text":"95 Stat. 304","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tI/s104/a/1/B"},"text":"Pub. L. 97–448, title I, § 104(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2380"},"text":"96 Stat. 2380","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4531682f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45316830-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id45316831-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2044 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s2045"},"text":"section 2045 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45316832-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448"},"text":"Pub. L. 97–448","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45316833-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id453168