{"tag":"section","attrib":{"id":"id46bd38bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6215"},"text":null,"children":[{"tag":"num","attrib":{"value":"6215"},"text":"§ 6215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of deficiency found by Tax Court","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46bd38c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6215/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the taxpayer files a petition with the Tax Court, the entire amount redetermined as the deficiency by the decision of the Tax Court which has become final shall be assessed and shall be paid upon notice and demand from the Secretary. No part of the amount determined as a deficiency by the Secretary but disallowed as such by the decision of the Tax Court which has become final shall be assessed or be collected by levy or by proceeding in court with or without assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bd38c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6215/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46bd38c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6215/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For assessment or collection of the amount of the deficiency determined by the Tax Court pending appellate court review, see section 7485.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bd38c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6215/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For dismissal of petition by Tax Court as affirmation of deficiency as determined by the Secretary, see section 7459(d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bd38c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6215/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For decision of Tax Court that tax is barred by limitation as its decision that there is no deficiency, see section 7459(e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bd38c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6215/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For assessment of damages awarded by Tax Court for instituting proceedings merely for delay, see section 6673.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bd38c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6215/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For rules applicable to Tax Court proceedings, see generally subchapter C of chapter 76.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bd38c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6215/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For extension of time for paying amount determined as deficiency, see section 6161(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46bd38c8-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/773"},"text":"68A Stat. 773","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/a/16"},"text":"Pub. L. 94–455, title XIX, § 1906(a)(16)","children":[],"tail":", (b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1825"},"text":"90 Stat. 1825","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIV/s1404/c/2"},"text":"Pub. L. 99–514, title XIV, § 1404(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2714"},"text":"100 Stat. 2714","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/b/46"},"text":"Pub. L. 115–141, div. U, title IV, § 401(b)(46)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1204"},"text":"132 Stat. 1204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46bd38c9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46bd38ca-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46bd38cb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(5) to (7). 