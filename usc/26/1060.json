{"tag":"section","attrib":{"id":"id44b31155-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060"},"text":null,"children":[{"tag":"num","attrib":{"value":"1060"},"text":"§ 1060.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special allocation rules for certain asset acquisitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44b31156-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any applicable asset acquisition, for purposes of determining both—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44b31157-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transferee’s basis in such assets, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b31158-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gain or loss of the transferor with respect to such acquisition,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the consideration received for such assets shall be allocated among such assets acquired in such acquisition in the same manner as amounts are allocated to assets under section 338(b)(5). If in connection with an applicable asset acquisition, the transferee and transferor agree in writing as to the allocation of any consideration, or as to the fair market value of any of the assets, such agreement shall be binding on both the transferee and transferor unless the Secretary determines that such allocation (or fair market value) is not appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44b31159-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information required to be furnished to Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations, the transferor and transferee in an applicable asset acquisition shall, at such times and in such manner as may be provided in such regulations, furnish to the Secretary the following information:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44b3115a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of the consideration received for the assets which is allocated to section 197 intangibles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b3115b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any modification of the amount described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b3115c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other information with respect to other assets transferred in such acquisition as the Secretary deems necessary to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44b3115d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable asset acquisition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “applicable asset acquisition” means any transfer (whether directly or indirectly)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44b3115e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of assets which constitute a trade or business, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b3115f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which the transferee’s basis in such assets is determined wholly by reference to the consideration paid for such assets.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A transfer shall not be treated as failing to be an applicable asset acquisition merely because section 1031 applies to a portion of the assets transferred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44b31160-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain partnership transactions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a distribution of partnership property or a transfer of an interest in a partnership—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44b31161-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rules of subsection (a) shall apply but only for purposes of determining the value of section 197 intangibles for purposes of applying section 755, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b31162-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if section 755 applies, such distribution or transfer (as the case may be) shall be treated as an applicable asset acquisition for purposes of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44b31163-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information required in case of certain transfers of interests in entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44b31164-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44b31165-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who is a 10-percent owner with respect to any entity transfers an interest in such entity, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44b31166-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with such transfer, such owner (or a related person) enters into an employment contract, covenant not to compete, royalty or lease agreement, or other agreement with the transferee,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such owner and the transferee shall, at such time and in such manner as the Secretary may prescribe, furnish such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b31167-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 10-percent owner","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44b31168-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “10-percent owner” means, with respect to any entity, any person who holds 10 percent or more (by value) of the interests in such entity immediately before the transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44b31169-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Constructive ownership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 318 shall apply in determining ownership of stock in a corporation. Similar principles shall apply in determining the ownership of interests in any other entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b3116a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “related person” means any person who is related (within the meaning of section 267(b) or 707(b)(1)) to the 10-percent owner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44b3116b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1060/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions relating to penalties for failure to file a return required by this section, see section 6721.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44b3116c-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s641/a"},"text":"Pub. L. 99–514, title VI, § 641(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2282"},"text":"100 Stat. 2282","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/h/1"},"text":"Pub. L. 100–647, title I, § 1006(h)(1)","children":[],"tail":", (2), (3)(B), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3410"},"text":"102 Stat. 3410","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11323/a"},"text":"Pub. L. 101–508, title XI, § 11323(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-464"},"text":"104 Stat. 1388–464","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13261/e"},"text":"Pub. L. 103–66, title XIII, § 13261(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/539"},"text":"107 Stat. 539","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44b3116d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44b3116e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id44b3116f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1060 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1063"},"text":"section 1063 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44b31170-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13261/e/1"},"text":"Pub. L. 103–66, § 13261(e)(1)","children":[],"tail":", substituted “section 197 intangibles” for “goodwill or going concern value”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13261/e/2"},"text":"Pub. L. 103–66, § 13261(e)(2)","children":[],"tail":", substituted “section 197 intangibles” for “goodwill or going concern value (or similar items)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11323/a"},"text":"Pub. L. 101–508, § 11323(a)","children":[],"tail":", inserted at end “If in connection with an applicable asset acquisition, the transferee and transferor agree in writing as to the allocation of any consideration, or as to the fair market value of any of the assets, such agreement shall be binding on both the transferee and transferor unless the Secretary determines that such allocation (or fair market value) is not appropriate.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11323/b/1"},"text":"Pub. L. 101–508, § 11323(b)(1)","children":[],"tail":", added subsec. (e) and redesignated former subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/h/1"},"text":"Pub. L. 100–647, § 1006(h)(1)","children":[],"tail":", substituted “deems” for “may find”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/h/2"},"text":"Pub. L. 100–647, § 1006(h)(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/h/3/B"},"text":"Pub. L. 100–647, § 1006(h)(3)(B)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44b31171-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44b31172-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" applicable, except as otherwise provided, with respect to property acquired after "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13261/g"},"text":"section 13261(g) of Pub. L. 103–66","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s197"},"text":"section 197 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44b31173-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" applicable to acquisitions after "},{"tag":"date","attrib":{"date":"1990-10-09"},"text":"Oct. 9, 1990","children":[],"tail":", but not applicable to any acquisition pursuant to a written binding contract in effect on "},{"tag":"date","attrib":{"date":"1990-10-09"},"text":"Oct. 9, 1990","children":[],"tail":", and at all times thereafter before such acquisition, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11323/d"},"text":"section 11323(d) of Pub. L. 101–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s338"},"text":"section 338 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44b31174-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44b31175-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s641/c"},"text":"Pub. L. 99–514, title VI, § 641(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2283"},"text":"100 Stat. 2283","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tVI/s641/c"},"text":"“The amendments made by this section [enacting this section and renumbering former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1060"},"text":"section 1060 of this title","children":[],"tail":" as section 1061] shall apply to any acquisition of assets after "},{"tag":"date","attrib":{"date":"1986-05-06"},"text":"May 6, 1986","children":[],"tail":", unless such acquisition is pursuant to a binding contract which was in effect on "},{"tag":"date","attrib":{"date":"1986-05-06"},"text":"May 6, 1986","children":[],"tail":", and at all times thereafter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
