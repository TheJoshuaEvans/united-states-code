{"tag":"section","attrib":{"id":"id45cc7036-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4254"},"text":null,"children":[{"tag":"num","attrib":{"value":"4254"},"text":"§ 4254.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45cc7037-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4254/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a bill is rendered the taxpayer for local telephone service or toll telephone service—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45cc7038-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4254/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount on which the tax with respect to such services shall be based shall be the sum of all charges for such services included in the bill; except that","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45cc7039-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4254/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the person who renders the bill groups individual items for purposes of rendering the bill and computing the tax, then (A) the amount on which the tax with respect to each such group shall be based shall be the sum of all items within that group, and (B) the tax on the remaining items not included in any such group shall be based on the charge for each item separately.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45cc703a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4254/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Where payment is made for toll telephone service in coin-operated telephones","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the tax imposed by section 4251 with respect to toll telephone service is paid by inserting coins in coin-operated telephones, tax shall be computed to the nearest multiple of 5 cents, except that, where the tax is midway between multiples of 5 cents, the next higher multiple shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45cc703b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4254/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain State and local taxes not included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter, in determining the amounts paid for communications services, there shall not be included the amount of any State or local tax imposed on the furnishing or sale of such services, if the amount of such tax is separately stated in the bill.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45cc703c-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/504"},"text":"68A Stat. 504","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tI/s133/a"},"text":"Pub. L. 85–859, title I, § 133(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1291"},"text":"72 Stat. 1291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tIII/s302"},"text":"Pub. L. 89–44, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/147"},"text":"79 Stat. 147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/172/s2/a"},"text":"Pub. L. 95–172, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-12"},"text":"Nov. 12, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1358"},"text":"91 Stat. 1358","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45cc703d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45cc703e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id45cc703f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This subchapter, relating to the tax on communications was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/364/tI/s105/b/3"},"text":"Pub. L. 90–364, title I, § 105(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-28"},"text":"June 28, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/266"},"text":"82 Stat. 266","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tVII/s702/b/3"},"text":"Pub. L. 91–172, title VII, § 702(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/660"},"text":"83 Stat. 660","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/614/tII/s201/b/3"},"text":"Pub. L. 91–614, title II, § 201(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1843"},"text":"84 Stat. 1843","children":[],"tail":", effective with respect to amounts paid pursuant to bills first rendered on or after "},{"tag":"date","attrib":{"date":"1982-01-01"},"text":"Jan. 1, 1982","children":[],"tail":". In the case of communications services rendered before "},{"tag":"date","attrib":{"date":"1981-11-01"},"text":"Nov. 1, 1981","children":[],"tail":", for which a bill has not been rendered before "},{"tag":"date","attrib":{"date":"1982-01-01"},"text":"Jan. 1, 1982","children":[],"tail":", a bill shall be treated as having been first rendered on "},{"tag":"date","attrib":{"date":"1981-12-31"},"text":"Dec. 31, 1981","children":[],"tail":". Repeal of this subchapter was not executed in view of the amendments to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4251"},"text":"section 4251 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/96/499"},"text":"Pub. L. 96–499","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":", extending the date in (and finally eliminating) provisions which had reduced the tax to zero after a specified date."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45cc7040-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/172"},"text":"Pub. L. 95–172","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" substituted “local telephone service or toll telephone service” for “general telephone service, toll telephone service, or telegraph service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" substituted “toll telephone service” for “toll telephone service or telegraph service” in catchline and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" provided that if the person who renders the bill groups individual items for purposes of rendering the bill and computing the tax, then the amount on which the tax with respect to each group shall be based shall be the sum of all items within that group, and the tax on remaining items not included in any such group shall be based on the charge of each item separately."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" substituted “toll telephone service” for “long distance telephone service”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45cc7041-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45cc7042-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/172/s2/b"},"text":"Pub. L. 95–172, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-12"},"text":"Nov. 12, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1358"},"text":"91 Stat. 1358","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/172/s2/b"},"text":"“The amendment made by this section [amending this section] shall take effect only with respect to amounts paid pursuant to bills first rendered on or after the first day of the first month which begins more than 20 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1977-11-12"},"text":"Nov. 12, 1977","children":[],"tail":"]. For purposes of the preceding sentence, in the case of communications services rendered more than 2 months before the effective date provided in the preceding sentence, no bill shall be treated as having been first rendered on or after such effective date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45cc7043-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1965 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" applicable to amounts paid pursuant to bills rendered on or after "},{"tag":"date","attrib":{"date":"1966-01-01"},"text":"January 1, 1966","children":[],"tail":", for service rendered on or after such date, but, in the case of amounts paid pursuant to bills rendered after "},{"tag":"date","attrib":{"date":"1966-01-01"},"text":"January 1, 1966","children":[],"tail":", for services rendered before such date for which no previous bill had been rendered, applicable except with respect to such services as were rendered more than two months before such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/s701/b/2/A"},"text":"section 701(b)(2)(A) of Pub. L. 89–44","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4251"},"text":"section 4251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45cc7044-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/s133/b"},"text":"section 133(b) of Pub. L. 85–859","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4251"},"text":"section 4251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
