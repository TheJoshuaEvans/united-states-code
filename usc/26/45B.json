{"tag":"section","attrib":{"id":"id40c97a66-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45B"},"text":null,"children":[{"tag":"num","attrib":{"value":"45B"},"text":"§ 45B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit for portion of employer social security taxes paid with respect to employee cash tips","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40c97a67-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 38, the employer social security credit determined under this section for the taxable year is an amount equal to the excess employer social security tax paid or incurred by the taxpayer during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40c97a68-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess employer social security tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40c97a69-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “excess employer social security tax” means any tax paid by an employer under section 3111 with respect to tips received by an employee during any month, to the extent such tips—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40c97a6a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45B/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are deemed to have been paid by the employer to the employee pursuant to section 3121(q) (without regard to whether such tips are reported under section 6053), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40c97a6b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45B/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exceed the amount by which the wages (excluding tips) paid by the employer to the employee during such month are less than the total amount which would be payable (with respect to such employment) at the minimum wage rate applicable to such individual under section 6(a)(1) of the Fair Labor Standards Act of 1938 (determined without regard to section 3(m) of such Act, and in the case of food or beverage establishments, as in effect on ","children":[{"tag":"date","attrib":{"date":"2007-01-01"},"text":"January 1, 2007","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40c97a6c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application only to certain lines of business","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In applying paragraph (1) there shall be taken into account only tips received from customers or clients in connection with the following services:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40c97a6d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45B/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The providing, delivering, or serving of food or beverages for consumption, if the tipping of employees delivering or serving food or beverages by customers is customary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40c97a6e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45B/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The providing of any of the following services to a customer or client if the tipping of employees providing such services is customary:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40c97a6f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45B/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Barbering and hair care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40c97a70-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45B/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nail care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40c97a71-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45B/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Esthetics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40c97a72-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45B/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Body and spa treatments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40c97a73-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of double benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowed under this chapter for any amount taken into account in determining the credit under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40c97a74-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election not to claim credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to a taxpayer for any taxable year if such taxpayer elects to have this section not apply for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id40c97a75-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13443/a"},"text":"Pub. L. 103–66, title XIII, § 13443(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/568"},"text":"107 Stat. 568","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1112/a/1"},"text":"Pub. L. 104–188, title I, § 1112(a)(1)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1759"},"text":"110 Stat. 1759","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/28/tVIII/s8213/a"},"text":"Pub. L. 110–28, title VIII, § 8213(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-25"},"text":"May 25, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/193"},"text":"121 Stat. 193","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70201/e"},"text":"Pub. L. 119–21, title VII, § 70201(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/171"},"text":"139 Stat. 171","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id40c97a76-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id40c97a77-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id40c97a78-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 3(m) and 6(a)(1) of the Fair Labor Standards Act of 1938, referred to in subsec. (b)(1)(B), are classified to sections 203(m) and 206(a)(1), respectively, of Title 29, Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id40c97a79-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70201/e/2"},"text":"Pub. L. 119–21, § 70201(e)(2)","children":[],"tail":", struck out “as in effect on "},{"tag":"date","attrib":{"date":"2007-01-01"},"text":"January 1, 2007","children":[],"tail":", and” before “determined without regard to” and inserted “, and in the case of food or beverage establishments, as in effect on "},{"tag":"date","attrib":{"date":"2007-01-01"},"text":"January 1, 2007","children":[],"tail":"” after “without regard to section 3(m) of such Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70201/e/1"},"text":"Pub. L. 119–21, § 70201(e)(1)","children":[],"tail":", amended par. (2) generally. Prior to amendment, text read as follows: “In applying paragraph (1), there shall be taken into account only tips received from customers in connection with the providing, delivering, or serving of food or beverages for consumption if the tipping of employees delivering or serving food or beverages by customers is customary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28"},"text":"Pub. L. 110–28","children":[],"tail":" inserted “as in effect on "},{"tag":"date","attrib":{"date":"2007-01-01"},"text":"January 1, 2007","children":[],"tail":", and” before “determined without regard to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1112/a/1"},"text":"Pub. L. 104–188, § 1112(a)(1)","children":[],"tail":", inserted “(without regard to whether such tips are reported under section 6053)” after “section 3121(q)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1112/b/1"},"text":"Pub. L. 104–188, § 1112(b)(1)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “"},{"tag":"inline","attrib":{},"text":"Only tips received at food and beverage establishments taken into account","children":[],"tail":".—In applying paragraph (1), there shall be taken into account only tips received from customers in connection with the provision of food or beverages for consumption on the premises of an establishment with respect to which the tipping of employees serving food or beverages by customers is customary.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id40c97a7a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id40c97a7b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70201/j"},"text":"Pub. L. 119–21, title VII, § 70201(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/173"},"text":"139 Stat. 173","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70201/j"},"text":"“The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s224"},"text":"section 224 of this title","children":[],"tail":", amending this section and sections 63, 199A, 6041, 6041A, 6050W, 6051, and 6213 of this title, and renumbering former "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s224"},"text":"section 224 of this title","children":[],"tail":" as section 225] shall apply to taxable years beginning after "},{"tag":"date","attrib":{"date":"2024-12-31"},"text":"December 31, 2024","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id40c97a7c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28/tVIII/s8213/b"},"text":"Pub. L. 110–28, title VIII, § 8213(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-25"},"text":"May 25, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/193"},"text":"121 Stat. 193","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/28/tVIII/s8213/b"},"text":"“The amendment made by this section [amending this section] shall apply to tips received for services performed after ","children":[{"tag":"date","attrib":{"date":"2006-12-31"},"text":"December 31, 2006","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id40c97a7d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1112/a/3"},"text":"Pub. L. 104–188, title I, § 1112(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1759"},"text":"110 Stat. 1759","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/188/tI/s1112/a/3"},"text":"“The amendments made by this subsection [amending this section and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s38"},"text":"section 38 of this title","children":[],"tail":"] shall take effect as if included in the amendments made by, and the provisions of, section 13443 of the Revenue Reconciliation Act of 1993 ["},{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1112/b/2"},"text":"Pub. L. 104–188, title I, § 1112(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1759"},"text":"110 Stat. 1759","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/188/tI/s1112/b/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall apply to tips received for services performed after ","children":[{"tag":"date","attrib":{"date":"1996-12-31"},"text":"December 31, 1996","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id40c97a7e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to taxes paid after ","children":[{"tag":"date","attrib":{"date":"1993-12-31"},"text":"Dec. 31, 1993","children":[],"tail":", with respect to services performed before, on, or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13443/d"},"text":"section 13443(d) of Pub. L. 103–66","children":[],"tail":", as amended, set out as an Effective Date of 1993 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
