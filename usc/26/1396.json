{"tag":"section","attrib":{"id":"id44ff5c3d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396"},"text":null,"children":[{"tag":"num","attrib":{"value":"1396"},"text":"§ 1396.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Empowerment zone employment credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44ff5c3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 38, the amount of the empowerment zone employment credit determined under this section with respect to any employer for any taxable year is the applicable percentage of the qualified zone wages paid or incurred during the calendar year which ends with or within such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ff5c3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the applicable percentage is 20 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ff5c40-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified zone wages","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ff5c41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “qualified zone wages” means any wages paid or incurred by an employer for services performed by an employee while such employee is a qualified zone employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5c42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Only first $15,000 of wages per year taken into account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to each qualified zone employee, the amount of qualified zone wages which may be taken into account for a calendar year shall not exceed $15,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5c43-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with work opportunity credit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ff5c44-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified zone wages” shall not include wages taken into account in determining the credit under section 51.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ff5c45-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with paragraph (2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The $15,000 amount in paragraph (2) shall be reduced for any calendar year by the amount of wages paid or incurred during such year which are taken into account in determining the credit under section 51.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ff5c46-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified zone employee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ff5c47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this subsection, the term “qualified zone employee” means, with respect to any period, any employee of an employer if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ff5c48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially all of the services performed during such period by such employee for such employer are performed within an empowerment zone in a trade or business of the employer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ff5c49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the principal place of abode of such employee while performing such services is within such empowerment zone.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5c4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain individuals not eligible","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified zone employee” shall not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ff5c4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual described in subparagraph (A), (B), or (C) of section 51(i)(1),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ff5c4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any 5-percent owner (as defined in section 416(i)(1)(B)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ff5c4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual employed by the employer for less than 90 days,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ff5c4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual employed by the employer at any facility described in section 144(c)(6)(B), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ff5c4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any individual employed by the employer in a trade or business the principal activity of which is farming (within the meaning of subparagraph (A) or (B) of section 2032A(e)(5)), but only if, as of the close of the taxable year, the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44ff5c50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/d/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate unadjusted bases (or, if greater, the fair market value) of the assets owned by the employer which are used in such a trade or business, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44ff5c51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/d/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate value of assets leased by the employer which are used in such a trade or business (as determined under regulations prescribed by the Secretary),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"exceeds $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5c52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules related to termination of employment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ff5c53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (2)(C) shall not apply to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44ff5c54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a termination of employment of an individual who before the close of the period referred to in paragraph (2)(C) becomes disabled to perform the services of such employment unless such disability is removed before the close of such period and the taxpayer fails to offer reemployment to such individual, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44ff5c55-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a termination of employment of an individual if it is determined under the applicable State unemployment compensation law that the termination was due to the misconduct of such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ff5c56-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Changes in form of business","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (2)(C), the employment relationship between the taxpayer and an employee shall not be treated as terminated—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44ff5c57-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a transaction to which section 381(a) applies if the employee continues to be employed by the acquiring corporation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44ff5c58-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1396/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by reason of a mere change in the form of conducting the trade or business of the taxpayer if the employee continues to be employed in such trade or business and the taxpayer retains a substantial interest in such trade or business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44ff5c59-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13301/a"},"text":"Pub. L. 103–66, title XIII, § 13301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/549"},"text":"107 Stat. 549","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1201/e/4"},"text":"Pub. L. 104–188, title I, § 1201(e)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1772"},"text":"110 Stat. 1772","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tIX"},"text":"Pub. L. 105–34, title IX","children":[],"tail":", §§ 951(b), 952(b), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/885"},"text":"111 Stat. 885","children":[],"tail":", 887; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s113/a"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 113(a), (b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–601.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44ff5c5a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44ff5c5b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id44ff5c5c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Taxpayer Relief Act of 1997, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/788"},"text":"111 Stat. 788","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id44ff5c5d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1396, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVI/s601/a"},"text":"Pub. L. 95–600, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2895"},"text":"92 Stat. 2895","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/595/s3/a/6"},"text":"Pub. L. 96–595, § 3(a)(6)","children":[],"tail":", (9), (10), "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3465"},"text":"94 Stat. 3465","children":[],"tail":", related to minimum distributions by an electing general stock ownership corporation, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIII/s1303/a"},"text":"Pub. L. 99–514, title XIII, § 1303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2658"},"text":"100 Stat. 2658","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44ff5c5e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s113/a"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 113(a)]","children":[],"tail":", amended subsec. (b) generally, substituting provisions establishing an applicable percentage of 20 percent for provisions setting out tables for determining the applicable percentage."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s113/b"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 113(b)]","children":[],"tail":", struck out heading and text of subsec. (e). Text read as follows: “This section shall be applied without regard to any empowerment zone designated under section 1391(g).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" substituted “For purposes of this section—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—Except as provided in paragraph (2), the term ‘applicable percentage’ means the percentage determined in accordance with the following table:”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"for “For purposes of this section, the term ‘applicable percentage’ means the percentage determined in accordance with the following table:” and added par. (2).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s952/b"},"text":"Pub. L. 105–34, § 952(b)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" substituted “work opportunity credit” for “targeted jobs credit” in heading."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44ff5c5f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44ff5c60-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s113/d"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 113(d)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–601, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/554/s1/a/7/tI/s113/d"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1400"},"text":"section 1400 of this title","children":[],"tail":"] shall apply to wages paid or incurred after "},{"tag":"date","attrib":{"date":"2001-12-31"},"text":"December 31, 2001","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44ff5c61-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s951/b"},"text":"section 951(b) of Pub. L. 105–34","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", except that designations of new empowerment zones made pursuant to amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s951"},"text":"section 951 of Pub. L. 105–34","children":[],"tail":" to be made during 180-day period beginning "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", and no designation pursuant to such amendments to take effect before "},{"tag":"date","attrib":{"date":"2000-01-01"},"text":"Jan. 1, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s951/c"},"text":"section 951(c) of Pub. L. 105–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1391"},"text":"section 1391 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44ff5c62-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" applicable to individuals who begin work for the employer after "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1201/g"},"text":"section 1201(g) of Pub. L. 104–188","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
