{"tag":"section","attrib":{"id":"id462e1885-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5203"},"text":null,"children":[{"tag":"num","attrib":{"value":"5203"},"text":"§ 5203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entry and examination of premises","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id462e1886-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Keeping premises accessible","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every proprietor of a distilled spirits plant shall furnish the Secretary such keys as may be required for internal revenue officers to gain access to the premises and any structures thereon, and such premises shall always be kept accessible to any officer having such keys.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462e1887-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of entry and examination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be lawful for any internal revenue officer at all times, as well by night as by day, to enter any distilled spirits plant, or any other premises where distilled spirits operations are carried on, or structure or place used in connection therewith for storage or other purposes; to make examination of the materials, equipment, and facilities thereon; and make such gauges and inventories as he deems necessary. Whenever any officer, having demanded admittance, and having declared his name and office, is not admitted into such premises by the proprietor or other person having charge thereof, it shall be lawful for such officer, at all times, as well by night as by day, to use such force as is necessary for him to gain entry to such premises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462e1888-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Furnishing facilities and assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the demand of any internal revenue officer or agent, every proprietor of a distilled spirits plant shall furnish the necessary facilities and assistance to enable the officer or agent to gauge the spirits in any container or to examine any apparatus, equipment, containers, or materials on such premises. Such proprietor shall also, on demand of such officer or agent, open all doors, and open for examination all boxes, packages, and all casks, barrels, and other vessels on such premises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462e1889-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5203/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to break up grounds or walls","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be lawful for any internal revenue officer, and any person acting in his aid, to break up the ground on any part of a distilled spirits plant or any other premises where distilled spirits operations are carried on, or any ground adjoining or near to such plant or premises, or any wall or partition thereof, or belonging thereto, or other place, to search for any pipe, cock, private conveyance, or utensil; and, upon finding any such pipe or conveyance leading therefrom or thereto, to break up any ground, house, wall, or other place through or into which such pipe or other conveyance leads, and to break or cut away such pipe or other conveyance, and turn any cock, or to examine whether such pipe or other conveyance conveys or conceals any distilled spirits, mash, wort, or beer, or other liquor, from the sight or view of the officer, so as to prevent or hinder him from taking a true account thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462e188a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5203/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For penalty for violation of this section, see section 5687.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id462e188b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1357"},"text":"72 Stat. 1357","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/22"},"text":"Pub. L. 96–39, title VIII, § 807(a)(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/283"},"text":"93 Stat. 283","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id462e188c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id462e188d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id462e188e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising this section were contained in prior sections of act ","children":[{"tag":"date","attrib":{"date":"1954-08-16"},"text":"Aug. 16, 1954","children":[],"tail":", prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":", as follows:"},{"tag":"quotedContent","attrib":{},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id462e188f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Present subsecs.:","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html