{"tag":"section","attrib":{"id":"id46d04b3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6332"},"text":null,"children":[{"tag":"num","attrib":{"value":"6332"},"text":"§ 6332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surrender of property subject to levy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46d04b3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, any person in possession of (or obligated with respect to) property or rights to property subject to levy upon which a levy has been made shall, upon demand of the Secretary, surrender such property or rights (or discharge such obligation) to the Secretary, except such part of the property or rights as is, at the time of such demand, subject to an attachment or execution under any judicial process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46d04b40-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for life insurance and endowment contracts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46d04b41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6332/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A levy on an organization with respect to a life insurance or endowment contract issued by such organization shall, without necessity for the surrender of the contract document, constitute a demand by the Secretary for payment of the amount described in paragraph (2) and the exercise of the right of the person against whom the tax is assessed to the advance of such amount. Such organization shall pay over such amount 90 days after service of notice of levy. Such notice shall include a certification by the Secretary that a copy of such notice has been mailed to the person against whom the tax is assessed at his last known address.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d04b42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6332/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Satisfaction of levy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such levy shall be deemed to be satisfied if such organization pays over to the Secretary the amount which the person against whom the tax is assessed could have had advanced to him by such organization on the date prescribed in paragraph (1) for the satisfaction of such levy, increased by the amount of any advance (including contractual interest thereon) made to such person on or after the date such organization had actual notice or knowledge (within the meaning of section 6323(i)(1)) of the existence of the lien with respect to which such levy is made, other than an advance (including contractual interest thereon) made automatically to maintain such contract in force under an agreement entered into before such organization had such notice or knowledge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d04b43-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6332/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The satisfaction of a levy under paragraph (2) shall be without prejudice to any civil action for the enforcement of any lien imposed by this title with respect to such contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46d04b44-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6332/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for banks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any bank (as defined in section 408(n)) shall surrender (subject to an attachment or execution under judicial process) any deposits (including interest thereon) in such bank only after 21 days after service of levy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46d04b45-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6332/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of levy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46d04b46-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6332/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extent of personal liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who fails or refuses to surrender any property or rights to property, subject to levy, upon demand by the Secretary, shall be liable in his own person and estate to the United States in a sum equal to the value of the property or rights not so surrendered, but not exceeding the amount of taxes for the collection of which such levy has been made, together with costs and interest on such sum at the underpayment rate established under section 6621 from the date of such levy (or, in the case of a levy described in section 6331(d)(3), from the date such person would otherwise have been obligated to pay over such amounts to the taxpayer). Any amount (other than costs) recovered under this paragraph shall be credited against the tax liability for the collection of which such levy was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d04b47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6332/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the personal liability imposed by paragraph (1), if any person required to surrender property or rights to property fails or refuses to surrender such property or rights to property without reasonable cause, such person shall be liable for a penalty equal to 50 percent of the amount recoverable under paragraph (1). No part of such penalty shall be credited against the tax liability for the collection of which such levy was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46d04b48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6332/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of honoring levy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person in possession of (or obligated with respect to) property or rights to property subject to levy upon which a levy has been made who, upon demand by the Secretary, surrenders such property or rights to property (or discharges such obligation) to the Secretary (or who pays a liability under subsection (d)(1)) shall be discharged from any obligation or liability to the delinquent taxpayer and any other person with respect to such property or rights to property arising from such surrender or payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46d04b49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6332/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person,” as used in subsection (a), includes an officer or employee of a corporation or a member or employee of a partnership, who as such officer, employee, or member is under a duty to surrender the property or rights to property, or to discharge the obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46d04b4a-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/784"},"text":"68A Stat. 784","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/719/tI/s104/b"},"text":"Pub. L. 89–719, title I, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1135"},"text":"80 Stat. 1135","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/625/s7/a/2/D"},"text":"Pub. L. 93–625, § 7(a)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2115"},"text":"88 Stat. 2115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXII/s1209/d/3"},"text":"Pub. L. 94–455, title XII, § 1209(d)(3)","children":[],"tail":", title XIX, § 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1710"},"text":"90 Stat. 1710","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1511/c/9"},"text":"Pub. L. 99–514, title XV, § 1511(c)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2745"},"text":"100 Stat. 2745","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1015/t/1"},"text":"Pub. L. 100–647, title I, § 1015(t)(1)","children":[],"tail":", title VI, § 6236(e), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3573"},"text":"102 Stat. 3573","children":[],"tail":", 3739; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11704/a/27"},"text":"Pub. L. 101–508, title XI, § 11704(a)(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-519"},"text":"104 Stat. 1388–519","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46d04b4b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46d04b4c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46d04b4d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted “this section” for “subsections (b) and (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s6236/e/2/A"},"text":"Pub. L. 100–647, § 6236(e)(2)(A)","children":[],"tail":", substituted “subsections (b) and (c)” for “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s6236/e/1"},"text":"Pub. L. 100–647, § 6236(e)(1)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s6236/e/1"},"text":"Pub. L. 100–647, § 6236(e)(1)","children":[],"tail":", redesignated subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1015/t/1"},"text":"Pub. L. 100–647, § 1015(t)(1)","children":[],"tail":", inserted “and any other person” after “delinquent taxpayer” and struck out sentence at end providing that in the case of a levy which is satisfied pursuant to subsection (b), such organization shall also be discharged from any obligation or liability to any beneficiary arising from such surrender or payment."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s6236/e/1"},"text":"Pub. L. 100–647, § 6236(e)(1)","children":[],"tail":", (2)(B), redesignated subsec. (d) as (e) and substituted “subsection (d)(1)” for “subsection (c)(1)”. Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s6236/e/1"},"text":"Pub. L. 100–647, § 6236(e)(1)","children":[],"tail":", redesignated subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “the underpayment rate established under section 6621” for “an annual rate established under section 6621”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 1209(d)(3), 1906(b)(13)(A), inserted “(or, in the case of a levy described in section 6331(d)(3), from the date such person would otherwise have been obligated to pay over such amounts to the taxpayer)” after “date of such levy”, and struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/625"},"text":"Pub. L. 93–625","children":[],"tail":" substituted “an annual rate established under section 6621” for “the rate of 6 percent per annum”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/719/s104/b/1"},"text":"Pub. L. 89–719, § 104(b)(1)","children":[],"tail":", substituted “Except as otherwise provided in subsection (b), any person” for “Any person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/719/s104/b/2"},"text":"Pub. L. 89–719, § 104(b)(2)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated, with amendments, as subsec. (c)(1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/719/s104/b/2"},"text":"Pub. L. 89–719, § 104(b)(2)","children":[],"tail":"–(4), redesignated as par. (1) provisions formerly set out as subsec. (b), inserted provisions that any amount other than costs recovered under par. (1) shall be credited against the tax liability for the collection of which the levy was made, and added par. (2). Former subsec. (c) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/719/s104/b/4"},"text":"Pub. L. 89–719, § 104(b)(4)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/719/s104/b/3"},"text":"Pub. L. 89–719, § 104(b)(3)","children":[],"tail":", redesignated former subsec. (c) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46d04b4e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46d04b4f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1015/t/2"},"text":"Pub. L. 100–647, title I, § 1015(t)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3573"},"text":"102 Stat. 3573","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1015/t/2"},"text":"“The amendment made by this subsection [amending this section] shall apply to levies issued after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s6236/e"},"text":"section 6236(e) of Pub. L. 100–647","children":[],"tail":" applicable to levies issued on or after "},{"tag":"date","attrib":{"date":"1989-07-01"},"text":"July 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s6236/h/1"},"text":"section 6236(h)(1) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6331"},"text":"section 6331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46d04b50-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" applicable for purposes of determining interest for periods after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1511/d"},"text":"section 1511(d) of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s47"},"text":"section 47 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46d04b51-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1209/d/3"},"text":"section 1209(d)(3) of Pub. L. 94–455","children":[],"tail":" effective only with respect to levies made after "},{"tag":"date","attrib":{"date":"1977-02-28"},"text":"Feb. 28, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1209/e"},"text":"section 1209(e) of Pub. L. 94–455","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/94/528/s2/c"},"text":"section 2(c) of Pub. L. 94–528","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2483"},"text":"90 Stat. 2483","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6334"},"text":"section 6334 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46d04b52-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1975 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/625"},"text":"Pub. L. 93–625","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1975-07-01"},"text":"July 1, 1975","children":[],"tail":", and applicable to amounts outstanding on such date or arising thereafter, see "},{"tag":"ref","attrib":{"href":"/us/pl/93/625/s7/e"},"text":"section 7(e) of Pub. L. 93–625","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6621"},"text":"section 6621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46d04b53-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/719"},"text":"Pub. L. 89–719","children":[],"tail":" applicable after "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", regardless of when title or lien of United States arose or when lien or interest of another person was acquired, with certain exceptions, see section 114(a)–(c) of "},{"tag":"ref","attrib":{"href":"/us/pl/89/719"},"text":"Pub. L. 89–719","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6323"},"text":"section 6323 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
