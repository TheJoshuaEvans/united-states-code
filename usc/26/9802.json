{"tag":"section","attrib":{"id":"id47cab184-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802"},"text":null,"children":[{"tag":"num","attrib":{"value":"9802"},"text":"§ 9802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibiting discrimination against individual participants and beneficiaries based on health status","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47cab185-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In eligibility to enroll","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47cab186-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), a group health plan may not establish rules for eligibility (including continued eligibility) of any individual to enroll under the terms of the plan based on any of the following factors in relation to the individual or a dependent of the individual:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47cab187-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47cab188-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medical condition (including both physical and mental illnesses).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47cab189-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Claims experience.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47cab18a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Receipt of health care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47cab18b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medical history.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47cab18c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Genetic information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47cab18d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evidence of insurability (including conditions arising out of acts of domestic violence).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47cab18e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47cab18f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No application to benefits or exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent consistent with section 9801, paragraph (1) shall not be construed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47cab190-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require a group health plan to provide particular benefits (or benefits with respect to a specific procedure, treatment, or service) other than those provided under the terms of such plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47cab191-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent such a plan from establishing limitations or restrictions on the amount, level, extent, or nature of the benefits or coverage for similarly situated individuals enrolled in the plan or coverage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47cab192-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), rules for eligibility to enroll under a plan include rules defining any applicable waiting periods for such enrollment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47cab193-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In premium contributions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47cab194-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A group health plan may not require any individual (as a condition of enrollment or continued enrollment under the plan) to pay a premium or contribution which is greater than such premium or contribution for a similarly situated individual enrolled in the plan on the basis of any factor described in subsection (a)(1) in relation to the individual or to an individual enrolled under the plan as a dependent of the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47cab195-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in paragraph (1) shall be construed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47cab196-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restrict the amount that an employer may be charged for coverage under a group health plan except as provided in paragraph (3); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47cab197-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent a group health plan from establishing premium discounts or rebates or modifying otherwise applicable copayments or deductibles in return for adherence to programs of health promotion and disease prevention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47cab198-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No group-based discrimination on basis of genetic information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47cab199-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, a group health plan may not adjust premium or contribution amounts for the group covered under such plan on the basis of genetic information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47cab19a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in subparagraph (A) or in paragraphs (1) and (2) of subsection (d) shall be construed to limit the ability of a group health plan to increase the premium for an employer based on the manifestation of a disease or disorder of an individual who is enrolled in the plan. In such case, the manifestation of a disease or disorder in one individual cannot also be used as genetic information about other group members and to further increase the premium for the employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47cab19b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Genetic testing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47cab19c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on requesting or requiring genetic testing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A group health plan may not request or require an individual or a family member of such individual to undergo a genetic test.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47cab19d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not be construed to limit the authority of a health care professional who is providing health care services to an individual to request that such individual undergo a genetic test.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47cab19e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction regarding payment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47cab19f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (1) shall be construed to preclude a group health plan from obtaining and using the results of a genetic test in making a determination regarding payment (as such term is defined for the purposes of applying the regulations promulgated by the Secretary of Health and Human Services under part C of title XI of the Social Security Act and section 264 of the Health Insurance Portability and Accountability Act of 1996, as may be revised from time to time) consistent with subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47cab1a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), a group health plan may request only the minimum amount of information necessary to accomplish the intended purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47cab1a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (1), a group health plan may request, but not require, that a participant or beneficiary undergo a genetic test if each of the following conditions is met:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47cab1a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The request is made pursuant to research that complies with part 46 of title 45, Code of Federal Regulations, or equivalent Federal regulations, and any applicable State or local law or regulations for the protection of human subjects in research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47cab1a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The plan clearly indicates to each participant or beneficiary, or in the case of a minor child, to the legal guardian of such beneficiary, to whom the request is made that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47cab1a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with the request is voluntary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47cab1a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" non-compliance will have no effect on enrollment status or premium or contribution amounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47cab1a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No genetic information collected or acquired under this paragraph shall be used for underwriting purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47cab1a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The plan notifies the Secretary in writing that the plan is conducting activities pursuant to the exception provided for under this paragraph, including a description of the activities conducted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47cab1a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The plan complies with such other conditions as the Secretary may by regulation require for activities conducted under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47cab1a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on collection of genetic information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47cab1aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A group health plan shall not request, require, or purchase genetic information for underwriting purposes (as defined in section 9832).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47cab1ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on collection of genetic information prior to enrollment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A group health plan shall not request, require, or purchase genetic information with respect to any individual prior to such individual’s enrollment under the plan or in connection with such enrollment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47cab1ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incidental collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a group health plan obtains genetic information incidental to the requesting, requiring, or purchasing of other information concerning any individual, such request, requirement, or purchase shall not be considered a violation of paragraph (2) if such request, requirement, or purchase is not in violation of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47cab1ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to all plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of subsections (a)(1)(F), (b)(3), (c), and (d) and subsection (b)(1) and section 9801 with respect to genetic information, shall apply to group health plans without regard to section 9831(a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47cab1ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for church plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A church plan (as defined in section 414(e)) shall not be treated as failing to meet the requirements of this section solely because such plan requires evidence of good health for coverage of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47cab1af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" both any employee of an employer with 10 or less employees (determined without regard to section 414(e)(3)(C)) and any self-employed individual, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47cab1b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual who enrolls after the first 90 days of initial eligibility under the plan.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This subsection shall apply to a plan for any year only if the plan included the provisions described in the preceding sentence on ","children":[{"tag":"date","attrib":{"date":"1997-07-15"},"text":"July 15, 1997","children":[],"tail":", and at all times thereafter before the beginning of such year."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47cab1b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Genetic information of a fetus or embryo","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any reference in this chapter to genetic information concerning an individual or family member of an individual shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47cab1b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to such an individual or family member of an individual who is a pregnant woman, include genetic information of any fetus carried by such pregnant woman; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47cab1b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9802/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to an individual or family member utilizing an assisted reproductive technology, include genetic information of any embryo legally held by the individual or family member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47cab1b4-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/tIV/s401/a"},"text":"Pub. L. 104–191, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2078"},"text":"110 Stat. 2078","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXV/s1532/a"},"text":"Pub. L. 105–34, title XV, § 1532(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1085"},"text":"111 Stat. 1085","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/233/tI/s103/a"},"text":"Pub. L. 110–233, title I, § 103(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"2008-05-21"},"text":"May 21, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/896"},"text":"122 Stat. 896","children":[],"tail":", 897; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s220/aa"},"text":"Pub. L. 113–295, div. A, title II, § 220(aa)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4037"},"text":"128 Stat. 4037","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47cab1b5-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47cab1b6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id47cab1b7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (c)(3)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Part C of title XI of the Act is classified generally to part C (§ 1320d et seq.) of subchapter XI of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 264 of the Health Insurance Portability and Accountability Act of 1996, referred to in subsec. (c)(3)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/s264"},"text":"section 264 of Pub. L. 104–191","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–2"},"text":"section 1320d–2 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47ccfaa8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" redesignated subsec. (f) relating to genetic information of a fetus or embryo as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/233/s103/a/1"},"text":"Pub. L. 110–233, § 103(a)(1)","children":[],"tail":", inserted “except as provided in paragraph (3)” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/233/s103/a/2"},"text":"Pub. L. 110–233, § 103(a)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","chi