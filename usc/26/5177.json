{"tag":"section","attrib":{"id":"id462bce03-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5177"},"text":null,"children":[{"tag":"num","attrib":{"value":"5177"},"text":"§ 5177.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other provisions relating to bonds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id462bce04-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5177/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions relating to bonds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of section 5551 shall be applicable to the bonds required by or given under sections 5173 and 5175.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462bce05-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5177/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id462bce06-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5177/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For deposit of United States bonds or notes in lieu of sureties, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9303"},"text":"section 9303 of title 31","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id462bce07-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5177/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For penalty and forfeiture for failure or refusal to give bond, or for giving false, forged, or fraudulent bond, or carrying on the business of a distiller without giving bond, see sections 5601(a)(4), 5601(a)(5), 5601(b), and 5615(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id462bce08-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1353"},"text":"72 Stat. 1353","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1905/b/6/B"},"text":"Pub. L. 94–455, title XIX, § 1905(b)(6)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1823"},"text":"90 Stat. 1823","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/17"},"text":"Pub. L. 96–39, title VIII, § 807(a)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/282"},"text":"93 Stat. 282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s3/f/3"},"text":"Pub. L. 97–258, § 3(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1064"},"text":"96 Stat. 1064","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id462bce09-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id462bce0a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes"