{"tag":"section","attrib":{"id":"id45f4e077-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4967"},"text":null,"children":[{"tag":"num","attrib":{"value":"4967"},"text":"§ 4967.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxes on prohibited benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45f4e078-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4967/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of taxes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f4e079-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4967/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On the donor, donor advisor, or related person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on the advice of any person described in subsection (d) to have a sponsoring organization make a distribution from a donor advised fund which results in such person or any other person described in subsection (d) receiving, directly or indirectly, a more than incidental benefit as a result of such distribution, a tax equal to 125 percent of such benefit. The tax imposed by this paragraph shall be paid by any person described in subsection (d) who advises as to the distribution or who receives such a benefit as a result of the distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e07a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4967/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On the fund management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on the agreement of any fund manager to the making of a distribution, knowing that such distribution would confer a benefit described in paragraph (1), a tax equal to 10 percent of the amount of such benefit. The tax imposed by this paragraph shall be paid by any fund manager who agreed to the making of the distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f4e07b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4967/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No tax shall be imposed under this section with respect to any distribution if a tax has been imposed with respect to such distribution under section 4958.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f4e07c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4967/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f4e07d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4967/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint and several liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If more than one person is liable under paragraph (1) or (2) of subsection (a) with respect to a distribution described in subsection (a), all such persons shall be jointly and severally liable under such paragraph with respect to such distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e07e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4967/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit for management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any one distribution described in subsection (a), the maximum amount of the tax imposed by subsection (a)(2) shall not exceed $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f4e07f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4967/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person is described in this subsection if such person is described in section 4958(f)(7) with respect to a donor advised fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45f4e080-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1231/a"},"text":"Pub. L. 109–280, title XII, § 1231(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1097"},"text":"120 Stat. 1097","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45f4e081-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45f4e082-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45f4e083-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1231/c"},"text":"section 1231(c) of Pub. L. 109–280","children":[],"tail":", set out as an Effective Date of 2006 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4963"},"text":"section 4963 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
