{"tag":"section","attrib":{"id":"id473b9033-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6725"},"text":null,"children":[{"tag":"num","attrib":{"value":"6725"},"text":"§ 6725.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to report information under section 4101","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id473b9034-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6725/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of each failure described in subsection (b) by any person with respect to a vessel or facility, such person shall pay a penalty of $10,000 in addition to the tax (if any).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id473b9035-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6725/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failures subject to penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the failures described in this subsection are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id473b9036-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6725/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any failure to make a report under section 4101(d) on or before the date prescribed therefor, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id473b9037-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6725/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any failure to include all of the information required to be shown on such report or the inclusion of incorrect information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id473b9038-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6725/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable cause exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed under this section with respect to any failure if it is shown that such failure is due to reasonable cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id473b9039-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s863/d/1"},"text":"Pub. L. 108–357, title VIII, § 863(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1620"},"text":"118 Stat. 1620","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id473b903a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id473b903b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id473b903c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to penalties imposed after ","children":[{"tag":"date","attrib":{"date":"2004-12-31"},"text":"Dec. 31, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s863/e"},"text":"section 863(e) of Pub. L. 108–357","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6719"},"text":"section 6719 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
