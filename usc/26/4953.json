{"tag":"section","attrib":{"id":"id45f02522-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4953"},"text":null,"children":[{"tag":"num","attrib":{"value":"4953"},"text":"§ 4953.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on excess contributions to black lung benefit trusts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45f02523-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4953/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax imposed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed for each taxable year a tax in an amount equal to 5 percent of the amount of the excess contributions made by a person to or under a trust or trusts described in section 501(c)(21). The tax imposed by this subsection shall be paid by the person making the excess contribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f02524-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4953/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess contribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “excess contribution” means the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f02525-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4953/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount by which the amount contributed for the taxable year to a trust or trusts described in section 501(c)(21) exceeds the amount of the deduction allowable to such person for such contributions for the taxable year under section 192, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f02526-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4953/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the amount determined under this subsection for the preceding taxable year, reduced by the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f02527-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4953/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the excess of the maximum amount allowable as a deduction under section 192 for the taxable year over the amount contributed to the trust or trusts for the taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f02528-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4953/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts distributed from the trust to the contributor which were excess contributions for the preceding taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f02529-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4953/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of withdrawal of excess contributions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts distributed during the taxable year from a trust described in section 501(c)(21) to the contributor thereof the sum of which does not exceed the amount of the excess contribution made by the contributor shall not be treated as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f0252a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4953/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an act of self-dealing (within the meaning of section 4951),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f0252b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4953/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a taxable expenditure (within the meaning of section 4952), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f0252c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4953/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an act contrary to the purposes for which the trust is exempt from taxation under section 501(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45f0252d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/227/s4/c/1"},"text":"Pub. L. 95–227, § 4(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-02-10"},"text":"Feb. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/22"},"text":"92 Stat. 22","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
