{"tag":"section","attrib":{"id":"id40defece-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W"},"text":null,"children":[{"tag":"num","attrib":{"value":"45W"},"text":"§ 45W.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit for qualified commercial clean vehicles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40defecf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 38, the qualified commercial clean vehicle credit for any taxable year is an amount equal to the sum of the credit amounts determined under subsection (b) with respect to each qualified commercial clean vehicle placed in service by the taxpayer during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40defed0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Per vehicle amount","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40defed1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (4), the amount determined under this subsection with respect to any qualified commercial clean vehicle shall be equal to the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40defed2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 15 percent of the basis of such vehicle (30 percent in the case of a vehicle not powered by a gasoline or diesel internal combustion engine), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40defed3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incremental cost of such vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defed4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incremental cost","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1)(B), the incremental cost of any qualified commercial clean vehicle is an amount equal to the excess of the purchase price for such vehicle over such price of a comparable vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defed5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comparable vehicle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “comparable vehicle” means, with respect to any qualified commercial clean vehicle, any vehicle which is powered solely by a gasoline or diesel internal combustion engine and which is comparable in size and use to such vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defed6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount determined under this subsection with respect to any qualified commercial clean vehicle shall not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40defed7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a vehicle which has a gross vehicle weight rating of less than 14,000 pounds, $7,500, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40defed8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a vehicle not described in subparagraph (A), $40,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40defed9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified commercial clean vehicle","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified commercial clean vehicle” means any vehicle which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40defeda-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements of section 30D(d)(1)(C) and is acquired for use or lease by the taxpayer and not for resale,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defedb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40defedc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements of subparagraph (D) of section 30D(d)(1) and is manufactured primarily for use on public streets, roads, and highways (not including a vehicle operated exclusively on a rail or rails), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40defedd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is mobile machinery, as defined in section 4053(8) (including vehicles that are not designed to perform a function of transporting a load over the public highways),","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defede-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40defedf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is propelled to a significant extent by an electric motor which draws electricity from a battery which has a capacity of not less than 15 kilowatt hours (or, in the case of a vehicle which has a gross vehicle weight rating of less than 14,000 pounds, 7 kilowatt hours) and is capable of being recharged from an external source of electricity, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40defee0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a motor vehicle which satisfies the requirements under subparagraphs (A) and (B) of section 30B(b)(3), and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defee1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is of a character subject to the allowance for depreciation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40defee2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40defee3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules under subsection (f) of section 30D (without regard to paragraph (10) or (11) thereof) shall apply for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defee4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vehicles placed in service by tax-exempt entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (c)(4) shall not apply to any vehicle which is not subject to a lease and which is placed in service by a tax-exempt entity described in clause (i), (ii), or (iv) of section 168(h)(2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defee5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No double benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No credit shall be allowed under this section with respect to any vehicle for which a credit was allowed under section 30D.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40defee6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" VIN number requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No credit shall be determined under subsection (a) with respect to any vehicle unless the taxpayer includes the vehicle identification number of such vehicle on the return of tax for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40defee7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue such regulations or other guidance as the Secretary determines necessary to carry out the purposes of this section, including regulations or other guidance relating to determination of the incremental cost of any qualified commercial clean vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40defee8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45W/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No credit shall be determined under this section with respect to any vehicle acquired after ","children":[{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id40defee9-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s13403/a"},"text":"Pub. L. 117–169, title I, § 13403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1964"},"text":"136 Stat. 1964","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70503"},"text":"Pub. L. 119–21, title VII, § 70503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/251"},"text":"139 Stat. 251","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id40defeea-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id40defeeb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id40defeec-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2032-12-31"},"text":"December 31, 2032","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id40defeed-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id40defeee-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s13403/c"},"text":"Pub. L. 117–169, title I, § 13403(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1966"},"text":"136 Stat. 1966","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/169/tI/s13403/c"},"text":"“The amendments made by this section [enacting this section and amending sections 38 and 6213 of this title] shall apply to vehicles acquired after ","children":[{"tag":"date","attrib":{"date":"2022-12-31"},"text":"December 31, 2022","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
