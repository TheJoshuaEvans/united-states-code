{"tag":"section","attrib":{"id":"id40d7d307-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O"},"text":null,"children":[{"tag":"num","attrib":{"value":"45O"},"text":"§ 45O.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural chemicals security credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40d7d308-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 38, in the case of an eligible agricultural business, the agricultural chemicals security credit determined under this section for the taxable year is 30 percent of the qualified security expenditures for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d7d309-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facility limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the credit determined under subsection (a) with respect to any facility for any taxable year shall not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d7d30a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000, reduced by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d7d30b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of credits determined under subsection (a) with respect to such facility for the 5 prior taxable years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d7d30c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the credit determined under subsection (a) with respect to any taxpayer for any taxable year shall not exceed $2,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d7d30d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified chemical security expenditure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified chemical security expenditure” means, with respect to any eligible agricultural business for any taxable year, any amount paid or incurred by such business during such taxable year for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d7d30e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employee security training and background checks,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d7d30f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limitation and prevention of access to controls of specified agricultural chemicals stored at the facility,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d7d310-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tagging, locking tank valves, and chemical additives to prevent the theft of specified agricultural chemicals or to render such chemicals unfit for illegal use,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d7d311-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection of the perimeter of specified agricultural chemicals,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d7d312-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" installation of security lighting, cameras, recording equipment, and intrusion detection sensors,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d7d313-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation of measures to increase computer or computer network security,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d7d314-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting a security vulnerability assessment,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d7d315-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing a site security plan, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d7d316-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other measures for the protection of specified agricultural chemicals as the Secretary may identify in regulation.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Amounts described in the preceding sentence shall be taken into account only to the extent that such amounts are paid or incurred for the purpose of protecting specified agricultural chemicals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d7d317-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible agricultural business","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “eligible agricultural business” means any person in the trade or business of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d7d318-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selling agricultural products, including specified agricultural chemicals, at retail predominantly to farmers and ranchers, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d7d319-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufacturing, formulating, distributing, or aerially applying specified agricultural chemicals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d7d31a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified agricultural chemical","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “specified agricultural chemical” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d7d31b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any fertilizer commonly used in agricultural operations which is listed under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d7d31c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 302(a)(2) of the Emergency Planning and Community Right-to-Know Act of 1986,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d7d31d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 101 of part 172 of title 49, Code of Federal Regulations, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d7d31e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part 126, 127, or 154 of title 33, Code of Federal Regulations, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d7d31f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any pesticide (as defined in section 2(u) of the Federal Insecticide, Fungicide, and Rodenticide Act), including all active and inert ingredients thereof, which is customarily used on crops grown for food, feed, or fiber.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d7d320-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of paragraphs (1) and (2) of section 41(f) shall apply for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d7d321-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may prescribe such regulations as may be necessary or appropriate to carry out the purposes of this section, including regulations which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d7d322-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the proper treatment of amounts which are paid or incurred for purpose of protecting any specified agricultural chemical and for other purposes, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d7d323-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the treatment of related properties as one facility for purposes of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d7d324-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45O/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to any amount paid or incurred after ","children":[{"tag":"date","attrib":{"date":"2012-12-31"},"text":"December 31, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id40d7d325-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXV/s15343/a"},"text":"Pub. L. 110–234, title XV, § 15343(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1518"},"text":"122 Stat. 1518","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XV, § 15343(a), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2280.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id40d7d326-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id40d7d327-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id40d7d328-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 302(a)(2) of the Emergency Planning and Community Right-to-Know Act of 1986, referred to in subsec. (f)(1)(A), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11002/a/2"},"text":"section 11002(a)(2) of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2(u) of the Federal Insecticide, Fungicide, and Rodenticide Act, referred to in subsec. (f)(2), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136/u"},"text":"section 136(u) of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id40d7d329-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id40d7d32a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id40d7d32b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section applicable to amounts paid or incurred after ","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s15343/e"},"text":"section 15343(e) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date of 2008 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s38"},"text":"section 38 of this title","chi