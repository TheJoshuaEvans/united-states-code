{"tag":"section","attrib":{"id":"id4227f9c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s212"},"text":null,"children":[{"tag":"num","attrib":{"value":"212"},"text":"§ 212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses for production of income","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In the case of an individual, there shall be allowed as a deduction all the ordinary and necessary expenses paid or incurred during the taxable year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4227f9c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s212/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the production or collection of income;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4227f9c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s212/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the management, conservation, or maintenance of property held for the production of income; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4227f9c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s212/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with the determination, collection, or refund of any tax.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4227f9c4-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/69"},"text":"68A Stat. 69","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4227f9c5-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4227f9c6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4227f9c7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Denial of Deduction for Amounts Paid or Incurred on Judgments in Suits Brought To Recover Price Increases in Purchase of New Principal Residence","children":[],"tail":null},{"tag":"p","attrib":{},"text":"No deductions to be allowed in computing taxable income for two-thirds of any amount paid or incurred on a judgment entered against any person in a suit brought under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/12/s208/b"},"text":"section 208(b) of Pub. L. 94–12","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/12/s208/c"},"text":"section 208(c) of Pub. L. 94–12","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s44"},"text":"section 44 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
