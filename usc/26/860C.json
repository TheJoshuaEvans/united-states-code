{"tag":"section","attrib":{"id":"id443973fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C"},"text":null,"children":[{"tag":"num","attrib":{"value":"860C"},"text":"§ 860C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxation of residual interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id443973fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pass-thru of income or loss","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443973ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the tax under this chapter of any holder of a residual interest in a REMIC, such holder shall take into account his daily portion of the taxable income or net loss of such REMIC for each day during the taxable year on which such holder held such interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44397400-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Daily portion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The daily portion referred to in paragraph (1) shall be determined—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44397401-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by allocating to each day in any calendar quarter its ratable portion of the taxable income (or net loss) for such quarter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44397402-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by allocating the amount so allocated to any day among the holders (on such day) of residual interests in proportion to their respective holdings on such day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44397403-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of taxable income or net loss","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44397404-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The taxable income of a REMIC shall be determined under an accrual method of accounting and, except as provided in regulations, in the same manner as in the case of an individual, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44397405-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regular interests in such REMIC (if not otherwise debt instruments) shall be treated as indebtedness of such REMIC,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44397406-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" market discount on any market discount bond shall be included in gross income for the taxable years to which it is attributable as determined under the rules of section 1276(b)(2) (and sections 1276(a) and 1277 shall not apply),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44397407-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there shall not be taken into account any item of income, gain, loss, or deduction allocable to a prohibited transaction,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44397408-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deductions referred to in section 703(a)(2) (other than any deduction under section 212) shall not be allowed, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44397409-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the net income from foreclosure property (if any) shall be reduced by the amount of the tax imposed by section 860G(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4439740a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net loss","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The net loss of any REMIC is the excess of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbdfb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deductions allowable in computing the taxable income of such REMIC, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbdfc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its gross income.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such amount shall be determined with the modifications set forth in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443bbdfd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any distribution by a REMIC—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443bbdfe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be included in gross income to the extent it does not exceed the adjusted basis of the interest, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbdff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent it exceeds the adjusted basis of the interest, shall be treated as gain from the sale or exchange of such interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443bbe00-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443bbe01-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The basis of any person’s residual interest in a REMIC shall be increased by the amount of the taxable income of such REMIC taken into account under subsection (a) by such person with respect to such interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe02-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decreases in basis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The basis of any person’s residual interest in a REMIC shall be decreased (but not below zero) by the sum of the following amounts:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbe03-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any distributions to such person with respect to such interest, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe04-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any net loss of such REMIC taken into account under subsection (a) by such person with respect to such interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443bbe05-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443bbe06-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts treated as ordinary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount taken into account under subsection (a) by any holder of a residual interest in a REMIC shall be treated as ordinary income or ordinary loss, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe07-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on losses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbe08-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the net loss of any REMIC taken into account by a holder under subsection (a) with respect to any calendar quarter shall not exceed the adjusted basis of such holder’s residual interest in such REMIC as of the close of such calendar quarter (determined without regard to the adjustment under subsection (d)(2)(B) for such calendar quarter).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe09-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indefinite carryforward","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any loss disallowed by reason of subparagraph (A) shall be treated as incurred by the REMIC in the succeeding calendar quarter with respect to such holder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe0a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860C/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For special treatment of income in excess of daily accruals, see section 860E.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id443bbe0b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s671/a"},"text":"Pub. L. 99–514, title VI, § 671(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2309"},"text":"100 Stat. 2309","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/t/1"},"text":"Pub. L. 100–647, title I, § 1006(t)(1)","children":[],"tail":", (8)(C), (21), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3419"},"text":"102 Stat. 3419","children":[],"tail":", 3421, 3426.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id443bbe0c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id443bbe0d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id443bbe0e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/21"},"text":"Pub. L. 100–647, § 1006(t)(21)","children":[],"tail":", substituted “and, except as provided in regulations, in the same manner” for “and in the same manner” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/8/C"},"text":"Pub. L. 100–647, § 1006(t)(8)(C)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/1"},"text":"Pub. L. 100–647, § 1006(t)(1)","children":[],"tail":", substituted “ordinary” for “ordinary income” in heading and amended text generally. Prior to amendment, text read as follows: “Any amount included in the gross income of any holder of a residual interest in a REMIC by reason of subsection (a) shall be treated as ordinary income.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id443bbe0f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id443bbe10-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
