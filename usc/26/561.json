{"tag":"section","attrib":{"id":"id43d5347b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s561"},"text":null,"children":[{"tag":"num","attrib":{"value":"561"},"text":"§ 561.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of deduction for dividends paid","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43d5347c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s561/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The deduction for dividends paid shall be the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43d5347d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s561/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dividends paid during the taxable year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43d5347e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s561/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consent dividends for the taxable year (determined under section 565), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43d5347f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s561/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a personal holding company, the dividend carryover described in section 564.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43d53480-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s561/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the deduction for dividends paid, the rules provided in section 562 (relating to rules applicable in determining dividends eligible for dividends paid deduction) and section 563 (relating to dividends paid after the close of the taxable year) shall be applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43d53481-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/198"},"text":"68A Stat. 198","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/403/s3/f"},"text":"Pub. L. 87–403, § 3(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-02-02"},"text":"Feb. 2, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/8"},"text":"76 Stat. 8","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1901/b/32/H"},"text":"Pub. L. 94–455, title XIX, § 1901(b)(32)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1800"},"text":"90 Stat. 1800","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43d53482-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43d53483-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43d53484-3