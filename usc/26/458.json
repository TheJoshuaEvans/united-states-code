{"tag":"section","attrib":{"id":"id4388e882-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458"},"text":null,"children":[{"tag":"num","attrib":{"value":"458"},"text":"§ 458.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Magazines, paperbacks, and records returned after the close of the taxable year","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4388e883-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion from gross income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A taxpayer who is on an accrual method of accounting may elect not to include in the gross income for the taxable year the income attributable to the qualified sale of any magazine, paperback, or record which is returned to the taxpayer before the close of the merchandise return period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4388e884-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4388e885-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Magazine","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “magazine” includes any other periodical.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4388e886-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Paperback","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “paperback” means any book which has a flexible outer cover and the pages of which are affixed directly to such outer cover. Such term does not include a magazine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4388e887-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “record” means a disc, tape, or similar object on which musical, spoken, or other sounds are recorded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4388e888-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate application with respect to magazines, paperbacks, and records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a taxpayer makes qualified sales of more than one category of merchandise in connection with the same trade or business, this section shall be applied as if the qualified sales of each such category were made in connection with a separate trade or business. For purposes of the preceding sentence, magazines, paperbacks, and records shall each be treated as a separate category of merchandise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4388e889-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified sale","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A sale of a magazine, paperback, or record is a qualified sale if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4388e88a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time of sale, the taxpayer has a legal obligation to adjust the sales price of such magazine, paperback, or record if it is not resold, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4388e88b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sales price of such magazine, paperback, or record is adjusted by the taxpayer because of a failure to resell it.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4388e88c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount excluded","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount excluded under this section with respect to any qualified sale shall be the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4388e88d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount covered by the legal obligation described in paragraph (5)(A), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4388e88e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the adjustment agreed to by the taxpayer before the close of the merchandise return period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4388e88f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merchandise return period","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4388e890-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subparagraph (B), the term “merchandise return period” means, with respect to any taxable year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4388e891-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of magazines, the period of 2 months and 15 days first occurring after the close of taxable year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4388e892-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of paperbacks and records, the period of 4 months and 15 days first occurring after the close of the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4388e893-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The taxpayer may select a shorter period than the applicable period set forth in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4388e894-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any change in the merchandise return period shall be treated as a change in the method of accounting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4388e895-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain evidence may be substituted for physical return of merchandise","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Secretary, the taxpayer may substitute, for the physical return of magazines, paperbacks, or records required by subsection (a), certification or other evidence that the magazine, paperback, or record has not been resold and will not be resold if such evidence—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4388e896-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the possession of the taxpayer at the close of the merchandise return period, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4388e897-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is satisfactory to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4388e898-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repurchase by the taxpayer not treated as resale","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A repurchase by the taxpayer shall be treated as an adjustment of the sales price rather than as a resale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4388e899-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified sales to which section applies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id438b599a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to qualified sales of magazines, paperbacks, or records, as the case may be, if and only if the taxpayer makes an election under this section with respect to the trade or business in connection with which such sales are made. An election under this section may be made without the consent of the Secretary. The election shall be made in such manner as the Secretary may by regulations prescribe and shall be made for any taxable year not later than the time prescribed by law for filing the return for such taxable year (including extensions thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id438b599b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election made under this section shall apply to all qualified sales of magazines, paperbacks, or records, as the case may be, made in connection with the trade or business with respect to which the taxpayer has made the election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id438b599c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period to which election applies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under this section shall be effective for the taxable year for which it is made and for all subsequent taxable years, unless the taxpayer secures the consent of the Secretary to the revocation of such election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id438b599d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as method of accounting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except to the extent inconsistent with the provisions of this section, for purposes of this subtitle, the computation of taxable income under an election made under this section shall be treated as a method of accounting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id438b599e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 5-year spread of transitional adjustments for magazines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying section 481(c) with respect to any election under this section which applies to magazines, the period for taking into account any decrease in taxable income resulting from the application of section 481(a)(2) shall be the taxable year for which the election is made and the 4 succeeding taxable years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id438b599f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspense account for paperbacks and records","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id438b59a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any election under this section which applies to paperbacks or records, in lieu of applying section 481, the taxpayer shall establish a suspense account for the trade or business for the taxable year for which the election is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id438b59a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial opening balance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The opening balance of the account described in paragraph (1) for the first taxable year to which the election applies shall be the largest dollar amount of returned merchandise which would have been taken into account under this section for any of the 3 immediately preceding taxable years if this section had applied to such preceding 3 taxable years. This paragraph and paragraph (3) shall be applied by taking into account only amounts attributable to the trade or business for which such account is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id438b59a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments in suspense account","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the close of each taxable year the suspense account shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id438b59a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reduced the excess (if any) of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id438b59a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the opening balance of the suspense account for the taxable year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id438b59a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount excluded from gross income for the taxable year under subsection (a), or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id438b59a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" increased (but not in excess of the initial opening balance) by the excess (if any) of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id438b59a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount excluded from gross income for the taxable year under subsection (a), over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id438b59a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the opening balance of the account for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id438b59a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gross income adjustments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id438b59aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reductions excluded from gross income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any reduction under paragraph (3)(A) in the account for the taxable year, an amount equal to such reduction shall be excluded from gross income for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id438b59ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increases added to gross income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any increase under paragraph (3)(B) in the account for the taxable year, an amount equal to such increase shall be included in gross income for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If the initial opening balance exceeds the dollar amount of returned merchandise which would have been taken into account under subsection (a) for the taxable year preceding the first taxable year for which the election is effective if this section had applied to such preceding taxable year, then an amount equal to the amount of such excess shall be included in gross income for such first taxable year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id438b59ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s458/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subchapter C transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The application of this subsection with respect to a taxpayer which is a party to any transaction with respect to which there is nonrecognition of gain or loss to any party to the transaction by reason of subchapter C shall be determined under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id438b59ad-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/tIII/s372/a"},"text":"Pub. L. 95–600, title III, § 372(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2860"},"text":"92 Stat. 2860","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/114"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(114)","children":[],"tail":", (115), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1189"},"text":"132 Stat. 1189","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id438b59ae-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id438b59af-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id438b59b0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/114"},"text":"Pub. L. 115–141, § 401(a)(114)","children":[],"tail":", substituted “Repurchase” for “Repurchased” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/115"},"text":"Pub. L. 115–141, § 401(a)(115)","children":[],"tail":", substituted “regulations prescribe” for “regulations prescribed”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id438b59b1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id438b59b2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/tIII/s372/c"},"text":"Pub. L. 95–600, title III, § 372(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2862"},"text":"92 Stat. 2862","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/600/tIII/s372/c"},"text":"“The amendments made by this section [enacting this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
