{"tag":"section","attrib":{"id":"id41006910-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B"},"text":null,"children":[{"tag":"num","attrib":{"value":"48B"},"text":"§ 48B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying gasification project credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id41006911-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 46, the qualifying gasification project credit for any taxable year is an amount equal to 20 percent (30 percent in the case of credits allocated under subsection (d)(1)(B)) of the qualified investment for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41006912-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified investment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41006913-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the qualified investment for any taxable year is the basis of eligible property placed in service by the taxpayer during such taxable year which is part of a qualifying gasification project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41006914-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id41006915-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction, reconstruction, or erection of which is completed by the taxpayer, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id41006916-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is acquired by the taxpayer if the original use of such property commences with the taxpayer, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41006917-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which depreciation (or amortization in lieu of depreciation) is allowable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41006918-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for certain subsidized property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to section 48(a)(4) (without regard to subparagraph (D) thereof) shall apply for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41006919-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain qualified progress expenditures rules made applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of subsections (c)(4) and (d) of section 46 (as in effect on the day before the enactment of the Revenue Reconciliation Act of 1990) shall apply for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4102b30a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4102b30b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying gasification project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualifying gasification project” means any project which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4102b30c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employs gasification technology,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b30d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be carried out by an eligible entity, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b30e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any portion of the qualified investment of which is certified under the qualifying gasification program as eligible for credit under this section in an amount (not to exceed $650,000,000) determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4102b30f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gasification technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “gasification technology” means any process which converts a solid or liquid product from coal, petroleum residue, biomass, or other materials which are recovered for their energy or feedstock value into a synthesis gas composed primarily of carbon monoxide and hydrogen for direct use or subsequent chemical or physical conversion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4102b310-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible property” means any property which is a part of a qualifying gasification project and is necessary for the gasification technology of such project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4102b311-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biomass","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4102b312-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “biomass” means any—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4102b313-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural or plant waste,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4102b314-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" byproduct of wood or paper mill operations, including lignin in spent pulping liquors, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4102b315-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other products of forestry maintenance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b316-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “biomass” does not include paper which is commonly recycled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4102b317-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carbon capture capability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “carbon capture capability” means a gasification plant design which is determined by the Secretary to reflect reasonable consideration for, and be capable of, accommodating the equipment likely to be necessary to capture carbon dioxide from the gaseous stream, for later use or sequestration, which would otherwise be emitted in the flue gas from a project which uses a nonrenewable fuel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4102b318-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “coal” means anthracite, bituminous coal, subbituminous coal, lignite, and peat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4102b319-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means any person whose application for certification is principally intended for use in a domestic project which employs domestic gasification applications related to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4102b31a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chemicals,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b31b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fertilizers,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b31c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" glass,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b31d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" steel,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b31e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" petroleum residues,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b31f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/7/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forest products,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b320-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/7/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agriculture, including feedlots and dairy operations, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b321-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/7/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation grade liquid fuels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4102b322-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petroleum residue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “petroleum residue” means the carbonized product of high-boiling hydrocarbon fractions obtained in petroleum processing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4102b323-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying gasification project program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4102b324-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of the enactment of this section, the Secretary, in consultation with the Secretary of Energy, shall establish a qualifying gasification project program to consider and award certifications for qualified investment eligible for credits under this section to qualifying gasification project sponsors under this section. The total amounts of credit that may be allocated under the program shall not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4102b325-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $350,000,000, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b326-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250,000,000 for qualifying gasification projects that include equipment which separates and sequesters at least 75 percent of such project’s total carbon dioxide emissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4102b327-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A certificate of eligibility under paragraph (1) may be issued only during the 10-fiscal year period beginning on ","children":[{"tag":"date","attrib":{"date":"2005-10-01"},"text":"October 1, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4102b328-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not make a competitive certification award for qualified investment for credit eligibility under this section unless the recipient has documented to the satisfaction of the Secretary that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4102b329-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the award recipient is financially viable without the receipt of additional Federal funding associated with the proposed project,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b32a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient will provide sufficient information to the Secretary for the Secretary to ensure that the qualified investment is spent efficiently and effectively,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b32b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a market exists for the products of the proposed project as evidenced by contracts or written statements of intent from potential customers,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b32c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fuels identified with respect to the gasification technology for such project will comprise at least 90 percent of the fuels required by the project for the production of chemical feedstocks, liquid transportation fuels, or coproduction of electricity,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b32d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the award recipient’s project team is competent in the construction and operation of the gasification technology proposed, with preference given to those recipients with experience which demonstrates successful and reliable operations of the technology on domestic fuels so identified, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b32e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the award recipient has met other criteria established and published by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4102b32f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining which qualifying gasification projects to certify under this section, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4102b330-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give highest priority to projects with the greatest separation and sequestration percentage of total carbon dioxide emissions, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b331-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give high priority to applicant participants who have a research partnership with an eligible educational institution (as defined in section 529(e)(5)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4102b332-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of double benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A credit shall not be allowed under this section for any qualified investment for which a credit is allowed under section 48A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4102b333-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48B/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recapture of credit for failure to sequester","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for recapturing the benefit of any credit allowable under subsection (a) with respect to any project which fails to attain or maintain the separation and sequestration requirements for such project under subsection (d)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4102b334-3a70-11f1-a967-d