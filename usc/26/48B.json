","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (d)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4102b338-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":" inserted “(without regard to subparagraph (D) thereof)” after “section 48(a)(4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/s112/a"},"text":"Pub. L. 110–343, § 112(a)","children":[],"tail":", inserted “(30 percent in the case of credits allocated under subsection (d)(1)(B))” after “20 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(7)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/s112/e"},"text":"Pub. L. 110–343, § 112(e)","children":[],"tail":", added subpar. (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/s112/b"},"text":"Pub. L. 110–343, § 112(b)","children":[],"tail":", substituted “shall not exceed—” for “shall not exceed $350,000,000 under rules similar to the rules of section 48A(d)(4).” and added subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/s112/d"},"text":"Pub. L. 110–343, § 112(d)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p