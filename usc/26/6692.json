{"tag":"section","attrib":{"id":"id472d38b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6692"},"text":null,"children":[{"tag":"num","attrib":{"value":"6692"},"text":"§ 6692.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to file actuarial report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The plan administrator (as defined in section 414(g)) of each defined benefit plan to which section 412 applies who fails to file the report required by section 6059 at the time and in the manner required by section 6059, shall pay a penalty of $1,000 for each such failure unless it is shown that such failure is due to reasonable cause.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id472d38b7-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tII/s1033/b"},"text":"Pub. L. 93–406, title II, § 1033(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/948"},"text":"88 Stat. 948","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id472d38b8-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id472d38b9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id472d38ba-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/406/s1034"},"text":"section 1034 of Pub. L. 93–406","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6057"},"text":"section 6057 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
