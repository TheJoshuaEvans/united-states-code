{"tag":"section","attrib":{"id":"id45d856bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4472"},"text":null,"children":[{"tag":"num","attrib":{"value":"4472"},"text":"§ 4472.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d856be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4472/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered voyage","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45d856bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4472/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered voyage” means a voyage of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45d856c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4472/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commercial passenger vessel which extends over 1 or more nights, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45d856c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4472/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commercial vessel transporting passengers engaged in gambling aboard the vessel beyond the territorial waters of the United States,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"during which passengers embark or disembark the vessel in the United States. Such term shall not include any voyage on any vessel owned or operated by the United States, a State, or any agency or subdivision thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d856c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4472/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain voyages on passenger vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered voyage” shall not include a voyage of a passenger vessel of less than 12 hours between 2 ports in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d856c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4472/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Passenger vessel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “passenger vessel” means any vessel having berth or stateroom accommodations for more than 16 passengers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d856c4-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7504/a"},"text":"Pub. L. 101–239, title VII, § 7504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2362"},"text":"103 Stat. 2362","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45d856c5-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45d856c6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id45d856c7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4472 was contained in subchapter C of this chapter prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/tIV/s404"},"text":"Pub. L. 89–44, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/149"},"text":"79 Stat. 149","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
