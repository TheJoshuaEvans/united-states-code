{"tag":"section","attrib":{"id":"id417ec126-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138"},"text":null,"children":[{"tag":"num","attrib":{"value":"138"},"text":"§ 138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medicare Advantage MSA","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id417ec127-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross income shall not include any payment to the Medicare Advantage MSA of an individual by the Secretary of Health and Human Services under part C of title XVIII of the Social Security Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417ec128-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medicare Advantage MSA","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “Medicare Advantage MSA” means an Archer MSA (as defined in section 220(d))—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id417ec129-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is designated as a Medicare Advantage MSA,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec12a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to which no contribution may be made other than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id417ec12b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contribution made by the Secretary of Health and Human Services pursuant to part C of title XVIII of the Social Security Act, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417ec12c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trustee-to-trustee transfer described in subsection (c)(4),","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec12d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the governing instrument of which provides that trustee-to-trustee transfers described in subsection (c)(4) may be made to and from such account, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec12e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is established in connection with an MSA plan described in section 1859(b)(3) of the Social Security Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417ec12f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for distributions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id417ec130-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions for qualified medical expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In applying section 220 to a Medicare Advantage MSA—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id417ec131-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualified medical expenses shall not include amounts paid for medical care for any individual other than the account holder, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417ec132-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 220(d)(2)(C) shall not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec133-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for distributions from Medicare Advantage MSA not used for qualified medical expenses if minimum balance not maintained","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id417ec134-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The tax imposed by this chapter for any taxable year in which there is a payment or distribution from a Medicare Advantage MSA which is not used exclusively to pay the qualified medical expenses of the account holder shall be increased by 50 percent of the excess (if any) of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id417ec135-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such payment or distribution, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id417ec136-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the excess (if any) of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id417ec137-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/c/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of the assets in such MSA as of the close of the calendar year preceding the calendar year in which the taxable year begins, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id417ec138-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/c/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 60 percent of the deductible under the Medicare Advantage MSA plan covering the account holder as of January 1 of the calendar year in which the taxable year begins.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Section 220(f)(4) shall not apply to any payment or distribution from a Medicare Advantage MSA.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417ec139-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraph (A) shall not apply if the payment or distribution is made on or after the date the account holder—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id417ec13a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" becomes disabled within the meaning of section 72(m)(7), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id417ec13b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417ec13c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id417ec13d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all Medicare Advantage MSAs of the account holder shall be treated as 1 account,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id417ec13e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all payments and distributions not used exclusively to pay the qualified medical expenses of the account holder during any taxable year shall be treated as 1 distribution, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id417ec13f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any distribution of property shall be taken into account at its fair market value on the date of the distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec140-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal of erroneous contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 220(f)(2) and paragraph (2) of this subsection shall not apply to any payment or distribution from a Medicare Advantage MSA to the Secretary of Health and Human Services of an erroneous contribution to such MSA and of the net income attributable to such contribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec141-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trustee-to-trustee transfers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 220(f)(2) and paragraph (2) of this subsection shall not apply to any trustee-to-trustee transfer from a Medicare Advantage MSA of an account holder to another Medicare Advantage MSA of such account holder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417ec142-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for treatment of account after death of account holder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying section 220(f)(8)(A) to an account which was a Medicare Advantage MSA of a decedent, the rules of section 220(f) shall apply in lieu of the rules of subsection (c) of this section with respect to the spouse as the account holder of such Medicare Advantage MSA.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417ec143-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a Medicare Advantage MSA, the report under section 220(h)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id417ec144-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include the fair market value of the assets in such Medicare Advantage MSA as of the close of each calendar year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec145-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be furnished to the account holder—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id417ec146-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than January 31 of the calendar year following the calendar year to which such reports relate, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417ec147-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in such manner as the Secretary prescribes in such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417ec148-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s138/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with limitation on number of taxpayers having Archer MSAs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (i) of section 220 shall not apply to an individual with respect to a Medicare Advantage MSA, and Medicare Advantage MSAs shall not be taken into account in determining whether the numerical limitations under section 220(j) are exceeded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id417ec149-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIV/s4006/a"},"text":"Pub. L. 105–33, title IV, § 4006(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/332"},"text":"111 Stat. 332","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tII/s202/a/3"},"text":"Pub. L. 106–554, § 1(a)(7) [title II, § 202(a)(3), (b)(6), (10)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–628, 2763A–629; "},{"tag":"ref","attrib":{"href":"/us/pl/108/311/tIV/s408/a/5/A"},"text":"Pub. L. 108–311, title IV, § 408(a)(5)(A)","children":[],"tail":"–(F), "},{"tag":"date","attrib":{"date":"2004-10-04"},"text":"Oct. 4, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1191"},"text":"118 Stat. 1191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id417ec14a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id417ec14b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id417ec14c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsecs. (a) and (b)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Part C of title XVIII of the Act is classified generally to part C (§ 1395w–21 et seq.) of subchapter XVIII of chapter 7 of Title 42, The Public Health and Welfare. Section 1859 of the Act is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–28"},"text":"section 1395w–28 of Title 42","children":[],"tail":". For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id417ec14d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 138 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s140"},"text":"section 140 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id417ec14e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311/s408/a/5/A"},"text":"Pub. L. 108–311, § 408(a)(5)(A)","children":[],"tail":"–(D), substituted “Medicare Advantage” for “Medicare+Choice” wherever appearing in section catchline, headings, and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311/s408/a/5/E"},"text":"Pub. L. 108–311, § 408(a)(5)(E)","children":[],"tail":", substituted “Medicare Advantage MSAs” for “Medicare+Choice MSAs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311/s408/a/5/F"},"text":"Pub. L. 108–311, § 408(a)(5)(F)","children":[],"tail":", substituted “Medicare Advantage MSAs” for “Medicare+Choice MSA’s”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tII/s202/b/10"},"text":"Pub. L. 106–554, § 1(a)(7) [title II, § 202(b)(10)]","children":[],"tail":", substituted “an Archer MSA” for “a Archer MSA” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tII/s202/a/3"},"text":"Pub. L. 106–554, § 1(a)(7) [title II, § 202(a)(3)]","children":[],"tail":", substituted “Archer MSA” for “medical savings account” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tII/s202/b/6"},"text":"Pub. L. 106–554, § 1(a)(7) [title II, § 202(b)(6)]","children":[],"tail":", substituted “Archer MSAs” for “medical savings accounts” in heading."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id417ec14f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id417ec150-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIV/s4006/c"},"text":"Pub. L. 105–33, title IV, § 4006(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/334"},"text":"111 Stat. 334","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/33/tIV/s4006/c"},"text":"“The amendments made by this section [enacting this section, amending sections 220 and 4973 of this title, and renumbering former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s138"},"text":"section 138 of this title","children":[],"tail":" as "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s139"},"text":"section 139 of this title","children":[],"tail":"] shall apply to taxable years beginning after "},{"tag":"date","attrib":{"date":"1998-12-31"},"text":"December 31, 1998","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
