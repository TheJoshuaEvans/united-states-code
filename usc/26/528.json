{"tag":"section","attrib":{"id":"id43c220f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528"},"text":null,"children":[{"tag":"num","attrib":{"value":"528"},"text":"§ 528.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain homeowners associations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43c220f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A homeowners association (as defined in subsection (c)) shall be subject to taxation under this subtitle only to the extent provided in this section. A homeowners association shall be considered an organization exempt from income taxes for the purpose of any law which refers to organizations exempt from income taxes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43c220f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax imposed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A tax is hereby imposed for each taxable year on the homeowners association taxable income of every homeowners association. Such tax shall be equal to 30 percent of the homeowners association taxable income (32 percent of such income in the case of a timeshare association).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43c220fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homeowners association defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43c220fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homeowners association","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “homeowners association” means an organization which is a condominium management association, a residential real estate management association, or a timeshare association if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43c220fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such organization is organized and operated to provide for the acquisition, construction, management, maintenance, and care of association property,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43c220fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 60 percent or more of the gross income of such organization for the taxable year consists solely of amounts received as membership dues, fees, or assessments from—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43c220fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owners of residential units in the case of a condominium management association,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43c220ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owners of residences or residential lots in the case of a residential real estate management association, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43c22100-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owners of timeshare rights to use, or timeshare ownership interests in, association property in the case of a timeshare association,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43c22101-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 percent or more of the expenditures of the organization for the taxable year are expenditures for the acquisition, construction, management, maintenance, and care of association property and, in the case of a timeshare association, for activities provided to or on behalf of members of the association,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43c22102-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no part of the net earnings of such organization inures (other than by acquiring, constructing, or providing management, maintenance, and care of association property, and other than by a rebate of excess membership dues, fees, or assessments) to the benefit of any private shareholder or individual, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43c22103-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such organization elects (at such time and in such manner as the Secretary by regulations prescribes) to have this section apply for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43c22104-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condominium management association","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “condominium management association” means any organization meeting the requirement of subparagraph (A) of paragraph (1) with respect to a condominium proj­ect substantially all of the units of which are used by individuals for residences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43c22105-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residential real estate management association","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “residential real estate management association” means any organization meeting the requirements of subparagraph (A) of paragraph (1) with respect to a subdivision, development, or similar area substantially all the lots or buildings of which may only be used by individuals for residences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43c22106-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timeshare association","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “timeshare association” means any organization (other than a condominium management association) meeting the requirement of subparagraph (A) of paragraph (1) if any member thereof holds a timeshare right to use, or a timeshare ownership interest in, real property constituting association property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43c22107-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Association property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “association property” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43c22108-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property held by the organization,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43c22109-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property commonly held by the members of the organization,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43c2210a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property within the organization privately held by the members of the organization, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43c2210b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property owned by a governmental unit and used for the benefit of residents of such unit.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In the case of a timeshare association, such term includes property in which the timeshare association, or members of the association, have rights arising out of recorded easements, covenants, or other recorded instruments to use property related to the timeshare project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43c2210c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homeowners association taxable income defined","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43c2210d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable income defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the homeowners association taxable income of any organization for any taxable year is an amount equal to the excess (if any) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43c2210e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross income for the taxable year (excluding any exempt function income), over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43c2210f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deductions allowed by this chapter which are directly connected with the production of the gross income (excluding exempt function income), computed with the modifications provided in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43c22110-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43c22111-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there shall be allowed a specific deduction of $100,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43c22112-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no net operating loss deduction shall be allowed under section 172, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43c22113-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no deduction shall be allowed under part VIII of subchapter B (relating to special deductions for corporations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43c22114-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempt function income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “exempt function income” means any amount received as membership dues, fees, or assessments from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43c22115-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owners of condominium housing units in the case of a condominium management association,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43c22116-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owners of real property in the case of a residential real estate management association, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43c22117-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s528/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owners of timeshare rights to use, or timeshare ownership interests in, real property in the case of a timeshare association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43c22118-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXXI/s2101/a"},"text":"Pub. L. 94–455, title XXI, § 2101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1897"},"text":"90 Stat. 1897","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tIII/s301/b/7"},"text":"Pub. L. 95–600, title III, § 301(b)(7)","children":[],"tail":", title IV, § 403(c)(2), title VII, § 701(n)(1), "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2821"},"text":"92 Stat. 2821","children":[],"tail":", 2868, 2907; "},{"tag":"ref","attrib":{"href":"/us/pl/96/605/tI/s105/a"},"text":"Pub. L. 96–605, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3523"},"text":"94 Stat. 3523","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tIX/s966/a"},"text":"Pub. L. 105–34, title IX, § 966(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/894"},"text":"111 Stat. 894","children":[],"tail":", 895.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43c22119-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43c2211a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43c2211b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s966/d"},"text":"Pub. L. 105–34, § 966(d)","children":[],"tail":", which directed amendment of subsec. (b) by inserting before the period “(32 percent of such income in the case of a timeshare association)”, was executed by making the insertion before the period at end to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s966/a/1/A"},"text":"Pub. L. 105–34, § 966(a)(1)(A)","children":[],"tail":", substituted “, a residential real estate management association, or a timeshare association” for “or a residential real estate management association” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s966/a/1/B"},"text":"Pub. L. 105–34, § 966(a)(1)(B)","children":[],"tail":", added cl. (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s966/a/1/C"},"text":"Pub. L. 105–34, § 966(a)(1)(C)","children":[],"tail":", inserted before comma at end “and, in the case of a timeshare association, for activities provided to or on behalf of members of the association”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s966/a/2"},"text":"Pub. L. 105–34, § 966(a)(2)","children":[],"tail":", added par. (4). Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s966/c"},"text":"Pub. L. 105–34, § 966(c)","children":[],"tail":", inserted concluding provisions “In the case of a timeshare association, such term includes property in which the timeshare association, or members of the association, have rights arising out of recorded easements, covenants, or other recorded instruments to use property related to the timeshare project.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s966/a/2"},"text":"Pub. L. 105–34, § 966(a)(2)","children":[],"tail":", redesignated par. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s966/b"},"text":"Pub. L. 105–34, § 966(b)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/605"},"text":"Pub. L. 96–605","children":[],"tail":" substituted provision that all income of a homeowners association be taxed at a rate of 30 per cent for provision that all income of a homeowners association be taxed a sum computed by multiplying the homeowners association taxable income by the highest rate of tax specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s11/b"},"text":"section 11(b) of this title","children":[],"tail":" and struck out provision providing for alternative tax in case of capital gains."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s301/b/7"},"text":"Pub. L. 95–600, § 301(b)(7)","children":[],"tail":", substituted “Such tax shall be computed by multiplying the homeowners association taxable income by the highest rate of tax specified in section 11(b)” for “Such tax shall consist of a normal tax and a surtax computed as provided in section 11 as though the homeowners association were a corporation and as though the homeowners association taxable income were the taxable income referred to in section 11” and struck out provision that for purposes of this subsection, the surtax exemption provided by section 11(d) not be allowed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s403/c/2"},"text":"Pub. L. 95–600, § 403(c)(2)","children":[],"tail":", substituted provision related to amount being determined according to section 1201(a) for provision requiring an amount of 30 percent."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s701/n/1"},"text":"Pub. L. 95–600, § 701(n)(1)","children":[],"tail":", substituted “by individuals for residences” for “as residences”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43c2211c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43c2211d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tIX/s966/e"},"text":"Pub. L. 105–34, title IX, § 966(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/895"},"text":"111 Stat. 895","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tIX/s966/e"},"text":"“The amendments made by this section [amending this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1996-12-31"},"text":"December 31, 1996","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43c2211e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{