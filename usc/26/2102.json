{"tag":"section","attrib":{"id":"id4538949e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2102"},"text":null,"children":[{"tag":"num","attrib":{"value":"2102"},"text":"§ 2102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits against tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4538949f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by section 2101 shall be credited with the amounts determined in accordance with sections 2012 and 2013 (relating to gift tax and tax on prior transfers).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453894a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unified credit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id453894a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A credit of $13,000 shall be allowed against the tax imposed by section 2101.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453894a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residents of possessions of the United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a decedent who is considered to be a “nonresident not a citizen of the United States” under section 2209, the credit under this subsection shall be the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id453894a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2102/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $13,000, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id453894a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2102/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that proportion of $46,800 which the value of that part of the decedent’s gross estate which at the time of his death is situated in the United States bears to the value of his entire gross estate wherever situated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453894a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2102/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id453894a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2102/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with treaties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent required under any treaty obligation of the United States, the credit allowed under this subsection shall be equal to the amount which bears the same ratio to the applicable credit amount in effect under section 2010(c) for the calendar year which includes the date of death as the value of the part of the decedent’s gross estate which at the time of his death is situated in the United States bears to the value of his entire gross estate wherever situated. For purposes of the preceding sentence, property shall not be treated as situated in the United States if such property is exempt from the tax imposed by this subchapter under any treaty obligation of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id453894a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2102/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with gift tax unified credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a credit has been allowed under section 2505 with respect to any gift made by the decedent, each dollar amount contained in paragraph (1) or (2) or subparagraph (A) of this paragraph (whichever applies) shall be reduced by the amount so allowed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453894a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2102/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation based on amount of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The credit allowed under this subsection shall not exceed the amount of the tax imposed by section 2101.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453894a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2102/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of other credits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), sections 2012 and 2013 shall be applied as if the credit allowed under this subsection were allowed under section 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id453894aa-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/397"},"text":"68A Stat. 397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/tI/s108/b"},"text":"Pub. L. 89–809, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1572"},"text":"80 Stat. 1572","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2001/c/1/E/i"},"text":"Pub. L. 94–455, title XX, § 2001(c)(1)(E)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1851"},"text":"90 Stat. 1851","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tV/s5032/b"},"text":"Pub. L. 100–647, title V, § 5032(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3669"},"text":"102 Stat. 3669","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1704/f/1"},"text":"Pub. L. 104–188, title I, § 1704(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1879"},"text":"110 Stat. 1879","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tV/s501/a/1/E"},"text":"Pub. L. 105–34, title V, § 501(a)(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/845"},"text":"111 Stat. 845","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tV/s532/c/7"},"text":"Pub. L. 107–16, title V, § 532(c)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/75"},"text":"115 Stat. 75","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id453894ab-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id453894ac-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id453894ad-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s532/c/7/A"},"text":"Pub. L. 107–16, § 532(c)(7)(A)","children":[],"tail":", reenacted heading without change and amended text of subsec. (a) generally. Prior to amendment, text read as follows: “The tax imposed by section 2101 shall be credited with the amounts determined in accordance with sections 2011 to 2013, inclusive (relating to State death taxes, gift tax, and tax on prior transfers), subject to the special limitation provided in subsection (b).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s532/c/7/B"},"text":"Pub. L. 107–16, § 532(c)(7)(B)","children":[],"tail":", redesignated subsec. (c) as (b) and struck out heading and text of former subsec. (b). Text read as follows: “The maximum credit allowed under section 2011 against the tax imposed by section 2101 for State death taxes paid shall be an amount which bears the same ratio to the credit computed as provided in section 2011(b) as the value of the property, as determined for purposes of this chapter, upon which State death taxes were paid and which is included in the gross estate under section 2103 bears to the value of the total gross estate under section 2103. For purposes of this subsection, the term ‘State death taxes’ means the taxes described in section 2011(a).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s532/c/7/C"},"text":"Pub. L. 107–16, § 532(c)(7)(C)","children":[],"tail":", substituted “2012 and 2013” for “2011 to 2013, inclusive,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s532/c/7/B"},"text":"Pub. L. 107–16, § 532(c)(7)(B)","children":[],"tail":", redesignated subsec. (c) as (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" substituted “the applicable credit amount in effect under section 2010(c) for the calendar year which includes the date of death” for “$192,800”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" inserted at end “For purposes of the preceding sentence, property shall not be treated as situated in the United States if such property is exempt from the tax imposed by this subchapter under any treaty obligation of the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s5032/b/1/A"},"text":"Pub. L. 100–647, § 5032(b)(1)(A)","children":[],"tail":", substituted “$13,000” for “$3,600”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s5032/b/1"},"text":"Pub. L. 100–647, § 5032(b)(1)","children":[],"tail":", substituted “$13,000” for “$3,600” in subpar. (A) and “$46,800” for “$15,075” in subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s5032/b/2"},"text":"Pub. L. 100–647, § 5032(b)(2)","children":[],"tail":", amended par. (3) generally, substituting provision relating to special rules for coordination with treaties and with gift tax unified tax credit for provision relating to a phase-in of the par. (2)(B) amount for decedents dying during 1977, 1978, 1979, and 1980."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809"},"text":"Pub. L. 89–809","children":[],"tail":" redesignated existing provisions as subsec. (a), inserted reference to special limitation provided in subsec. (b), and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id453894ae-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id453894af-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"