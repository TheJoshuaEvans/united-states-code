{"tag":"section","attrib":{"id":"id4626ebd8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5067"},"text":null,"children":[{"tag":"num","attrib":{"value":"5067"},"text":"§ 5067.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduced rates not allowed for smuggled or illegally produced beer, wine, or spirits","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In the case of beer, wine, or distilled spirits that are smuggled into the United States or produced other than as authorized by this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4626ebd9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5067/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rates of tax under paragraphs (1)(A)(i) and (2) of section 5051(a) shall not apply in the case of any such beer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4626ebda-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5067/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the credit under section 5041(c) shall not apply in the case of any such wine, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4626ebdb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5067/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rates of tax under section 5001(c) shall not apply in the case of any such distilled spirits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4626ebdc-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/tI/s108/a"},"text":"Pub. L. 116–260, div. EE, title I, § 108(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3049"},"text":"134 Stat. 3049","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4626ebdd-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4626ebde-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4626ebdf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5067 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s5068"},"text":"section 5068 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4626ebe0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4626ebe1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/tI/s108/c"},"text":"Pub. L. 116–260, div. EE, title I, § 108(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3049"},"text":"134 Stat. 3049","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"ori