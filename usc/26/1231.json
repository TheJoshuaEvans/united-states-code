xt":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/332"},"text":"95 Stat. 332","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s176/a"},"text":"Pub. L. 98–369, div. A, title I, § 176(a)","children":[],"tail":", title VII, § 711(c)(2)(A)(iii), title X, § 1001(b)(15), (e), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/709"},"text":"98 Stat. 709","children":[],"tail":", 944, 1012; "},{"tag":"ref","attrib":{"href":"/us/pl/106/170/tV/s532/c/1/G"},"text":"Pub. L. 106–170, title V, § 532(c)(1)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-17"},"text":"Dec. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1930"},"text":"113 Stat. 1930","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/81"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(81)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4049"},"text":"128 Stat. 4049","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13314/b"},"text":"Pub. L. 115–97, title I, § 13314(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2133"},"text":"131 Stat. 2133","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44bef826-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44bef827-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44bef828-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" inserted “a patent, invention, model or design (whether or not patented), a secret formula or process,” before “a copyright”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" struck out “beginning after "},{"tag":"date","attrib":{"date":"1981-12-31"},"text":"December 31, 1981","children":[],"tail":"” after “years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(1)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/170"},"text":"Pub. L. 106–170","children":[],"tail":" substituted “section 1221(a)” for “section 1221”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1001/b/15"},"text":"Pub. L. 98–369, § 1001(b)(15)","children":[],"tail":", (e), substituted “6 months” for “1 year” wherever appearing, applicable to property acquired after "},{"tag":"date","attrib":{"date":"1984-06-22"},"text":"June 22, 1984","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1988-01-01"},"text":"Jan. 1, 1988","children":[],"tail":". See Effective Date of 1984 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s711/c/2/A/iii"},"text":"Pub. L. 98–369, § 711(c)(2)(A)(iii)","children":[],"tail":", amended subsec. (a) generally, substituting pars. (1) to (4), for “If, during the taxable year, the recognized gains on sales or exchanges of property used in the trade or business, plus the recognized gains from the compulsory or involuntary conversion (as a result of destruction in whole or in part, theft or seizure, or an exercise of the power of requisition or condemnation or the threat or imminence thereof) of property used in the trade or business and capital assets held for more than 1 year into other property or money, exceed the recognized losses from such sales, exchanges, and conversions, such gains and losses shall be considered as gains and losses from sales or exchanges of capital assets held for more than 1 year. If such gains do not exceed such losses, such gains and losses shall not be considered as gains and losses from sales or exchanges of capital assets. For purposes of this subsection—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) in determining under this subsection whether gains exceed losses, the gains described therein shall be included only if and to the extent taken into account in computing gross income and the losses described therein shall be included only if and to the extent taken into account in computing taxable income, except that section 1211 shall not apply; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) losses (including losses not compensated for by insurance or otherwise) upon the destruction, in whole or in part, theft or seizure, or requisition or condemnation of (A) property used in the trade or business or (B) capital assets held for more than 1 year shall be considered losses from a compulsory or involuntary conversion.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the case of any involuntary conversion (subject to the provisions of this subsection but for this sentence) arising from fire, storm, shipwreck, or other casualty, or from theft, of any property used in the trade or business or of any capital asset held for more than 1 year, this subsection shall not apply to such conversion (whether resulting in gain or loss) if during the taxable year the recognized losses from such conversions exceed the recognized gains from such conversions.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1001/b/15"},"text":"Pub. L. 98–369, § 1001(b)(15)","children":[],"tail":", (e), substituted “6 months” for “1 year”, applicable to property acquired after "},{"tag":"date","attrib":{"date":"1984-06-22"},"text":"June 22, 1984","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1988-01-01"},"text":"Jan. 1, 1988","children":[],"tail":". See Effective Date of 1984 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s176/a"},"text":"Pub. L. 98–369, § 176(a)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" substituted “paragraph (5)” for “paragraph (6)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (b)(1), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1402/b/2"},"text":"Pub. L. 94–455, § 1402(b)(2)","children":[],"tail":", provided that “9 months” would be changed to “1 year” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1402/b/1/R"},"text":"Pub. L. 94–455, § 1402(b)(1)(R)","children":[],"tail":", provided that in subsecs. (a), first and last sentences, (a)(2), and (b)(1), (4), “6 months” would be changed to “9 months” for taxable years beginning in 1977."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/s516/b"},"text":"Pub. L. 91–172, § 516(b)","children":[],"tail":", provided that casualty (or theft) losses with respect to depreciable property and real estate used in trade or business and capital assets held for the production of income as well as personal assets are to be consolidated with casualty (or theft) gains with respect to this type of property and if the casualty losses exceed the casualty gains, the net loss is treated as an ordinary loss without regard to whether there may be noncasualty gains under this section, but, if the casualty gains exceed the casualty losses, the net gain is treated as a gain under this section and must be consolidated with other gains and losses under this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/s514/b/2"},"text":"Pub. L. 91–172, § 514(b)(2)","children":[],"tail":", inserted reference to a letter or memorandum."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/s212/b/1"},"text":"Pub. L. 91–172, § 212(b)(1)","children":[],"tail":", redesignated existing provisions as subpar. (B) and added subpar. (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272"},"text":"Pub. L. 88–272","children":[],"tail":" inserted reference to iron ore in text, and to domestic iron ore in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866"},"text":"Pub. L. 85–866","children":[],"tail":" inserted provision respecting casualty losses sustained upon certain uninsured property."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44c14219-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries"