{"tag":"section","attrib":{"id":"id44bef7f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231"},"text":null,"children":[{"tag":"num","attrib":{"value":"1231"},"text":"§ 1231.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property used in the trade or business and involuntary conversions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44bef7f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44bef7f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gains exceed losses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44bef7f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the section 1231 gains for any taxable year, exceed","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44bef7f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the section 1231 losses for such taxable year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such gains and losses shall be treated as long-term capital gains or long-term capital losses, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bef7fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gains do not exceed losses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44bef7fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the section 1231 gains for any taxable year, do not exceed","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44bef7fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the section 1231 losses for such taxable year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such gains and losses shall not be treated as gains and losses from sales or exchanges of capital assets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bef7fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 1231 gains and losses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44bef7fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 1231 gain","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “section 1231 gain” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44bef7ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recognized gain on the sale or exchange of property used in the trade or business, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44bef800-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any recognized gain from the compulsory or involuntary conversion (as a result of destruction in whole or in part, theft or seizure, or an exercise of the power of requisition or condemnation or the threat or imminence thereof) into other property or money of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id44bef801-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property used in the trade or business, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44bef802-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any capital asset which is held for more than 1 year and is held in connection with a trade or business or a transaction entered into for profit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44bef803-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 1231 loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “section 1231 loss” means any recognized loss from a sale or exchange or conversion described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bef804-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44bef805-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In determining under this subsection whether gains exceed losses—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44bef806-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the section 1231 gains shall be included only if and to the extent taken into account in computing gross income, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44bef807-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the section 1231 losses shall be included only if and to the extent taken into account in computing taxable income, except that section 1211 shall not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44bef808-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Losses (including losses not compensated for by insurance or otherwise) on the destruction, in whole or in part, theft or seizure, or requisition or condemnation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44bef809-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property used in the trade or business, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44bef80a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capital assets which are held for more than 1 year and are held in connection with a trade or business or a transaction entered into for profit,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be treated as losses from a compulsory or involuntary conversion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44bef80b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of any involuntary conversion (subject to the provisions of this subsection but for this sentence) arising from fire, storm, shipwreck, or other casualty, or from theft, of any—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44bef80c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property used in the trade or business, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44bef80d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/a/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any capital asset which is held for more than 1 year and is held in connection with a trade or business or a transaction entered into for profit,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"this subsection shall not apply to such conversion (whether resulting in gain or loss) if during the taxable year the recognized losses from such conversions exceed the recognized gains from such conversions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44bef80e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of property used in the trade or business","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44bef80f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “property used in the trade or business” means property used in the trade or business, of a character which is subject to the allowance for depreciation provided in section 167, held for more than 1 year, and real property used in the trade or business, held for more than 1 year, which is not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44bef810-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property of a kind which would properly be includible in the inventory of the taxpayer if on hand at the close of the taxable year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44bef811-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property held by the taxpayer primarily for sale to customers in the ordinary course of his trade or business,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44bef812-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a patent, invention, model or design (whether or not patented), a secret formula or process, a copyright, a literary, musical, or artistic composition, a letter or memorandum, or similar property, held by a taxpayer described in paragraph (3) of section 1221(a), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44bef813-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a publication of the United States Government (including the Congressional Record) which is received from the United States Government, or any agency thereof, other than by purchase at the price at which it is offered for sale to the public, and which is held by a taxpayer described in paragraph (5) of section 1221(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bef814-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timber, coal, or domestic iron ore","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such term includes timber, coal, and iron ore with respect to which section 631 applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bef815-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Livestock","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such term includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44bef816-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cattle and horses, regardless of age, held by the taxpayer for draft, breeding, dairy, or sporting purposes, and held by him for 24 months or more from the date of acquisition, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44bef817-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other livestock, regardless of age, held by the taxpayer for draft, breeding, dairy, or sporting purposes, and held by him for 12 months or more from the date of acquisition.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term does not include poultry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bef818-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unharvested crop","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an unharvested crop on land used in the trade or business and held for more than 1 year, if the crop and the land are sold or exchanged (or compulsorily or involuntarily converted) at the same time and to the same person, the crop shall be considered as “property used in the trade or business.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44bef819-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recapture of net ordinary losses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44bef81a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The net section 1231 gain for any taxable year shall be treated as ordinary income to the extent such gain does not exceed the non-recaptured net section 1231 losses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bef81b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-recaptured net section 1231 losses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “non-recaptured net section 1231 losses” means the excess of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44bef81c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of the net section 1231 losses for the 5 most recent preceding taxable years, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44bef81d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the portion of such losses taken into account under paragraph (1) for such preceding taxable years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bef81e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net section 1231 gain","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “net section 1231 gain” means the excess of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44bef81f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the section 1231 gains, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44bef820-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the section 1231 losses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bef821-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net section 1231 loss","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “net section 1231 loss” means the excess of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44bef822-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the section 1231 losses, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44bef823-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the section 1231 gains.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44bef824-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1231/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determining the amount of the net section 1231 gain or loss for any taxable year, the rules of paragraph (4) of subsection (a) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44bef825-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, c