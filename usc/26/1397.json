{"tag":"section","attrib":{"id":"id44ff5c63-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397"},"text":"§ 1397.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions and special rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44ff5c64-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subpart—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ff5c65-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wages” has the same meaning as when used in section 51.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5c66-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain training and educational benefits","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ff5c67-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following amounts shall be treated as wages paid to an employee:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44ff5c68-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount paid or incurred by an employer which is excludable from the gross income of an employee under section 127, but only to the extent paid or incurred to a person not related to the employer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44ff5c69-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an employee who has not attained the age of 19, any amount paid or incurred by an employer for any youth training program operated by such employer in conjunction with local education officials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ff5c6a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person is related to any other person if the person bears a relationship to such other person specified in section 267(b) or 707(b)(1), or such person and such other person are engaged in trades or businesses under common control (within the meaning of subsections (a) and (b) of section 52). For purposes of the preceding sentence, in applying section 267(b) or 707(b)(1), “10 percent” shall be substituted for “50 percent”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ff5c6b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled groups","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subpart—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ff5c6c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all employers treated as a single employer under subsection (a) or (b) of section 52 shall be treated as a single employer for purposes of this subpart, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5c6d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the credit (if any) determined under section 1396 with respect to each such employer shall be its proportionate share of the wages giving rise to such credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ff5c6e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain other rules made applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subpart, rules similar to the rules of section 51(k) and subsections (c), (d), and (e) of section 52 shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44ff5c6f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13301/a"},"text":"Pub. L. 103–66, title XIII, § 13301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/551"},"text":"107 Stat. 551","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44ff5c70-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44ff5c71-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id44ff5c72-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1397, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVI/s601/a"},"text":"Pub. L. 95–600, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2895"},"text":"92 Stat. 2895","children":[],"tail":", related to special rules applicable to an electing general stock ownership corporation, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIII/s1303/a"},"text":"Pub. L. 99–514, title XIII, § 1303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2658"},"text":"100 Stat. 2658","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
