{"tag":"section","attrib":{"id":"id461b05b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5007"},"text":null,"children":[{"tag":"num","attrib":{"value":"5007"},"text":"§ 5007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of tax on distilled spirits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id461b05b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on distilled spirits removed from bonded premises","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax on domestic distilled spirits and on distilled spirits removed from customs custody under section 5232 shall be paid in accordance with section 5061.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id461b05b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of tax on imported distilled spirits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The internal revenue tax imposed by section 5001(a)(1) and (2) upon imported distilled spirits shall be collected by the Secretary and deposited as internal revenue collections, under such regulations as the Secretary may prescribe. Section 5688 shall be applicable to the disposition of imported spirits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id461b05b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id461b05b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5007/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For authority of the Secretary to make determinations and assessments of internal revenue taxes and penalties, see section 6201(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461b05b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5007/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For authority to assess tax on distilled spirits not bonded, see section 5006(c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461b05b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5007/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions relating to payment of tax, under certain conditions, on distilled spirits withdrawn free of tax, denatured distilled spirits, articles, and volatile fruit-flavor concentrates, see section 5001(a)(4), (5), and (6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id461b05b8-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1322"},"text":"72 Stat. 1322","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1905(b)(2)(A), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1822"},"text":"90 Stat. 1822","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/5"},"text":"Pub. L. 96–39, title VIII, § 807(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/280"},"text":"93 Stat. 280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tI/s136/c/3"},"text":"Pub. L. 103–465, title I, § 136(c)(3)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4841"},"text":"108 Stat. 4841","children":[],"tail":", 4842.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id461b05b9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id461b05ba-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id461b05bb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5007, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/600"},"text":"68A Stat. 600","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior section 5007(c) related to “payment of tax on alcoholic compounds from Puerto Rico and Virgin Islands”. See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7652"},"text":"section 7652 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior section 5007(e)(1) related to “assessment for deficiencies in production and excess of materials used” and “requirement”. See sections 5004(b)(1) and 5006(a)(3) of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior section 5007(e)(2) related to “relief from assessment for deficiencies in production and excess of materials used” and is obsolete.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id461b05bc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s136/c/3"},"text":"Pub. L. 103–465, § 136(c)(3)","children":[],"tail":", amended subsec. (b) generally, striking out provisions relating to collection and deposit as internal revenue collections of taxes on imported perfumes containing distilled spirits."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s136/c/4"},"text":"Pub. L. 103–465, § 136(c)(4)","children":[],"tail":", substituted “section 5001(a)(4), (5), and (6)” for “section 5001(a)(5), (6), and (7)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" struck out “(1) General” before “The tax on domestic” and par. (2) which related to distilled spirits withdrawn to bottling premises under withdrawal bond."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text"