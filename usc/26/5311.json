{"tag":"section","attrib":{"id":"id4635445f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5311"},"text":null,"children":[{"tag":"num","attrib":{"value":"5311"},"text":"§ 5311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detention of containers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be lawful for any internal revenue officer to detain any container, containing or supposed to contain, distilled spirits, wines, or beer, when he has reason to believe that the tax imposed by law on such distilled spirits, wines, or beer has not been paid or determined as required by law, or that such container is being removed in violation of law; and every such container may be held by him at a safe place until it shall be determined whether the property so detained is liable by law to be proceeded against for forfeiture; but such summary detention shall not continue in any case longer than 72 hours without process of law or intervention of the officer to whom such detention is to be reported.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id46354460-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1375"},"text":"72 Stat. 1375","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46354461-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46354462-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"ta