{"tag":"section","attrib":{"id":"id43fb59fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s702"},"text":null,"children":[{"tag":"num","attrib":{"value":"702"},"text":"§ 702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income and credits of partner","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43fb59ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining his income tax, each partner shall take into account separately his distributive share of the partnership’s—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43fb5a00-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gains and losses from sales or exchanges of capital assets held for not more than 1 year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fb5a01-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gains and losses from sales or exchanges of capital assets held for more than 1 year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fb5a02-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s702/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gains and losses from sales or exchanges of property described in section 1231 (relating to certain property used in a trade or business and involuntary conversions),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fb5a03-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s702/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charitable contributions (as defined in section 170(c)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fb5a04-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s702/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dividends with respect to which section 1(h)(11) or part VIII of subchapter B applies,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fb5a05-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s702/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taxes, described in section 901, paid or accrued to foreign countries and to possessions of the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fb5a06-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s702/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other items of income, gain, loss, deduction, or credit, to the extent provided by regulations prescribed by the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fb5a07-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s702/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taxable income or loss, exclusive of items requiring separate computation under other paragraphs of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43fb5a08-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Character of items constituting distributive share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The character of any item of income, gain, loss, deduction, or credit included in a partner’s distributive share under paragraphs (1) through (7) of subsection (a) shall be determined as if such item were realized directly from the source from which realized by the partnership, or incurred in the same manner as incurred by the partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43fb5a09-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gross income of a partner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case where it is necessary to determine the gross income of a partner for purposes of this title, such amount shall include his distributive share of the gross income of the partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43fb5a0a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For rules relating to procedures for determining the tax treatment of partnership items see subchapter C of chapter 63 (section 6221 and following).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43fb5a0b-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/239"},"text":"68A Stat. 239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s201/d/7"},"text":"Pub. L. 88–272, title II, § 201(d)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/32"},"text":"78 Stat. 32","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIV/s1402/b/1/L"},"text":"Pub. L. 94–455, title XIV, § 1402(b)(1)(L)","children":[],"tail":", (2), title XIX, §§ 1901(b)(1)(I)(i), (ii), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1732"},"text":"90 Stat. 1732","children":[],"tail":", 1791, 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/96/223/tIV/s404/b/5"},"text":"Pub. L. 96–223, title IV, § 404(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-02"},"text":"Apr. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/307"},"text":"94 Stat. 307","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIII/s301/b/5"},"text":"Pub. L. 97–34, title III, § 301(b)(5)","children":[],"tail":", (6)(C), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/270"},"text":"95 Stat. 270","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIV/s402/c/1"},"text":"Pub. L. 97–248, title IV, § 402(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/667"},"text":"96 Stat. 667","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tI/s103/a/4"},"text":"Pub. L. 97–448, title I, § 103(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2375"},"text":"96 Stat. 2375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1001/b/9"},"text":"Pub. L. 98–369, div. A, title X, § 1001(b)(9)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1011"},"text":"98 Stat. 1011","children":[],"tail":", 1012; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s612/b/5"},"text":"Pub. L. 99–514, title VI, § 612(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2250"},"text":"100 Stat. 2250","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/27/tIII/s302/e/8"},"text":"Pub. L. 108–27, title III, § 302(e)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-28"},"text":"May 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/764"},"text":"117 Stat. 764","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43fb5a0c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43fb5a0d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43fb5a0e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/27"},"text":"Pub. L. 108–27","children":[],"tail":" amended par. (5) generally. Prior to amendment, par. (5) read as follows: “dividends with respect to which there is a deduction under part VIII of subchapter B,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" amended par. (5) generally. Prior to amendment, par. (5) read as follows: “dividends or interest with respect to which there is an exclusion under section 116 or 128, or a deduction under part VIII of subchapter B,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “6 months” for “1 year”, applicable to property acquired after "},{"tag":"date","attrib":{"date":"1984-06-22"},"text":"June 22, 1984","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1988-01-01"},"text":"Jan. 1, 1988","children":[],"tail":". See Effective Date of 1984 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448"},"text":"Pub. L. 97–448","children":[],"tail":" substituted “an exclusion under section 116 or 128,” for “provided an exclusion under section 116 or 128”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s301/b/6/C"},"text":"Pub. L. 97–34, § 301(b)(6)(C)","children":[],"tail":", inserted reference to “interest” in heading and text which continued the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/96/223"},"text":"Pub. L. 96–223","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s301/b/5"},"text":"Pub. L. 97–34, § 301(b)(5)","children":[],"tail":", inserted “or 128” after “section 116”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223"},"text":"Pub. L. 96–223","children":[],"tail":" inserted “or interest” after “dividends”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1402/b/2"},"text":"Pub. L. 94–455, § 1402(b)(2)","children":[],"tail":", provided that “9 months” would be changed to “1 year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1402/b/1/L"},"text":"Pub. L. 94–455, § 1402(b)(1)(L)","children":[],"tail":", provided that “6 months” would be changed to “9 months” for taxable years beginning in 1977."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 1901(b)(1)(I)(i), 1906(b)(13)(A), redesignated pars. (8) and (9) as (7) and (8), respectively, and in par. (7), as so redesignated, struck out “or his delegate” after “Secretary”. Former par. (7), which related to partially tax-exempt interest on obligations of the United States or its instrumentalities, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/b/1/I/ii"},"text":"Pub. L. 94–455, § 1901(b)(1)(I)(ii)","children":[],"tail":", substituted “paragraphs (1) through (7)” for “paragraphs (1) through (8)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272"},"text":"Pub. L. 88–272","children":[],"tail":" struck out “a credit under section 34,” before “an exclusion”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43fb5a0f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43fb5a10-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/27"},"text":"Pub. L. 108–27","children":[],"tail":" applicable, except as otherwise provided, to taxable years beginning after "},{"tag":"date","attrib":{"date":"2002-12-31"},"text":"Dec. 31, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/27/s302/f"},"text":"section 302(f) of Pub. L. 108–27","children":[],"tail":", set out as an Effective and Termination Dates of 2003 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43fb5a11-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s612/c"},"text":"section 612(c) of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s301"},"text":"section 301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43fb5a12-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" applicable to property acquired after "},{"tag":"date","attrib":{"date":"1984-06-22"},"text":"June 22, 1984","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1988-01-01"},"text":"Jan. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1001/e"},"text":"section 1001(e) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s166"},"text":"section 166 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43fb5a13-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448"},"text":"Pub. L. 97–448","children":[],"tail":" effective, except as otherwise provided, as if it had been included in the provision of the Economic Recovery Tax Act of 1981, "},{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/s109"},"text":"section 109 of Pub. L. 97–448","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43fb5a14-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIV/s407/a"},"text":"Pub. L. 97–248, title IV, § 407(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/670"},"text":"96 Stat. 670","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the amendments made by sections 402, 403, and 404 [enacting sections 6221 to 6234 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1508"},"text":"section 1508 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, amending this section and sections 6031, 6213, 6216, 6422, 6501, 6504, 6511, 6512, 6515, 7422, 7451, 7456, 7459, 7482, and 7485 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1346"},"text":"section 1346 of Title 28","children":[],"tail":", and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6031"},"text":"section 6031 of this title","children":[],"tail":"] shall apply to partnership taxable years beginning after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" [Former] Section 6232 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] shall apply to periods after ","children":[{"tag":"date","attrib":{"date":"1982-12-31"},"text":"December 31, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by sections 402, 403, and 404 shall apply to any partnership taxable year (or in the case of [former] section 6232 of such Code, to any period) ending after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":"] if the partnership, each partner, and each indirect partner requests such application and the Secretary of the Treasury or his delegate consents to such application.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43fb5a15-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s301/b/5"},"text":"section 301(b)(5) of Pub. L. 97–34","children":[],"tail":" applicable to taxable years ending after "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"Sept. 30, 1981","children":[],"tail":", and amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/s301/b/6/C"},"text":"section 301(b)(6)(C) of Pub. L. 97–34","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"dat