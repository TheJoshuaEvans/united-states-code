{"tag":"section","attrib":{"id":"id460cd461-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C"},"text":null,"children":[{"tag":"num","attrib":{"value":"4980C"},"text":"§ 4980C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for issuers of qualified long-term care insurance contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id460cd462-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on any person failing to meet the requirements of subsection (c) or (d) a tax in the amount determined under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460cd463-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460cd464-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the tax imposed by subsection (a) shall be $100 per insured for each day any requirement of subsection (c) or (d) is not met with respect to each qualified long-term care insurance contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460cd465-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a failure which is due to reasonable cause and not to willful neglect, the Secretary may waive part or all of the tax imposed by subsection (a) to the extent that payment of the tax would be excessive relative to the failure involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460cd466-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of this subsection are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460cd467-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements of model provisions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460cd468-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model regulation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following requirements of the model regulation must be met:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id460cd469-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 13 (relating to application forms and replacement coverage).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460cd46a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 14 (relating to reporting requirements), except that the issuer shall also report at least annually the number of claims denied during the reporting period for each class of business (expressed as a percentage of claims denied), other than claims denied for failure to meet the waiting period or because of any applicable preexisting condition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460cd46b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 20 (relating to filing requirements for marketing).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460cd46c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Section 21 (relating to standards for marketing), including inaccurate completion of medical histories, other than sections 21C(1) and 21C(6) thereof, except that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id460cd46d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/1/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in addition to such requirements, no person shall, in selling or offering to sell a qualified long-term care insurance contract, misrepresent a material fact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id460cd46e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/1/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no such requirements shall include a requirement to inquire or identify whether a prospective applicant or enrollee for long-term care insurance has accident and sickness insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460cd46f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 22 (relating to appropriateness of recommended purchase).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460cd470-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 24 (relating to standard format outline of coverage).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460cd471-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 25 (relating to requirement to deliver shopper’s guide).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460cd472-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model Act","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following requirements of the model Act must be met:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id460cd473-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 6F (relating to right to return), except that such section shall also apply to denials of applications and any refund shall be made within 30 days of the return or denial.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460cd474-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 6G (relating to outline of coverage).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460cd475-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 6H (relating to requirements for certificates under group plans).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460cd476-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 6I (relating to policy summary).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460cd477-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 6J (relating to monthly reports on accelerated death benefits).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460cd478-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 7 (relating to incontestability period).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460cd479-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the terms “model regulation” and “model Act” have the meanings given such terms by section 7702B(g)(2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460cd47a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery of policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an application for a qualified long-term care insurance contract (or for a certificate under such a contract for a group) is approved, the issuer shall deliver to the applicant (or policyholder or certificateholder) the contract (or certificate) of insurance not later than 30 days after the date of the approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460cd47b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information on denials of claims","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a claim under a qualified long-term care insurance contract is denied, the issuer shall, within 60 days of the date of a written request by the policyholder or certificateholder (or representative)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460cd47c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a written explanation of the reasons for the denial, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460cd47d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available all information directly relating to such denial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460cd47e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this subsection are met if the issuer of a long-term care insurance policy discloses in such policy and in the outline of coverage required under subsection (c)(1)(B)(ii) that the policy is intended to be a qualified long-term care insurance contract under section 7702B(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460cd47f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified long-term care insurance contract defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “qualified long-term care insurance contract” has the meaning given such term by section 7702B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460cd480-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980C/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with State requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State imposes any requirement which is more stringent than the analogous requirement imposed by this section or section 7702B(g), the requirement imposed by this section or section 7702B(g) shall be treated as met if the more stringent State requirement is met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id460cd481-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/tIII/s326/a"},"text":"Pub. L. 104–191, title III, § 326(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2065"},"text":"110 Stat. 2065","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id460cd482-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id460cd483-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id460cd484-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/tIII/s327"},"text":"Pub. L. 104–191, title III, § 327","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2066"},"text":"110 Stat. 2066","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/191/tIII/s327"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of, and amendments made by, this part [part II (§§ 325–327) of subtitle C of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Pub. L. 104–191","children":[],"tail":", enacting this section and amending "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7702B"},"text":"section 7702B of this title","children":[],"tail":"] shall apply to contracts issued after "},{"tag":"date","attrib":{"date":"1996-12-31"},"text":"December 31, 1996","children":[],"tail":". The provisions of section 321(f) [set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7702B"},"text":"section 7702B of this title","children":[],"tail":"] (relating to transition rule) shall apply to such contracts."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by section 326 [enacting this section] shall apply to actions taken after ","children":[{"tag":"date","attrib":{"date":"1996-12-31"},"text":"December 31, 1996","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
