{"tag":"section","attrib":{"id":"id44cf997f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254"},"text":null,"children":[{"tag":"num","attrib":{"value":"1254"},"text":"§ 1254.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gain from disposition of interest in oil, gas, geothermal, or other mineral properties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44cf9980-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44cf9981-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ordinary income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any section 1254 property is disposed of, the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44cf9982-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the aggregate amount of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44cf9983-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenditures which have been deducted by the taxpayer or any person under section 263, 616, or 617 with respect to such property and which, but for such deduction, would have been included in the adjusted basis of such property, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44cf9984-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deductions for depletion under section 611 which reduced the adjusted basis of such property, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44cf9985-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the excess of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44cf9986-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id44cf9987-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/a/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sale, exchange, or involuntary conversion, the amount realized, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44cf9988-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/a/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other disposition, the fair market value of such property, over","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44cf9989-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjusted basis of such property,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be treated as gain which is ordinary income. Such gain shall be recognized notwithstanding any other provision of this subtitle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44cf998a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of portion of property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44cf998b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of the disposition of a portion of section 1254 property (other than an undivided interest), the entire amount of the aggregate expenditures or deductions described in paragraph (1)(A) with respect to such property shall be treated as allocable to such portion to the extent of the amount of the gain to which paragraph (1) applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44cf998c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of the disposition of an undivided interest in a section 1254 property (or a portion thereof), a proportionate part of the expenditures or deductions described in paragraph (1)(A) with respect to such property shall be treated as allocable to such undivided interest to the extent of the amount of the gain to which paragraph (1) applies.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This paragraph shall not apply to any expenditures to the extent the taxpayer establishes to the satisfaction of the Secretary that such expenditures do not relate to the portion (or interest therein) disposed of.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44cf998d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 1254 property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “section 1254 property” means any property (within the meaning of section 614) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44cf998e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any expenditures described in paragraph (1)(A) are properly chargeable to such property, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44cf998f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjusted basis of such property includes adjustments for deductions for depletion under section 611.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44cf9990-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment for amounts included in gross income under section 617(b)(1)(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the expenditures referred to in paragraph (1)(A)(i) shall be properly adjusted for amounts included in gross income under section 617(b)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44cf9991-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules under regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44cf9992-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules similar to the rule of subsection (g) of section 617 and to the rules of subsections (b) and (c) of section 1245 shall be applied for purposes of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44cf9993-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1254/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the sale or exchange of stock in an S corporation, rules similar to the rules of section 751 shall be applied to that portion of the excess of the amount realized over the adjusted basis of the stock which is attributable to expenditures referred to in subsection (a)(1)(A) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44cf9994-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tII/s205/a"},"text":"Pub. L. 94–455, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1533"},"text":"90 Stat. 1533","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/618/tIV/s402/c/1"},"text":"Pub. L. 95–618, title IV, § 402(c)(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3202"},"text":"92 Stat. 3202","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/354/s5/a/37"},"text":"Pub. L. 97–354, § 5(a)(37)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"Oct. 19, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1696"},"text":"96 Stat. 1696","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tIV/s413/a"},"text":"Pub. L. 99–514, title IV, § 413(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2227"},"text":"100 Stat. 2227","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1004/c"},"text":"Pub. L. 100–647, title I, § 1004(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3387"},"text":"102 Stat. 3387","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44cf9995-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44cf9996-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44cf9997-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" amended section generally, substituting “geothermal, or other mineral properties” for “or geothermal property” in section catchline, revising and restating subsec. (a), pars. (1) to (4) as pars. (1) to (3), and reenacting subsec. (b) without change except for substituting “rule of subsection (g)” for “rules of subsection (g)” in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/354"},"text":"Pub. L. 97–354","children":[],"tail":" substituted “an S corporation” for “an electing small business corporation (as defined in section 1371(b))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/618/s402/c/3"},"text":"Pub. L. 95–618, § 402(c)(3)","children":[],"tail":", substituted “oil, gas, or geothermal” for “oil or gas” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/618/s402/c/1"},"text":"Pub. L. 95–618, § 402(c)(1)","children":[],"tail":", substituted “oil, gas, or geothermal property” for “oil or gas property” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/618/s402/c/2"},"text":"Pub. L. 95–618, § 402(c)(2)","children":[],"tail":", substituted “Oil, gas, or geothermal” for “Oil or gas” in heading and in text substituted “The term ‘oil, gas, or geothermal property’ means” for “The term ‘oil or gas property’ means”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44cf9998-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44cf9999-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44cf999a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tIV/s413/c"},"text":"Pub. L. 99–514, title IV, § 413(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2229"},"text":"100 Stat. 2229","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tIV/s413/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s617"},"text":"section 617 of this title","children":[],"tail":"] shall apply to any disposition of property which is placed in service by the taxpayer after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for binding contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section shall not apply to any disposition of property placed in service after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", if such property was acquired pursuant to a written contract which was entered into before "},{"tag":"date","attrib":{"date":"1985-09-26"},"text":"September 26, 1985","children":[],"tail":", and which was binding at all times thereafter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44cf999b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/354"},"text":"Pub. L. 97–354","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1982-12-31"},"text":"Dec. 31, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/354/s6/a"},"text":"section 6(a) of Pub. L. 97–354","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1361"},"text":"section 1361 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44cf999c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/618"},"text":"Pub. L. 95–618","children":[],"tail":" applicable with respect to wells commenced on or after "},{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":", in taxable years ending on or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/618/s402/e"},"text":"section 402(e) of Pub. L. 95–618","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s263"},"text":"section 263 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44cf999d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tII/s205/e"},"text":"Pub. L. 94–455, title II, § 205(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1535"},"text":"90 Stat. 1535","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/455/tII/s205/e"},"text":"“The amendments made by this section [enacting this section and amending sections 163, 170, 301, 312, 341, 453, and 751 of this title] shall apply with respect to taxable years ending after ","children":[{"tag":"date","attrib":{"date":"1975-12-31"},"text":"December 31, 1975","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
