{"tag":"section","attrib":{"id":"id466e7cb5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A"},"text":null,"children":[{"tag":"num","attrib":{"value":"6041A"},"text":"§ 6041A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns regarding payments of remuneration for services and direct sales","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id466e7cb6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns regarding remuneration for services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id466e7cb7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any service-recipient engaged in a trade or business pays in the course of such trade or business during any calendar year remuneration to any person for services performed by such person, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id466e7cb8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate of such remuneration paid to such person during such calendar year equals or exceeds the dollar amount in effect for such calendar year under section 6041(a),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then the service-recipient shall make a return, according to the forms or regulations prescribed by the Secretary, setting forth the aggregate amount of such payments (including a separate accounting of any such amounts reasonably designated as cash tips and the occupation described in section 224(d)(1) of the person receiving such tips) and the name and address of the recipient of such payments. For purposes of the preceding sentence, the term “service-recipient” means the person for whom the service is performed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4670edb9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct sales of $5,000 or more","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4670edba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4670edbb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person engaged in a trade or business in the course of such trade or business during any calendar year sells consumer products to any buyer on a buy-sell basis, a deposit-commission basis, or any similar basis which the Secretary prescribes by regulations, for resale (by the buyer or any other person) in the home or otherwise than in a permanent retail establishment, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4670edbc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of the sales to such buyer during such calendar year is $5,000 or more,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then such person shall make a return, according to the forms or regulations prescribed by the Secretary, setting forth the name and address of the buyer to whom such sales are made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4670edbd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4670edbe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Buy-sell basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A transaction is on a buy-sell basis if the buyer performing the services is entitled to retain part or all of the difference between the price at which the buyer purchases the product and the price at which the buyer sells the product as part or all of the buyer’s remuneration for the services, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4670edbf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit-commission basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A transaction is on a deposit-commission basis if the buyer performing the services is entitled to retain part or all of a purchase deposit paid by the consumer in connection with the transaction as part or all of the buyer’s remuneration for the services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4670edc0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain services not included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No return shall be required under subsection (a) or (b) if a statement with respect to the services is required to be furnished under section 6051, 6052, or 6053.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4670edc1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications to governmental units","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4670edc2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treated as persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” includes any governmental unit (and any agency or instrumentality thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4670edc3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any payment by a governmental entity or any agency or instrumentality thereof—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4670edc4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a) shall be applied without regard to the trade or business requirement contained therein, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4670edc5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any return under this section shall be made by the officer or employee having control of the payment or appropriately designated for the purpose of making such return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4670edc6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to corporations by Federal executive agencies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4670edc7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any regulation prescribed by the Secretary before the date of the enactment of this paragraph, subsection (a) shall apply to remuneration paid to a corporation by any Federal executive agency (as defined in section 6050M(b)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4670edc8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraph (A) shall not apply to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4670edc9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services under contracts described in section 6050M(e)(3) with respect to which the requirements of section 6050M(e)(2) are met, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4670edca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other services as the Secretary may specify in regulations prescribed after the date of the enactment of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4670edcb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements to be furnished to persons with respect to whom information is required to be furnished","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every person required to make a return under subsection (a) or (b) shall furnish to each person whose name is required to be set forth in such return a written statement showing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4670edcc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and phone number of the information contact of the person required to make such return,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4670edcd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of subsection (a), the aggregate amount of payments to the person required to be shown on such return, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4670edce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of subsection (a), the portion of payments that have been reasonably designated as cash tips and the occupation described in section 224(d)(1) of the person receiving such tips.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The written statement required under the preceding sentence shall be furnished to the person on or before January 31 of the year following the calendar year for which the return under subsection (a) was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4670edcf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recipient to furnish name, address, and identification number; inclusion on return","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4670edd0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Furnishing of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person with respect to whom a return or statement is required under this section to be made by another person shall furnish to such other person his name, address, and identification number at such time and in such manner as the Secretary may prescribe by regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4670edd1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6041A/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion on return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The person to whom an identification number is furnished under paragraph (1) shall include such number on any return which such person is required to file under this section and to which such identification number relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4670edd2-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s312/a"},"text":"Pub. L. 97–248, title III, § 312(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/601"},"text":"96 Stat. 601","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/168/tXII/s1201/a/2"},"text":"Pub. L. 104–168, title XII, § 1201(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1469"},"text":"110 Stat. 1469","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1022/a"},"text":"Pub. L. 105–34, title X, § 1022(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/923"},"text":"111 Stat. 923","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII"},"text":"Pub. L. 119–21, title VII","children":[],"tail":", §§ 70201(f)(2), 70433(c), "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/172"},"text":"139 Stat. 172","children":[],"tail":", 244.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4670edd3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4670edd4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4670edd5-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this paragraph, referred to in subsec. (d)(3), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4670edd6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70201/f/2/A"},"text":"Pub. L. 119–21, § 70201(f)(2)(A)","children":[],"tail":", inserted “(including a separate accounting of any such amounts reasonably designated as cash tips and the occupation described in section 224(d)(1) of the person receiving such tips)” after “amount of such payments” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70433/c"},"text":"Pub. L. 119–21, § 70433(c)","children":[],"tail":", substituted “equals or exceeds the dollar amount in effect for such calendar year under section 6041(a)” for “is $600 or more”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70201/f/2/B"},"text":"Pub. L. 119–21, § 70201(f)(2)(B)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168"},"text":"Pub. L. 104–168","children":[],"tail":" substituted “name, address, and phone number of the information contact” for “name and address”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4670edd7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4670edd8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70201/f/2"},"text":"section 70201(f)(2) of Pub. L. 119–21","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2024-12-31"},"text":"Dec. 31, 2024","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70201/j"},"text":"section 70201(j) of Pub. L. 119–21","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s45B"},"text":"section 45B of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70433/c"},"text":"section 70433(c) of Pub. L. 119–21","children":[],"tail":" applicable with respect to payments made after "},{"tag":"date","attrib":{"date":"2025-12-31"},"text":"Dec. 31, 2025","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70433/f"},"text":"section 70433(f) of Pub. L. 119–21","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3406"},"text":"section 3406 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4670edd9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1022/b"},"text":"Pub. L. 105–34, title X, § 1022(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/923"},"text":"111 Stat. 923","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tX/s1022/b"},"text":"“The amendment made by this section [amending this section] shall apply to returns the due date for which (determined without regard to any extension) is more than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4670edda-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168"},"text":"Pub. L. 104–168","children":[],"tail":" applicable to statements required to be furnished after "},{"tag":"date","attrib":{"date":"1996-12-31"},"text":"Dec. 31, 1996","children":[],"tail":" (determined without regard to any extension), see "},{"tag":"ref","attrib":{"href":"/us/pl/104/168/s1201/b"},"text":"section 1201(b) of Pub. L. 104–168","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6041"},"text":"section 6041 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4670eddb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s312/c"},"text":"Pub. L. 97–248, title III, § 312(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/603"},"text":"96 Stat. 603","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/248/tIII/s312/c"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6678"},"text":"section 6678 of this title","children":[],"tail":"] shall apply to payments and sales made after "},{"tag":"date","attrib":{"date":"1982-12-31"},"text":"December 31, 1982","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
