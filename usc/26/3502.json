{"tag":"section","attrib":{"id":"id45a3d94b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3502"},"text":null,"children":[{"tag":"num","attrib":{"value":"3502"},"text":"§ 3502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondeductibility of taxes in computing taxable income","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45a3d94c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The taxes imposed by section 3101 of chapter 21, and by sections 3201 and 3211 of chapter 22 shall not be allowed as a deduction to the taxpayer in computing taxable income under subtitle A.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a3d94d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The tax deducted and withheld under chapter 24 shall not be allowed as a deduction either to the employer or to the recipient of the income in computing taxable income under subtitle A.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45a3d94e-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/471"},"text":"68A Stat. 471","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII"},"text":"Pub. L. 97–248, title III","children":[],"tail":", §§ 305(b), 308(a), "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/588"},"text":"96 Stat. 588","children":[],"tail":", 591; "},{"tag":"ref","attrib":{"href":"/us/pl/98/67/tI/s102/a"},"text":"Pub. L. 98–67, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-05"},"text":"Aug. 5, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/369"},"text":"97 Stat. 369","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45a3d94f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45a3d950-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45a3d951-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/67"},"text":"Pub. L. 98–67","children":[],"tail":" repealed amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":". See 1982 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" provided that, applicable to payments of interest, dividends, and patronage dividends paid or credited after "},{"tag":"date","attrib":{"date":"1983-06-30"},"text":"June 30, 1983","children":[],"tail":", subsec. (b) is amended and a new subsec. (c) is added. Section 102(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/98/67/tI"},"text":"Pub. L. 98–67, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-05"},"text":"Aug. 5, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/369"},"text":"97 Stat. 369","children":[],"tail":", repealed subtitle A (§§ 301–308) of title III of "},{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" as of the close of "},{"tag":"date","attrib":{"date":"1983-06-30"},"text":"June 30, 1983","children":[],"tail":", and provided that the Internal Revenue Code of 1954 [now 1986] [this title] shall be applied and administered (subject to certain exceptions) as if such subtitle A (and the amendments made by such subtitle A) had not been enacted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
