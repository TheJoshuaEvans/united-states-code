{"tag":"section","attrib":{"id":"id443973ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860A"},"text":null,"children":[{"tag":"num","attrib":{"value":"860A"},"text":"§ 860A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxation of REMIC’s","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id443973eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this part, a REMIC shall not be subject to taxation under this subtitle (and shall not be treated as a corporation, partnership, or trust for purposes of this subtitle).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443973ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income taxable to holders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The income of any REMIC shall be taxable to the holders of interests in such REMIC as provided in this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id443973ed-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s671/a"},"text":"Pub. L. 99–514, title VI, § 671(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2309"},"text":"100 Stat. 2309","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/t/20"},"text":"Pub. L. 100–647, title I, § 1006(t)(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3426"},"text":"102 Stat. 3426","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id443973ee-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id443973ef-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id443973f0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" substituted “this subtitle” for “this chapter” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id443973f1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id443973f2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id443973f3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s675/a"},"text":"Pub. L. 99–514, title VI, § 675(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2320"},"text":"100 Stat. 2320","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/w/1"},"text":"Pub. L. 100–647, title I, § 1006(w)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3427"},"text":"102 Stat. 3427","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1006/w/1"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this section, the amendments made by this subtitle [subtitle H (§§ 671–675) of title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", enacting this part and amending sections 582, 593, 856, 1272, 6049, and 7701 of this title] shall take effect on "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rules for Accruing Original Issue Discount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by section 672 [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1272"},"text":"section 1272 of this title","children":[],"tail":"] shall apply to debt instruments issued after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", in taxable years ending after such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Taxable Mortgage Pools.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by section 673 [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7701"},"text":"section 7701 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"1992-01-01"},"text":"January 1, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of existing entities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by section 673 shall not apply to any entity in existence on ","children":[{"tag":"date","attrib":{"date":"1991-12-31"},"text":"December 31, 1991","children":[],"tail":". The preceding sentence shall cease to apply with respect to any entity as of the 1st day after "},{"tag":"date","attrib":{"date":"1991-12-31"},"text":"December 31, 1991","children":[],"tail":", on which there is a substantial transfer of cash or other property to such entity."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for coordination with wash-sale rules","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraphs (1) and (2), for purposes of applying section 860F(d) of the Internal Revenue Code of 1986 (as added by this part [this subtitle]), the amendment made by section 673 shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id443973f4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s675/d"},"text":"Pub. L. 99–514, title VI, § 675(d)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/w/2"},"text":"Pub. L. 100–647, title I, § 1006(w)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3427"},"text":"102 Stat. 3427","children":[],"tail":", directed Secretary of the Treasury to conduct a study of the operation of the amendments made by this part [this subtitle] and their competitive impact on savings and loan institutions and similar financial institutions and, not later than "},{"tag":"date","attrib":{"date":"1990-01-01"},"text":"Jan. 1, 1990","children":[],"tail":", report to Congress, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11832/5"},"text":"Pub. L. 101–508, title XI, § 11832(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-559"},"text":"104 Stat. 1388–559","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
