{"tag":"section","attrib":{"id":"id472fa94f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6696"},"text":null,"children":[{"tag":"num","attrib":{"value":"6696"},"text":"§ 6696.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules applicable with respect to sections 6694, 6695, 6695A, and 6695B","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id472fa950-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6696/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties to be additional to any other penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalties provided by sections 6694, 6695, 6695A, and 6695B shall be in addition to any other penalties provided by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472fa951-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6696/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deficiency procedures not to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subchapter B of chapter 63 (relating to deficiency procedures for income, estate, gift, and certain excise taxes) shall not apply with respect to the assessment or collection of the penalties provided by sections 6694, 6695, 6695A, and 6695B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472fa952-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6696/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure for claiming refund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any claim for credit or refund of any penalty paid under section 6694, 6695, 6695A, or 6695B shall be filed in accordance with regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472fa953-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6696/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periods of limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472fa954-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6696/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any penalty under section 6694(a), 6695, or 6695A shall be assessed within 3 years (or, in the case of any penalty under section 6695B, 6 years) after the return or claim for refund with respect to which the penalty is assessed was filed, and no proceeding in court without assessment for the collection of such tax shall be begun after the expiration of such period. In the case of any penalty under section 6694(b), the penalty may be assessed, or a proceeding in court for the collection of the penalty may be begun without assessment, at any time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472fa955-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6696/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claim for refund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in section 6694(d), any claim for refund of an overpayment of any penalty assessed under section 6694, 6695, or 6695A shall be filed within 3 years (or, in the case of any claim for refund of an overpayment of any penalty assessed under section 6695B, 6 years) from the time the penalty was paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472fa956-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6696/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of sections 6694, 6695, 6695A, and 6695B—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472fa957-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6696/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “return” means any return of any tax imposed by this title, any administrative adjustment request under section 6227, and any partnership adjustment tracking report under section 6226(b)(4)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472fa958-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6696/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claim for refund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “claim for refund” means a claim for refund of, or credit against, any tax imposed by this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id472fa959-3a70-11f1-a967-d35dac11796a"},"text":