/us/stat/139/269"},"text":"139 Stat. 269","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id472fa95a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id472fa95b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id472fa95c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1219/b/2"},"text":"Section 1219(b)(2) of Pub. L. 109–280","children":[],"tail":", which directed the amendment of section 6696 without specifying the act to be amended, was executed to this section, which is section 6696 of the Internal Revenue Code of 1986, to reflect the probable intent of Congress. See 2006 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id472fa95d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70512/k/2/A/i"},"text":"Pub. L. 119–21, § 70512(k)(2)(A)(i)","children":[],"tail":", (ii), substituted “6695A, and 6695B” for “and 6695A” in section catchline and wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70512/k/2/A/iii"},"text":"Pub. L. 119–21, § 70512(k)(2)(A)(iii)","children":[],"tail":", substituted “6695A, or 6695B” for “or 6695A”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70512/k/2/A/iv/I"},"text":"Pub. L. 119–21, § 70512(k)(2)(A)(iv)(I)","children":[],"tail":", inserted “(or, in the case of any penalty under section 6695B, 6 years)” after “assessed within 3 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70512/k/2/A/iv/II"},"text":"Pub. L. 119–21, § 70512(k)(2)(A)(iv)(II)","children":[],"tail":", inserted “(or, in the case of any claim for refund of an overpayment of any penalty assessed under section 6695B, 6 years)” after “filed within 3 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/311"},"text":"Pub. L. 115–141, § 401(a)(311)","children":[],"tail":", substituted “sections 6694,” for “section 6694,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/312"},"text":"Pub. L. 115–141, § 401(a)(312)","children":[],"tail":", substituted “6695,” for “section 6695,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/n/3"},"text":"Pub. L. 115–141, § 206(n)(3)","children":[],"tail":", inserted “, any administrative adjustment request under section 6227, and any partnership adjustment tracking report under section 6226(b)(4)(A)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172"},"text":"Pub. L. 110–172","children":[],"tail":" substituted “, section 6695, or 6695A” for “or under section 6695”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28"},"text":"Pub. L. 110–28","children":[],"tail":" substituted “this title” for “subtitle A” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"h