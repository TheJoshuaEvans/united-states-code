{"tag":"section","attrib":{"id":"id43bd664b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s521"},"text":null,"children":[{"tag":"num","attrib":{"value":"521"},"text":"§ 521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption of farmers’ cooperatives from tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43bd664c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s521/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A farmers’ cooperative organization described in subsection (b)(1) shall be exempt from taxation under this subtitle except as otherwise provided in part I of subchapter T (sec. 1381 and following). Notwithstanding part I of subchapter T (sec. 1381 and following), such an organization shall be considered an organization exempt from income taxes for purposes of any law which refers to organizations exempt from income taxes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43bfd74d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s521/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43bfd74e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s521/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempt farmers’ cooperatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The farmers’ cooperatives exempt from taxation to the extent provided in subsection (a) are farmers’, fruit growers’, or like associations organized and operated on a cooperative basis (A) for the purpose of marketing the products of members or other producers, and turning back to them the proceeds of sales, less the necessary marketing expenses, on the basis of either the quantity or the value of the products furnished by them, or (B) for the purpose of purchasing supplies and equipment for the use of members or other persons, and turning over such supplies and equipment to them at actual cost, plus necessary expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43bfd74f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s521/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organizations having capital stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Exemption shall not be denied any such association because it has capital stock, if the dividend rate of such stock is fixed at not to exceed the legal rate of interest in the State of incorporation or 8 percent per annum, whichever is greater, on the value of the consideration for which the stock was issued, and if substantially all such stock (other than nonvoting preferred stock, the owners of which are not entitled or permitted to participate, directly or indirectly, in the profits of the association, upon dissolution or otherwise, beyond the fixed dividends) is owned by producers who market their products or purchase their supplies and equipment through the association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43bfd750-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s521/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organizations maintaining reserve","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Exemption shall not be denied any such association because there is accumulated and maintained by it a reserve required by State law or a reasonable reserve for any necessary purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43bfd751-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s521/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transactions with nonmembers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Exemption shall not be denied any such association which markets the products of nonmembers in an amount the value of which does not exceed the value of the products marketed for members, or which purchases supplies and equipment for nonmembers in an amount the value of which does not exceed the value of the supplies and equipment purchased for members, provided the value of the purchases made for persons who are neither members nor producers does not exceed 15 percent of the value of all its purchases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43bfd752-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s521/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Business for the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Business done for the United States or any of its agencies shall be disregarded in determining the right to exemption under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43bfd753-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s521/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Netting of losses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Exemption shall not be denied any such association because such association computes its net earnings for purposes of determining any amount available for distribution to patrons in the manner described in paragraph (1) of section 1388(j).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43bfd754-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s521/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For treatment of value-added processing involving animals, see section 1388(k).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43bfd755-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/176"},"text":"68A Stat. 176","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/834/s17/b/1"},"text":"Pub. L. 87–834, § 17(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-16"},"text":"Oct. 16, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1051"},"text":"76 Stat. 1051","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIII/s13210/b"},"text":"Pub. L. 99–272, title XIII, § 13210(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/324"},"text":"100 St