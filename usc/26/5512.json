{"tag":"section","attrib":{"id":"id463c70d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5512"},"text":null,"children":[{"tag":"num","attrib":{"value":"5512"},"text":"§ 5512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Control of products after manufacture","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For applicability of all provisions of this chapter pertaining to distilled spirits and wines, including those requiring payment of tax, to volatile fruit-flavor concentrates sold, transported, or used in violation of law or regulations, see section 5001(a)(6).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id463c70d8-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1392"},"text":"72 Stat. 1392","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/247"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(247)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1195"},"text":"132 Stat. 1195","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id463c70d9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id463c70da-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id463c70db-3a70-11f1-a967-d35d