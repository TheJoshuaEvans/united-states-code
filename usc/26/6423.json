{"tag":"section","attrib":{"id":"id46ecd44a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6423"},"text":null,"children":[{"tag":"num","attrib":{"value":"6423"},"text":"§ 6423.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions to allowance in the case of alcohol and tobacco taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46ecd44b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6423/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No credit or refund shall be allowed or made, in pursuance of a court decision or otherwise, of any amount paid or collected as an alcohol or tobacco tax unless the claimant establishes (under regulations prescribed by the Secretary)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46ecd44c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6423/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that he bore the ultimate burden of the amount claimed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ecd44d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6423/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that he has unconditionally repaid the amount claimed to the person who bore the ultimate burden of such amount; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ecd44e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6423/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that (A) the owner of the commodity furnished him the amount claimed for payment of the tax, (B) he has filed with the Secretary the written consent of such owner to the allowance to the claimant of the credit or refund, and (C) such owner satisfies the requirements of paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46ecd44f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6423/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No credit or refund of any amount to which subsection (a) applies shall be allowed or made unless a claim therefor has been filed by the person who paid the amount claimed, and unless such claim is filed within the time prescribed by law and in accordance with regulations prescribed by the Secretary. All evidence relied upon in support of such claim shall be clearly set forth and submitted with the claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46ecd450-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6423/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of section","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall apply only if the credit or refund is claimed on the grounds that an amount of alcohol or tobacco tax was assessed or collected erroneously, illegally, without authority, or in any manner wrongfully, or on the grounds that such amount was excessive. This section shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46ecd451-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6423/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any claim for drawback, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ecd452-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6423/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any claim made in accordance with any law expressly providing for credit or refund where a commodity is withdrawn from the market, returned to bond, or lost or destroyed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46ecd453-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6423/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meaning of terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46ecd454-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6423/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alcohol or tobacco tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “alcohol or tobacco tax” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46ecd455-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6423/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any tax imposed by chapter 51 (other than part II of subchapter A, relating to occupational taxes) or by chapter 52 or by any corresponding provision of prior internal revenue laws, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46ecd456-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6423/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any commodity of a kind subject to a tax described in subparagraph (A), any tax equal to any such tax, any additional tax, or any floor stocks tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ecd457-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6423/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tax” includes a tax and an exaction denominated a “tax”, and any penalty, addition to tax, additional amount, or interest applicable to any such tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ecd458-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6423/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ultimate burden","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The claimant shall be treated as having borne the ultimate burden of an amount of an alcohol or tobacco tax for purposes of subsection (a)(1), and the owner referred to in subsection (a)(3) shall be treated as having borne such burden for purposes of such subsection, only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46ecd459-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6423/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" he has not, directly or indirectly, been relieved of such burden or shifted such burden to any other person,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46ecd45a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6423/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no understanding or agreement exists for any such relief or shifting, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46ecd45b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6423/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if he has neither sold nor contracted to sell the commodities involved in such claim, he agrees that there will be no such relief or shifting, and furnishes such bond as the Secretary may require to insure faithful compliance with his agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46ecd45c-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/323/s1"},"text":"Pub. L. 85–323, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-02-11"},"text":"Feb. 11, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/9"},"text":"72 Stat. 9","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/a/29"},"text":"Pub. L. 94–455, title XIX, § 1906(a)(29)","children":[],"tail":", (b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1828"},"text":"90 Stat. 1828","children":[],"tail":", 1834.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46ecd45d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46ecd45e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46ecd45f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/a/29/A"},"text":"Pub. L. 94–455, § 1906(a)(29)(A)","children":[],"tail":", among other changes, struck out provisions allowing any claimant who has on or before "},{"tag":"date","attrib":{"date":"1958-04-30"},"text":"Apr. 30, 1958","children":[],"tail":", filed a claim for any amount to which subsec. (a) applies, may file a superseding claim after "},{"tag":"date","attrib":{"date":"1958-04-30"},"text":"Apr. 30, 1958","children":[],"tail":", conforming to the requirements of this section and covering the amount claimed in such prior claim."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/a/29/B"},"text":"Pub. L. 94–455, § 1906(a)(29)(B)","children":[],"tail":", (C), redesignated subsec. (d) as (c) and struck out par. (3) relating to any amount claimed with respect to a commodity which has been lost, where a suit or proceeding was instituted before "},{"tag":"date","attrib":{"date":"1957-06-15"},"text":"June 15, 1957","children":[],"tail":". Former subsec. (c), relating to disallowance of any suit or proceeding which was barred on "},{"tag":"date","attrib":{"date":"1958-04-30"},"text":"Apr. 30, 1958","children":[],"tail":", was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/a/29/B"},"text":"Pub. L. 94–455, § 1906(a)(29)(B)","children":[],"tail":", (b)(13)(A), redesignated subsec. (e) as (d) and struck out “or his delegate” after “Secretary”. Former subsec. (d) redesignated (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46ecd460-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46ecd461-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" effective on first day of first month which begins more than 90 days after "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/d/1"},"text":"section 1906(d)(1) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6013"},"text":"section 6013 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46ecd462-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/323/s3"},"text":"Pub. L. 85–323, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-02-11"},"text":"Feb. 11, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/10"},"text":"72 Stat. 10","children":[],"tail":", provided that this section shall not apply to any credit or refund allowed or made before "},{"tag":"date","attrib":{"date":"1958-05-01"},"text":"May 1, 1958","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
