{"tag":"section","attrib":{"id":"id42b25f0f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s316"},"text":null,"children":[{"tag":"num","attrib":{"value":"316"},"text":"§ 316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dividend defined","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42b25f10-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s316/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subtitle, the term “dividend” means any distribution of property made by a corporation to its shareholders—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42b25f11-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s316/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" out of its earnings and profits accumulated after ","children":[{"tag":"date","attrib":{"date":"1913-02-28"},"text":"February 28, 1913","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42b25f12-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s316/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" out of its earnings and profits of the taxable year (computed as of the close of the taxable year without diminution by reason of any distributions made during the taxable year), without regard to the amount of the earnings and profits at the time the distribution was made.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Except as otherwise provided in this subtitle, every distribution is made out of earnings and profits to the extent thereof, and from the most recently accumulated earnings and profits. To the extent that any distribution is, under any provision of this subchapter, treated as a distribution of property to which section 301 applies, such distribution shall be treated as a distribution of property for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42b25f13-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s316/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42b25f14-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s316/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain insurance company dividends","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The definition in subsection (a) shall not apply to the term “dividend” as used in subchapter L in any case where the reference is to dividends of insurance companies paid to policyholders as such.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42b25f15-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s316/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions by personal holding companies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42b25f16-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s316/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a corporation which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42b25f17-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s316/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the law applicable to the taxable year in which the distribution is made, is a personal holding company (as defined in section 542), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42b25f18-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s316/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the taxable year in respect of which the distribution is made under section 563(b) (relating to dividends paid after the close of the taxable year), or section 547 (relating to deficiency dividends), or the corresponding provisions of prior law, is a personal holding company under the law applicable to such taxable year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the term “dividend” also means any distribution of property (whether or not a dividend as defined in subsection (a)) made by the corporation to its shareholders, to the extent of its undistributed personal holding company income (determined under section 545 without regard to distributions under this paragraph) for such year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42b25f19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s316/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of subparagraph (A), the term “distribution of property” includes a distribution in complete liquidation occurring within 24 months after the adoption of a plan of liquidation, but—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42b25f1a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s316/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only to the extent of the amounts distributed to distributees other than corporate shareholders, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42b25f1b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s316/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only to the extent that the corporation designates such amounts as a dividend distribution and duly notifies such distributees of such designation, under regulations prescribed by the Secretary, but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42b25f1c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s316/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not in excess of the sum of such distributees’ allocable share of the undistributed personal holding company income for such year, computed without regard to this subparagraph or section 562(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42b25f1d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s316/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deficiency dividend distributions by a regulated investment company or real estate investment trust","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “dividend” also means any distribution of property (whether or not a dividend as defined in subsection (a)) which constitutes a “deficiency dividend” as defined in section 860(f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42b25f1e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s316/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain distributions by regulated investment companies in excess of earnings and profits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a regulated investment company that has a taxable year other than a calendar year, if the distributions by the company with respect to any class of stock of such company for the taxable year exceed the company’s current and accumulated earnings and profits which may be used for the payment of dividends on such class of stock, the company’s current earnings and profits shall, for purposes of subsection (a), be allocated first to distributions with respect to such class of stock made during the portion of the taxable year which precedes January 1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id42b25f1f-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/98"},"text":"68A Stat. 98","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-03-13/ch83/s5/1"},"text":"Mar. 13, 1956, ch. 83, § 5(1)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/49"},"text":"70 Stat. 49","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s225/f/1"},"text":"Pub. L. 88–272, title II, § 225(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/87"},"text":"78 Stat. 87","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXVI/s1601/d"},"text":"Pub. L. 94–455, title XVI, § 1601(d)","children":[],"tail":", title XIX, § 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1746"},"text":"90 Stat. 1746","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tIII/s362/d/1"},"text":"Pub. L. 95–600, title III, § 362(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2851"},"text":"92 Stat. 2851","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/325/tIII/s305/a"},"text":"Pub. L. 111–325, title III, § 305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3549"},"text":"124 Stat. 3549","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id42b25f20-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id42b25f21-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id42b25f22-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325"},"text":"Pub. L. 111–325","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" inserted “regulated investment company or” after “distributions by a” in heading and substituted in text “section 860(f)” for “section 859(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b)(2)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1601/d"},"text":"Pub. L. 94–455, § 1601(d)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272"},"text":"Pub. L. 88–272","children":[],"tail":" inserted definition of “distribution of property”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Subsec. (b)(1). Act ","children":[{"tag":"date","attrib":{"date":"1956-03-13"},"text":"Mar. 13, 1956","children":[],"tail":", substituted “subchapter L” for “sections 803(e), 821(a)(2), and 832(c)(11)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id42b25f23-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42b25f24-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325/tIII/s305/b"},"text":"Pub. L. 111–325, title III, § 305(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3549"},"text":"124 Stat. 3549","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/325/tIII/s305/b"},"text":"“The amendment made by this section [amending this section] shall apply to distributions made in taxable years beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42b25f25-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" applicable with respect to determinations (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s860/e"},"text":"section 860(e) of this title","children":[],"tail":") after "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/s362/e"},"text":"section 362(e) of Pub. L. 95–600","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s860"},"text":"section 860 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42b25f26-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1601/d"},"text":"section 1601(d) of Pub. L. 94–455","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1608/a"},"text":"section 1608(a) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s857"},"text":"section 857 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42b25f27-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1964 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s225"},"text":"Pub. L. 88–272, title II, § 225","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/94"},"text":"78 Stat. 94","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/stat/78/94"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by this section [enacting section 1022, redesignating former section 1022 as 1023, amending this section and sections 331, 333, 381, 541, 542, 543, 544, 545, 551, 553, 554, 562, 856, 1016, 1361, 6501, and the analysis preceding section 1011, and enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s333"},"text":"section 333 of this title","children":[],"tail":"] (other than by subsections (c)(1), (f), (g), and (j) [enacting section 1022, redesignating former section 1022 as 1023, amending this section and sections 331, 333, 542, 551, 562, 1016, and the analysis preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1011"},"text":"section 1011 of this title","children":[],"tail":"]) shall apply to taxable years beginning after "},{"tag":"date","attrib":{"date":"1963-12-31"},"text":"December 31, 1963","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendment made by subsection (c)(1) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s542"},"text":"section 542 of this title","children":[],"tail":"] shall apply to taxable years beginning after "},{"tag":"date","attrib":{"date":"1962-10-16"},"text":"October 16, 1962","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by subsections (f) and (g) [amending this section and sections 331, 333, 551, and 562 of this title] shall apply to distributions made in any taxable year of the distributing corporation beginning after ","children":[{"tag":"date","attrib":{"date":"1963-12-31"},"text":"December 31, 1963","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by subsection (j) [enacting section 1022, redesignating former section 1022 as 1023, and amending section 1016 and the analysis preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1011"},"text":"section 1011 of this title","children":[],"tail":"] shall apply in respect of decedents dying after "},{"tag":"date","attrib":{"date":"1963-12-31"},"text":"December 31, 1963","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (h) [set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s333"},"text":"section 333 of this title","children":[],"tail":"] shall apply to taxable years beginning after "},{"tag":"date","attrib":{"date":"1963-12-31"},"text":"December 31, 1963","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42b25f28-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1956 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1956-03-13/ch83/s6"},"text":"Act Mar. 13, 1956, ch. 83, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/49"},"text":"70 Stat. 49","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1956-03-13/ch83/s6"},"text":"“The amendments made by this Act [amending this section and sections 501, 594, 801 to 805, 811 to 813, 816 to 818, 821, 822, 832, 841, 842, 843, 891, 1201, 1504, and 4371 of this title] shall apply only to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1954-12-31"},"text":"December 31, 1954","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
