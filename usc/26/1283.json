{"tag":"section","attrib":{"id":"id44ddf1a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283"},"text":null,"children":[{"tag":"num","attrib":{"value":"1283"},"text":"§ 1283.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44ddf1a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subpart—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ddf1a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short-term obligation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ddf1a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the term “short-term obligation” means any bond, debenture, note, certificate, or other evidence of indebtedness which has a fixed maturity date not more than 1 year from the date of issue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ddf1a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions for tax-exempt obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “short-term obligation” shall not include any tax-exempt obligation (as defined in section 1275(a)(3)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ddf1a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition discount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “acquisition discount” means the excess of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ddf1a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the stated redemption price at maturity (as defined in section 1273), over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ddf1a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer’s basis for the obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ddf1a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Daily portion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subpart—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ddf1a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratable accrual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this subsection, the daily portion of the acquisition discount is an amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ddf1aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such discount, divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ddf1ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of days after the day on which the taxpayer acquired the obligation and up to (and including) the day of its maturity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ddf1ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of accrual on basis of constant interest rate (in lieu of ratable accrual)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ddf1ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the election of the taxpayer with respect to any obligation, the daily portion of the acquisition discount for any day is the portion of the acquisition discount accruing on such day determined (under regulations prescribed by the Secretary) on the basis of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44ddf1ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer’s yield to maturity based on the taxpayer’s cost of acquiring the obligation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44ddf1af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compounding daily.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ddf1b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election irrevocable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under subparagraph (A), once made with respect to any obligation, shall be irrevocable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ddf1b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for nongovernmental obligations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ddf1b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any short-term obligation which is not a short-term Government obligation (as defined in section 1271(a)(3)(B))—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ddf1b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 1281 and 1282 shall be applied by taking into account original issue discount in lieu of acquisition discount, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ddf1b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate adjustments shall be made in the application of subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ddf1b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to have paragraph (1) not apply","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ddf1b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A taxpayer may make an election under this paragraph to have paragraph (1) not apply to all obligations acquired by the taxpayer on or after the first day of the first taxable year to which such election applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ddf1b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period to which election applies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under this paragraph shall apply to the taxable year for which it is made and for all subsequent taxable years, unless the taxpayer secures the consent of the Secretary to the revocation of such election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ddf1b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ddf1b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The basis of any short-term obligation in the hands of the holder thereof shall be increased by the amount included in his gross income pursuant to section 1281.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ddf1ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Double inclusion in income not required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 1281 shall not require the inclusion of any amount previously includible in gross income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ddf1bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1283/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 454(b) and paragraphs (3) and (4) of section 1271(a) shall not apply to any short-term obligation to which section 1281 applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44ddf1bc-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s41/a"},"text":"Pub. L. 98–369, div. A, title I, § 41(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/549"},"text":"98 Stat. 549","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1803/a/1/B"},"text":"Pub. L. 99–514, title XVIII, § 1803(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2792"},"text":"100 Stat. 2792","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44ddf1bd-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44ddf1be-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44ddf1bf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “paragraphs (3) and (4) of section 1271(a)” for “section 1271(a)(3)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44ddf1c0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44ddf1c1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44ddf1c2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years ending after ","children":[{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", and to obligations acquired after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s44"},"text":"section 44 of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1271"},"text":"section 1271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id44ddf1c3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1800–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
