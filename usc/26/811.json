811","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1956-03-13/ch83/s2"},"text":"Mar. 13, 1956, ch. 83, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/44"},"text":"70 Stat. 44","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-24/ch696/s2/c"},"text":"July 24, 1956, ch. 696, § 2(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/633"},"text":"70 Stat. 633","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-03-17"},"text":"Mar. 17, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/345/s2/c"},"text":"Pub. L. 85–345, § 2(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/37"},"text":"72 Stat. 37","children":[],"tail":", imposed a tax on the life insurance company taxable income of all life insurance companies for taxable years beginning after "},{"tag":"date","attrib":{"date":"1957-12-31"},"text":"Dec. 31, 1957","children":[],"tail":", prior to the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/86/69/s2/a"},"text":"Pub. L. 86–69, § 2(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id440e6cd2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" substituted “the interest rate in effect under section 808(g)” for “the greater of the prevailing State assumed interest rate or applicable Federal interest rate in effect under section 807”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" substituted “the greater of the prevailing State assumed interest rate or applicable Federal interest rate in effect under section 807 for the contract” for “the prevailing State assumed interest rate for the contract”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s42/a/8"},"text":"Pub. L. 98–369, § 42(a)(8)","children":[],"tail":", substituted “section 1273” for “section 1232(b)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id440e6cd3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id440e6cd4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", with transition rule and transition relief, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13517/c"},"text":"section 13517(c) of Pub. L. 115–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s807"},"text":"section 807 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id440e6cd5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Revenue Act of 1987, "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX"},"text":"Pub. L. 100–203, title X","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/u"},"text":"section 2004(u) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s56"},"text":"section 56 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id440e6cd6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s42/a/8"},"text":"section 42(a)(8) of Pub. L. 98–369","children":[],"tail":" applicable to taxable years ending after "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s44"},"text":"section 44 of Pub. L. 98–369","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1271"},"text":"section 1271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id440e6cd7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1983-12-31"},"text":"Dec. 31, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s215"},"text":"section 215 of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
