{"tag":"section","attrib":{"id":"id454ba7c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2653"},"text":null,"children":[{"tag":"num","attrib":{"value":"2653"},"text":"§ 2653.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxation of multiple skips","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id454ba7c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2653/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454ba7c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2653/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a generation-skipping transfer of any property, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba7c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2653/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately after such transfer such property is held in trust,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for purposes of applying this chapter (other than section 2651) to subsequent transfers from the portion of such trust attributable to such property, the trust will be treated as if the transferor of such property were assigned to the first generation above the highest generation of any person who has an interest in such trust immediately after the transfer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454ba7c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2653/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust retains inclusion ratio","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454ba7c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2653/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the provisions of subsection (a) shall not affect the inclusion ratio determined with respect to any trust. Under regulations prescribed by the Secretary, notwithstanding the preceding sentence, proper adjustment shall be made to the inclusion ratio with respect to such trust to take into account any tax under this chapter borne by such trust which is imposed by this chapter on the transfer described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba7ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2653/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for pour-over trust","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454ba7cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2653/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the generation-skipping transfer referred to in subsection (a) involves the transfer of property from 1 trust to another trust (hereinafter in this paragraph referred to as the “pour-over trust”), the inclusion ratio for the pour-over trust shall be determined by treating the nontax portion of such distribution as if it were a part of a GST exemption allocated to such trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454ba7cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2653/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nontax portion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the nontax portion of any distribution is the amount of such distribution multiplied by the applicable fraction which applies to such distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id454ba7cd-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIV/s1431/a"},"text":"Pub. L. 99–514, title XIV, § 1431(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2727"},"text":"100 Stat. 2727","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id454ba7ce-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id454ba7cf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id454ba7d0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to generation-skipping transfers (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s2611"},"text":"section 2611 of this title","children":[],"tail":") made after "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1433"},"text":"section 1433 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2601"},"text":"section 2601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
