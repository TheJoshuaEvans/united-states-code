ce, or gift tax marital deductions, but that in the case of the estate of an individual dying before the date 3 years after "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", or a gift by an individual before the date 3 years after "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", the requirement of the preceding provision that the individual not be a citizen or resident of the United States shall not apply, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7815/d/14"},"text":"section 7815(d)(14) of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2056"},"text":"section 2056 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
