{"tag":"section","attrib":{"id":"id45a3d98a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3509"},"text":null,"children":[{"tag":"num","attrib":{"value":"3509"},"text":"§ 3509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of employer’s liability for certain employment taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45a3d98b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3509/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any employer fails to deduct and withhold any tax under chapter 24 or subchapter A of chapter 21 with respect to any employee by reason of treating such employee as not being an employee for purposes of such chapter or subchapter, the amount of the employer’s liability for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45a3d98c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3509/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Tax under chapter 24 for such year with respect to such employee shall be determined as if the amount required to be deducted and withheld were equal to 1.5 percent of the wages (as defined in section 3401) paid to such employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a3d98d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3509/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee social security tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Taxes under subchapter A of chapter 21 with respect to such employee shall be determined as if the taxes imposed under such subchapter were 20 percent of the amount imposed under such subchapter without regard to this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a3d98e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3509/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer’s liability increased where employer disregards reporting requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45a3d98f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3509/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an employer who fails to meet the applicable requirements of section 6041(a), 6041A, or 6051 with respect to any employee, unless such failure is due to reasonable cause and not willful neglect, subsection (a) shall be applied with respect to such employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45a3d990-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3509/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “3 percent” for “1.5 percent” in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a3d991-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3509/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “40 percent” for “20 percent” in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a3d992-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3509/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the term “applicable requirements” means the requirements described in paragraph (1) which would be applicable consistent with the employer’s treatment of the employee as not being an employee for purposes of chapter 24 or subchapter A of chapter 21.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a3d993-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3509/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section not to apply in cases of intentional dis­regard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to the determination of the employer’s liability for tax under chapter 24 or subchapter A of chapter 21 if such liability is due to the employer’s intentional disregard of the requirement to deduct and withhold such tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a3d994-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3509/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45a3d995-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3509/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of liability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the amount of any liability for tax is determined under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45a3d996-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3509/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee’s liability for tax shall not be affected by the assessment or collection of the tax so determined,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a3d997-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3509/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer shall not be entitled to recover from the employee any tax so determined, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a3d998-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3509/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 3402(d) and section 6521 shall not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a3d999-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3509/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section not to apply where employer deducts wage but not social security taxes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply to any employer with respect to any wages if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45a3d99a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3509/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer deducted and withheld any amount of the tax imposed by chapter 24 on such wages, but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a3d99b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3509/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failed to deduct and withhold the amount of the tax imposed by subchapter A of chapter 21 with respect to such wages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a3d99c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3509/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section not to apply to certain statutory employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to any tax under subchapter A of chapter 21 with respect to an individual described in subsection (d)(3) of section 3121 (without regard to whether such individual is described in paragraph (1) or (2) of such subsection).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45a3d99d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tII/s270/a"},"text":"Pub. L. 97–248, title II, § 270(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/553"},"text":"96 Stat. 553","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tII/s2003/d"},"text":"Pub. L. 100–647, title II, § 2003(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3598"},"text":"102 Stat. 3598","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tV/s5130/a/4"},"text":"Pub. L. 101–508, title V, § 5130(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-289"},"text":"104 Stat. 1388–289","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/218"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(218)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1194"},"text":"132 Stat. 1194","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45a3d99e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45a3d99f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45a3d9a0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “section 3402(d)” for “sections 3402(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted “subsection (d)(3)” for “subsection (d)(4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" substituted “subsection (d)(4)” for “subsection (d)(3)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45a3d9a1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45a3d9a2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" effective as if included in the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2003/d"},"text":"Pub. L. 100–647, § 2003(d)","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s5130/b"},"text":"section 5130(b) of Pub. L. 101–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1402"},"text":"section 1402 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45a3d9a3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tII/s270/c"},"text":"Pub. L. 97–248, title II, § 270(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/554"},"text":"96 Stat. 554","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/248/tII/s270/c"},"text":"“The amendment made by this section [enacting this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":"], except that such amendments shall not apply to any assessment made before "},{"tag":"date","attrib":{"date":"1983-01-01"},"text":"January 1, 1983","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
