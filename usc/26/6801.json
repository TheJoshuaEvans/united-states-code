{"tag":"section","attrib":{"id":"id473b9067-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6801"},"text":null,"children":[{"tag":"num","attrib":{"value":"6801"},"text":"§ 6801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for establishment, alteration, and distribution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id473b9068-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6801/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and alteration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish, and from time to time alter, renew, replace, or change the form, style, character, material, and device of any stamp, mark, or label under any provision of the laws relating to internal revenue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id473b9069-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6801/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation and distribution of regulations, forms, stamps and dies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prepare and distribute all the instructions, regulations, directions, forms, blanks, and stamps; and shall provide proper and sufficient adhesive stamps and other stamps or dies for expressing and denoting the several stamp taxes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id473b906a-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/829"},"text":"68A Stat. 829","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/569/s2"},"text":"Pub. L. 94–569, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-20"},"text":"Oct. 20, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2699"},"text":"90 Stat. 2699","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s454/c/13"},"text":"Pub. L. 98–369, div. A, title IV, § 454(c)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/822"},"text":"98 Stat. 822","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id473b906b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id473b906c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id473b906d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" struck out “, except that stamps required by or prescribed pursuant to the provisions of section 5205 or section 5235 may be prepared and distributed by persons authorized by the Secretary, under such controls for the protection of the revenue as shall be deemed necessary” before the period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/94/569"},"text":"Pub. L. 94–569","children":[],"tail":" struck out “or his delegate” after “Secretary” and provided that stamps required by or prescribed pursuant to the provisions of section 5205 or section 5235 may be prepared and distributed by persons authorized by the Secretary, under such controls for the protection of the revenue as shall be deemed necessary."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id473b906e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id473b906f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-07-01"},"text":"July 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s456/b"},"text":"section 456(b) of Pub. L. 98–369","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5101"},"text":"section 5101