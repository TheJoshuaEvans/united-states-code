{"tag":"section","attrib":{"id":"id479d6001-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7810"},"text":null,"children":[{"tag":"num","attrib":{"value":"7810"},"text":"§ 7810.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revolving fund for redemption of real property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id479d6002-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7810/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a revolving fund, under the control of the Secretary, which shall be available without fiscal year limitation for all expenses necessary for the redemption (by the Secretary) of real property as provided in section 7425(d) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2410"},"text":"section 2410 of title 28","children":[],"tail":" of the United States Code. There are authorized to be appropriated from time to time such sums (not to exceed $10,000,000 in the aggregate) as may be necessary to carry out the purposes of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id479d6003-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7810/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fund shall be reimbursed from the proceeds of a subsequent sale of real property redeemed by the United States in an amount equal to the amount expended out of such fund for such redemption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id479d6004-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7810/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System of accounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall maintain an adequate system of accounts for such fund and prepare annual reports on the basis of such accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id479d6005-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/719/tI/s112/a"},"text":"Pub. L. 89–719, title I, § 112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1145"},"text":"80 Stat. 1145","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s443"},"text":"Pub. L. 98–369, div. A, title IV, § 443","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/816"},"text":"98 Stat. 816","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id479d6006-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id479d6007-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id479d6008-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “$10,000,000” for “$1,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id479d6009-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id479d600a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable after ","children":[{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", regardless of when title or lien of United States arose or when lien or interest of another person was acquired, with certain exceptions, see section 114(a)–(c) of "},{"tag":"ref","attrib":{"href":"/us/pl/89/719"},"text":"Pub. L. 89–719","children":[],"tail":", set out as an Effective Date of 1966 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6323"},"text":"section 6323 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
