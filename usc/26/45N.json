{"tag":"section","attrib":{"id":"id40d7d2f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45N"},"text":null,"children":[{"tag":"num","attrib":{"value":"45N"},"text":"§ 45N.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mine rescue team training credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40d7d2f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45N/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of credit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of section 38, the mine rescue team training credit determined under this section with respect to each qualified mine rescue team employee of an eligible employer for any taxable year is an amount equal to the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d7d2f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45N/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 20 percent of the amount paid or incurred by the taxpayer during the taxable year with respect to the training program costs of such qualified mine rescue team employee (including wages of such employee while attending such program), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d7d2f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45N/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d7d2f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45N/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified mine rescue team employee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified mine rescue team employee” means with respect to any taxable year any full-time employee of the taxpayer who is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d7d2f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45N/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a miner eligible for more than 6 months of such taxable year to serve as a mine rescue team member as a result of completing, at a minimum, an initial 20-hour course of instruction as prescribed by the Mine Safety and Health Administration’s Office of Educational Policy and Development, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d7d2f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45N/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a miner eligible for more than 6 months of such taxable year to serve as a mine rescue team member by virtue of receiving at least 40 hours of refresher training in such instruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d7d2f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45N/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible employer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “eligible employer” means any taxpayer which employs individuals as miners in underground mines in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d7d2f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45N/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “wages” has the meaning given to such term by subsection (b) of section 3306 (determined without regard to any dollar limitation contained in such section).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d7d2f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45N/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"December 31, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id40d7d2fa-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s405/a"},"text":"Pub. L. 109–432, div. A, title IV, § 405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2957"},"text":"120 Stat. 2957","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dC/tIII/s310"},"text":"Pub. L. 110–343, div. C, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3869"},"text":"122 Stat. 3869","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/312/tVII