{"tag":"section","attrib":{"id":"id43d7a53f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585"},"text":null,"children":[{"tag":"num","attrib":{"value":"585"},"text":"§ 585.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserves for losses on loans of banks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43d7a540-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve for bad debts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43d7a541-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (c), a bank shall be allowed a deduction for a reasonable addition to a reserve for bad debts. Such deduction shall be in lieu of any deduction under section 166(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43d7a542-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bank","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43d7a543-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bank” means any bank (as defined in section 581).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43d7a544-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Banking business of United States branch of foreign corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bank” also includes any corporation to which subparagraph (A) would apply except for the fact that it is a foreign corporation. In the case of any such foreign corporation, this section shall apply only with respect to loans outstanding the interest on which is effectively connected with the conduct of a banking business within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43d7a545-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Addition to reserves for bad debts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43d7a546-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), the reasonable addition to the reserve for bad debts of any financial institution to which this section applies shall be an amount determined by the taxpayer which shall not exceed the addition to the reserve for losses on loans determined under the experience method as provided in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43d7a547-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Experience method","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount determined under this paragraph for a taxable year shall be the amount necessary to increase the balance of the reserve for losses on loans (at the close of the taxable year) to the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43d7a548-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount which bears the same ratio to loans outstanding at the close of the taxable year as (i) the total bad debts sustained during the taxable year and the 5 preceding taxable years (or, with the approval of the Secretary, a shorter period), adjusted for recoveries of bad debts during such period, bears to (ii) the sum of the loans outstanding at the close of such 6 or fewer taxable years, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43d7a549-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lower of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43d7a54a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the balance of the reserve at the close of the base year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43d7a54b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the amount of loans outstanding at the close of the taxable year is less than the amount of loans outstanding at the close of the base year, the amount which bears the same ratio to loans outstanding at the close of the taxable year as the balance of the reserve at the close of the base year bears to the amount of loans outstanding at the close of the base year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of this paragraph, the base year shall be the last taxable year before the most recent adoption of the experience method, except that for taxable years beginning after 1987 the base year shall be the last taxable year beginning before 1988.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43d7a54c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations; definition of loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall define the term loan and prescribe such regulations as may be necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43d7a54d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section not to apply to large banks","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43d7a54e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a large bank, this section shall not apply (and no deduction shall be allowed under any other provision of this subtitle for any addition to a reserve for bad debts).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43d7a54f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Large banks","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, a bank is a large bank if, for the taxable year (or for any preceding taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":")—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43d7a550-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average adjusted bases of all assets of such bank exceeded $500,000,000, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43d7a551-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such bank was a member of a parent-subsidiary controlled group and the average adjusted bases of all assets of such group exceeded $500,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43d7a552-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 4-year spread of adjustments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43d7a553-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (4), in the case of any bank which for its last taxable year before the disqualification year maintained a reserve for bad debts—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43d7a554-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of this subsection shall be treated as a change in the method of accounting of such bank for the disqualification year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43d7a555-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such change shall be treated as having been made with the consent of the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43d7a556-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the net amount of adjustments required by section 481(a) to be taken into account by the taxpayer shall be taken into account in each of the 4 taxable years beginning with the disqualification year with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id43d7a557-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount taken into account for the 1st of such taxable years being the greater of 10 percent of such net amount or such higher percentage of such net amount as the taxpayer may elect, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id43d7a558-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount taken into account in each of the 3 succeeding taxable years being equal to the applicable fraction (determined in accordance with the following table for the taxable year involved) of the portion of such net amount not taken into account under subclause (I).","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id43d9ef49-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":"The applicable","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":"    If the case of the—","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":"fraction is—","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"     1st succeeding year","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:sup","attrib":{},"text":"2","children":[],"tail":"⁄"},{"tag":"html:sub","attrib":{},"text":"9","children":[],"tail":"  "}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"     2nd succeeding year","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"⅓  ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"     3rd succeeding year","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:sup","attrib":{},"text":"4","children":[],"tail":"⁄"},{"tag":"html:sub","attrib":{},"text":"9","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43d9ef4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of recapture for taxable year for which bank is financially troubled","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43d9ef4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a bank which is a financially troubled bank for any taxable year—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id43d9ef4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no adjustment shall be taken into account under subparagraph (A) for such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id43d9ef4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such taxable year shall be disregarded in determining whether any other taxable year is a taxable year for which an adjustment is required to be taken into account under subparagraph (A) or the amount of such adjustment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43d9ef4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for elective recapture for 1st year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Clause (i) shall not apply to the 1st taxable year referred to in subparagraph (A)(iii)(I) if the taxpayer elects a higher percentage in accordance with such subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43d9ef4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financially troubled bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of clause (i), the term “financially troubled bank” means any bank if, for the taxable year, the nonperforming loan percentage of such bank exceeds 75 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43d9ef50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonperforming loan percentage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of clause (iii), the term “nonperforming loan percentage” means the percentage determined by dividing—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id43d9ef51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the outstanding balances of nonperforming loans of the bank as of the close of each quarter of the taxable year, by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id43d9ef52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the amounts of equity of the bank as of the close of each such quarter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" In the case of a bank which is a member of a parent-subsidiary controlled group for the taxable year, the preceding sentence shall be applied with respect to such group.","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43d9ef53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subparagraph—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id43d9ef54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3/B/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonperforming loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nonperforming loan” means any loan which is considered to be nonperforming by the primary Federal regulatory agency with respect to the bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id43d9ef55-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3/B/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “equity” means the equity of the bank as determined for Federal regulatory purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43d9ef56-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with estimated tax payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of applying section 6655(e)(2)(A)(i) with respect to any installment, the determination under subparagraph (B) of whether an adjustment is required to be taken into account under subparagraph (A) shall be made as of the last day prescribed for payment of such installment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43d9ef57-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elective cut-off method","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a bank makes an election under this paragraph for the disqualification year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43d9ef58-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of this subsection shall not be treated as a change in the method of accounting of the taxpayer for purposes of section 481,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43d9ef59-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer shall continue to maintain its reserve for loans held by the bank as of the 1st day of the disqualification year and charge against such reserve any losses resulting from loans held by the bank as of such 1st day, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43d9ef5a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no deduction shall be allowed under this section (or any other provision of this subtitle) for any addition to such reserve for the disqualification year or any subsequent taxable year.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If the amount of the reserve referred to in subparagraph (B) as of the close of any taxable year exceeds the outstanding balance (as of such time) of the loans referred to in subparagraph (B), such excess shall be included in gross income for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43d9ef5b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43d9ef5c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parent-subsidiary controlled group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “parent-subsidiary controlled group” means any controlled group of corporations described in section 1563(a)(1). In determining the average adjusted bases of assets held by such a group, interests held by one member of such group in another member of such group shall be disregarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43d9ef5d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualification year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “disqualification year” means, with respect to any bank, the 1st taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", for which such bank was a large bank if such bank maintained a reserve for bad debts for the preceding taxable year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43d9ef5e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s585/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election made by each member","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a parent-subsidiary controlled group, any election under this section shall be made separately by each member of such group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43d9ef5f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIV/s431/a"},"text":"Pub. L. 91–172, title IV, § 431(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/616"},"text":"83 Stat. 616","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tII/s267/a"},"text":"Pub. L. 97–34, title II, § 267(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/266"},"text":"95 Stat. 266","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tIX/s901/a"},"text":"Pub. L. 99–514, title IX, § 901(a)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2375"},"text":"100 Stat. 2375","children":[],"tail":", 2378; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10301/b/2"},"text":"Pub. L. 100–203, title X, § 10301(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-429"},"text":"101 Stat. 1330–429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1009/a/2"},"text":"Pub. L. 100–647, title I, § 1009(a)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3445"},"text":"102 Stat. 3445","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11801/a/26"},"text":"Pub. L. 101–508, title XI, § 11801(a)(26)","children":[],"tail":", (c)(12)(C)–(E), "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-521"},"text":"104 Stat. 1388–521","children":[],"tail":", 1388–527; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1616/b/6"},"text":"Pub. L. 104–188, title I, § 1616(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1856"},"text":"110 Stat. 1856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43d9ef60-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43d9ef61-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43d9ef62-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" struck out “other than an organization to which section 593 applies” after “section 581)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11801/c/12/C"},"text":"Pub. L. 101–508, § 11801(c)(12)(C)","children":[],"tail":", substituted “shall not exceed the addition to the reserve for losses on loans determined under the experience method as provided in paragraph (2).” for “shall not exceed the greater of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) for taxable years beginning before 1988 the addition to the reserve for losses on loans determined under the percentage method as provided in paragraph (2), or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the addition to the reserve for losses on loans determined under the experience method as provided in paragraph (3).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11801/a/26"},"text":"Pub. L. 101–508, § 11801(a)(26)","children":[],"tail":", (c)(12)(D), redesignated par. (3) as (2) and struck out former par. (2) which related to use of percentage method for determining amount to add to reserve for bad debts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11801/c/12/D"},"text":"Pub. L. 101–508, § 11801(c)(12)(D)","children":[],"tail":", (E), redesignated par. (4) as (3), substituted heading for one which read: “Regulations; definition of eligible loan, etc.”, and amended text generally. Prior to amendment, text read as follows: “The Secretary shall define the terms ‘loan’ and ‘eligible loan’ and prescribe such regulations as may be necessary to carry out the purposes of this section; except that the term ‘eligible loan’ shall not include—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) a loan to a bank (as defined in section 581),","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) a loan to a domestic branch of a foreign corporation to which subsection (a)(2) applies,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) a loan secured by a deposit (i) in the lending bank, or (ii) in an institution described in subparagraph (A) or (B) if the lending bank has control over withdrawal of such deposit,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) a loan to or guaranteed by the United States, a possession or instrumentality thereof, or a State or a political subdivision thereof,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) a loan evidenced by a security as defined in section 165(g)(2)(C),","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(F) a loan of Federal funds, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(G) commercial paper, including short-term promissory notes which may be purchased on the open market.” Former par. (3) redesignated (2).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11801/c/12/D"},"text":"Pub. L. 101–508, § 11801(c)(12)(D)","children":[],"tail":", redesignated par. (4) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c)(3)(A)(iii)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1009/a/2/B"},"text":"Pub. L. 100–647, § 1009(a)(2)(B)","children":[],"tail":", substituted “such higher percentage of such net amount as the taxpayer may elect” for “such greater amount as the taxpayer may designate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1009/a/2/C"},"text":"Pub. L. 100–647, § 1009(a)(2)(C)","children":[],"tail":", substituted “elects a higher percentage” for “designates an amount”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1009/a/3"},"text":"Pub. L. 100–647, § 1009(a)(3)","children":[],"tail":", inserted at end “If the amount of the reserve referred to in subparagraph (B) as of the close of any taxable year exceeds the outstanding balance (as of such time) of the loans referred to in subparagraph (B), such excess shall be included in gross income for such taxable year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1009/a/2/A"},"text":"Pub. L. 100–647, § 1009(a)(2)(A)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (c)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" substituted “section 6655(e)(2)(A)(i)” for “section 6655(d)(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s901/a/1"},"text":"Pub. L. 99–514, § 901(a)(1)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “This section shall apply to the following financial institutions:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) any bank (as defined in section 581) other than an organization to which section 593 applies, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) any corporation to which paragraph (1) would apply except for the fact that it is a foreign corporation, and in the case of any such foreign corporation this section shall apply only with respect to loans outstanding the interest on which is effectively connected with the conduct of a banking business within the United States.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s901/d/1"},"text":"Pub. L. 99–514, § 901(d)(1)","children":[],"tail":", substituted “subsection (a)” for “section 166(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s901/a/2"},"text":"Pub. L. 99–514, § 901(a)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" defined “allowable percentage” to mean 1.0 percent for taxable years beginning in 1982 and 0.6 percent for taxable years beginning after 1982, previously so applicable for taxable years beginning after 1981 and redefined “base year” by substituting the last taxable year beginning before 1976 for taxable years beginning after 1975 but before 1983, for the last taxable year beginning before 1976 for taxable years after 1975 but before 1982; and the last taxable year beginning before 1983 for taxable years beginning after 1982, for the last taxable year beginning before 1982 for taxable years beginning after 1981."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43d9ef63-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43d9ef64-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1995-12-31"},"text":"Dec. 31, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1616/c"},"text":"section 1616(c) of Pub. L. 104–188","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s593"},"text":"section 593 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43d9ef65-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{