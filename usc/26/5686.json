{"tag":"section","attrib":{"id":"id46439c95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5686"},"text":null,"children":[{"tag":"num","attrib":{"value":"5686"},"text":"§ 5686.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for having, possessing, or using liquor or property intended to be used in violating provisions of this chapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46439c96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5686/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful to have or possess any liquor or property intended for use in violating any provision of this chapter or regulations issued pursuant thereto, or which has been so used, and every person so having or possessing or using such liquor or property, shall be fined not more than $5,000, or imprisoned not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46439c97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5686/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For seizure and forfeiture of liquor and property had, possessed, or used in violation of subsection (a), see section 7302.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46439c98-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1411"},"text":"72 Stat. 1411","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46439c99-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46439c9a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46439c9b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5686, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/700"},"text":"68A Stat. 700","children":[],"tail":", consisted in subsecs. (b) and (c) of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior section 5686(a) related to offenses as to operation of industrial alcohol or denaturing plants or unlawful withdrawal of taxable alcohol. See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s5687"},"text":"section 5687 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
