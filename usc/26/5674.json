{"tag":"section","attrib":{"id":"id46439c3d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5674"},"text":null,"children":[{"tag":"num","attrib":{"value":"5674"},"text":"§ 5674.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for unlawful production or removal of beer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46439c3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5674/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful production","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who brews beer or produces beer shall be fined not more than $1,000, or imprisoned not more than 1 year, or both, unless such beer is brewed or produced in a brewery qualified under subchapter G or such production is exempt from tax under section 5053(e) (relating to beer for personal or family use).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46439c3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5674/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any brewer or other person who removes or in any way aids in the removal from any brewery of beer without complying with the provisions of this chapter or regulations issued pursuant thereto shall be fined not more than $1,000, or imprisoned not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46439c40-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1408"},"text":"72 Stat. 1408","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/458/s2/b/5/A"},"text":"Pub. L. 95–458, § 2(b)(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-14"},"text":"Oct. 14, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1256"},"text":"92 Stat. 1256","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46439c41-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46439c42-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46439c43-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5674, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/696"},"text":"68A Stat. 696","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46439c44-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/458"},"text":"Pub. L. 95–458","children":[],"tail":" substituted “production or removal” for “removal” in section catchline, redesignated existing provision as subsec. (b), and added subsec. (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46439c45-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46439c46-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/458"},"text":"Pub. L. 95–458","children":[],"tail":" effective on first day of first calendar month beginning more than 90 days after "},{"tag":"date","attrib":{"date":"1978-10-14"},"text":"Oct. 14, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/458/s2/c"},"text":"section 2(c) of Pub. L. 95–458","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5042"},"text":"section 5042 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
