{"tag":"section","attrib":{"id":"id43fb59fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s701"},"text":null,"children":[{"tag":"num","attrib":{"value":"701"},"text":"§ 701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partners, not partnership, subject to tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A partnership as such shall not be subject to the income tax imposed by this chapter. Persons carrying on business as partners shall be liable for income tax only in their separate or individual capacities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id43fb59fd-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/239"},"text":"68A Stat. 239","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
