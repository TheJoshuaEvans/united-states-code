{"tag":"section","attrib":{"id":"id45420a47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2513"},"text":null,"children":[{"tag":"num","attrib":{"value":"2513"},"text":"§ 2513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gift by husband or wife to third party","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45420a48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considered as made one-half by each","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45420a49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2513/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A gift made by one spouse to any person other than his spouse shall, for the purposes of this chapter, be considered as made one-half by him and one-half by his spouse, but only if at the time of the gift each spouse is a citizen or resident of the United States. This paragraph shall not apply with respect to a gift by a spouse of an interest in property if he creates in his spouse a general power of appointment, as defined in section 2514(c), over such interest. For purposes of this section, an individual shall be considered as the spouse of another individual only if he is married to such individual at the time of the gift and does not remarry during the remainder of the calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45420a4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2513/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent of both spouses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall apply only if both spouses have signified (under the regulations provided for in subsection (b)) their consent to the application of paragraph (1) in the case of all such gifts made during the calendar year by either while married to the other.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45420a4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner and time of signifying consent","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45420a4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2513/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":" A consent under this section shall be signified in such manner as is provided under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45420a4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2513/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such consent may be so signified at any time after the close of the calendar year in which the gift was made, subject to the following limitations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45420a4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2513/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The consent may not be signified after the 15th day of April following the close of such year, unless before such 15th day no return has been filed for such year by either spouse, in which case the consent may not be signified after a return for such year is filed by either spouse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45420a4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2513/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The consent may not be signified after a notice of deficiency with respect to the tax for such year has been sent to either spouse in accordance with section 6212(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45420a50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2513/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation of consent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Revocation of a consent previously signified shall be made in such manner as in provided under regulations prescribed by the Secretary, but the right to revoke a consent previously signified with respect to a calendar year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45420a51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2513/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not exist after the 15th day of April following the close of such year if the consent was signified on or before such 15th day; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45420a52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2513/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not exist if the consent was not signified until after such 15th day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45420a53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2513/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint and several liability for tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the consent required by subsection (a)(2) is signified with respect to a gift made in any calendar year, the liability with respect to the entire tax imposed by this chapter of each spouse for such year shall be joint and several.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45420a54-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/406"},"text":"68A Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/614/tI/s102/b/2"},"text":"Pub. L. 91–614, title I, § 102(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1840"},"text":"84 Stat. 1840","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV/s442/b/2"},"text":"Pub. L. 97–34, title IV, § 442(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/322"},"text":"95 Stat. 322","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45420a55-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45420a56-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45420a57-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s442/b/2/A"},"text":"Pub. L. 97–34, § 442(b)(2)(A)","children":[],"tail":", substituted “calendar year” for “calendar quarter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s442/b/2/B"},"text":"Pub. L. 97–34, § 442(b)(2)(B)","children":[],"tail":"–(D), in introductory text, substituted “calendar year” for “calendar quarter”, in subpar. (A), substituted “The consent” for “the consent”, “15th day of April following the close of such year” for “15th day of the second month following the close of such calendar quarter”, and “such year” for “such calendar quarter” in two other places, and in subpar. (B) substituted “The consent” and “such year” for “the consent” and “such calendar quarter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s442/b/2/E"},"text":"Pub. L. 97–34, § 442(b)(2)(E)","children":[],"tail":", in provision preceding par. (1) substituted “calendar year” for “calendar quarter” and in par. (1) “15th day of April following the close of such year” for “15th day of the second month following the close of such quarter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s442/b/2/F"},"text":"Pub. L. 97–34, § 442(b)(2)(F)","children":[],"tail":", substituted “any calendar year” and “such year” for “any calendar quarter” and “such calendar quarter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (b)(1), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsecs. (a), (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614/s102/b/2/A"},"text":"Pub. L. 91–614, § 102(b)(2)(A)","children":[],"tail":", substituted “calendar quarter” for “calendar year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614/s102/b/2/B"},"text":"Pub. L. 91–614, § 102(b)(2)(B)","children":[],"tail":", substituted “the 15th day of the second month” for “the 15th day of April” and substituted “such calendar quarter” for “such year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614/s102/b/2/C"},"text":"Pub. L. 91–614, § 102(b)(2)(C)","children":[],"tail":", substituted “such calendar quarter” for “such year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614/s102/b/2/A"},"text":"Pub. L. 91–614, § 102(b)(2)(A)","children":[],"tail":", substituted “calendar quarter” for “calendar year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614/s102/b/2/D"},"text":"Pub. L. 91–614, § 102(b)(2)(D)","children":[],"tail":", substituted “15th day of the second month following the close of such calendar quarter” for “15th day of April following the close of such year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614/s102/b/2/A"},"text":"Pub. L. 91–614, § 102(b)(2)(A)","children":[],"tail":", (E), substituted “calendar quarter” for “calendar year” and “such calendar quarter” for “such year”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45420a58-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45420a59-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" applicable with respect to gifts made after "},{"tag":"date","attrib":{"date":"1981-12-31"},"text":"Dec. 31, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/s442/e"},"text":"section 442(e) of Pub. L. 97–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2501"},"text":"section 2501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45420a5a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/9