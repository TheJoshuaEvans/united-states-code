{"tag":"section","attrib":{"id":"id472aef41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6677"},"text":null,"children":[{"tag":"num","attrib":{"value":"6677"},"text":"§ 6677.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to file information with respect to certain foreign trusts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id472aef42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6677/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any criminal penalty provided by law, if any notice or return required to be filed by section 6048—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472aef43-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6677/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not filed on or before the time provided in such section, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472aef44-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6677/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include all the information required pursuant to such section or includes incorrect information,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the person required to file such notice or return shall pay a penalty equal to the greater of $10,000 or 35 percent of the gross reportable amount. If any failure described in the preceding sentence continues for more than 90 days after the day on which the Secretary mails notice of such failure to the person required to pay such penalty, such person shall pay a penalty (in addition to the amount determined under the preceding sentence) of $10,000 for each 30-day period (or fraction thereof) during which such failure continues after the expiration of such 90-day period. At such time as the gross reportable amount with respect to any failure can be determined by the Secretary, any subsequent penalty imposed under this subsection with respect to such failure shall be reduced as necessary to assure that the aggregate amount of such penalties do not exceed the gross reportable amount (and to the extent that such aggregate amount already exceeds the gross reportable amount the Secretary shall refund such excess to the taxpayer).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472aef45-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6677/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for returns under section 6048(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a return required under section 6048(b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472aef46-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6677/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States person referred to in such section shall be liable for the penalty imposed by subsection (a), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472aef47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6677/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a) shall be applied by substituting “5 percent” for “35 percent”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472aef48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6677/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gross reportable amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the term “gross reportable amount” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472aef49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6677/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross value of the property involved in the event (determined as of the date of the event) in the case of a failure relating to section 6048(a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472aef4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6677/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross value of the portion of the trust’s assets at the close of the year treated as owned by the United States person in the case of a failure relating to section 6048(b)(1), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472aef4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6677/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross amount of the distributions in the case of a failure relating to section 6048(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472aef4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6677/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable cause exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed by this section on any failure which is shown to be due to reasonable cause and not due to willful neglect. The fact that a foreign jurisdiction would impose a civil or criminal penalty on the taxpayer (or any other person) for disclosing the required information is not reasonable cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472aef4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6677/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deficiency procedures not to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subchapter B of chapter 63 (relating to deficiency procedures for income, estate, gift, and certain excise taxes) shall not apply in respect of the assessment or collection of any penalty imposed by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id472aef4e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/834/s7/g"},"text":"Pub. L. 87–834, § 7(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-16"},"text":"Oct. 16, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/988"},"text":"76 Stat. 988","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tI/s101/j/53"},"text":"Pub. L. 91–172, title I, § 101(j)(53)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/531"},"text":"83 Stat. 531","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/406/tII/s1016/a/21"},"text":"Pub. L. 93–406, title II, § 1016(a)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/931"},"text":"88 Stat. 931","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tX/s1013/d/2"},"text":"Pub. L. 94–455, title X, § 1013(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1616"},"text":"90 Stat. 1616","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1901/b"},"text":"Pub. L. 104–188, title I, § 1901(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1907"},"text":"110 Stat. 1907","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/147/tV/s535/a"},"text":"Pub. L. 111–147, title V, § 535(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-18"},"text":"Mar. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/115"},"text":"124 Stat. 115","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id472aef4f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id472aef50-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id472aef51-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/147"},"text":"Pub. L. 111–147","children":[],"tail":", in concluding provisions, inserted “the greater of $10,000 or” before “35 percent” and substituted “At such time as the gross reportable amount with respect to any failure can be determined by the Secretary, any subsequent penalty imposed under this subsection with respect to such failure shall be reduced as necessary to assure that the aggregate amount of such penalties do not exceed the gross reportable amount (and to the extent that such aggregate amount already exceeds the gross reportable amount the Secretary shall refund such excess to the taxpayer).” for “In no event shall the penalty under this subsection with respect to any failure exceed the gross reportable amount.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1901/b"},"text":"Pub. L. 104–188, § 1901(b)","children":[],"tail":", substituted “information” for “information returns” in section catchline and amended text generally, substituting present provisions for former provisions which related to civil penalty in subsec. (a) and nonapplicability of deficiency procedures in subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" inserted “(or, in the case of a failure with respect to section 6048(c), equal to 5 percent of the value of the corpus of the trust at the close of the taxable year)” after “transferred to a trust”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406"},"text":"Pub. L. 93–406","children":[],"tail":" substituted “and certain excise” for “chapter 42”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" inserted reference to chapter 42 taxes."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id472aef52-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id472aef53-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/147/tV/s535/b"},"text":"Pub. L. 111–147, title V, § 535(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-18"},"text":"Mar. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/115"},"text":"124 Stat. 115","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/147/tV/s535/b"},"text":"“The amendments made by this section [amending this section] shall apply to notices and returns required to be filed after ","children":[{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id472aef54-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":", to the extent related to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6048/a"},"text":"section 6048(a) of this title","children":[],"tail":", applicable to reportable events (as defined in such section) occurring after "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", to the extent related to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6048/b"},"text":"section 6048(b) of this title","children":[],"tail":", applicable to taxable years of United States persons beginning after "},{"tag":"date","attrib":{"date":"1995-12-31"},"text":"Dec. 31, 1995","children":[],"tail":", and to the extent related to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6048/c"},"text":"section 6048(c) of this title","children":[],"tail":", applicable to distributions received after "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1901/d"},"text":"section 1901(d) of Pub. L. 104–188","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6048"},"text":"section 6048 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id472aef55-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" applicable to taxable years ending after "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", but only in the case of foreign trusts created after "},{"tag":"date","attrib":{"date":"1974-05-21"},"text":"May 21, 1974","children":[],"tail":" and transfer of property to foreign trusts after "},{"tag":"date","attrib":{"date":"1974-05-21"},"text":"May 21, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1013/f/1"},"text":"section 1013(f)(1) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s679"},"text":"section 679 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id472aef56-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406"},"text":"Pub. L. 93–406","children":[],"tail":" applicable, except as otherwise provided in section 1017(c) through (i) of "},{"tag":"ref","attrib":{"href":"/us/pl/93/406"},"text":"Pub. L. 93–406","children":[],"tail":", for plan years beginning after "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", but, in the case of plans in existence on "},{"tag":"date","attrib":{"date":"1974-01-01"},"text":"Jan. 1, 1974","children":[],"tail":", amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/93/406"},"text":"Pub. L. 93–406","children":[],"tail":" applicable for plan years beginning after "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/406/s1017"},"text":"section 1017 of Pub. L. 93–406","children":[],"tail":", set out as an Effective Date; Transitional Rules note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s410"},"text":"section 410 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id472aef57-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1969 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/s101/k/1"},"text":"section 101(k)(1) of Pub. L. 91–172","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"hre