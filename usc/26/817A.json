{"tag":"section","attrib":{"id":"id4410dd7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A"},"text":null,"children":[{"tag":"num","attrib":{"value":"817A"},"text":"§ 817A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for modified guaranteed contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4410dd7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of reserves","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a modified guaranteed contract, clause (ii) of section 807(e)(1)(A) shall not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4410dd7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Segregated assets under modified guaranteed contracts marked to market","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4410dd7d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any life insurance company, for purposes of this subtitle—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4410dd7e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any gain or loss with respect to a segregated asset shall be treated as ordinary income or loss, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4410dd7f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If any segregated asset is held by such company as of the close of any taxable year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4410dd80-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such company shall recognize gain or loss as if such asset were sold for its fair market value on the last business day of such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4410dd81-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any such gain or loss shall be taken into account for such taxable year.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Proper adjustment shall be made in the amount of any gain or loss subsequently realized for gain or loss taken into account under the preceding sentence. The Secretary may provide by regulations for the application of this subparagraph at times other than the times provided in this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4410dd82-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Segregated asset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the term “segregated asset” means any asset held as part of a segregated account referred to in subsection (d)(1) under a modified guaranteed contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4410dd83-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule in computing life insurance reserves","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of applying section 816(b)(1)(A) to any modified guaranteed contract, an assumed rate of interest shall include a rate of interest determined, from time to time, with reference to a market rate of interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4410dd84-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modified guaranteed contract defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “modified guaranteed contract” means a contract not described in section 817—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4410dd85-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all or part of the amounts received under which are allocated to an account which, pursuant to State law or regulation, is segregated from the general asset accounts of the company and is valued from time to time with reference to market values,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4410dd86-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4410dd87-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for the payment of annuities,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4410dd88-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a life insurance contract, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4410dd89-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a pension plan contract which is not a life, accident, or health, property, casualty, or liability contract,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4410dd8a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which reserves are valued at market for annual statement purposes, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4410dd8b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which provides for a net surrender value or a policyholder’s fund (as defined in section 807(e)(1)).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If only a portion of a contract is not described in section 817, such portion shall be treated for purposes of this section as a separate contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4410dd8c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may prescribe regulations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4410dd8d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the treatment of market value adjustments under sections 72, 7702, 7702A, and 807(e)(1)(B),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4410dd8e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the interest rates applicable under sections 807(c)(3) and 807(d)(2)(B) with respect to a modified guaranteed contract annually, in a manner appropriate for modified guaranteed contracts and, to the extent appropriate for such a contract, to modify or waive the applicability of section 811(d),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4410dd8f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide rules to limit ordinary gain or loss treatment to assets constituting reserves for modified guaranteed contracts (and not other assets) of the company,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4410dd90-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide appropriate treatment of transfers of assets to and from the segregated account, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4410dd91-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s817A/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as may be necessary or appropriate to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4410dd92-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1612/a"},"text":"Pub. L. 104–188, title I, § 1612(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1846"},"text":"110 Stat. 1846","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13518/b"},"text":"Pub. L. 115–97, title I, § 13518(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2148"},"text":"131 Stat. 2148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4410dd93-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4410dd94-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4410dd95-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" substituted “and 807(d)(2)(B)” for “, 807(d)(2)(B), and 812”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4410dd96-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4410dd97-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13518/c"},"text":"section 13518(c) of Pub. L. 115–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s812"},"text":"section 812 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4410dd98-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1612/c"},"text":"Pub. L. 104–188, title I, § 1612(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1847"},"text":"110 Stat. 1847","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/188/tI/s1612/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of net adjustments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (3), in the case of any taxpayer required by the amendments made by this section to change its calculation of reserves to take into account market value adjustments and to mark segregated assets to market for any taxable year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such changes shall be treated as a change in method of accounting initiated by the taxpayer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such changes shall be treated as made with the consent of the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjustments required by reason of section 481 of the Internal Revenue Code of 1986, shall be taken into account as ordinary income by the taxpayer for the taxpayer’s first taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on loss recognition and on deduction for reserve increases.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on loss recognition.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The aggregate loss recognized by reason of the application of section 481 of the Internal Revenue Code of 1986 with respect to section 817A(b) of such Code (as added by this section) for the first taxable year of the taxpayer beginning after ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":", shall not exceed the amount included in the taxpayer’s gross income for such year by reason of the excess (if any) of—"}],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"“(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of life insurance reserves as of the close of the prior taxable year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"“(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such reserves as of the beginning of such first taxable year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"  to the extent such excess is attributable to subsection (a) of such section 817A. Notwithstanding the preceding sentence, the adjusted basis of each segregated asset shall be determined as if all such losses were recognized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disallowed loss allowed over period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of the loss which is not allowed under clause (i) shall be allowed ratably over the period of 7 taxable years beginning with the taxpayer’s first taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on deduction for increase in reserves.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The deduction allowed for the first taxable year of the taxpayer beginning after ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":", by reason of the application of section 481 of such Code with respect to section 817A(a) of such Code (as added by this section) shall not exceed the aggregate built-in gain recognized by reason of the application of such section 481 with respect to section 817A(b) of such Code (as added by this section) for such first taxable year."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disallowed deduction allowed over period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of the deduction which is disallowed under clause (i) shall be allowed ratably over the period of 7 taxable years beginning with the taxpayer’s first taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Built-in gain","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subparagraph, the built-in gain on an asset is the amount equal to the excess of—","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"“(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of the asset as of the beginning of the first taxable year of the taxpayer beginning after ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":", over"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"“(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjusted basis of such asset as of such time.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
