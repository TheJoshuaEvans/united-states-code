{"tag":"section","attrib":{"id":"id46ac9710-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6114"},"text":null,"children":[{"tag":"num","attrib":{"value":"6114"},"text":"§ 6114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treaty-based return positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46ac9711-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each taxpayer who, with respect to any tax imposed by this title, takes the position that a treaty of the United States overrules (or otherwise modifies) an internal revenue law of the United States shall disclose (in such manner as the Secretary may prescribe) such position—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46ac9712-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the return of tax for such tax (or any statement attached to such return), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ac9713-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if no return of tax is required to be filed, in such form as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46ac9714-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive the requirements of subsection (a) with respect to classes of cases for which the Secretary determines that the waiver will not impede the assessment and collection of tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46ac9715-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/aa/5/A"},"text":"Pub. L. 100–647, title I, § 1012(aa)(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3532"},"text":"102 Stat. 3532","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11702/c"},"text":"Pub. L. 101–508, title XI, § 11702(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-514"},"text":"104 Stat. 1388–514","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46ac9716-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46ac9717-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46ac9718-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6114 was renumbered 6116 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46ac9719-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" struck out “by regulations” before “waive the requirements”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46ac971a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46ac971b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" effective as if included in the provision of the Technical and Miscellaneous Revenue Act of 1988, "},{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11702/j"},"text":"section 11702(j) of Pub. L. 101–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s59"},"text":"section 59 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46ac971c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/aa/5/D"},"text":"Pub. L. 100–647, title I, § 1012(aa)(5)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-