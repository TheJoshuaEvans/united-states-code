{"tag":"section","attrib":{"id":"id4749e924-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345"},"text":null,"children":[{"tag":"num","attrib":{"value":"7345"},"text":"§ 7345.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation or denial of passport in case of certain tax delinquencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4749e925-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary receives certification by the Commissioner of Internal Revenue that an individual has a seriously delinquent tax debt, the Secretary shall transmit such certification to the Secretary of State for action with respect to denial, revocation, or limitation of a passport pursuant to section 32101 of the FAST Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4749e926-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seriously delinquent tax debt","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4749e927-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “seriously delinquent tax debt” means an unpaid, legally enforceable Federal tax liability of an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4749e928-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has been assessed,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4749e929-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is greater than $50,000, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4749e92a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4749e92b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notice of lien has been filed pursuant to section 6323 and the administrative rights under section 6320 with respect to such filing have been exhausted or have lapsed, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4749e92c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a levy is made pursuant to section 6331.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4749e92d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such term shall not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4749e92e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a debt that is being paid in a timely manner pursuant to an agreement to which the individual is party under section 6159 or 7122, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4749e92f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a debt with respect to which collection is suspended with respect to the individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4749e930-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because a due process hearing under section 6330 is requested or pending, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4749e931-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because an election under subsection (b) or (c) of section 6015 is made or relief under subsection (f) of such section is requested.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4749e932-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reversal of certification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4749e933-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual with respect to whom the Commissioner makes a certification under subsection (a), the Commissioner shall notify the Secretary (and the Secretary shall subsequently notify the Secretary of State) if such certification is found to be erroneous or if the debt with respect to such certification is fully satisfied or ceases to be a seriously delinquent tax debt by reason of subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4749e934-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of notice","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4749e935-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full satisfaction of debt","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a debt that has been fully satisfied or has become legally unenforceable, such notification shall be made not later than the date required for issuing the certificate of release of lien with respect to such debt under section 6325(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4749e936-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innocent spouse relief","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual who makes an election under subsection (b) or (c) of section 6015, or requests relief under subsection (f) of such section, such notification shall be made not later than 30 days after any such election or request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4749e937-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Installment agreement or offer-in-compromise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an installment agreement under section 6159 or an offer-in-compromise under section 7122, such notification shall be made not later than 30 days after such agreement is entered into or such offer is accepted by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id474c5938-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Erroneous certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a certification found to be erroneous, such notification shall be made as soon as practicable after such finding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id474c5939-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contemporaneous notice to individual","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall contemporaneously notify an individual of any certification under subsection (a), or any reversal of certification under subsection (c), with respect to such individual. Such notice shall include a description in simple and nontechnical terms of the right to bring a civil action under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id474c593a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review of certification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id474c593b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the Commissioner notifies an individual under subsection (d), the taxpayer may bring a civil action against the United States in a district court of the United States, or against the Commissioner in the Tax Court, to determine whether the certification was erroneous or whether the Commissioner has failed to reverse the certification. For purposes of the preceding sentence, the court first acquiring jurisdiction over such an action shall have sole jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474c593c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the court determines that such certification was erroneous, then the court may order the Secretary to notify the Secretary of State that such certification was erroneous.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id474c593d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment for inflation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a calendar year beginning after 2016, the dollar amount in subsection (b)(1)(B) shall be increased by an amount equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id474c593e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dollar amount, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474c593f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost-of-living adjustment determined under section 1(f)(3) for the calendar year, determined by substituting “calendar year 2015” for “calendar year 2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If any amount as adjusted under the preceding sentence is not a multiple of $1,000, such amount shall be rounded to the nearest multiple of $1,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id474c5940-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7345/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A certification under subsection (a) or reversal of certification under subsection (c) may only be delegated by the Commissioner of Internal Revenue to the Deputy Commissioner for Services and Enforcement, or the Commissioner of an operating division, of the Internal Revenue Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id474c5941-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dC/tXXXII/s32101/a"},"text":"Pub. L. 114–94, div. C, title XXXII, § 32101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1729"},"text":"129 Stat. 1729","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s11002/d/1/RR"},"text":"Pub. L. 115–97, title I, § 11002(d)(1)(RR)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2061"},"text":"131 Stat. 2061","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tI/s103/a"},"text":"Pub. L. 115–141, div. U, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1169"},"text":"132 Stat. 1169","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id474c5942-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id474c5943-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inflation Adjusted Items for Certain Years","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For inflation adjustment of certain items in this section, see Revenue Procedures listed in a table under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id474c5944-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id474c5945-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 32101 of the FAST Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s32101"},"text":"section 32101 of Pub. L. 114–94","children":[],"tail":", which enacted this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2714a"},"text":"section 2714a of Title 22","children":[],"tail":", Foreign Relations and Intercourse, and amended sections 6103, 6320, 6331, and 7508 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id474c5946-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s103/a/1"},"text":"Pub. L. 115–141, § 103(a)(1)","children":[],"tail":", substituted “, or against the Commissioner in the Tax Court,” for “or the Tax Court” and inserted at end “For purposes of the preceding sentence, the court first acquiring jurisdiction over such an action shall have sole jurisdiction.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s103/a/2"},"text":"Pub. L. 115–141, § 103(a)(2)","children":[],"tail":", substituted “subsection (b)(1)(B)” for “subsection (a)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" substituted “for ‘calendar year 2016’ in subparagraph (A)(ii)” for “for ‘calendar year 1992’ in subparagraph (B)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id474c5947-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id474c5948-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tI/s103/b"},"text":"Pub. L. 115–141, div. U, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1170"},"text":"132 Stat. 1170","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/141/dU/tI/s103/b"},"text":"“The amendments made by this section [amending this section] shall take effect as if included in section 32101 of the Fixing America’s Surface Transportation Act [","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id474c5949-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s11002/e"},"text":"section 11002(e) of Pub. L. 115–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
