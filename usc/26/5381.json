{"tag":"section","attrib":{"id":"id4637b574-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5381"},"text":null,"children":[{"tag":"num","attrib":{"value":"5381"},"text":"§ 5381.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natural wine","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Natural wine is the product of the juice or must of sound, ripe grapes or other sound, ripe fruit, made with such cellar treatment as may be authorized under section 5382 and containing not more than 21 percent by weight of total solids. Any wine conforming to such definition except for having become substandard by reason of its condition shall be deemed not to be natural wine, unless the condition is cor­rected.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4637b575-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1383"},"text":"72 Stat. 1383","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/48"},"text":"Pub. L. 96–39, title VIII, § 807(a)(48)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/288"},"text":"93 Stat. 288","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4637b576-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4637b577-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4637b578-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5381, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/668"},"text":"68A Stat. 668","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4637b579-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" struck out provisions authorizing removal for distillation of wine deemed not to be natural wine, destruction of such wine under government supervision, and transfer of such wine to premises in which other than natural wine may be stored or used."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4637b57a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4637b57b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":