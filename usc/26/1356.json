{"tag":"section","attrib":{"id":"id44ec48fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356"},"text":null,"children":[{"tag":"num","attrib":{"value":"1356"},"text":"§ 1356.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying shipping activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44ec48fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying shipping activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the term “qualifying shipping activities” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ec48ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" core qualifying activities,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ec4900-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualifying secondary activities, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ec4901-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualifying incidental activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ec4902-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Core qualifying activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter, the term “core qualifying activities” means activities in operating qualifying vessels in United States foreign trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ec4903-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying secondary activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ec4904-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualifying secondary activities” means secondary activities but only to the extent that, without regard to this subchapter, the gross income derived by such corporation from such activities does not exceed 20 percent of the gross income derived by the corporation from its core qualifying activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ec4905-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secondary activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “secondary activities” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ec4906-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the active management or operation of vessels other than qualifying vessels in the United States foreign trade,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ec4907-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of vessel, barge, container, or cargo-related facilities or services to any person,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ec4908-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" other activities of the electing corporation and other members of its electing group that are an integral part of its business of operating qualifying vessels in United States foreign trade, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44ec4909-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ownership or operation of barges, containers, chassis, and other equipment that are the complement of, or used in connection with, a qualifying vessel in United States foreign trade,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44ec490a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inland haulage of cargo shipped, or to be shipped, on qualifying vessels in United States foreign trade, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44ec490b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of terminal, maintenance, repair, logistical, or other vessel, barge, container, or cargo-related services that are an integral part of operating qualifying vessels in United States foreign trade, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ec490c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other activities as may be prescribed by the Secretary pursuant to regulations.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term shall not include any core qualifying activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ec490d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying incidental activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified incidental activities” means shipping-related activities if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ec490e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" they are incidental to the corporation’s core qualifying activities,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ec490f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" they are not qualifying secondary activities, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ec4910-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to this subchapter, the gross income derived by such corporation from such activities does not exceed 0.1 percent of the corporation’s gross income from its core qualifying activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ec4911-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1356/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of gross income tests in case of electing group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an electing group, subsections (c)(1) and (d)(3) shall be applied as if such group were 1 entity, and the limitations under such subsections shall be allocated among the corporations in such group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44ec4912-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tII/s248/a"},"text":"Pub. L. 108–357, title II, § 248(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1454"},"text":"118 Stat. 1454","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s403/g/3"},"text":"Pub. L. 109–135, title IV, § 403(g)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2624"},"text":"119 Stat. 2624","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44ec4913-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44ec4914-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44ec4915-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/g/3/B"},"text":"Pub. L. 109–135, § 403(g)(3)(B)","children":[],"tail":", inserted concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/g/3/A"},"text":"Pub. L. 109–135, § 403(g)(3)(A)","children":[],"tail":", struck out heading and text of par. (3). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—Such term shall not include any core qualifying activities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) ","children":[{"tag":"inline","attrib":{},"text":"Nonelecting corporations","children":[],"tail":".—In the case of a corporation (other than an electing corporation) which is a member of an electing group, any core qualifying activities of the corporation shall be treated as qualifying secondary activities (and not as core qualifying activities).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44ec4916-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44ec4917-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" effective as if included in the provisions of the American Jobs Creation Act of 2004, "},{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":", to which they relate, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/nn"},"text":"section 403(nn) of Pub. L. 109–135","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s26"},"text":"section 26 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44ec4918-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s248/c"},"text":"section 248(c) of Pub. L. 108–357","children":[],"tail":", set out as an Effective Date of 2004 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s56"},"text":"section 56 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
