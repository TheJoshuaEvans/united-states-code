{"tag":"section","attrib":{"id":"id44c3b2b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1236"},"text":null,"children":[{"tag":"num","attrib":{"value":"1236"},"text":"§ 1236.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dealers in securities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44c3b2b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1236/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital gains","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Gain by a dealer in securities from the sale or exchange of any security shall in no event be considered as gain from the sale or exchange of a capital asset unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44c3b2b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1236/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the security was, before the close of the day on which it was acquired (or such earlier time as the Secretary may prescribe by regulations), clearly identified in the dealer’s records as a security held for investment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c3b2b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1236/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the security was not, at any time after the close of such day (or such earlier time), held by such dealer primarily for sale to customers in the ordinary course of his trade or business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44c3b2b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1236/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ordinary losses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Loss by a dealer in securities from the sale or exchange of any security shall, except as otherwise provided in section 582(c), (relating to bond, etc., losses of banks), in no event be considered as ordinary loss if at any time the security was clearly identified in the dealer’s records as a security held for investment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44c3b2b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1236/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “security” means any share of stock in any corporation, certificate of stock or interest in any corporation, note, bond, debenture, or evidence of indebtedness, or any evidence of an interest in or right to subscribe to or purchase any of the foregoing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44c3b2b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1236/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for floor specialists","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44c3b2b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1236/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a floor specialist (but only with respect to acquisitions, in connection with his duties on an exchange, of stock in which the specialist is registered with the exchange), subsection (a) shall be applied—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44c3b2ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1236/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by inserting “the 7th business day following” before “the day” the first place it appears in paragraph (1) and by inserting “7th business” before “day” in paragraph (2), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44c3b2bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1236/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by striking the parenthetical phrase in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c3b2bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1236/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Floor specialist","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “floor specialist” means a person who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44c3b2bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1236/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of a national securities exchange,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44c3b2be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1236/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is registered as a specialist with the exchange, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44c3b2bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1236/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements for specialists established by the Securities and Exchange Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44c3b2c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1236/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for options","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), any security acquired by a dealer pursuant to an option held by such dealer may be treated as held for investment only if the dealer, before the close of the day on which the option was acquired, clearly identified the option on his records as held for investment. For purposes of the preceding sentence, the term “option” includes the right to subscribe to or purchase any security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44c3b2c1-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/330"},"text":"68A Stat. 330","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1901/b/3/E"},"text":"Pub. L. 94–455, title XIX, § 1901(b)(3)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1793"},"text":"90 Stat. 1793","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tV/s506"},"text":"Pub. L. 97–34, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/332"},"text":"95 Stat. 332","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tI/s105/d/1"},"text":"Pub. L. 97–448, title I, § 105(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2387"},"text":"96 Stat. 2387","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s107/b"},"text":"Pub. L. 98–369, div. A, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/630"},"text":"98 Stat. 630","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/83"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(83)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4049"},"text":"128 Stat. 4049","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44c3b2c2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44c3b2c3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44c3b2c4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" struck out “after "},{"tag":"date","attrib":{"date":"1951-11-19"},"text":"November 19, 1951","children":[],"tail":",” after “time”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s107/b/1"},"text":"Pub. L. 98–369, § 107(b)(1)","children":[],"tail":", substituted “the security was, before the close of the day on which it was acquired (or such earlier time as the Secretary may prescribe by regulations), clearly identified in the dealer’s records as a security held for investment; and” for “the security was, before the close of the day on which it was acquired (before the close of the following day in the case of an acquisition before "},{"tag":"date","attrib":{"date":"1982-01-01"},"text":"January 1, 1982","children":[],"tail":"), clearly identified in the dealer’s records as a security held for investment or if acquired before "},{"tag":"date","attrib":{"date":"1951-10-20"},"text":"October 20, 1951","children":[],"tail":", was so identified before "},{"tag":"date","attrib":{"date":"1951-11-20"},"text":"November 20, 1951","children":[],"tail":"; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s107/b/2"},"text":"Pub. L. 98–369, § 107(b)(2)","children":[],"tail":", inserted “(or such earlier time)” after “such day”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448"},"text":"Pub. L. 97–448","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s506/a"},"text":"Pub. L. 97–34, § 506(a)","children":[],"tail":", substituted “before the close of the day on which it was acquired (before the close of the following day in the case of an acquisition before "},{"tag":"date","attrib":{"date":"1982-01-01"},"text":"January 1, 1982","children":[],"tail":")” for “before the expiration of the 30th day after the date of its acquisition” in par. (1) and “close of such day” for “expiration of such 30th day” in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s506/b"},"text":"Pub. L. 97–34, § 506(b)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted “ordinary loss” for “loss from the sale or exchange of property which is not a capital asset”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44c3b2c5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44c3b2c6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/b"},"text":"section 221(b) of Pub. L. 113–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44c3b2c7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" applicable to positions entered into after "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", in taxable years ending after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s107/e"},"text":"section 107(e) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1092"},"text":"section 1092 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44c3b2c8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448/tI/s105/d/2"},"text":"Pub. L. 97–448, title I, § 105(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2387"},"text":"96 Stat. 2387","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/448/tI/s105/d/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall apply to securities acquired after ","children":[{"tag":"date","attrib":{"date":"1982-09-22"},"text":"September 22, 1982","children":[],"tail":", in taxable years ending after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44c3b2c9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" applicable to property acquired by the taxpayer after "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", in taxable years ending after such date, and applicable when so elected with respect to property held on "},{"tag":"date","attrib":{"date":"1981-06-23"},"text":"June 23, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/s508"},"text":"section 508 of Pub. L. 97–34","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1092"},"text":"section 1092 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44c3b2ca-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" applicable with respect to taxable years beginning after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"Dec. 31, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/d"},"text":"section 1901(d) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
