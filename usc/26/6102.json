{"tag":"section","attrib":{"id":"id468d762b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6102"},"text":null,"children":[{"tag":"num","attrib":{"value":"6102"},"text":"§ 6102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computations on returns or other documents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id468d762c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts shown on internal revenue forms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to provide with respect to any amount required to be shown on a form prescribed for any internal revenue return, statement, or other document, that if such amount of such item is other than a whole-dollar amount, either—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id468d762d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fractional part of a dollar shall be disregarded; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id468d762e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fractional part of a dollar shall be disregarded unless it amounts to one-half dollar or more, in which case the amount (determined without regard to the fractional part of a dollar) shall be increased by $1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id468d762f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election not to use whole dollar amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person making a return, statement, or other document shall be allowed, under regulations prescribed by the Secretary, to make such return, statement, or other document without regard to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id468d7630-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability to computation of amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of subsections (a) and (b) shall not be applicable to items which must be taken into account in making the computations necessary to determine the amount required to be shown on a form, but shall be applicable only to such final amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id468d7631-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/753"},"text":"68A Stat. 753","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id468d7632-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id468d7633-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id468d7634-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
