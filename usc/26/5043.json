."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id461fe7c2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id461fe7c3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Taxpayer Relief Act of 1997, "},{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":", to which such amendment relates (see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1422/c"},"text":"section 1422(c) of Pub. L. 105–34","children":[],"tail":" set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5364"},"text":"section 5364 of this title","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6024"},"text":"section 6024 of Pub. L. 105–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id461fe7c4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-01-01"},"text":"Jan. 1,