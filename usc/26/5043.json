{"tag":"section","attrib":{"id":"id461fe7b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5043"},"text":null,"children":[{"tag":"num","attrib":{"value":"5043"},"text":"§ 5043.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of taxes on wines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id461fe7b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5043/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons liable for payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The taxes on wine provided for in this subpart shall be paid—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id461fe7b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5043/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bonded wine cellars","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of wines removed from any bonded wine cellar, by the proprietor of such bonded wine cellar; except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id461fe7b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5043/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any transfer of wine in bond as authorized under the provisions of section 5362(b), the liability for payment of the tax shall become the liability of the transferee from the time of removal of the wine from the transferor’s premises, and the transferor shall thereupon be relieved of such liability; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id461fe7b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5043/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any wine withdrawn by a person other than such proprietor without payment of tax as authorized under the provisions of section 5362(c), the liability for payment of the tax shall become the liability of such person from the time of the removal of the wine from the bonded wine cellar, and such proprietor shall thereupon be relieved of such liability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461fe7ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5043/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign wine","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of foreign wines which are not transferred to a bonded wine cellar free of tax under section 5364, by the importer thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461fe7bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5043/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other wines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Immediately, in the case of any wine produced, imported, received, removed, or possessed otherwise than as authorized by law, by any person producing, importing, receiving, removing, or possessing such wine; and all such persons shall be jointly and severally liable for such tax with each other as well as with any proprietor, transferee, or importer who may be liable for the tax under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id461fe7bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5043/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The taxes on wines shall be paid in accordance with section 5061.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id461fe7bd-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1332"},"text":"72 Stat. 1332","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1905/b/2/C"},"text":"Pub. L. 94–455, title XIX, § 1905(b)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1822"},"text":"90 Stat. 1822","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/8"},"text":"Pub. L. 96–39, title VIII, § 807(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/281"},"text":"93 Stat. 281","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tVI/s6014/b/1"},"text":"Pub. L. 105–206, title VI, § 6014(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/820"},"text":"112 Stat. 820","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id461fe7be-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"t