{"tag":"section","attrib":{"id":"id479aeeae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805"},"text":null,"children":[{"tag":"num","attrib":{"value":"7805"},"text":"§ 7805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id479aeeaf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except where such authority is expressly given by this title to any person other than an officer or employee of the Treasury Department, the Secretary shall prescribe all needful rules and regulations for the enforcement of this title, including all rules and regulations as may be necessary by reason of any alteration of law in relation to internal revenue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id479aeeb0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retroactivity of regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id479aeeb1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this subsection, no temporary, proposed, or final regulation relating to the internal revenue laws shall apply to any taxable period ending before the earliest of the following dates:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id479aeeb2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date on which such regulation is filed with the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id479aeeb3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any final regulation, the date on which any proposed or temporary regulation to which such final regulation relates was filed with the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id479aeeb4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date on which any notice substantially describing the expected contents of any temporary, proposed, or final regulation is issued to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479aeeb5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for promptly issued regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to regulations filed or issued within 18 months of the date of the enactment of the statutory provision to which the regulation relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479aeeb6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention of abuse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide that any regulation may take effect or apply retroactively to prevent abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479aeeb7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction of procedural defects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide that any regulation may apply retroactively to correct a procedural defect in the issuance of any prior regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479aeeb8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internal regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The limitation of paragraph (1) shall not apply to any regulation relating to internal Treasury Department policies, practices, or procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479aeeb9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The limitation of paragraph (1) may be superseded by a legislative grant from Congress authorizing the Secretary to prescribe the effective date with respect to any regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479d5fba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to apply retroactively","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide for any taxpayer to elect to apply any regulation before the dates specified in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479d5fbb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to rulings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prescribe the extent, if any, to which any ruling (including any judicial decision or any administrative determination other than by regulation) relating to the internal revenue laws shall be applied without retroactive effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id479d5fbc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation and distribution of regulations, forms, stamps, and other matters","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prepare and distribute all the instructions, regulations, directions, forms, blanks, stamps, and other matters pertaining to the assessment and collection of internal revenue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id479d5fbd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of making elections prescribed by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except to the extent otherwise provided by this title, any election under this title shall be made at such time and in such manner as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id479d5fbe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id479d5fbf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any temporary regulation issued by the Secretary shall also be issued as a proposed regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479d5fc0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 3-year duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any temporary regulation shall expire within 3 years after the date of issuance of such regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id479d5fc1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of impact of regulations on small business","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id479d5fc2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submissions to Small Business Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After publication of any proposed or temporary regulation by the Secretary, the Secretary shall submit such regulation to the Chief Counsel for Advocacy of the Small Business Administration for comment on the impact of such regulation on small business. Not later than the date 4 weeks after the date of such submission, the Chief Counsel for Advocacy shall submit comments on such regulation to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479d5fc3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of comments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In prescribing any final regulation which supersedes a proposed or temporary regulation which had been submitted under this subsection to the Chief Counsel for Advocacy of the Small Business Administration—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id479d5fc4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall consider the comments of the Chief Counsel for Advocacy on such proposed or temporary regulation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id479d5fc5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall discuss any response to such comments in the preamble of such final regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479d5fc6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of certain final regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of the promulgation by the Secretary of any final regulation (other than a temporary regulation) which does not supersede a proposed regulation, the requirements of paragraphs (1) and (2) shall apply; except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id479d5fc7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the submission under paragraph (1) shall be made at least 4 weeks before the date of such promulgation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id479d5fc8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7805/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consideration (and discussion) required under paragraph (2) shall be made in connection with the promulgation of such final regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id479d5fc9-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/917"},"text":"68A Stat. 917","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s43/b"},"text":"Pub. L. 98–369, div. A, title I, § 43(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/558"},"text":"98 Stat. 558","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6232/a"},"text":"Pub. L. 100–647, title VI, § 6232(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3734"},"text":"102 Stat. 3734","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11621/a"},"text":"Pub. L. 101–508, title XI, § 11621(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-503"},"text":"104 Stat. 1388–503","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/168/tXI/s1101/a"},"text":"Pub. L. 104–168, title XI, § 1101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1468"},"text":"110 Stat. 1468","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3704"},"text":"Pub. L. 105–206, title III, § 3704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/777"},"text":"112 Stat. 777","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id479d5fca-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id479d5fcb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id479d5fcc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" struck out “by regulations or forms” before “prescribe”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168"},"text":"Pub. L. 104–168","children":[],"tail":" struck out “or rulings” after “regulations” in heading and amended text generally. Prior to amendment, text read as follows: “The Secretary may prescribe the extent, if any, to which any ruling or regulation, relating to the internal revenue laws, shall be applied without retroactive effect.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted heading for one which read “Impact of regulations on small business reviewed” and amended text generally. Prior to amendment, text read as follows: “After the publication of any proposed regulation by the Secretary and before the promulgation of any final regulation by the Secretary which does not supersede a proposed regulation, the Secretary shall submit such regulation to the Administrator of the Small Business Administration for comment on the impact of such regulation on small business. The Administrator shall have 4 weeks from the date of submission to respond.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" added subsecs. (e) and (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id479d5fcd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id479d5fce-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/tXI/s1101/b"},"text":"Pub. L. 104–168, title XI, § 1101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1469"},"text":"110 Stat. 1469","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/168/tXI/s1101/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply with respect to regulations which relate to statutory provisions enacted on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id479d5fcf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11621/b"},"text":"Pub. L. 101–508, title XI, § 11621(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-504"},"text":"104 Stat. 1388–504","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/508/tXI/s11621/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to regulations issued after the date which is 30 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id479d5fd0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6232/b"},"text":"Pub. L. 100–647, title VI, § 6232(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3735"},"text":"102 Stat. 3735","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tVI/s6232/b"},"text":"“The amendments made by this section [amending this section] shall apply to any regulation issued after the date which is 10 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id479d5fd1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" applicable to taxable years ending after "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s44"},"text":"section 44 of Pub. L. 98–369","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1271"},"text":"section 1271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id479d5fd2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Form 1040SR for Seniors","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/dD/tII/s41106"},"text":"Pub. L. 115–123, div. D, title II, § 41106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/157"},"text":"132 Stat. 157","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/123/dD/tII/s41106"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury (or the Secretary’s delegate) shall make available a form, to be known as ‘Form 1040SR’, for use by individuals to file the return of tax imposed by chapter 1 of the Internal Revenue Code of 1986. Such form shall be as similar as practicable to Form 1040EZ, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the form shall be available only to individuals who have attained age 65 as of the close of the taxable year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the form may be used even if income for the taxable year includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" social security benefits (as defined in section 86(d) of the Internal Revenue Code of 1986),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributions from qualified retirement plans (as defined in section 4974(c) of such Code), annuities or other such deferred payment arrangements,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest and dividends, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capital gains and losses taken into account in determining adjusted net capital gain (as defined in section 1(h)(3) of such Code), and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the form shall be available without regard to the amount of any item of taxable income or the total amount of taxable income for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The form required by subsection (a) shall be made available for taxable years beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id479d5fd3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Internet Availability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tII/s2003/d"},"text":"Pub. L. 105–206, title II, § 2003(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/725"},"text":"112 Stat. 725","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/206/tII/s2003/d"},"text":"“In the case of taxable periods beginning after ","children":[{"tag":"date","attrib":{"date":"1998-12-31"},"text":"December 31, 1998","children":[],"tail":", the Secretary of the Treasury or the Secretary’s delegate shall establish procedures for all tax forms, instructions, and publications created in the most recent 5-year period to be made available electronically on the Internet in a searchable database at approximately the same time such records are available to the public in paper form. In addition, in the case of taxable periods beginning after "},{"tag":"date","attrib":{"date":"1998-12-31"},"text":"December 31, 1998","children":[],"tail":", the Secretary of the Treasury or the Secretary’s delegate shall, to the extent practicable, establish procedures for other taxpayer guidance to be made available electronically on the Internet in a searchable database at approximately the same time such guidance is available to the public in paper form.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
