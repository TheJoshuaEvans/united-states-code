{"tag":"section","attrib":{"id":"id40d0a6e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I"},"text":null,"children":[{"tag":"num","attrib":{"value":"45I"},"text":"§ 45I.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit for producing oil and gas from marginal wells","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40d0a6e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of section 38, the marginal well production credit for any taxable year is an amount equal to the product of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d0a6e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the credit amount, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d0a6ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the qualified crude oil production and the qualified natural gas production which is attributable to the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d0a6eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d0a6ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The credit amount is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d0a6ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3 per barrel of qualified crude oil production, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d0a6ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 cents per 1,000 cubic feet of qualified natural gas production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d0a6ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction as oil and gas prices increase","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d0a6f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The $3 and 50 cents amounts under paragraph (1) shall each be reduced (but not below zero) by an amount which bears the same ratio to such amount (determined without regard to this paragraph) as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40d0a6f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the excess (if any) of the applicable reference price over $15 ($1.67 for qualified natural gas production), bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d0a6f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3 ($0.33 for qualified natural gas production).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The applicable reference price for a taxable year is the reference price of the calendar year preceding the calendar year in which the taxable year begins.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d0a6f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any taxable year beginning in a calendar year after 2005, each of the dollar amounts contained in subparagraph (A) shall be increased to an amount equal to such dollar amount multiplied by the inflation adjustment factor for such calendar year (determined under section 43(b)(3)(B) by substituting “2004” for “1990”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d317f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reference price","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph, the term “reference price” means, with respect to any calendar year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40d317f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of qualified crude oil production, the reference price determined under section 45K(d)(2)(C), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d317f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of qualified natural gas production, the Secretary’s estimate of the annual average wellhead price per 1,000 cubic feet for all domestic natural gas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d317f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified crude oil and natural gas production","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d317f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “qualified crude oil production” and “qualified natural gas production” mean domestic crude oil or natural gas which is produced from a qualified marginal well.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d317f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on amount of production which may qualify","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d317fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Crude oil or natural gas produced during any taxable year from any well shall not be treated as qualified crude oil production or qualified natural gas production to the extent production from the well during the taxable year exceeds 1,095 barrels or barrel-of-oil equivalents (as defined in section 45K(d)(5)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d317fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proportionate reductions","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40d317fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short taxable years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a short taxable year, the limitations under this paragraph shall be proportionately reduced to reflect the ratio which the number of days in such taxable year bears to 365.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d317fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wells not in production entire year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a well which is not capable of production during each day of a taxable year, the limitations under this paragraph applicable to the well shall be proportionately reduced to reflect the ratio which the number of days of production bears to the total number of days in the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d317fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d317ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified marginal well","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified marginal well” means a domestic well—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40d31800-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production from which during the taxable year is treated as marginal production under section 613A(c)(6), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d31801-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which, during the taxable year—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id40d31802-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/c/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has average daily production of not more than 25 barrel-of-oil equivalents (as so defined), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id40d31803-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/c/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produces water at a rate not less than 95 percent of total well effluent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d31804-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crude oil, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “crude oil”, “natural gas”, “domestic”, and “barrel” have the meanings given such terms by section 613A(e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d31805-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d31806-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production attributable to the taxpayer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a qualified marginal well in which there is more than one owner of operating interests in the well and the crude oil or natural gas production exceeds the limitation under subsection (c)(2), qualifying crude oil production or qualifying natural gas production attributable to the taxpayer shall be determined on the basis of the ratio which taxpayer’s revenue interest in the production bears to the aggregate of the revenue interests of all operating interest owners in the production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d31807-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operating interest required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any credit under this section may be claimed only on production which is attributable to the holder of an operating interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d31808-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45I/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production from nonconventional sources excluded","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of production from a qualified marginal well which is eligible for the credit allowed under section 45K for the taxable year, no credit shall be allowable under this section unless the taxpayer elects not to claim the credit under section 45K with respect to the well.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id40d31809-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIII/s341/a"},"text":"Pub. L. 108–357, title III, § 341(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1485"},"text":"118 Stat. 1485","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXIII/s1322/a/3/B"},"text":"Pub. L. 109–58, title XIII, § 1322(a)(3)(B)","children":[],"tail":", (D), "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1011"},"text":"119 Stat. 1011","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s412/k"},"text":"Pub. L. 109–135, title IV, § 412(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2637"},"text":"119 Stat. 2637","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id40d3180a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id40d3180b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inflation Adjusted Items for Certain Tax Years","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For inflation adjustment of certain items in this section, see Internal Revenue Notices listed in a table below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id40d3180c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id40d3180d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" substituted “qualified crude oil production” for “qualified credit oil production”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1322/a/3/B"},"text":"Pub. L. 109–58, § 1322(a)(3)(B)","children":[],"tail":", substituted “section 45K(d)(2)(C)” for “section 29(d)(2)(C)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1322/a/3/D/i"},"text":"Pub. L. 109–58, § 1322(a)(3)(D)(i)","children":[],"tail":", substituted “section 45K(d)(5))” for “section 29(d)(5))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1322/a/3/D/ii"},"text":"Pub. L. 109–58, § 1322(a)(3)(D)(ii)","children":[],"tail":", substituted “section 45K” for “section 29” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id40d3180e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id40d3180f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" applicable to credits determined under the Internal Revenue Code of 1986 for taxable years ending after "},{"tag":"date","attrib":{"date":"2005-12-31"},"text":"Dec. 31, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1322/c/1"},"text":"section 1322(c)(1) of Pub. L. 109–58","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s45K"},"text":"section 45K of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id40d31810-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to production in taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2004-12-31"},"text":"Dec. 31, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s341/e"},"text":"section 341(e) of Pub. L. 108–357","children":[],"tail":", set out as an Effective Date of 2004 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id40d31811-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inflation Adjusted Items for Certain Years","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions relating to inflation adjustment of items in this section for certain years were contained in the following:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Internal Revenue Notice 2024–52.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Internal Revenue Notice 2023–58.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Internal Revenue Notice 2023–41.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Internal Revenue Notice 2022–18.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Internal Revenue Notice 2021–34.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Internal Revenue Notice 2020–21.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Internal Revenue Notice 2019–37.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Internal Revenue Notice 2018–52.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Internal Revenue Notice 2017–51.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
