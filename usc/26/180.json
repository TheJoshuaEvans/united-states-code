{"tag":"section","attrib":{"id":"id4214e629-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s180"},"text":null,"children":[{"tag":"num","attrib":{"value":"180"},"text":"§ 180.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures by farmers for fertilizer, etc.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4214e62a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s180/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A taxpayer engaged in the business of farming may elect to treat as expenses which are not chargeable to capital account expenditures (otherwise chargeable to capital account) which are paid or incurred by him during the taxable year for the purchase or acquisition of fertilizer, lime, ground limestone, marl, or other materials to enrich, neutralize, or condition land used in farming, or for the application of such materials to such land. The expenditures so treated shall be allowed as a deduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4214e62b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s180/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land used in farming","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), the term “land used in farming” means land used (before or simultaneously with the expenditures described in subsection (a)) by the taxpayer or his tenant for the production of crops, fruits, or other agricultural products or for the sustenance of livestock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4214e62c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s180/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The election under subsection (a) for any taxable year shall be made within the time prescribed by law (including extensions thereof) for filing the return for such taxable year. Such election shall be made in such manner as the Secretary may by regulations prescribe. Such election may not be revoked except with the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4214e62d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/779/s6/a"},"text":"Pub. L. 86–779, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-14"},"text":"Sept. 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/1001"},"text":"74 Stat. 1001","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4214e62e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4214e62f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4214e630-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4214e631-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4214e632-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/779/s6/d"},"text":"Pub. L. 86–779, § 6(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-14"},"text":"Sept. 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/1001"},"text":"74 Stat. 1001","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/86/779/s6/d"},"text":"“The amendments made by subsections (a), (b), and (c) [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s263"},"text":"section 263 of this title","children":[],"tail":"] shall apply to taxable years beginning after "},{"tag":"date","attrib":{"date":"1959-12-31"},"text":"December 31, 1959","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
