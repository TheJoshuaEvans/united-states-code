{"tag":"section","attrib":{"id":"id445ab7d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s894"},"text":null,"children":[{"tag":"num","attrib":{"value":"894"},"text":"§ 894.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income affected by treaty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id445ab7d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s894/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treaty provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id445ab7d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s894/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this title shall be applied to any taxpayer with due regard to any treaty obligation of the United States which applies to such taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id445ab7da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s894/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For relationship between treaties and this title, see section 7852(d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id445ab7db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s894/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permanent establishment in United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of applying any exemption from, or reduction of, any tax provided by any treaty to which the United States is a party with respect to income which is not effectively connected with the conduct of a trade or business within the United States, a nonresident alien individual or a foreign corporation shall be deemed not to have a permanent establishment in the United States at any time during the taxable year. This subsection shall not apply in respect of the tax computed under section 877(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id445ab7dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s894/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of treaty benefits for certain payments through hybrid entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id445ab7dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s894/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to certain payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A foreign person shall not be entitled under any income tax treaty of the United States with a foreign country to any reduced rate of any withholding tax imposed by this title on an item of income derived through an entity which is treated as a partnership (or is otherwise treated as fiscally transparent) for purposes of this title if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id445ab7de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s894/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such item is not treated for purposes of the taxation laws of such foreign country as an item of income of such person,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id445ab7df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s894/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the treaty does not contain a provision addressing the applicability of the treaty in the case of an item of income derived through a partnership, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id445ab7e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s894/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the foreign country does not impose tax on a distribution of such item of income from such entity to such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id445ab7e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s894/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary or appropriate to determine the extent to which a taxpayer to which paragraph (1) does not apply shall not be entitled to benefits under any income tax treaty of the United States with respect to any payment received by, or income attributable to any activities of, an entity organized in any jurisdiction (including the United States) that is treated as a partnership or is otherwise treated as fiscally transparent for purposes of this title (including a common investment trust under section 584, a grantor trust, or an entity that is disregarded for purposes of this title) and is treated as fiscally nontransparent for purposes of the tax laws of the jurisdiction of residence of the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id445ab7e2-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/284"},"text":"68A Stat. 284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/tI/s105/a"},"text":"Pub. L. 89–809, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1563"},"text":"80 Stat. 1563","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/aa/6"},"text":"Pub. L. 100–647, title I, § 1012(aa)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3533"},"text":"102 Stat. 3533","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1054/a"},"text":"Pub. L. 105–34, title X, § 1054(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/943"},"text":"111 Stat. 943","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id445ab7e3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id445ab7e4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id445ab7e5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" substituted “Treaty provisions” for “Income affected by treaty” in heading and amended text generally. Prior to amendment, text read as follows: “Income of any kind, to the extent required by any treaty obligation of the United States, shall not be included in gross income and shall be exempt from taxation under this subtitle.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809"},"text":"Pub. L. 89–809","children":[],"tail":" designated existing provisions as subsec. (a), added subsec. (b), and substituted “affected by treaty” for “exempt under treaty” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id445ab7e6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id445ab7e7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1054/b"},"text":"Pub. L. 105–34, title X, § 1054(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/944"},"text":"111 Stat. 944","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tX/s1054/b"},"text":"“The amendments made by this section [amending this section] shall apply upon the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id445ab7e8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id445ab7e9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809/tI/s105/d"},"text":"Pub. L. 89–809, title I, § 105(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1565"},"text":"80 Stat. 1565","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/809/tI/s105/d"},"text":"“The amendments made by this section (other than subsections (d) and (f)) [amending this section and enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s896"},"text":"section 896 of this title","children":[],"tail":"] shall apply with respect to taxable years beginning after "},{"tag":"date","attrib":{"date":"1966-12-31"},"text":"December 31, 1966","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
