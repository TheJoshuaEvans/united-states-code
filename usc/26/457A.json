{"tag":"section","attrib":{"id":"id4388e859-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A"},"text":null,"children":[{"tag":"num","attrib":{"value":"457A"},"text":"§ 457A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonqualified deferred compensation from certain tax indifferent parties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4388e85a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any compensation which is deferred under a nonqualified deferred compensation plan of a nonqualified entity shall be includible in gross income when there is no substantial risk of forfeiture of the rights to such compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4388e85b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonqualified entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “nonqualified entity” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4388e85c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any foreign corporation unless substantially all of its income is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4388e85d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effectively connected with the conduct of a trade or business in the United States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4388e85e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to a comprehensive foreign income tax, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4388e85f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any partnership unless substantially all of its income is allocated to persons other than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4388e860-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign persons with respect to whom such income is not subject to a comprehensive foreign income tax, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4388e861-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations which are exempt from tax under this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4388e862-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinability of amounts of compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4388e863-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the amount of any compensation is not determinable at the time that such compensation is otherwise includible in gross income under subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4388e864-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount shall be so includible in gross income when determinable, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4388e865-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the tax imposed under this chapter for the taxable year in which such compensation is includible in gross income shall be increased by the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4388e866-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of interest determined under paragraph (2), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4388e867-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 20 percent of the amount of such compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4388e868-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1)(B)(i), the interest determined under this paragraph for any taxable year is the amount of interest at the underpayment rate under section 6621 plus 1 percentage point on the underpayments that would have occurred had the deferred compensation been includible in gross income for the taxable year in which first deferred or, if later, the first taxable year in which such deferred compensation is not subject to a substantial risk of forfeiture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4388e869-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4388e86a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial risk of forfeiture","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4388e86b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rights of a person to compensation shall be treated as subject to a substantial risk of forfeiture only if such person’s rights to such compensation are conditioned upon the future performance of substantial services by any individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4388e86c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for compensation based on gain recognized on an investment asset","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4388e86d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent provided in regulations prescribed by the Secretary, if compensation is determined solely by reference to the amount of gain recognized on the disposition of an investment asset, such compensation shall be treated as subject to a substantial risk of forfeiture until the date of such disposition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4388e86e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment asset","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of clause (i), the term “investment asset” means any single asset (other than an investment fund or similar entity)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4388e86f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/d/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquired directly by an investment fund or similar entity,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4388e870-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/d/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which such entity does not (nor does any person related to such entity) participate in the active management of such asset (or if such asset is an interest in an entity, in the active management of the activities of such entity), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4388e871-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/d/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially all of any gain on the disposition of which (other than such deferred compensation) is allocated to investors in such entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4388e872-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (3)(B) shall not apply to any compensation to which clause (i) applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4388e873-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive foreign income tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “comprehensive foreign income tax” means, with respect to any foreign person, the income tax of a foreign country if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4388e874-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person is eligible for the benefits of a comprehensive income tax treaty between such foreign country and the United States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4388e875-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person demonstrates to the satisfaction of the Secretary that such foreign country has a comprehensive income tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4388e876-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonqualified deferred compensation plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4388e877-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nonqualified deferred compensation plan” has the meaning given such term under section 409A(d), except that such term shall include any plan that provides a right to compensation based on the appreciation in value of a specified number of equity units of the service recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4388e878-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Compensation shall not be treated as deferred for purposes of this section if the service provider receives payment of such compensation not later than 12 months after the end of the taxable year of the service recipient during which the right to the payment of such compensation is no longer subject to a substantial risk of forfeiture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4388e879-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain compensation with respect to effectively connected income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a foreign corporation with income which is taxable under section 882, this section shall not apply to compensation which, had such compensation been paid in cash on the date that such compensation ceased to be subject to a substantial risk of forfeiture, would have been deductible by such foreign corporation against such income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4388e87a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of paragraphs (5) and (6) of section 409A(d) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4388e87b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s457A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary or appropriate to carry out the purposes of this section, including regulations disregarding a substantial risk of forfeiture in cases where necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4388e87c-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dC/tVIII/s801/a"},"text":"Pub. L. 110–343, div. C, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3929"},"text":"122 Stat. 3929","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/113"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(113)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1189"},"text":"132 Stat. 1189","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4388e87d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4388e87e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4388e87f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “case of a foreign” for “case a foreign” and “been paid” for “had been paid”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4388e880-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4388e881-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dC/tVIII/s801/d"},"text":"Pub. L. 110–343, div. C, title VIII, § 801(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3931"},"text":"122 Stat. 3931","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/343/dC/tVIII/s801/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this subsection, the amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s26"},"text":"section 26 of this title","children":[],"tail":"] shall apply to amounts deferred which are attributable to services performed after "},{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application to existing deferrals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any amount deferred to which the amendments made by this section do not apply solely by reason of the fact that the amount is attributable to services performed before ","children":[{"tag":"date","attrib":{"date":"2009-01-01"},"text":"January 1, 2009","children":[],"tail":", to the extent such amount is not includible in gross income in a taxable year beginning before 2018, such amounts shall be includible in gross income in the later of—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the last taxable year beginning before 2018, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxable year in which there is no substantial risk of forfeiture of the rights to such compensation (determined in the same manner as determined for purposes of section 457A of the Internal Revenue Code of 1986, as added by this section).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accelerated payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":"], the Secretary shall issue guidance providing a limited period of time during which a nonqualified deferred compensation arrangement attributable to services performed on or before "},{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":", may, without violating the requirements of section 409A(a) of the Internal Revenue Code of 1986, be amended to conform the date of distribution to the date the amounts are required to be included in income."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain back-to-back arrangements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the taxpayer is also a service recipient and maintains one or more nonqualified deferred compensation arrangements for its service providers under which any amount is attributable to services performed on or before ","children":[{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":", the guidance issued under paragraph (4) shall permit such arrangements to be amended to conform the dates of distribution under such arrangement to the date amounts are required to be included in the income of such taxpayer under this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accelerated payment not treated as material modification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any amendment to a nonqualified deferred compensation arrangement made pursuant to paragraph (4) or (5) shall not be treated as a material modification of the arrangement for purposes of section 409A of the Internal Revenue Code of 1986.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
