{"tag":"section","attrib":{"id":"id43784694-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s446"},"text":null,"children":[{"tag":"num","attrib":{"value":"446"},"text":"§ 446.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule for methods of accounting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43784695-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s446/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Taxable income shall be computed under the method of accounting on the basis of which the taxpayer regularly computes his income in keeping his books.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43784696-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s446/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If no method of accounting has been regularly used by the taxpayer, or if the method used does not clearly reflect income, the computation of taxable income shall be made under such method as, in the opinion of the Secretary, does clearly reflect income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43784697-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s446/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible methods","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the provisions of subsections (a) and (b), a taxpayer may compute taxable income under any of the following methods of accounting—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43784698-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s446/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cash receipts and disbursements method;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43784699-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s446/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an accrual method;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4378469a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s446/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other method permitted by this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4378469b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s446/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of the foregoing methods permitted under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4378469c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s446/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxpayer engaged in more than one business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A taxpayer engaged in more than one trade or business may, in computing taxable income, use a different method of accounting for each trade or business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4378469d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s446/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement respecting change of accounting method","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise expressly provided in this chapter, a taxpayer who changes the method of accounting on the basis of which he regularly computes his income in keeping his books shall, before computing his taxable income under the new method, secure the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4378469e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s446/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to request change of method of accounting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the taxpayer does not file with the Secretary a request to change the method of accounting, the absence of the consent of the Secretary to a change in the method of accounting shall not be taken into account—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4378469f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s446/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent the imposition of any penalty, or the addition of any amount to tax, under this title, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id437846a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s446/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to diminish the amount of such penalty or addition to tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id437846a1-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/151"},"text":"68A Stat. 151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906"},"text":"Pub. L. 94–455, title XIX, § 1906","children":[],"tail":" (b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s161/a"},"text":"Pub. L. 98–369, div. A, title I, § 161(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/696"},"text":"98 Stat. 696","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id437846a2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id437846a3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id437846a4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (b), (c), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id437846a5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id437846a6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s161/b"},"text":"Pub. L. 98–369, div. A, title I, § 161(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/697"},"text":"98 Stat. 697","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tI/s161/b"},"text":"“The amendment made by this section [amending this section] shall apply to taxable years beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
