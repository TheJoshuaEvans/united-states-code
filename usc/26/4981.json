{"tag":"section","attrib":{"id":"id460f1f47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981"},"text":null,"children":[{"tag":"num","attrib":{"value":"4981"},"text":"§ 4981.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excise tax on undistributed income of real estate investment trusts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id460f1f48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby imposed a tax on every real estate investment trust for each calendar year equal to 4 percent of the excess (if any) of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460f1f49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the required distribution for such calendar year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1f4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distributed amount for such calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460f1f4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460f1f4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “required distribution” means, with respect to any calendar year, the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460f1f4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 85 percent of the real estate investment trust’s ordinary income for such calendar year, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1f4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 95 percent of the real estate investment trust’s capital gain net income for such calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1f4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase by prior year shortfall","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount determined under paragraph (1) for any calendar year shall be increased by the excess (if any) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460f1f50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grossed up required distribution for the preceding calendar year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1f51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distributed amount for such preceding calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1f52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grossed up required distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The grossed up required distribution for any calendar year is the required distribution for such year determined—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460f1f53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the application of paragraph (2) to such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1f54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “100 percent” for each percentage set forth in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460f1f55-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributed amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460f1f56-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “distributed amount” means, with respect to any calendar year, the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460f1f57-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deduction for dividends paid (as defined in section 561) during such calendar year (but computed without regard to that portion of such deduction which is attributable to the amount excluded under section 857(b)(2)(D)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1f58-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount on which tax is imposed under subsection (b)(1) or (b)(3)(A) ","children":[{"tag":"ref","attrib":{"idref":"fn002249"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002249"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of section 857 for any taxable year ending in such calendar year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1f59-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase by prior year overdistribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount determined under paragraph (1) for any calendar year shall be increased by the excess (if any) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460f1f5a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distributed amount for the preceding calendar year (determined with the application of this paragraph to such preceding calendar year), over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1f5b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grossed up required distribution for such preceding calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1f5c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of dividends paid","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the dividends paid during any calendar year shall be determined without regard to the provisions of section 858.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460f1f5d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for payment of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by this section for any calendar year shall be paid on or before March 15 of the following calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460f1f5e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460f1f5f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ordinary income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “ordinary income” means the real estate investment trust taxable income (as defined in section 857(b)(2)) determined—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460f1f60-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to subparagraph (B) of section 857(b)(2),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1f61-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by not taking into account any gain or loss from the sale or exchange of a capital asset, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118f62-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by treating the calendar year as the trust’s taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118f63-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital gain net income","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118f64-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “capital gain net income” has the meaning given such term by section 1222(9) (determined by treating the calendar year as the trust’s taxable year).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118f65-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction for net ordinary loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount determined under subparagraph (A) shall be reduced by the amount of the trust’s net ordinary loss for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118f66-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net ordinary loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the net ordinary loss for the calendar year is the amount which would be net operating loss of the trust for the calendar year if the amount of such loss were determined in the same manner as ordinary income is determined under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118f67-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of deficiency distributions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any deficiency dividend (as defined in section 860(f))—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118f68-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dividend shall be taken into account when paid without regard to section 860, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118f69-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4981/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any income giving rise to the adjustment shall be treated as arising when the dividend is paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46118f6a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXVI/s1605/a"},"text":"Pub. L. 94–455, title XVI, § 1605(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1754"},"text":"90 Stat. 1754","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s668/a"},"text":"Pub. L. 99–514, title VI, § 668(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2306"},"text":"100 Stat. 2306","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/s/1"},"text":"Pub. L. 100–647, title I, § 1006(s)(1)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3418"},"text":"102 Stat. 3418","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46118f6b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46118f6c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id46118f6d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (b)(3)(A) of section 857, referred to in subsec. (c)(1)(B), was repealed and subsection (b)(3)(B) was redesignated (b)(3)(A) by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13001/b/2/K/i"},"text":"Pub. L. 115–97, title I, § 13001(b)(2)(K)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2096"},"text":"131 Stat. 2096","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46118f6e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/s/3"},"text":"Pub. L. 100–647, § 1006(s)(3)","children":[],"tail":", inserted “(but computed without regard to that portion of such deduction which is attributable to the amount excluded under section 857(b)(2)(D)” after “such calendar year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/s/1"},"text":"Pub. L. 100–647, § 1006(s)(1)","children":[],"tail":", amended par. (2) generally, designating existing provisions as subpar. (A) and adding subpars. (B) and (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Excise tax on undistributed income of real estate investment trusts” for “Excise tax based on certain real estate investment trust taxable income not distributed during the taxable year” as section catchline and amended text generally. Prior to amendment text read as follows: “Effective with respect to taxable years beginning after "},{"tag":"date","attrib":{"date":"1979-12-31"},"text":"December 31, 1979","children":[],"tail":", there is hereby imposed on each real estate investment trust for the taxable year a tax equal to 3 percent of the amount (if any) by which 75 percent of the real estate investment trust taxable income (as defined in section 857(b)(2), but determined without regard to section 857(b)(2)(B), and by excluding any net capital gain for the taxable year) exceeds the amount of the dividends paid deduction (as defined in section 561, but computed without regard to capital gains dividends as defined in section 857(b)(3)(C) and without regard to any dividend paid after the close of the taxable year) for the taxable year. For purposes of the preceding sentence, the determination of the real estate investment trust taxable income shall be made by taking into account only the amount and character of the items of income and deduction as reported by such trust in its return for the taxable year.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46118f6f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46118f70-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46118f71-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" applicable to calendar years beginning after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s669/b"},"text":"section 669(b) of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s856"},"text":"section 856 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
