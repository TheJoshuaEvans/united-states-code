{"tag":"section","attrib":{"id":"id443bbe11-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860D"},"text":null,"children":[{"tag":"num","attrib":{"value":"860D"},"text":"§ 860D.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" REMIC defined","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id443bbe12-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860D/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this title, the terms “real estate mortgage investment conduit” and “REMIC” mean any entity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443bbe13-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860D/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which an election to be treated as a REMIC applies for the taxable year and all prior taxable years,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe14-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860D/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all of the interests in which are regular interests or residual interests,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe15-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860D/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has 1 (and only 1) class of residual interests (and all distributions, if any, with respect to such interests are pro rata),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe16-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860D/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of the close of the 3rd month beginning after the startup day and at all times thereafter, substantially all of the assets of which consist of qualified mortgages and permitted investments,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe17-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860D/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has a taxable year which is a calendar year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe18-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860D/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to which there are reasonable arrangements designed to ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbe19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860D/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" residual interests in such entity are not held by disqualified organizations (as defined in section 860E(e)(5)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe1a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860D/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information necessary for the application of section 860E(e) will be made available by the entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In the case of a qualified liquidation (as defined in section 860F(a)(4)(A)), paragraph (4) shall not apply during the liquidation period (as defined in section 860F(a)(4)(B)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443bbe1b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860D/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443bbe1c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860D/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity (otherwise meeting the requirements of subsection (a)) may elect to be treated as a REMIC for its 1st taxable year. Such an election shall be made on its return for such 1st taxable year. Except as provided in paragraph (2), such an election shall apply to the taxable year for which made and all subsequent taxable years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe1d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860D/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbe1e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860D/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any entity ceases to be a REMIC at any time during the taxable year, such entity shall not be treated as a REMIC for such taxable year or any succeeding taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe1f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860D/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inadvertent terminations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id443bbe20-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860D/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity ceases to be a REMIC,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id443bbe21-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860D/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that such cessation was inadvertent,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id443bbe22-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860D/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no later than a reasonable time after the discovery of the event resulting in such cessation, steps are taken so that such entity is once more a REMIC, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id443bbe23-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860D/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such entity, and each person holding an interest in such entity at any time during the period specified pursuant to this subsection, agrees to make such adjustments (consistent with the treatment of such entity as a REMIC or a C corporation) as may be required by the Secretary with respect to such period,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then, notwithstanding such terminating event, such entity shall be treated as continuing to be a REMIC (or such cessation shall be disregarded for purposes of subparagraph (A)) whichever the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id443bbe24-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s671/a"},"text":"Pub. L. 99–514, title VI, § 671(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2311"},"text":"100 Stat. 2311","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/t/2/A"},"text":"Pub. L. 100–647, title I, § 1006(t)(2)(A)","children":[],"tail":", (16)(A), (19), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3419"},"text":"102 Stat. 3419","children":[],"tail":", 3423, 3426; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11704/a/8"},"text":"Pub. L. 101–508, title XI, § 11704(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-518"},"text":"104 Stat. 1388–518","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id443bbe25-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id443bbe26-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id443bbe27-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" inserted closing parenthesis before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/19"},"text":"Pub. L. 100–647, § 1006(t)(19)","children":[],"tail":", inserted at end “In the case of a qualified liquidation (as defined in section 860F(a)(4)(A)), paragraph (4) shall not apply during the liquidation period (as defined in section 860F(a)(4)(B).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/2/A/i"},"text":"Pub. L. 100–647, § 1006(t)(2)(A)(i)","children":[],"tail":", substituted “3rd month beginning after” for “4th month ending after”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/2/A/ii"},"text":"Pub. L. 100–647, § 1006(t)(2)(A)(ii)","children":[],"tail":", substituted “and at all times thereafter” for “and each quarter ending thereafter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/16/A"},"text":"Pub. L. 100–647, § 1006(t)(16)(A)","children":[],"tail":", added par. (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id443bbe28-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id443bbe29-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/t/2/B"},"text":"Pub. L. 100–647, title I, § 1006(t)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3419"},"text":"102 Stat. 3419","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1006/t/2/B"},"text":"“The amendment made by subparagraph (A)(ii) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1988-01-01"},"text":"January 1, 1988","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/t/16/D/i"},"text":"Pub. L. 100–647, title I, § 1006(t)(16)(D)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3425"},"text":"102 Stat. 3425","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1006/t/16/D/i"},"text":"“The amendments made by subparagraph (A) [amending this section] shall apply in the case of any REMIC where the start-up day (as defined in section 860G(a)(9) of the 1986 Code, as in effect on the day before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":"]) is after "},{"tag":"date","attrib":{"date":"1988-03-31"},"text":"March 31, 1988","children":[],"tail":"; except that such amendments shall not apply in the case of a REMIC formed pursuant to a binding written contract in effect on such date.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by section 1006(t)(2)(A)(i), (19) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
