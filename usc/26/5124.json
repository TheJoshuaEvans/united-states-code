{"tag":"section","attrib":{"id":"id46295d6d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5124"},"text":null,"children":[{"tag":"num","attrib":{"value":"5124"},"text":"§ 5124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration by dealers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every dealer who is subject to the recordkeeping requirements under section 5121 or 5122 shall register with the Secretary such dealer’s name or style, place of residence, trade or business, and the place where such trade or business is to be carried on. In the case of a firm or company, the names of the several persons constituting the same, and the places of residence, shall be so registered.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id46295d6e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11125/b/8"},"text":"Pub. L. 109–59, title XI, § 11125(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1955"},"text":"119 Stat. 1955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46295d6f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46295d70-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46295d71-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5124 was renumbered ","children":[{"tag":"ref","attrib