{"tag":"section","attrib":{"id":"id441cc443-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s843"},"text":null,"children":[{"tag":"num","attrib":{"value":"843"},"text":"§ 843.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual accounting period","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For purposes of this subtitle, the annual accounting period for each insurance company subject to a tax imposed by this subchapter shall be the calendar year. Under regulations prescribed by the Secretary, an insurance company which joins in the filing of a consolidated return (or is required to so file) may adopt the taxable year of the common parent corporation even though such year is not a calendar year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id441cc444-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-03-13/ch83/s4/a"},"text":"Mar. 13, 1956, ch. 83, § 4(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/48"},"text":"70 Stat. 48","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXV/s1507/b/2"},"text":"Pub. L. 94–455, title XV, § 1507(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1740"},"text":"90 Stat. 1740","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id441cc445-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id441cc446-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id441cc447-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" inserted provision permitting an insurance company which joins in the filing of a consolidated return to adopt the taxable year of the common parent corporation even though such year is not a calendar year."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id441cc448-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id441cc449-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1980-12-31"},"text":"Dec. 31, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1507/c/1"},"text":"section 1507(c)(1) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1504"},"text":"section 1504 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id441cc44a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1954-12-31"},"t