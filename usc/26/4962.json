{"tag":"section","attrib":{"id":"id45f295ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4962"},"text":null,"children":[{"tag":"num","attrib":{"value":"4962"},"text":"§ 4962.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abatement of first tier taxes in certain cases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45f295ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4962/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If it is established to the satisfaction of the Secretary that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f295ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4962/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a taxable event was due to reasonable cause and not to willful neglect, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f295ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4962/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such event was corrected within the correction period for such event,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then any qualified first tier tax imposed with respect to such event (including interest) shall not be assessed and, if assessed, the assessment shall be abated and, if collected, shall be credited or refunded as an overpayment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f295f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4962/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified first tier tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “qualified first tier tax” means any first tier tax imposed by subchapter A, C, D, or G of this chapter, except that such term shall not include the tax imposed by section 4941(a) (relating to initial tax on self-dealing).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f295f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4962/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for tax on political expenditures of section 501(c)(3) organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of the tax imposed by section 4955(a), subsection (a)(1) shall be applied by substituting “not willful and flagrant” for “due to reasonable cause and not to willful neglect”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45f295f2-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIII/s305/a"},"text":"Pub. L. 98–369, div. A, title III, § 305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/783"},"text":"98 Stat. 783","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10712/b/1"},"text":"Pub. L. 100–203, title X, § 10712(b)(1)","children":[],"tail":", (2), (4), "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-467"},"text":"101 Stat. 1330–467","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXVI/s1603/a"},"text":"Pub. L. 105–34, title XVI, § 1603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1096"},"text":"111 Stat. 1096","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/172/s3/h"},"text":"Pub. L. 110–172, § 3(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-29"},"text":"Dec. 29, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2475"},"text":"121 Stat. 2475","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45f295f3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45f295f4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id45f295f5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4962 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4963"},"text":"section 4963 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45f295f6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172"},"text":"Pub. L. 110–172","children":[],"tail":" substituted “D, or G” for “or D”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" substituted “subchapter A, C, or D” for “subchapter A or C”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s10712/b/4"},"text":"Pub. L. 100–203, § 10712(b)(4)","children":[],"tail":", struck out “private foundation” before “first tier taxes” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s10712/b/2"},"text":"Pub. L. 100–203, § 10712(b)(2)","children":[],"tail":", substituted “any qualified first tier tax” for “any private foundation first tier tax” in closing provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s10712/b/1"},"text":"Pub. L. 100–203, § 10712(b)(1)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) “Private foundation first tier tax” which read as follows: “For purposes of this section, the term ‘private foundation first tier tax’ means any first tier tax imposed by subchapter A of chapter 42, except that such term shall not include the tax imposed by section 4941(a) (relating to initial tax on self-dealing).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s10712/b/1"},"text":"Pub. L. 100–203, § 10712(b)(1)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45f295f7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45f295f8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 