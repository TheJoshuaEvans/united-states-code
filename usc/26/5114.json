ent made by subsection (a) [amending this section] shall apply to claims filed on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1968-10-21"},"text":"Oct. 21, 1968","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
