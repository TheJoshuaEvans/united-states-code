{"tag":"section","attrib":{"id":"id4626ec27-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5114"},"text":null,"children":[{"tag":"num","attrib":{"value":"5114"},"text":"§ 5114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drawback","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4626ec28-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of drawback","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of distilled spirits on which the tax has been paid or determined, and which have been used as provided in this subpart, a drawback shall be allowed on each proof gallon at a rate of $1 less than the rate at which the distilled spirits tax has been paid or determined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4626ec29-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such drawback shall be due and payable quarterly upon filing of a proper claim with the Secretary; except that, where any person entitled to such drawback shall elect in writing to file monthly claims therefor, such drawback shall be due and payable monthly upon filing of a proper claim with the Secretary. The Secretary may require persons electing to file monthly drawback claims to file with him a bond or other security in such amount and with such conditions as he shall by regulations prescribe. Any such election may be revoked on filing of notice thereof with the Secretary. No claim under this subpart shall be allowed unless filed with the Secretary within the 6 months next succeeding the quarter in which the distilled spirits covered by the claim were used as provided in this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4626ec2a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of drawback even where certain requirements not met","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4626ec2b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5114/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No claim for drawback under this section shall be denied in the case of a failure to comply with any requirement imposed under this subpart or any rule or regulation issued thereunder upon the claimant’s establishing to the satisfaction of the Secretary that distilled spirits on which the tax has been paid or determined were in fact used in the manufacture or production of medicines, medicinal preparations, food products, flavors, flavoring extracts, or perfume, which were unfit for beverage purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4626ec2c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5114/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4626ec2d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5114/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a failure to comply with any requirement imposed under this subpart or any rule or regulation issued thereunder, the claimant shall be liable for a penalty of $1,000 for each failure to comply unless it is shown that the failure to comply was due to reasonable cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4626ec2e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5114/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty may not exceed amount of claim","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The aggregate amount of the penalties imposed under subparagraph (A) for failures described in paragraph (1) in respect of any claim shall not exceed the amount of such claim (determined without regard to subparagraph (A)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4626ec2f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5114/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty treated as tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalty imposed by paragraph (2) shall be assessed, collected, and paid in the same manner as taxes, as provided in section 6665(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4626ec30-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title 