{"tag":"section","attrib":{"id":"id4723c2c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6657"},"text":null,"children":[{"tag":"num","attrib":{"value":"6657"},"text":"§ 6657.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bad checks","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any instrument in payment, by any commercially acceptable means, of any amount receivable under this title is not duly paid, in addition to any other penalties provided by law, there shall be paid as a penalty by the person who tendered such instrument, upon notice and demand by the Secretary, in the same manner as tax, an amount equal to 2 percent of the amount of such instrument, except that if the amount of such instrument is less than $1,250, the penalty under this section shall be $25 or the amount of such instrument, whichever is the lesser. This section shall not apply if the person tendered such instrument in good faith and with reasonable cause to believe that it would be duly paid.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4723c2c8-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/826"},"text":"68A Stat. 826","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tV/s5071/a"},"text":"Pub. L. 100–647, title V, § 5071(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3681"},"text":"102 Stat. 3681","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/28/tVIII/s8245/a"},"text":"Pub. L. 110–28, title VIII, § 8245(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-25"},"text":"May 25, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/200"},"text":"121 Stat. 200","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/198/s3/a"},"text":"Pub. L. 111–198, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-02"},"text":"July 2, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1356"},"text":"124 Stat. 1356","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4723c2c9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4723c2ca-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4723c2cb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/198/s3/a/2"},"text":"Pub. L. 111–198, § 3(a)(2)","children":[],"tail":", substituted “such instrument” for “such check” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/198/s3/a/1"},"text":"Pub. L. 111–198, § 3(a)(1)","children":[],"tail":", substituted “If any instrument in payment, by any commercially acceptable means, of any amount” for “If any check or money order in payment of any amount”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28"},"text":"Pub. L. 110–28","children":[],"tail":" substituted “$1,250” for “$750” and “$25” for “$15”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" substituted “2” for “1”, “$750” for “$500”, and “$15” for “$5”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4723c2cc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4723c2cd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/198/s3/b"},"text":"Pub. L. 111–198, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-02"},"text":"July 2, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1356"},"text":"124 Stat. 1356","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/198/s3/b"},"text":"“The amendments made by this section [amending this section] shall apply to instruments tendered after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-07-02"},"text":"July 2, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4723c2ce-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28/tVIII/s8245/b"},"text":"Pub. L. 110–28, title VIII, § 8245(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-25"},"text":"May 25, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/200"},"text":"121 Stat. 200","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/28/tVIII/s8245/b"},"text":"“The amendments made by this section [amending this section] apply to checks or money orders received after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2007-05-25"},"text":"May 25, 2007","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4723c2cf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tV/s5071/b"},"text":"Pub. L. 100–647, title V, § 5071(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3681"},"text":"102 Stat. 3681","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tV/s5071/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to checks or money orders received after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
