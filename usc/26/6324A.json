{"tag":"section","attrib":{"id":"id46cb9123-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A"},"text":null,"children":[{"tag":"num","attrib":{"value":"6324A"},"text":"§ 6324A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special lien for estate tax deferred under section 6166","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46cb9124-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any estate with respect to which an election has been made under section 6166, if the executor makes an election under this section (at such time and in such manner as the Secretary shall by regulations prescribe) and files the agreement referred to in subsection (c), the deferred amount (plus any interest, additional amount, addition to tax, assessable penalty, and costs attributable to the deferred amount) shall be a lien in favor of the United States on the section 6166 lien property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46cb9125-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 6166 lien property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46cb9126-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “section 6166 lien property” means interests in real and other property to the extent such interests—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46cb9127-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can be expected to survive the deferral period, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46cb9128-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are designated in the agreement referred to in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46cb9129-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum value of required property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The maximum value of the property which the Secretary may require as section 6166 lien property with respect to any estate shall be a value which is not greater than the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46cb912a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deferred amount, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46cb912b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the required interest amount.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of the preceding sentence, the value of any property shall be determined as of the date prescribed by section 6151(a) for payment of the tax imposed by chapter 11 and shall be determined by taking into account any encumbrance such as a lien under section 6324B.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46cb912c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partial substitution of bond for lien","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the value required as section 6166 lien property pursuant to paragraph (2) exceeds the value of the interests in property covered by the agreement referred to in subsection (c), the Secretary may accept bond in an amount equal to such excess conditioned on the payment of the amount extended in accordance with the terms of such extension.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46cb912d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agreement referred to in this subsection is a written agreement signed by each person in being who has an interest (whether or not in possession) in any property designated in such agreement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46cb912e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consenting to the creation of the lien under this section with respect to such property, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46cb912f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designating a responsible person who shall be the agent for the beneficiaries of the estate and for the persons who have consented to the creation of the lien in dealings with the Secretary on matters arising under section 6166 or this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46cb9130-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46cb9131-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement that lien be filed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The lien imposed by this section shall not be valid as against any purchaser, holder of a security interest, mechanic’s lien, or judgment lien creditor until notice thereof which meets the requirements of section 6323(f) has been filed by the Secretary. Such notice shall not be required to be refiled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46cb9132-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of lien","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The lien imposed by this section shall arise at the time the executor is discharged from liability under section 2204 (or, if earlier, at the time notice is filed pursuant to paragraph (1)) and shall continue until the liability for the deferred amount is satisfied or becomes unenforceable by reason of lapse of time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46cb9133-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Even though notice of a lien imposed by this section has been filed as provided in paragraph (1), such lien shall not be valid—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46cb9134-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real property tax and special assessment liens","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent provided in section 6323(b)(6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46cb9135-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real property subject to a mechanic’s lien for repairs and improvement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any real property subject to a lien for repair or improvement, as against a mechanic’s lienor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46cb9136-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real property construction or improvement financing agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As against any security interest set forth in paragraph (3) of section 6323(c) (whether such security interest came into existence before or after tax lien filing).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Subparagraphs (B) and (C) shall not apply to any security interest which came into existence after the date on which the Secretary filed notice (in a manner similar to notice filed under section 6323(f)) that payment of the deferred amount has been accelerated under section 6166(g).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46cb9137-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lien to be in lieu of section 6324 lien","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If there is a lien under this section on any property with respect to any estate, there shall not be any lien under section 6324 on such property with respect to the same estate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46cb9138-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional lien property required in certain cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If at any time the value of the property covered by the agreement is less than the unpaid portion of the deferred amount and the required interest amount, the Secretary may require the addition of property to the agreement (but he may not require under this paragraph that the value of the property covered by the agreement exceed such unpaid portion). If property having the required value is not added to the property covered by the agreement (or if other security equal to the required value is not furnished) within 90 days after notice and demand therefor by the Secretary, the failure to comply with the preceding sentence shall be treated as an act accelerating payment of the installments under section 6166(g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46cb9139-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lien to be in lieu of bond","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not require under section 6165 the furnishing of any bond for the payment of any tax to which an agreement which meets the requirements of subsection (c) applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46cb913a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46cb913b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferred amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “deferred amount” means the aggregate amount deferred under section 6166 (determined as of the date prescribed by section 6151(a) for payment of the tax imposed by chapter 11).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46cb913c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required interest amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “required interest amount” means the aggregate amount of interest which will be payable over the first 4 years of the deferral period with respect to the deferred amount (determined as of the date prescribed by section 6151(a) for the payment of the tax imposed by chapter 11).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46cb913d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferral period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “deferral period” means the period for which the payment of tax is deferred pursuant to the election under section 6166.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46cb913e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6324A/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of definitions in case of deficiencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a deficiency, a separate deferred amount, required interest amount, and deferral period shall be determined as of the due date of the first installment after the deficiency is prorated to installments under section 6166.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46cb913f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2004/d/1"},"text":"Pub. L. 94–455, title XX, § 2004(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1868"},"text":"90 Stat. 1868","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s702/e/1"},"text":"Pub. L. 95–600, title VII, § 702(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2929"},"text":"92 Stat. 2929","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV/s422/e/6/A"},"text":"Pub. L. 97–34, title IV, § 422(e)(6)(A)","children":[],"tail":"–(C), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/316"},"text":"95 Stat. 316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46cb9140-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46cb9141-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46cb9142-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s422/e/6/C"},"text":"Pub. L. 97–34, § 422(e)(6)(C)","children":[],"tail":", struck out “or 6166A” after “section 6166” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s422/e/6/A"},"text":"Pub. L. 97–34, § 422(e)(6)(A)","children":[],"tail":", struck out “or 6166A” after “section 6166”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s422/e/6/B"},"text":"Pub. L. 97–34, § 422(e)(6)(B)","children":[],"tail":", struck out “or 6166A(h)” after “section 6166(g)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1), (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s422/e/6/A"},"text":"Pub. L. 97–34, § 422(e)(6)(A)","children":[],"tail":", struck out “or 6166A” after “section 6166”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s702/e/1/B"},"text":"Pub. L. 95–600, § 702(e)(1)(B)","children":[],"tail":", substituted “required interest amount” for “aggregate interest amount”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s702/e/1/C"},"text":"Pub. L. 95–600, § 702(e)(1)(C)","children":[],"tail":", substituted “required interest amount” for “aggregate interest amount”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s702/e/1/A"},"text":"Pub. L. 95–600, § 702(e)(1)(A)","children":[],"tail":", substituted “Required interest amount” for “Aggregate interest amount” in heading and in text “required interest amount”, “over the first 4 years of the deferral period” and “for the payment” for “aggregate interest amount”, “over the deferral period” and “for payment”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s702/e/1/D"},"text":"Pub. L. 95–600, § 702(e)(1)(D)","children":[],"tail":", substituted “required interest amount” for “aggregate interest amount”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46cb9143-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46cb9144-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" applicable to estates of decedents dying after "},{"tag":"date","attrib":{"date":"1981-12-31"},"text":"Dec. 31, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/s422/f/1"},"text":"section 422(f)(1) of Pub. L. 97–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6166"},"text":"section 6166 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46cb9145-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s702/e/2"},"text":"Pub. L. 95–600, title VII, § 702(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2930"},"text":"92 Stat. 2930","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/600/tVII/s702/e/2"},"text":"“The amendments made by this section [amending this section] shall apply to the estates of decedents dying after ","children":[{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
