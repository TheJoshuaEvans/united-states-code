{"tag":"section","attrib":{"id":"id46fd9e04-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6434"},"text":null,"children":[{"tag":"num","attrib":{"value":"6434"},"text":"§ 6434.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trump accounts contribution pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46fd9e05-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6434/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual who makes an election under this section with respect to an eligible child of the individual, such eligible child shall be treated as making a payment against the tax imposed by subtitle A (for the taxable year for which the election was made) in an amount equal to $1,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46fd9e06-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6434/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount treated as a payment under subsection (a) shall be paid by the Secretary to the Trump account with respect to which such eligible child is the account beneficiary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46fd9e07-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6434/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible child","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “eligible child” means a qualifying child (as defined in section 152(c))—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46fd9e08-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6434/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is born after ","children":[{"tag":"date","attrib":{"date":"2024-12-31"},"text":"December 31, 2024","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2029-01-01"},"text":"January 1, 2029","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46fd9e09-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6434/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to whom no prior election has been made under this section by such individual or any other individual, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46fd9e0a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6434/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a United States citizen.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46fd9e0b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6434/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under this section shall be made at such time and in such manner as the Secretary shall provide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46fd9e0c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6434/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Social security number required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46fd9e0d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6434/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to any taxpayer unless such individual includes with the election made under this section the social security number of the eligible child with respect to whom the election is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46fd9e0e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6434/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Social security number defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the term “social security number” shall have the meaning given such term in section 24(h)(7), determined by substituting “before the date of the election made under section 6434” for “before the due date of ","children":[{"tag":"ref","attrib":{"idref":"fn002311"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002311"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “for”."}],"tail":" such return” in subparagraph (B) thereof."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46fd9e0f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6434/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception from reduction or offset","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any payment made to any individual under this section shall not be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46fd9e10-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6434/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to reduction or offset pursuant to subsection (c), (d), (e), or (f) of section 6402 or any similar authority permitting offset, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46fd9e11-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6434/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduced or offset by other assessed Federal taxes that would otherwise be subject to levy or collection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46fd9e12-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6434/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule regarding interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The period determined under section 6611(a) with respect to any payment under this section shall not begin before ","children":[{"tag":"date","attrib":{"date":"2028-01-01"},"text":"January 1, 2028","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46fd9e13-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6434/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mirror code possessions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any possession of the United States with a mirror code tax system (as defined in section 24(k)), this section shall not be treated as part of the income tax laws of the United States for purposes of determining the income tax law of such possession unless such possession elects to have this section be so treated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46fd9e14-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6434/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the terms “Trump account” and “account beneficiary” have the meaning given such terms in section 530A(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46fd9e15-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70204/d/1"},"text":"Pub. L. 119–21, title VII, § 70204(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/187"},"text":"139 Stat. 187","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46fd9e16-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46fd9e17-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46fd9e18-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2025-12-31"},"text":"Dec. 31, 2025","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70204/e"},"text":"section 70204(e) of Pub. L. 119–21","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s128"},"text":"section 128 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
