"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “reasonable cause” for “reasonable basis” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s209/c/1"},"text":"Pub. L. 114–113, § 209(c)(1)","children":[],"tail":", substituted “is due to reasonable cause” for “has a reasonable basis”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s209/b"},"text":"Pub. L. 114–113, § 209(b)","children":[],"tail":", struck out “(other than a claim for a refund or credit relating to the earned income credit under section 32)” after “income tax”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s209/c/2"},"text":"Pub. L. 114–113, § 209(c)(2)","children":[],"tail":", substituted “due to reasonable cause” for “having a reasonable basis”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152"},"text":"Pub. L. 111–152","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d). See Codification note above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id472aef3c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id472aef3d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" applicable to claims for credit or re