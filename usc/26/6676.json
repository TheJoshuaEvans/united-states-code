{"tag":"section","attrib":{"id":"id472aef31-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6676"},"text":null,"children":[{"tag":"num","attrib":{"value":"6676"},"text":"§ 6676.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Erroneous claim for refund or credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id472aef32-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6676/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a claim for refund or credit with respect to income or employment tax is made for an excessive amount, unless it is shown that the claim for such excessive amount is due to reasonable cause, the person making such claim shall be liable for a penalty in an amount equal to 20 percent of the excessive amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472aef33-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6676/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excessive amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “excessive amount” means in the case of any person the amount by which the amount of the claim for refund or credit for any taxable year exceeds the amount of such claim allowable under this title for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472aef34-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6676/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noneconomic substance transactions treated as lacking reasonable cause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, any excessive amount which is attributable to any transaction described in section 6662(b)(6) shall not be treated as due to reasonable cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472aef35-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6676/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to any portion of the excessive amount of a claim for refund or credit which is subject to a penalty imposed under part II of subchapter A of chapter 68.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id472aef36-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28/tVIII/s8247/a"},"text":"Pub. L. 110–28, title VIII, § 8247(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-25"},"text":"May 25, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/204"},"text":"121 Stat. 204","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/152/tI/s1409/d"},"text":"Pub. L. 111–152, title I, § 1409(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-30"},"text":"Mar. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1070"},"text":"124 Stat. 1070","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tII/s209/b"},"text":"Pub. L. 114–113, div. Q, title II, § 209(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date