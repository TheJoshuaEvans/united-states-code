{"tag":"section","attrib":{"id":"id4546c527-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2524"},"text":null,"children":[{"tag":"num","attrib":{"value":"2524"},"text":"§ 2524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extent of deductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The deductions provided in sections 2522 and 2523 shall be allowed only to the extent that the gifts therein specified are included in the amount of gifts against which such deductions are applied.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4546c528-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/414"},"text":"68A Stat. 414","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
