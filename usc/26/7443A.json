{"tag":"section","attrib":{"id":"id47583fc3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443A"},"text":null,"children":[{"tag":"num","attrib":{"value":"7443A"},"text":"§ 7443A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special trial judges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47583fc4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chief judge may, from time to time, appoint special trial judges who shall proceed under such rules and regulations as may be promulgated by the Tax Court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47583fc5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proceedings which may be assigned to special trial judges","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The chief judge may assign—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47583fc6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any declaratory judgment proceeding,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47583fc7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any proceeding under section 7463,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47583fc8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443A/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any proceeding where neither the amount of the deficiency placed in dispute (within the meaning of section 7463) nor the amount of any claimed overpayment exceeds $50,000,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47583fc9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443A/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any proceeding under section 6320 or 6330,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47583fca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443A/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any proceeding under section 7436(c),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47583fcb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443A/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any proceeding under section 7623(b)(4), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47583fcc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443A/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other proceeding which the chief judge may designate,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to be heard by the special trial judges of the court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47583fcd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make court decision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court may authorize a special trial judge to make the decision of the court with respect to any proceeding described in paragraph (1), (2), (3), (4), (5), or (6) of subsection (b), subject to such conditions and review as the court may provide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47583fce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Salary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each special trial judge shall receive salary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47583fcf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a rate equal to 90 percent of the rate for judges of the Tax Court, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47583fd0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the same installments as such judges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47583fd1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses for travel and subsistence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (d) of section 7443 shall apply to special trial judges subject to such rules and regulations as may be promulgated by the Tax Court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47583fd2-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1556/a"},"text":"Pub. L. 99–514, title XV, § 1556(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2754"},"text":"100 Stat. 2754","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII"},"text":"Pub. L. 105–206, title III","children":[],"tail":", §§ 3103(b)(1), 3401(c), "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/731"},"text":"112 Stat. 731","children":[],"tail":", 749; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dJ/tIV/s4002/e"},"text":"Pub. L. 105–277, div. J, title IV, § 4002(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-907"},"text":"112 Stat. 2681–907","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tVIII/s857/a"},"text":"Pub. L. 109–280, title VIII, § 857(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1020"},"text":"120 Stat. 1020","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s406/a/2"},"text":"Pub. L. 109–432, div. A, title IV, § 406(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2959"},"text":"120 Stat. 2959","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47583fd3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47583fd4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47583fd5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s857/a"},"text":"Pub. L. 109–280, § 857(a)","children":[],"tail":", added par. (5). Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s406/a/2/A"},"text":"Pub. L. 109–432, § 406(a)(2)(A)","children":[],"tail":", added par. (6). Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s857/a"},"text":"Pub. L. 109–280, § 857(a)","children":[],"tail":", redesignated par. (5) as (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s406/a/2/A"},"text":"Pub. L. 109–432, § 406(a)(2)(A)","children":[],"tail":", redesignated par. (6) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s406/a/2/B"},"text":"Pub. L. 109–432, § 406(a)(2)(B)","children":[],"tail":", substituted “(5), or (6)” for “or (5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s857/b"},"text":"Pub. L. 109–280, § 857(b)","children":[],"tail":", substituted “(4), or (5)” for “or (4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3103/b/1"},"text":"Pub. L. 105–206, § 3103(b)(1)","children":[],"tail":", substituted “$50,000” for “$10,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3401/c/1"},"text":"Pub. L. 105–206, § 3401(c)(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s4002/e/1"},"text":"Pub. L. 105–277, § 4002(e)(1)","children":[],"tail":", added par. (4) and redesignated former par. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3401/c/2"},"text":"Pub. L. 105–206, § 3401(c)(2)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s4002/e/2"},"text":"Pub. L. 105–277, § 4002(e)(2)","children":[],"tail":", substituted “(3), or (4)” for “or (3)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47583fd6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47583fd7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" applicable to information provided on or after "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/s406/d"},"text":"section 406(d) of Pub. L. 109–432","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s62"},"text":"section 62 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tVIII/s857/c"},"text":"Pub. L. 109–280, title VIII, § 857(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1020"},"text":"120 Stat. 1020","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/280/tVIII/s857/c"},"text":"“The amendments made by this section [amending this section] shall apply to any proceeding under section 7436(c) of the Internal Revenue Code of 1986 with respect to which a decision has not become final (as determined under section 7481 of such Code) before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47583fd8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective as if included in the provision of the Internal Revenue Service Restructuring and Reform Act of 1998, "},{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s4002/k"},"text":"section 4002(k) of Pub. L. 105–277","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3103"},"text":"section 3103 of Pub. L. 105–206","children":[],"tail":" applicable to proceedings commenced after "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3103/c"},"text":"section 3103(c) of Pub. L. 105–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7436"},"text":"section 7436 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3401"},"text":"section 3401 of Pub. L. 105–206","children":[],"tail":" applicable to collection actions initiated after the date which is 180 days after "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3401/d"},"text":"section 3401(d) of Pub. L. 105–206","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6320"},"text":"section 6320 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47583fd9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1556/c"},"text":"Pub. L. 99–514, title XV, § 1556(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2755"},"text":"100 Stat. 2755","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXV/s1556/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the amendments made by this section [enacting this section and amending sections 7456 and 7471 of this title] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Salary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (d) of section 7443A of the Internal Revenue Code of 1954 [now 1986] (as added by this section) shall take effect on the 1st day of the 1st month beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"New appointments not required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in the amendments made by this section shall be construed to require the reappointment of any individual serving as a special trial judge of the Tax Court on the day before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id47583fda-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inconsistencies With Presidential Salary Recommendations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1015/j"},"text":"Pub. L. 100–647, title I, § 1015(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3571"},"text":"102 Stat. 3571","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1015/j"},"text":"“To the extent the salary recommendations submitted by the President on ","children":[{"tag":"date","attrib":{"date":"1987-01-05"},"text":"January 5, 1987","children":[],"tail":", are inconsistent with the provisions of section 7443A(d)(1) of the 1986 Code, such recommendations shall not be effective for any period.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
