{"tag":"section","attrib":{"id":"id4723c2d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6658"},"text":null,"children":[{"tag":"num","attrib":{"value":"6658"},"text":"§ 6658.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with title 11","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4723c2d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6658/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain failures to pay tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No addition to the tax shall be made under section 6651, 6654, or 6655 for failure to make timely payment of tax with respect to a period during which a case is pending under title 11 of the United States Code—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4723c2d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6658/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such tax was incurred by the estate and the failure occurred pursuant to an order of the court finding probable insufficiency of funds of the estate to pay administrative expenses, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4723c2d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6658/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4723c2d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6658/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such tax was incurred by the debtor before the earlier of the order for relief or (in the involuntary case) the appointment of a trustee, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4723c2d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6658/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4723c2d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6658/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the petition was filed before the due date prescribed by law (including extensions) for filing a return of such tax, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4723c2d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6658/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date for making the addition to the tax occurs on or after the day on which the petition was filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4723c2d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6658/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for collected taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to any liability for an addition to the tax which arises from the failure to pay or deposit a tax withheld or collected from others and required to be paid to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4723c2d9-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/589/s6/e/1"},"text":"Pub. L. 96–589, § 6(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3408"},"text":"94 Stat. 3408","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4723c2da-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4723c2db-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4723c2dc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6658, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/826"},"text":"68A Stat. 826","children":[],"tail":", authorized inclusion as part of the tax a 25 percent penalty in cases of violations or attempted violations of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6851"},"text":"section 6851 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/167/s6/a"},"text":"Pub. L. 96–167, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-29"},"text":"Dec. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1276"},"text":"93 Stat. 1276","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4723c2dd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4723c2de-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", but not applicable to proceedings under Title 11, Bankruptcy, commenced before "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/589/s7/e"},"text":"section 7(e) of Pub. L. 96–589","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s108"},"text":"section 108 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
