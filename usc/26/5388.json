{"tag":"section","attrib":{"id":"id4639fed3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388"},"text":null,"children":[{"tag":"num","attrib":{"value":"5388"},"text":"§ 5388.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of wines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4639fed4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard wines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Standard wines may be removed from premises subject to the provisions of this subchapter and be marked, transported, and sold under their proper designation as to kind and origin, or, if there is no such designation known to the trade or consumers, then under a truthful and adequate statement of composition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4639fed5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other wines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Wines other than standard wines may be removed for consumption or sale and be marked, transported, or sold only under such designation as to kind and origin as adequately describes the true composition of such products and as adequately distinguish them from standard wines, as regulations prescribed by the Secretary shall provide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4639fed6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of semi-generic designations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4639fed7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Semi-generic designations may be used to designate wines of an origin other than that indicated by such name only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4639fed8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there appears in direct conjunction therewith an appropriate appellation of origin disclosing the true place of origin of the wine, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4639fed9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the wine so designated conforms to the standard of identity, if any, for such wine contained in the regulations under this section or, if there is no such standard, to the trade understanding of such class or type.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4639feda-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of whether name is semi-­generic","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4639fedb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), a name of geographic significance, which is also the designation of a class or type of wine, shall be deemed to have become semi-generic only if so found by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4639fedc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain names treated as semi-generic","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The following names shall be treated as semi-generic: Angelica, Burgundy, Claret, Chablis, Champagne, Chianti, Malaga, Marsala, Madeira, Moselle, Port, Rhine Wine or Hock, Sauterne, Haut Sauterne, Sherry, Tokay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4639fedd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for use of certain semi-generic designations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4639fede-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any wine to which this paragraph applies—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4639fedf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (1) shall not apply,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4639fee0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of wine of the European Community, designations referred to in subparagraph (C)(i) may be used for such wine only if the requirement of subparagraph (B)(ii) is met, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4639fee1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case any other wine bearing a brand name, or brand name and fanciful name, semi-generic designations may be used for such wine only if the requirements of clauses (i), (ii), and (iii) of subparagraph (B) are met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4639fee2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4639fee3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirement of this clause is met if there appears in direct conjunction with the semi-generic designation an appropriate appellation of origin disclosing the origin of the wine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4639fee4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirement of this clause is met if the wine conforms to the standard of identity, if any, for such wine contained in the regulations under this section or, if there is no such standard, to the trade understanding of such class or type.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4639fee5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirement of this clause is met if the person, or its successor in interest, using the semi-generic designation held a Certificate of Label Approval or Certificate of Exemption from Label Approval issued by the Secretary for a wine label bearing such brand name, or brand name and fanciful name, before ","children":[{"tag":"date","attrib":{"date":"2006-03-10"},"text":"March 10, 2006","children":[],"tail":", on which such semi-generic designation appeared."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4639fee6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wines to which paragraph applies","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4639fee7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), this paragraph shall apply to any grape wine which is designated as Burgundy, Claret, Chablis, Champagne, Chianti, Malaga, Marsala, Madeira, Moselle, Port, Retsina, Rhine Wine or Hock, Sauterne, Haut Sauterne, Sherry, or Tokay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4639fee8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This paragraph shall not apply to wine which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4639fee9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/3/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains less than 7 percent or more than 24 percent alcohol by volume,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4639feea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/3/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is intended for sale outside the United States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4639feeb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5388/c/3/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not bear a brand name.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4639feec-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1387"},"text":"72 Stat. 1387","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tIX/s910/a"},"text":"Pub. L. 105–34, title IX, § 910(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/877"},"text":"111 Stat. 877","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s422/a"},"text":"Pub. L. 109–432, div. A, title IV, § 422(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2972"},"text":"120 Stat. 2972","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4639feed-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4639feee-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4639feef-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5388, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/672"},"text":"68A Stat. 672","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4639fef0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4639fef1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4639fef2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s422/b"},"text":"Pub. L. 109–432, div. A, title IV, § 422(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2973"},"text":"120 Stat. 2973","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/432/dA/tIV/s422/b"},"text":"“The amendments made by this section [amending this section] shall apply to wine imported or bottled in the United States on or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4639fef3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tIX/s910/b"},"text":"Pub. L. 105–34, title IX, § 910(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/877"},"text":"111 Stat. 877","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tIX/s910/b"},"text":"“The amendment made by this section [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
