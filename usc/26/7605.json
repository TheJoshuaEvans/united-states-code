{"tag":"section","attrib":{"id":"id47773a25-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7605"},"text":null,"children":[{"tag":"num","attrib":{"value":"7605"},"text":"§ 7605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time and place of examination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47773a26-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time and place","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The time and place of examination pursuant to the provisions of section 6420(e)(2), 6421(g)(2), 6427(j)(2), or 7602 shall be such time and place as may be fixed by the Secretary and as are reasonable under the circumstances. In the case of a summons under authority of paragraph (2) of section 7602, or under the corresponding authority of section 6420(e)(2), 6421(g)(2), or 6427(j)(2), the date fixed for appearance before the Secretary shall not be less than 10 days from the date of the summons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47773a27-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on examination of taxpayer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No taxpayer shall be subjected to unnecessary examination or investigations, and only one inspection of a taxpayer’s books of account shall be made for each taxable year unless the taxpayer requests otherwise or unless the Secretary, after investigation, notifies the taxpayer in writing that an additional inspection is necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47773a28-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7605/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions restricting church tax inquiries and examinations, see section 7611.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47773a29-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/902"},"text":"68A Stat. 902","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-04-02/ch160/s4/i"},"text":"Apr. 2, 1956, ch. 160, § 4(i)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/91"},"text":"70 Stat. 91","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-06-29/ch462"},"text":"June 29, 1956, ch. 462","children":[],"tail":", title II, § 208(d)(4), "},{"tag":"ref","attrib":{"href":"/us/stat/70/396"},"text":"70 Stat. 396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tII/s202/c/4"},"text":"Pub. L. 89–44, title II, § 202(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/139"},"text":"79 Stat. 139","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tI/s121/f"},"text":"Pub. L. 91–172, title I, § 121(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/548"},"text":"83 Stat. 548","children":[],"tail":"; "},{"tag":"ref","attrib":{