{"tag":"section","attrib":{"id":"id44ba1618-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1211"},"text":null,"children":[{"tag":"num","attrib":{"value":"1211"},"text":"§ 1211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on capital losses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44ba1619-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1211/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a corporation, losses from sales or exchanges of capital assets shall be allowed only to the extent of gains from such sales or exchanges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ba161a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1211/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other taxpayers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a taxpayer other than a corporation, losses from sales or exchanges of capital assets shall be allowed only to the extent of the gains from such sales or exchanges, plus (if such losses exceed such gains) the lower of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ba161b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1211/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,000 ($1,500 in the case of a married individual filing a separate return), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ba161c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1211/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the excess of such losses over such gains.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44ba161d-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/321"},"text":"68A Stat. 321","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tV/s513/a"},"text":"Pub. L. 91–172, title V, § 513(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/642"},"text":"83 Stat. 642","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tV/s501/b/6"},"text":"Pub. L. 94–455, title V, § 501(b)(6)","children":[],"tail":", title XIV, § 1401(a), (b), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1559"},"text":"90 Stat. 1559","children":[],"tail":", 1731; "},{"tag":"ref","attrib":{"href":"/us/pl/95/30/tI/s102/b/14"},"text":"Pub. L. 95–30, title I, § 102(b)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-23"},"text":"May 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/138"},"text":"91 Stat. 138","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tIII/s301/b/10"},"text":"Pub. L. 99–514, title III, § 301(b)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2217"},"text":"100 Stat. 2217","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44ba161e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44ba161f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44ba1620-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" amended subsec. (b) generally, substituting present provisions for provisions which had declared in: par. (1), general rule for limitation on capital losses for taxpayer other than corporation; in par. (2), meaning of term “applicable amount”; and in par. (3), rule relating to computation of taxable income."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/30"},"text":"Pub. L. 95–30","children":[],"tail":" inserted “reduced (but not below zero) by the zero bracket amount” after “taxable year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1401/a"},"text":"Pub. L. 94–455, § 1401(a)","children":[],"tail":", substituted “the applicable amount” for “$1,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1401/b"},"text":"Pub. L. 94–455, § 1401(b)","children":[],"tail":", substituted provision relating to “applicable amount” for prior provision limiting amount of capital losses for married individuals and reading “In the case of a husband or wife who files a separate return, the amount specified in paragraph (1)(B) shall be $500 in lieu of $1,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s501/b/6"},"text":"Pub. L. 94–455, § 501(b)(6)","children":[],"tail":", struck out last sentence “If the taxpayer elects to pay the optional tax imposed by section 3, ‘taxable income’ as used in this subsection shall read as ‘adjusted gross income’.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" provided for only 50 percent of an individual’s long-term capital losses to be offset against his ordinary income up to the $1,000 limit although short-term capital losses continue to be fully deductible within the $1,000 limit and the deduction of capital losses against ordinary income for married persons filing separate returns to be limited to $500 for each spouse rather than the $1,000 formerly allowed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44ba1621-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44ba1622-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s301/c"},"text":"section 301(c) of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s62"},"text":"section 62 of this ti