{"tag":"section","attrib":{"id":"id47667146-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7483"},"text":null,"children":[{"tag":"num","attrib":{"value":"7483"},"text":"§ 7483.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of appeal","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Review of a decision of the Tax Court shall be obtained by filing a notice of appeal with the clerk of the Tax Court within 90 days after the decision of the Tax Court is entered. If a timely notice of appeal is filed by one party, any other party may take an appeal by filing a notice of appeal within 120 days after the decision of the Tax Court is entered.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id47667147-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/891"},"text":"68A Stat. 891","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIX/s959/a"},"text":"Pub. L. 91–172, title IX, § 959(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/734"},"text":"83 Stat. 734","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47667148-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47667149-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4766714a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1969—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" substituted references to notice of appeal for references to petition for review, and otherwise generally altered the section as to time for appeal and terminology in order to conform section to the form of the Federal Rules of Appellate Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4766714b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4766714c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1969 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIX/s962/f"},"text":"Pub. L. 91–172, title IX, § 962(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/736"},"text":"83 Stat. 736","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"“The amendments made by sections 959 and 960(h) [amending this section and sections 7481, 7482, and 7485 of this title] shall take effect 30 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":"]. In the case of any decision of the Tax Court entered before the 30th day after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":"], the United States Courts of Appeals shall have jurisdiction to hear an appeal from such decision, if such appeal was filed within the time prescribed by Rule 13(a) of the Federal Rules of Appellate Procedure or by section 7483 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] as in effect at the time the decision of the Tax Court was entered.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
