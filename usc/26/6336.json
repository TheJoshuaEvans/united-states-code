{"tag":"section","attrib":{"id":"id46d2bccc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6336"},"text":null,"children":[{"tag":"num","attrib":{"value":"6336"},"text":"§ 6336.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of perishable goods","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines that any property seized is liable to perish, he shall appraise the value of such property and—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46d2bccd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6336/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return to owner","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the owner of the property can be readily found, the Secretary shall give him notice of such determination of the appraised value of the property. The property shall be returned to the owner if, within such time as may be specified in the notice, the owner—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46d2bcce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6336/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pays to the Secretary an amount equal to the appraised value, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46d2bccf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6336/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Gives bond in such form, with such sureties, and in such amount as the Secretary shall prescribe, to pay the appraised amount at such time as the Secretary determines to be appropriate in the circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d2bcd0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6336/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immediate sale","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the owner does not pay such amount or furnish such bond in accordance with this section, the Secretary shall as soon as practicable make public sale of the property in accordance with such regulations as may be prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46d2bcd1-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/786"},"text":"68A Stat. 786","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/25/tI/s1404/a"},"text":"Pub. L. 116–25, title I, § 1404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/997"},"text":"133 Stat. 997","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46d2bcd2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46d2bcd3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46d2bcd4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25"},"text":"Pub. L. 116–25","children":[],"tail":" struck out “or become greatly reduced in price or value by keeping, or that such property cannot be kept without great expense” after “to perish” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46d2bcd5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46d2bcd6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/tI/s1404/b"},"text":"Pub. L. 116–25, title I, § 1404(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/997"},"text":"133 Stat. 997","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/25/tI/s1404/b"},"text":"“The amendment made by this section [amending this section] shall apply to property seized after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
