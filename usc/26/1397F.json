{"tag":"section","attrib":{"id":"id4501a5ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397F"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397F"},"text":"§ 1397F.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary or appropriate to carry out the purposes of parts II and III, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4501a5eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397F/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations limiting the benefit of parts II and III in circumstances where such benefits, in combination with benefits provided under other Federal programs, would result in an activity being 100 percent or more subsidized by the Federal Government,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a5ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397F/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations preventing abuse of the provisions of parts II and III, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a5ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397F/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations dealing with inadvertent failures of entities to be enterprise zone businesses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4501a5ee-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13301/a"},"text":"Pub. L. 103–66, title XIII, § 1