{"tag":"section","attrib":{"id":"id4768e18c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502"},"text":null,"children":[{"tag":"num","attrib":{"value":"7502"},"text":"§ 7502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timely mailing treated as timely filing and paying","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4768e18d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4768e18e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date of delivery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any return, claim, statement, or other document required to be filed, or any payment required to be made, within a prescribed period or on or before a prescribed date under authority of any provision of the internal revenue laws is, after such period or such date, delivered by United States mail to the agency, officer, or office with which such return, claim, statement, or other document is required to be filed, or to which such payment is required to be made, the date of the United States postmark stamped on the cover in which such return, claim, statement, or other document, or payment, is mailed shall be deemed to be the date of delivery or the date of payment, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4768e18f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mailing requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection shall apply only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4768e190-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the postmark date falls within the prescribed period or on or before the prescribed date—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4768e191-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the filing (including any extension granted for such filing) of the return, claim, statement, or other document, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4768e192-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for making the payment (including any extension granted for making such payment), and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4768e193-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the return, claim, statement, or other document, or payment was, within the time prescribed in subparagraph (A), deposited in the mail in the United States in an envelope or other appropriate wrapper, postage prepaid, properly addressed to the agency, officer, or office with which the return, claim, statement, or other document is required to be filed, or to which such payment is required to be made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4768e194-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postmarks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply in the case of postmarks not made by the United States Postal Service only if and to the extent provided by regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4768e195-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registered and certified mailing; electronic filing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4768e196-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registered mail","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, if any return, claim, statement, or other document, or payment, is sent by United States registered mail—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4768e197-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such registration shall be prima facie evidence that the return, claim, statement, or other document was delivered to the agency, officer, or office to which addressed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4768e198-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of registration shall be deemed the postmark date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4768e199-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified mail; electronic filing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to provide by regulations the extent to which the provisions of paragraph (1) with respect to prima facie evidence of delivery and the postmark date shall apply to certified mail and electronic filing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4768e19a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4768e19b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the filing of a document in, or the making of a payment to, any court other than the Tax Court,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4768e19c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" currency or other medium of payment unless actually received and accounted for, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4768e19d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" returns, claims, statements, or other documents, or payments, which are required under any provision of the internal revenue laws or the regulations thereunder to be delivered by any method other than by mailing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4768e19e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mailing of deposits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4768e19f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date of deposit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any deposit required to be made (pursuant to regulations prescribed by the Secretary under section 6302(c)) on or before a prescribed date is, after such date, delivered by the United States mail to the bank, trust company, domestic building and loan association, or credit union authorized to receive such deposit, such deposit shall be deemed received by such bank, trust company, domestic building and loan association, or credit union on the date the deposit was mailed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4768e1a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mailing requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall apply only if the person required to make the deposit establishes that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4768e1a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of mailing falls on or before the second day before the prescribed date for making the deposit (including any extension of time granted for making such deposit), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4768e1a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deposit was, on or before such second day, mailed in the United States in an envelope or other appropriate wrapper, postage prepaid, properly addressed to the bank, trust company, domestic building and loan association, or credit union authorized to receive such deposit.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In applying subsection (c) for purposes of this subsection, the term “payment” includes “deposit”, and the reference to the postmark date refers to the date of mailing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4768e1a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No application to certain deposits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply with respect to any deposit of $20,000 or more by any person who is required to deposit any tax more than once a month.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4768e1a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of private delivery services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4768e1a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in this section to the United States mail shall be treated as including a reference to any designated delivery service, and any reference in this section to a postmark by the United States Postal Service shall be treated as including a reference to any date recorded or marked as described in paragraph (2)(C) by any designated delivery service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4768e1a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated delivery service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “designated delivery service” means any delivery service provided by a trade or business if such service is designated by the Secretary for purposes of this section. The Secretary may designate a delivery service under the preceding sentence only if the Secretary determines that such service—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4768e1a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is available to the general public,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4768e1a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at least as timely and reliable on a regular basis as the United States mail,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4768e1a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" records electronically to its data base, kept in the regular course of its business, or marks on the cover in which any item referred to in this section is to be delivered, the date on which such item was given to such trade or business for delivery, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4768e1aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other criteria as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4768e1ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7502/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equivalents of registered and certified mail","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide a rule similar to the rule of paragraph (1) with respect to any service provided by a designated delivery service which is substantially equivalent to United States registered or certified mail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4768e1ac-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/895"},"text":"68A Stat. 895","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s89/a"},"text":"Pub. L. 85–866, title I, § 89(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1665"},"text":"72 Stat. 1665","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/713/s5/a"},"text":"Pub. L. 89–713, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1110"},"text":"80 Stat. 1110","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/364/tI/s106/a"},"text":"Pub. L. 90–364, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-28"},"text":"June 28, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/266"},"text":"82 Stat. 266","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1906(a)(49), (b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1831"},"text":"90 Stat. 1831","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/95/147/s3/b"},"text":"Pub. L. 95–147, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-28"},"text":"Oct. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1228"},"text":"91 Stat. 1228","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s157/a"},"text":"Pub. L. 98–369, div. A, title I, § 157(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/695"},"text":"98 Stat. 695","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1811/e"},"text":"Pub. L. 99–514, title XVIII, § 1811(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2833"},"text":"100 Stat. 2833","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/168/tXII/s1210"},"text":"Pub. L. 104–168, title XII, § 1210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1474"},"text":"110 Stat. 1474","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tII/s2003/b"},"text":"Pub. L. 105–206, title II, § 2003(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/725"},"text":"112 Stat. 725","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4768e1ad-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4768e1ae-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4768e1af-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" inserted “; electronic filing” after “mailing” in heading and amended text of subsec. (c) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Registered mail","children":[],"tail":".—For purposes of this section, if any such return, claim, statement, or other document, or payment, is sent by United States registered mail—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) such registration shall be prima facie evidence that the return, claim, statement, or other document was delivered to the agency, officer, or office to which addressed, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the date of registration shall be deemed the postmark date.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Certified mail","children":[],"tail":".—The Secretary is authorized to provide by regulations the extent to which the provisions of paragraph (1) of this subsection with respect to prima facie evidence of delivery and the postmark date shall apply to certified mail.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168"},"text":"Pub. L. 104–168","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “any tax” for “the tax”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/147"},"text":"Pub. L. 95–147","children":[],"tail":" substituted “, trust company, domestic building and loan association, or credit union” for “or trust company” in three places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/a/49"},"text":"Pub. L. 94–455, § 1906(a)(49)","children":[],"tail":", (b)(13)(A), substituted “United States Postal Service” for “United States Post Office” after “made by the”, and struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c)(2), (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/364"},"text":"Pub. L. 90–364","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/713"},"text":"Pub. L. 89–713","children":[],"tail":" inserted filing of tax returns and the payments of tax to the list of operations to which the timely-mailing-timely-filing provisions of the subsec. apply and altered the subsec. structurally by dividing its provisions into pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/713"},"text":"Pub. L. 89–713","children":[],"tail":" substituted “Postmarks” for “Stamp machine” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/713"},"text":"Pub. L. 89–713","children":[],"tail":" inserted returns and payments to the list of operations to which the timely-mailing-timely-filing provisions apply and altered par. (1) structurally by dividing its provisions into subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/713"},"text":"Pub. L. 89–713","children":[],"tail":" designated existing provisions as par. (1) and added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866"},"text":"Pub. L. 85–866","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4768e1b0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4768e1b1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/