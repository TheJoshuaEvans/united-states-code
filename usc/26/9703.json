{"tag":"section","attrib":{"id":"id47c385d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703"},"text":null,"children":[{"tag":"num","attrib":{"value":"9703"},"text":"§ 9703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47c385d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each eligible beneficiary of the Combined Fund shall receive—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c385d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health benefits described in subsection (b), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c385d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible beneficiary described in subsection (f)(1), death benefits coverage described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c385d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c385d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The trustees of the Combined Fund shall provide health care benefits to each eligible beneficiary by enrolling the beneficiary in a health care services plan which undertakes to provide such benefits on a prepaid risk basis. The trustees shall utilize all available plan resources to ensure that, consistent with paragraph (2), coverage under the managed care system shall to the maximum extent feasible be substantially the same as (and subject to the same limitations of) coverage provided under the 1950 UMWA Benefit Plan and the 1974 UMWA Benefit Plan as of ","children":[{"tag":"date","attrib":{"date":"1992-01-01"},"text":"January 1, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c385d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan payment rates","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c385d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The trustees of the Combined Fund shall negotiate payment rates with the health care services plans described in paragraph (1) for each plan year which are in amounts which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47c385da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vary as necessary to ensure that beneficiaries in different geographic areas have access to a uniform level of health benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47c385db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in aggregate payments for such plan year from the Combined Fund which do not exceed the total premium payments required to be paid to the Combined Fund under section 9704(a) for the plan year, adjusted as provided in subparagraphs (B) and (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c385dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reductions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount determined under subparagraph (A)(ii) for any plan year shall be reduced—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47c385dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the aggregate death benefit premiums determined under section 9704(c) for the plan year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47c385de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the amount reserved for plan administration under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c385df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount determined under subparagraph (A)(ii) shall be increased—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47c385e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any reduction in the total premium payments required to be paid under section 9704(a) by reason of transfers described in section 9705,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47c385e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" by any carryover to the plan year from any preceding plan year which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id47c385e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/b/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is derived from amounts described in section 9704(e)(3)(B)(i), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id47c385e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/b/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trustees elect to use to pay benefits for the current plan year, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47c385e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any interest earned by the Combined Fund which the trustees elect to use to pay benefits for the current plan year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c385e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified providers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The trustees of the Combined Fund shall not enter into an agreement under paragraph (1) with any provider of services which is of a type which is required to be certified by the Secretary of Health and Human Services when providing services under title XVIII of the Social Security Act unless the provider is so certified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c385e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Benefits shall be provided under paragraph (1) on and after ","children":[{"tag":"date","attrib":{"date":"1993-02-01"},"text":"February 1, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c385e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Death benefits coverage","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c385e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The trustees of the Combined Fund shall provide death benefits coverage to each eligible beneficiary described in subsection (f)(1) which is identical to the benefits provided under the 1950 UMWA Pension Plan or 1974 UMWA Pension Plan, whichever is applicable, on ","children":[{"tag":"date","attrib":{"date":"1992-07-20"},"text":"July 20, 1992","children":[],"tail":". Such coverage shall be provided on and after "},{"tag":"date","attrib":{"date":"1993-02-01"},"text":"February 1, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c385e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The 1950 UMWA Pension Plan and the 1974 UMWA Pension Plan shall each be amended to provide that death benefits coverage shall not be provided to eligible beneficiaries on and after ","children":[{"tag":"date","attrib":{"date":"1993-02-01"},"text":"February 1, 1993","children":[],"tail":". This paragraph shall not prohibit such plans from subsequently providing death benefits not described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c385ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserves for administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The trustees of the Combined Fund may reserve for each plan year, for use in payment of the administrative costs of the Combined Fund, an amount not to exceed 5 percent of the premiums to be paid to the Combined Fund under section 9704(a) during the plan year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c385eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on enrollment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Combined Fund shall not enroll any individual who is not receiving benefits under the 1950 UMWA Benefit Plan or the 1974 UMWA Benefit Plan as of ","children":[{"tag":"date","attrib":{"date":"1992-07-20"},"text":"July 20, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c385ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible beneficiary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the term “eligible beneficiary” means an individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c385ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a coal industry retiree who, on ","children":[{"tag":"date","attrib":{"date":"1992-07-20"},"text":"July 20, 1992","children":[],"tail":", was eligible to receive, and receiving, benefits from the 1950 UMWA Benefit Plan or the 1974 UMWA Benefit Plan, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c385ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9703/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on such date was eligible to receive, and receiving, benefits in either such plan by reason of a relationship to such retiree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47c385ef-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s19143/a"},"text":"Pub. L. 102–486, title XIX, § 19143(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3041"},"text":"106 Stat. 3041","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47c385f0-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47c385f1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id47c385f2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title XVIII of the Act is classified generally to subchapter XVIII (§ 1395 et seq.) of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
