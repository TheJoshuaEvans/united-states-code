{"tag":"section","attrib":{"id":"id44266110-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A"},"text":null,"children":[{"tag":"num","attrib":{"value":"853A"},"text":"§ 853A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits from tax credit bonds allowed to shareholders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44266111-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A regulated investment company—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44266112-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which holds (directly or indirectly) one or more tax credit bonds on one or more applicable dates during the taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44266113-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which meets the requirements of section 852(a) for the taxable year (determined after the application of this section),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may elect the application of this section with respect to some or all of the credits allowable (determined without regard to this section and sections 54(c), 54A(c)(1), 54AA(c)(1), and 1397E(c)) ","children":[{"tag":"ref","attrib":{"idref":"fn002136"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002136"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" to the investment company during such taxable year with respect to such bonds."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44266114-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of election","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the election provided in subsection (a) is in effect with respect to any credits for any taxable year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44266115-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the regulated investment company—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44266116-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be allowed such credits,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44266117-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include in gross income (as interest) for such taxable year the amount which would have been so included with respect to such credits had the application of this section not been elected,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44266118-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include in earnings and profits the amount so included in gross income, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44266119-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be treated as making one or more distributions of money with respect to its stock equal to the amount of such credits on the date or dates (on or after the applicable date for any such credit) during such taxable year (or following the close of the taxable year pursuant to section 855) selected by the company, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4426611a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each shareholder of such investment company shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4426611b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be treated as receiving such shareholder’s proportionate share of any distribution of money which is treated as made by such investment company under paragraph (1)(D), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4426611c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be allowed credits against the tax imposed by this chapter equal to the amount of such distribution, subject to the provisions of this title applicable to the credit involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4426611d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements ","children":[{"tag":"ref","attrib":{"idref":"fn002137"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002137"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See 2010 Amendment note below."}],"tail":" to shareholders"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount treated as a distribution of money received by a shareholder under subsection (b)(2)(A) (and as credits allowed to such shareholder under subsection (b)(2)(B)) shall not exceed the amount so reported by the regulated investment company in a written statement furnished to such shareholder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4426611e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of making election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The election provided in subsection (a) shall be made in such manner as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4426611f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44266120-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44266121-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax credit bond","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “tax credit bond” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44266122-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualified tax credit bond (as defined in section 54A(d)),","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44266123-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a build America bond (as defined in section 54AA(d)) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" other than a qualified bond described in section 54AA(g),"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44266124-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any bond for which a credit is allowable under subpart H of part IV of subchapter A of this chapter.","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44266125-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable date","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable date” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44266126-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a qualified tax credit bond or a bond described in subparagraph (A)(iii), any credit allowance date (as defined in section 54A(e)(1)),","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44266127-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a build America bond (as defined in section 54AA(d)),","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" any interest payment date (as defined in section 54AA(e))."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44266128-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stripped tax credit bonds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the ownership of a tax credit bond is separated from the credit with respect to such bond, subsection (a) shall be applied by reference to the instruments evidencing the entitlement to the credit rather than the tax credit bond.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44266129-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s853A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations or other guidance as may be necessary or appropriate to carry out the purposes of this section, including methods for determining a shareholder’s proportionate share of credits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4426612a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI/s1541/a"},"text":"Pub. L. 111–5, div. B, title I, § 1541(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/360"},"text":"123 Stat. 360","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/325/tIII/s301/d"},"text":"Pub. L. 111–325, title III, § 301(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3544"},"text":"124 Stat. 3544","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s209/h"},"text":"Pub. L. 113–295, div. A, title II, § 209(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4029"},"text":"128 Stat. 4029","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4426612b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4426612c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4426612d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 54, 54A, and 54AA, referred to in subsecs. (a) and (e)(1), were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13404/a"},"text":"Pub. L. 115–97, title I, § 13404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2138"},"text":"131 Stat. 2138","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1397E, referred to in subsec. (a), was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13404/c/1"},"text":"Pub. L. 115–97, title I, § 13404(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2138"},"text":"131 Stat. 2138","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subpart H of part IV of subchapter A of this chapter, referred to in subsec. (e)(1)(A)(iii), is subpart H (§ 54) of part IV of subchapter A of chapter 1 of this title, which was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13404/a"},"text":"Pub. L. 115–97, title I, § 13404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2138"},"text":"131 Stat. 2138","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4426612e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s209/h/2"},"text":"Pub. L. 113–295, § 209(h)(2)","children":[],"tail":", in concluding provisions, substituted “with respect to some or all of the credits” for “with respect to credits” and inserted “(determined without regard to this section and sections 54(c), 54A(c)(1), 54AA(c)(1), and 1397E(c))” after “credits allowable”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s209/h/1"},"text":"Pub. L. 113–295, § 209(h)(1)","children":[],"tail":", inserted “(determined after the application of this section)” before comma at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s209/h/3"},"text":"Pub. L. 113–295, § 209(h)(3)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) consisted of pars. (1) to (3) relating to effects of elections under subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s209/h/4"},"text":"Pub. L. 113–295, § 209(h)(4)","children":[],"tail":", amended subsec. (c) generally. The amendment was effective as if included in the provisions of the American Recovery and Reinvestment Tax Act of 2009 ("},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI"},"text":"Pub. L. 111–5, div. B, title I","children":[],"tail":") to which it relates. As enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/s1541/a"},"text":"Pub. L. 111–5, § 1541(a)","children":[],"tail":", subsec. (c) read as follows: “"},{"tag":"inline","attrib":{},"text":"Notice to Shareholders","children":[],"tail":".—For purposes of subsection (b)(3), the shareholder’s proportionate share of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) credits described in subsection (a), and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) gross income in respect of such credits,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"shall not exceed the amounts so designated by the regulated investment company in a written notice mailed to its shareholders not later than 60 days after the close of its taxable year.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s209/h/5"},"text":"Pub. L. 113–295, § 209(h)(5)","children":[],"tail":", inserted “other than a qualified bond described in section 54AA(g)” after “as defined in section 54AA(d))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325/s301/d/1"},"text":"Pub. L. 111–325, § 301(d)(1)","children":[],"tail":", which directed substitution of “Statements” for “Notice” in heading and “so reported by the regulated investment company in a written statement furnished to such shareholder” for “so designated by the regulated investment company in a written notice mailed to its shareholders not later than 60 days after the close of its taxable year” in text, could not be executed to the text because the words “so reported by the regulated investment company in a written statement furnished to such shareholder” already appeared after the subsequent general amendment of subsec. (c) by "},{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" which was effective as if included in the provisions of the American Recovery and Reinvestment Tax Act of 2009 ("},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI"},"text":"Pub. L. 111–5, div. B, title I","children":[],"tail":") to which it relates. However, the substitution was executed to the heading to reflect the probable intent of Congress. See 2014 Amendment note above and Effective Date of 2014 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325/s301/d/2"},"text":"Pub. L. 111–325, § 301(d)(2)","children":[],"tail":", struck out “and notifying shareholders” after “election” in heading and “and the notice to shareholders required by subsection (c)” after “subsection (a)” in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4428ab1f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4428ab20-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" effective as if included in the provisions of the American Recovery and Reinvestment Tax Act of 2009, "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI"},"text":"Pub. L. 111–5, div. B, title I","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s209/k"},"text":"section 209(k) of Pub. L. 113–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s24"},"text":"section 24 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4428ab21-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325"},"text":"Pub. L. 111–325","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/325/s301/h"},"text":"section 301(h) of Pub. L. 111–325","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s852"},"text":"section 852 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4428ab22-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI/s1541/c"},"text":"Pub. L. 111–5, div. B, title I, § 1541(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/362"},"text":"123 Stat. 362","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/5/dB/tI/s1541/c"},"text":"“The amendments made by this section [enacting this section and amending sections 54 and 54A of this title] shall apply to taxable years ending after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
