{"tag":"section","attrib":{"id":"id44514172-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s872"},"text":null,"children":[{"tag":"num","attrib":{"value":"872"},"text":"§ 872.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gross income","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44514173-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s872/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a nonresident alien individual, except where the context clearly indicates otherwise, gross income includes only—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44514174-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s872/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gross income which is derived from sources within the United States and which is not effectively connected with the conduct of a trade or business within the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44514175-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s872/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gross income which is effectively connected with the conduct of a trade or business within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44514176-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s872/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following items shall not be included in gross income of a nonresident alien individual, and shall be exempt from taxation under this subtitle:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44514177-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s872/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ships operated by certain nonresidents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross income derived by an individual resident of a foreign country from the international operation of a ship or ships if such foreign country grants an equivalent exemption to individual residents of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44514178-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s872/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aircraft operated by certain nonresidents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross income derived by an individual resident of a foreign country from the international operation of aircraft if such foreign country grants an equivalent exemption to individual residents of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44514179-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s872/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of participants in certain exchange or training programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Compensation paid by a foreign employer to a nonresident alien individual for the period he is temporarily present in the United States as a nonimmigrant under subparagraph (F), (J), or (Q) of section 101(a)(15) of the Immigration and Nationality Act, as amended. For purposes of this paragraph, the term “foreign employer” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4451417a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s872/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonresident alien individual, foreign partnership, or foreign corporation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4451417b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s872/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an office or place of business maintained in a foreign country or in a possession of the United States by a domestic corporation, a domestic partnership, or an individual who is a citizen or resident of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4451417c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s872/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain bond income of residents of the Ryukyu Islands or the Trust Territory of the Pacific Islands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Income derived by a nonresident alien individual from a series E or series H United States savings bond, if such individual acquired such bond while a resident of the Ryukyu Islands or the Trust Territory of the Pacific Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4451417d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s872/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income derived from wagering transactions in certain parimutuel pools","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross income derived by a nonresident alien individual from a legal wagering transaction initiated outside the United States in a parimutuel pool with respect to a live horse race or dog race in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4451417e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s872/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain rental income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Income to which paragraphs (1) and (2) apply shall include income which is derived from the rental on a full or bareboat basis of a ship or ships or aircraft, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4451417f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s872/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to different types of transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide that this subsection be applied separately with respect to income from different types of transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44514180-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s872/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of possessions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent provided in regulations, a possession of the United States shall be treated as a foreign country for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44514181-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/280"},"text":"68A Stat. 280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/256/s110/c"},"text":"Pub. L. 87–256, § 110(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-21"},"text":"Sept. 21, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/536"},"text":"75 Stat. 536","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/tI/s103/b"},"text":"Pub. L. 89–809, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1550"},"text":"80 Stat. 1550","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1212/c/1"},"text":"Pub. L. 99–514, title XII, § 1212(c)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2538"},"text":"100 Stat. 2538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/e/2/B"},"text":"Pub. L. 100–647, title I, § 1012(e)(2)(B)","children":[],"tail":", (5), (s)(2)(A), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3500"},"text":"102 Stat. 3500","children":[],"tail":", 3527; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7811/i/8/C"},"text":"Pub. L. 101–239, title VII, § 7811(i)(8)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2411"},"text":"103 Stat. 2411","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/296/tIII/s320/a/2"},"text":"Pub. L. 103–296, title III, § 320(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-15"},"text":"Aug. 15, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1535"},"text":"108 Stat. 1535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIV/s419/a"},"text":"Pub. L. 108–357, title IV, § 419(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1513"},"text":"118 Stat. 1513","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44514182-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44514183-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id44514184-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 101 of the Immigration and Nationality Act, referred to in subsec. (b)(3), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44514185-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(5) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" added par. (5) and redesignated former pars. (5) to (7) as (6) to (8), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296"},"text":"Pub. L. 103–296","children":[],"tail":" substituted “(F), (J), or (Q)” for “(F) or (J)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1012/s/2/A"},"text":"Pub. L. 100–647, § 1012(s)(2)(A)","children":[],"tail":", inserted “, except where the context clearly indicates otherwise” after “individual”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1012/e/2/B"},"text":"Pub. L. 100–647, § 1012(e)(2)(B)","children":[],"tail":", (5), substituted “to individual residents of the United States” for “to citizens of the United States and to corporations organized in the United States” and “international operation” for “operation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1212/c/1"},"text":"Pub. L. 99–514, § 1212(c)(1)","children":[],"tail":", added par. (1) and struck out former par. (1), ships under foreign flag, which read as follows: “Earnings derived from the operation of a ship or ships documented under the laws of a foreign country which grants an equivalent exemption to citizens of the United States and to corporations organized in the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1212/c/1"},"text":"Pub. L. 99–514, § 1212(c)(1)","children":[],"tail":", added par. (2) and struck out former par. (2), aircraft of foreign registry, which read as follows: “Earnings derived from the operation of aircraft registered under the laws of a foreign country which grants an equivalent exemption to citizens of the United States and to corporations organized in the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1212/c/2"},"text":"Pub. L. 99–514, § 1212(c)(2)","children":[],"tail":", added pars. (5) and (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809/s103/b/1"},"text":"Pub. L. 89–809, § 103(b)(1)","children":[],"tail":", limited the inclusion of gross income which is derived from sources within the United States to such income which is not effectively connected with the conduct of a trade or business within the United States and inserted provision including gross income without the limitation as to source which is effectively connected with the conduct of a trade or business within the United States."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809/s103/b/2"},"text":"Pub. L. 89–809, § 103(b)(2)","children":[],"tail":", substituted “by a domestic corporation, a domestic partnership, or an individual who is a citizen or resident of the United States” for “by a domestic corporation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809/s102/b/3"},"text":"Pub. L. 89–809, § 102(b)(3)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1961—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/256"},"text":"Pub. L. 87–256","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44514186-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44514187-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIV/s419/c"},"text":"Pub. L. 108–357, title IV, § 419(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1513"},"text":"118 Stat. 1513","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tIV/s419/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s883"},"text":"section 883 of this title","children":[],"tail":"] shall apply to wagers made after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44514188-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296"},"text":"Pub. L. 103–296","children":[],"tail":" effective with calendar quarter following "},{"tag":"date","attrib":{"date":"1994-08-15"},"text":"Aug. 15, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/296/s320/c"},"text":"section 320(c) of Pub. L. 103–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s871"},"text":"section 871 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44514189-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Technical and Miscellaneous Revenue Act of 1988, "},{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7817"},"text":"section 7817 of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4451418a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such a