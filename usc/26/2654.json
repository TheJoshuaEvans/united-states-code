{"tag":"section","attrib":{"id":"id454ba7d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2654"},"text":null,"children":[{"tag":"num","attrib":{"value":"2654"},"text":"§ 2654.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id454ba7d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2654/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis adjustment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454ba7d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2654/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), if property is transferred in a generation-skipping transfer, the basis of such property shall be increased (but not above the fair market value of such property) by an amount equal to that portion of the tax imposed by section 2601 with respect to the transfer which is attributable to the excess of the fair market value of such property over its adjusted basis immediately before the transfer. The preceding shall be applied after any basis adjustment under section 1015 with respect to the transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba7d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2654/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain transfers at death","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If property is transferred in a taxable termination which occurs at the same time as and as a result of the death of an individual, the basis of such property shall be adjusted in a manner similar to the manner provided under section 1014(a); except that, if the inclusion ratio with respect to such property is less than 1, any increase or decrease in basis shall be limited by multiplying such increase or decrease (as the case may be) by the inclusion ratio.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454ba7d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2654/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain trusts treated as separate trusts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454ba7d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2654/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the portions of a trust attributable to transfers from different transferors shall be treated as separate trusts, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba7d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2654/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially separate and independent shares of different beneficiaries in a trust shall be treated as separate trusts.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Except as provided in the preceding sentence, nothing in this chapter shall be construed as authorizing a single trust to be treated as 2 or more trusts. For purposes of this subsection, a trust shall be treated as part of an estate during any period that the trust is so treated under section 645.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454ba7d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2654/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclaimers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions relating to the effect of a qualified disclaimer for purposes of this chapter, see section 2518.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454ba7d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2654/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on personal liability of trustee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A trustee shall not be personally liable for any increase in the tax imposed by section 2601 which is attributable to the fact that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454ba7da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2654/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 2642(c) (relating to exemption of certain nontaxable gifts) does not apply to a transfer to the trust which was made during the life of the transferor and for which a gift tax return was not filed, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba7db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2654/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inclusion ratio with respect to the trust is greater than the amount of such ratio as computed on the basis of the return on which was made (or was deemed made) an allocation of the GST exemption to property transferred to such trust.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The preceding sentence shall not apply if the trustee has knowledge of facts sufficient reasonably to conclude that a gift tax return was required to be filed or that the inclusion ratio was erroneous.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id454ba7dc-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIV/s1431/a"},"text":"Pub. L. 99–514, title XIV, § 1431(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2727"},"text":"100 Stat. 2727","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1014/g/12"},"text":"Pub. L. 100–647, title I, § 1014(g)(12)","children":[],"tail":", (13), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3565"},"text":"102 Stat. 3565","children":[],"tail":", 3566; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7811/j/2"},"text":"Pub. L. 101–239, title VII, § 7811(j)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2411"},"text":"103 Stat. 2411","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tVI/s6013/a/4/B"},"text":"Pub. L. 105–206, title VI, § 6013(a)(4)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/819"},"text":"112 Stat. 819","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/95/B/iii"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(95)(B)(iii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4051"},"text":"128 Stat. 4051","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id454ba7dd-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id454ba7de-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id454ba7df-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" struck out “(computed without regard to section 2604)” after “section 2601”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" inserted at end “For purposes of this subsection, a trust shall be treated as part of an estate during any period that the trust is so treated under section 645.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" inserted at end “The preceding shall be applied after any basis adjustment under section 1015 with respect to the transfer.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1014/g/12"},"text":"Pub. L. 100–647, § 1014(g)(12)","children":[],"tail":", inserted “or decrease” after “any increase” and “or decrease (as the case may be)” after “such increase”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1014/g/13"},"text":"Pub. L. 100–647, § 1014(g)(13)","children":[],"tail":", substituted “Certain trusts” for “Separate shares” in heading and amended text generally. Prior to amendment, text read as follows: “Substantially separate and independent shares of different beneficiaries in a trust shall be treated as separate trusts.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id454ba7e0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id454ba7e1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/b"},"text":"section 221(b) of Pub. L. 113–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id454ba7e2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":