{"tag":"section","attrib":{"id":"id45041760-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1400Z–1"},"text":"§ 1400Z–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45041761-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified opportunity zone defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this subchapter, the term “qualified opportunity zone” means a population census tract that is a low-income community that is designated as a qualified opportunity zone.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45041762-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45041763-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), a population census tract that is a low-income community is designated as a qualified opportunity zone if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45041764-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than the end of the determination period, the chief executive officer of the State in which the tract is located—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45041765-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nominates the tract for designation as a qualified opportunity zone, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45041766-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifies the Secretary in writing of such nomination, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45041767-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary certifies such nomination and designates such tract as a qualified opportunity zone before the end of the consideration period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45041768-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of periods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A chief executive officer of a State may request that the Secretary extend either the determination or consideration period, or both (determined without regard to this subparagraph),","children":[{"tag":"ref","attrib":{"idref":"fn002183"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002183"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “paragraph),”."}],"tail":" for an additional 30 days."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45041769-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for Puerto Rico","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each population census tract in Puerto Rico that is a low-income community shall be deemed to be certified and designated as a qualified opportunity zone, effective on the date of the enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Public Law 115–97","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4504176a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4504176b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income communities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “low-income community” means any population census tract if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4504176c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such population census tract has a median family income that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4504176d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a population census tract not located within a metropolitan area, does not exceed 70 percent of the statewide median family income, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4504176e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a population census tract located within a metropolitan area, does not exceed 70 percent of the metropolitan area median family income, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4504176f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such population census tract—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45041770-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a poverty rate of at least 20 percent, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45041771-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has a median family income that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id45041772-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/c/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a population census tract not located within a metropolitan area, does not exceed 125 percent of the statewide median family income, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id45041773-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/c/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a population census tract located within a metropolitan area, does not exceed 125 percent of the metropolitan area median family income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45041774-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of periods","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45041775-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “consideration period” means the 30-day period beginning on the date on which the Secretary receives notice under subsection (b)(1)(A)(ii), as extended under subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45041776-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “determination period” means the 90-day period beginning on the decennial determination date, as extended under subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45041777-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decennial determination date","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “decennial determination date” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45041778-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2026-07-01"},"text":"July 1, 2026","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45041779-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each July 1 of the year that is 10 years after the preceding decennial determination date under this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4504177a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “State” includes any possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4504177b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of designations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4504177c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided by paragraph (2), the number of population census tracts in a State that may be designated as qualified opportunity zones under this section during any period may not exceed 25 percent of the number of low-income communities in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4504177d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the number of low-income communities in a State is less than 100, then a total of 25 of such tracts may be designated as qualified opportunity zones during any period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4504177e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period for which designation is in effect","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4504177f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A designation as a qualified opportunity zone shall remain in effect for the period beginning on the applicable start date and ending on the day before the date that is 10 years after the applicable start date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45041780-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1400Z–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable start date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “applicable start date” means, with respect to any qualified opportunity zone designated under this section, the January 1 following the date on which such qualified opportunity zone was certified and designated by the Secretary under subsection (b)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45041781-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13823/a"},"text":"Pub. L. 115–97, title I, § 13823(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2183"},"text":"131 Stat. 2183","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dD/tII/s41115"},"text":"Pub. L. 115–123, div. D, title II, § 41115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/161"},"text":"132 Stat. 161","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70421/a/1"},"text":"Pub. L. 119–21, title VII, § 70421(a)(1)","children":[],"tail":"–(4), (b)(1)–(3), "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/223"},"text":"139 Stat. 223","children":[],"tail":", 224.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45041782-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id45041783-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Subsection (b)(3)","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70421/a/3"},"text":"Pub. L. 119–21, title VII, § 70421(a)(3)","children":[],"tail":", (5)(B), "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/223"},"text":"139 Stat. 223","children":[],"tail":", 224, provided that, effective on "},{"tag":"date","attrib":{"date":"2026-12-31"},"text":"Dec. 31, 2026","children":[],"tail":", subsection (b)(3) of this section is repealed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45041784-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id45041785-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Public Law 115–97","children":[],"tail":", referred to in subsec. (b)(3), is "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45041786-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70421/a/3"},"text":"Pub. L. 119–21, § 70421(a)(3)","children":[],"tail":", struck out par. (3). Text read as follows: “Each population census tract in Puerto Rico that is a low-income community shall be deemed to be certified and designated as a qualified opportunity zone, effective on the date of the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Public Law 115–97","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70421/b/1"},"text":"Pub. L. 119–21, § 70421(b)(1)","children":[],"tail":", substituted “For purposes of this section—” for “For purposes of this subsection—” in introductory provisions, added par. (1), and struck out former par. (1). Prior to amendment, text read as follows: “The term ‘low-income community’ has the same meaning as when used in section 45D(e).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70421/a/1"},"text":"Pub. L. 119–21, § 70421(a)(1)","children":[],"tail":", substituted “beginning on the decennial determination date” for “beginning on the date of the enactment of the Tax Cuts and Jobs Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70421/a/2"},"text":"Pub. L. 119–21, § 70421(a)(2)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70421/a/4/A"},"text":"Pub. L. 119–21, § 70421(a)(4)(A)","children":[],"tail":", struck out “and subsection (b)(3)” after “by paragraph (2)” and inserted “during any period” after “the number of population census tracts in a State that may be designated as qualified opportunity zones under this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70421/a/4/B"},"text":"Pub. L. 119–21, § 70421(a)(4)(B)","children":[],"tail":", inserted “during any period” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70421/b/3"},"text":"Pub. L. 119–21, § 70421(b)(3)","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, text read as follows: “A designation as a qualified opportunity zone shall remain in effect for the period beginning on the date of the designation and ending at the close of the 10th calendar year beginning on or after such date of designation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70421/b/2"},"text":"Pub. L. 119–21, § 70421(b)(2)","children":[],"tail":", redesignated subsec. (f) as (e) and struck out former subsec. (e) which related to designation of tracts contiguous with low-income communities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","at