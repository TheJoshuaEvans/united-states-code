{"tag":"section","attrib":{"id":"id45d5e5ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4377"},"text":null,"children":[{"tag":"num","attrib":{"value":"4377"},"text":"§ 4377.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45d5e5cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4377/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d5e5cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4377/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accident and health coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “accident and health coverage” means any coverage which, if provided by an insurance policy, would cause such policy to be a specified health insurance policy (as defined in section 4375(c)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e5cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4377/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurance policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “insurance policy” means any policy or other instrument whereby a contract of insurance is issued, renewed, or extended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e5ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4377/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” includes any possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d5e5cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4377/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of governmental entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d5e5d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4377/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45d5e5d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4377/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “person” includes any governmental entity, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d5e5d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4377/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding any other law or rule of law, governmental entities shall not be exempt from the fees imposed by this subchapter except as provided in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e5d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4377/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of exempt governmental programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an exempt governmental program, no fee shall be imposed under section 4375 or section 4376 on any covered life under such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e5d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4377/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempt governmental program defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the term “exempt governmental program” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45d5e5d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4377/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any insurance program established under title XVIII of the Social Security Act,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d5e5d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4377/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the medical assistance program established by title XIX or XXI of the Social Security Act,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d5e5d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4377/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any program established by Federal law for providing medical care (other than through insurance policies) to individuals (or the spouses and dependents thereof) by reason of such individuals being members of the Armed Forces of the United States or veterans, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d5e5d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4377/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any program established by Federal law for providing medical care (other than through insurance policies) to members of Indian tribes (as defined in section 4(d) of the Indian Health Care Improvement Act).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d5e5d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4377/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subtitle F, the fees imposed by this subchapter shall be treated as if they were taxes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d5e5da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4377/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No cover over to possessions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, no amount collected under this subchapter shall be covered over to any possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d5e5db-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6301/e/2/A"},"text":"Pub. L. 111–148, title VI, § 6301(e)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/746"},"text":"124 Stat. 746","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45d5e5dc-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45d5e5dd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id45d5e5de-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (b)(3)(A), (B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Titles XVIII, XIX, and XXI of the Act are classified generally to subchapters XVIII (§ 1395 et seq.), XIX (§ 1396 et seq.), and XXI (§ 1397aa et seq.), respectively, of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4(d) of the Indian Health Care Improvement Act, referred to in subsec. (b)(3)(D), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603/d"},"text":"section 1603(d) of Title 25","children":[],"tail":", Indians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
