{"tag":"section","attrib":{"id":"id44b09fbc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1055"},"text":null,"children":[{"tag":"num","attrib":{"value":"1055"},"text":"§ 1055.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redeemable ground rents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44b09fbd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1055/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Character","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subtitle—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44b09fbe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1055/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a redeemable ground rent shall be treated as being in the nature of a mortgage, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b09fbf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1055/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" real property held subject to liabilities under a redeemable ground rent shall be treated as held subject to liabilities under a mortgage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44b09fc0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1055/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of subsection (a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44b09fc1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1055/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall take effect on the day after the date of the enactment of this section and shall apply with respect to taxable years ending after such date of enactment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b09fc2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1055/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis of holder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the basis of real property held subject to liabilities under a redeemable ground rent, subsection (a) shall apply whether such real property was acquired before or after the enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b09fc3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1055/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis of reserved redeemable ground rent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a redeemable ground rent reserved or created on or before the date of the enactment of this section in connection with a transfer of the right to hold real property subject to liabilities under such ground rent, the basis of such ground rent after such date in the hands of the person who reserved or created the ground rent shall be the amount taken into account in respect of such ground rent for Federal income tax purposes as consideration for the disposition of such real property. If no such amount was taken into account, such basis shall be determined as if this section had not been enacted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44b09fc4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1055/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redeemable ground rent defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subtitle, the term “redeemable ground rent” means only a ground rent with respect to which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44b09fc5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1055/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a lease of land which is assignable by the lessee without the consent of the lessor and which (together with periods for which the lease may be renewed at the option of the lessee) is for a term in excess of 15 years,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b09fc6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1055/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the leaseholder has a present or future right to terminate, and to acquire the entire interest of the lessor in the land, by payment of a determined or determinable amount, which right exists by virtue of State or local law and not because of any private agreement or privately created condition, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b09fc7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1055/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lessor’s interest in the land is primarily a security interest to protect the rental payments to which the lessor is entitled under the lease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44b09fc8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1055/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For treatment of rentals under redeemable ground rents as interest, see section 163(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44b09fc9-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/9/s1/b"},"text":"Pub. L. 88–9, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-04-10"},"text":"Apr. 10, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/7"},"text":"77 Stat. 7","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44b09fca-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44b09fcb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id44b09fcc-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Date of the enactment of this section, referred to in subsec. (b)(1), (3), means ","children":[{"tag":"date","attrib":{"date":"1963-04-10"},"text":"Apr. 10, 1963","children":[],"tail":", the date of approval of "},{"tag":"ref","attrib":{"href":"/us/pl/88/9"},"text":"Pub. L. 88–9","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id44b09fcd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1055 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1063"},"text":"section 1063 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44b09fce-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44b09fcf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/9/s2"},"text":"Pub. L. 88–9, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-04-10"},"text":"Apr. 10, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/8"},"text":"77 Stat. 8","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/88/9/s2"},"text":"“The amendments made by subsection (a) of the first section of this Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s163"},"text":"section 163 of this title","children":[],"tail":"] shall take effect as of "},{"tag":"date","attrib":{"date":"1962-01-01"},"text":"January 1, 1962","children":[],"tail":", and shall apply with respect to taxable years ending on or after such date. The amendments made by subsection (b) of the first section of this Act [enacting this section] shall take effect on the day after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1963-04-10"},"text":"Apr. 10, 1963","children":[],"tail":"] and shall apply with respect to taxable years ending after such date of enactment.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
