{"tag":"section","attrib":{"id":"id47c385bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9702"},"text":null,"children":[{"tag":"num","attrib":{"value":"9702"},"text":"§ 9702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of the United Mine Workers of America Combined Benefit Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47c385be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c385bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable (but not later than 60 days) after the enactment date, the persons described in subsection (b) shall designate the individuals to serve as trustees. Such trustees shall create a new private plan to be known as the United Mine Workers of America Combined Benefit Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c385c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merger of retiree benefit plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As of ","children":[{"tag":"date","attrib":{"date":"1993-02-01"},"text":"February 1, 1993","children":[],"tail":", the settlors of the 1950 UMWA Benefit Plan and the 1974 UMWA Benefit Plan shall cause such plans to be merged into the Combined Fund, and such merger shall not be treated as an employer withdrawal for purposes of any 1988 coal wage agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c385c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9702/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Combined Fund shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c385c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9702/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan described in section 302(c)(5) of the Labor Management Relations Act, 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s186/c/5"},"text":"29 U.S.C. 186(c)(5)","children":[],"tail":"),"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c385c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9702/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee welfare benefit plan within the meaning of section 3(1) of the Employee Retirement Income Security Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002/1"},"text":"29 U.S.C. 1002(1)","children":[],"tail":"), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c385c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9702/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a multiemployer plan within the meaning of section 3(37) of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002/37"},"text":"29 U.S.C. 1002(37)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c385c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9702/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this title, the Combined Fund and any related trust shall be treated as an organization exempt from tax under section 501(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c385c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of trustees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c385c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the board of trustees for the Combined Fund shall be appointed as follows—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c385c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9702/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 individuals who represent employers in the coal mining industry shall be designated by the BCOA;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c385c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9702/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 individuals designated by the United Mine Workers of America; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c385ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9702/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 individuals selected by the individuals appointed under subparagraphs (A) and (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c385cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Successor trustees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any successor trustee shall be appointed in the same manner as the trustee being succeeded. The plan establishing the Combined Fund shall provide for the removal of trustees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c385cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9702/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the BCOA ceases to exist, any trustee or successor under paragraph (1)(A) shall be designated by the 3 employers who were members of the BCOA on the enactment date and who have been assigned the greatest number of eligible beneficiaries under section 9706.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c385cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The first plan year of the Combined Fund shall begin ","children":[{"tag":"date","attrib":{"date":"1993-02-01"},"text":"February 1, 1993","children":[],"tail":", and end "},{"tag":"date","attrib":{"date":"1993-09-30"},"text":"September 30, 1993","children":[],"tail":". Each succeeding plan year shall begin on October 1 of each calendar year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47c385ce-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s19143/a"},"text":"Pub. L. 102–486, title XIX, § 19143(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3040"},"text":"106 Stat. 3040","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dC/tII/s213/a"},"text":"Pub. L. 109–432, div. C, title II, § 213(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3027"},"text":"120 Stat. 3027","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47c385cf-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47c385d0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47c385d1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" reenacted heading without change and amended text of subsec. (b) generally. Prior to amendment, text contained provisions which related to: in par. (1), appointment of one trustee by the BCOA, one by the three employers having the greatest number of eligible beneficiaries under section 9706, two by the United Mine Workers of America, and three by the persons otherwise appointed; in par. (2), successor trustees and removal of trustees; and in par. (3), special rules relating to designation of trustees or successor trustees if the BCOA should cease to exist and designation of the initial trustee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
