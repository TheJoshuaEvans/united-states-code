{"tag":"section","attrib":{"id":"id4749e8c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7303"},"text":null,"children":[{"tag":"num","attrib":{"value":"7303"},"text":"§ 7303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other property subject to forfeiture","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There may be seized and forfeited to the United States the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4749e8c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7303/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counterfeit stamps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every stamp involved in the offense described in section 7208 (relating to counterfeit, reused, cancelled, etc., stamps), and the vellum, parchment, document, paper, package, or article upon which such stamp was placed or impressed in connection with such offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4749e8c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7303/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False stamping of packages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any container involved in the offense described in section 7271 (relating to disposal of stamped packages), and of the contents of such container.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4749e8c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7303/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraudulent bonds, permits, and entries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All property to which any false or fraudulent instrument involved in the offense described in section 7207 relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4749e8c6-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/868"},"text":"68A Stat. 868","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/881/s1/c"},"text":"Pub. L. 85–881, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1704"},"text":"72 Stat. 1704","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/490/s3/b/5"},"text":"Pub. L. 93–490, § 3(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-26"},"text":"Oct. 26, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1467"},"text":"88 Stat. 1467","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1904/b/8/G"},"text":"Pub. L. 94–455, title XIX, § 1904(b)(8)(G)","children":[],"tail":", (9)(D), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1816"},"text":"90 Stat. 1816","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4749e8c7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4749e8c8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4749e8c9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1904/b/9/D"},"text":"Pub. L. 94–455, § 1904(b)(9)(D)","children":[],"tail":", redesignated par. (7) as (2). Former par. (2), which related to oleomargarine or filled cheese adjudged to contain deleterious ingredients, was repealed. See 1958 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1904/b/9/D"},"text":"Pub. L. 94–455, § 1904(b)(9)(D)","children":[],"tail":", redesignated par. (8) as (3). Former par. (3), relating to offenses by manufacturers or importers of or wholesale dealers in oleomargarine or adulterated butter, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1904/b/9/D"},"text":"Pub. L. 94–455, § 1904(b)(9)(D)","children":[],"tail":", struck out par. (4) which related to the purchase or receipt of adulterated butter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1904/b/9/D"},"text":"Pub. L. 94–455, § 1904(b)(9)(D)","children":[],"tail":", struck out par. (5) which related to packages of oleomargarine found without required stamps or marks."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1904/b/8/G"},"text":"Pub. L. 94–455, § 1904(b)(8)(G)","children":[],"tail":", struck out par. (6) which related to white phosphorus matches."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1904/b/9/D"},"text":"Pub. L. 94–455, § 1904(b)(9)(D)","children":[],"tail":", redesignated pars. (7) and (8) as (2) and (3), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/490"},"text":"Pub. L. 93–490","children":[],"tail":" substituted provisions relating to purchase or receipt of adulterated butter and payment of tax under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4821"},"text":"section 4821 of this title","children":[],"tail":" for provisions relating to purchase or receipt of filled cheese or adulterated butter and payment of tax under section 4821 or 4841 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/490"},"text":"Pub. L. 93–490","children":[],"tail":" substituted provisions relating to packages of oleomargarine subject to tax under subchapter F of chapter 38 of this title for provisions relating to oleomargarine or filled cheese subject to tax under subchapter F of chapter 38 or part II of subchapter C of chapter 39 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/881"},"text":"Pub. L. 85–881","children":[],"tail":" repealed par. (2) which related to oleomargarine or filled cheese adjudged to contain deleterious ingredients."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4749e8ca-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4749e8cb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"