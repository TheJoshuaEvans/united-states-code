,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45c06289-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4162/a/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" landing nets,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45c0628a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4162/a/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gaff hooks,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45c0628b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4162/a/6/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fishing hook disgorgers, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45c0628c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4162/a/6/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dressing for fishing lines and artificial flies,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45c0628d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4162/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fishing tip-ups and tilts,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45c0628e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4162/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fishing rod belts, fishing rodholders, fishing harnesses, fish fighting chairs, fishing outriggers, and fishing downriggers, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45c0628f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4162/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electric outboard boat motors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45c06290-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4162/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain resales","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45c06291-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4162/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45c06292-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4162/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manufacturer, producer, or importer sells any article taxable under section 4161(a) to any person,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45c06293-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4162/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the constructive sale price rules of section 4216(b) do not apply to such sale, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45c06294-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4162/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person (or any other person) sells such article to a related person with respect to the manufacturer, producer, or importer,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then such related person shall be liable for tax under section 4161 in the same manner as if such related person were the manufacturer of the article.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45c06295-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4162/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit for tax previously paid","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45c06296-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4162/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tax is imposed on the sale of any article by reason of paragraph (1), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45c06297-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4162/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the related person establishes the amount of the tax which was paid on the sale described in paragraph (1)(A),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the amount of the tax so paid shall be allowed as a credit against the tax imposed by reason of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45c06298-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4162/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “related person” has the meaning given such term by section 465(b)(3)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45c06299-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4162/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except to the extent provided in regulations, rules similar to the rules of this subsection shall also apply in cases (not described in paragraph (1)) in which intermediaries or other devices are used for purposes of reducing the amount of the tax imposed by section 4161(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45c0629a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1015/b"},"text":"Pub. L. 98–369, div. A, title X, § 1015(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1017"},"text":"98 Stat. 1017","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tII/s201/d/7/C"},"text":"Pub. L. 99–514, title II, § 201(d)(7)(C)","children":[],"tail":", (12), title XVIII, § 1878(b), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2141"},"text":"100 Stat. 2141","children":[],"tail":", 2142, 2903; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIII/s334/a"},"text":"Pub. L. 108–357, title III, § 334(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1478"},"text":"118 Stat. 1478","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45c0629b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45c0629c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45c0629d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(8) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s334/a"},"text":"Pub. L. 108–357, § 334(a)","children":[],"tail":", inserted “and” at end of par. (8), substituted a period for “, and” at end of par. (9), and struck out par. (10) which read as follows: “sonar devices suitable for finding fish.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s334/b"},"text":"Pub. L. 108–357, § 334(b)","children":[],"tail":", redesignated subsec. (c) as (b) and struck out heading and text of former subsec. (b). Text read as follows: “For purposes of this part, the term ‘sonar device suitable for finding fish’ shall not include any sonar device which is—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) a graph recorder,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) a digital type,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) a meter readout, or","children":[],"ta