{"tag":"section","attrib":{"id":"id42d3a252-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s385"},"text":null,"children":[{"tag":"num","attrib":{"value":"385"},"text":"§ 385.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain interests in corporations as stock or indebtedness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42d3a253-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s385/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to prescribe regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to prescribe such regulations as may be necessary or appropriate to determine whether an interest in a corporation is to be treated for purposes of this title as stock or indebtedness (or as in part stock and in part indebtedness).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42d3a254-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s385/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations prescribed under this section shall set forth factors which are to be taken into account in determining with respect to a particular factual situation whether a debtor-creditor relationship exists or a corporation-shareholder relationship exists. The factors so set forth in the regulations may include among other factors:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42d3a255-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s385/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there is a written unconditional promise to pay on demand or on a specified date a sum certain in money in return for an adequate consideration in money or money’s worth, and to pay a fixed rate of interest,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42d3a256-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s385/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there is subordination to or preference over any indebtedness of the corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42d3a257-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s385/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ratio of debt to equity of the corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42d3a258-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s385/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there is convertibility into the stock of the corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42d3a259-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s385/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relationship between holdings of stock in the corporation and holdings of the interest in question.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42d3a25a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s385/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of classification by issuer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42d3a25b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s385/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The characterization (as of the time of issuance) by the issuer as to whether an interest in a corporation is stock or indebtedness shall be binding on such issuer and on all holders of such interest (but shall not be binding on the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42d3a25c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s385/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of inconsistent treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in regulations, paragraph (1) shall not apply to any holder of an interest if such holder on his return discloses that he is treating such interest in a manner inconsistent with the characterization referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42d6135d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s385/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to require such information as the Secretary determines to be necessary to carry out the provisions of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id42d6135e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIV/s415/a"},"text":"Pub. L. 91–172, title IV, § 415(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/613"},"text":"83 Stat. 613","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7208/a/1"},"text":"Pub. L. 101–239, title VII, § 7208(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2337"},"text":"103 Stat. 2337","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s1936/a"},"text":"Pub. L. 102–486, title XIX, § 1936(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3032"},"text":"106 Stat. 3032","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id42d6135f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id42d61360-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id42d61361-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" inserted “(or as in part stock and in part indebtedness)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id42d61362-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42d61363-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s1936/b"},"text":"Pub. L. 102–486, title XIX, § 1936(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3032"},"text":"106 Stat. 3032","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/486/tXIX/s1936/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to instruments issued after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id42d61364-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations Not To Be Applied Retroactively","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7208/a/2"},"text":"Pub. L. 101–239, title VII, § 7208(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2337"},"text":"103 Stat. 2337","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tVII/s7208/a/2"},"text":"“Any regulations issued pursuant to the authority granted by the amendment made by paragraph (1) [amending this section] shall only apply with respect to instruments issued after the date on which the Secretary of the Treasury or his delegate provides public guidance as to the characterization of such instruments whether by regulation, ruling, or otherwise.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
