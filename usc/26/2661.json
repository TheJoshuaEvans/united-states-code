{"tag":"section","attrib":{"id":"id454ba7eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2661"},"text":null,"children":[{"tag":"num","attrib":{"value":"2661"},"text":"§ 2661.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Insofar as applicable and not inconsistent with the provisions of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454ba7ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2661/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in paragraph (2), all provisions of subtitle F (including penalties) applicable to the gift tax, to chapter 12, or to section 2501, are hereby made applicable in respect of the generation-skipping transfer tax, this chapter, or section 2601, as the case may be, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba7ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2661/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a generation-skipping transfer occurring at the same time as and as a result of the death of an individual, all provisions of subtitle F (including penalties) applicable to the estate tax, to chapter 11, or to section 2001 are hereby made applicable in respect of the generation-skipping transfer tax, this chapter, or section 2601 (as the case may be).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id454ba7ee-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIV/s1431/a"},"text":"Pub. L. 99–514, title XIV, § 1431(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2728"},"text":"100 Stat. 2728","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id454ba7ef-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id454ba7f0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id454ba7f1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to generation-skipping transfers (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s2611"},"text":"section 2611 of this title","children":[],"tail":") made after "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1433"},"text":"section 1433 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2601"},"text":"section 2601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
