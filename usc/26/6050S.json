{"tag":"section","attrib":{"id":"id467f453a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S"},"text":null,"children":[{"tag":"num","attrib":{"value":"6050S"},"text":"§ 6050S.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns relating to higher education tuition and related expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id467f453b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467f453c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is an eligible educational institution which enrolls any individual for any academic period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f453d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is engaged in a trade or business of making payments to any individual under an insurance arrangement as reimbursements or refunds (or similar amounts) of qualified tuition and related expenses; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f453e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in regulations, which is engaged in a trade or business and, in the course of which, receives from any individual interest aggregating $600 or more for any calendar year on one or more qualified education loans,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall make the return described in subsection (b) with respect to the individual at such time as the Secretary may by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467f453f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and manner of returns","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A return is described in this subsection if such return—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467f4540-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in such form as the Secretary may prescribe, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f4541-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contains—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467f4542-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the name, address, and TIN of any individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id467f4543-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is or has been enrolled at the institution and with respect to whom transactions described in subparagraph (B) are made during the calendar year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id467f4544-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to whom payments described in subsection (a)(2) or (a)(3) were made or received,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467f4545-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id467f4546-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aggregate amount of payments received for qualified tuition and related expenses with respect to the individual described in subparagraph (A) during the calendar year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id467f4547-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aggregate amount of grants received by such individual for payment of costs of attendance that are administered and processed by the institution during such calendar year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id467f4548-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amount of any adjustments to the aggregate amounts reported by the institution pursuant to clause (i) or (ii) with respect to such individual for a prior calendar year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id467f4549-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aggregate amount of reimbursements or refunds (or similar amounts) paid to such individual during the calendar year by a person engaged in a trade or business described in subsection (a)(2), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id467f454a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aggregate amount of interest received for the calendar year from such individual,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467f454b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer identification number of the institution, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467f454c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467f454d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to governmental units","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467f454e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a governmental unit or any agency or instrumentality thereof shall be treated as a person, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f454f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any return required under subsection (a) by such governmental entity shall be made by the officer or employee appropriately designated for the purpose of making such return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467f4550-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements to be furnished to individuals with respect to whom information is required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every person required to make a return under subsection (a) shall furnish to each individual whose name is required to be set forth in such return under subparagraph (A) of subsection (b)(2) a written statement showing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467f4551-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and phone number of the information contact of the person required to make such return, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f4552-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information required by subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The written statement required under the preceding sentence shall be furnished on or before January 31 of the year following the calendar year for which the return under subsection (a) was required to be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467f4553-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the terms “eligible educational institution” and “qualified tuition and related expenses” have the meanings given such terms by section 25A (without regard to subsection (g)(2) thereof), and except as provided in regulations, the term “qualified education loan” has the meaning given such term by section 221(d)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467f4554-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns which would be required to be made by 2 or more persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except to the extent provided in regulations prescribed by the Secretary, in the case of any amount received by any person on behalf of another person, only the person first receiving such amount shall be required to make the return under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467f4555-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050S/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to carry out the provisions of this section. No penalties shall be imposed under part II of subchapter B of chapter 68 with respect to any return or statement required under this section until such time as such regulations are issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id467f4556-3a70-11f1-a967-d35dac11796a"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tII"},"text":"Pub. L. 105–34, title II","children":[],"tail":", §§ 201(c)(1), 202(c), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/804"},"text":"111 Stat. 804","children":[],"tail":", 808; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3712/a"},"text":"Pub. L. 105–206, title III, § 3712(a)","children":[],"tail":", (b), title VI, § 6004(a)(2), "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/781"},"text":"112 Stat. 781","children":[],"tail":", 792; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tIV/s412/a/2"},"text":"Pub. L. 107–16, title IV, § 412(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/63"},"text":"115 Stat. 63","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/131/s1"},"text":"Pub. L. 107–131, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-16"},"text":"Jan. 16, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2410"},"text":"115 Stat. 2410","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/27/tVIII/s804/c"},"text":"Pub. L. 114–27, title VIII, § 804(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-29"},"text":"June 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/416"},"text":"129 Stat. 416","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tII"},"text":"Pub. L. 114–113, div. Q, title II","children":[],"tail":", §§ 211(b), 212(a), "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3085"},"text":"129 Stat. 3085","children":[],"tail":", 3086.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id467f4557-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id467f4558-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id467f4559-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s212/a"},"text":"Pub. L. 114–113, § 212(a)","children":[],"tail":", struck out “or the aggregate amount billed” after “received”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s211/b"},"text":"Pub. L. 114–113, § 211(b)","children":[],"tail":", added subpar. (C) and redesignated former subpar. (C) as (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/27"},"text":"Pub. L. 114–27","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “the amounts described in subparagraph (B) of subsection (b)(2).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/131/s1/a"},"text":"Pub. L. 107–131, § 1(a)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “which is an eligible educational institution—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) which receives payments for qualified tuition and related expenses with respect to any individual for any calendar year; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) which makes reimbursements or refunds (or similar amounts) to any individual of qualified tuition and related expenses;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/131/s1/b/1"},"text":"Pub. L. 107–131, § 1(b)(1)","children":[],"tail":", inserted “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/131/s1/b/2"},"text":"Pub. L. 107–131, § 1(b)(2)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “the name, address, and TIN of the individual with respect to whom payments or interest described in subsection (a) were received from (or were paid to),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/131/s1/b/4"},"text":"Pub. L. 107–131, § 1(b)(4)","children":[],"tail":", amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “the—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) aggregate amount of payments for qualified tuition and related expenses received with respect to the individual described in subparagraph (A) during the calendar year,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the amount of any grant received by such individual for payment of costs of attendance and processed by the person making such return during such calendar year,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) aggregate amount of reimbursements or refunds (or similar amounts) paid to such individual during the calendar year by the person making such return, and and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iv) aggregate amount of interest received for the calendar year from such individual, and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/131/s1/b/3"},"text":"Pub. L. 107–131, § 1(b)(3)","children":[],"tail":", redesignated subpar. (C) as (B) and struck out former subpar. (B) which read as follows: “the name, address, and TIN of any individual certified by the individual described in subparagraph (A) as the taxpayer who will claim the individual as a dependent for purposes of the deduction allowable under section 151 for any taxable year ending with or within the calendar year, and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/131/s1/b/3"},"text":"Pub. L. 107–131, § 1(b)(3)","children":[],"tail":", redesignated subpars. (C) and (D) as (B) and (C), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/131/s1/c/1"},"text":"Pub. L. 107–131, § 1(c)(1)","children":[],"tail":", struck out “or (B)” after “subparagraph (A)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/131/s1/c/2"},"text":"Pub. L. 107–131, § 1(c)(2)","children":[],"tail":", substituted “subparagraph (B)” for “subparagraph (C)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16"},"text":"Pub. L. 107–16","children":[],"tail":" substituted “section 221(d)(1)” for “section 221(e)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6004/a/2"},"text":"Pub. L. 105–206, § 6004(a)(2)","children":[],"tail":", amended heading and text of subsec. (a) generally. Prior to amendment, text read as follows: “Any person—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) which is an eligible educational institution which receives payments for qualified tuition and related expenses with respect to any individual for any calendar year, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) which is engaged in a trade or business and which, in the course of such trade or business—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) makes payments during any calendar year to any individual which constitutes reimbursements or refunds (or similar amounts) of qualified tuition and related expenses of such individual, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) except as provided in regulations, receives from any individual interest aggregating $600 or more for any calendar year on 1 or more qualified education loans,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"shall make the return described in subsection (b) with respect to the individual at such time as the Secretary may by regulations prescribe.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3712/a/1"},"text":"Pub. L. 105–206, § 3712(a)(1)","children":[],"tail":", added cl. (ii). Former cl. (ii) redesignated (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3712/a/1"},"text":"Pub. L. 105–206, § 3712(a)(1)","children":[],"tail":", (2), redesignated cl. (ii) as (iii) and inserted “by the person making such return” after “year”. Former cl. (iii) redesignated (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3712/a/1"},"text":"Pub. L. 105–206, § 3712(a)(1)","children":[],"tail":", (3), redesignated cl. (iii) as (iv) and inserted “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3712/b/1"},"text":"Pub. L. 105–206, § 3712(b)(1)","children":[],"tail":", struck out “aggregate” before “amounts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3712/b/2"},"text":"Pub. L. 105–206, § 3712(b)(2)","children":[],"tail":", inserted “(without regard to subsection (g)(2) thereof)” after “section 25A”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s202/c/1"},"text":"Pub. L. 105–34, § 202(c)(1)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “which is engaged in a trade or business and which, in the course of such trade or business, makes payments during any calendar year to any individual which constitute reimbursements or refunds (or similar amounts) of qualified tuition and related expenses of such individual,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s202/c/2/A"},"text":"Pub. L. 105–34, § 202(c)(2)(A)","children":[],"tail":", inserted “or interest” after “payments”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s202/c/2/B"},"text":"Pub. L. 105–34, § 202(c)(2)(B)","children":[],"tail":", added cl. (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s202/c/3"},"text":"Pub. L. 105–34, § 202(c)(3)","children":[],"tail":", inserted at end “, and except as provided in regulations, the term ‘qualified education loan’ has the meaning given such term by section 221(e)(1)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id467f455a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id467f455b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tII/s211/c/2"},"text":"Pub. L. 114–113, div. Q, title II, § 211(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3085"},"text":"129 Stat. 3085","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/113/dQ/tII/s211/c/2"},"text":"“The amendments made by subsection (b) [amending this section] shall apply to expenses paid after ","child