{"tag":"section","attrib":{"id":"id47642703-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481"},"text":null,"children":[{"tag":"num","attrib":{"value":"7481"},"text":"§ 7481.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date when Tax Court decision becomes final","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47642704-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviewable decisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsections (b), (c), and (d), the decision of the Tax Court shall become final—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47642705-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timely notice of appeal not filed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the expiration of the time allowed for filing a notice of appeal, if no such notice has been duly filed within such time; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47642706-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decision affirmed or appeal dismissed","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47642707-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition for certiorari not filed on time","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the expiration of the time allowed for filing a petition for certiorari, if the decision of the Tax Court has been affirmed or the appeal dismissed by the United States Court of Appeals and no petition for certiorari has been duly filed; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47642708-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition for certiorari denied","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the denial of a petition for certiorari, if the decision of the Tax Court has been affirmed or the appeal dismissed by the United States Court of Appeals; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47642709-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" After mandate of Supreme Court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the expiration of 30 days from the date of issuance of the mandate of the Supreme Court, if such Court directs that the decision of the Tax Court be affirmed or the appeal dismissed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4764270a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decision modified or reversed","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4764270b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Upon mandate of Supreme Court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Supreme Court directs that the decision of the Tax Court be modified or reversed, the decision of the Tax Court rendered in accordance with the mandate of the Supreme Court shall become final upon the expiration of 30 days from the time it was rendered, unless within such 30 days either the Secretary or the taxpayer has instituted proceedings to have such decision corrected to accord with the mandate, in which event the decision of the Tax Court shall become final when so corrected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4764270c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Upon mandate of the Court of Appeals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the decision of the Tax Court is modified or reversed by the United States Court of Appeals, and if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4764270d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time allowed for filing a petition for certiorari has expired and no such petition has been duly filed, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4764270e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the petition for certiorari has been denied, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4764270f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the decision of the United States Court of Appeals has been affirmed by the Supreme Court, then the decision of the Tax Court rendered in accordance with the mandate of the United States Court of Appeals shall become final on the expiration of 30 days from the time such decision of the Tax Court was rendered, unless within such 30 days either the Secretary or the taxpayer has instituted proceedings to have such decision corrected so that it will accord with the mandate, in which event the decision of the Tax Court shall become final when so corrected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47642710-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rehearing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Supreme Court orders a rehearing; or if the case is remanded by the United States Court of Appeals to the Tax Court for a rehearing, and if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47642711-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time allowed for filing a petition for certiorari has expired and no such petition has been duly filed, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47642712-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the petition for certiorari has been denied, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47642713-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the decision of the United States Court of Appeals has been affirmed by the Supreme Court,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then the decision of the Tax Court rendered upon such rehearing shall become final in the same manner as though no prior decision of the Tax Court has been rendered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47642714-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of “mandate”","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “mandate”, in case a mandate has been recalled prior to the expiration of 30 days from the date of issuance thereof, means the final mandate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47642715-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonreviewable decisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The decision of the Tax Court in a proceeding conducted under section 7436(c) or 7463 shall become final upon the expiration of 90 days after the decision is entered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47642716-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction over interest determinations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47642717-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a), if, within 1 year after the date the decision of the Tax Court becomes final under subsection (a) in a case to which this subsection applies, the taxpayer files a motion in the Tax Court for a redetermination of the amount of interest involved, then the Tax Court may reopen the case solely to determine whether the taxpayer has made an overpayment of such interest or the Secretary has made an underpayment of such interest and the amount thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47642718-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cases to which this subsection applies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection shall apply where—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47642719-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4764271a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment has been made by the Secretary under section 6215 which includes interest as imposed by this title, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4764271b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer has paid the entire amount of the deficiency plus interest claimed by the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4764271c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Tax Court finds under section 6512(b) that the taxpayer has made an overpayment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4764271d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Tax Court determines under this subsection that the taxpayer has made an overpayment of interest or that the Secretary has made an underpayment of interest, then that determination shall be treated under section 6512(b)(1) as a determination of an overpayment of tax. An order of the Tax Court redetermining interest, when entered upon the records of the court, shall be reviewable in the same manner as a decision of the Tax Court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4764271e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decisions relating to estate tax extended under section 6166","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If with respect to a decedent’s estate subject to a decision of the Tax Court—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4764271f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time for payment of an amount of tax imposed by chapter 11 is extended under section 6166, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47642720-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" there is treated as an administrative expense under section 2053 either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47642721-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount of interest which a decedent’s estate pays on any portion of the tax imposed by section 2001 on such estate for which the time of payment is extended under section 6166, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47642722-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7481/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest on any estate, succession, legacy, or inheritance tax imposed by a State on such estate during the period of the extension of time for payment under section 6166,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then, upon a motion by the petitioner in such case in which such time for payment of tax has been extended under section 6166, the Tax Court may reopen the case solely to modify the Court’s decision to reflect such estate’s entitlement to a deduction for such administration expenses under section 2053 and may hold further trial solely with respect to the claim for such deduction if, within the discretion of the Tax Court, such a hearing is deemed necessary. An order of the Tax Court disposing of a motion under this subsection shall be reviewable in the same manner as a decision of the Tax Court, but only with respect to the matters determined in such order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47642723-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/889"},"text":"68A Stat. 889","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIX/s960/h/1"},"text":"Pub. L. 91–172, title IX, § 960(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/734"},"text":"83 Stat. 734","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI"},"text":"Pub. L. 100–647, title VI","children":[],"tail":", §§ 6246(a), (b)(2), 6247(a), (b)(2), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3751"},"text":"102 Stat. 3751","children":[],"tail":", 3752; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIV"},"text":"Pub. L. 105–34, title XIV","children":[],"tail":", §§ 1452(a), 1454(b)(3), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1054"},"text":"111 Stat. 1054","children":[],"tail":", 1057.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47642724-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47642725-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47642726-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1454/b/3"},"text":"Pub. L. 105–34, § 1454(b)(3)","children":[],"tail":", substituted “section 7436(c) or 7463” for “section 7463”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1452/a"},"text":"Pub. L. 105–34, § 1452(a)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “Notwithstanding subsection (a), if—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) an assessment has been made by the Secretary under section 6215 which includes interest as imposed by this title,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the taxpayer has paid the entire amount of the deficiency plus interest claimed by the Secretary, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) within 1 year after the date the decision of the Tax Court becomes final under subsection (a), the taxpayer files a petition in the Tax Court for a determination that the amount of interest claimed by the Secretary exceeds the amount of interest imposed by this title,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"then the Tax Court may reopen the case solely to determine whether the taxpayer has made an overpayment of such interest and the amount of any such overpayment. If the Tax Court determines under this subsection that the taxpayer has made an overpayment of interest, then that determination shall be treated under section 6512(b)(1) as a determination of an overpayment of tax. An order of the Tax Court redetermining the interest due, when entered upon the records of the court, shall be reviewable in the same manner as a decision of the Tax Court.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s6247/b/2"},"text":"Pub. L. 100–647, § 6247(b)(2)","children":[],"tail":", substituted “subsections (b), (c), and (d)” for “subsections (b) and (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s6246/b/2"},"text":"Pub. L. 100–647, § 6246(b)(2)","children":[],"tail":", substituted “subsections (b) and (c)” for “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s6246/a"},"text":"Pub. L. 100–647, § 6246(a)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s6247/a"},"text":"Pub. L. 100–647, § 6247(a)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(3)(A), (B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" designated existing provisions as subsec. (a), inserted reference to the exception provided for in subsec. (b), substituted “notice of appeal” for “petition for review” in par. (1), and substituted references to dismissal of appeal for references to dismissal of petition for review in par. (2), and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47642727-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47642728-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIV/s1452/b"},"text":"Pub. L. 105–34, title XIV, § 1452(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1055"},"text":"111 Stat. 1055","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tXIV/s1452/b"},"text":"“The amendment made by