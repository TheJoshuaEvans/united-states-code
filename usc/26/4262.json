{"tag":"section","attrib":{"id":"id45ceb9a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262"},"text":null,"children":[{"tag":"num","attrib":{"value":"4262"},"text":"§ 4262.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of taxable transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45ceb9a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable transportation; in general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, except as provided in subsection (b), the term “taxable transportation” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45ceb9a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation by air which begins in the United States or in the 225–mile zone and ends in the United States or in the 225–mile zone; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ceb9a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of transportation by air other than transportation described in paragraph (1), that portion of such transportation which is directly or indirectly from one port or station in the United States to another port or station in the United States, but only if such portion is not a part of uninterrupted international air transportation (within the meaning of subsection (c)(3)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45ceb9a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of certain travel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, the term “taxable transportation” does not include that portion of any transportation by air which meets all 4 of the following requirements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45ceb9a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such portion is outside the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ceb9aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" neither such portion nor any segment thereof is directly or indirectly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45ceb9ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between (i) a point where the route of the transportation leaves or enters the continental United States, or (ii) a port or station in the 225-mile zone, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45ceb9ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a port or station in the 225-mile zone;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ceb9ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such portion—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45ceb9ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begins at either (i) the point where the route of the transportation leaves the United States, or (ii) a port or station in the 225-mile zone, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45ceb9af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ends at either (i) the point where the route of the transportation enters the United States, or (ii) a port or station in the 225-mile zone; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ceb9b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a direct line from the point (or the port or station) specified in paragraph (3)(A), to the point (or the port or station) specified in paragraph (3)(B), passes through or over a point which is not within 225 miles of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45ceb9b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45ceb9b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continental United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “continental United States” means the District of Columbia and the States other than Alaska and Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ceb9b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 225-mile zone","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “225-mile zone” means that portion of Canada and Mexico which is not more than 225 miles from the nearest point in the continental United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ceb9b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uninterrupted international air transportation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “uninterrupted international air transportation” means any transportation by air which is not transportation described in subsection (a)(1) and in which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45ceb9b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scheduled interval between (i) the beginning or end of the portion of such transportation which is directly or indirectly from one port or station in the United States to another port or station in the United States and (ii) the end or beginning of the other portion of such transportation is not more than 12 hours, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45ceb9b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scheduled interval between the beginning or end and the end or beginning of any two segments of the portion of such transportation referred to in subparagraph (A)(i) is not more than 12 hours.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of this paragraph, in the case of personnel of the United States Army, Air Force, Navy, Marine Corps, and Coast Guard traveling in uniform at their own expense when on official leave, furlough, or pass, the scheduled interval described in subparagraph (A) shall be deemed to be not more than 12 hours if a ticket for the subsequent portion of such transportation is purchased within 12 hours after the end of the earlier portion of such transportation and the purchaser accepts and utilizes the first accommodations actually available to him for such subsequent portion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45ceb9b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this part, the term “transportation” includes layover or waiting time and movement of the aircraft in deadhead service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45ceb9b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to waive 225-mile zone provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45ceb9b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary of the Treasury determines that Canada or Mexico has entered into a qualified agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45ceb9ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall publish a notice of such determination in the Federal Register, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45ceb9bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective with respect to transportation beginning after the date specified in such notice, to the extent provided in the agreement, the term “225-mile zone” shall not include part or all of the country with respect to which such determination is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ceb9bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a determination was made under paragraph (1) with respect to any country and the Secretary of the Treasury subsequently determines that the agreement is no longer in effect or that the agreement is no longer a qualified agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45ceb9bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall publish a notice of such determination in the Federal Register, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45ceb9be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraph (B) of paragraph (1) shall cease to apply with respect to transportation beginning after the date specified in such notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ceb9bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “qualified agreement” means an agreement between the United States and Canada or Mexico (as the case may be)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45ceb9c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setting forth that portion of such country which is not to be treated as within the 225-mile zone, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45ceb9c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing that the tax imposed by such country on transportation described in subparagraph (A) will be at a level which the Secretary of the Treasury determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d12ac2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4262/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement that agreement be submitted to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No notice may be published under paragraph (1)(A) with respect to any qualified agreement before the date 90 days after the date on which a copy of such agreement was furnished to the Committee on Ways and Means of the House of Representatives and the Committee on Finance of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d12ac3-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-07-25/ch725/s3"},"text":"July 25, 1956, ch. 725, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/644"},"text":"70 Stat. 644","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/70/s22/b"},"text":"Pub. L. 86–70, § 22(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-06-25"},"text":"June 25, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/146"},"text":"73 Stat. 146","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/624/s18/a"},"text":"Pub. L. 86–624, § 18(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/416"},"text":"74 Stat. 416","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/508/s5/b"},"text":"Pub. L. 87–508, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-06-28"},"text":"June 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/116"},"text":"76 Stat. 116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tVIII/s803/a"},"text":"Pub. L. 89–44, title VIII, § 803(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/160"},"text":"79 Stat. 160","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/258/tII/s203/b"},"text":"Pub. L. 91–258, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-05-21"},"text":"May 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/238"},"text":"84 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tII/s281A/a/1"},"text":"Pub. L. 97–248, title II, § 281A(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/566"},"text":"96 Stat. 566","children":[],"tail":", 567.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45d12ac4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45d12ac5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id45d12ac6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4262 was renumbered 4263 of this title and later repealed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45d12ac7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s281A/a/1"},"text":"Pub. L. 97–248, § 281A(a)(1)","children":[],"tail":", substituted “12 hours” for “6 hours” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s281A/a/2"},"text":"Pub. L. 97–248, § 281A(a)(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/258/s203/b/1"},"text":"Pub. L. 91–258, § 203(b)(1)","children":[],"tail":"–(3), substituted “part” for “subchapter” in introductory text, “transportation by air” for “transportation” in par. (1), and “in the case of transportation by air” for “in the case of transportation” in par. (2), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/258/s203/b/1"},"text":"Pub. L. 91–258, § 203(b)(1)","children":[],"tail":", (4), substituted “part” for “subchapter” and “transportation by air which” for “transportation which”, in introductory text, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/258/s203/b/5"},"text":"Pub. L. 91–258, § 203(b)(5)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" inserted sentence relating to personnel of the Armed Forces traveling in uniform at their own expense following subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/508"},"text":"Pub. L. 87–508","children":[],"tail":" substituted in introductory phrase “subchapter” for “part” and inserted in par. (2) “, but only if such portion is not a part of uninterrupted international air transportation (within the meaning of subsection (c)(3))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/508"},"text":"Pub. L. 87–508","children":[],"tail":" substituted in introductory phrase “subchapter” for “part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/508"},"text":"Pub. L. 87–508","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/624"},"text":"Pub. L. 86–624","children":[],"tail":" inserted “and Hawaii” after “Alaska”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/70"},"text":"Pub. L. 86–70","children":[],"tail":" substituted “the District of Columbia and the States other than Alaska” for “the existing 48 States and the District of Columbia”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45d12ac8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{