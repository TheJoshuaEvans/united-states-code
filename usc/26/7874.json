{"tag":"section","attrib":{"id":"id47a48b59-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874"},"text":null,"children":[{"tag":"num","attrib":{"value":"7874"},"text":"§ 7874.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules relating to expatriated entities and their foreign parents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47a48b5a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on inversion gain of expatriated entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47a48b5b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The taxable income of an expatriated entity for any taxable year which includes any portion of the applicable period shall in no event be less than the inversion gain of the entity for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48b5c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expatriated entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47a48b5d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “expatriated entity” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47a48b5e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the domestic corporation or partnership referred to in subparagraph (B)(i) with respect to which a foreign corporation is a surrogate foreign corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47a48b5f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any United States person who is related (within the meaning of section 267(b) or 707(b)(1)) to a domestic corporation or partnership described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47a48b60-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surrogate foreign corporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A foreign corporation shall be treated as a surrogate foreign corporation if, pursuant to a plan (or a series of related transactions)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47a48b61-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity completes after ","children":[{"tag":"date","attrib":{"date":"2003-03-04"},"text":"March 4, 2003","children":[],"tail":", the direct or indirect acquisition of substantially all of the properties held directly or indirectly by a domestic corporation or substantially all of the properties constituting a trade or business of a domestic partnership,"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47a48b62-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after the acquisition at least 60 percent of the stock (by vote or value) of the entity is held—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id47a48b63-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/a/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an acquisition with respect to a domestic corporation, by former shareholders of the domestic corporation by reason of holding stock in the domestic corporation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id47a48b64-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/a/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an acquisition with respect to a domestic partnership, by former partners of the domestic partnership by reason of holding a capital or profits interest in the domestic partnership, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47a48b65-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the acquisition the expanded affiliated group which includes the entity does not have substantial business activities in the foreign country in which, or under the law of which, the entity is created or organized, when compared to the total business activities of such expanded affiliated group.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"An entity otherwise described in clause (i) with respect to any domestic corporation or partnership trade or business shall be treated as not so described if, on or before ","children":[{"tag":"date","attrib":{"date":"2003-03-04"},"text":"March 4, 2003","children":[],"tail":", such entity acquired directly or indirectly more than half of the properties held directly or indirectly by such corporation or more than half of the properties constituting such partnership trade or business, as the case may be."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48b66-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with subsection (b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A corporation which is treated as a domestic corporation under subsection (b) shall not be treated as a surrogate foreign corporation for purposes of paragraph (2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a48b67-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inverted corporations treated as domestic corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 7701(a)(4), a foreign corporation shall be treated for purposes of this title as a domestic corporation if such corporation would be a surrogate foreign corporation if subsection (a)(2) were applied by substituting “80 percent” for “60 percent”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a48b68-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47a48b69-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanded affiliated group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “expanded affiliated group” means an affiliated group as defined in section 1504(a) but without regard to section 1504(b)(3), except that section 1504(a) shall be applied by substituting “more than 50 percent” for “at least 80 percent” each place it appears.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48b6a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain stock disregarded","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall not be taken into account in determining ownership under subsection (a)(2)(B)(ii)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47a48b6b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stock held by members of the expanded affiliated group which includes the foreign corporation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47a48b6c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stock of such foreign corporation which is sold in a public offering related to the acquisition described in subsection (a)(2)(B)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48b6d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan deemed in certain cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a foreign corporation acquires directly or indirectly substantially all of the properties of a domestic corporation or partnership during the 4-year period beginning on the date which is 2 years before the ownership requirements of subsection (a)(2)(B)(ii) are met, such actions shall be treated as pursuant to a plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48b6e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain transfers disregarded","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The transfer of properties or liabilities (including by contribution or distribution) shall be disregarded if such transfers are part of a plan a principal purpose of which is to avoid the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48b6f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for related partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of applying subsection (a)(2)(B)(ii) to the acquisition of a trade or business of a domestic partnership, except as provided in regulations, all partnerships which are under common control (within the meaning of section 482) shall be treated as 1 partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48b70-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe such regulations as may be appropriate to determine whether a corporation is a surrogate foreign corporation, including regulations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47a48b71-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to treat warrants, options, contracts to acquire stock, convertible debt interests, and other similar interests as stock, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47a48b72-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to treat stock as not stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a48b73-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47a48b74-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable period” means the period—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47a48b75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning on the first date properties are acquired as part of the acquisition described in subsection (a)(2)(B)(i), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47a48b76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ending on the date which is 10 years after the last date properties are acquired as part of such acquisition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48b77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inversion gain","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “inversion gain” means the income or gain recognized by reason of the transfer during the applicable period of stock or other properties by an expatriated entity, and any income received or accrued during the applicable period by reason of a license of any property by an expatriated entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47a48b78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as part of the acquisition described in subsection (a)(2)(B)(i), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47a48b79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after such acquisition if the transfer or license is to a foreign related person.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Subparagraph (B) shall not apply to property described in section 1221(a)(1) in the hands of the expatriated entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48b7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign related person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “foreign related person” means, with respect to any expatriated entity, a foreign person which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47a48b7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is related (within the meaning of section 267(b) or 707(b)(1)) to such entity, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47a48b7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is under the same common control (within the meaning of section 482) as such entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a48b7d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47a48b7e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits not allowed against tax on inversion gain","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Credits (other than the credit allowed by section 901) shall be allowed against the tax imposed by this chapter on an expatriated entity for any taxable year described in subsection (a) only to the extent such tax exceeds the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47a48b7f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the inversion gain for the taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47a48b80-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the highest rate of tax specified in section 11(b).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of determining the credit allowed by section 901, inversion gain shall be treated as from sources within the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48b81-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an expatriated entity which is a partnership—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47a48b82-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a)(1) shall apply at the partner rather than the partnership level,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47a48b83-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the inversion gain of any partner for any taxable year shall be equal to the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47a48b84-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the partner’s distributive share of inversion gain of the partnership for such taxable year, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47a48b85-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gain recognized for the taxable year by the partner by reason of the transfer during the applicable period of any partnership interest of the partner in such partnership to the surrogate foreign corporation, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47a48b86-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the highest rate of tax specified in the rate schedule applicable to the partner under this chapter shall be substituted for the rate of tax referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48b87-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with section 172 and minimum tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of paragraphs (3) and (4) of section 860E(a) shall apply for purposes of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48b88-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47a48b89-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The statutory period for the assessment of any deficiency attributable to the inversion gain of any taxpayer for any pre-inversion year shall not expire before the expiration of 3 years from the date the Secretary is notified by the taxpayer (in such manner as the Secretary may prescribe) of the acquisition described in subsection (a)(2)(B)(i) to which such gain relates and such deficiency may be assessed before the expiration of such 3-year period notwithstanding the provisions of any other law or rule of law which would otherwise prevent such assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47a48b8a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pre-inversion year","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the term “pre-inversion year” means any taxable year if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47a48b8b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/e/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any portion of the applicable period is included in such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47a48b8c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/e/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such year ends before the taxable year in which the acquisition described in subsection (a)(2)(B)(i) is completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a48b8d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for treaties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in section 894 or 7852(d) or in any other provision of law shall be construed as permitting an exemption, by reason of any treaty obligation of the United States heretofore or hereafter entered into, from the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a48b8e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide such regulations as are necessary to carry out this section, including regulations providing for such adjustments to the application of this section as are necessary to prevent the avoidance of the purposes of this section, including the avoidance of such purposes through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47a48b8f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of related persons, pass-through or other noncorporate entities, or other intermediaries, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a48b90-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7874/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transactions designed to have persons cease to be (or not become) members of expanded affiliated groups or related persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47a48b91-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s801/a"},"text":"Pub. L. 108–357, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1562"},"text":"118 Stat. 1562","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s403/u"},"text":"Pub. L. 109–135, title IV, § 403(u)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2628"},"text":"119 Stat. 2628","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13001/b/1/C"},"text":"Pub. L. 115–97, title I, § 13001(b)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2096"},"text":"131 Stat. 2096","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47a48b92-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47a48b93-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47a48b94-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (e)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" substituted “section 11(b)” for “section 11(b)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “Paragraph (1) shall not apply to any entity which is treated as a domestic corporation under subsection (b).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47a48b95-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47a48b96-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13001/c/1"},"text":"section 13001(c)(1) of Pub. L. 115–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s11"},"text":"section 11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47a48b97-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" effective as if included in the provision of the American Jobs Creation Act of 2004, "},{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/nn"},"text":"section 403(nn) of Pub. L. 109–135","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s26"},"text":"section 26 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47a48b98-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s801/c"},"text":"Pub. L. 108–357, title VIII, § 801(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1566"},"text":"118 Stat. 1566","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tVIII/s801/c"},"text":"“The amendments made by this section [enacting this section] shall apply to taxable years ending after ","children":[{"tag":"date","attrib":{"date":"2003-03-04"},"text":"March 4, 2003","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
