{"tag":"section","attrib":{"id":"id4742bce7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122"},"text":null,"children":[{"tag":"num","attrib":{"value":"7122"},"text":"§ 7122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compromises","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4742bce8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may compromise any civil or criminal case arising under the internal revenue laws prior to reference to the Department of Justice for prosecution or defense; and the Attorney General or his delegate may compromise any such case after reference to the Department of Justice for prosecution or defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4742bce9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever a compromise is made by the Secretary in any case, there shall be placed on file in the office of the Secretary the opinion of the General Counsel for the Department of the Treasury or his delegate, with his reasons therefor, with a statement of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4742bcea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of tax assessed,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4742bceb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of interest, additional amount, addition to the tax, or assessable penalty, imposed by law on the person against whom the tax is assessed, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4742bcec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount actually paid in accordance with the terms of the compromise.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Notwithstanding the foregoing provisions of this subsection, no such opinion shall be required with respect to the compromise of any civil case in which the unpaid amount of tax assessed (including any interest, additional amount, addition to the tax, or assessable penalty) is less than $50,000. However, such compromise shall be subject to continuing quality review by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4742bced-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules for submission of offers-in-compromise","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4742bcee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partial payment required with submission","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4742bcef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump-sum offers","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4742bcf0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The submission of any lump-sum offer-in-compromise shall be accompanied by the payment of 20 percent of the amount of such offer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4742bcf1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump-sum offer-in-compromise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “lump-sum offer-in-compromise” means any offer of payments made in 5 or fewer installments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4742bcf2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic payment offers","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4742bcf3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The submission of any periodic payment offer-in-compromise shall be accompanied by the payment of the amount of the first proposed installment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4742bcf4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to make installment during pendency of offer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any failure to make an installment (other than the first installment) due under such offer-in-compromise during the period such offer is being evaluated by the Secretary may be treated by the Secretary as a withdrawal of such offer-in-compromise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4742bcf5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of application","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4742bcf6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The application of any payment made under this subsection to the assessed tax or other amounts imposed under this title with respect to such tax may be specified by the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4742bcf7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of user fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any assessed tax or other amounts imposed under this title with respect to such tax which is the subject of an offer-in-compromise to which this subsection applies, such tax or other amounts shall be reduced by any user fee imposed under this title with respect to such offer-in-compromise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4742bcf8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may issue regulations waiving any payment required under paragraph (1) in a manner consistent with the practices established in accordance with the requirements under subsection (d)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4742bcf9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for low-income taxpayers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1), and any user fee otherwise required in connection with the submission of an offer-in-compromise, shall not apply to any offer-in-compromise with respect to a taxpayer who is an individual with adjusted gross income, as determined for the most recent taxable year for which such information is available, which does not exceed 250 percent of the applicable poverty level (as determined by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4742bcfa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for evaluation of offers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4742bcfb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe guidelines for officers and employees of the Internal Revenue Service to determine whether an offer-in-compromise is adequate and should be accepted to resolve a dispute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4742bcfc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowances for basic living expenses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4742bcfd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In prescribing guidelines under paragraph (1), the Secretary shall develop and publish schedules of national and local allowances designed to provide that taxpayers entering into a compromise have an adequate means to provide for basic living expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4742bcfe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of schedules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The guidelines shall provide that officers and employees of the Internal Revenue Service shall determine, on the basis of the facts and circumstances of each taxpayer, whether the use of the schedules published under subparagraph (A) is appropriate and shall not use the schedules to the extent such use would result in the taxpayer not having adequate means to provide for basic living expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4742bcff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules relating to treatment of offers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidelines under paragraph (1) shall provide that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4742bd00-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer or employee of the Internal Revenue Service shall not reject an offer-in-compromise from a low-income taxpayer solely on the basis of the amount of the offer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4742bd01-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an offer-in-compromise which relates only to issues of liability of the taxpayer—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4742bd02-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such offer shall not be rejected solely because the Secretary is unable to locate the taxpayer’s return or return information for verification of such liability; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4742bd03-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer shall not be required to provide a financial statement, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4742bd04-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any offer-in-compromise which does not meet the requirements of subparagraph (A)(i) or (B)(i), as the case may be, of subsection (c)(1) may be returned to the taxpayer as unprocessable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4742bd05-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish procedures—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4742bd06-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an independent administrative review of any rejection of a proposed offer-in-compromise or installment agreement made by a taxpayer under this section or section 6159 before such rejection is communicated to the taxpayer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4742bd07-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which allow a taxpayer to appeal any rejection of such offer or agreement to the Internal Revenue Service Independent Office of Appeals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4742bd08-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deemed acceptance of offer not rejected within certain period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any offer-in-compromise submitted under this section shall be deemed to be accepted by the Secretary if such offer is not rejected by the Secretary before the date which is 24 months after the date of the submission of such offer. For purposes of the preceding sentence, any period during which any tax liability which is the subject of such offer-in-compromise is in dispute in any judicial proceeding shall not be taken into account in determining the expiration of the 24-month period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4742bd09-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7122/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frivolous submissions, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, if the Secretary determines that any portion of an application for an offer-in-compromise or installment agreement submitted under this section or section 6159 meets the requirement of clause (i) or (ii) of section 6702(b)(2)(A), then the Secretary may treat such portion as if it were never submitted and such portion shall not be subject to any further administrative or judicial review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4742bd0a-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/849"},"text":"68A Stat. 849","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/168/tV/s503/a"},"text":"Pub. L. 104–168, title V, § 503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1461"},"text":"110 Stat. 1461","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3462/a"},"text":"Pub. L. 105–206, title III, § 3462(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/764"},"text":"112 Stat. 764","children":[],"tail":", 766; "},{"tag":"ref","attrib":{"href":"/us/pl/109/222/tV/s509/a"},"text":"Pub. L. 109–222, title V, § 509(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2006-05-17"},"text":"May 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/362"},"text":"120 Stat. 362","children":[],"tail":", 363; "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s407/d"},"text":"Pub. L. 109–432, div. A, title IV, § 407(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2962"},"text":"120 Stat. 2962","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s220/y"},"text":"Pub. L. 113–295, div. A, title II, § 220(y)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4036"},"text":"128 Stat. 4036","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/25/tI"},"text":"Pub. L. 116–25, title I","children":[],"tail":", §§ 1001(b)(1)(F), 1102(a), "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/985"},"text":"133 Stat. 985","children":[],"tail":", 986.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4742bd0b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4742bd0c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4742bd0d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/s1102/a"},"text":"Pub. L. 116–25, § 1102(a)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/s1001/b/1/F"},"text":"Pub. L. 116–25, § 1001(b)(1)(F)","children":[],"tail":", substituted “Internal Revenue Service Independent Office of Appeals” for “Internal Revenue Service Office of Appeals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" redesignated subsec. (f) relating to frivolous submissions as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/222/s509/a"},"text":"Pub. L. 109–222, § 509(a)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/222/s509/a"},"text":"Pub. L. 109–222, § 509(a)","children":[],"tail":", redesignated subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/222/s509/b/1"},"text":"Pub. L. 109–222, § 509(b)(1)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/222/s509/a"},"text":"Pub. L. 109–222, § 509(a)","children":[],"tail":", redesignated subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" added subsec. (f) relating to frivolous submissions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/222/s509/b/2"},"text":"Pub. L. 109–222, § 509(b)(2)","children":[],"tail":", added subsec. (f) relating to deemed acceptance of offer not rejected within certain period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3462/a"},"text":"Pub. L. 105–206, § 3462(a)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3462/c/1"},"text":"Pub. L. 105–206, § 3462(c)(1)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168"},"text":"Pub. L. 104–168","children":[],"tail":" substituted “$50,000. However, such compromise shall be subject to continuing quality review by the Secretary.” for “$500.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4742bd0e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4742bd0f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/tI/s1102/b"},"text":"Pub. L. 116–25, title I, § 1102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/986"},"text":"133 Stat. 986","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/25/tI/s1102/b"},"text":"“The amendment made by this section [amending this section] shall apply to offers-in-compromise submitted after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4742bd10-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" applicable to submissions made and issues raised after the date on which the Secretary first prescribes a list under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6702/c"},"text":"section 6702(c) of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/s407/f"},"text":"section 407(f) of Pub. L. 109–432","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6320"},"text":"section 6320 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/222"},"text":"Pub. L. 109–222","children":[],"tail":" applicable to offers-in-compromise submitted on and after the date which is 60 days after "},{"tag":"date","attrib":{"date":"2006-05-17"},"text":"May 17, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/222/s509/d"},"text":"section 509(d) of Pub. L. 109–222","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6159"},"text":"section 6159 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4742bd11-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" applicable to proposed offers-in-compromise and installment agreements submitted after "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3462/e/1"},"text":"section 3462(e)(1) of Pub. L. 105–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6331"},"text":"section 6331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4742bd12-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/tV/s503/b"},"text":"Pub. L. 104–168, title V, § 503(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1461"},"text":"110 Stat. 1461","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/168/tV/s503/b"},"text":"“The amendment made by this section [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4742bd13-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Preparation of Statement Relating to Offers-in-Compromise","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3462/d"},"text":"Pub. L. 105–206, title III, § 3462(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/766"},"text":"112 Stat. 766","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/206/tIII/s3462/d"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary of the Treasury shall prepare a statement which sets forth in simple, nontechnical terms the rights of a taxpayer and the obligations of the Internal Revenue Service relating to offers-in-compromise. Such statement shall—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise taxpayers who have entered into a compromise of the advantages of promptly notifying the Internal Revenue Service of any change of address or marital status;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide notice to taxpayers that in the case of a compromise terminated due to the actions of one spouse or former spouse, the Internal Revenue Service will, upon application, reinstate such compromise with the spouse or former spouse who remains in compliance with such compromise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide notice to the taxpayer that the taxpayer may appeal the rejection of an offer-in-compromise to the Internal Revenue Service Office of Appeals [now Internal Revenue Service Independent Office of Appeals].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
