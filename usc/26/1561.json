ttrib":{"href":"/us/pl/99/514/tVII/s701/e/2"},"text":"Pub. L. 99–514, title VII, § 701(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2342"},"text":"100 Stat. 2342","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tII/s2004"},"text":"Pub. L. 100–647, title II, § 2004","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3606"},"text":"102 Stat. 3606","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1703/f"},"text":"Pub. L. 104–188, title I, § 1703(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1876"},"text":"110 Stat. 1876","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/12/H"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(12)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4038"},"text":"128 Stat. 4038","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI"},"text":"Pub. L. 115–97, title I","children":[],"tail":", §§ 12001(b)(16), 13001(b)(6)(A), "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2094"},"text":"131 Stat. 2094","children":[],"tail":", 2098.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id451e5629-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id451e562a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id451e562b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13001/b/6/A"},"text":"Pub. L. 115–97, § 13001(b)(6)(A)","children":[],"tail":", amended section generally. Prior to amendment, section related to limitations on certain multiple tax benefits in the case of certain controlled corporations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s12001/b/16/B"},"text":"Pub. L. 115–97, § 12001(b)(16)(B)","children":[],"tail":", struck out at end “In applying section 55(d)(3), the alternative minimum taxable income of all component members shall be taken into account and any decrease in the exemption amount shall be allocated to the component members in the same manner as under paragraph (3).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s12001/b/16/A"},"text":"Pub. L. 115–97, § 12001(b)(16)(A)","children":[],"tail":", struck out par. (3) which read as follows: “one $40,000 exemption amount for purposes of computing the amount of the minimum tax.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/a/12/H/ii"},"text":"Pub. L. 113–295, § 221(a)(12)(H)(ii)","children":[],"tail":", substituted “and the amount specified in paragraph (3)” for “, the amount specified in paragraph (3), and the amount specified in paragraph (4)” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/a/12/H/i"},"text":"Pub. L. 113–295, § 221(a)(12)(H)(i)","children":[],"tail":", inserted “and” at end of par. (2), substituted a period for “, and” at end of par. (3), and struck out par. (4) which read as follows: “one $2,000,000 amount for purposes of computing the tax imposed by section 59A.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" in closing provisions substituted “last 2 sentences” for “last sentence” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" substituted “section 11(b)(1)” for “section 11(b)” in par. (1) and in penultimate sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" added par. (3), and in concluding provisions, substituted “amounts specified in paragraph (1) (and the amount specified in paragraph (3))” for “amounts specified in paragraph (1)” and inserted “In applying section 55(d)(3), the alternative minimum taxable income of all component members shall be taken into account and any decrease in the exemption amount shall be allocated to the component members in the same manner as under paragraph (3).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499"},"text":"Pub. L. 99–499","children":[],"tail":", in subsec. (a) as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" above, added par. (4), and in concluding provisions substituted “, the amount specified in paragraph (3), and the amount specified in paragraph (4)” for “(and the amount specified in paragraph (3))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s211/b/21/A"},"text":"Pub. L. 98–369, § 211(b)(21)(A)","children":[],"tail":", inserted “and” at end of par. (1), substituted a period for the comma at end of par. (2), struck out par. (3) which read as follows: “one $25,000 amount for purposes of computing the limitation on the small business deduction of life insurance companies under sections 804(a)(3) and 809(d)(10), and”, struck out par. (4) which read as follows: “one $1,000,000 amount (adjusted as provided in section 809(f)(3) for purposes of computing the limitation under paragraph (1) or (2) of section 809(f).”, and substituted “paragraph (2)” for “paragraphs (2), (3), and (4)” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s66/b"},"text":"Pub. L. 98–369, § 66(b)","children":[],"tail":", inserted provision that notwithstanding paragraph (1), in applying last sentence of section 11(b) to such component members, the taxable income of all such component members shall be taken into account and any increase in tax under the last sentence shall be divided among such component members in the same manner as amounts under paragraph (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s211/b/21/B"},"text":"Pub. L. 98–369, § 211(b)(21)(B)","children":[],"tail":", inserted “and” at end of par. (1), struck out par. (3) which read as follows: “the amount to be used in computing the limitation on the small business deduction of life insurance companies under sections 804(a)(3) and 809(d)(10), and”, struck out par. (4) which read as follows: “the amount (adjusted as provided in section 809(f)(3)) to be used in computing the limitation under paragraph (1) or (2) of section 809(f),”, and substituted “or (2)” for “, (2), (3), or (4)” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s259/b"},"text":"Pub. L. 97–248, § 259(b)","children":[],"tail":", added par. (4) and inserted reference to par. (4) in text following par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s259/c"},"text":"Pub. L. 97–248, § 259(c)","children":[],"tail":", added par. (4) and inserted reference to subsec. (a)(4) in text following par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" substituted “$250,000 ($150,000 if any component member is a corporation described in section 535(c)(2)(B))” for “$150,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s301/b/19/A"},"text":"Pub. L. 95–600, § 301(b)(19)(A)","children":[],"tail":", in par. (1) substituted “amounts in each taxable income bracket in the tax table in section 11(b) which do not aggregate more than the maximum amount in such bracket to which a corporation is not a component member of a controlled group is entitled” for “the surtax exemption under section 11(d)” and in provisions following par. (3) substituted “amounts” for “amount” in two places and struck out provision that in applying section 11(b)(2), the first $25,000 of taxable income and the second $25,000 of taxable income each be allocated among the component members of a controlled group of corporations in the same manner as the surtax exemption is allocated."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s301/b/19/B"},"text":"Pub. L. 95–600, § 301(b)(19)(B)","children":[],"tail":", substituted “the amount in each taxable income bracket in the tax table in section 11(b)” for “the surtax exemption under section 11(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s703/j/7"},"text":"Pub. L. 95–600, § 703(j)(7)","children":[],"tail":", substituted “804(a)(3)” for “804(a)(4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 901(c)(1), 1906(b)(13)(A), inserted “In applying section 11(b)(2), the first $25,000 of taxable income and the second $25,000 of taxable income shall each be allocated among the component members of a controlled group of corporations in the same manner as the surtax exemption is allocated” after “unequal allocation of such amounts” and struck out “or his delegate” after “Secretary” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/b/1/J/v"},"text":"Pub. L. 94–455, § 1901(b)(1)(J)(v)","children":[],"tail":", substituted “804(a)(3)” for “804(a)(4)” after “under sections”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/164"},"text":"Pub. L. 94–164","children":[],"tail":" struck out “$25,000” in par. (1) as par. (1) is in effect for taxable years ending after "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/12/s303/c/1"},"text":"Pub. L. 94–12, § 303(c)(1)","children":[],"tail":", substituted “$50,000” for “$25,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/12/s304/b"},"text":"Pub. L. 94–12, § 304(b)","children":[],"tail":", substituted “$150,000” for “$100,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 