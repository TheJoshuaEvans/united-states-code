{"tag":"section","attrib":{"id":"id478f081a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A"},"text":null,"children":[{"tag":"num","attrib":{"value":"7702A"},"text":"§ 7702A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modified endowment contract defined","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id478f081b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of section 72, the term “modified endowment contract” means any contract meeting the requirements of section 7702—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id478f081c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id478f081d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entered into on or after ","children":[{"tag":"date","attrib":{"date":"1988-06-21"},"text":"June 21, 1988","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id478f081e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to meet the 7-pay test of subsection (b), or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id478f081f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is received in exchange for a contract described in paragraph (1) or this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id478f0820-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 7-pay test","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), a contract fails to meet the 7-pay test of this subsection if the accumulated amount paid under the contract at any time during the 1st 7 contract years exceeds the sum of the net level premiums which would have been paid on or before such time if the contract provided for paid-up future benefits after the payment of 7 level annual premiums.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id478f0821-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computational rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id478f0822-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in this subsection, the determination under subsection (b) of the 7 level annual premiums shall be made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id478f0823-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of the time the contract is issued, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id478f0824-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by applying the rules of section 7702(b)(2) and of section 7702(e) (other than paragraph (2)(C) thereof), except that the death benefit provided for the 1st contract year shall be deemed to be provided until the maturity date without regard to any scheduled reduction after the 1st 7 contract years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id478f0825-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction in benefits during 1st 7 years","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id478f0826-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If there is a reduction in benefits under the contract within the 1st 7 contract years, this section shall be applied as if the contract had originally been issued at the reduced benefit level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id478f0827-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reductions attributable to nonpayment of premiums","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reduction in benefits attributable to the nonpayment of premiums due under the contract shall not be taken into account under subparagraph (A) if the benefits are reinstated within 90 days after the reduction in such benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id478f0828-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of material changes","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id478f0829-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If there is a material change in the benefits under (or in other terms of) the contract which was not reflected in any previous determination under this section, for purposes of this section—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id478f082a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such contract shall be treated as a new contract entered into on the day on which such material change takes effect, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id478f082b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate adjustments shall be made in determining whether such contract meets the 7-pay test of subsection (b) to take into account the cash surrender value under the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id478f082c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain benefit increases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the term “material change” includes any increase in the death benefit under the contract or any increase in, or addition of, a qualified additional benefit under the contract. Such term shall not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id478f082d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any increase which is attributable to the payment of premiums necessary to fund the lowest level of the death benefit and qualified additional benefits payable in the 1st 7 contract years (determined after taking into account death benefit increases described in subparagraph (A) or (B) of section 7702(e)(2)) or to crediting of interest or other earnings (including policyholder dividends) in respect of such premiums, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id478f082e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent provided in regulations, any cost-of-living increase based on an established broad-based index if such increase is funded ratably over the remaining period during which premiums are required to be paid under the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id478f082f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for contracts with death benefits of $10,000 or less","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a contract—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id478f0830-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which provides an initial death benefit of $10,000 or less, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id478f0831-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which requires at least 7 nondecreasing annual premium payments,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"each of the 7 level annual premiums determined under subsection (b) (without regard to this paragraph) shall be increased by $75. For purposes of this paragraph, the contract involved and all contracts previously issued to the same policyholder by the same company shall be treated as one contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id478f0832-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory authority for certain collection expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may by regulations prescribe rules for taking into account expenses solely attributable to the collection of premiums paid more frequently than annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id478f0833-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain contracts with more than one insured","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id478f0834-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract provides a death benefit which is payable only upon the death of 1 insured following (or occurring simultaneously with) the death of another insured, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id478f0835-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a reduction in such death benefit below the lowest level of such death benefit provided under the contract during the 1st 7 contract years,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"this section shall be applied as if the contract had originally been issued at the reduced benefit level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id478f0836-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions affected","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a contract fails to meet the 7-pay test of subsection (b), such contract shall be treated as failing to meet such requirements only in the case of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id478f0837-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributions during the contract year in which the failure takes effect and during any subsequent contract year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id478f0838-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under regulations prescribed by the Secretary, distributions (not described in paragraph (1)) in anticipation of such failure.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of the preceding sentence, any distribution which is made within 2 years before the failure to meet the 7-pay test shall be treated as made in anticipation of such failure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id478f0839-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id478f083a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount paid","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id478f083b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “amount paid” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id478f083c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the premiums paid under the contract, reduced by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id478f083d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts to which section 72(e) applies (determined without regard to paragraph (4)(A) thereof) but not including amounts includible in gross income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id478f083e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain premiums returned","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, in order to comply with the requirements of subsection (b), any portion of any premium paid during any contract year is returned by the insurance company (with interest) within 60 days after the end of such contract year, the amount so returned (excluding interest) shall be deemed to reduce the sum of the premiums paid under the contract during such contract year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id478f083f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest returned includible in gross income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of section 72(e), the amount of any interest returned as provided in subparagraph (B) shall be includible in the gross income of the recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id478f0840-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “contract year” means the 12-month period beginning with the 1st month for which the contract is in effect, and each 12-month period beginning with the corresponding month in subsequent calendar years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id478f0841-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7702A/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, terms used in this section shall have the same meaning as when used in section 7702.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id478f0842-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tV/s5012/c/1"},"text":"Pub. L. 100–647, title V, § 5012(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3662"},"text":"102 Stat. 3662","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII"},"text":"Pub. L. 101–239, title VII","children":[],"tail":", §§ 7647(a), 7815(a)(1), (4), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2382"},"text":"103 Stat. 2382","children":[],"tail":", 2414; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s318/a/1"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 318(a)(1), (2)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–645; "},{"tag":"ref","attrib":{"href":"/us/pl/107/147/tIV/s416/f"},"text":"Pub. L. 107–147, title IV, § 416(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-09"},"text":"Mar. 9, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/55"},"text":"116 Stat. 55","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id478f0843-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id478f0844-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id478f0845-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (c)(3)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147"},"text":"Pub. L. 107–147","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s318/a/2"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 318(a)(2)]","children":[],"tail":". See 2000 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s318/a/1"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 318(a)(1)]","children":[],"tail":", inserted “or this paragraph” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s318/a/2"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 318(a)(2)]","children":[],"tail":", which substituted “under the old contract” for “under the contract”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/147"},"text":"Pub. L. 107–147","children":[],"tail":". See Construction of 2002 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7815/a/1"},"text":"Pub. L. 101–239, § 7815(a)(1)","children":[],"tail":", substituted “benefit increases” for “increases in future benefits” in heading and amended text generally. Prior to amendment, text read as follows: “For purposes of subparagraph (A), the term ‘material change’ includes any increase in future benefits under the contract. Such term shall not include—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) any increase which is attributable to the payment of premiums necessary to fund the lowest level of future benefits payable in the 1st 7 contract years (determined after taking into account death benefit increases described in subparagraph (A) or (B) of section 7702(e)(2)) or to crediting of interest or other earnings (including policyholder dividends) in respect of such premiums, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) to the extent provided in regulations, any cost-of-living increase based on an established broad-based index if such increase is funded ratably over the remaining life of the the contract.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7815/a/4"},"text":"Pub. L. 101–239, § 7815(a)(4)","children":[],"tail":", substituted “of $10,000 or less” for “under $10,000” in heading and “the same policyholder” for “the same insurer” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7647/a"},"text":"Pub. L. 101–239, § 7647(a)","children":[],"tail":", added par. (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id478f0846-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id478f0847-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s318/a/3"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 318(a)(3)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–645, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/554/s1/a/7/tIII/s318/a/3"},"text":"“The amendments made by this subsection [amending this section] shall take effect as if included in the amendments made by section 5012 of the Technical and Miscellaneous Revenue Act of 1988 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id478f0848-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7647/b"},"text":"Pub. L. 101–239, title VII, § 7647(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2383"},"text":"103 Stat. 2383","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tVII/s7647/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to contracts entered into on or after ","children":[{"tag":"date","attrib":{"date":"1989-09-14"},"text":"September 14, 1989","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by section 7815(a)(1), (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Technical and Miscellaneous Revenue Act of 1988, "},{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7817"},"text":"section 7817 of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id478f0849-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tV/s5012/e"},"text":"Pub. L. 100–647, title V, § 5012(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3665"},"text":"102 Stat. 3665","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7815/a/2"},"text":"Pub. L. 101–239, title VII, § 7815(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2414"},"text":"103 Stat. 2414","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tVII/s7815/a/2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this subsection, the amendments made by this section [enacting this section and amending sections 26 and 72 of this title] shall apply to contracts entered into on or after ","children":[{"tag":"date","attrib":{"date":"1988-06-21"},"text":"June 21, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule where death benefit increases by more than $150,000","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the death benefit under the contract increases by more than $150,000 over the death benefit under the contract in effect on ","children":[{"tag":"date","attrib":{"date":"1988-10-20"},"text":"October 20, 1988","children":[],"tail":", the rules of section 7702A(c)(3) of the 1986 Code (as added by this section) shall apply in determining whether such contract is issued on or after "},{"tag":"date","attrib":{"date":"1988-06-21"},"text":"June 21, 1988","children":[],"tail":". The preceding sentence shall not apply in the case of a contract which, as of "},{"tag":"date","attrib":{"date":"1988-06-21"},"text":"June 21, 1988","children":[],"tail":", required at least 7 level annual premium payments and under which the policyholder makes at least 7 level annual premium payments."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain other material changes taken into account","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A contract entered into before ","children":[{"tag":"date","attrib":{"date":"1988-06-21"},"text":"June 21, 1988","children":[],"tail":", shall be treated as entered into after such date if—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on or after ","children":[{"tag":"date","attrib":{"date":"1988-06-21"},"text":"June 21, 1988","children":[],"tail":", the death benefit under the contract is increased (or a qualified additional benefit is increased or added) and before "},{"tag":"date","attrib":{"date":"1988-06-21"},"text":"June 21, 1988","children":[],"tail":", the owner of the contract did not have a unilateral right under the contract to obtain such increase or addition without providing additional evidence of insurability, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contract is converted after ","children":[{"tag":"date","attrib":{"date":"1988-06-20"},"text":"June 20, 1988","children":[],"tail":", from a term life insurance contract to a life insurance contract providing coverage other than term life insurance coverage without regard to any right of the owner of the contract to such conversion."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain exchanges permitted","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a modified endowment contract which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required at least 7 annual level premium payments,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entered into after ","children":[{"tag":"date","attrib":{"date":"1988-06-20"},"text":"June 20, 1988","children":[],"tail":", and before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":"], and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is exchanged within 3 months after such date of enactment for a life insurance contract which meets the requirements of section 7702A(b),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the contract which is received in exchange for such contract shall not be treated as a modified endowment contract if the taxpayer elects, notwithstanding section 1035 of the 1986 Code, to recognize gain on such exchange.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for annuity contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of annuity contracts, the amendments made by subsection (d) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s72"},"text":"section 72 of this title","children":[],"tail":"] shall apply to contracts entered into after "},{"tag":"date","attrib":{"date":"1988-10-21"},"text":"October 21, 1988","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id478f084a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147/tIV/s416/f"},"text":"Pub. L. 107–147, title IV, § 416(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-09"},"text":"Mar. 9, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/55"},"text":"116 Stat. 55","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/147/tIV/s416/f"},"text":"“Paragraph (2) of section 318(a) of the Community Renewal Tax Relief Act of 2000 [H.R. 5662, as enacted by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7"},"text":"section 1(a)(7) of Pub. L. 106–554","children":[],"tail":"]("},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":"A–645) [amending this section] is repealed, and clause (ii) of section 7702A(c)(3)(A) shall read and be applied as if the amendment made by such paragraph had not been enacted.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
