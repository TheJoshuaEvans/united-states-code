{"tag":"section","attrib":{"id":"id41327595-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67"},"text":null,"children":[{"tag":"num","attrib":{"value":"67"},"text":"§ 67.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2-percent floor on miscellaneous itemized deductions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id41327596-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual, the miscellaneous itemized deductions for any taxable year shall be allowed only to the extent that the aggregate of such deductions exceeds 2 percent of adjusted gross income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41327597-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous itemized deductions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “miscellaneous itemized deductions” means the itemized deductions other than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41327598-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deduction under section 163 (relating to interest),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41327599-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deduction under section 164 (relating to taxes),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4132759a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deduction under section 165(a) for casualty or theft losses described in paragraph (2) or (3) of section 165(c) or for losses described in section 165(d),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4132759b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deductions under section 170 (relating to charitable, etc., contributions and gifts) and section 642(c) (relating to deduction for amounts paid or permanently set aside for a charitable purpose),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4132759c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deduction under section 213 (relating to medical, dental, etc., expenses),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4132759d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any deduction allowable for impairment-related work expenses,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4132759e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deduction under section 691(c) (relating to deduction for estate tax in case of income in respect of the decedent),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4132759f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any deduction allowable in connection with personal property used in a short sale,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id413275a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deduction under section 1341 (relating to computation of tax where taxpayer restores substantial amount held under claim of right),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id413275a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deduction under section 72(b)(3) (relating to deduction where annuity payments cease before investment recovered),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id413275a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deduction under section 171 (relating to deduction for amortizable bond premium),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id413275a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deduction under section 216 (relating to deductions in connection with cooperative housing corporations), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id413275a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deductions allowed by section 162 for educator expenses (as defined in subsection (g)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id413275a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disallowance of indirect deduction through pass-thru entity","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id413275a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe regulations which prohibit the indirect deduction through pass-thru entities of amounts which are not allowable as a deduction if paid or incurred directly by an individual and which contain such reporting requirements as may be necessary to carry out the purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id413275a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of publicly offered regulated investment companies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id413275a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply with respect to any publicly offered regulated investment company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id413275a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publicly offered regulated investment companies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id413275aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “publicly offered regulated investment company” means a regulated investment company the shares of which are—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id413275ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/c/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuously offered pursuant to a public offering (within the meaning of section 4 of the Securities Act of 1933, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"15 U.S.C. 77a","children":[],"tail":" to 77aa)),"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id413275ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/c/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regularly traded on an established securities market, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id413275ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/c/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" held by or for no fewer than 500 persons at all times during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id413275ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary may reduce 500 person requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may by regulation decrease the minimum shareholder requirement of clause (i)(III) in the case of regulated investment companies which experience a loss of shareholders through net redemptions of their shares.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id413275af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain other entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id413275b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to cooperatives and real estate investment trusts, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id413275b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in regulations, with respect to estates and trusts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id413275b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impairment-related work expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “impairment-related work expenses” means expenses—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id413275b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of a handicapped individual (as defined in section 190(b)(3)) for attendant care services at the individual’s place of employment and other expenses in connection with such place of employment which are necessary for such individual to be able to work, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id413275b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which a deduction is allowable under section 162 (determined without regard to this section).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id413275b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of adjusted gross income in case of estates and trusts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the adjusted gross income of an estate or trust shall be computed in the same manner as in the case of an individual, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id413275b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deductions for costs which are paid or incurred in connection with the administration of the estate or trust and which would not have been incurred if the property were not held in such trust or estate, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id413275b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deductions allowable under sections 642(b), 651, and 661,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be treated as allowable in arriving at adjusted gross income. Under regulations, appropriate adjustments shall be made in the application of part I of subchapter J of this chapter to take into account the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id413275b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall be applied before the application of the dollar limitation of the second sentence of section 162(a) (relating to trade or business expenses).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id413275b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educator expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (b)(13), the term “educator expenses” means expenses of a type which would be described in section 62(a)(2)(D) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id413275ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such section were applied—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id413275bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to the dollar limitation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id413275bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to “(other than nonathletic supplies for courses of instruction in health or physical education)” in clause (ii) thereof, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id413275bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “as part of instructional activity” for “in the classroom” in clause (ii) thereof, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id413275be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 62(d)(1)(A) were applied by inserting “, interscholastic sports administrator or coach,” after “counselor”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id413275bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s67/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension for taxable years beginning after 2017","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a), no miscellaneous itemized deduction shall be allowed for any taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id413275c0-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tI/s132/a"},"text":"Pub. L. 99–514, title I, § 132(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2113"},"text":"100 Stat. 2113","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"