children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70110/a"},"text":"Pub. L. 119–21, § 70110(a)","children":[],"tail":", substituted “beginning after 2017” for “2018 through 2025” in heading and struck out “, and before "},{"tag":"date","attrib":{"date":"2026-01-01"},"text":"January 1, 2026","children":[],"tail":"” after “"},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":"” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70110/b/2"},"text":"Pub. L. 119–21, § 70110(b)(2)","children":[],"tail":", redesignated subsec. (g) as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" substituted “the second sentence” for “the last sentence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" substituted “for casualty or theft losses described in paragraph (2) or (3) of section 165(c) or for losses described in section 165(d)” for “for losses described in subsection (c)(3) or (d) of section 165”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(6) to (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" redesignated pars. (7) to (13) as (6) to (12), respectively, and struck out former par. (6) which read as follows: “the deduction under section 217 (relating to moving expenses),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","c