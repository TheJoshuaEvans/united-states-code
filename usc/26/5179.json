{"tag":"section","attrib":{"id":"id462bce30-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5179"},"text":null,"children":[{"tag":"num","attrib":{"value":"5179"},"text":"§ 5179.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration of stills","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id462bce31-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5179/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person having in his possession or custody, or under his control, any still or distilling apparatus set up, shall register such still or apparatus with the Secretary immediately on its being set up, by subscribing and filing with the Secretary a statement, in writing, setting forth the particular place where such still or distilling apparatus is set up, the kind of still and its capacity, the owner thereof, his place of residence, and the purpose for which said still or distilling apparatus has been or is intended to be used (except that stills or distilling apparatus not used or intended to be used for the distillation, redistillation, or recovery of distilled spirits are not required to be registered under this section).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462bce32-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5179/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id462bce33-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5179/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For penalty and forfeiture provisions relating to unregistered stills, see sections 5601(a)(1) and 5615(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id462bce34-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5179/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions requiring notification to set up a still, boiler, or other vessel for distilling, see section 5101(a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id462bce35-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1355"},"text":"72 Stat. 1355","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1905(b)(6)(C), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1823"},"text":"90 Stat. 1823","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s451/b/1"},"text":"Pub. L. 98–369, div. A, title IV, § 451(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/819"},"text":"98 Stat. 819","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id462bce36-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id462bce37-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"headi