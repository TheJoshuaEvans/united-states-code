{"tag":"section","attrib":{"id":"id46295db8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173"},"text":null,"children":[{"tag":"num","attrib":{"value":"5173"},"text":"§ 5173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bonds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46295db9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operations at, and withdrawals from, distilled spirits plant must be covered by bond","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46295dba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided under section 5551(d), no person intending to establish a distilled spirits plant may commence operations at such plant unless such person has furnished bond covering operations at such plant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46295dbb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided under section 5551(d), no distilled spirits (other than distilled spirits withdrawn under section 5214 or 7510) may be withdrawn from bonded premises except on payment of tax unless the proprietor of the bonded premises has furnished bond covering such withdrawal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46295dbc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operations bonds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The bond required by paragraph (1) of subsection (a) shall meet the requirements of paragraph (1), (2), or (3) of this subsection:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46295dbd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" One plant bond","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The bond covers operations at a single distilled spirits plant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46295dbe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjacent wine cellar bond","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The bond covers operations at a distilled spirits plant and at an adjacent bonded wine cellar.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46295dbf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area bond","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The bond covers operations at 2 or more distilled spirits plants (and adjacent bonded wine cellars) which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46295dc0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are located in the same geographical area (as designated in regulations prescribed by the Secretary), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46295dc1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are operated by the same person (or, in the case of a corporation, by such corporation and its controlled subsidiaries).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46295dc2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal bonds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The bond required by paragraph (2) of subsection (a) shall cover withdrawals from 1 or more bonded premises the operations at which could be covered by the same operations bond under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46295dc3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unit bonds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary, the requirements of paragraphs (1) and (2) of subsection (a) shall be treated as met by a unit bond which covers both operations at, and withdrawals from, 1 or more bonded premises which could be covered by the same operations bond under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46295dc4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46295dc5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any bond furnished under this section shall be conditioned that the person furnishing the bond—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46295dc6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will faithfully comply with all provisions of law and regulations relating to the activities covered by such bond, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46295dc7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" will pay—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46295dc8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all taxes imposed by this chapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46295dc9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all penalties incurred by, or fines imposed on, such person for violation of any such provision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46295dca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any bond furnished under this section shall contain such other terms and conditions as may be required by regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46295dcb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46295dcc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penal sum of any bond shall be the amount determined under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46295dcd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum and minimum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall by regulations prescribe a minimum amount and a maximum amount for each type of bond which may be furnished under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46295dce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total amount available","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of any bond furnished under this section shall be available for the satisfaction of any liability incurred under the terms and conditions of such bond.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46295dcf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46295dd0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal bonds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any bond furnished under this section which covers withdrawals but not operations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46295dd1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such bond shall be in addition to the operations bond, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46295dd2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if distilled spirits are withdrawn under such bond, the operations bond shall no longer cover liability for payment of the tax on the spirits withdrawn.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46295dd3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjacent wine cellars","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46295dd4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No wine cellar shall be treated as being adjacent to a distilled spirits plant unless—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46295dd5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/h/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such distilled spirits plant is qualified under this subchapter for the production of distilled spirits, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46295dd6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/h/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such wine cellar and the distilled spirits plant are operated by the same person (or, in the case of a corporation, by such corporation and its controlled subsidiaries).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46295dd7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5173/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bond in lieu of wine cellar bond","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any adjacent wine cellar, a bond furnished under this section which covers operations at such wine cellar shall be in lieu of any bond which would otherwise be required under section 5354 with respect to such wine cellar (other than supplemental bonds required under the second sentence of section 5354).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46295dd8-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1349"},"text":"72 Stat. 1349","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/659/s4"},"text":"Pub. L. 91–659, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-08"},"text":"Jan. 8, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1966"},"text":"84 Stat. 1966","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s805/c"},"text":"Pub. L. 96–39, title VIII, § 805(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/276"},"text":"93 Stat. 276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tIII/s332/b/2/A"},"text":"Pub. L. 114–113, div. Q, title III, § 332(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3105"},"text":"129 Stat. 3105","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46295dd9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46295dda-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46295ddb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5173, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/628"},"text":"68A Stat. 628","children":[],"tail":", related to “distillery fixtures and equipment”, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See sections 5178(a)(1)(A), (2)(B)(C), (c)(1) and 5202(b) of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising subsecs. (a), (b), (b)(1), (b)(1)(A) to (C), (b)(3), (c), (c)(1), (d) and (e)(1) of this section were contained in prior sections of act ","children":[{"tag":"date","attrib":{"date":"1954-08-16"},"text":"Aug. 16, 1954","children":[],"tail":", prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":", as follows:"},{"tag":"quotedContent","attrib":{},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id46295ddc-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Present subsecs.:","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Prior sections","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5172, 5176(a), 5231, 5232(a), 5272(a)