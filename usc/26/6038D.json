{"tag":"section","attrib":{"id":"id4669c15a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D"},"text":null,"children":[{"tag":"num","attrib":{"value":"6038D"},"text":"§ 6038D.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information with respect to foreign financial assets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4669c15b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual who, during any taxable year, holds any interest in a specified foreign financial asset shall attach to such person’s return of tax imposed by subtitle A for such taxable year the information described in subsection (c) with respect to each such asset if the aggregate value of all such assets exceeds $50,000 (or such higher dollar amount as the Secretary may prescribe).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4669c15c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified foreign financial assets","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “specified foreign financial asset” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4669c15d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any financial account (as defined in section 1471(d)(2)) maintained by a foreign financial institution (as defined in section 1471(d)(4)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c15e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any of the following assets which are not held in an account maintained by a financial institution (as defined in section 1471(d)(5))—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4669c15f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any stock or security issued by a person other than a United States person,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4669c160-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any financial instrument or contract held for investment that has an issuer or counterparty which is other than a United States person, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4669c161-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any interest in a foreign entity (as defined in section 1473).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4669c162-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information described in this subsection with respect to any asset is:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4669c163-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any account, the name and address of the financial institution in which such account is maintained and the number of such account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c164-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any stock or security, the name and address of the issuer and such information as is necessary to identify the class or issue of which such stock or security is a part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c165-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of any other instrument, contract, or interest—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4669c166-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such information as is necessary to identify such instrument, contract, or interest, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4669c167-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the names and addresses of all issuers and counterparties with respect to such instrument, contract, or interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c168-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The maximum value of the asset during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4669c169-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for failure to disclose","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4669c16a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any individual fails to furnish the information described in subsection (c) with respect to any taxable year at the time and in the manner described in subsection (a), such person shall pay a penalty of $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c16b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in penalty where failure continues after notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any failure described in paragraph (1) continues for more than 90 days after the day on which the Secretary mails notice of such failure to the individual, such individual shall pay a penalty (in addition to the penalties under paragraph (1)) of $10,000 for each 30-day period (or fraction thereof) during which such failure continues after the expiration of such 90-day period. The penalty imposed under this paragraph with respect to any failure shall not exceed $50,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4669c16c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumption that value of specified foreign financial assets exceeds dollar threshold","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4669c16d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that an individual has an interest in one or more specified foreign financial assets, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c16e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individual does not provide sufficient information to demonstrate the aggregate value of such assets,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then the aggregate value of such assets shall be treated as being in excess of $50,000 (or such higher dollar amount as the Secretary prescribes for purposes of subsection (a)) for purposes of assessing the penalties imposed under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4669c16f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to certain entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent provided by the Secretary in regulations or other guidance, the provisions of this section shall apply to any domestic entity which is formed or availed of for purposes of holding, directly or indirectly, specified foreign financial assets, in the same manner as if such entity were an individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4669c170-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable cause exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed by this section on any failure which is shown to be due to reasonable cause and not due to willful neglect. The fact that a foreign jurisdiction would impose a civil or criminal penalty on the taxpayer (or any other person) for disclosing the required information is not reasonable cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4669c171-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe such regulations or other guidance as may be necessary or appropriate to carry out the purposes of this section, including regulations or other guidance which provide appropriate exceptions from the application of this section in the case of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4669c172-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classes of assets identified by the Secretary, including any assets with respect to which the Secretary determines that disclosure under this section would be duplicative of other disclosures,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c173-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonresident aliens, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c174-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038D/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bona fide residents of any possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4669c175-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/147/tV/s511/a"},"text":"Pub. L. 111–147, title V, § 511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-18"},"text":"Mar. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/109"},"text":"124 Stat. 109","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4669c176-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4669c177-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4669c178-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/147/tV/s511/c"},"text":"Pub. L. 111–147, title V, § 511(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-18"},"text":"Mar. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/110"},"text":"124 Stat. 110","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/147/tV/s511/c"},"text":"“The amendments made by this section [enacting this section] shall apply to taxable years beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-03-18"},"text":"Mar. 18, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
