{"tag":"section","attrib":{"id":"id44c14287-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234B"},"text":null,"children":[{"tag":"num","attrib":{"value":"1234B"},"text":"§ 1234B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gains or losses from securities futures contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44c14288-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of gain or loss","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44c14289-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gain or loss attributable to the sale, exchange, or termination of a securities futures contract shall be considered gain or loss from the sale or exchange of property which has the same character as the property to which the contract relates has in the hands of the taxpayer (or would have in the hands of the taxpayer if acquired by the taxpayer).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c1428a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplication of subsection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44c1428b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234B/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract which constitutes property described in paragraph (1) or (7) of section 1221(a), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44c1428c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234B/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any income derived in connection with a contract which, without regard to this subsection, is treated as other than gain from the sale or exchange of a capital asset.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44c1428d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short-term gains and losses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in the regulations under section 1092(b) or this section, or in section 1233, if gain or loss on the sale, exchange, or termination of a securities futures contract to sell property is considered as gain or loss from the sale or exchange of a capital asset, such gain or loss shall be treated as short-term capital gain or loss.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44c3b28e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securities futures contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “securities futures contract” means any security future (as defined in section 3(a)(55)(A) of the Securities Exchange Act of 1934, as in effect on the date of the enactment of this section). The Secretary may prescribe regulations regarding the status of contracts the values of which are determined directly or indirectly by reference to any index which becomes (or ceases to be) a narrow-based security index (as defined for purposes of section 1256(g)(6)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44c3b28f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts not treated as commodity futures contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this title, a securities futures contract shall not be treated as a commodity futures contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44c3b290-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234B/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be appropriate to provide for the proper treatment of securities futures contracts under this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44c3b291-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234B/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For special rules relating to dealer securities futures contracts, see section 1256.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44c3b292-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIV/s401/a"},"text":"Pub. L. 106–554, § 1(a)(7) [title IV, § 401(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–648; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/147/tIV/s412/d/1/B"},"text":"Pub. L. 107–147, title IV, § 412(d)(1)(B)","children":[],"tail":", (3)(B), "},{"tag":"date","attrib":{"date":"2002-03-09"},"text":"Mar. 9, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/53"},"text":"116 Stat. 53","children":[],"tail":", 54; "},{"tag":"ref","attrib":{"href":"/us/pl/108/311/tIV/s405/a/1"},"text":"Pub. L. 108–311, title IV, § 405(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-04"},"text":"Oct. 4, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1188"},"text":"118 Stat. 1188","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44c3b293-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44c3b294-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id44c3b295-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3(a)(55)(A) of the Securities Exchange Act of 1934, referred to in subsec. (c), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a/55/A"},"text":"section 78c(a)(55)(A) of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (c), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id44c3b296-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIV/s401/a"},"text":"Pub. L. 106–554, § 1(a)(7) [title IV, § 401(a)]","children":[],"tail":", which directed amendment of subpart IV of subchapter P of chapter 1 by adding this section after section 1234A, was executed by adding this section after 1234A of this part which is part IV of subchapter P of chapter 1, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44c3b297-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311"},"text":"Pub. L. 108–311","children":[],"tail":" inserted at end “The Secretary may prescribe regulations regarding the status of contracts the values of which are determined directly or indirectly by reference to any index which becomes (or ceases to be) a narrow-based security index (as defined for purposes of section 1256(g)(6)).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147/s412/d/1/B/i"},"text":"Pub. L. 107–147, § 412(d)(1)(B)(i)","children":[],"tail":", substituted “sale, exchange, or termination of a securities futures contract” for “sale or exchange of a securities futures contract”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147/s412/d/1/B/i"},"text":"Pub. L. 107–147, § 412(d)(1)(B)(i)","children":[],"tail":", (3)(B), inserted “or in section 1233,” after “or this section,” and substituted “sale, exchange, or termination of a securities futures contract” for “sale or exchange of a securities futures contract”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147/s412/d/1/B/ii"},"text":"Pub. L. 107–147, § 412(d)(1)(B)(ii)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44c3b298-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44c3b299-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311/tIV/s405/b"},"text":"Pub. L. 108–311, title IV, § 405(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-04"},"text":"Oct. 4, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1189"},"text":"118 Stat. 1189","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/311/tIV/s405/b"},"text":"“The amendments made by subsection (a) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1256"},"text":"section 1256 of this title","children":[],"tail":"] shall take effect as if included in section 401 of the Community Renewal Tax Relief Act of 2000 [H.R. 5662, as enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7"},"text":"section 1(a)(7) of Pub. L. 106–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–587].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44c3b29a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147"},"text":"Pub. L. 107–147","children":[],"tail":" effective as if included in the provisions of the Community Renewal Tax Relief Act of 2000 [H.R. 5662, as enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":"], to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/147/s412/e"},"text":"section 412(e) of Pub. L. 107–147","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s151"},"text":"section 151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
