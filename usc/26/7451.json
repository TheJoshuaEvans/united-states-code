{"tag":"section","attrib":{"id":"id475cfac0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7451"},"text":null,"children":[{"tag":"num","attrib":{"value":"7451"},"text":"§ 7451.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id475cfac1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7451/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Tax Court is authorized to impose a fee in an amount not in excess of $60 to be fixed by the Tax Court for the filing of any petition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id475cfac2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7451/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tolling of time in certain cases","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id475cfac3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7451/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this title, in any case (including by reason of a lapse in appropriations) in which a filing location is inaccessible or otherwise unavailable to the general public on the date a petition is due, the relevant time period for filing such petition shall be tolled for the number of days within the period of inaccessibility plus an additional 14 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id475cfac4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7451/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing location","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “filing location” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id475cfac5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7451/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the office of the clerk of the Tax Court, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id475cfac6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7451/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any on-line portal made available by the Tax Court for electronic filing of petitions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id475cfac7-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/884"},"text":"68A Stat. 884","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/406/tII/s1041/b/1"},"text":"Pub. L. 93–406, title II, § 1041(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/950"},"text":"88 Stat. 950","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIII/s1306/b/1"},"text":"Pub. L. 94–455, title XIII, § 1306(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"t