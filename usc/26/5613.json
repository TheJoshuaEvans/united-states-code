{"tag":"section","attrib":{"id":"id46412ad6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5613"},"text":null,"children":[{"tag":"num","attrib":{"value":"5613"},"text":"§ 5613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture of distilled spirits not closed, marked, or branded as required by law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46412ad7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5613/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unmarked or unbranded casks or packages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All distilled spirits found in any cask or package required by this chapter or any regulation issued pursuant thereto to bear a mark, brand, or identification, which cask or package is not marked, branded, or identified in compliance with this chapter and regulations issued pursuant thereto, shall be forfeited to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46412ad8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5613/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Containers without closures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All distilled spirits found in any container which is required by this chapter to bear a closure or other device and which does not bear a closure or other device in compliance with this chapter shall be forfeited to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46412ad9-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},