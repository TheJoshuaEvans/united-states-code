{"tag":"section","attrib":{"id":"id472d38b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6690"},"text":null,"children":[{"tag":"num","attrib":{"value":"6690"},"text":"§ 6690.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraudulent statement or failure to furnish statement to plan participant","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person required under section 6057(e) to furnish a statement to a participant who willfully furnishes a false or fraudulent statement, or who willfully fails to furnish a statement in the manner, at the time, and showing the information required under section 6057(e), or regulations prescribed thereunder, shall for each such act, or for each such failure, be subject to a penalty under this subchapter of $50, which shall be assessed and collected in the same manner as the tax on employers imposed by section 3111.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id472d38b1-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tII/s1031/b/2/A"},"text":"Pub. L. 93–406, title II, § 1031(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/946"},"text":"88 Stat. 946","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id472d38b2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id472d38b3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id472d38b4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/406/s1034"},"text":"section 1034 of Pub. L. 93–406","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6057"},"text":"section 6057 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
