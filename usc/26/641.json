{"tag":"section","attrib":{"id":"id43e84691-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641"},"text":null,"children":[{"tag":"num","attrib":{"value":"641"},"text":"§ 641.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43e84692-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The tax imposed by section 1(e) shall apply to the taxable income of estates or of any kind of property held in trust, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43e84693-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" income accumulated in trust for the benefit of unborn or unascertained persons or persons with contingent interests, and income accumulated or held for future distribution under the terms of the will or trust;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43e84694-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" income which is to be distributed currently by the fiduciary to the beneficiaries, and income collected by a guardian of an infant which is to be held or distributed as the court may direct;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43e84695-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" income received by estates of deceased persons during the period of administration or settlement of the estate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43e84696-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" income which, in the discretion of the fiduciary, may be either distributed to the beneficiaries or accumulated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43e84697-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation and payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The taxable income of an estate or trust shall be computed in the same manner as in the case of an individual, except as otherwise provided in this part. The tax shall be computed on such taxable income and shall be paid by the fiduciary. For purposes of this subsection, a foreign trust or foreign estate shall be treated as a nonresident alien individual who is not present in the United States at any time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43e84698-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for taxation of electing small business trusts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43e84699-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43e8469a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the portion of any electing small business trust which consists of stock in 1 or more S corporations shall be treated as a separate trust, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43e8469b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the tax imposed by this chapter on such separate trust shall be determined with the modifications of paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43e8469c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the modifications of this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43e8469d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in section 1(h), the amount of the tax imposed by section 1(e) shall be determined by using the highest rate of tax set forth in section 1(e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43e8469e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The exemption amount under section 55(d) shall be zero.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43e8469f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The only items of income, loss, deduction, or credit to be taken into account are the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43e846a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The items required to be taken into account under section 1366.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43e846a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any gain or loss from the disposition of stock in an S corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43e846a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent provided in regulations, State or local income taxes or administrative expenses to the extent allocable to items described in clauses (i) and (ii).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43e846a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any interest expense paid or accrued on indebtedness incurred to acquire stock in an S corporation.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"No deduction or credit shall be allowed for any amount not described in this paragraph, and no item described in this paragraph shall be apportioned to any beneficiary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43e846a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No amount shall be allowed under paragraph (1) or (2) of section 1211(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43e846a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43e846a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 642(c) shall not apply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43e846a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of section 170(b)(1)(G), adjusted gross income shall be computed in the same manner as in the case of an individual, except that the deductions for costs which are paid or incurred in connection with the administration of the trust and which would not have been incurred if the property were not held in such trust shall be treated as allowable in arriving at adjusted gross income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43e846a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of remainder of trust and distributions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of determining—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43e846a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the tax imposed by this chapter on the portion of any electing small business trust not treated as a separate trust under paragraph (1), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43e846aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distributable net income of the entire trust,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the items referred to in paragraph (2)(C) shall be excluded. Except as provided in the preceding sentence, this subsection shall not affect the taxation of any distribution from the trust.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43e846ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of unused deductions where termination of separate trust","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a portion of an electing small business trust ceases to be treated as a separate trust under paragraph (1), any carryover or excess deduction of the separate trust which is referred to in section 642(h) shall be taken into account by the entire trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43e846ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s641/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electing small business trust","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “electing small business trust” has the meaning given such term by section 1361(e)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43e846ad-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/215"},"text":"68A Stat. 215","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tVIII/s803/d/3"},"text":"Pub. L. 91–172, title VIII, § 803(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/684"},"text":"83 Stat. 684","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tVII/s701/e/2"},"text":"Pub. L. 94–455, title VII, § 701(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1579"},"text":"90 Stat. 1579","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/30/tI/s101/d/8"},"text":"Pub. L. 95–30, title I, § 101(d)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-23"},"text":"May 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/134"},"text":"91 Stat. 134","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1302/d"},"text":"Pub. L. 104–188, title I, § 1302(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1778"},"text":"110 Stat. 1778","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXVI/s1601/i/3/B"},"text":"Pub. L. 105–34, title XVI, § 1601(i)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1093"},"text":"111 Stat. 1093","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tVI/s6007/f/2"},"text":"Pub. L. 105–206, title VI, § 6007(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/810"},"text":"112 Stat. 810","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/28/tVIII/s8236/a"},"text":"Pub. L. 110–28, title VIII, § 8236(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-25"},"text":"May 25, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/199"},"text":"121 Stat. 199","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13542/a"},"text":"Pub. L. 115–97, title I, § 13542(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2154"},"text":"131 Stat. 2154","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43e846ae-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43e846af-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43e846b0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (c)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (c)(2)(C)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28"},"text":"Pub. L. 110–28","children":[],"tail":" added cl. (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" redesignated subsec. (d) as (c) and struck out heading and text of former subsec. (c). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"General rule","children":[],"tail":".—For purposes of this part, the taxable income of a trust does not include the amount of any includible gain as defined in section 644(b) reduced by any deductions properly allocable thereto."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Cross reference","children":[],"tail":".—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"“For the taxation of any includible gain, see section 644.”","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" inserted at end “For purposes of this subsection, a foreign trust or foreign estate shall be treated as a nonresident alien individual who is not present in the United States at any time.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/30"},"text":"Pub. L. 95–30","children":[],"tail":" substituted “section 1(e)” for “section 1(d)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" substituted “The tax imposed by section 1(d)” for “The taxes imposed by this chapter on individuals”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43e846b1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43e846b2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13542/b"},"text":"Pub. L. 115–97, title I, § 13542(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":",