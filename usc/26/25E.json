{"tag":"section","attrib":{"id":"id406ed75f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E"},"text":null,"children":[{"tag":"num","attrib":{"value":"25E"},"text":"§ 25E.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Previously-owned clean vehicles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id406ed760-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of credit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a qualified buyer who during a taxable year places in service a previously-owned clean vehicle, there shall be allowed as a credit against the tax imposed by this chapter for the taxable year an amount equal to the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id406ed761-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,000, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id406ed762-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount equal to 30 percent of the sale price with respect to such vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id406ed763-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation based on modified adjusted gross income","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id406ed764-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No credit shall be allowed under subsection (a) for any taxable year if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id406ed765-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id406ed766-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modified adjusted gross income of the taxpayer for such taxable year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id406ed767-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modified adjusted gross income of the taxpayer for the preceding taxable year, exceeds","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id406ed768-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the threshold amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id406ed769-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Threshold amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)(B), the threshold amount shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id406ed76a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a joint return or a surviving spouse (as defined in section 2(a)), $150,000,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id406ed76b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a head of household (as defined in section 2(b)), $112,500, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id406ed76c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a taxpayer not described in subparagraph (A) or (B), $75,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id406ed76d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modified adjusted gross income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “modified adjusted gross income” means adjusted gross income increased by any amount excluded from gross income under section 911, 931, or 933.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id406ed76e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id406ed76f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Previously-owned clean vehicle","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “previously-owned clean vehicle” means, with respect to a taxpayer, a motor vehicle—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id406ed770-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the model year of which is at least 2 years earlier than the calendar year in which the taxpayer acquires such vehicle,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id406ed771-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the original use of which commences with a person other than the taxpayer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id406ed772-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is acquired by the taxpayer in a qualified sale, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id406ed773-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id406ed774-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements of subparagraphs (C), (D), (E), (F), and (H) (except for clause (iv) thereof) of section 30D(d)(1), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id406ed775-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is a motor vehicle which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id40714876-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c/1/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies the requirements under subparagraphs (A) and (B) of section 30B(b)(3), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id40714877-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c/1/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a gross vehicle weight rating of less than 14,000 pounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40714878-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified sale","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified sale” means a sale of a motor vehicle—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40714879-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a dealer (as defined in section 30D(g)(8)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4071487a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a sale price which does not exceed $25,000, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4071487b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is the first transfer since the date of the enactment of this section to a qualified buyer other than the person with whom the original use of such vehicle commenced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4071487c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified buyer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified buyer” means, with respect to a sale of a motor vehicle, a taxpayer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4071487d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is an individual,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4071487e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who purchases such vehicle for use and not for resale,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4071487f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to whom no deduction is allowable with respect to another taxpayer under section 151, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40714880-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has not been allowed a credit under this section for any sale during the 3-year period ending on the date of the sale of such vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40714881-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motor vehicle; capacity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “motor vehicle” and “capacity” have the meaning given such terms in paragraphs (2) and (4) of section 30D(d), respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40714882-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" VIN number requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No credit shall be allowed under subsection (a) with respect to any vehicle unless the taxpayer includes the vehicle identification number of such vehicle on the return of tax for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40714883-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of certain rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, rules similar to the rules of section 30D(f) (without regard to paragraph (10) or (11) thereof) shall apply for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40714884-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of section 30D(g) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40714885-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s25E/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No credit shall be allowed under this section with respect to any vehicle acquired after ","children":[{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id40714886-3a70-11f1-a967-d35dac11796a"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s13402/a"},"text":"Pub. L. 117–169, title I, § 13402(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1962"},"text":"136 Stat. 1962","children":[],"tail":", 1963; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70501"},"text":"Pub. L. 119–21, title VII, § 70501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/250"},"text":"139 Stat. 250","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id40714887-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id40714888-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id40714889-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (c)(2)(C), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4071488a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2032-12-31"},"text":"December 31, 2032","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/s13402/b"},"text":"Pub. L. 117–169, § 13402(b)","children":[],"tail":", added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4071488b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4071488c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s13402/e"},"text":"Pub. L. 117–169, title I, § 13402(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1964"},"text":"136 Stat. 1964","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/169/tI/s13402/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the amendments made by this section [enacting this section and amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6213"},"text":"section 6213 of this title","children":[],"tail":"] shall apply to vehicles acquired after "},{"tag":"date","attrib":{"date":"2022-12-31"},"text":"December 31, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of credit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsection (b) [amending this section] shall apply to vehicles acquired after ","children":[{"tag":"date","attrib":{"date":"2023-12-31"},"text":"December 31, 2023","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
