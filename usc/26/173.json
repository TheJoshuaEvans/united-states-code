{"tag":"section","attrib":{"id":"id4208ffac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s173"},"text":null,"children":[{"tag":"num","attrib":{"value":"173"},"text":"§ 173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Circulation expenditures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4208ffad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s173/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 263, all expenditures (other than expenditures for the purchase of land or depreciable property or for the acquisition of circulation through the purchase of any part of the business of another publisher of a newspaper, magazine, or other periodical) to establish, maintain, or increase the circulation of a newspaper, magazine, or other periodical shall be allowed as a deduction; except that the deduction shall not be allowed with respect to the portion of such expenditures as, under regulations prescribed by the Secretary, is chargeable to capital account if the taxpayer elects, in accordance with such regulations, to treat such portion as so chargeable. Such election, if made, must be for the total amount of such portion of the expenditures which is so chargeable to capital account, and shall be binding for all subsequent taxable years unless, upon application by the taxpayer, the Secretary permits a revocation of such election subject to such conditions as he deems necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4208ffae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s173/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For election of 3-year amortization of expenditures allowable as a deduction under subsection (a), see section 59(e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4208ffaf-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/65"},"text":"68A Stat. 65","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tII/s201/d/9/A"},"text":"Pub. L. 97–248, title II, § 201(d)(9)(A)","children":[],"tail":", formerly § 201(c)(9)(A), "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/420"},"text":"96 Stat. 420","children":[],"tail":", renumbered § 201(d)(9)(A), "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tIII/s306/a/1/A/i"},"text":"Pub. L. 97–448, title III, § 306(a)(1)(A)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2400"},"text":"96 Stat. 2400","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII/s711/a/3/C"},"text":"Pub. L. 98–369, div. A, title VII, § 711(a)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/942"},"text":"98 Stat. 942","