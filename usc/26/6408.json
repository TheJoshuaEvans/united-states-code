{"tag":"section","attrib":{"id":"id46dc3239-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6408"},"text":null,"children":[{"tag":"num","attrib":{"value":"6408"},"text":"§ 6408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State escheat laws not to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No overpayment of any tax imposed by this title shall be refunded (and no interest with respect to any such overpayment shall be paid) if the amount of such refund (or interest) would escheat to a State or would otherwise become the property of a State under any law relating to the disposition of unclaimed or abandoned property. No refund (or payment of interest) shall be made to the estate of any decedent unless it is affirmatively shown that such amount will not escheat to a State or otherwise become the property of a State under such a law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id46dc323a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10621/a"},"text":"Pub. L. 100–203, title X, § 10621(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-452"},"text":"101 Stat. 1330–452","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46dc323b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46dc323c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46dc323d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10621/c"},"text":"Pub. L. 100–203, title X, § 10621(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-452"},"text":"101 Stat. 1330–452","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/203/tX/s10621/c"},"text":"“The amendments made by this section [enacting this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
