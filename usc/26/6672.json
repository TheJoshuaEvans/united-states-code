{"tag":"section","attrib":{"id":"id47287ddd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672"},"text":null,"children":[{"tag":"num","attrib":{"value":"6672"},"text":"§ 6672.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to collect and pay over tax, or attempt to evade or defeat tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47287dde-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person required to collect, truthfully account for, and pay over any tax imposed by this title who willfully fails to collect such tax, or truthfully account for and pay over such tax, or willfully attempts in any manner to evade or defeat any such tax or the payment thereof, shall, in addition to other penalties provided by law, be liable to a penalty equal to the total amount of the tax evaded, or not collected, or not accounted for and paid over. No penalty shall be imposed under section 6653 or part II of subchapter A of chapter 68 for any offense to which this section is applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47287ddf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preliminary notice requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47287de0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed under subsection (a) unless the Secretary notifies the taxpayer in writing by mail to an address as determined under section 6212(b) or in person that the taxpayer shall be subject to an assessment of such penalty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47287de1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The mailing of the notice described in paragraph (1) (or, in the case of such a notice delivered in person, such delivery) shall precede any notice and demand of any penalty under subsection (a) by at least 60 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47287de2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a notice described in paragraph (1) with respect to any penalty is mailed or delivered in person before the expiration of the period provided by section 6501 for the assessment of such penalty (determined without regard to this paragraph), the period provided by such section for the assessment of such penalty shall not expire before the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47287de3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date 90 days after the date on which such notice was mailed or delivered in person, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47287de4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there is a timely protest of the proposed assessment, the date 30 days after the Secretary makes a final administrative determination with respect to such protest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47287de5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for jeopardy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not apply if the Secretary finds that the collection of the penalty is in jeopardy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47287de6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of period of collection where bond is filed","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47287de7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, within 30 days after the day on which notice and demand of any penalty under subsection (a) is made against any person, such person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47287de8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pays an amount which is not less than the minimum amount required to commence a proceeding in court with respect to his liability for such penalty,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47287de9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files a claim for refund of the amount so paid, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47287dea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnishes a bond which meets the requirements of paragraph (3),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"no levy or proceeding in court for the collection of the remainder of such penalty shall be made, begun, or prosecuted until a final resolution of a proceeding begun as provided in paragraph (2). Notwithstanding the provisions of section 7421(a), the beginning of such proceeding or levy during the time such prohibition is in force may be enjoined by a proceeding in the proper court. Nothing in this paragraph shall be construed to prohibit any counterclaim for the remainder of such penalty in a proceeding begun as provided in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47287deb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suit must be brought to determine liability for penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, within 30 days after the day on which his claim for refund with respect to any penalty under subsection (a) is denied, the person described in paragraph (1) fails to begin a proceeding in the appropriate United States district court (or in the Court of Federal Claims) for the determination of his liability for such penalty, paragraph (1) shall cease to apply with respect to such penalty, effective on the day following the close of the 30-day period referred to in this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47287dec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bond","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The bond referred to in paragraph (1) shall be in such form and with such sureties as the Secretary may by regulations prescribe and shall be in an amount equal to 1½ times the amount of excess of the penalty assessed over the payment described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47287ded-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of running of period of limitations on collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The running of the period of limitations provided in section 6502 on the collection by levy or by a proceeding in court in respect of any penalty described in paragraph (1) shall be suspended for the period during which the Secretary is prohibited from collecting by levy or a proceeding in court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47287dee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jeopardy collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary makes a finding that the collection of the penalty is in jeopardy, nothing in this subsection shall prevent the immediate collection of such penalty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47287def-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of contribution where more than 1 person liable for penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If more than 1 person is liable for the penalty under subsection (a) with respect to any tax, each person who paid such penalty shall be entitled to recover from other persons who are liable for such penalty an amount equal to the excess of the amount paid by such person over such person’s proportionate share of the penalty. Any claim for such a recovery may be made only in a proceeding which is separate from, and is not joined or consolidated with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47287df0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an action for collection of such penalty brought by the United States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47287df1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proceeding in which the United States files a counterclaim or third-party complaint for the collection of such penalty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47287df2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for voluntary board members of tax-exempt organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No penalty shall be imposed by subsection (a) on any unpaid, volunteer member of any board of trustees or directors of an organization exempt from tax under subtitle A if such member—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47287df3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is solely serving in an honorary capacity,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47287df4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not participate in the day-to-day or financial operations of the organization, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47287df5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6672/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not have actual knowledge of the failure on which such penalty is imposed.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The preceding sentence shall not apply if it results in no person being liable for the penalty imposed by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47287df6-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/828"},"text":"68A Stat. 828","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/628/s9/a"},"text":"Pub. L. 95–628, § 9(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3633"},"text":"92 Stat. 3633","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII"},"text":"Pub. L. 101–239, title VII","children":[],"tail":", §§ 7721(c)(9), 7737(a), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2400"},"text":"103 Stat. 2400","children":[],"tail":", 2404; "},{"tag":"ref","attrib":{"href":"/us/pl/104/168/tIX"},"text":"Pub. L. 104–168, title IX","children":[],"tail":", §§ 901(a), 903(a), 904(a), "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1465-1467"},"text":"110 Stat. 1465–1467","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3307/a"},"text":"Pub. L. 105–206, title III, § 3307(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/744"},"text":"112 Stat. 744","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/325/D"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(325)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1200"},"text":"132 Stat. 1200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47287df7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47287df8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47287df9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “Court of Federal Claims” for “Court of Claims”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3307/a"},"text":"Pub. L. 105–206, § 3307(a)","children":[],"tail":", inserted “or in person” after “section 6212(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3307/b/1"},"text":"Pub. L. 105–206, § 3307(b)(1)","children":[],"tail":", inserted “(or, in the case of such a notice delivered in person, such delivery)” after “paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3307/b/2"},"text":"Pub. L. 105–206, § 3307(b)(2)","children":[],"tail":", inserted “or delivered in person” after “mailed” in introductory provisions and in subpar. (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/s901/a"},"text":"Pub. L. 104–168, § 901(a)","children":[],"tail":", added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/s903/a"},"text":"Pub. L. 104–168, § 903(a)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/s904/a"},"text":"Pub. L. 104–168, § 904(a)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7721/c/9"},"text":"Pub. L. 101–239, § 7721(c)(9)","children":[],"tail":", inserted “or part II of subchapter A of chapter 68” after “under section 6653”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7737/a"},"text":"Pub. L. 101–239, § 7737(a)","children":[],"tail":", inserted at end “Nothing in this paragraph shall be construed to prohibit any counterclaim for the remainder of such penalty in a proceeding begun as provided in paragraph (2).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/628"},"text":"Pub. L. 95–628","children":[],"tail":" designated existing provisions as subsec. (a), added subsec. (a) heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47287dfa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47287dfb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3307/c"},"text":"Pub. L. 105–206, title III, § 3307(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/744"},"text":"112 Stat. 744","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/206/tIII/s3307/c"},"text":"“The amendments made by this section [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47287dfc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/tIX/s901/b"},"text":"Pub. L. 104–168, title IX, § 901(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1466"},"text":"110 Stat. 1466","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/168/tIX/s901/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to proposed assessments made after ","children":[{"tag":"date","attrib":{"date":"1996-06-30"},"text":"June 30, 1996","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/tIX/s903/b"},"text":"Pub. L. 104–168, title IX, § 903(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1466"},"text":"110 Stat. 1466","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/168/tIX/s903/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to penalties assessed after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47287dfd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7721/c/9"},"text":"section 7721(c)(9) of Pub. L. 101–239","children":[],"tail":" applicable to returns the due date for which (determined without regard to extensions) is after "},{"tag":"date","attrib":{"date":"1989-12-31"},"text":"Dec. 31, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7721/d"},"text":"section 7721(d) of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s461"},"text":"section 461 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7737/b"},"text":"Pub. L. 101–239, title VII, § 7737(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2404"},"text":"103 Stat. 2404","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tVII/s7737/b"},"text":"“The amendment made by subsection (a) [amending this section and sections 6694 and 6703 of this title] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47287dfe-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/628/s9/c"},"text":"Pub. L. 95–628, § 9(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3633"},"text":"92 Stat. 3633","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/628/s9/c"},"text":"“The amendments made by this section [amending this section and sections 7103 and 7421 of this title] shall apply with respect to penalties assessed more than 60 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id47287dff-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Public Information To Ensure Employee Awareness of Responsibilities and Liabilities Under Tax Depository System","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/tIX/s904/b"},"text":"Pub. L. 104–168, title IX, § 904(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1467"},"text":"110 Stat. 1467","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/168/tIX/s904/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury or the Secretary’s delegate (hereafter in this subsection referred to as the ‘Secretary’) shall take such actions as may be appropriate to ensure that employees are aware of their responsibilities under the Federal tax depository system, the circumstances under which employees may be liable for the penalty imposed by section 6672 of the Internal Revenue Code of 1986, and the responsibility to promptly report to the Internal Revenue Service any failure referred to in subsection (a) of such section 6672. Such actions shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" printing of a warning on deposit coupon booklets and the appropriate tax returns that certain employees may be liable for the penalty imposed by such section 6672, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of a special information packet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development of explanatory materials","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall develop materials explaining the circumstances under which board members of tax-exempt organizations (including voluntary and honorary members) may be subject to penalty under section 6672 of such Code. Such materials shall be made available to tax-exempt organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"IRS instructions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall clarify the instructions to Internal Revenue Service employees on the application of the penalty under section 6672 of such Code with regard to voluntary members of boards of trustees or directors of tax-exempt organizations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
