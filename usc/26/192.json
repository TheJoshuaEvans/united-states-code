{"tag":"section","attrib":{"id":"id4219c8db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192"},"text":null,"children":[{"tag":"num","attrib":{"value":"192"},"text":"§ 192.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions to black lung benefit trust","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4219c8dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of deduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is allowed as a deduction for the taxable year an amount equal to the sum of the amounts contributed by the taxpayer during the taxable year to or under a trust or trusts described in section 501(c)(21).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4219c8dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The maximum amount of the deduction allowed by subsection (a) for any taxpayer for any taxable year shall not exceed the greater of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4219c8de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount necessary to fund (with level funding) the remaining unfunded liability of the taxpayer for black lung claims filed (or expected to be filed) by (or with respect to) past or present employees of the taxpayer, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4219c8df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount necessary to increase each trust described in section 501(c)(21) to the amount required to pay all amounts payable out of such trust for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4219c8e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4219c8e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of determining amounts referred to in subsection (b)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4219c8e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts described in subsection (b) shall be determined by using reasonable actuarial methods and assumptions which are not inconsistent with regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4219c8e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (C), the funding period for purposes of subsection (b)(1) shall be the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4219c8e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average remaining working life of miners who are present employees of the taxpayer, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4219c8e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 taxable years.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of the preceding sentence, the term “miner” has the same meaning as such term has when used in section 402(d) of the Black Lung Benefits Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s902/d"},"text":"30 U.S.C. 902(d)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4219c8e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Different funding periods","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4219c8e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations prescribed by the Secretary provide for a different period, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4219c8e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary consents to a different period proposed by the taxpayer,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such different period shall be substituted for the funding period provided in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4219c8e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefit payments taken into account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the amounts described in subsection (b), only those black lung benefit claims the payment of which is expected to be made from the trust shall be taken into account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4219c8ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time when contributions deemed made","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, a taxpayer shall be deemed to have made a payment of a contribution on the last day of a taxable year if the payment is on account of that taxable year and is made not later than the time prescribed by law for filing the return for that taxable year (including extensions thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4219c8eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions to be in cash or certain other items","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowed under subsection (a) with respect to any contribution to a trust described in section 501(c)(21) other than a contribution in cash or in items in which such trust may invest under subclause (II) of section 501(c)(21)(A)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4219c8ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of section 162 deduction with respect to liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowed under section 162(a) with respect to any liability taken into account in determining the deduction under subsection (a) of this section of the taxpayer (or a predecessor).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4219c8ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryover of excess contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount of the deduction determined under subsection (a) for the taxable year (without regard to the limitation imposed by subsection (b)) with respect to a trust exceeds the limitation imposed by subsection (b) for the taxable year, the excess shall be carried over to the succeeding taxable year and treated as contributed to the trust during that year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4219c8ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s192/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of black lung benefit claim","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “black lung benefit claim” means a claim for compensation for disability or death due to pneumoconiosis under part C of title IV of the Federal Mine Safety and Health Act of 1977 or under any State law providing for such compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4219c8ef-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/227/s4/b/1"},"text":"Pub. L. 95–227, § 4(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-02-10"},"text":"Feb. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/16"},"text":"92 Stat. 16","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/488/s1/a"},"text":"Pub. L. 95–488, § 1(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1978-10-20"},"text":"Oct. 20, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1637"},"text":"92 Stat. 1637","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/222/tI/s108/b/2/B"},"text":"Pub. L. 96–222, title I, § 108(b)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-01"},"text":"Apr. 1, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/226"},"text":"94 Stat. 226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s1940/c"},"text":"Pub. L. 102–486, title XIX, § 1940(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3035"},"text":"106 Stat. 3035","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4219c8f0-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4219c8f1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4219c8f2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Mine Safety and Health Act of 1977, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/173"},"text":"Pub. L. 91–173","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/742"},"text":"83 Stat. 742","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/95/164"},"text":"Pub. L. 95–164","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-09"},"text":"Nov. 9, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1290"},"text":"91 Stat. 1290","children":[],"tail":". Part C of title IV of the Federal Mine Safety and Health Act of 1977 is classified generally to part C of subchapter IV of chapter 22 (§ 931 et seq.) of Title 30, Mineral Lands and Mining. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s801"},"text":"section 801 of Title 30","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4219c8f3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":" substituted “subclause (II) of section 501(c)(21)(A)(ii)” for “clause (ii) of section 501(c)(21)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/222"},"text":"Pub. L. 96–222","children":[],"tail":" substituted “Federal Mine Safety and Health Act of 1977” for “Federal Coal Mine Health and Safety Act of 1969”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/488/s1/a"},"text":"Pub. L. 95–488, § 1(a)","children":[],"tail":", substituted provision limiting the allowable deduction to the greater of the amount necessary to fund the remaining unfunded liability of the taxpayer for the black lung claims filed or expected to be filed by past or present employees of the taxpayer or the aggregate amount necessary to increase each trust described in section 501(c)(21) to the amount required to pay all amounts payable out of such trust for the taxable year for provision limiting the allowable deduction to the amount necessary, when added to the fair market value of trust assets at the beginning of the taxable year, to fund the greater of current year obligations or certain future obligations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/488/s1/b"},"text":"Pub. L. 95–488, § 1(b)","children":[],"tail":", substituted “Method of determining amounts referred to in subsection (b)” for “Determination of expected future payments” in heading and in text inserted provisions establishing the funding period as the greater of the average remaining working life of miners who are present employees of the taxpayer or 10 taxable years and permitting a different funding period if prescribed or consented to by the Secretary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/488/s1/c"},"text":"Pub. L. 95–488, § 1(c)","children":[],"tail":", added par. (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4219c8f4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4219c8f5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s1940/d"},"text":"Pub. L. 102–486, title XIX, § 1940(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3035"},"text":"106 Stat. 3035","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/486/tXIX/s1940/d"},"text":"“The amendments made by this section [amending this section and sections 501 and 4951 of this title] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1991-12-31"},"text":"December 31, 1991","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4219c8f6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/222/tI/s108/b/4"},"text":"Pub. L. 96–222, title I, § 108(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-01"},"text":"Apr. 1, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/226"},"text":"94 Stat. 226","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/222/tI/s108/b/4"},"text":"“Any amendment made by this subsection [amending this section, sections 6503, 6511, 6862, 7422, and 7454 of this title, and sections 934 and 934a of Title 30, Mineral Lands and Mining] shall take effect as if included in the provision of the Black Lung Benefits Revenue Act of 1977 [see Short Title of 1978 Amendments note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"] to which such amendment relates.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4219c8f7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/488/s1/e"},"text":"Pub. L. 95–488, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-20"},"text":"Oct. 20, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1638"},"text":"92 Stat. 1638","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6104"},"text":"section 6104 of this title","children":[],"tail":"] shall apply to taxable years beginning after "},{"tag":"date","attrib":{"date":"1977-12-31"},"text":"December 31, 1977","children":[],"tail":". Nothing in the amendments made by subsection (d) to section 6104 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] shall be construed to permit the disclosure under such section 6104 of confidential business information of contributors to any trust described in section 501(c)(21) of such Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4219c8f8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/227/s4/f"},"text":"Pub. L. 95–227, § 4(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-02-10"},"text":"Feb. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/24"},"text":"92 Stat. 24","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/227/s4/f"},"text":"“The amendments made by this section [enacting this section and sections 4951 to 4953 and amending sections 501, 4946, 6104, 6213, 6405, 6501, 6503, and 7451 of this title] shall apply with respect to contributions, acts, and expenditures made after ","children":[{"tag":"date","attrib":{"date":"1977-12-31"},"text":"December 31, 1977","children":[],"tail":", in and for taxable years beginning after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
