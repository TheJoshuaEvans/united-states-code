{"tag":"section","attrib":{"id":"id46d50612-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343"},"text":null,"children":[{"tag":"num","attrib":{"value":"6343"},"text":"§ 6343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to release levy and return property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46d50613-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release of levy and notice of release","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46d50614-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Secretary, the Secretary shall release the levy upon all, or part of, the property or rights to property levied upon and shall promptly notify the person upon whom such levy was made (if any) that such levy has been released if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46d50615-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the liability for which such levy was made is satisfied or becomes unenforceable by reason of lapse of time,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46d50616-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" release of such levy will facilitate the collection of such liability,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46d50617-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer has entered into an agreement under section 6159 to satisfy such liability by means of installment payments, unless such agreement provides otherwise,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46d50618-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has determined that such levy is creating an economic hardship due to the financial condition of the taxpayer, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46d50619-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of the property exceeds such liability and release of the levy on a part of such property could be made without hindering the collection of such liability.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of subparagraph (C), the Secretary is not required to release such levy if such release would jeopardize the secured creditor status of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d5061a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited determination on certain business property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any tangible personal property essential in carrying on the trade or business of the taxpayer, the Secretary shall provide for an expedited determination under paragraph (1) if levy on such tangible personal property would prevent the taxpayer from carrying on such trade or business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d5061b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent levy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The release of levy on any property under paragraph (1) shall not prevent any subsequent levy on such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46d5061c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines that property has been wrongfully levied upon, it shall be lawful for the Secretary to return—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46d5061d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific property levied upon,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d5061e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount of money equal to the amount of money levied upon, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d5061f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount of money equal to the amount of money received by the United States from a sale of such property.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Property may be returned at any time. An amount equal to the amount of money levied upon or received from such sale may be returned at any time before the expiration of 2 years from the date of such levy. For purposes of paragraph (3), if property is declared purchased by the United States at a sale pursuant to section 6335(e) (relating to manner and conditions of sale), the United States shall be treated as having received an amount of money equal to the minimum price determined pursuant to such section or (if larger) the amount received by the United States from the resale of such property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46d50620-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Interest shall be allowed and paid at the overpayment rate established under section 6621—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46d50621-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a case described in subsection (b)(2), from the date the Secretary receives the money to a date (to be determined by the Secretary) preceding the date of return by not more than 30 days, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d50622-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a case described in subsection (b)(3), from the date of the sale of the property to a date (to be determined by the Secretary) preceding the date of return by not more than 30 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46d50623-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of property in certain cases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46d50624-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property has been levied upon, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d50625-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46d50626-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the levy on such property was premature or otherwise not in accordance with administrative procedures of the Secretary,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46d50627-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer has entered into an agreement under section 6159 to satisfy the tax liability for which the levy was imposed by means of installment payments, unless such agreement provides otherwise,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46d50628-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the return of such property will facilitate the collection of the tax liability, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46d50629-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the consent of the taxpayer or the National Taxpayer Advocate, the return of such property would be in the best interests of the taxpayer (as determined by the National Taxpayer Advocate) and the United States,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the provisions of subsection (b) shall apply in the same manner as if such property had been wrongly levied upon, except that no interest shall be allowed under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46d5062a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release of levy upon agreement that amount is not collectible","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a levy on the salary or wages payable to or received by the taxpayer, upon agreement with the taxpayer that the tax is not collectible, the Secretary shall release such levy as soon as practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46d5062b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals held harmless on wrongful levy, etc.","children":[{"tag":"ref","attrib":{"idref":"fn002306"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002306"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" on retirement plan"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id46d5062c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines that an individual’s account or benefit under an eligible retirement plan (as defined in section 402(c)(8)(B)) has been levied upon in a case to which subsection (b) or (d)(2)(A) applies and property or an amount of money is returned to the individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46d5062d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the individual may contribute such property or an amount equal to the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46d5062e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of money so returned by the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46d5062f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest paid under subsection (c) on such amount of money,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"into such eligible retirement plan if such contribution is permitted by the plan, or into an individual retirement plan (other than an endowment contract) to which a rollover contribution of a distribution from such eligible retirement plan is permitted, but only if such contribution is made not later than the due date (not including extensions) for filing the return of tax for the taxable year in which such property or amount of money is returned, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46d50630-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall, at the time such property or amount of money is returned, notify such individual that a contribution described in subparagraph (A) may be made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d50631-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as rollover","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The distribution on account of the levy and any contribution under paragraph (1) with respect to the return of such distribution shall be treated for purposes of this title as if such distribution and contribution were described in section 402(c), 402A(c)(3), 403(a)(4), 403(b)(8), 408(d)(3), 408A(d)(3), or 457(e)(16), whichever is applicable; except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46d50632-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contribution shall be treated as having been made for the taxable year in which the distribution on account of the levy occurred, and the interest paid under subsection (c) shall be treated as earnings within the plan after the contribution and shall not be included in gross income, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46d50633-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such contribution shall not be taken into account under section 408(d)(3)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d50634-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund, etc., of income tax on levy","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46d50635-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any amount is includible in gross income for a taxable year by reason of a distribution on account of a levy referred to in paragraph (1) and any portion of such amount is treated as a rollover contribution under paragraph (2), any tax imposed by chapter 1 on such portion shall not be assessed, and if assessed shall be abated, and if collected shall be credited or refunded as an overpayment made on the due date for filing the return of tax for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46d50636-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply to a rollover contribution under this subsection which is made from an eligible retirement plan which is not a Roth IRA or a designated Roth account (within the meaning of section 402A) to a Roth IRA or a designated Roth account under an eligible retirement plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d50637-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (d), interest shall be allowed under subsection (c) in a case in which the Secretary makes a determination described in subsection (d)(2)(A) with respect to a levy upon an individual retirement plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d50638-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6343/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of inherited accounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1)(A), section 408(d)(3)(C) shall be disregarded in determining whether an individual retirement plan is a plan to which a rollover contribution of a distribution from the plan levied upon is permitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46d50639-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/789"},"text":"68A Stat. 789","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/719/tI/s104/i"},"text":"Pub. L. 89–719, title I, § 104(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1138"},"text":"80 Stat. 1138","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/167/s4/a"},"text":"Pub. L. 96–167, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-29"},"text":"Dec. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1275"},"text":"93 Stat. 1275","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1511/c/10"},"text":"Pub. L. 99–514, title XV, § 1511(c)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2745"},"text":"100 Stat. 2745","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6236/f"},"text":"Pub. L. 100–647, title VI, § 6236(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3740"},"text":"102 Stat. 3740","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/168/tV/s501/b"},"text":"Pub. L. 104–168, title V, § 501(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1460"},"text":"110 Stat. 1460","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tI/s1102/d/1/B"},"text":"Pub. L. 105–206, title I, § 1102(d)(1)(B)","children":[],"tail":", title III, § 3432(a), "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/704"},"text":"112 Stat. 704","children":[],"tail":", 759; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s11071/a"},"text":"Pub. L. 115–97, title I, § 11071(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2091"},"text":"131 Stat. 2091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dD/tII/s41104/a"},"text":"Pub. L. 115–123, div. D, title II, § 41104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02