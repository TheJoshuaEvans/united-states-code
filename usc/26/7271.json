{"tag":"section","attrib":{"id":"id47477872-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7271"},"text":null,"children":[{"tag":"num","attrib":{"value":"7271"},"text":"§ 7271.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for offenses relating to stamps","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any person who with respect to any tax payable by stamps—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47477873-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7271/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to attach or cancel stamps, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fails to comply with rules or regulations prescribed pursuant to section 6804 (relating to attachment, cancellation, etc., of stamps), unless such failure is shown to be due to reasonable cause and not willful neglect; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47477874-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7271/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Instruments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Makes, signs, issues, or accepts, or causes to be made, signed, issued, or accepted, any instrument, document, or paper of any kind or description whatsoever without the full amount of tax thereon being duly paid; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47477875-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7271/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal and receipt of stamped packages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any container which is stamped, branded, or marked (whether or not under authority of law) in such manner as to show that the provisions of the internal revenue laws with respect to the contents or intended contents thereof have been complied with, and which is empty or contains any contents other than contents therein when the container was lawfully stamped, branded, or marked—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47477876-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7271/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transfers or receives (whether by sale, gift, or otherwise) such container knowing it to be empty or to contain such other contents; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47477877-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7271/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Stamps, brands, or marks such container, or otherwise produces such a stamped, branded, or marked container, knowing it to be empty or to contain such other contents;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be liable for each such offense to a penalty of $50.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47477878-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/865"},"text":"68A Stat. 865","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/a/41"},"text":"Pub. L. 94–455, title XIX, § 1906(a)(41)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1830"},"text":"90 Stat. 1830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47477879-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4747787a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4747787b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Pars. (2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" redesignated pars. (3) and (4) as (2) and (3), respectively. Former par. (2), which related to persons who manufactured or imported and sold, or offered for sale, or caused to be manufactured or imported and sold, or offered for sale, any playing card, package, or other article without the full amount of tax being paid, was struck out."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4747787c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4747787d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" effective on first day of first month which begins more than 90 days after "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/d/1"},"text":"section 1906(d)(1) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6013"},"text":"section 6013 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
