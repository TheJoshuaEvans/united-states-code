{"tag":"section","attrib":{"id":"id4726336f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A"},"text":null,"children":[{"tag":"num","attrib":{"value":"6662A"},"text":"§ 6662A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of accuracy-related penalty on understatements with respect to reportable transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47263370-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a taxpayer has a reportable transaction understatement for any taxable year, there shall be added to the tax an amount equal to 20 percent of the amount of such understatement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47263371-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reportable transaction understatement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47263372-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “reportable transaction understatement” means the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47263373-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the product of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47263374-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the increase (if any) in taxable income which results from a difference between the proper tax treatment of an item to which this section applies and the taxpayer’s treatment of such item (as shown on the taxpayer’s return of tax), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47263375-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the highest rate of tax imposed by section 1 (section 11 in the case of a taxpayer which is a corporation), and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47263376-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the decrease (if any) in the aggregate amount of credits determined under subtitle A which results from a difference between the taxpayer’s treatment of an item to which this section applies (as shown on the taxpayer’s return of tax) and the proper tax treatment of such item.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of subparagraph (A), any reduction of the excess of deductions allowed for the taxable year over gross income for such year, and any reduction in the amount of capital losses which would (without regard to section 1211) be allowed for such year, shall be treated as an increase in taxable income.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47263377-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Items to which section applies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall apply to any item which is attributable to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47263378-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any listed transaction, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47263379-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reportable transaction (other than a listed transaction) if a significant purpose of such transaction is the avoidance or evasion of Federal income tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4726337a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Higher penalty for nondisclosed listed and other avoidance transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall be applied by substituting “30 percent” for “20 percent” with respect to the portion of any reportable transaction understatement with respect to which the requirement of section 6664(d)(3)(A) is not met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4726337b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions of reportable and listed transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the terms “reportable transaction” and “listed transaction” have the respective meanings given to such terms by section 6707A(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4726337c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4726337d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with penalties, etc., on other understatements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an understatement (as defined in section 6662(d)(2))—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4726337e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such understatement (determined without regard to this paragraph) shall be increased by the aggregate amount of reportable transaction understatements for purposes of determining whether such understatement is a substantial understatement under section 6662(d)(1), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4726337f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the addition to tax under section 6662(a) shall apply only to the excess of the amount of the substantial understatement (if any) after the application of subparagraph (A) over the aggregate amount of reportable transaction understatements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47263380-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other penalties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47263381-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with fraud penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to any portion of an understatement on which a penalty is imposed under section 6663.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47263382-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with certain increased underpayment penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to any portion of an understatement on which a penalty is imposed under section 6662 if the rate of the penalty is determined under subsections (h) or (i) of section 6662.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47263383-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6662A/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for amended returns","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in regulations, in no event shall any tax treatment included with an amendment or supplement to a return of tax be taken into account in determining the amount of any reportable transaction understatement if the amendment or supplement is filed after the earlier of the date the taxpayer is first contacted by the Secretary regarding the examination of the return or such other date as is specified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47263384-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s812/a"},"text":"Pub. L. 108–357, title VIII, § 812(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1577"},"text":"118 Stat. 1577","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s403/x/2"},"text":"Pub. L. 109–135, title IV, § 403(x)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2629"},"text":"119 Stat. 2629","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/152/tI/s1409/b/3"},"text":"Pub. L. 111–152, title I, § 1409(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-30"},"text":"Mar. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1069"},"text":"124 Stat. 1069","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s220/w"},"text":"Pub. L. 113–295, div. A, title II, § 220(w)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4036"},"text":"128 Stat. 4036","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47263385-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47263386-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id47263387-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s1409/b/3"},"text":"Section 1409(b)(3) of Pub. L. 111–152","children":[],"tail":", which directed the amendment of section 6662A without specifying the act to be amended, was executed to this section, which is section 6662A of the Internal Revenue Code of 1986, to reflect the probable intent of Congress. See 2010 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47263388-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" substituted “section 6664(d)(3)(A)” for “section 6664(d)(2)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (e)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152"},"text":"Pub. L. 111–152","children":[],"tail":" substituted “certain increased underpayment penalties” for “gross valuation misstatement penalty” in heading and “subsections (h) or (i) of section 6662” for “section 6662(h)” in text. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) ","children":[{"tag":"inline","attrib":{},"text":"Application of fraud penalty","children":[],"tail":".—References to an underpayment in section 6663 shall be treated as including references to a reportable transaction understatement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) ","children":[{"tag":"inline","attrib":{},"text":"No double penalty","children":[],"tail":".—This section shall not apply to any portion of an understatement on which a penalty is imposed under section 6663."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) ","children":[{"tag":"inline","attrib":{},"text":"Coordination with valuation penalties","children":[],"tail":".—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) ","children":[{"tag":"inline","attrib":{},"text":"Section 6662","children":[],"tail":"(e).—Section 6662(e) shall not apply to any portion of an understatement on which a penalty is imposed under this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) ","children":[{"tag":"inline","attrib":{},"text":"Section 6662","children":[],"tail":"(h).—This section shall not apply to any portion of an understatement on which a penalty is imposed under section 6662(h).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47263389-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4726338a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152"},"text":"Pub. L. 111–152","children":[],"tail":" applicable to underpayments attributable to transactions entered into after "},{"tag":"date","attrib":{"date":"2010-03-30"},"text":"Mar. 30, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/152/s1409/e/2"},"text":"section 1409(e)(2) of Pub. L. 111–152","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6662"},"text":"section 6662 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4726338b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" effective as if included in the provision of the American Jobs Creation Act of 2004, "},{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/nn"},"text":"section 403(nn) of Pub. L. 109–135","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s26"},"text":"section 26 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4726338c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years ending after ","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s812/f"},"text":"section 812(f) of Pub. L. 108–357","children":[],"tail":", set out as an Effective Date of 2004 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6662"},"text":"section 6662 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4726338d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Tax Shelter Penalties and Certain Other Enforcement Actions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/240/tII/s2103"},"text":"Pub. L. 111–240, title II, § 2103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2564"},"text":"124 Stat. 2564","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/240/tII/s2103"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner of Internal Revenue, in consultation with the Secretary of the Treasury, shall submit to the Committee on Ways and Means of the House of Representatives and the Committee on Finance of the Senate an annual report on the penalties assessed by the Internal Revenue Service during the preceding year under each of the following provisions of the Internal Revenue Code of 1986:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 6662A (relating to accuracy-related penalty on understatements with respect to reportable transactions).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 6700(a) (relating to promoting abusive tax shelters).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 6707 (relating to failure to furnish information regarding reportable transactions).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 6707A (relating to failure to include reportable transaction information with return).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 6708 (relating to failure to maintain lists of advisees with respect to reportable transactions).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under subsection (a) shall also include information on the following with respect to each year:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any action taken under section 330(b) [now 330(c)] of title 31, United States Code, with respect to any reportable transaction (as defined in section 6707A(c) of the Internal Revenue Code of 1986).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any extension of the time for assessment of tax enforced, or assessment of any amount under such an extension, under paragraph (10) of section 6501(c) of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Date of Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The first report required under subsection (a) shall be submitted not later than ","children":[{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
