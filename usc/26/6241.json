{"tag":"section","attrib":{"id":"id46c1f419-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241"},"text":null,"children":[{"tag":"num","attrib":{"value":"6241"},"text":"§ 6241.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46c1f41a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “partnership” means any partnership required to file a return under section 6031(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f41b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership adjustment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46c1f41c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “partnership adjustment” means any adjustment to a partnership-related item.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c1f41d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership-related item","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “partnership-related item” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46c1f41e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any item or amount with respect to the partnership (without regard to whether or not such item or amount appears on the partnership’s return and including an imputed underpayment and any item or amount relating to any transaction with, basis in, or liability of, the partnership) which is relevant (determined without regard to this subchapter) in determining the tax liability of any person under chapter 1, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46c1f41f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any partner’s distributive share of any item or amount described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f420-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return due date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “return due date” means, with respect to the taxable year, the date prescribed for filing the partnership return for such taxable year (determined without regard to extensions).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f421-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments nondeductible","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowed under subtitle A for any payment required to be made by a partnership under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f422-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships having principal place of business outside United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 6234, a principal place of business located outside the United States shall be treated as located in the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f423-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships in cases under title 11 of United States Code","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46c1f424-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of period of limitations on making adjustment, assessment, or collection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The running of any period of limitations provided in this subchapter on making a partnership adjustment (or provided by section 6501 or 6502 on the assessment or collection of any imputed underpayment determined under this subchapter) shall, in a case under title 11 of the United States Code, be suspended during the period during which the Secretary is prohibited by reason of such case from making the adjustment (or assessment or collection) and—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46c1f425-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for adjustment or assessment, 60 days thereafter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46c1f426-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for collection, 6 months thereafter.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A rule similar to the rule of section 6213(f)(2) shall apply for purposes of section 6232(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c1f427-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of period of limitation for filing for judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The running of the period specified in section 6234 shall, in a case under title 11 of the United States Code, be suspended during the period during which the partnership is prohibited by reason of such case from filing a petition under section 6234 and for 60 days thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f428-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment where partnership ceases to exist","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a partnership ceases to exist before a partnership adjustment under this subchapter takes effect, such adjustment shall be taken into account by the former partners of such partnership under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f429-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension to entities filing partnership return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a partnership return is filed by an entity for a taxable year but it is determined that the entity is not a partnership (or that there is no entity) for such year, then, to the extent provided in regulations, the provisions of this subchapter are hereby extended in respect of such year to such entity and its items and to persons holding an interest in such entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f42a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other chapters","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46c1f42b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subchapter shall not apply with respect to any tax imposed (including any amount required to be deducted or withheld) under chapter 2, 2A, 3, or 4, except that any partnership adjustment determined under this subchapter for purposes of chapter 1 shall be taken into account for purposes of determining any such tax to the extent that such adjustment is relevant to such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c1f42c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of withholding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any tax imposed (including any amount required to be deducted or withheld) under chapter 3 or 4, which is determined with respect to an adjustment described in subparagraph (A), such tax—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46c1f42d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be so determined with respect to the reviewed year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46c1f42e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be so imposed (or so required to be deducted or withheld) with respect to the adjustment year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c1f42f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitation on assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For special rule with respect to limitation on assessment of taxes under chapter 2 or 2A which are attributable to any partnership adjustment, see section 6501(c)(12).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f430-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to require electronic filing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 6011(e), the Secretary may require that anything required to be filed or submitted under section 6225(c), or to be furnished to or filed with the Secretary under section 6226, be so filed, submitted, or furnished by magnetic media or in other machine-readable form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f431-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of special enforcement matters","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46c1f432-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of partnership-related items which involve special enforcement matters, the Secretary may prescribe regulations pursuant to which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46c1f433-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/11/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this subchapter (or any portion thereof) does not apply to such items, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46c1f434-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/11/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such items are subject to such special rules (including rules related to assessment and collection) as the Secretary determines to be necessary for the effective and efficient enforcement of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c1f435-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special enforcement matters","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the term “special enforcement matters” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46c1f436-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/11/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failure to comply with the requirements of section 6226(b)(4)(A)(ii),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46c1f437-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/11/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessments under section 6851 (relating to termination assessments of income tax) or section 6861 (relating to jeopardy assessments of income, estate, gift, and certain excise taxes),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46c1f438-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/11/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criminal investigations,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46c1f439-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/11/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indirect methods of proof of income,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46c1f43a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/11/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign partners or partnerships, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46c1f43b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/11/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other matters that the Secretary determines by regulation present special enforcement considerations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c1f43c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States shareholders and certain other persons treated as partners","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46c1f43d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided by the Secretary, in the case of any controlled foreign corporation (as defined in section 957 or 953(c)(1)) which is a partner of a partnership, each United States shareholder (as defined in section 951(b) or 953(c)(1)) with respect to such controlled foreign corporation shall be treated for purposes of this subchapter as a partner of such partnership. For purposes of the preceding sentence, any distributive share of any such United States shareholder with respect to such partnership shall, except as otherwise provided by the Secretary, be equal to such United States shareholder’s pro rata share with respect to such controlled foreign corporation (determined under rules similar to the rules of section 951(a)(2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c1f43e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Passive foreign investment companies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), in the case of a passive foreign investment company (as defined in section 1297), each taxpayer that makes an election under section 1295 with respect to such company shall be treated in the same manner as United States shareholders under subparagraph (A), except that such taxpayer’s pro rata share with respect to the passive foreign investment company shall be determined under rules similar to the rules of section 1293(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c1f43f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6241/12/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations or other guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue such regulations or other guidance as is necessary or appropriate to carry out the purposes of this paragraph, including regulations which apply the rules of subparagraph (A) in similar circumstances or with respect to similarly situated persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46c1f440-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/74/tXI/s1101/c/1"},"text":"Pub. L. 114–74, title XI, § 1101(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/636"},"text":"129 Stat. 636","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tII"},"text":"Pub. L. 115–141, div. U, title II","children":[],"tail":", §§ 201(a), (b)(1), 206(c), ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), (m), (p)(7), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1171"},"text":"132 Stat. 1171","children":[],"tail":", 1172, 1178, 1180–1182.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46c1f441-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46c1f442-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46c1f443-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6241, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXII/s1222/a"},"text":"Pub. L. 105–34, title XII, § 1222(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/100"},"text":"111 Stat. 100","children":[],"tail":", related to consistency of a partner’s return with the partnership return, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/74/tXI/s1101/b/2"},"text":"Pub. L. 114–74, title XI, § 1101(b)(2)","children":[],"tail":", (g), "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/625"},"text":"129 Stat. 625","children":[],"tail":", applicable to returns filed for partnership taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 6241, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/354/s4/a"},"text":"Pub. L. 97–354, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"Oct. 19, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1691"},"text":"96 Stat. 1691","children":[],"tail":", directed that tax treatment be determined at the corporate level, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/1