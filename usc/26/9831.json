{"tag":"section","attrib":{"id":"id47d909b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831"},"text":null,"children":[{"tag":"num","attrib":{"value":"9831"},"text":"§ 9831.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General exceptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47d909b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of this chapter shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47d909b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any governmental plan, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d909b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other than with respect to section 9826, any group health plan for any plan year if, on the first day of such plan year, such plan has less than 2 participants who are current employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47d909ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this chapter shall not apply to any group health plan in relation to its provision of excepted benefits described in section 9832(c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47d909bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain benefits if certain conditions met","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47d909bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited, excepted benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of this chapter shall not apply to any group health plan in relation to its provision of excepted benefits described in section 9832(c)(2) if the benefits—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47d909bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are provided under a separate policy, certificate, or contract of insurance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d909be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are otherwise not an integral part of the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d909bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncoordinated, excepted benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of this chapter shall not apply to any group health plan in relation to its provision of excepted benefits described in section 9832(c)(3) if all of the following conditions are met:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47d909c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The benefits are provided under a separate policy, certificate, or contract of insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d909c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is no coordination between the provision of such benefits and any exclusion of benefits under any group health plan maintained by the same plan sponsor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d909c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such benefits are paid with respect to an event without regard to whether benefits are provided with respect to such an event under any group health plan maintained by the same plan sponsor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d909c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental excepted benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this chapter shall not apply to any group health plan in relation to its provision of excepted benefits described in section 9832(c)(4) if the benefits are provided under a separate policy, certificate, or contract of insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47d909c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for qualified small employer health reimbursement arrangements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47d909c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this title (and notwithstanding any other provision of this title), the term “group health plan” shall not include any qualified small employer health reimbursement arrangement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d909c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified small employer health reimbursement arrangement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47d909c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified small employer health reimbursement arrangement” means an arrangement which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47d909c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is described in subparagraph (B), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47d909c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is provided on the same terms to all eligible employees of the eligible employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d909ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arrangement described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An arrangement is described in this subparagraph if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47d909cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such arrangement is funded solely by an eligible employer and no salary reduction contributions may be made under such arrangement,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47d909cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such arrangement provides, after the employee provides proof of coverage, for the payment of, or reimbursement of, an eligible employee for expenses for medical care (as defined in section 213(d)) incurred by the eligible employee or the eligible employee’s family members (as determined under the terms of the arrangement), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47d909cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of payments and reimbursements described in clause (ii) for any year do not exceed $4,950 ($10,000 in the case of an arrangement that also provides for payments or reimbursements for family members of the employee).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d909ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain variation permitted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A)(ii), an arrangement shall not fail to be treated as provided on the same terms to each eligible employee merely because the employee’s permitted benefit under such arrangement varies in accordance with the variation in the price of an insurance policy in the relevant individual health insurance market based on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47d909cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the age of the eligible employee (and, in the case of an arrangement which covers medical expenses of the eligible employee’s family members, the age of such family members), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47d909d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of family members of the eligible employee the medical expenses of which are covered under such arrangement.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The variation permitted under the preceding sentence shall be determined by reference to the same insurance policy with respect to all eligible employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d909d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules relating to maximum dollar limitation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47d909d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount prorated in certain cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual who is not covered by an arrangement for the entire year, the limitation under subparagraph (B)(iii) for such year shall be an amount which bears the same ratio to the amount which would (but for this clause) be in effect for such individual for such year under subparagraph (B)(iii) as the number of months for which such individual is covered by the arrangement for such year bears to 12.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47d909d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any year beginning after 2016, each of the dollar amounts in subparagraph (B)(iii) shall be increased by an amount equal to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id47d909d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/2/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dollar amount, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id47d909d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/2/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost-of-living adjustment determined under section 1(f)(3) for the calendar year in which the taxable year begins, determined by substituting “calendar year 2015” for “calendar year 2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" If any dollar amount increased under the preceding sentence is not a multiple of $50, such dollar amount shall be rounded to the next lowest multiple of $50.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d909d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47d909d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible employee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible employee” means any employee of an eligible employer, except that the terms of the arrangement may exclude from consideration employees described in any clause of section 105(h)(3)(B) (applied by substituting “90 days” for “3 years” in clause (i) thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d909d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible employer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible employer” means an employer that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47d909d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not an applicable large employer as defined in section 4980H(c)(2), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47d909da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not offer a group health plan to any of its employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d909db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “permitted benefit” means, with respect to any eligible employee, the maximum dollar amount of payments and reimbursements which may be made under the terms of the qualified small employer health reimbursement arrangement for the year with respect to such employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d909dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47d909dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employer funding a qualified small employer health reimbursement arrangement for any year shall, not later than 90 days before the beginning of such year (or, in the case of an employee who is not eligible to participate in the arrangement as of the beginning of such year, the date on which such employee is first so eligible), provide a written notice to each eligible employee which includes the information described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d909de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notice required under subparagraph (A) shall include each of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47d909df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement of the amount which would be such eligible employee’s permitted benefit under the arrangement for the year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47d909e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement that the eligible employee should provide the information described in clause (i) to any health insurance exchange to which the employee applies for advance payment of the premium assistance tax credit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47d909e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9831/d/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement that if the employee is not covered under minimum essential coverage for any month the employee may be subject to tax under section 5000A for such month and reimbursements under the arrangement may be includible in gross income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47d909e2-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/tIV/s401/a"},