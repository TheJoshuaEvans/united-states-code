{"tag":"section","attrib":{"id":"id4688bb93-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6071"},"text":null,"children":[{"tag":"num","attrib":{"value":"6071"},"text":"§ 6071.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for filing returns and other documents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4688bb94-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6071/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When not otherwise provided for by this title, the Secretary shall by regulations prescribe the time for filing any return, statement, or other document required by this title or by regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4688bb95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6071/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronically filed information returns","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Returns made under subpart B of part III of this subchapter (other than returns and statements required to be filed with respect to nonemployee compensation) which are filed electronically shall be filed on or before March 31 of the year following the calendar year to which such returns relate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4688bb96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6071/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns and statements relating to employee wage information and nonemployee compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Forms W–2 and W–3 and any returns or statements required by the Secretary to report nonemployee compensation shall be filed on or before January 31 of the year following the calendar year to which such returns relate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4688bb97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6071/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For payment of special taxes before engaging in certain trades and businesses, see section 4901 and section 5732.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4688bb98-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/749"},"text":"68A Stat. 749","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s204/1"},"text":"Pub. L. 85–859, title II, § 204(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1428"},"text":"72 Stat. 1428","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105