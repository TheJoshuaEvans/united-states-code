{"tag":"section","attrib":{"id":"id45be1857-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161"},"text":null,"children":[{"tag":"num","attrib":{"value":"4161"},"text":"§ 4161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45be1858-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sport fishing equipment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45be1859-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45be185a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on the sale of any article of sport fishing equipment by the manufacturer, producer, or importer a tax equal to 10 percent of the price for which so sold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45be185b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on tax imposed on fishing rods and poles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by subparagraph (A) on any fishing rod or pole shall not exceed $10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45be185c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 3 percent rate of tax for electric outboard motors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an electric outboard motor, paragraph (1) shall be applied by substituting “3 percent” for “10 percent”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45be185d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 3 percent rate of tax for tackle boxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of fishing tackle boxes, paragraph (1) shall be applied by substituting “3 percent” for “10 percent”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45be185e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parts or accessories sold in connection with taxable sale","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any sale by the manufacturer, producer, or importer of any article of sport fishing equipment, such article shall be treated as including any parts or accessories of such article sold on or in connection therewith or with the sale thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45be185f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bows and arrows, etc.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45be1860-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bows","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45be1861-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on the sale by the manufacturer, producer, or importer of any bow which has a peak draw weight of 30 pounds or more, a tax equal to 11 percent of the price for which so sold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45be1862-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Archery equipment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby imposed on the sale by the manufacturer, producer, or importer—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45be1863-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of any part or accessory suitable for inclusion in or attachment to a bow described in subparagraph (A), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45be1864-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of any quiver, broadhead, or point suitable for use with an arrow described in paragraph (2),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"a tax equal to 11 percent of the price for which so sold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45be1865-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arrows","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45be1866-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby imposed on the first sale by the manufacturer, producer, or importer of any shaft (whether sold separately or incorporated as part of a finished or unfinished product) of a type used in the manufacture of any arrow which after its assembly—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45be1867-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures 18 inches overall or more in length, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45c06258-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures less than 18 inches overall in length but is suitable for use with a bow described in paragraph (1)(A),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"a tax equal to 39 cents per shaft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45c06259-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for certain wooden arrow shafts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraph (A) shall not apply to any shaft consisting of all natural wood with no laminations or artificial means of enhancing the spine of such shaft (whether sold separately or incorporated as part of a finished or unfinished product) of a type used in the manufacture of any arrow which after its assembly—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45c0625a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures ","children":[{"tag":"sup","attrib":{},"text":"5","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"16","children":[],"tail":" of an inch or less in diameter, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45c0625b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not suitable for use with a bow described in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45c0625c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment for inflation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45c0625d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any calendar year beginning after 2005, the 39-cent amount specified in subparagraph (A) shall be increased by an amount equal to the product of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id45c0625e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/b/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id45c0625f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/b/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost-of-living adjustment determined under section 1(f)(3) for such calendar year, determined by substituting “2004” for “2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45c06260-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rounding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any increase determined under clause (i) is not a multiple of 1 cent, such increase shall be rounded to the nearest multiple of 1 cent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45c06261-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4161/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with subsection (a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No tax shall be imposed under this subsection with respect to any article taxable under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45c06262-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/489"},"text":"68A Stat. 489","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tII/s205/a"},"text":"Pub. L. 89–44, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/140"},"text":"79 Stat. 140","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/558/tII/s201/a"},"text":"Pub. L. 92–558, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-25"},"text":"Oct. 25, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1173"},"text":"86 Stat. 1173","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX"},"text":"Pub. L. 98–369, div. A, title X","children":[],"tail":", §§ 1015(a), 1017(a), (b), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1017"},"text":"98 Stat. 1017","children":[],"tail":", 1021; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1899A/48"},"text":"Pub. L. 99–514, title XVIII, § 1899A(48)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2961"},"text":"100 Stat. 2961","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIV/s1433/a"},"text":"Pub. L. 105–34, title XIV, § 1433(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1051"},"text":"111 Stat. 1051","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIII"},"text":"Pub. L. 108–357, title III","children":[],"tail":", §§ 332(a)–(c), 333(a), "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1477"},"text":"118 Stat. 1477","children":[],"tail":", 1478; "},{"tag":"ref","attrib":{"href":"/us/pl/108/493/s1/a"},"text":"Pub. L. 108–493, § 1(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3984"},"text":"118 Stat. 3984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11117/a"},"text":"Pub. L. 109–59, title XI, § 11117(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1951"},"text":"119 Stat. 1951","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s412/uu"},"text":"Pub. L. 109–135, title IV, § 412(uu)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2640"},"text":"119 Stat. 2640","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dC/tV/s503/a"},"text":"Pub. L. 110–343, div. C, title V, § 503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3877"},"text":"122 Stat. 3877","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s11002/d/11"},"text":"Pub. L. 115–97, title I, § 11002(d)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2062"},"text":"131 Stat. 2062","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45c06263-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id45c06264-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inflation Adjusted Items for Certain Years","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For inflation adjustment of certain items in this section, see Revenue Procedures listed in a table under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45c06265-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45c06266-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(2)(C)(i)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" substituted “for ‘2016’ in subparagraph (A)(ii)” for “for ‘1992’ in subparagraph (B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(2)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343"},"text":"Pub. L. 110–343","children":[],"tail":" added subpar. (B) and redesignated former subpar. (B) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11117/a"},"text":"Pub. L. 109–59, § 11117(a)","children":[],"tail":", reenacted heading without change and amended text of par. (1) generally, designating existing provisions as subpar. (A), inserting subpar. heading, and adding subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" amended heading and text of par. (2) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—In the case of an electric outboard motor or a sonar device suitable for finding fish, paragraph (1)(A) shall be applied by substituting ‘3 percent’ for ‘10 percent’."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) $30","children":[{"tag":"inline","attrib":{},"text":" limitation on tax imposed on sonar devices suitable for finding fish","children":[],"tail":".—The tax imposed by paragraph (1)(A) on any sonar device suitable for finding fish shall not exceed $30.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11117/b"},"text":"Pub. L. 109–59, § 11117(b)","children":[],"tail":", substituted “paragraph (1)(A)” for “paragraph (1)” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s333/a"},"text":"Pub. L. 108–357, § 333(a)","children":[],"tail":", added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s332/a"},"text":"Pub. L. 108–357, § 332(a)","children":[],"tail":", reenacted heading without change and amended text of par. (1) generally, substituting provisions imposing a tax on the sale of any bow which has a peak draw weight of 30 pounds or more, any part or accessory, and any quiver or broadhead suitable for use with an arrow described in par. (2), for provisions imposing a tax on the sale of any bow which has a draw weight of 10 pounds or more, any part of accessory, and any quiver suitable for use with arrows described in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/493/s1/c"},"text":"Pub. L. 108–493, § 1(c)","children":[],"tail":", substituted “quiver, broadhead, or point” for “quiver or broadhead”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/493/s1/b"},"text":"Pub. L. 108–493, § 1(b)","children":[],"tail":", amended heading and text of par. (2) generally, substituting provisions relating to arrows for provisions relating to arrow components."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s332/c"},"text":"Pub. L. 108–357, § 332(c)","children":[],"tail":", substituted “Arrow components” for “Arrows” in heading and inserted “(other than broadheads)” after “point” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/493/s1/a"},"text":"Pub. L. 108–493, § 1(a)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s332/b"},"text":"Pub. L. 108–357, § 332(b)","children":[],"tail":". See note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s332/b"},"text":"Pub. L. 108–357, § 332(b)","children":[],"tail":", which directed the amendment of subsec. (b) by adding par. (3), relating to arrows, and redesignating former par. (3) as (4), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/108/493/s1/a"},"text":"Pub. L. 108–493, § 1(a)","children":[],"tail":". See Construction of 2004 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) consisted of pars. (1) to (3) imposing taxes on bows and arrows and parts and accessories and providing for coordination of taxes under subsecs. (a) and (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted a comma for the period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1015/a"},"text":"Pub. L. 98–369, § 1015(a)","children":[],"tail":", in amending subsec. (a) generally, designated existing provisions as par. (1), substituted “any article of sport fishing equipment by the manufacturer, producer, or importer” for “fishing rods, creels, reels, and artificial lures, baits, and flies (including parts or accessories of such articles sold on or in connection therewith, or with the sale thereof) by the manufacturer, producer, or importer”, and added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1017/a"},"text":"Pub. L. 98–369, § 1017(a)","children":[],"tail":", designated existing provisions as cl. (i) and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1017/b/2"},"text":"Pub. L. 98–369, § 1017(b)(2)","children":[],"tail":", struck out “(other than a fishing reel)” after “part or accessory”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1017/b/1"},"text":"Pub. L. 98–369, § 1017(b)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/558/s201/a/1"},"text":"Pub. L. 92–558, § 201(a)(1)","children":[],"tail":", designated existing provisions as subsec. (a) and inserted catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/558/s201/a/2"},"text":"Pub. L. 92–558, § 201(a)(2)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" removed 10 percent tax on equipment for billiards, pool, bowling, trap shooting, cricket, croquet, badminton, curling, deck tennis, golf, lacrosse, polo, skiing, squash, table tennis, and tennis, and retained tax only for fishing equipment."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45c06267-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45c06268-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"