{"tag":"section","attrib":{"id":"id42b25f2d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318"},"text":null,"children":[{"tag":"num","attrib":{"value":"318"},"text":"§ 318.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Constructive ownership of stock","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42b25f2e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of those provisions of this subchapter to which the rules contained in this section are expressly made applicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42b25f2f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of family","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42b25f30-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual shall be considered as owning the stock owned, directly or indirectly, by or for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42b25f31-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his spouse (other than a spouse who is legally separated from the individual under a decree of divorce or separate maintenance), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42b25f32-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his children, grandchildren, and parents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42b25f33-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of adoption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A)(ii), a legally adopted child of an individual shall be treated as a child of such individual by blood.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42b25f34-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attribution from partnerships, estates, trusts, and corporations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42b25f35-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" From partnerships and estates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Stock owned, directly or indirectly, by or for a partnership or estate shall be considered as owned proportionately by its partners or beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42b25f36-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" From trusts","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42b25f37-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Stock owned, directly or indirectly, by or for a trust (other than an employees’ trust described in section 401(a) which is exempt from tax under section 501(a)) shall be considered as owned by its beneficiaries in proportion to the actuarial interest of such beneficiaries in such trust.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42b25f38-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Stock owned, directly or indirectly, by or for any portion of a trust of which a person is considered the owner under subpart E of part I of subchapter J (relating to grantors and others treated as substantial owners) shall be considered as owned by such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42b25f39-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" From corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If 50 percent or more in value of the stock in a corporation is owned, directly or indirectly, by or for any person, such person shall be considered as owning the stock owned, directly or indirectly, by or for such corporation, in that proportion which the value of the stock which such person so owns bears to the value of all the stock in such corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42b25f3a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attribution to partnerships, estates, trusts, and corporations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42b25f3b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" To partnerships and estates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Stock owned, directly or indirectly, by or for a partner or a beneficiary of an estate shall be considered as owned by the partnership or estate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42b25f3c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" To trusts","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42b25f3d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Stock owned, directly or indirectly, by or for a beneficiary of a trust (other than an employees’ trust described in section 401(a) which is exempt from tax under section 501(a)) shall be considered as owned by the trust, unless such beneficiary’s interest in the trust is a remote contingent interest. For purposes of this clause, a contingent interest of a beneficiary in a trust shall be considered remote if, under the maximum exercise of discretion by the trustee in favor of such beneficiary, the value of such interest, computed actuarially, is 5 percent or less of the value of the trust property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42b25f3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Stock owned, directly or indirectly, by or for a person who is considered the owner of any portion of a trust under subpart E of part I of subchapter J (relating to grantors and others treated as substantial owners) shall be considered as owned by the trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42b25f3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" To corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If 50 percent or more in value of the stock in a corporation is owned, directly or indirectly, by or for any person, such corporation shall be considered as owning the stock owned, directly or indirectly, by or for such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42b25f40-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Options","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any person has an option to acquire stock, such stock shall be considered as owned by such person. For purposes of this paragraph, an option to acquire such an option, and each one of a series of such options, shall be considered as an option to acquire such stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42b25f41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operating rules","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42b25f42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraphs (B) and (C), stock constructively owned by a person by reason of the application of paragraph (1), (2), (3), or (4), shall, for purposes of applying paragraphs (1), (2), (3), and (4), be considered as actually owned by such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42b25f43-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of family","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Stock constructively owned by an individual by reason of the application of paragraph (1) shall not be considered as owned by him for purposes of again applying paragraph (1) in order to make another the constructive owner of such stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42b25f44-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships, estates, trusts, and corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Stock constructively owned by a partnership, estate, trust, or corporation by reason of the application of paragraph (3) shall not be considered as owned by it for purposes of applying paragraph (2) in order to make another the constructive owner of such stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42b25f45-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Option rule in lieu of family rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, if stock may be considered as owned by an individual under paragraph (1) or (4), it shall be considered as owned by him under paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42b25f46-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" S corporation treated as partnership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42b25f47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/5/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an S corporation shall be treated as a partnership, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42b25f48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/a/5/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any shareholder of the S corporation shall be treated as a partner of such partnership.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The preceding sentence shall not apply for purposes of determining whether stock in the S corporation is constructively owned by any person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42b25f49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For provisions to which the rules contained in subsection (a) apply, see—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42b25f4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 302 (relating to redemption of stock);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42b25f4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 304 (relating to redemption by related corporations);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42b4a93c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 306(b)(1)(A) (relating to disposition of section 306 stock);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42b4a93d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 338(h)(3) (defining purchase);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42b4a93e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 382(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":null},{"tag":"b","attrib":{},"text":")(3) (relating to special limitations on net operating loss carryovers);","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42b4a93f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 856(d) (relating to definition of rents from real property in the case of real estate investment trusts);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42b4a940-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 958(b) (relating to constructive ownership rules with respect to controlled foreign corporations); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42b4a941-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s318/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","att