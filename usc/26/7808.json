{"tag":"section","attrib":{"id":"id479d5fe4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7808"},"text":null,"children":[{"tag":"num","attrib":{"value":"7808"},"text":"§ 7808.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depositaries for collections","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to designate one or more depositaries in each State for the deposit and safe-keeping of the money collected by virtue of the internal revenue laws; and the receipt of the proper officer of such depositary to the proper officer or employee of the Treasury Department for the money deposited by him shall be a sufficient voucher for such Treasury officer or employee in the settlement of his accounts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id479d5fe5-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/918"},"text":"68A Stat. 918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id479d5fe6-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id479d5fe7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id479d5fe8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
