{"tag":"section","attrib":{"id":"id4670edfe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043"},"text":null,"children":[{"tag":"num","attrib":{"value":"6043"},"text":"§ 6043.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liquidating, etc., transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4670edff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporate liquidating, etc., transactions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every corporation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4670ee00-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within 30 days after the adoption by the corporation of a resolution or plan for the dissolution of the corporation or for the liquidation of the whole or any part of its capital stock, make a return setting forth the terms of such resolution or plan and such other information as the Secretary shall by forms or regulations prescribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4670ee01-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When required by the Secretary, make a return regarding its distributions in liquidation, stating the name and address of, the number and class of shares owned by, and the amount paid to, each shareholder, or, if the distribution is in property other than money, the fair market value (as of the date the distribution is made) of the property distributed to each shareholder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4670ee02-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempt organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every organization which for any of its last 5 taxable years preceding its liquidation, dissolution, termination, or substantial contraction was exempt from taxation under section 501(a) shall file such return and other information with respect to such liquidation, dissolution, termination, or substantial contraction as the Secretary shall by forms or regulations prescribe; except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4670ee03-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no return shall be required under this subsection from churches, their integrated auxiliaries, conventions or associations of churches, or any organization which is not a private foundation (as defined in section 509(a)) and the gross receipts of which in each taxable year are normally not more than $5,000, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4670ee04-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may relieve any organization from such filing where he determines that such filing is not necessary to the efficient administration of the internal revenue laws or, with respect to an organization described in section 401(a), where the employer who established such organization files such a return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4670ee05-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Changes in control and recapitalizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4670ee06-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" control (as defined in section 304(c)(1)) of a corporation is acquired by any person (or group of persons) in a transaction (or series of related transactions), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4670ee07-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a recapitalization of a corporation or other substantial change in the capital structure of a corporation,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"when required by the Secretary, such corporation shall make a return (at such time and in such manner as the Secretary may prescribe) setting forth the identity of the parties to the transaction, the fees involved, the changes in the capital structure involved, and such other information as the Secretary may require with respect to such transaction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4670ee08-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For provisions relating to penalties for failure to file—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4670ee09-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a return under subsection (b), see section 6652(c), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4670ee0a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6043/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a return under subsection (c), see section 6652(1).","children":[{"tag":"ref","attrib":{"idref":"fn002282"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002282"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “6652("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":").”"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4670ee0b-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/746"},"text":"68A Stat. 746","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tI/s101/j/35"},"text":"Pub. L. 91–172, title I, § 101(j)(35)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/529"},"text":"83 Stat. 529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1501/d/1/C"},"text":"Pub. L. 99–514, title XV, § 1501(d)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2740"},"text":"100 Stat. 2740","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7208/b/1"},"text":"Pub. L. 101–239, title VII, § 7208(b)(1)","children":[],"tail":", (3)(A), (B), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2337"},"text":"103 Stat. 2337","children":[],"tail":", 2338; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1704/t/17"},"text":"Pub. L. 104–188, title I, § 1704(t)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1888"},"text":"110 Stat. 1888","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4670ee0c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4670ee0d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4670ee0e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" substituted “Liquidating, etc., transactions” for “Liquidating; etc., transactions” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7208/b/3/B"},"text":"Pub. L. 101–239, § 7208(b)(3)(B)","children":[],"tail":", substituted “Liquidating; etc., transactions” for “Returns regarding liquidation, dissolution, termination, or contraction” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7208/b/3/A"},"text":"Pub. L. 101–239, § 7208(b)(3)(A)","children":[],"tail":", substituted “Corporate liquidating, etc., transactions” for “Corporations” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7208/b/1"},"text":"Pub. L. 101–239, § 7208(b)(1)","children":[],"tail":", added subsecs. (c) and (d) and struck out former subsec. (c) which read as follows: “"},{"tag":"inline","attrib":{},"text":"Cross Reference","children":[],"tail":".—For provisions relating to penalties for failure to file a return required by subsection (b), see section 6652(c).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “section 6652(c)” for “section 6652(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" inserted references to termination and contraction in section catchline, designated existing provisions as subsec. (a), and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4670ee0f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4670ee10-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7208/b/4"},"text":"Pub. L. 101–239, title VII, § 7208(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2338"},"text":"103 Stat. 2338","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tVII/s7208/b/4"},"text":"“The amendments made by this subsection [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6652"},"text":"section 6652 of this title","children":[],"tail":"] shall apply to transactions after "},{"tag":"date","attrib":{"date":"1990-03-31"},"text":"March 31, 1990","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4670ee11-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" applicable to returns the due date for which (determined without regard to extensions) is after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1501/e"},"text":"section 1501(e) of Pub. L. 99–514","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6721"},"text":"section 6721 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4670ee12-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1969 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1969-12-31"},"text":"Dec. 31, 1969","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/s101/k/2/B"},"text":"section 101(k)(2)(B) of Pub. L. 91–172","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4940"},"text":"section 4940 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
