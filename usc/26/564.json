{"tag":"section","attrib":{"id":"id43d534b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s564"},"text":null,"children":[{"tag":"num","attrib":{"value":"564"},"text":"§ 564.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dividend carryover","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43d534b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s564/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of computing the dividends paid deduction under section 561, in the case of a personal holding company the dividend carryover for any taxable year shall be the dividend carryover to such taxable year, computed as provided in subsection (b), from the two preceding taxable years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43d534b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s564/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of dividend carryover","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The dividend carryover to the taxable year shall be determined as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43d534ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s564/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each of the 2 preceding taxable years there shall be determined the taxable income computed with the adjustments provided in section 545 (whether or not the taxpayer was a personal holding company for either of such preceding taxable years), and there shall also be determined for each such year the deduction for dividends paid during such year as provided in section 561 (but determined without regard to the dividend carryover to such year).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43d534bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s564/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be determined for each such taxable year whether there is an excess of such taxable income over such deduction for dividends paid or an excess of such deduction for dividends paid over such taxable income, and the amount of each such excess.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43d534bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s564/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If there is an excess of such deductions for dividends paid over such taxable income for the first preceding taxable year, such excess shall be allowed as a dividend carryover to the taxable year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43d534bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s564/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If there is an excess of such deduction for dividends paid over such taxable income for the second preceding taxable year, such excess shall be reduced by the amount determined in paragraph (5), and the remainder of such excess shall be allowed as a dividend carryover to the taxable year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43d534be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s564/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of the reduction specified in paragraph (4) shall be the amount of the excess of the taxable income, if any, for the first preceding taxable year over such deduction for dividends paid, if any, for the first preceding taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43d534bf-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/200"},"text":"68A Stat. 200","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1901/a/81"},"text":"Pub. L. 94–455, title XIX, § 1901(a)(81)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1778"},"text":"90 Stat. 1778","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43d534c0-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43d534c1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43d534c2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out subsec. (c) which related to the determination of dividend carryover from taxable years to which this subtitle does not apply."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43d534c3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43d534c4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" applicable with respect to taxable years beginning after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"Dec. 31, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/d"},"text":"section 1901(d) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
