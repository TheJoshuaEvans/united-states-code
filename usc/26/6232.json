{"tag":"section","attrib":{"id":"id46bfa9bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232"},"text":null,"children":[{"tag":"num","attrib":{"value":"6232"},"text":"§ 6232.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment, collection, and payment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46bfa9bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any imputed underpayment shall be assessed and collected in the same manner as if it were a tax imposed for the adjustment year by subtitle A, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46bfa9bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter B of chapter 63 shall not apply, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bfa9be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an administrative adjustment request to which section 6227(b)(1) applies, the underpayment shall be paid and may be assessed when the request is filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bfa9bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this subtitle (other than subchapter B of this chapter), no assessment of an imputed underpayment may be made (and no levy or proceeding in any court for the collection of any amount resulting from such adjustment may be made, begun or prosecuted) before—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46bfa9c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the close of the 90th day after the day on which a notice of a final partnership adjustment was mailed, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bfa9c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a petition is filed under section 6234 with respect to such notice, the decision of the court has become final.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The preceding sentence shall not apply in the case of a specified similar amount (as defined in subsection (f)(2)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bfa9c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premature action may be enjoined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 7421(a), any action which violates subsection (b) may be enjoined in the proper court, including the Tax Court. The Tax Court shall have no jurisdiction to enjoin any action under this subsection unless a timely petition has been filed under section 6234 and then only in respect of the adjustments that are the subject of such petition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bfa9c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions to restrictions on adjustments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46bfa9c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments arising out of math or clerical errors","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46bfa9c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":" If the partnership is notified that, on account of a mathematical or clerical error appearing on the partnership return, an adjustment to an item is required, rules similar to the rules of paragraphs (1) and (2) of section 6213(b) shall apply to such adjustment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bfa9c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a partnership is a partner in another partnership, any adjustment on account of such partnership’s failure to comply with the requirements of section 6222(a) with respect to its interest in such other partnership shall be treated as an adjustment referred to in subparagraph (A), except that paragraph (2) of section 6213(b) shall not apply to such adjustment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bfa9c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership may waive restrictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The partnership may at any time (whether or not any notice of partnership adjustment has been issued), by a signed notice in writing filed with the Secretary, waive the restrictions provided in subsection (b) on the making of any partnership adjustment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bfa9c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit where no proceeding begun","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If no proceeding under section 6234 is begun with respect to any notice of a final partnership adjustment during the 90-day period described in subsection (b), the amount for which the partnership is liable under section 6225 shall not exceed the amount determined in accordance with such notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bfa9c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to pay imputed underpayment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46bfa9ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any amount of any imputed underpayment to which section 6225 applies or any specified similar amount (or any interest or penalties with respect to any such amount) has not been paid by the date which is 10 days after the date on which the Secretary provides notice and demand for such payment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46bfa9cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 6621(a)(2)(B) shall be applied by substituting “5 percentage points” for “3 percentage points” with respect to such amount, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bfa9cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may assess upon each partner of the partnership (determined as of the close of the adjustment year or, if the partnership has ceased to exist as of such time, the former partners of the partnership as determined for purposes of section 6241(7)) a tax equal to such partner’s proportionate share of such amount (including any such interest or penalties, determined after application of subparagraph (A)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bfa9cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified similar amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “specified similar amount” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46bfa9ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount described in subclause (II) of section 6226(b)(4)(A)(ii) (including any failure to satisfy the requirement of subclause (I) of such section which is treated as a failure to pay such amount under section 6651(i)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bfa9cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount assessed under paragraph (1)(B) upon a partner which is a partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bfa9d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proportionate share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), a partner’s proportionate share is such percentage as the Secretary may determine on the basis of such partner’s distributive share. The Secretary shall make determinations under the preceding sentence such that the aggregate proportionate shares so determined total 100 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bfa9d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with partnership liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The liability of the partnership for any amount with respect to which a partner is made liable under paragraph (1) shall be reduced upon payment by the partner of such amount. Paragraph (1)(B) shall not apply with respect to any amount after the date on which such amount is paid by the partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bfa9d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" S corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, an S corporation and its shareholders shall be treated in the same manner as a partnership and its partners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bfa9d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules related to assessment and collection","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46bfa9d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/f/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deficiency procedures not applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subchapter B shall not apply to any assessment or collection under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bfa9d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6232/f/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subtitle, no assessment may be made (or proceeding in court begun without assessment) with respect to any partner with respect to an amount under paragraph (1) after the date which is 2 years after the date on which the Secretary provides the notice and demand referred to in paragraph (1) with respect to such amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46bfa9d6-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/74/tXI/s1101/c/1"},"text":"Pub. L. 114–74, title XI, § 1101(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/632"},"text":"129 Stat. 632","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tII"},"text":"Pub. L. 115–141, div. U, title II","children":[],"tail":", §§ 205(a), 206(g), (p)(4)–(6), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1177"},"text":"132 Stat. 1177","children":[],"tail":", 1179, 1182.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46bfa9d7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46bfa9d8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46bfa9d9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6232, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIV/s402/a"},"text":"Pub. L. 97–248, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/666"},"text":"96 Stat. 666","children":[],"tail":", related to extension of subchapter provisions, respecting tax treatment of partnership items, to windfall profit tax, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1941/b/1"},"text":"Pub. L. 100–418, title I, § 1941(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1323"},"text":"102 Stat. 1323","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46c1f3ca-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/g/1"},"text":"Pub. L. 115–141, § 206(g)(1)","children":[],"tail":", substituted “except that—” for “except that in the case of an administrative adjustment request to which section 6227(b)(1) applies, the underpayment shall be paid when the request is filed.” and added pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/p/4"},"text":"Pub. L. 115–141, § 206(p)(4)","children":[],"tail":", substituted “this subtitle (other than subchapter B of this chapter)” for “this chapter” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/g/2"},"text":"Pub. L. 115–141, § 206(g)(2)","children":[],"tail":", substituted “assessment of an imputed underpayment” for “assessment of a deficiency” in introductory provisions and inserted concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/p/5"},"text":"Pub. L. 115–141, § 206(p)(5)","children":[],"tail":", substituted “an item” for “a item”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/p/6"},"text":"Pub. L. 115–141, § 206(p)(6)","children":[],"tail":", struck out “thereof” after “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s205/a"},"text":"Pub. L. 115–141, § 205(a)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46c1f3cb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46c1f3cc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" effective as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/114/74/s1101"},"text":"section 1101 of Pub. L. 114–74","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/s207"},"text":"section 207 of Pub. L. 115–141","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6031"},"text":"section 6031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46c1f3cd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to returns filed for partnership taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/74/s1101/g"},"text":"section 1101(g) of Pub. L. 114–74","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6221"},"text":"section 6221 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
