{"tag":"section","attrib":{"id":"id47a946aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9011"},"text":null,"children":[{"tag":"num","attrib":{"value":"9011"},"text":"§ 9011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47a946ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9011/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of certification, determination, or other action by the Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any certification, determination, or other action by the Commission made or taken pursuant to the provisions of this chapter shall be subject to review by the United States Court of Appeals for the District of Columbia upon petition filed in such Court by any interested person. Any petition filed pursuant to this section shall be filed within thirty days after the certification, determination, or other action by the Commission for which review is sought.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a946ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9011/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suits to implement chapter","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47a946ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9011/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission, the national committee of any political party, and individuals eligible to vote for President are authorized to institute such actions, including actions for declaratory judgment or injunctive relief, as may be appropriate to implement or construe any provision of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a946ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9011/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The district courts of the United States shall have jurisdiction of proceedings instituted pursuant to this subsection and shall exercise the same without regard to whether a person asserting rights under provisions of this subsection shall have exhausted any administrative or other remedies that may be provided at law. Such proceedings shall be heard and determined by a court of three judges in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2284"},"text":"section 2284 of title 28","children":[],"tail":", United States Code, and any appeal shall lie to the Supreme Court."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47a946af-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/178/tVIII/s801"},"text":"Pub. L. 92–178, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/570"},"text":"85 Stat. 570","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/tIV/s404/c/19"},"text":"Pub. L. 93–443, title IV, § 404(c)(19)","children":[],"tail":"–(21), "},{"tag":"date","attrib":{"date":"1974-10-15"},"text":"Oct. 15, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1293"},"text":"88 Stat. 1293","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/tIV/s402/28/F"},"text":"Pub. L. 98–620, title IV, § 402(28)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3359"},"text":"98 Stat. 3359","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/339"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(339)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1200"},"text":"132 Stat. 1200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47a946b0-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47a946b1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47a946b2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “construe” for “contrue”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":" struck out provision requiring the judges designated to hear the case to assign the case for hearing at the earliest practicable date, to participate in the hearing and determination thereof, and to cause the case to be in every way expedited."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443/s404/c/19"},"text":"Pub. L. 93–443, § 404(c)(19)","children":[],"tail":", (20), substituted “Commission” for “Comptroller General” in heading and wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443/s404/c/21"},"text":"Pub. L. 93–443, § 404(c)(21)","children":[],"tail":", substituted “Commission” for “Comptroller General”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47a946b3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47a946b4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":" not applicable to cases pending on "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/s403"},"text":"section 403 of Pub. L. 98–620","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1657"},"text":"section 1657 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47a946b5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443"},"text":"Pub. L. 93–443","children":[],"tail":" applicable with respect to taxable years beginning after "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","ch