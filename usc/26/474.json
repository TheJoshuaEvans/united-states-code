{"tag":"section","attrib":{"id":"id439e6ce7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474"},"text":null,"children":[{"tag":"num","attrib":{"value":"474"},"text":"§ 474.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simplified dollar-value LIFO method for certain small businesses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id439e6ce8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible small business may elect to use the simplified dollar-value method of pricing inventories for purposes of the LIFO method.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439e6ce9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simplified dollar-value method of pricing inventories","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id439e6cea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The simplified dollar-value method of pricing inventories is a dollar-value method of pricing inventories under which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439e6ceb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer maintains a separate inventory pool for items in each major category in the applicable Government price index, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439e6cec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjustment for each such separate pool is based on the change from the preceding taxable year in the component of such index for the major category.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439e6ced-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable Government price index","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable Government price index” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439e6cee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subparagraph (B), the Producer Price Index published by the Bureau of Labor Statistics, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439e6cef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a retailer using the retail method, the Consumer Price Index published by the Bureau of Labor Statistics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439e6cf0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major category","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “major category” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439e6cf1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the Producer Price Index, any of the 2-digit standard industrial classifications in the Producer Prices Data Report, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439e6cf2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the Consumer Price Index, any of the general expenditure categories in the Consumer Price Index Detailed Report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439e6cf3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible small business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, a taxpayer is an eligible small business for any taxable year if the average annual gross receipts of the taxpayer for the 3 preceding taxable years do not exceed $5,000,000. For purposes of the preceding sentence, rules similar to the rules of section 448(c)(3) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439e6cf4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id439e6cf5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled groups","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439e6cf6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a taxpayer which is a member of a controlled group, all persons which are component members of such group shall be treated as 1 taxpayer for purposes of determining the gross receipts of the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439e6cf7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled group defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), persons shall be treated as being component members of a controlled group if such persons would be treated as a single employer under section 52.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439e6cf8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439e6cf9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The election under this section may be made without the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439e6cfa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period to which election applies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The election under this section shall apply—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id439e6cfb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the taxable year for which it is made, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439e6cfc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to all subsequent taxable years for which the taxpayer is an eligible small business,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless the taxpayer secures the consent of the Secretary to the revocation of such election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439e6cfd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" LIFO method","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “LIFO method” means the method provided by section 472(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439e6cfe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transitional rules","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439e6cff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a year of change under this section—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id439e6d00-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the inventory pools shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id439e6d01-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d/4/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the 1st taxable year to which such an election applies, be established in accordance with the major categories in the applicable Government price index, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id439e6d02-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d/4/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the 1st taxable year after such election ceases to apply, be established in the manner provided by regulations under section 472;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439e6d03-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate dollar amount of the taxpayer’s inventory as of the beginning of the year of change shall be the same as the aggregate dollar value as of the close of the taxable year preceding the year of change, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439e6d04-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the year of change shall be treated as a new base year in accordance with procedures provided by regulations under section 472.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439e6d05-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Year of change","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph, the year of change under this section is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id439e6d06-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 1st taxable year to which an election under this section applies, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439e6d07-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s474/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a cessation of such an election, the 1st taxable year after such election ceases to apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id439e6d08-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/tII/s237/a"},"text":"Pub. L. 97–34, title II, § 237(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/252"},"text":"95 Stat. 252","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVIII/s802/a"},"text":"Pub. L. 99–514, title VIII, § 802(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2348"},"text":"100 Stat. 2348","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id439e6d09-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id439e6d0a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id439e6d0b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" amended section generally, substituting provisions relating to election by eligible small business to use simplified dollar-value method of pricing inventories for purposes of LIFO method for provisions relating to election by eligible small business which uses dollar-value method of pricing inventories under method provided by "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s472/b"},"text":"section 472(b) of this title","children":[],"tail":" to use one inventory pool for any trade or business of such eligible small business."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id439e6d0c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id439e6d0d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVIII/s802/c"},"text":"Pub. L. 99–514, title VIII, § 802(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2350"},"text":"100 Stat. 2350","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tVIII/s802/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of taxpayers who made elections under existing section 474","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section shall not apply to any taxpayer who made an election under section 474 of the Internal Revenue Code of 1954 (as in effect on the day before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":"]) for any period during which such election is in effect. Notwithstanding any provision of such section 474 (as so in effect), an election under such section may be revoked without the consent of the Secretary.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id439e6d0e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/tII/s237/c"},"text":"Pub. L. 97–34, title II, § 237(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/253"},"text":"95 Stat. 253","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/34/tII/s237/c"},"text":"“The amendments made by this section [enacting this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1981-12-31"},"text":"December 31, 1981","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
