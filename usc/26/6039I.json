{"tag":"section","attrib":{"id":"id466c3335-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039I"},"text":null,"children":[{"tag":"num","attrib":{"value":"6039I"},"text":"§ 6039I.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns and records with respect to employer-owned life insurance contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id466c3336-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039I/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every applicable policyholder owning 1 or more employer-owned life insurance contracts issued after the date of the enactment of this section shall file a return (at such time and in such manner as the Secretary shall by regulations prescribe) showing for each year such contracts are owned—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id466c3337-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039I/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of employees of the applicable policyholder at the end of the year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id466c3338-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039I/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such employees insured under such contracts at the end of the year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id466c3339-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039I/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of insurance in force at the end of the year under such contracts,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id466c333a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039I/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and taxpayer identification number of the applicable policyholder and the type of business in which the policyholder is engaged, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id466c333b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039I/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the applicable policyholder has a valid consent for each insured employee (or, if all such consents are not obtained, the number of insured employees for whom such consent was not obtained).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id466c333c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039I/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each applicable policyholder owning 1 or more employer-owned life insurance contracts during any year shall keep such records as may be necessary for purposes of determining whether the requirements of this section and section 101(j) are met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id466c333d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039I/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any term used in this section which is used in section 101(j) shall have the same meaning given such term by section 101(j).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id466c333e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tVIII/s863/b"},"text":"Pub. L. 109–280, title VIII, § 863(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1023"},"text":"120 Stat. 1023","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id466c333f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id466c3340-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id466c3341-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id466c3342-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id466c3343-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to life insurance contracts issued after ","children":[{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", except for a contract issued after such date pursuant to an exchange described in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1035"},"text":"section 1035 of this title","children":[],"tail":" for a contract issued on or prior to that date, and any material change to cause the contract to be treated as a new contract, with exception in the case of a master contract, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/s863/d"},"text":"section 863(d) of Pub. L. 109–280","children":[],"tail":", set out as an Effective Date of 2006 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
