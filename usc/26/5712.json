{"tag":"section","attrib":{"id":"id464ac88b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5712"},"text":null,"children":[{"tag":"num","attrib":{"value":"5712"},"text":"§ 5712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for permit","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Every person, before commencing business as a manufacturer or importer of tobacco products or processed tobacco or as an export warehouse proprietor, and at such other time as the Secretary shall by regulation prescribe, shall make application for the permit provided for in section 5713. The application shall be in such form as the Secretary shall prescribe and shall set forth, truthfully and accurately, the information called for on the form. Such application may be rejected and the permit denied if the Secretary, after notice and opportunity for hearing, find that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id464ac88c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5712/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the premises on which it is proposed to conduct the business are not adequate to protect the revenue;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464ac88d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5712/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activity proposed to be carried out at such premises does not meet such minimum capacity or activity requirements as the Secretary may prescribe,","children":[{"tag":"ref","attrib":{"idref":"fn002267"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002267"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should be a semicolon."}],"tail":" or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464ac88e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5712/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such person (including, in the case of a corporation, any officer, director, or principal stockholder and, in the case of a partnership, a partner)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id464ac88f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5712/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is, by reason of his business experience, financial standing, or trade connections or by reason of previous or current legal proceedings involving a felony violation of any other provision of Federal criminal law relating to tobacco products, processed tobacco, cigarette paper, or cigarette tubes, not likely to maintain operations in compliance with this chapter,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id464ac890-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5712/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been convicted of a felony violation of any provision of Federal or State criminal law relating to tobacco products, processed tobacco, cigarette paper, or cigarette tubes, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id464ac891-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5712/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has failed to disclose any material information required or made any material false statement in the application therefor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id464ac892-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/712"},"text":"68A Stat. 712","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s202"},"text":"Pub. L. 85–859, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1421"},"text":"72 Stat. 1421","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1905(a)(27), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1821"},"text":"90 Stat. 1821","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIX/s9302/h/2/A"},"text":"Pub. L. 105–33, title IX, § 9302(h)(2)(A)","children":[],"tail":", (5), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/674"},"text":"111 Stat. 674","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/3/tVII/s702/a/1/A"},"text":"Pub. L. 111–3, title VII, § 702(a)(1)(A)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2009-02-04"},"text":"Feb. 4, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/108"},"text":"123 Stat. 108","children":[],"tail":", 109.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id464ac893-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id464ac894-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id464ac895-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/3/s702/a/1/A"},"text":"Pub. L. 111–3, § 702(a)(1)(A)","children":[],"tail":", inserted “or processed tobacco” after “tobacco products” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/3/s702/b/1"},"text":"Pub. L. 111–3, § 702(b)(1)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “such person (including, in the case of a corporation, any officer, director, or principal stockholder and, in the case of a partnership, a partner) is, by reason of his business experience, financial standing, or trade connections, not likely to maintain operations in compliance with this chapter, or has failed to disclose any material information required or made any material false statement in the application therefor.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s9302/h/5"},"text":"Pub. L. 105–33, § 9302(h)(5)","children":[],"tail":", struck out “or” at end of par. (1), added par. (2), and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s9302/h/2/A"},"text":"Pub. L. 105–33, § 9302(h)(2)(A)","children":[],"tail":", inserted “or importer” after “manufacturer” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” and struck out provision that no person subject to this section, who was lawfully engaged in business on the date of the enactment of the Excise Tax Technical Changes Act of 1958, be denied the right to carry on that business pending reasonable opportunity to make applications for permit and final action thereon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" included export warehouse proprietors, and excluded dealers in tobacco materials."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id464ac896-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464ac897-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/3/s702/a/1/A"},"text":"section 702(a)(1)(A) of Pub. L. 111–3","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-04-01"},"text":"Apr. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/3/s702/a/6"},"text":"section 702(a)(6) of Pub. L. 111–3","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5702"},"text":"section 5702 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/3/tVII/s702/b/3"},"text":"Pub. L. 111–3, title VII, § 702(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-04"},"text":"Feb. 4, 2009