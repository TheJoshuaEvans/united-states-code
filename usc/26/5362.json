{"tag":"section","attrib":{"id":"id4637b4f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362"},"text":null,"children":[{"tag":"num","attrib":{"value":"5362"},"text":"§ 5362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removals of wine from bonded wine cellars","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4637b4f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawals on determination of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Wine may be withdrawn from bonded wine cellars on payment or determination of the tax thereon, under such regulations as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4637b4f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of wine between bonded premises","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4637b4f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Wine on which the tax has not been paid or determined may, under such regulations as the Secretary shall prescribe, be transferred in bond between bonded premises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4637b4f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wine transferred to a distilled spirits plant may not be removed for consumption or sale as wine","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any wine transferred to the bonded premises of a distilled spirits plant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4637b4f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be used in the manufacture of a distilled spirits product, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4637b4f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be removed from such bonded premises for consumption or sale as wine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4637b4f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued liability for tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The liability for tax on wine transferred to the bonded premises of a distilled spirits plant pursuant to paragraph (1) shall (except as otherwise provided by law) continue until the wine is used in a distilled spirits product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4637b4f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer in bond not treated as removal for consumption or sale","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the removal of wine for transfer in bond between bonded premises shall not be treated as a removal for consumption or sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4637b4f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bonded premises","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “bonded premises” means a bonded wine cellar or the bonded premises of a distilled spirits plant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4637b4fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawals of wine free of tax or without payment of tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Wine on which the tax has not been paid or determined may, under such regulations and bonds as the Secretary may deem necessary to protect the revenue, be withdrawn from bonded wine cellars—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4637b4fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without payment of tax for export by the proprietor or by any authorized exporter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4637b4fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without payment of tax for transfer to any foreign-trade zone;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4637b4fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without payment of tax for use of certain vessels and aircraft as authorized by law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4637b4fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without payment of tax for transfer to any customs bonded warehouse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4637b4ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without payment of tax for use in the production of vinegar;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4637b500-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without payment of tax for use in distillation in any distilled spirits plant authorized to produce distilled spirits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4637b501-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" free of tax for experimental or research purposes by any scientific university, college of learning, or institution of scientific research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4637b502-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" free of tax for use by or for the account of the proprietor or his agents for analysis or testing, organoleptic or otherwise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4637b503-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" free of tax for use by the United States or any agency thereof, and for use for analysis, testing, research, or experimentation by the governments of the several States and the District of Columbia or of any political subdivision thereof or by any agency of such governments. No bond shall be required of any such government or agency under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4637b504-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal free of tax of wine and wine products unfit for beverage use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under such regulations as the Secretary may deem necessary to protect the revenue, wine, or wine products made from wine, when rendered unfit for beverage use, on which the tax has not been paid or determined, may be withdrawn from bonded wine cellars free of tax. The wine or wine products to be so withdrawn may be treated with methods or materials which render such wine or wine products suitable for their intended use. No wine or wine products so withdrawn shall contain more than 21 percent of alcohol by volume, or be used in the compounding of distilled spirits or wine for beverage use or in the manufacture of any product intended to be used in such compounding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4637b505-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal from customs bonded warehouses for use of foreign embassies, legations, etc.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4637b506-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, wine entered into customs bonded warehouses under subsection (c)(4) may, under such regulations as the Secretary may prescribe, be withdrawn from such warehouses for consumption in the United States by and for the official or family use of such foreign governments, organizations, and individuals who are entitled to withdraw imported wines from such warehouses free of tax. Wines transferred to customs bonded warehouses under subsection (c)(4) shall be entered, stored, and accounted for in such warehouses under such regulations and bonds as the Secretary may prescribe, and may be withdrawn therefrom by such governments, organizations, and individuals free of tax under the same conditions and procedures as imported wines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4637b507-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal for domestic use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Wine entered into customs bonded warehouses under subsection (c)(4) for purposes of removal under paragraph (1) may be withdrawn therefrom for domestic use. Wines so withdrawn shall be treated as American goods exported and returned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4637b508-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5362/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale or unauthorized use prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Wine withdrawn from customs bonded warehouses or otherwise brought into the United States free of tax for the official or family use of foreign governments, organizations, or individuals authorized to obtain wine free of tax shall not be sold and shall not be disposed of or possessed for any use other than an authorized use. The provisions of paragraphs (1)(B) and (3) of section 5043(a) are hereby extended and made applicable to any person selling, disposing of, or possessing any wine in violation of the preceding sentence, and to the wine involved in any such violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4637b509-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1380"},"text":"72 Stat. 1380","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/73/s1/a"},"text":"Pub. L. 90–73, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-08-29"},"text":"Aug. 29, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/175"},"text":"81 Stat. 175","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1905(c)(4), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1823"},"text":"90 Stat. 1823","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/44"},"text":"Pub. L. 96–39, title VIII, § 807(a)(44)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/287"},"text":"93 Stat. 287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/601/s2/a"},"text":"Pub. L. 96–601, § 2(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3495"},"text":"94 Stat. 3495","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4637b50a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4637b50b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4637b50c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5362, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/665"},"text":"68A Stat. 665","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4637b50d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/601/s2/a"},"text":"Pub. L. 96–601, § 2(a)","children":[],"tail":", substituted “customs bonded” for “class 6 customs manufacturing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/601/s2/b"},"text":"Pub. L. 96–601, § 2(b)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" substituted references to bonded premises for references to bonded wine cellars and inserted provisions relating to wine transferred in bond to a distilled spirits plant which may not be removed for consumption or sale as wine, provisions relating to continued liability for tax on wine transferred to bonded premises, and provisions defining “bonded premises”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1905/c/4"},"text":"Pub. L. 94–455, § 1905(c)(4)","children":[],"tail":", struck out “and Territories” after “the several States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/73"},"text":"Pub. L. 90–73","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4637b50e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4637b50f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/601/s2/c"},"text":"Pub. L. 96–601, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3496"},"text":"94 Stat. 3496","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/601/s2/c"},"text":"“The amendments made by this section [amending this section] shall take effect on the first day of the first calendar month which begins more than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4637b510-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-01-01"},"text":"Jan. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/s810"},"text":"section 810 of Pub. L. 96–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4637b511-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1905/c/4"},"text":"section 1905(c)(4) of Pub. L. 94–455","children":[],"tail":" effective on first day of first month which begins more than 90 days after "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1905/d"},"text":"section 1905(d) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5005"},"text":"section 5005 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4637b512-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1967 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/73/s1/b"},"text":"Pub. L. 90–73, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-08-29"},"text":"Aug. 29, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/175"},"text":"81 Stat. 175","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/73/s1/b"},"text":"“The amendment made by subsection (a) [amending this section] shall become effective on the first day of the first month which begins 90 days or more after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1967-08-29"},"text":"Aug. 29, 1967","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
