{"tag":"section","attrib":{"id":"id4546c55d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2611"},"text":null,"children":[{"tag":"num","attrib":{"value":"2611"},"text":"§ 2611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generation-skipping transfer defined","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4546c55e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the term “generation-skipping transfer” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4546c55f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2611/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a taxable distribution,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4546c560-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2611/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a taxable termination, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4546c561-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2611/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a direct skip.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4546c562-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain transfers excluded","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “generation-skipping transfer” does not include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4546c563-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2611/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any transfer which, if made inter vivos by an individual, would not be treated as a taxable gift by reason of section 2503(e) (relating to exclusion of certain transfers for educational or medical expenses), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4546c564-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2611/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any transfer to the extent—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4546c565-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2611/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property transferred was subject to a prior tax imposed under this chapter,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4546c566-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2611/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transferee in the prior transfer was assigned to the same generation as (or a lower generation than) the generation assignment of the transferee in this transfer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4546c567-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2611/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such transfers do not have the effect of avoiding tax under this chapter with respect to any transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4546c568-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2006/a"},"text":"Pub. L. 94–455, title XX, § 2006(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1882"},"text":"90 Stat. 1882","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIV/s1431/a"},"text":"Pub. L. 99–514, title XIV, § 1431(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2718"},"text":"100 Stat. 2718","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI"},"text":"Pub. L. 100–647, title I","children":[],"tail":", §§ 1014(g)(1), (2), 1018(u)(43), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3562"},"text":"102 Stat. 3562","children":[],"tail":", 3592.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4546c569-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4546c56a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4546c56b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":", §§ 1014(g)(1), 1018(u)(43), substituted “generation-skipping transfer” for “generation-skipping transfers” and “means” for “mean”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1014/g/2"},"text":"Pub. L. 100–647, § 1014(g)(2)","children":[],"tail":", redesignated pars. (2) and (3) as (1) and (2), respectively, and struck out former par. (1) which read as follows: “any transfer (other than a direct skip) from a trust, to the extent such transfer is subject to a tax imposed by chapter 11 or 12 with respect to a person in the 1st generation below that of the grantor, and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" amended section generally, substituting provisions defining “generation-skipping transfers” and what that term does not include, for former provisions which defined “generation-skipping transfer”, “transfer”, and “generation-skipping trust”, contained provisions to be used in determining the ascertainment of generation, and provided for a generation-skipping trust equivalent."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4546c56c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4546c56d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4546c56e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to generation-skipping transfers (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s2611"},"text":"section 2611 of this title","children":[],"tail":") made after "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1433"},"text":"section 1433 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2601"},"text":"section 2601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
