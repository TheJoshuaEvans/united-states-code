{"tag":"section","attrib":{"id":"id4667512a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038B"},"text":null,"children":[{"tag":"num","attrib":{"value":"6038B"},"text":"§ 6038B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of certain transfers to foreign persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4667512b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each United States person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4667512c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" transfers property to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4667512d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038B/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign corporation in an exchange described in section 332, 351, 354, 355, 356, or 361, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4667512e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038B/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign partnership in a contribution described in section 721 or in any other contribution described in regulations prescribed by the Secretary, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4667512f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes a distribution described in section 336 to a person who is not a United States person,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall furnish to the Secretary, at such time and in such manner as the Secretary shall by regulations prescribe, such information with respect to such exchange or distribution as the Secretary may require in such regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46675130-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions for certain transfers to foreign partnerships; special rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46675131-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a)(1)(B) shall apply to a transfer by a United States person to a foreign partnership only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46675132-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038B/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States person holds (immediately after the transfer) directly or indirectly at least a 10-percent interest (as defined in section 6046A(d)) in the partnership, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46675133-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038B/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of the property transferred (when added to the value of the property transferred by such person or any related person to such partnership or a related partnership during the 12-month period ending on the date of the transfer) exceeds $100,000.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of the preceding sentence, the value of any transferred property is its fair market value at the time of its transfer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c134-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If by reason of an adjustment under section 482 or otherwise, a contribution described in subsection (a)(1) is deemed to have been made, such contribution shall be treated for purposes of this section as having been made not earlier than the date specified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4669c135-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for failure to furnish information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4669c136-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any United States person fails to furnish the information described in subsection (a) at the time and in the manner required by regulations, such person shall pay a penalty equal to 10 percent of the fair market value of the property at the time of the exchange (and, in the case of a contribution described in subsection (a)(1)(B), such person shall recognize gain as if the contributed property had been sold for such value at the time of such contribution).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c137-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable cause exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to any failure if the United States person shows such failure is due to reasonable cause and not to willful neglect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c138-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6038B/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalty under paragraph (1) with respect to any exchange shall not exceed $100,000 unless the failure with respect to such exchange was due to intentional disregard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4669c139-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s131/d/1"},"text":"Pub. L. 98–369, div. A, title I, § 131(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/664"},"text":"98 Stat. 664","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXI/s1144/a"},"text":"Pub. L. 105–34, title XI, § 1144(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/984"},"text":"111 Stat. 984","children":[],"tail":", 985; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tVI/s6011/g"},"text":"Pub. L. 105–206, title VI, § 6011(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/818"},"text":"112 Stat. 818","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s409/c"},"text":"Pub. L. 109–135, title IV, § 409(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2636"},"text":"119 Stat. 2636","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4669c13a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4669c13b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4669c13c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" inserted “or” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6011/g"},"text":"Pub. L. 105–206, § 6011(g)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s1144/c"},"text":"Pub. L. 105–206, § 1144(c)","children":[],"tail":". See 1997 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1144/a"},"text":"Pub. L. 105–34, § 1144(a)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “transfers property to a foreign corporation in an exchange described in section 332, 351, 354, 355, 356, or 361, or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1144/b"},"text":"Pub. L. 105–34, § 1144(b)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1144/c"},"text":"Pub. L. 105–34, § 1144(c)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6011/g"},"text":"Pub. L. 105–206, § 6011(g)","children":[],"tail":", substituted “equal to 10 percent of the fair market value of the property at the time of the exchange (and, in the case of a contribution described in subsection (a)(1)(B), such person shall recognize gain as if the contributed property had been sold for such value at the time of such contribution)” for “equal to 25 percent of the amount of the gain realized on the exchange” in par. (1) and added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1144/b"},"text":"Pub. L. 105–34, § 1144(b)","children":[],"tail":", redesignated subsec. (b) as (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4669c13d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4669c13e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" effective as if included in the provisions of the Taxpayer Relief Act of 1997, "},{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/s409/d"},"text":"section 409(d) of Pub. L. 109–135","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s961"},"text":"section 961 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4669c13f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Taxpayer Relief Act of 1997, "},{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6024"},"text":"section 6024 of Pub. L. 105–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4669c140-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXI/s1144/d/1"},"text":"Pub. L. 105–34, title XI, § 1144(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/985"},"text":"111 Stat. 985","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tXI/s1144/d/1"},"text":"“The amendments made by this section [amending this section] shall apply to transfers made after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4669c141-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to transfers or exchanges after ","children":[{"tag":"date","attrib":{"date":"1984-12-31"},"text":"Dec. 31, 1984","children":[],"tail":", in taxable years ending after such date, with special rules for certain transfers and ruling requests before "},{"tag":"date","attrib":{"date":"1984-03-01"},"text":"Mar. 1, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s131/g"},"text":"section 131(g) of Pub. L. 98–369","children":[],"tail":", set out as an Effective Date of 1984 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s367"},"text":"section 367 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4669c142-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Election of Retroactive Effect","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXI/s1144/d/2"},"text":"Pub. L. 105–34, title XI, § 1144(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/985"},"text":"111 Stat. 985","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tXI/s1144/d/2"},"text":"“Section 1494(c) of the Internal Revenue Code of 1986 shall not apply to any transfer after ","children":[{"tag":"date","attrib":{"date":"1996-08-20"},"text":"August 20, 1996","children":[],"tail":", if all applicable reporting requirements under section 6038B of such Code (as amended by this section) are satisfied. The Secretary of the Treasury or his delegate may prescribe simplified reporting requirements under the preceding sentence.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
