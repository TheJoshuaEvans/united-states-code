{"tag":"section","attrib":{"id":"id44003c15-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s724"},"text":null,"children":[{"tag":"num","attrib":{"value":"724"},"text":"§ 724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Character of gain or loss on contributed unrealized receivables, inventory items, and capital loss property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44003c16-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions of unrealized receivables","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any property which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44003c17-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s724/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was contributed to the partnership by a partner, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44003c18-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s724/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was an unrealized receivable in the hands of such partner immediately before such contribution,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"any gain or loss recognized by the partnership on the disposition of such property shall be treated as ordinary income or ordinary loss, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44003c19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions of inventory items","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any property which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44003c1a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s724/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was contributed to the partnership by a partner, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44003c1b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s724/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was an inventory item in the hands of such partner immediately before such contribution,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"any gain or loss recognized by the partnership on the disposition of such property during the 5-year period beginning on the date of such contribution shall be treated as ordinary income or ordinary loss, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44003c1c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s724/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions of capital loss property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any property which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44003c1d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s724/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was contributed by a partner to the partnership, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44003c1e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s724/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was a capital asset in the hands of such partner immediately before such contribution,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"any loss recognized by the partnership on the disposition of such property during the 5-year period beginning on the date of such contribution shall be treated as a loss from the sale of a capital asset to the extent that, immediately before such contribution, the adjusted basis of such property in the hands of the partner exceeded the fair market value of such property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44003c1f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s724/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44003c20-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s724/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unrealized receivable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “unrealized receivable” has the meaning given such term by section 751(c) (determined by treating any reference to the partnership as referring to the partner).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44003c21-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s724/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory item","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “inventory item” has the meaning given such term by section 751(d) (determined by treating any reference to the partnership as referring to the partner and by applying section 1231 without regard to any holding period therein provided).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44003c22-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s724/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substituted basis property","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44003c23-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s724/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any property described in subsection (a), (b), or (c) is disposed of in a nonrecognition transaction, the tax treatment which applies to such property under such subsection shall also apply to any substituted basis property resulting from such transaction. A similar rule shall also apply in the case of a series of non-recognition transactions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44003c24-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s724/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for stock in C corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply to any stock in a C corporation received in an exchange described in section 351.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44003c25-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s74/a"},"text":"Pub. L. 98–369, div. A, title I, § 74(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/592"},"text":"98 Stat. 592","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1704/t/63"},"text":"Pub. L. 104–188, title I, § 1704(t)(63)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1890"},"text":"110 Stat. 1890","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1062/b/3"},"text":"Pub. L. 105–34, title X, § 1062(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/947"},"text":"111 Stat. 947","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44003c26-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44003c27-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44003c28-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" substituted “section 751(d)” for “section 751(d)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" substituted “Subparagraph” for “Subparagaph”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44003c29-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44003c2a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1062/c"},"text":"Pub. L. 105–34, title X, § 1062(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/947"},"text":"111 Stat. 947","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tX/s1062/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section and sections 731, 732, 735, and 751 of this title] shall apply to sales, exchanges, and distributions after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Binding contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section shall not apply to any sale or exchange pursuant to a written binding contract in effect on ","children":[{"tag":"date","attrib":{"date":"1997-06-08"},"text":"June 8, 1997","children":[],"tail":", and at all times thereafter before such sale or exchange.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44003c2b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s74/d/1"},"text":"Pub. L. 98–369, div. A, title I, § 74(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/594"},"text":"98 Stat. 594","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tI/s74/d/1"},"text":"“The amendment made by subsection (a) [enacting this section] shall apply to property contributed to a partnership after ","children":[{"tag":"date","attrib":{"date":"1984-03-31"},"text":"March 31, 1984","children":[],"tail":", in taxable years ending after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
