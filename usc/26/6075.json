{"tag":"section","attrib":{"id":"id468b2cc0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6075"},"text":null,"children":[{"tag":"num","attrib":{"value":"6075"},"text":"§ 6075.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for filing estate and gift tax returns","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id468b2cc1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6075/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estate tax returns","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Returns made under section 6018(a) (relating to estate taxes) shall be filed within 9 months after the date of the decedent’s death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id468b2cc2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6075/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gift tax returns","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id468b2cc3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6075/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Returns made under section 6019 (relating to gift taxes) shall be filed on or before the 15th day of April following the close of the calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id468b2cc4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6075/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension where taxpayer granted extension for filing income tax return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any extension of time granted the taxpayer for filing the return of income taxes imposed by subtitle A for any taxable year which is a calendar year shall be deemed to be also an extension of time granted the taxpayer for filing the return under section 6019 for such calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id468b2cc5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6075/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with due date for estate tax return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraphs (1) and (2), the time for filing the return made under section 6019 for the calendar year which includes the date of death of the donor shall not be later than the time (including extensions) for filing the return made under section 6018 (relating to estate tax returns) with respect to such donor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id468b2cc6-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/751"},"text":"68A Stat. 751","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/614/tI"},"text":"Pub. L. 91–614, title I","children":[],"tail":", §§ 101(b), 102(d)(4), "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1836"},"text":"84 Stat. 1836","children":[],"tail":", 1842; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2008/b"},"text":"Pub. L. 94–455, title XX, § 2008(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1892"},"text":"90 Stat. 1892","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/167/s8/a"},"text":"Pub. L. 96–167, § 8(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1979-12-29"},"text":"Dec. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1277"},"text":"93 Stat. 1277","children":[],"tail":", 1278; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV/s442/d/3"},"text":"Pub. L. 97–34, title IV, § 442(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/322"},"text":"95 Stat. 322","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tV/s542/b/3"},"text":"Pub. L. 107–16, title V, § 542(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/83"},"text":"115 Stat. 83","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/312/tIII/s301/a"},"text":"Pub. L. 111–312, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-17"},"text":"Dec. 17, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3300"},"text":"124 Stat. 3300","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id468b2cc7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id468b2cc8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id468b2cc9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsecs. (a), (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312"},"text":"Pub. L. 111–312","children":[],"tail":" amended subsecs. (a) and (b)(3) to read as if amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/s542/b/3"},"text":"Pub. L. 107–16, § 542(b)(3)","children":[],"tail":", had never been enacted. See 2001 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s542/b/3/A"},"text":"Pub. L. 107–16, § 542(b)(3)(A)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, text read as follows: “Returns made under section 6018(a) (relating to estate taxes) shall be filed within 9 months after the date of the decedent’s death.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s542/b/3/B"},"text":"Pub. L. 107–16, § 542(b)(3)(B)","children":[],"tail":", substituted “section 6018 return” for “estate tax return” in heading and “(relating to returns relating to large transfers at death)” for “(relating to estate tax returns)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" substituted in par. (1) the rule for filing gift tax returns on or before the 15th day of April following the close of the calendar year for prior provision for such filing on or before, in the case of a return for the first, second, or third calendar quarter of any calendar year, the 15th day of the second month following the close of the calendar quarter, or, in the case of a return for the fourth calendar quarter of any calendar year, the 15th day of the fourth month following the close of the calendar quarter, redesignated former par. (3) as (2), and, as so redesignated, substituted “under section 6019 for such calendar year” for “under section 6019 for the fourth calendar quarter of such taxable year”, struck out former par. (2) setting forth special rule where gifts in a calendar quarter totalled $25,000 or less, added par. (3), and struck out par. (4) respecting application of the special rule to nonresidents not citizens of the United States."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/167/s8/a"},"text":"Pub. L. 96–167, § 8(a)","children":[],"tail":", substituted “(A) in the case of a return for the first, second, or third calendar quarter of any calendar year, the 15th day of the second month following the close of the calendar quarter, or” for “the 15th day of the second month following the close of the calendar quarter”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/167/s8/c"},"text":"Pub. L. 96–167, § 8(c)","children":[],"tail":", substituted “the date prescribed by paragraph (1) for filing the return for” for “the 15th day of the second month after” in provisions preceding subpar. (A), and struck out “the close of” before “the first subsequent” in subpar. (a) and before “the fourth calendar quarter” in subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/167/s8/b"},"text":"Pub. L. 96–167, § 8(b)","children":[],"tail":", added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" designated existing provisions as par. (1) and added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614/s101/b"},"text":"Pub. L. 91–614, § 101(b)","children":[],"tail":", substituted “9 months” for “15 months”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614/s102/d/4"},"text":"Pub. L. 91–614, § 102(d)(4)","children":[],"tail":", substituted “the 15th day of the second month following the close of the calendar quarter” for “the 15th day of April following the close of the calendar year”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id468b2cca-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468b2ccb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312"},"text":"Pub. L. 111–312","children":[],"tail":" applicable to estates of decedents dying, and transfers made after "},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"Dec. 31, 2009","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/312/s301/e"},"text":"section 301(e) of Pub. L. 111–312","children":[],"tail":", set out as an Effective and Termination Dates of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s121"},"text":"section 121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468b2ccc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16"},"text":"Pub. L. 107–16","children":[],"tail":" applicable to estates of decedents dying after "},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"Dec. 31, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/s542/f/1"},"text":"section 542(f)(1) of Pub. L. 107–16","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s121"},"text":"section 121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468b2ccd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" applicable with respect to gifts made after "},{"tag":"date","attrib":{"date":"1981-12-31"},"text":"Dec. 31, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/s442/e"},"text":"section 442(e) of Pub. L. 97–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2501"},"text":"section 2501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468b2cce-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/167/s8/d"},"text":"Pub. L. 96–167, § 8(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-29"},"text":"Dec. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1278"},"text":"93 Stat. 1278","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/167/s8/d"},"text":"“The amendments made by this section [amending this section] shall apply to returns for gifts made in calendar years ending after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1979-12-29"},"text":"Dec. 29, 1979","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468b2ccf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2008/d/2"},"text":"Pub. L. 94–455, title XX, § 2008(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1893"},"text":"90 Stat. 1893","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/455/tXX/s2008/d/2"},"text":"“The amendment made by subsection (b) [amending this section] shall apply to gifts made after ","children":[{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468b2cd0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614"},"text":"Pub. L. 91–614","children":[],"tail":" applicable with respect to decedents dying after "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/614/s101/j"},"text":"section 101(j) of Pub. L. 91–614","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2032"},"text":"section 2032 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614"},"text":"Pub. L. 91–614","children":[],"tail":" applicable with respect to gifts made after "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/614/s102/e"},"text":"section 102(e) of Pub. L. 91–614","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2501"},"text":"section 2501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id468b2cd1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Extension of Time For Performing Certain Acts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312/tIII/s301/d/1"},"text":"Pub. L. 111–312, title III, § 301(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-17"},"text":"Dec. 17, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3300"},"text":"124 Stat. 3300","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/312/tIII/s301/d/1"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In the case of the estate of a decedent dying after ","children":[{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":", and before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2010-12-17"},"text":"Dec. 17, 2010","children":[],"tail":"], the due date for—"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" filing any return under section 6018 of the Internal Revenue Code of 1986 (including any election required to be made on such a return) as such section is in effect after the date of the enactment of this Act without regard to any election under subsection (c),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making any payment of tax under chapter 11 of such Code, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making any disclaimer described in section 2518(b) of such Code of an interest in property passing by reason of the death of such decedent,","children":[{"tag":"p","attrib":{},"text":"“shall not be earlier than the date which is 9 months after the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
