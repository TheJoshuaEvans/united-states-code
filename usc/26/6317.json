{"tag":"section","attrib":{"id":"id46c6af53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6317"},"text":null,"children":[{"tag":"num","attrib":{"value":"6317"},"text":"§ 6317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments of Federal unemployment tax for calendar quarter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Payment of Federal unemployment tax for a calendar quarter or other period within a calendar year pursuant to section 6157 shall be considered payment on account of the tax imposed by chapter 23 of such calendar year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id46c6af54-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/53/s2/c"},"text":"Pub. L. 91–53, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-08-07"},"text":"Aug. 7, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/92"},"text":"83 Stat. 92","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/76/tII/s231/b/2/B"},"text":"Pub. L. 98–76, title II, § 231(b)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-12"},"text":"Aug. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/429"},"text":"97 Stat. 429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVII/s7106/c/3"},"text":"Pub. L. 100–647, title VII, § 7106(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3773"},"text":"102 Stat. 3773","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46c6af55-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46c6af56-3a70-11f1-a967-d35dac