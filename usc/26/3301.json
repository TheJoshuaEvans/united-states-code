0/203/tIX/s9153/a"},"text":"Pub. L. 100–203, title IX, § 9153(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-326"},"text":"101 Stat. 1330–326","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11333/a"},"text":"Pub. L. 101–508, title XI, § 11333(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-470"},"text":"104 Stat. 1388–470","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/164/tIV/s402"},"text":"Pub. L. 102–164, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-15"},"text":"Nov. 15, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1061"},"text":"105 Stat. 1061","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13751"},"text":"Pub. L. 103–66, title XIII, § 13751","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/664"},"text":"107 Stat. 664","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1035"},"text":"Pub. L. 105–34, title X, § 1035","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/937"},"text":"111 Stat. 937","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXV/s1501/a"},"text":"Pub. L. 110–140, title XV, § 1501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1800"},"text":"121 Stat. 1800","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dB/tIV/s404/a"},"text":"Pub. L. 110–343, div. B, title IV, § 404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3860"},"text":"122 Stat. 3860","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/92/s10/a"},"text":"Pub. L. 111–92, § 10(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-06"},"text":"Nov. 6, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2988"},"text":"123 Stat. 2988","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/b/37"},"text":"Pub. L. 115–141, div. U, title IV, § 401(b)(37)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1204"},"text":"132 Stat. 1204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id457687f3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id457687f4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id457687f5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “equal to 6 percent of the total wages (as defined in section 3306(b)) paid by such employer during the calendar year with respect to employment (as defined in section 3306(c)).” for “equal to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) 6.2 percent in the case of calendar years 1988 through 2010 and the first 6 months of calendar year 2011; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) 6.0 percent in the case of the remainder of calendar year 2011 and each calendar year thereafter;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"of the total wages (as defined in section 3306(b)) paid by him during the calendar year (or portion of the calendar year) with respect to employment (as defined in section 3306(c)).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/92"},"text":"Pub. L. 111–92","children":[],"tail":" inserted “(or portion of the calendar year)” after “during the calendar year” in concluding provisions and substituted “through 2010 and the first 6 months of calendar year 2011” for “through 2009” in par. (1) and “the remainder of calendar year 2011” for “calendar year 2010” in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/s404/a/1"},"text":"Pub. L. 110–343, § 404(a)(1)","children":[],"tail":", substituted “through 2009” for “through 2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/s404/a/2"},"text":"Pub. L. 110–343, § 404(a)(2)","children":[],"tail":", substituted “calendar year 2010” for “calendar year 2009”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1501/a/1"},"text":"Pub. L. 110–140, § 1501(a)(1)","children":[],"tail":", substituted “2008” for “2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1501/a/2"},"text":"Pub. L. 110–140, § 1501(a)(2)","children":[],"tail":", substituted “2009” for “2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1035/1"},"text":"Pub. L. 105–34, § 1035(1)","children":[],"tail":", substituted “2007” for “1998”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1035/2"},"text":"Pub. L. 105–34, § 1035(2)","children":[],"tail":", substituted “2008” for “1999”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13751/1"},"text":"Pub. L. 103–66, § 13751(1)","children":[],"tail":", substituted “1998” for “1996”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13751/2"},"text":"Pub. L. 103–66, § 13751(2)","children":[],"tail":", substituted “1999” for “1997”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/164/s402/1"},"text":"Pub. L. 102–164, § 402(1)","children":[],"tail":", substituted “1996” for “1995”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/164/s402/2"},"text":"Pub. L. 102–164, § 402(2)","children":[],"tail":", substituted “1997” for “1996”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11333/a/1"},"text":"Pub. L. 101–508, § 11333(a)(1)","children":[],"tail":", substituted “1988 through 1995” for “1988, 1989, and 1990”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11333/a/2"},"text":"Pub. L. 101–508, § 11333(a)(2)","children":[],"tail":", substituted “1996” for “1991”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Pars. (1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" amended pars. (1) and (2) generally. Prior to amendment, pars. (1) and (2) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) 6.2 percent, in the case of a calendar year beginning before the first calendar year after 1976, as of January 1 of which there is not a balance of repayable advances made to the extended unemployment compensation account (established by section 905(a) of the Social Security Act); or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) 6.0 percent, in the case of such first calendar year and each calendar year thereafter;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “unemployment” for “unemployed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s271/c/1/A"},"text":"Pub. L. 97–248, § 271(c)(1)(A)","children":[],"tail":", substituted “6.2 percent” for “3.5 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s271/b/1"},"text":"Pub. L. 97–248, § 271(b)(1)","children":[],"tail":", substituted “3.5 percent” for “3.4 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s271/c/1/B"},"text":"Pub. L. 97–248, § 271(c)(1)(B)","children":[],"tail":", substituted “6.0 percent” for “3.2 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/566"},"text":"Pub. L. 94–566","children":[],"tail":" substituted provisions imposing an excise tax equal to 3.4 percent, in the case of a calendar year beginning before the first calendar year after 1976, as of January 1 of which there is not a balance of repayable advances made to the extended unemployed compensation account (established by section 905(a) of the Social Security Act), or 3.2 percent, in the case of such first calendar year and each calendar year thereafter, of the total wages (as defined in section 3306(b)) paid by him during the calendar year with respect to employment (as defined in section 3306(c)), for provisions imposing an excise tax for the calendar year 1970 and each calendar year thereafter, with respect to having individuals in his employ, equal to 3.2 percent of the total wages (as defined in section 3306(b)) paid by him during the calendar year with respect to employment (as defined in section 3306(c)) and provisions that, in the case of wages paid during the calendar year 1973, the rate of such tax should be 3.28 percent in lieu of 3.2 percent."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted “each calendar year” for “the calendar year 1970 and each calendar year thereafter” and struck out provisions relating to the rate of tax in the case of wages paid during the calendar year 1973."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/329"},"text":"Pub. L. 92–329","children":[],"tail":" inserted provisions setting forth the rate of tax in the case of wages paid during the calendar year 1973."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/373"},"text":"Pub. L. 91–373","children":[],"tail":" increased the rate from 3.1 percent to 3.2 percent and struck out provisions setting special rates for wages paid during 1962 and 1963."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/31"},"text":"Pub. L. 88–31","children":[],"tail":" reduced the tax rate for the year 1963 from 3.5 percent to 3.35 percent."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1961—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/6"},"text":"Pub. L. 87–6","children":[],"tail":" provided for a tax rate of 3.5 percent for calendar years 1962 and 1963."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/778"},"text":"Pub. L. 86–778","children":[],"tail":" substituted “1961” for “1955” and “3.1 percent” for “3 percent”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id457687f6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id457687f7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/92/s10/b"},"text":"Pub. L. 111–92, § 10(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-06"},"text":"Nov. 6, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2989"},"text":"123 Stat. 2989","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/92/s10/b"},"text":"“The amendments made by this section [amending this section] shall apply to wages paid after ","children":[{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id457687f8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dB/tIV/s404/b"},"text":"Pub. L. 110–343, div. B, title IV, § 404(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/386