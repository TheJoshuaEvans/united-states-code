{"tag":"section","attrib":{"id":"id457687f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3301"},"text":null,"children":[{"tag":"num","attrib":{"value":"3301"},"text":"§ 3301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on every employer (as defined in section 3306(a)) for each calendar year an excise tax, with respect to having individuals in his employ, equal to 6 percent of the total wages (as defined in section 3306(b)) paid by such employer during the calendar year with respect to employment (as defined in section 3306(c)).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id457687f2-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/439"},"text":"68A Stat. 439","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/778/tV/s523/a"},"text":"Pub. L. 86–778, title V, § 523(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-13"},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/980"},"text":"74 Stat. 980","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/6/s14/a"},"text":"Pub. L. 87–6, § 14(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-03-24"},"text":"Mar. 24, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/16"},"text":"75 Stat. 16","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/31/s2/a"},"text":"Pub. L. 88–31, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-05-29"},"text":"May 29, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/51"},"text":"77 Stat. 51","children":[],"tail":"; "},{"ta