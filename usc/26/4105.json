{"tag":"section","attrib":{"id":"id45bba7d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4105"},"text":null,"children":[{"tag":"num","attrib":{"value":"4105"},"text":"§ 4105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Two-party exchanges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45bba7d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In a two-party exchange, the delivering person shall not be liable for the tax imposed under section 4081(a)(1)(A)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45bba7d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Two-party exchange","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “two-party exchange” means a transaction, other than a sale, in which taxable fuel is transferred from a delivering person registered under section 4101 as a taxable fuel registrant to a receiving person who is so registered where all of the following occur:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45bba7da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The transaction includes a transfer from the delivering person, who holds the inventory position for taxable fuel in the terminal as reflected in the records of the terminal operator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45bba7db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The exchange transaction occurs before or contemporaneous with completion of removal across the rack from the terminal by the receiving person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45bba7dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4105/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terminal operator in its books and records treats the receiving person as the person that removes the product across the terminal rack for purposes of reporting the transaction to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45bba7dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4105/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The transaction is the subject of a written contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45bba7de-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s866/a"},"text":"Pub. L. 108–357, title VIII, § 866(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1621"},"text":"118 Stat. 1621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45bba7df-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45bba7e0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id45bba7e1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 4111 to 4113, 4121, and 4131 of this title constituted a former subchapter B of this chapter, see Prior Provisions note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4121"},"text":"section 4121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45bba7e2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45bba7e3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s866/c"},"text":"Pub. L. 108–357, title VIII, § 866(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1622"},"text":"118 Stat. 1622","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tVIII/s866/c"},"text":"“The amendment made by this section [enacting this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
