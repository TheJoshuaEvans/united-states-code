{"tag":"section","attrib":{"id":"id46ac9762-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6155"},"text":null,"children":[{"tag":"num","attrib":{"value":"6155"},"text":"§ 6155.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment on notice and demand","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46ac9763-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6155/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receipt of notice and demand from the Secretary, there shall be paid at the place and time stated in such notice the amount of any tax (including any interest, additional amounts, additions to tax, and assessable penalties) stated in such notice and demand.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46ac9764-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6155/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46ac9765-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6155/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For restrictions on assessment and collection of deficiency assessments of taxes subject to the jurisdiction of the Tax Court, see sections 6212 and 6213.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ac9766-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6155/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions relating to assessment of claims allowed in a receivership proceeding, see section 6873.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ac9767-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6155/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions relating to jeopardy assessments, see subchapter A of chapter 70.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46ac9768-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/760"},"text":"68A Stat. 760","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/589/s6/i/7"},"text":"Pub. L. 96–589, § 6(i)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3410"},"text":"94 Stat. 3410","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46ac9769-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46ac976a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46ac976b-3a70-11f1-a96