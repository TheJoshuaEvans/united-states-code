{"tag":"section","attrib":{"id":"id467a63fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050G"},"text":null,"children":[{"tag":"num","attrib":{"value":"6050G"},"text":"§ 6050G.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns relating to certain railroad retirement benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id467a63fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050G/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Railroad Retirement Board shall make a return, according to the forms and regulations prescribed by the Secretary, setting forth—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467a63fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050G/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of benefits paid under the Railroad Retirement Act of 1974 (other than tier 1 railroad retirement benefits, as defined in section 86(d)(4)) to any individual during any calendar year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467a63ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050G/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee contributions which are treated as having been paid for purposes of section 72(r),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467a6400-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050G/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of such individual, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467a6401-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050G/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467a6402-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050G/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements to be furnished to persons with respect to whom information is required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Railroad Retirement Board shall furnish to each individual whose name is required to be set forth in the return under subsection (a) a written statement showing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467a6403-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050G/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of payments to such individual, and of employee contributions with respect thereto, required to be shown on the return, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467a6404-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050G/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The written statement required under the preceding sentence shall be furnished to the individual on or before January 31 of the year following the calendar year for which the return under subsection (a) was required to be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id467a6405-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/76/tII/s224/b/1"},"text":"Pub. L. 98–76, title II, § 224(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-12"},"text":"Aug. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/422"},"text":"97 Stat. 422","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1501/c/10"},"text":"Pub. L. 99–514, title XV, § 1501(c)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2739"},"text":"100 Stat. 2739","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/b/45"},"text":"Pub. L. 115–141, div. U, title IV, § 401(b)(45)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1204"},"text":"132 Stat. 1204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id467a6406-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id467a6407-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id467a6408-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Railroad Retirement Act of 1974, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-29/ch812"},"text":"act Aug. 29, 1935, ch. 812","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/93/445/tI/s101"},"text":"Pub. L. 93–445, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-16"},"text":"Oct. 16, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1305"},"text":"88 Stat. 1305","children":[],"tail":", which is classified generally to subchapter IV (§ 231 et seq.) of chapter 9 of Title 45, Railroads. For further details and complete classification of this Act to the Code, see Codification note set out preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s231"},"text":"section 231 of Title 45","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s231t"},"text":"section 231t of Title 45","children":[],"tail":", and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id467a6409-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" struck out “(to the extent not previously taken into account under section 72(d)(1))” after “contributions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", in amending subsec. (b) generally, substituted “information is required” for “information is furnished” in heading and, in text, substituted references to persons required to make a return for former references to persons making a return and references to persons whose name is required to be set forth for former references to persons whose name is set forth."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id467a640a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id467a640b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" applicable to returns the due date for which (determined without regard to extensions) is after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1501/e"},"text":"section 1501(e) of Pub. L. 99–514","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6721"},"text":"section 6721 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id467a640c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of section applicable to benefits received after ","children":[{"tag":"date","attrib":{"date":"1983-12-31"},"text":"Dec. 31, 1983","children":[],"tail":", in taxable years ending after such date, except for portions of lump-sum payments received after "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"Dec. 31, 1983","children":[],"tail":", if the generally applicable payment date for such portion was before "},{"tag":"date","attrib":{"date":"1984-01-01"},"text":"Jan. 1, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/76/s227/b"},"text":"section 227(b) of Pub. L. 98–76","children":[],"tail":", set out as an Effective Date of 1983 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s72"},"text":"section 72 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id467a640d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that nothing in amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" be construed to affect treatment of certain transactions occurring, property acquired, or items of income, loss, deduction, or credit taken into account prior to "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", for purposes of determining liability for tax for periods ending after "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/e"},"text":"section 401(e) of Pub. L. 115–141","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s23"},"text":"section 23 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
