-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id468d7611-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" substituted “$6” for “$2” and “$3” for “$1” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “allowable under part IV of subchapter A of chapter 1 (other than subpart C thereof” for “allowable under sections 33, 37, 38, 40, 41, 42, 44, 44A, 44B, 44C, 44D, 44E, 44F, 44G, and 44H”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/414"},"text":"Pub. L. 97–414","children":[],"tail":" inserted reference to section 44H."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s331/e/1"},"text":"Pub. L. 97–34, § 331(e)(1)","children":[],"tail":", inserted reference to section 44G."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s221/c/1"},"text":"Pub. L. 97–34, § 221(c)(1)","children":[],"tail":", inserted reference to section 44F."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223"},"text":"Pub. L. 96–223","children":[],"tail":", §§ 231(b)(2), 232(b)(3)(C), inserted reference to sections 44D and 44E."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/618"},"text":"Pub. L. 95–618","children":[],"tail":" inserted reference to section 44C."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/30"},"text":"Pub. L. 95–30","children":[],"tail":" inserted reference to section 44B."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 401(a)(2)(C), 504(c)(2), inserted reference to section 42 in subsec. (a) as in effect on day before date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/94/12"},"text":"Pub. L. 94–12","children":[],"tail":" and reference to section 44A."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/12"},"text":"Pub. L. 94–12","children":[],"tail":" inserted reference to sections 42 and 44."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/53"},"text":"Pub. L. 93–53","children":[],"tail":" struck out “for the account of the candidates of any specified political party for President and Vice President of the United States, or if no specific account is designated by such individual, for a general account for all candidates for election to the offices of President and Vice President of the United States,” after “Fund” and substituted “section 9006(a)” for “section 9006(a)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/53"},"text":"Pub. L. 93–53","children":[],"tail":" struck out reference to sections 32(2) and 35, and inserted reference to sections 40 and 41."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/53"},"text":"Pub. L. 93–53","children":[],"tail":" provided that if designation is made at the time of filing the return of the tax imposed by chapter 1 for the taxable year, the designation shall be made either on the first page of the return or on the page bearing the taxpayer’s signature."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/178"},"text":"Pub. L. 92–178","children":[],"tail":" substituted “$1 shall be paid over to the Presidential Election Campaign Fund for the account of the candidates of any specified political party for President and Vice President of the United States, or if no specific account is designated by such individual, for a general account for all candidates for election to the offices of President and Vice President of the United States, in accordance with the provisions of section 9006(a)(1)” for “$1 shall be paid into the Presidential Election Campaign Fund established by section 303 of the Presidential Election Campaign Fund Act of 1966” and provided, in the case of a joint return of husband and wife having an income tax liability of $2 or more, that each spouse may designate that $1 shall be paid to any such account in the fund."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id468d7612-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468d7613-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"