","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/53/s6/d"},"text":"Pub. L. 93–53, § 6(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-07-01"},"text":"July 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/139"},"text":"87 Stat. 139","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"“The amendments made by this section [amending this section and sections 9003, 9006, 9007, and 9012 of this title] shall apply with respect to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1972-12-31"},"text":"December 31, 1972","children":[],"tail":". Any designation made under section 6096 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] (as in effect for taxable years beginning before "},{"tag":"date","attrib":{"date":"1973-01-01"},"text":"January 1, 1973","children":[],"tail":") for the account of the candidates of any specified political party shall, for purposes of section 9006(a) of such Code (as amended by subsection (b)), be treated solely as a designation to the Presidential Election Campaign Fund.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468d761d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of Section and Effective Date of 1971 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of this section, together with amendment of subsec. (a) of this section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/178"},"text":"Pub. L. 92–178","children":[],"tail":", applicable only to taxable years ending on or after "},{"tag":"date","attrib":{"date":"1972-12-31"},"text":"Dec. 31, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/178/s802/b/2"},"text":"section 802(b)(2) of Pub. L. 92–178","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id468d761e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809/tIII/s302/c"},"text":"Pub. L. 89–809, title III, § 302(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1588"},"text":"80 Stat. 1588","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/809/tIII/s302/c"},"text":"“The amendments made by this section [enacting this section] shall apply with respect to income tax liability for taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1966-12-31"},"text":"December 31, 1966","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id468d761f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809/tIII/s301"},"text":"Pub. L. 89–809, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1587"},"text":"80 Stat. 1587","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/809/tIII/s301"},"text":"“This title [enacting this section and sections 971, 972, and 973 of former Title 31, Money and Finance] may be cited as the ‘Presidential Election Campaign Fund Act of 1966’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id468d7620-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Adoption of Guidelines","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/26/s5"},"text":"Pub. L. 90–26, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-06-13"},"text":"June 13, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/58"},"text":"81 Stat. 58","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds which become available under the Presidential Election Campaign Fund Act of 1966 [this section and section 971 et seq. of former Title 31, Money and Finance] shall be appropriated and disbursed only after the adoption by law of guidelines governing their distribution. Section 6096 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] shall become applicable only after the adoption by law of such guidelines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Guidelines adopted in accordance with this section shall state expressly that they are intended to comply with this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
