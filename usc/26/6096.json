{"tag":"section","attrib":{"id":"id468d7608-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6096"},"text":null,"children":[{"tag":"num","attrib":{"value":"6096"},"text":"§ 6096.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation by individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id468d7609-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6096/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every individual (other than a nonresident alien) whose income tax liability for the taxable year is $3 or more may designate that $3 shall be paid over to the Presidential Election Campaign Fund in accordance with the provisions of section 9006(a). In the case of a joint return of husband and wife having an income tax liability of $6 or more, each spouse may designate that $3 shall be paid to the fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id468d760a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6096/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income tax liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), the income tax liability of an individual for any taxable year is the amount of the tax imposed by chapter 1 on such individual for such taxable year (as shown on his return), reduced by the sum of the credits (as shown in his return) allowable under part IV of subchapter A of chapter 1 (other than subpart C thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id468d760b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6096/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner and time of designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A designation under subsection (a) may be made with respect to any taxable year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id468d760c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6096/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time of filing the return of the tax imposed by chapter 1 for such taxable year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id468d760d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6096/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at any other time (after the time of filing the return of the tax imposed by chapter 1 for such taxable year) specified in regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such designation shall be made in such manner as the Secretary prescribes by regulations except that, if such designation is made at the time of filing the return of the tax imposed by chapter 1 for such taxable year, such designation shall be made either on the first page of the return or on the page bearing the taxpayer’s signature.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id468d760e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809/tIII/s302/a"},"text":"Pub. L. 89–809, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1587"},"text":"80 Stat. 1587","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/178/tVIII/s802/a"},"text":"Pub. L. 92–178, title VIII, § 802(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/573"},"text":"85 Stat. 573","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/53/s6/a"},"text":"Pub. L. 93–53, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-07-01"},"text":"July 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/138"},"text":"87 Stat. 138","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/12/tII"},"text":"Pub. L. 94–12, title II","children":[],"tail":", §§ 203(b)(4), 208(d)(4), "},{"tag":"date","attrib":{"date":"1975-03-29"},"text":"Mar. 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/30"},"text":"89 Stat. 30","children":[],"tail":", 35; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tIV/s401/a/2/C"},"text":"Pub. L. 94–455, title IV, § 401(a)(2)(C)","children":[],"tail":", title V, § 504(c)(2), title XIX, § 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1555"},"text":"90 Stat. 1555","children":[],"tail":", 1565, 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/95/30/tII/s202/d/6"},"text":"Pub. L. 95–30, title II, § 202(d)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-23"},"text":"May 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/151"},"text":"91 Stat. 151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/618/tI/s101/b/4"},"text":"Pub. L. 95–618, title I, § 101(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"