{"tag":"section","attrib":{"id":"id47abb822-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9034"},"text":null,"children":[{"tag":"num","attrib":{"value":"9034"},"text":"§ 9034.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entitlement of eligible candidates to payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47abb823-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9034/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every candidate who is eligible to receive payments under section 9033 is entitled to payments under section 9037 in an amount equal to the amount of each contribution received by such candidate on or after the beginning of the calendar year immediately preceding the calendar year of the presidential election with respect to which such candidate is seeking nomination, or by his authorized committees, disregarding any amount of contributions from any person to the extent that the total of the amounts contributed by such person on or after the beginning of such preceding calendar year exceeds $250. For purposes of this subsection and section 9033(b), the term “contribution” means a gift of money made by a written instrument which identifies the person making the contribution by full name and mailing address, but does not include a subscription, loan, advance, or deposit of money, or anything of value or anything described in subparagraph (B), (C), or (D) of section 9032(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47abb824-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9034/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of payments to which a candidate is entitled under subsection (a) shall not exceed 50 percent of the expenditure limitation applicable under section 315(b)(1)(A) of the Federal Election Campaign Act of 1971.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47abb825-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443/tIV/s408/c"},"text":"Pub. L. 93–443, title IV, § 408(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-15"},"text":"Oct. 15, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1299"},"text":"88 Stat. 1299","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/283/tIII/s307/b"},"text":"Pub. L. 94–283, title III, § 307(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/501"},"text":"90 Stat. 501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/172/s11/a/42/D"},"text":"Pub. L. 110–172, § 11(a)(42)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-29"},"text":"Dec. 29, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2488"},"text":"121 Stat. 2488","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47abb826-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47abb827-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id47abb828-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 315(b)(1)(A) of the Federal Election Campaign Act of 1971, referred to in subsec. (b), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30116/b/1/A"},"text":"section 30116(b)(1)(A) of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47abb829-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172"},"text":"Pub. L. 110–172","children":[],"tail":" substituted “section 315(b)(1)(A)” for “section 320(b)(1)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/283"},"text":"Pub. L. 94–283","children":[],"tail":" substituted “section 320(b)(1)(A) of the Federal Election Campaign Act of 1971” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t18/s608/c/1/A"},"text":"section 608(c)(1)(A) of title 18","children":[],"tail":", United States Code”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47abb82a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47abb82b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/s410/c/1"},"text":"section 410(c)(1) of Pub. L. 93–443","children":[],"tail":", set out as an Effective Date of 1974 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
