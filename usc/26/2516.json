{"tag":"section","attrib":{"id":"id45420a7e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2516"},"text":null,"children":[{"tag":"num","attrib":{"value":"2516"},"text":"§ 2516.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain property settlements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Where a husband and wife enter into a written agreement relative to their marital and property rights and divorce occurs within the 3-year period beginning on the date 1 year before such agreement is entered into (whether or not such agreement is approved by the divorce decree), any transfers of property or interests in property made pursuant to such agreement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45420a7f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2516/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to either spouse in settlement of his or her marital or property rights, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45420a80-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2516/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a reasonable allowance for the support of issue of the marriage during minority,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be deemed to be transfers made for a full and adequate consideration in money or money’s worth.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45420a81-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/409"},"text":"68A Stat. 409","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s425/b"},"text":"Pub. L. 98–369, div. A, title IV, § 425(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/804"},"text":"98 Stat. 804","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45420a82-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45420a83-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45420a84-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted in introductory text “within the 3-year period beginning on the date 1 year before such agreement is entered into” for “within 2 years thereafter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45420a85-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45420a86-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s425/c/2"},"text":"Pub. L. 98–369, div. A, title IV, § 425(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/804"},"text":"98 Stat. 804","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tIV/s425/c/2"},"text":"“The amendment made by subsection (b) [amending this section] shall apply to transfers after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
