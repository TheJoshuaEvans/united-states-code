{"tag":"section","attrib":{"id":"id45a3d963-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3506"},"text":null,"children":[{"tag":"num","attrib":{"value":"3506"},"text":"§ 3506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals providing companion sitting placement services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45a3d964-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subtitle, a person engaged in the trade or business of putting sitters in touch with individuals who wish to employ them shall not be treated as the employer of such sitters (and such sitters shall not be treated as employees of such person) if such person does not pay or receive the salary or wages of the sitters and is compensated by the sitters or the persons who employ them on a fee basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a3d965-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “sitters” means individuals who furnish personal attendance, companionship, or household care services to children or to individuals who are elderly or disabled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a3d966-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to carry out the purpose of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45a3d967-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/171/s10/a"},"text":"Pub. L. 95–171, § 10(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-12"},"text":"Nov. 12, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1356"},"text":"91 Stat. 1356","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45a3d968-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45a3d969-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45a3d96a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/171/s10/c"},"text":"Pub. L. 95–171, § 10(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-12"},"text":"Nov. 12, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1356"},"text":"91 Stat. 1356","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/171/s10/c"},"text":"“The amendments made by this section [enacting this section] shall apply to remuneration received after ","children":[{"tag":"date","attrib":{"date":"1974-12-31"},"text":"December 31, 1974","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id45a3d96b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Unemployment Compensation or Social Security Benefits Based on Services Performed Before ","children":[{"tag":"date","attrib":{"date":"1977-11-12"},"text":"November 12, 1977","children":[],"tail":", Unaffected"}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/171/s10/d"},"text":"Pub. L. 95–171, § 10(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-12"},"text":"Nov. 12, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1356"},"text":"91 Stat. 1356","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/171/s10/d"},"text":"“The amendments made by this section [enacting this section] shall not be construed as affecting (1) any individual’s right to receive unemployment compensation based on services performed before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1977-11-12"},"text":"Nov. 12, 1977","children":[],"tail":"], or (2) any individual’s eligibility for social security benefits to the extent based on services performed before that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
