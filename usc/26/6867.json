{"tag":"section","attrib":{"id":"id47404b0e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867"},"text":null,"children":[{"tag":"num","attrib":{"value":"6867"},"text":"§ 6867.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumptions where owner of large amount of cash is not identified","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47404b0f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the individual who is in physical possession of cash in excess of $10,000 does not claim such cash—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47404b10-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as his, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47404b11-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as belonging to another person whose identity the Secretary can readily ascertain and who acknowledges ownership of such cash,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then, for purposes of sections 6851 and 6861, it shall be presumed that such cash represents gross income of a single individual for the taxable year in which the possession occurs, and that the collection of tax will be jeopardized by delay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47404b12-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules for assessing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any assessment resulting from the application of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47404b13-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entire amount of the cash shall be treated as taxable income for the taxable year in which the possession occurs,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47404b14-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such income shall be treated as taxable at the highest rate of tax specified in section 1, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47404b15-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subsection (c), the possessor of the cash shall be treated (solely with respect to such cash) as the taxpayer for purposes of chapters 63 and 64 and section 7429(a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47404b16-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of later substitution of true owner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, after an assessment resulting from the application of subsection (a), such assessment is abated and replaced by an assessment against the owner of the cash, such later assessment shall be treated for purposes of all laws relating to lien, levy and collection as relating back to the date of the original assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47404b17-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47404b18-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cash","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cash” includes any cash equivalent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47404b19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cash equivalent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “cash equivalent” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47404b1a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign currency,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47404b1b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any bearer obligation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47404b1c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any medium of exchange which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47404b1d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is of a type which has been frequently used in illegal activities, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47404b1e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is specified as a cash equivalent for purposes of this part in regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47404b1f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Value of cash equivalent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any cash equivalent shall be taken into account—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47404b20-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a bearer obligation, at its face amount, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47404b21-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6867/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other cash equivalent, at its fair market value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47404b22-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s330/a"},"text":"Pub. L. 97–248, title III, § 330(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/619"},"text":"96 Stat. 619","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1001/a/1"},"text":"Pub. L. 100–647, title I, § 1001(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3349"},"text":"102 Stat. 3349","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47404b23-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47404b24-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47404b25-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" substituted “the highest rate of tax specified in section 1” for “a 50-percent rate”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47404b26-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47404b27-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47404b28-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s330/c"},"text":"Pub. L. 97–248, title III, § 330(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/620"},"text":"96 Stat. 620","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/248/tIII/s330/c"},"text":"“The amendments made by subsections (a) and (b) [enacting this section] shall take effect on the day after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
