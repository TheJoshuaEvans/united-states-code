{"tag":"section","attrib":{"id":"id47700e67-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523"},"text":null,"children":[{"tag":"num","attrib":{"value":"7523"},"text":"§ 7523.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Graphic presentation of major categories of Federal outlays and income","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47700e68-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any booklet of instructions for Form 1040, 1040A, or 1040EZ prepared by the Secretary for filing individual income tax returns for taxable years beginning in any calendar year, the Secretary shall include in a prominent place—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47700e69-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pie-shaped graph showing the relative sizes of the major outlay categories, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700e6a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pie-shaped graph showing the relative sizes of the major income categories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47700e6b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47700e6c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major outlay categories","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “major outlay categories” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47700e6d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Defense, veterans, and foreign affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e6e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Social security, medicare, and other retirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e6f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Physical, human, and community development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e70-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Social programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e71-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Law enforcement and general government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e72-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interest on the debt.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700e73-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major income categories","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “major income categories” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47700e74-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Social security, medicare, and unemployment and other retirement taxes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Personal income taxes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Corporate income taxes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Borrowing to cover the deficit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Excise, customs, estate, gift, and miscellaneous taxes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700e79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required footnotes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The pie-shaped graph showing the major outlay categories shall include the following footnotes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47700e7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A footnote to the category referred to in paragraph (1)(A) showing the percentage of the total outlays which is for defense, the percentage of total outlays which is for veterans, and the percentage of total outlays which is for foreign affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A footnote to the category referred to in paragraph (1)(C) showing that such category consists of agriculture, natural resources, environment, transportation, education, job training, economic development, space, energy, and general science.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A footnote to the category referred to in paragraph (1)(D) showing the percentage of the total outlays which is for medicaid, supplemental nutrition assistance program benefits, and assistance under a State program funded under part A of title IV of the Social Security Act and the percentage of total outlays which is for public health, unemployment, assisted housing, and social services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700e7d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7523/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data on which graphs are based","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The graphs required under subsection (a) shall be based on data for the most recent fiscal year for which complete data is available as of the completion of the preparation of the instructions by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47700e7e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11622/a"},"text":"Pub. L. 101–508, title XI, § 11622(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-504"},