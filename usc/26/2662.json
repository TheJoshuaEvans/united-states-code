{"tag":"section","attrib":{"id":"id454ba7f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2662"},"text":null,"children":[{"tag":"num","attrib":{"value":"2662"},"text":"§ 2662.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id454ba7f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2662/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe by regulations the person who is required to make the return with respect to the tax imposed by this chapter and the time by which any such return must be filed. To the extent practicable, such regulations shall provide that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454ba7f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2662/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person who is required to make such return shall be the person liable under section 2603(a) for payment of such tax, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454ba7f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2662/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the return shall be filed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id454ba7f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2662/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a direct skip (other than from a trust), on or before the date on which an estate or gift tax return is required to be filed with respect to the transfer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id454ba7f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2662/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in all other cases, on or before the 15th day of the 4th month after the close of the taxable year of the person required to make such return in which such transfer occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454ba7f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2662/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information returns","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may by regulations require a return to be filed containing such information as he determines to be necessary for purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id454ba7f9-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIV/s1431/a"},"text":"Pub. L. 99–514, title XIV, § 1431(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2728"},"text":"100 Stat. 2728","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id454ba7fa-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id454ba7fb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id454ba7fc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to generation-skipping transfers (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s2611"},"text":"section 2611 of this title","children":[],"tail":") made after "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1433"},"text":"section 1433 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2601"},"text":"section 2601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id454ba7fd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Extension of Time for Filing Return","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312/tIII/s301/d/2"},"text":"Pub. L. 111–312, title III, § 301(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-17"},"text":"Dec. 17, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3300"},"text":"124 Stat. 3300","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/312/tIII/s301/d/2"},"text":"“In the case of any generation-skipping transfer made after ","children":[{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":", and before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2010-12-17"},"text":"Dec. 17, 2010","children":[],"tail":"], the due date for filing any return under section 2662 of the Internal Revenue Code of 1986 (including any election required to be made on such a return) shall not be earlier than the date which is 9 months after the date of the enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
