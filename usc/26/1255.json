{"tag":"section","attrib":{"id":"id44cf999e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1255"},"text":null,"children":[{"tag":"num","attrib":{"value":"1255"},"text":"§ 1255.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gain from disposition of section 126 property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44cf999f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1255/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44cf99a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1255/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ordinary income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section, if section 126 property is disposed of, the lower of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44cf99a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1255/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable percentage of the aggregate payments, with respect to such property, excluded from gross income under section 126, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44cf99a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1255/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the excess of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44cf99a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1255/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount realized (in the case of a sale, exchange, or involuntary conversion), or the fair market value of such section 126 property (in the case of any other disposition), over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44cf99a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1255/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjusted basis of such property,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be treated as ordinary income. Such gain shall be recognized notwithstanding any other provision of this subtitle, except that this section shall not apply to the extent such gain is recognized as ordinary income under any other provision of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44cf99a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1255/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 126 property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, “section 126 property” means any property acquired, improved, or otherwise modified by the application of payments excluded from gross income under section 126.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44cf99a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1255/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, if section 126 property is disposed of less than 10 years after the date of receipt of payments excluded from gross income under section 126, the applicable percentage is 100 percent. If section 126 property is disposed of more than 10 years after such date, the applicable percentage is 100 percent reduced (but not below zero) by 10 percent for each year or part thereof in excess of 10 years such property was held after the date of receipt of the payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44cf99a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1255/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44cf99a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1255/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules similar to the rules applicable under section 1245 shall be applied for purposes of this section, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44cf99a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1255/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of sections 170(e) and 751(c), amounts treated as ordinary income under this section shall be treated in the same manner as amounts treated as ordinary income under section 1245.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44cf99aa-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/p