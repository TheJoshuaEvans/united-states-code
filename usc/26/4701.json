{"tag":"section","attrib":{"id":"id45e1cd4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4701"},"text":null,"children":[{"tag":"num","attrib":{"value":"4701"},"text":"§ 4701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on issuer of registration-required obligation not in registered form","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45e1cd4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any person who issues a registration-required obligation which is not in registered form, there is hereby imposed on such person on the issuance of such obligation a tax in an amount equal to the product of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45e1cd4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 percent of the principal amount of such obligation, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e1cd4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of calendar years (or portions thereof) during the period beginning on the date of issuance of such obligation and ending on the date of maturity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45e1cd50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45e1cd51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration-required obligation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45e1cd52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4701/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “registration-required obligation” has the same meaning as when used in section 163(f), except that such term shall not include any obligation which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45e1cd53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4701/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required to be registered under section 149(a), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45e1cd54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4701/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45e1cd55-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4701/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain obligations not included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An obligation is described in this subparagraph if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45e1cd56-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4701/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are arrangements reasonably designed to ensure that such obligation will be sold (or resold in connection with the original issue) only to a person who is not a United States person,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45e1cd57-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4701/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest on such obligation is payable only outside the United States and its possessions, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45e1cd58-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4701/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the face of such obligation there is a statement that any United States person who holds such obligation will be subject to limitations under the United States income tax laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e1cd59-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registered form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “registered form” has the same meaning as when used in section 163(f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45e1cd5a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s310/b/4/A"},"text":"Pub. L. 97–248, title III, § 310(b)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/598"},"text":"96 Stat. 598","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIII/s1301/j/5"},"text":"Pub. L. 99–514, title XIII, § 1301(j)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2657"},"text":"100 Stat. 2657","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/147/tV/s502/e"},"text":"Pub. L. 111–147, title V, § 502(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-18"},"text":"Mar. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/108"},"text":"124 Stat. 108","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45e1cd5b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45e1cd5c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45e1cd5d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/147"},"text":"Pub. L. 111–147","children":[],"tail":" amended par. (1) generally. Prior to amendment, text read as follows: “The term ‘registration-required obligation’ has the same meaning as when used in section 163(f), except that such term shall not include any obligation required to be registered under section 149(a).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “section 149(a)” for “section 103(j)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45e1cd5e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45e1cd5f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/147"},"text":"Pub. L. 111–147","children":[],"tail":" applicable to obligations issued after the date which is 2 years after "},{"tag":"date","attrib":{"date":"2010-03-18"},"text":"Mar. 18, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/147/s502/f"},"text":"section 502(f) of Pub. L. 111–147","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s149"},"text":"section 149 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45e1cd60-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" applicable to bonds issued after "},{"tag":"date","attrib":{"date":"1986-08-15"},"text":"Aug. 15, 1986","children":[],"tail":", except as otherwise provided, see sections 1311 to 1318 of "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", set out as an Effective Date; Transitional Rules note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s141"},"text":"section 141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45e1cd61-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to obligations issued after ","children":[{"tag":"date","attrib":{"date":"1982-12-31"},"text":"Dec. 31, 1982","children":[],"tail":", with an exception for certain warrants, see section 310(d)(1), (3) of "},{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":", set out as an Effective Date of 1982 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s103"},"text":"section 103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
