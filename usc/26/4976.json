{"tag":"section","attrib":{"id":"id460337ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4976"},"text":null,"children":[{"tag":"num","attrib":{"value":"4976"},"text":"§ 4976.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxes with respect to funded welfare benefit plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id460337cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4976/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460337cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4976/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employer maintains a welfare benefit fund, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460337cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4976/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a disqualified benefit provided during any taxable year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"there is hereby imposed on such employer a tax equal to 100 percent of such disqualified benefit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460337ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4976/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualified benefit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460337cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4976/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “disqualified benefit” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460337d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4976/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any post-retirement medical benefit or life insurance benefit provided with respect to a key employee if a separate account is required to be established for such employee under section 419A(d) and such payment is not from such account,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460337d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4976/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any post-retirement medical benefit or life insurance benefit provided with respect to an individual in whose favor discrimination is prohibited unless the plan meets the requirements of section 505(b) with respect to such benefit (whether or not such requirements apply to such plan), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460337d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4976/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any portion of a welfare benefit fund reverting to the benefit of the employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460337d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4976/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for collective bargaining plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1)(B) shall not apply to any plan maintained pursuant to an agreement between employee representatives and 1 or more employers if the Secretary finds that such agreement is a collective bargaining agreement and that the benefits referred to in paragraph (1)(B) were the subject of good faith bargaining between such employee representatives and such employer or employers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460337d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4976/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for nondeductible contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1)(C) shall not apply to any amount attributable to a contribution to the fund which is not allowable as a deduction under section 419 for the taxable year or any prior taxable year (and such contribution shall not be included in any carryover under section 419(d)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460337d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4976/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain amounts charged against existing reserve","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraphs (A) and (B) of paragraph (1) shall not apply to post-retirement benefits charged against an existing reserve for post-retirement medical or life insurance benefits (as defined in section 512(a)(3)(E)) or charged against the income on such reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460337d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4976/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the terms used in this section shall have the same respective meanings as when used in subpart D of part I of subchapter D of chapter 1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id460337d7-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tV/s511/c/1"},"text":"Pub. L. 98–369, div. A, title V, § 511(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/861"},"text":"98 Stat. 861","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1851/a/11"},"text":"Pub. L. 99–514, title XVIII, § 1851(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2861"},"text":"100 Stat. 2861","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1011B/a/27/A"},"text":"Pub. L. 100–647, title I, § 1011B(a)(27)(A)","children":[],"tail":", (B), title III, § 3021(a)(1)(C), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3487"},"text":"102 Stat. 3487","children":[],"tail":", 3626; "},{"tag":"ref","attrib":{"href":"/us/pl/101/140/tII/s203/a/2"},"text":"Pub. L. 101–140, title II, § 203(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-08"},"text":"Nov. 8, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/830"},"text":"103 Stat. 830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id460337d8-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id460337d9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id460337da-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/140"},"text":"Pub. L. 101–140","children":[],"tail":" amended this section to read as if the amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1011B/a/27"},"text":"section 1011B(a)(27) of Pub. L. 100–647","children":[],"tail":" (enacting subsec. (c)) had not been enacted. Subsequent to enactment by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":", subsec. (c) was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s3021/a/1/C"},"text":"Pub. L. 100–647, § 3021(a)(1)(C)","children":[],"tail":". See 1988 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id460337db-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/140"},"text":"Pub. L. 101–140","children":[],"tail":" amended subsec. (b) to read as if amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1011B/a/27/B"},"text":"Pub. L. 100–647, § 1011B(a)(27)(B)","children":[],"tail":", had not been enacted, see 1988 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/140"},"text":"Pub. L. 101–140","children":[],"tail":" amended this section to read as if amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1011B/a/27/A"},"text":"Pub. L. 100–647, § 1011B(a)(27)(A)","children":[],"tail":", had not been enacted, see 1988 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1011B/a/27/B"},"text":"Pub. L. 100–647, § 1011B(a)(27)(B)","children":[],"tail":", added par. (5) relating to limitation in case of benefits to which section 89 applies."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1011B/a/27/A"},"text":"Pub. L. 100–647, § 1011B(a)(27)(A)","children":[],"tail":", added subsec. (c) relating to tax on funded welfare benefit funds which include discriminatory employee benefit plan. Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s3021/a/1/C/i"},"text":"Pub. L. 100–647, § 3021(a)(1)(C)(i)","children":[],"tail":", substituted “any testing year (as defined in section 89(j)(13))” for “any plan year”, see Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s3021/a/1/C/ii"},"text":"Pub. L. 100–647, § 3021(a)(1)(C)(ii)","children":[],"tail":", substituted “testing” for “plan” in cls. (i) and (ii), see Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1011B/a/27/A"},"text":"Pub. L. 100–647, § 1011B(a)(27)(A)","children":[],"tail":", redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “For purposes of subsection (a), the term ‘disqualified benefit’ means—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) any medical benefit or life insurance benefit provided with respect to a key employee other than from a separate account established for such owner under section 419A(d), and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) any post-retirement medical or life insurance benefit unless the plan meets the requirements of section 505(b)(1) with respect to such benefit, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) any portion of such fund reverting to the benefit of the employer.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id460337dc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id460337dd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/140"},"text":"Pub. L. 101–140","children":[],"tail":" effective as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1151"},"text":"section 1151 of Pub. L. 99–514","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/140/s203/c"},"text":"section 203(c) of Pub. L. 101–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s79"},"text":"section 79 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id460337de-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 1011B(a)(27)(A), (B) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s3021/a/1/C"},"text":"section 3021(a)(1)(C) of Pub. L. 100–647","children":[],"tail":" effective as if included in the amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1151"},"text":"section 1151 of Pub. L. 99–514","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s3021/d/1"},"text":"section 3021(d)(1) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s129"},"text":"section 129 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id460337df-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id460337e0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to benefits provided after ","children":[{"tag":"date","attrib":{"date":"1985-12-31"},"text":"Dec. 31, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s511/e/7"},"text":"section 511(e)(7) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s419"},"text":"section 419 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id460337e1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1800–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
