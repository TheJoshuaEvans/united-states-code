{"tag":"section","attrib":{"id":"id43d534e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s581"},"text":null,"children":[{"tag":"num","attrib":{"value":"581"},"text":"§ 581.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For purposes of sections 582 and 584, the term “bank” means a bank or trust company incorporated and doing business under the laws of the United States (including laws relating to the District of Columbia) or of any State, a substantial part of the business of which consists of receiving deposits and making loans and discounts, or of exercising fiduciary powers similar to those permitted to national banks under authority of the Comptroller of the Currency, and which is subject by law to supervision and examination by State or Federal authority having supervision over banking institutions. Such term also means a domestic building and loan association.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id43d534e1-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/202"},"text":"68A Stat. 202","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/722/s5"},"text":"Pub. L. 87–722, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-28"},"text":"Sept. 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/670"},"text":"76 Stat. 670","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1901/c/5"},"text":"Pub. L. 94–455, title XIX, § 1901(c)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1803"},"text":"90 Stat. 1803","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43d534e2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43d534e3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43d534e4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted “or of any State” for “of any State, or of any Territory” after “District of Columbia)” and struck out “, Territorial,” after “examination by State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/722"},"text":"Pub. L. 87–722","children":[],"tail":" substituted “authority of the Comptroller of the Currency” for “section 11(k) of the Federal Reserve Act ("},{"tag":"ref","attrib":{"href":"/us/stat/38/262"},"text":"38 Stat. 262","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s248/k"},"text":"12 U.S.C. 248(k)","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
