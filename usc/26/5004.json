c. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/s807/a/2/C"},"text":"Pub. L. 96–39, § 807(a)(2)(C)","children":[],"tail":", substituted “(3), or (11)” for “or (3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39/s807/a/2/A"},"text":"Pub. L. 96–39, § 807(a)(2)(A)","children":[],"tail":", (B), redesignated subsec. (c) as (b). Former subsec. (b), relating to other property subject to lien, was repealed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/176"},"text":"Pub. L. 95–176","children":[],"tail":" struck out reference to par. (9) of section 5214(a) in subpar. (B), and in subpar. (C) substituted “a customs bonded warehouse” for “customs manufacturing bonded warehouses” and provided for termination of the lien for tax when the distilled spirits are used in certain research, development, or testing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b)(3)(B), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”, wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" substituted “5223(e)” for “5223(d)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4618bb88-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4618bb89-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment",