{"tag":"section","attrib":{"id":"id4618bb7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5004"},"text":null,"children":[{"tag":"num","attrib":{"value":"5004"},"text":"§ 5004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lien for tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4618bb7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distilled spirits subject to lien","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4618bb7d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5004/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by section 5001(a)(1) shall be a first lien on the distilled spirits from the time the spirits are in existence as such until the tax is paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4618bb7e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5004/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The lien imposed by paragraph (1), or any similar lien imposed on the spirits under prior provisions of internal revenue law, shall terminate in the case of distilled spirits produced on premises qualified under internal revenue law for the production of distilled spirits when such distilled spirits are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4618bb7f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5004/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdrawn from bonded premises on determination of tax; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4618bb80-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5004/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdrawn from bonded premises free of tax under provisions of section 5214(a)(1), (2), (3), (11), or (12), or section 7510; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4618bb81-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5004/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exported, deposited in a foreign-trade zone, used in the production of wine, laden as supplies upon, or used in the maintenance or repair of, certain vessels or aircraft, deposited in a customs bonded warehouse, or used in certain research, development, or testing, as provided by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4618bb82-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions relating to extinguishing of lien in case of redistillation, see section 5223(e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4618bb83-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"ta