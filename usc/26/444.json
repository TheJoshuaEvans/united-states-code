{"tag":"section","attrib":{"id":"id4378466b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444"},"text":null,"children":[{"tag":"num","attrib":{"value":"444"},"text":"§ 444.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of taxable year other than required taxable year","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4378466c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, a partnership, S corporation, or personal service corporation may elect to have a taxable year other than the required taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4378466d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on taxable years which may be elected","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4378466e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraphs (2) and (3), an election may be made under subsection (a) only if the deferral period of the taxable year elected is not longer than 3 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4378466f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Changes in taxable year","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (3), in the case of an entity changing a taxable year, an election may be made under subsection (a) only if the deferral period of the taxable year elected is not longer than the shorter of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43784670-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 months, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43784671-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deferral period of the taxable year which is being changed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43784672-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for entities retaining 1986 taxable years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an entity’s 1st taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", an entity may elect a taxable year under subsection (a) which is the same as the entity’s last taxable year beginning in 1986."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43784673-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferral period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, except as provided in regulations, the term “deferral period” means, with respect to any taxable year of the entity, the months between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43784674-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the beginning of such year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43784675-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the close of the 1st required taxable year ending within such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43784676-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of election","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an entity makes an election under subsection (a), then—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43784677-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a partnership or S corporation, such entity shall make the payments required by section 7519, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43784678-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a personal service corporation, such corporation shall be subject to the deduction limitations of section 280H.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43784679-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elections","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4378467a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person making election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under subsection (a) shall be made by the partnership, S corporation, or personal service corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4378467b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of election","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4378467c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any election under subsection (a) shall remain in effect until the partnership, S corporation, or personal service corporation changes its taxable year or otherwise terminates such election. Any change to a required taxable year may be made without the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4378467d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No further election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an election is terminated under subparagraph (A) or paragraph (3)(A), the partnership, S corporation, or personal service corporation may not make another election under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4378467e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tiered structures, etc.","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4378467f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43784680-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no election may be under subsection (a) with respect to any entity which is part of a tiered structure, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43784681-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an election under subsection (a) with respect to any entity shall be terminated if such entity becomes part of a tiered structure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43784682-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions for structures consisting of certain entities with same taxable year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply to any tiered structure which consists only of partnerships or S corporations (or both) all of which have the same taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43784683-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required taxable year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “required taxable year” means the taxable year determined under section 706(b), 1378, or 441(i) without taking into account any taxable year which is allowable by reason of business purposes. Solely for purposes of the preceding sentence, sections 706(b), 1378, and 441(i) shall be treated as in effect for taxable years beginning before ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43784684-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal service corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “personal service corporation” has the meaning given to such term by section 441(i)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43784685-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s444/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to carry out the provisions of this section, including regulations to prevent the avoidance of subsection (b)(2)(B) or (d)(2)(B) through the change in form of an entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43784686-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10206/a/1"},"text":"Pub. L. 100–203, title X, § 10206(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-397"},"text":"101 Stat. 1330–397","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tII/s2004/e/1"},"text":"Pub. L. 100–647, title II, § 2004(e)(1)","children":[],"tail":", (2)(A), (12), (13), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3600"},"text":"102 Stat. 3600","children":[],"tail":", 3602.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43784687-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43784688-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43784689-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/e/1/A"},"text":"Pub. L. 100–647, § 2004(e)(1)(A)","children":[],"tail":", substituted “as otherwise provided in this section” for “as provided in subsections (b) and (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/e/13"},"text":"Pub. L. 100–647, § 2004(e)(13)","children":[],"tail":", inserted “except as provided in regulations,” before “the term”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/e/12"},"text":"Pub. L. 100–647, § 2004(e)(12)","children":[],"tail":", inserted “or otherwise terminates such election” after “its taxable year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/e/1/C"},"text":"Pub. L. 100–647, § 2004(e)(1)(C)","children":[],"tail":", inserted “or paragraph (3)(A)” after “under subparagraph (A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/e/1/B"},"text":"Pub. L. 100–647, § 2004(e)(1)(B)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “No election may be made under subsection (a) with respect to an entity which is part of a tiered structure other than a tiered structure comprised of 1 or more partnerships or S corporations all of which have the same taxable year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/e/2/A"},"text":"Pub. L. 100–647, § 2004(e)(2)(A)","children":[],"tail":", added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4378468a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4378468b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Revenue Act of 1987, "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX"},"text":"Pub. L. 100–203, title X","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/u"},"text":"section 2004(u) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s56"},"text":"section 56 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4378468c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10206/d"},"text":"Pub. L. 100–203, title X, § 10206(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-403"},"text":"101 Stat. 1330–403","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tII/s2004/e/11"},"text":"Pub. L. 100–647, title II, § 2004(e)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3602"},"text":"102 Stat. 3602","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tII/s2004/e/11"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in this subsection, the amendments made by this section [enacting this section and sections 280H and 7519 of this title] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsection (b) [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7519"},"text":"section 7519 of this title","children":[],"tail":"] shall apply to applicable election years beginning after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elections","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any election under section 444 of the Internal Revenue Code of 1986 (as added by subsection (a)) for an entity’s 1st taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", shall not be required to be made before the 90th day after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for existing entities electing s corporation status","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a C corporation (within the meaning of section 1361(a)(2) of the Internal Revenue Code of 1986) with a taxable year other than the calendar year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made an election after ","children":[{"tag":"date","attrib":{"date":"1986-09-18"},"text":"September 18, 1986","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1988-01-01"},"text":"January 1, 1988","children":[],"tail":", under section 1362 of such Code to be treated as an S corporation, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elected to have the calendar year as the taxable year of the S corporation,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then section 444(b)(2)(B) of such Code shall be applied by taking into account the deferral period of the last taxable year of the C corporation rather than the deferral period of the taxable year being changed. The preceding sentence shall apply only in the case of an election under section 444 of such Code made for a taxable year beginning before 1989.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
