{"tag":"section","attrib":{"id":"id45447ba6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2519"},"text":null,"children":[{"tag":"num","attrib":{"value":"2519"},"text":"§ 2519.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dispositions of certain life estates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45447ba7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2519/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter and chapter 11, any disposition of all or part of a qualifying income interest for life in any property to which this section applies shall be treated as a transfer of all interests in such property other than the qualifying income interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45447ba8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2519/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property to which this subsection applies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies to any property if a deduction was allowed with respect to the transfer of such property to the donor—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45447ba9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2519/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under section 2056 by reason of subsection (b)(7) thereof, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45447baa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2519/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under section 2523 by reason of subsection (f) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45447bab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2519/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For right of recovery for gift tax in the case of property treated as transferred under this section, see section 2207A(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45447bac-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV/s403/d/3/B/i"},"text":"Pub. L. 97–34, title IV, § 403(d)(3)(B)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/304"},"text":"95 Stat. 304","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tI/s104/a/3"},"text":"Pub. L. 97–448, title I, § 104(a)(3)","children":[],"tail":", (7), "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2380"},"text":"96 Stat. 2380","children":[],"tail":", 2381.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45447bad-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45447bae-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":nu