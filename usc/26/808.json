{"tag":"section","attrib":{"id":"id440c228d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808"},"text":null,"children":[{"tag":"num","attrib":{"value":"808"},"text":"§ 808.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policyholder dividends deduction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id440c228e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policyholder dividend defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this part, the term “policyholder dividend” means any dividend or similar distribution to policyholders in their capacity as such.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id440c228f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain amounts included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, the term “policyholder dividend” includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id440c2290-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount paid or credited (including as an increase in benefits) where the amount is not fixed in the contract but depends on the experience of the company or the discretion of the management,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440c2291-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" excess interest,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440c2292-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" premium adjustments, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440c2293-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experience-rated refunds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id440c2294-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of deduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The deduction for policyholder dividends for any taxable year shall be an amount equal to the policyholder dividends paid or accrued during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id440c2295-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id440c2296-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “excess interest” means any amount in the nature of interest—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id440c2297-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid or credited to a policyholder in his capacity as such, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id440c2298-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in excess of interest determined at the prevailing State assumed rate for such contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440c2299-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premium adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “premium adjustment” means any reduction in the premium under an insurance or annuity contract which (but for the reduction) would have been required to be paid under the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440c229a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Experience-rated refund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “experience-rated refund” means any refund or credit based on the experience of the contract or group involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id440c229b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of policyholder dividends","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, any policyholder dividend which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id440c229c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increases the cash surrender value of the contract or other benefits payable under the contract, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440c229d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces the premium otherwise required to be paid,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be treated as paid to the policyholder and returned by the policyholder to the company as a premium.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id440c229e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of 1984 fresh-start adjustment with acceleration of policyholder dividends deduction through change in business practice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id440c229f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount determined under paragraph (1) of subsection (c) for the year of change shall (before any reduction under paragraph (2) of subsection (c)) be reduced by so much of the accelerated policyholder dividends deduction for such year as does not exceed the 1984 fresh-start adjustment for policyholder dividends (to the extent such adjustment was not previously taken into account under this subsection).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440c22a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Year of change","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “year of change” means the taxable year in which the change in business practices which results in the accelerated policyholder dividends deduction takes effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440c22a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accelerated policyholder dividends deduction defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “accelerated policyholder dividends deduction” means the amount which (but for this subsection) would be determined for the taxable year under paragraph (1) of subsection (c) but which would have been determined (under such paragraph) for a later taxable year under the business practices of the taxpayer as in effect at the close of the preceding taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440c22a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1984 fresh-start adjustment for policyholder dividends","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “1984 fresh-start adjustment for policyholder dividends” means the amounts held as of ","children":[{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":", by the taxpayer as reserves for dividends to policyholders under section 811(b) (as in effect on the day before the date of the enactment of the Tax Reform Act of 1984) other than for dividends which accrued before "},{"tag":"date","attrib":{"date":"1984-01-01"},"text":"January 1, 1984","children":[],"tail":". Such amounts shall be properly reduced to reflect the amount of previously nondeductible policyholder dividends (as determined under section 809(f) as in effect on the day before the date of the enactment of the Tax Reform Act of 1984)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440e6c93-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate application with respect to lines of business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall be applied separately with respect to each line of business of the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440e6c94-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsection not to apply to mere change in dividend amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not apply to a mere change in the amount of policyholder dividends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440e6c95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsection not to apply to policies issued after ","children":[{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id440e6c96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/f/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not apply to any policyholder dividend paid or accrued with respect to a policy issued after ","children":[{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id440e6c97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/f/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchanges of substantially similar policies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), any policy issued after ","children":[{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":", in exchange for a substantially similar policy issued on or before such date shall be treated as issued before "},{"tag":"date","attrib":{"date":"1984-01-01"},"text":"January 1, 1984","children":[],"tail":". A similar rule shall apply in the case of a series of exchanges."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440e6c98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/f/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsection to apply to policies provided under employee benefit plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not apply to any policyholder dividend paid or accrued with respect to a group policy issued in connection with a plan to provide welfare benefits to employees (within the meaning of section 419(e)(2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id440e6c99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevailing State assumed interest rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id440e6c9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “prevailing State assumed interest rate” means, with respect to any contract, the highest assumed interest rate permitted to be used in computing life insurance reserves for insurance contracts or annuity contracts (as the case may be) under the insurance laws of at least 26 States. For purposes of the preceding sentence, the effect of nonforfeiture laws of a State on interest rates for reserves shall not be taken into account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440e6c9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s808/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" When rate determined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prevailing State assumed interest rate with respect to any contract shall be determined as of the beginning of the calendar year in which the contract was issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id440e6c9c-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tII/s211/a"},"text":"Pub. L. 98–369, div. A, title II, § 211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/732"},"text":"98 Stat. 732","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1821/b"},"text":"Pub. L. 99–514, title XVIII, § 1821(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2838"},"text":"100 Stat. 2838","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/218/tII/s205/b/3"},"text":"Pub. L. 108–218, title II, § 205(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-04-10"},"text":"Apr. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/610"},"text":"118 Stat. 610","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13517/b/1"},"text":"Pub. L. 115–97, title I, § 13517(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2147"},"text":"131 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id440e6c9d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id440e6c9e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id440e6c9f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Tax Reform Act of 1984, referred to in subsec. (f)(4), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id440e6ca0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/218"},"text":"Pub. L. 108–218","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—Except as limited by paragraph (2), the deduction for policyholder dividends for any taxable year shall be an amount equal to the policyholder dividends paid or accrued during the taxable year."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Reduction in case of mutual companies","children":[],"tail":".—In the case of a mutual life insurance company, the deduction for policyholder dividends for any taxable year shall be reduced by the amount determined under section 809.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1821/b"},"text":"Pub. L. 99–514, § 1821(b)","children":[],"tail":", amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “determined at a rate in excess of the prevailing State assumed interest rate for such contract.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1821/c"},"text":"Pub. L. 99–514, § 1821(c)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id440e6ca1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id440e6ca2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", with transition rule and transition relief, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13517/c"},"text":"section 13517(c) of Pub. L. 115–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s807"},"text":"section 807 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id440e6ca3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/218"},"text":"Pub. L. 108–218","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2004-12-31"},"text":"Dec. 31, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/218/s205/c"},"text":"section 205(c) of Pub. L. 108–218","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s807"},"text":"section 807 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id440e6ca4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"r