{"tag":"section","attrib":{"id":"id439014e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464"},"text":null,"children":[{"tag":"num","attrib":{"value":"464"},"text":"§ 464.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on deductions for certain farming expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id439014e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any taxpayer to whom subsection (d) applies, a deduction (otherwise allowable under this chapter) for amounts paid for feed, seed, fertilizer, or other similar farm supplies shall only be allowed for the taxable year in which such feed, seed, fertilizer, or other supplies are actually used or consumed, or, if later, for the taxable year for which allowable as a deduction (determined without regard to this section).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439285e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain poultry expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any taxpayer to whom subsection (d) applies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id439285e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of poultry (including egg-laying hens and baby chicks) purchased for use in a trade or business (or both for use in a trade or business and for sale) shall be capitalized and deducted ratably over the lesser of 12 months or their useful life in the trade or business, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439285e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of poultry purchased for sale shall be deducted for the taxable year in which the poultry is sold or otherwise disposed of.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439285e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to any amount paid for supplies which are on hand at the close of the taxable year on account of fire, storm, or other casualty, or on account of disease or drought.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439285e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain persons prepaying 50 percent or more of certain farming expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id439285e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxpayer to whom subsection applies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection applies to any taxpayer for any taxable year if such taxpayer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439285e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not use an accrual method of accounting,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439285ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has excess prepaid farm supplies for the taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439285eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a qualified farm-related taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439285ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified farm-related taxpayer","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439285ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “qualified farm-related taxpayer” means any farm-related taxpayer if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id439285ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id439285ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/d/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate prepaid farm supplies for the 3 taxable years preceding the taxable year are less than 50 percent of,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id439285f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/d/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate deductible farming expenses (other than prepaid farm supplies) for such 3 taxable years, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439285f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer has excess prepaid farm supplies for the taxable year by reason of any change in business operation directly attributable to extraordinary circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439285f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farm-related taxpayer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph, the term “farm-related taxpayer” means any taxpayer—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id439285f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose principal residence (within the meaning of section 121) is on a farm,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439285f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has a principal occupation of farming, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439285f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a member of the family (within the meaning of section 461(k)(2)(E)) of a taxpayer described in clause (i) or (ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439285f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439285f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess prepaid farm supplies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “excess prepaid farm supplies” means the prepaid farm supplies for the taxable year to the extent the amount of such supplies exceeds 50 percent of the deductible farming expenses for the taxable year (other than prepaid farm supplies).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439285f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prepaid farm supplies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “prepaid farm supplies” means any amounts which are described in subsection (a) or (b) and would be allowable for a subsequent taxable year under the rules of subsections (a) and (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439285f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deductible farming expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “deductible farming expenses” means any amount allowable as a deduction under this chapter (including any amount allowable as a deduction for depreciation or amortization) which is properly allocable to the trade or business of farming.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439285fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s464/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farming","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “farming” means the cultivation of land or the raising or harvesting of any agricultural or horticultural commodity including the raising, shearing, feeding, caring for, training, and management of animals. For purposes of the preceding sentence, trees (other than trees bearing fruit or nuts) shall not be treated as an agricultural or horticultural commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id439285fb-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tII/s207/a/1"},"text":"Pub. L. 94–455, title II, § 207(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1536"},"text":"90 Stat. 1536","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s701"},"text":"Pub. L. 95–600, title VII, § 701","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3), "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2907"},"text":"92 Stat. 2907","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/354/s5/a/30"},"text":"Pub. L. 97–354, § 5(a)(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"Oct. 19, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1695"},"text":"96 Stat. 1695","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tIV/s404/a"},"text":"Pub. L. 99–514, title IV, § 404(a)","children":[],"tail":", (b)(1), title VIII, § 803(b)(8), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2223"},"text":"100 Stat. 2223","children":[],"tail":", 2224, 2356; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1008/a/4"},"text":"Pub. L. 100–647, title I, § 1008(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3437"},"text":"102 Stat. 3437","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tIII/s312/d/1"},"text":"Pub. L. 105–34, title III, § 312(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/839"},"text":"111 Stat. 839","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/58/A"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(58)(A)","children":[],"tail":", (B)(i), (C), (D), "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4047"},"text":"128 Stat. 4047","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/118"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(118)","children":[],"tail":", (119), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1190"},"text":"132 Stat. 1190","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id439285fc-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id439285fd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id439285fe-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/118"},"text":"Pub. L. 115–141, § 401(a)(118)","children":[],"tail":", inserted “expenses” after “farming” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/119"},"text":"Pub. L. 115–141, § 401(a)(119)","children":[],"tail":", substituted “section 461(k)(2)(E)” for “subsection (c)(2)(E)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/a/58/A"},"text":"Pub. L. 113–295, § 221(a)(58)(A)","children":[],"tail":", substituted “any taxpayer to whom subsection (d) applies” for “any farming syndicate (as defined in subsection (c))” in subsec. (a) and in introductory provisions of subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/a/58/C/i"},"text":"Pub. L. 113–295, § 221(a)(58)(C)(i)","children":[],"tail":", redesignated subsec. (d) as (c). Former subsec. (c) transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s461"},"text":"section 461 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/a/58/B/i"},"text":"Pub. L. 113–295, § 221(a)(58)(B)(i)","children":[],"tail":", transferred subsec. (c) defining the term “farming syndicate” to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s461"},"text":"section 461 of this title","children":[],"tail":" and redesignated it as subsec. (j) of that section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/a/58/D"},"text":"Pub. L. 113–295, § 221(a)(58)(D)","children":[],"tail":", struck out “Subsections (a) and (b) to apply to” before “Certain persons” in heading, redesignated pars. (2) to (4) as (1) to (3), respectively, and struck out former par. (1). Prior to amendment, text of par. (1) read as follows: “In the case of a taxpayer to whom this subsection applies, subsections (a) and (b) shall apply to the excess prepaid farm supplies of such taxpayer in the same manner as if such taxpayer were a farming syndicate.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/a/58/C/i"},"text":"Pub. L. 113–295, § 221(a)(58)(C)(i)","children":[],"tail":", redesignated subsec. (f) as (d). Former subsec. (d) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/a/58/C"},"text":"Pub. L. 113–295, § 221(a)(58)(C)","children":[],"tail":", added subsec. (e) and struck out former subsec. (e) which defined the terms “farming” and “limited entrepreneur” for purposes of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/a/58/C/i"},"text":"Pub. L. 113–295, § 221(a)(58)(C)(i)","children":[],"tail":", redesignated subsec. (f) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/a/58/C/i"},"text":"Pub. L. 113–295, § 221(a)(58)(C)(i)","children":[],"tail":", struck out subsec. (g). Text read as follows: “Except as provided in subsection (f), subsections (a) and (b) shall not apply to any taxable year beginning after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (f)(3)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" substituted “section 121” for “section 1034”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s404/b/1"},"text":"Pub. L. 99–514, § 404(b)(1)","children":[],"tail":", substituted “for certain farming” for “in case of farming syndicates” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s803/b/8"},"text":"Pub. L. 99–514, § 803(b)(8)","children":[],"tail":", substituted “Exception” for “Exceptions” as heading and amended text generally. Prior to amendment, text read as follows: “Subsection (a) shall not apply to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) any amount paid for supplies which are on hand at the close of the taxable year on account of fire, storm, flood, or other casualty or on account of disease or drought, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) any amount required to be charged to capital account under section 278.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s404/a"},"text":"Pub. L. 99–514, § 404(a)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (c)(1)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/354"},"text":"Pub. L. 97–354","children":[],"tail":" substituted “an S corporation” for “an electing small business corporation (as defined in section 1371(b))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" substituted in subpar. (E) “(or a spouse of any such member)” for “(within the meaning of section 267(c)(4))” and provided that for purposes of subpar. (E) the term “family” has the meaning given to such term by section 267(c)(4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id439285ff-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","