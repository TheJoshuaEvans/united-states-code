{"tag":"section","attrib":{"id":"id44ff5cac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397C"},"text":"§ 1397C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enterprise zone business defined","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44ff5cad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, the term “enterprise zone business” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ff5cae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any qualified business entity, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5caf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any qualified proprietorship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ff5cb0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified business entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified business entity” means, with respect to any taxable year, any corporation or partnership if for such year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ff5cb1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" every trade or business of such entity is the active conduct of a qualified business within an empowerment zone,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5cb2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 50 percent of the total gross income of such entity is derived from the active conduct of such business,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5cb3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantial portion of the use of the tangible property of such entity (whether owned or leased) is within an empowerment zone,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5cb4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantial portion of the intangible property of such entity is used in the active conduct of any such business,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5cb5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantial portion of the services performed for such entity by its employees are performed in an empowerment zone,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5cb6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 35 percent of its employees are residents of an empowerment zone,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5cb7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than 5 percent of the average of the aggregate unadjusted bases of the property of such entity is attributable to collectibles (as defined in section 408(m)(2)) other than collectibles that are held primarily for sale to customers in the ordinary course of such business, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5cb8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than 5 percent of the average of the aggregate unadjusted bases of the property of such entity is attributable to nonqualified financial property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ff5cb9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified proprietorship","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified proprietorship” means, with respect to any taxable year, any qualified business carried on by an individual as a proprietorship if for such year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ff5cba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 50 percent of the total gross income of such individual from such business is derived from the active conduct of such business in an empowerment zone,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5cbb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantial portion of the use of the tangible property of such individual in such business (whether owned or leased) is within an empowerment zone,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5cbc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantial portion of the intangible property of such business is used in the active conduct of such business,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a5ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantial portion of the services performed for such individual in such business by employees of such business are performed in an empowerment zone,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a5ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 35 percent of such employees are residents of an empowerment zone,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a5af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than 5 percent of the average of the aggregate unadjusted bases of the property of such individual which is used in such business is attributable to collectibles (as defined in section 408(m)(2)) other than collectibles that are held primarily for sale to customers in the ordinary course of such business, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a5b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than 5 percent of the average of the aggregate unadjusted bases of the property of such individual which is used in such business is attributable to nonqualified financial property.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of this subsection, the term “employee” includes the proprietor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4501a5b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified business","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4501a5b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subsection, the term “qualified business” means any trade or business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a5b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rental of real property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rental to others of real property located in an empowerment zone shall be treated as a qualified business if and only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4501a5b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property is not residential rental property (as defined in section 168(e)(2)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4501a5b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 50 percent of the gross rental income from the real property is from enterprise zone businesses.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of subparagraph (B), the lessor of the property may rely on a lessee’s certification that such lessee is an enterprise zone business.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a5b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rental of tangible personal property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rental to others of tangible personal property shall be treated as a qualified business if and only if at least 50 percent of the rental of such property is by enterprise zone businesses or by residents of an empowerment zone.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a5b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of business holding intangibles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified business” shall not include any trade or business consisting predominantly of the development or holding of intangibles for sale or license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a5b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain businesses excluded","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified business” shall not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4501a5b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any trade or business consisting of the operation of any facility described in section 144(c)(6)(B), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4501a5ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any trade or business the principal activity of which is farming (within the meaning of subparagraph (A) or (B) of section 2032A(e)(5)), but only if, as of the close of the taxable year, the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4501a5bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/d/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate unadjusted bases (or, if greater, the fair market value) of the assets owned by the taxpayer which are used in such a trade or business, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4501a5bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/d/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate value of assets leased by the taxpayer which are used in such a trade or business,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"exceeds $500,000.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of subparagraph (B), rules similar to the rules of section 1397(b) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4501a5bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonqualified financial property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “nonqualified financial property” means debt, stock, partnership interests, options, futures contracts, forward contracts, warrants, notional principal contracts, annuities, and other similar property specified in regulations; except that such term shall not include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4501a5be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable amounts of working capital held in cash, cash equivalents, or debt instruments with a term of 18 months or less, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a5bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" debt instruments described in section 1221(a)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4501a5c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of businesses straddling census tract lines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4501a5c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a business entity or proprietorship uses real property located within an empowerment zone,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a5c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the business entity or proprietorship also uses real property located outside the empowerment zone,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a5c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of real property described in paragraph (1) is substantial compared to the amount of real property described in paragraph (2), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a5c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397C/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the real property described in paragraph (2) is contiguous to part or all of the real property described in paragraph (1),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then all the services performed by employees, all business activities, all tangible property, and all intangible property of the business entity or proprietorship that occur in or is located on the real property described in paragraphs (1) and (2) shall be treated as occurring or situated in an empowerment zone.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4501a5c5-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13301/a"},"text":"Pub. L. 103–66, title XIII, § 13301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/552"},"text":"107 Stat. 552","children":[],"tail":", § 1397B; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1703/m"},"text":"Pub. L. 104–188, title I, § 1703(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1877"},"text":"110 Stat. 1877","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tIX/s956/a"},"text":"Pub. L. 105–34, title IX, § 956(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/890"},"text":"111 Stat. 890","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/170/tV/s532/c/4"},"text":"Pub. L. 106–170, title V, § 532(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-17"},"text":"Dec. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1931"},"text":"113 Stat. 1931","children":[],"tail":"; renumbered § 1397C, "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s116/a/2"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 116(a)(2)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–602; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/196"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(196)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1193"},"text":"132 Stat. 1193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4501a5c6-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4501a5c7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"t