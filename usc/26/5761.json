{"tag":"section","attrib":{"id":"id464f8250-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5761"},"text":null,"children":[{"tag":"num","attrib":{"value":"5761"},"text":"§ 5761.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id464f8251-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5761/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitting things required or doing things forbidden","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever willfully omits, neglects, or refuses to comply with any duty imposed upon him by this chapter, or to do, or cause to be done, any of the things required by this chapter, or does anything prohibited by this chapter, shall in addition to any other penalty provided in this title, be liable to a penalty of $1,000, to be recovered, with costs of suit, in a civil action, except where a penalty under subsection (b) or (c) or under section 6651 or 6653 or part II of subchapter A of chapter 68 may be collected from such person by assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464f8252-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5761/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to pay tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever fails to pay any tax imposed by this chapter at the time prescribed by law or regulations, shall, in addition to any other penalty provided in this title, be liable to a penalty of 5 percent of the tax due but unpaid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464f8253-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5761/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of tobacco products and cigarette papers and tubes for export","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsections (b) and (d) of section 5704—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id464f8254-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5761/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" every person who sells, relands, or receives within the jurisdiction of the United States any tobacco products or cigarette papers or tubes which have been labeled or shipped for exportation under this chapter,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464f8255-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5761/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" every person who sells or receives such relanded tobacco products or cigarette papers or tubes, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464f8256-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5761/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" every person who aids or abets in such selling, relanding, or receiving,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall, in addition to the tax and any other penalty provided in this title, be liable for a penalty equal to the greater of $1,000 or 5 times the amount of the tax imposed by this chapter. All tobacco products and cigarette papers and tubes relanded within the jurisdiction of the United States shall be forfeited to the United States and destroyed. All vessels, vehicles, and aircraft used in such relanding or in removing such products, papers, and tubes from the place where relanded, shall be forfeited to the United States. This subsection and section 5754 shall not apply to any person who relands or receives tobacco products in the quantity allowed entry free of tax and duty under subchapter IV of chapter 98 of the Harmonized Tariff Schedule of the United States. No quantity of tobacco products other than the quantity referred to in the preceding sentence may be relanded or received as a personal use quantity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464f8257-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5761/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal use quantities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id464f8258-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5761/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No quantity of tobacco products other than the quantity referred to in paragraph (2) may be relanded or received as a personal use quantity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464f8259-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5761/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for personal use quantity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (c) and section 5754 shall not apply to any person who relands or receives tobacco products in the quantity allowed entry free of tax and duty under chapter 98 of the Harmonized Tariff Schedule of the United States, and such person may voluntarily relinquish to the Secretary at the time of entry any excess of such quantity without incurring the penalty under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id464f825a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5761/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for delivery sales","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id464f825b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5761/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (2) shall not apply to any tobacco product sold in connection with a delivery sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id464f825c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5761/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery sale","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the term “delivery sale” means any sale of a tobacco product to a consumer if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id464f825d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5761/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consumer submits the order for such sale by means of a telephone or other method of voice transmission, the mail, or the Internet or other online service, or the seller is otherwise not in the physical presence of the buyer when the request for purchase or order is made, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id464f825e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5761/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tobacco product is delivered by use of a common carrier, private delivery service, or the mail, or the seller is not in the physical presence of the buyer when the buyer obtains personal possession of the tobacco product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464f825f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5761/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of section 6665","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalties imposed by subsections (b) and (c) shall be assessed, collected, and paid in the same manner as taxes, as provided in section 6665(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464f8260-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5761/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For penalty for failure to make deposits or for over­statement of deposits, see section 6656.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id464f8261-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/717"},"text":"68A Stat. 717","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s202"},"text":"Pub. L. 85–859, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1425"},"text":"72 Stat. 1425","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tVII"},"text":"Pub. L. 97–34, title VII","children":[],"tail":", §§ 722(a)(3), 724(b)(5), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/342"},"text":"95 Stat. 342","children":[],"tail":", 345; "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tI/s107/b"},"text":"Pub. L. 97–448, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2391"},"text":"96 Stat. 2391","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII/s714/h/2"},"text":"Pub. L. 98–369, div. A, title VII, § 714(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/962"},"text":"98 Stat. 962","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7721/c/4"},"text":"Pub. L. 101–239, title VII, § 7721(c)(4)","children":[],"tail":", (5), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2399"},"text":"103 Stat. 2399","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIX/s9302/h/1/B"},"text":"Pub. L. 105–33, title IX, § 9302(h)(1)(B)","children":[],"tail":"–(D), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/673"},"text":"111 Stat. 673","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/476/tIV"},"text":"Pub. L. 106–476, title IV","children":[],"tail":", §§ 4002(c), 4003(a), "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2177"},"text":"114 Stat. 2177","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s315/a/3"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 315(a)(3)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–644; "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dC/tIV/s401/f/1"},"text":"Pub. L. 109–432, div. C, title IV, § 401(f)(1)","children":[],"tail":", (2)(A), "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3049"},"text":"120 Stat. 3049","children":[],"tail":", 3050.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id464f8262-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id464f8263-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id464f8264-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Harmonized Tariff Schedule of the United States, referred to in subsecs. (c) and (d)(2), is not set out in the Code. See Publication of Harmonized Tariff Schedule note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id464f8265-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s401/f/2/A"},"text":"Pub. L. 109–432, § 401(f)(2)(A)","children":[],"tail":", struck out at end “This subsection and section 5754 shall not apply to any person who relands or receives tobacco products in the quantity allowed entry free of tax and duty under chapter 98 of the Harmonized Tariff Schedule of the United States, and such person may voluntarily relinquish to the Secretary at the time of entry any excess of such quantity without incurring the penalty under this subsection. No quantity of tobacco products other than the quantity referred to in the preceding sentence may be relanded or received as a personal use quantity.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s401/f/1"},"text":"Pub. L. 109–432, § 401(f)(1)","children":[],"tail":", added subsec. (d) and redesignated former subsecs. (d) and (e) as (e) and (f), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" inserted at end “This subsection and section 5754 shall not apply to any person who relands or receives tobacco products in the quantity allowed entry free of tax and duty under chapter 98 of the Harmonized Tariff Schedule of the United States, and such person may voluntarily relinquish to the Secretary at the time of entry any excess of such quantity without incurring the penalty under this subsection. No quantity of tobacco products other than the quantity referred to in the preceding sentence may be relanded or received as a personal use quantity.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/476/s4003/a"},"text":"Pub. L. 106–476, § 4003(a)","children":[],"tail":", inserted at end “This subsection and section 5754 shall not apply to any person who relands or receives tobacco products in the quantity allowed entry free of tax and duty under subchapter IV of chapter 98 of the Harmonized Tariff Schedule of the United States. No quantity of tobacco products other than the quantity referred to in the preceding sentence may be relanded or received as a personal use quantity.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/476/s4002/c"},"text":"Pub. L. 106–476, § 4002(c)","children":[],"tail":", which directed amendment of the last sentence of subsec. (c) by substituting “the jurisdiction of the United States shall be forfeited to the United States and destroyed. All vessels, vehicles, and aircraft used in such relanding or in removing such products, papers, and tubes from the place where relanded, shall be forfeited to the United States.” for “the jurisdiction of the United States” and all that followed through the end period, was executed by making the substitution for “the jurisdiction of the United States, and all vessels, vehicles, and aircraft used in such relanding or in removing such products, papers, and tubes from the place where relanded, shall be forfeited to the United States.” in the second sentence of subsec. (c) to reflect the probable intent of Congress and the intervening retroactive amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/106/476/s4003/a"},"text":"Pub. L. 106–476, § 4003(a)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":". See above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s9302/h/1/C"},"text":"Pub. L. 105–33, § 9302(h)(1)(C)","children":[],"tail":", substituted “subsection (b) or (c)” for “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s9302/h/1/B"},"text":"Pub. L. 105–33, § 9302(h)(1)(B)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s9302/h/1/D"},"text":"Pub. L. 105–33, § 9302(h)(1)(D)","children":[],"tail":", substituted “The penalties imposed by subsections (b) and (c)” for “The penalty imposed by subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s9302/h/1/B"},"text":"Pub. L. 105–33, § 9302(h)(1)(B)","children":[],"tail":", redesignated subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s9302/h/1/B"},"text":"Pub. L. 105–33, § 9302(h)(1)(B)","children":[],"tail":", redesignated subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7721/c/4"},"text":"Pub. L. 101–239, § 7721(c)(4)","children":[],"tail":", inserted “or part II of subchapter A of chapter 68” after “or 6653”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7721/c/5"},"text":"Pub. L. 101–239, § 7721(c)(5)","children":[],"tail":", substituted “6665” for “6662” in heading and “6665(a)” for “6662(a)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “section 6662” for “section 6660” in heading and “section 6662(a)” for “section 6660(a)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448"},"text":"Pub. L. 97–448","children":[],"tail":" substituted “section 6660” for “section 6659” in heading, and substituted “section 6660(a)” for “section 6659(a)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s724/b/5"},"text":"Pub. L. 97–34, § 724(b)(5)","children":[],"tail":", added subsec. (c). Former subsec. (c), which related to applicability of section 6656 to failure to make deposit of taxes imposed under subchapter A on the prescribed date and imposition of penalty, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":", §§ 722(a)(3), 724(b)(5), added subsec. (d). Former subsec. (d), which related to applicability of section 6660 and penalties imposed by subsections (b) and (c) to be assessed, collected, and paid in the manner as taxes provided in section 6660(a), was struck out. See subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" struck out reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6652"},"text":"section 6652 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" substituted provisions relating to failure to pay tax for provisions which made persons willfully failing to pay a tax liable, in addition to any other penalty provided in this title, to a penalty of the amount of the tax evaded, or not paid."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" substituted provisions relating to failure to make deposit of taxes for provisions which authorized a penalty of 5 percent of the tax due but unpaid where a person failed to pay tax at the time prescribed, and required the penalties to be added to the tax and assessed and collected at the same time, in the same manner, and as a part of the tax."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" added subsec. (d). Similar provisions were formerly contained in subsec. (c) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id464f8266-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464f8267-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" applicable with respect to goods entered, or withdrawn from warehouse for consumption, on or after the 15th day after "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/s