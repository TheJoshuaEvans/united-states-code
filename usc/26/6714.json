{"tag":"section","attrib":{"id":"id473464aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6714"},"text":null,"children":[{"tag":"num","attrib":{"value":"6714"},"text":"§ 6714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to meet disclosure requirements applicable to quid pro quo contributions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id473464ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6714/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an organization fails to meet the disclosure requirement of section 6115 with respect to a quid pro quo contribution, such organization shall pay a penalty of $10 for each contribution in respect of which the organization fails to make the required disclosure, except that the total penalty imposed by this subsection with respect to a particular fundraising event or mailing shall not exceed $5,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id473464ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6714/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable cause exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed under this section with respect to any failure if it is shown that such failure is due to reasonable cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id473464ad-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13173/b"},"text":"Pub. L. 103–66, title XIII, § 13173(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/456"},"text":"107 Stat. 456","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id473464ae-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id473464af-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id473464b0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 6714 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6715"},"text":"section 6715 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id473464b1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id473464b2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to quid pro quo contributions made on or after ","children":[{"tag":"date","attrib":{"date":"1994-01-01"},"text":"Jan. 1, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13173/d"},"text":"section 13173(d) of Pub. L. 103–66","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6115"},"text":"section 6115 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
