{"tag":"section","attrib":{"id":"id42ad7d36-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306"},"text":null,"children":[{"tag":"num","attrib":{"value":"306"},"text":"§ 306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dispositions of certain stock","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42ad7d37-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a shareholder sells or otherwise disposes of section 306 stock (as defined in subsection (c))—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42ad7d38-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dispositions other than redemptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If such disposition is not a redemption (within the meaning of section 317(b))—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42ad7d39-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount realized shall be treated as ordinary income. This subparagraph shall not apply to the extent that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42ad7d3a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount realized, exceeds","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42ad7d3b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such stock’s ratable share of the amount which would have been a dividend at the time of distribution if (in lieu of section 306 stock) the corporation had distributed money in an amount equal to the fair market value of the stock at the time of distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42ad7d3c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any excess of the amount realized over the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42ad7d3d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount treated under subparagraph (A) as ordinary income, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42ad7d3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjusted basis of the stock,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be treated as gain from the sale of such stock.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42ad7d3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No loss shall be recognized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42ad7d40-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment as dividend","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of section 1(h)(11) and such other provisions as the Secretary may specify, any amount treated as ordinary income under this paragraph shall be treated as a dividend received from the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ad7d41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the disposition is a redemption, the amount realized shall be treated as a distribution of property to which section 301 applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42ad7d42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42ad7d43-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of shareholder’s interest, etc.","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42ad7d44-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Not in redemption","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the disposition—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42ad7d45-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a redemption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42ad7d46-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not, directly or indirectly, to a person the ownership of whose stock would (under section 318(a)) be attributable to the shareholder; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42ad7d47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminates the entire stock interest of the shareholder in the corporation (and for purposes of this clause, section 318(a) shall apply).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42ad7d48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In redemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the disposition is a redemption and paragraph (3) or (4) of section 302(b) applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ad7d49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liquidations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the section 306 stock is redeemed in a distribution in complete liquidation to which part II (sec. 331 and following) applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ad7d4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Where gain or loss is not recognized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that, under any provision of this subtitle, gain or loss to the shareholder is not recognized with respect to the disposition of the section 306 stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ad7d4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transactions not in avoidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If it is established to the satisfaction of the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42ad7d4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the distribution, and the disposition or redemption, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42ad7d4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a prior or simultaneous disposition (or redemption) of the stock with respect to which the section 306 stock disposed of (or redeemed) was issued, that the disposition (or redemption) of the section 306 stock,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"was not in pursuance of a plan having as one of its principal purposes the avoidance of Federal income tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42ad7d4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 306 stock defined","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42ad7d4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the term “section 306 stock” means stock which meets the requirements of subparagraph (A), (B), or (C) of this paragraph.","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42ad7d50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributed to seller","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Stock (other than common stock issued with respect to common stock) which was distributed to the shareholder selling or otherwise disposing of such stock if, by reason of section 305(a), any part of such distribution was not includible in the gross income of the shareholder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42ad7d51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Received in a corporate reorganization or separation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Stock which is not common stock and—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42ad7d52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which was received, by the shareholder selling or otherwise disposing of such stock, in pursuance of a plan of reorganization (within the meaning of section 368(a)), or in a distribution or exchange to which section 355 (or so much of section 356 as relates to section 355) applied, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42ad7d53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the receipt of which gain or loss to the shareholder was to any extent not recognized by reason of part III, but only to the extent that either the effect of the transaction was substantially the same as the receipt of a stock dividend, or the stock was received in exchange for section 306 stock.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of this section, a receipt of stock to which the foregoing provisions of this subparagraph apply shall be treated as a distribution of stock.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42ad7d54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stock having transferred or substituted basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in subparagraph (B), stock the basis of which (in the hands of the shareholder selling or otherwise disposing of such stock) is determined by reference to the basis (in the hands of such shareholder or any other person) of section 306 stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ad7d55-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception where no earnings and profits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “section 306 stock” does not include any stock no part of the distribution of which would have been a dividend at the time of the distribution if money had been distributed in lieu of the stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ad7d56-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain stock acquired in section 351 exchange","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “section 306 stock” also includes any stock which is not common stock acquired in an exchange to which section 351 applied if receipt of money (in lieu of the stock) would have been treated as a dividend to any extent. Rules similar to the rules of section 304(b)(2) shall apply—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42ad7d57-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of the preceding sentence, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42ad7d58-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of determining the application of this section to any subsequent disposition of stock which is section 306 stock by reason of an exchange described in the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ad7d59-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of attribution rules for certain purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraphs (1)(B)(ii) and (3), section 318(a) shall apply. For purposes of applying the preceding sentence to paragraph (3), the rules of section 304(c)(3)(B) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42ad7d5a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stock rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42ad7d5b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stock rights shall be treated as stock, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ad7d5c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stock acquired through the exercise of stock rights shall be treated as stock distributed at the time of the distribution of the stock rights, to the extent of the fair market value of such rights at the time of the distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42ad7d5d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Convertible stock","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (c)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42ad7d5e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if section 306 stock was issued with respect to common stock and later such section 306 stock is exchanged for common stock in the same corporation (whether or not such exchange is pursuant to a conversion privilege contained in the section 306 stock), then (except as provided in paragraph (2)) the common stock so received shall not be treated as section 306 stock; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ad7d5f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" common stock with respect to which there is a privilege of converting into stock other than common stock (or into property), whether or not the conversion privilege is contained in such stock, shall not be treated as common stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42ad7d60-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source of gain","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount treated under subsection (a)(1)(A) as ordinary income shall, for purposes of part I of subchapter N (sec. 861 and following, relating to determination of sources of income), be treated as derived from the same source as would have been the source if money had been received from the corporation as a dividend at the time of the distribution of such stock. If under the preceding sentence such amount is determined to be derived from sources within the United States, such amount shall be considered to be fixed or determinable annual or periodical gains, profits, and income within the meaning of section 871(a) or section 881(a), as the case may be.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42ad7d61-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change in terms and conditions of stock","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a substantial change is made in the terms and conditions of any stock, then, for purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42ad7d62-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of such stock shall be the fair market value at the time of the distribution or at the time of such change, whichever such value is higher;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ad7d63-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such stock’s ratable share of the amount which would have been a dividend if money had been distributed in lieu of stock shall be determined as of the time of distribution or as of the time of such change, whichever such ratable share is higher; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ad7d64-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s306/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (c)(2) shall not apply unless the stock meets the requirements of such subsection both at the time of such distribution and at the time of such change.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id42ad7d65-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/90"},"text":"68A 