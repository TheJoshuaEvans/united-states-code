{"tag":"section","attrib":{"id":"id44d936ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275"},"text":null,"children":[{"tag":"num","attrib":{"value":"1275"},"text":"§ 1275.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions and special rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44d936cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subpart—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d936cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debt instrument","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d936cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the term “debt instrument” means a bond, debenture, note, or certificate or other evidence of indebtedness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d936ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain annuity contracts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “debt instrument” shall not include any annuity contract to which section 72 applies and which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44d936cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depends (in whole or in substantial part) on the life expectancy of 1 or more individuals, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d936d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is issued by an insurance company subject to tax under subchapter L (or by an entity described in section 501(c) and exempt from tax under section 501(a) which would be subject to tax under subchapter L were it not so exempt)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id44d936d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/a/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a transaction in which there is no consideration other than cash or another annuity contract meeting the requirements of this clause,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44d936d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/a/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to the exercise of an election under an insurance contract by a beneficiary thereof on the death of the insured party under such contract, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44d936d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/a/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a transaction involving a qualified pension or employee benefit plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d936d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issue date","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d936d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publicly offered debt instruments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any debt instrument which is publicly offered, the term “date of original issue” means the date on which the issue was first issued to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d936d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issues not publicly offered and not issued for property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any debt instrument to which section 1273(b)(2) applies, the term “date of original issue” means the date on which the debt instrument was sold by the issuer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d936d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other debt instruments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any debt instrument not described in subparagraph (A) or (B), the term “date of original issue” means the date on which the debt instrument was issued in a sale or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d936d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax-exempt obligation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “tax-exempt obligation” means any obligation if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d936d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interest on such obligation is not includible in gross income under section 103, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d936da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interest on such obligation is exempt from tax (without regard to the identity of the holder) under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d936db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of obligations distributed by corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any debt obligation of a corporation distributed by such corporation with respect to its stock shall be treated as if it had been issued by such corporation for property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d936dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of borrower in the case of certain loans for personal use","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d936dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sections 1274 and 483 not to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of the obligor under any debt instrument given in consideration for the sale or exchange of property, sections 1274 and 483 shall not apply if such property is personal use property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d936de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Original issue discount deducted on cash basis in certain cases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any debt instrument, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d936df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such instrument—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44d936e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is incurred in connection with the acquisition or carrying of personal use property, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d936e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has original issue discount (determined after the application of paragraph (1)), and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d936e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the obligor under such instrument uses the cash receipts and disbursements method of accounting,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"notwithstanding section 163(e), the original issue discount on such instrument shall be deductible only when paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d936e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal use property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “personal use property” means any property substantially all of the use of which by the taxpayer is not in connection with a trade or business of the taxpayer or an activity described in section 212. The determination of whether property is described in the preceding sentence shall be made as of the time of issuance of the debt instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d936e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d936e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information required to be set forth on instrument","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d936e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any debt instrument having original issue discount, the Secretary may by regulations require that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44d936e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the original issue discount, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d936e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issue date,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"be set forth on such instrument.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d936e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for instruments not publicly offered","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any issue of debt instruments not publicly offered, the regulations prescribed under subparagraph (A) shall not require the information to be set forth on the debt instrument before any disposition of such instrument by the first buyer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d936ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information required to be submitted to Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any issue of publicly offered debt instruments having original issue discount, the issuer shall (at such time and in such manner as the Secretary shall by regulation prescribe) furnish the Secretary the following information:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d936eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of the original issue discount.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d936ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The issue date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d936ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other information with respect to the issue as the Secretary may by regulations require.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of the preceding sentence, any person who makes a public offering of stripped bonds (or stripped coupons) shall be treated as the issuer of a publicly offered debt instrument having original issue discount.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d936ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not apply to any obligation referred to in section 1272(a)(2) (relating to exceptions from current inclusion of original issue discount).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d936ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For civil penalty for failure to meet requirements of this subsection, see section 6706.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d936f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1275/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prescribe regulations providing that where, by reason of varying rates of interest, put or call options, indefinite maturities, contingent payments, assumptions of debt instruments, or other circumstances, the tax treatment under this subpart (or section 163(e)) does not carry out the purposes of this subpart (or section 163(e)), such treatment shall be modified to the extent appropriate to carry out the purposes of this subpart (or section 163(e)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44d936f1-3a70-11f1-a967-d35dac11796a"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI"},"text":"Pub. L. 98–369, div. A, title I","children":[],"tail":", §§ 41(a), 61(c)(2), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/540"},"text":"98 Stat. 540","children":[],"tail":", 581; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1804/f/2/A"},"text":"Pub. L. 99–514, title XVIII, § 1804(f)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2805"},"text":"100 Stat. 2805","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/u/4"},"text":"Pub. L. 100–647, title I, § 1006(u)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3427"},"text":"102 Stat. 3427","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11325/a/2"},"text":"Pub. L. 101–508, title XI, § 11325(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-466"},"text":"104 Stat. 1388–466","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s318/c/1"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 318(c)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–645.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44d936f2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44d936f3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44db7fe4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":", in introductory provisions, substituted “subchapter L (or by an entity described in section 501(c) and exempt from tax under section 501(a) which would be subject to tax under subchapter L were it not so exempt)” for “subchapter L”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/