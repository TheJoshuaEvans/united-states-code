{"tag":"section","attrib":{"id":"id475cfae3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7454"},"text":null,"children":[{"tag":"num","attrib":{"value":"7454"},"text":"§ 7454.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Burden of proof in fraud, foundation man­ager, and transferee cases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id475cfae4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7454/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraud","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any proceeding involving the issue whether the petitioner has been guilty of fraud with intent to evade tax, the burden of proof in respect of such issue shall be upon the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id475cfae5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7454/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foundation managers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any proceeding involving the issue whether a foundation manager (as defined in section 4946(b)) has “knowingly” participated in an act of self-dealing (within the meaning of section 4941), participated in an investment which jeopardizes the carrying out of exempt purposes (within the meaning of section 4944), or agreed to the making of a taxable expenditure (within the meaning of section 4945), or whether the trustee of a trust described in section 501(c)(21) has “knowingly” participated in an act of self-dealing (within the meaning of section 4951) or agreed to the making of a taxable expenditure (within the meaning of section 4952), or whether an organization manager (as defined in section 4955(f)(2)) has “knowingly” agreed to the making of a political expenditure (within the meaning of section 4955), or whether an organization manager (as defined in section 4912(d)(2)) has “knowingly” agreed to the making of disqualifying lobbying expenditures within the meaning of section 4912(b), or whether an organization manager (as defined in section 4958(f)(2)) has “knowingly” participated in an excess benefit transaction (as defined in section 4958(c)), the burden of proof in respect of such issue shall be upon the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id475f6be6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7454/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions relating to burden of proof as to transferee liability, see section 6902(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id475f6be7-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/884"},"text":"68A Stat. 884","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tI/s101/j/57"},"text":"Pub. L. 91–172, title I, § 101(j)(57)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/532"},"text":"83 Stat. 532","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},