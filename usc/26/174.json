{"tag":"section","attrib":{"id":"id4208ffb9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s174"},"text":null,"children":[{"tag":"num","attrib":{"value":"174"},"text":"§ 174.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amortization of research and experimental expenditures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4208ffba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s174/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a taxpayer’s foreign research or experimental expenditures for any taxable year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4208ffbb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s174/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in paragraph (2), no deduction shall be allowed for such expenditures, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4208ffbc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s174/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the taxpayer shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4208ffbd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s174/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charge such expenditures to capital account, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4208ffbe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s174/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be allowed an amortization deduction of such expenditures ratably over the 15-year period beginning with the midpoint of the taxable year in which such expenditures are paid or incurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4208ffbf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s174/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign research or experimental expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “foreign research or experimental expenditures” means, with respect to any taxable year, research or experimental expenditures which are paid or incurred by the taxpayer during such taxable year in connection with the taxpayer’s trade or business and which are attributable to foreign research (within the meaning of section 41(d)(4)(F)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4208ffc0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s174/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4208ffc1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s174/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land and other property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to any expenditure for the acquisition or improvement of land, or for the acquisition or improvement of property to be used in connection with the research or experimentation and of a character which is subject to the allowance under section 167 (relating to allowance for depreciation, etc.) or section 611 (relating to allowance for depletion); but for purposes of this section allowances under section 167, and allowances under section 611, shall be considered as expenditures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4208ffc2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s174/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exploration expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to any expenditure paid or incurred for the purpose of ascertaining the existence, location, extent, or quality of any deposit of ore or other mineral (including oil and gas).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4208ffc3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s174/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Software development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, any amount paid or incurred in connection with the development of any software shall be treated as a research or experimental expenditure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4208ffc4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s174/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment upon disposition, retirement, or abandonment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any property with respect to which foreign research or experimental expenditures are paid or incurred is disposed, retired, or abandoned during the period during which such expenditures are allowed as an amortization deduction under this section, no deduction or reduction to amount realized shall be allowed with respect to such expenditures on account of such disposition, retirement, or abandonment and such amortization deduction shall continue with respect to such expenditures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4208ffc5-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/66"},"text":"68A Stat. 66","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1901(a)(30), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1769"},"text":"90 Stat. 1769","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tII/s201/d/9/B"},"text":"Pub. L. 97–248, title II, § 201(d)(9)(B)","children":[],"tail":" formerly § 201(c)(9)(B), "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/420"},"text":"96 Stat. 420","children":[],"tail":", renumbered § 201(d)(9)(B), "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tIII/s306/a/1/A/i"},"text":"Pub. L. 97–448, title III, § 306(a)(1)(A)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2400"},"text":"96 Stat. 2400","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVII/s701/e/4/D"},"text":"Pub. L. 99–514, title VII, § 701(e)(4)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2343"},"text":"100 Stat. 2343","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1007/g/5"},"text":"Pub. L. 100–647, title I, § 1007(g)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3435"},"text":"102 Stat. 3435","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7110/d"},"text":"Pub. L. 101–239, title VII, § 7110(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2325"},"text":"103 Stat. 2325","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/31"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(31)","children":[],"tail":", (32), "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4042"},"text":"128 Stat. 4042","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13206/a"},"text":"Pub. L. 115–97, title I, § 13206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2111"},"text":"131 Stat. 2111","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70302/b/1"},"text":"Pub. L. 119–21, title VII, § 70302(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/191"},"text":"139 Stat. 191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4208ffc6-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4208ffc7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4208ffc8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70302/b/1/A/i"},"text":"Pub. L. 119–21, § 70302(b)(1)(A)(i)","children":[],"tail":", substituted “a taxpayer’s foreign research or experimental expenditures” for “a taxpayer’s specified research or experimental expenditures” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70302/b/1/A/ii"},"text":"Pub. L. 119–21, § 70302(b)(1)(A)(ii)","children":[],"tail":", substituted “over the 15-year period” for “over the 5-year period (15-year period in the case of any specified research or experimental expenditures which are attributable to foreign research (within the meaning of section 41(d)(4)(F)))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70302/b/1/B"},"text":"Pub. L. 119–21, § 70302(b)(1)(B)","children":[],"tail":", substituted “Foreign” for “Specified” in heading and “foreign research” for “specified research” in text and inserted before period at end “and which are attributable to foreign research (within the meaning of section 41(d)(4)(F))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70302/b/1/C"},"text":"Pub. L. 119–21, § 70302(b)(1)(C)","children":[],"tail":", substituted “foreign research or experimental expenditures” for “specified research or experimental expenditures” and inserted “or reduction to amount realized” after “no deduction”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) to (f) relating to treatment of research and experimental expenditures as expenses, amortization of certain research and experimental expenditures, expenditure for the acquisition or improvement of land or property, ore and mineral deposit exploration expenditures, limitation to reasonable research expenditures eligible, and cross references, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/a/31"},"text":"Pub. L. 113–295, § 221(a)(31)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, text read as follows: “A taxpayer may, without the consent of the Secretary, adopt the method provided in this subsection for his first taxable year—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) which begins after ","children":[{"tag":"date","attrib":{"date":"1953-12-31"},"text":"December 31, 1953","children":[],"tail":", and ends after "},{"tag":"date","attrib":{"date":"1954-08-16"},"text":"August 16, 1954","children":[],"tail":", and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) for which expenditures described in paragraph (1) are paid or incurred.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/a/32"},"text":"Pub. L. 113–295, § 221(a)(32)","children":[],"tail":", struck out “beginning after "},{"tag":"date","attrib":{"date":"1953-12-31"},"text":"December 31, 1953","children":[],"tail":"” after “for any taxable year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" added subsec. (e) and redesignated former subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" substituted “section 59(e)” for “section 59(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “section 59(d)” for “section 58(i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s201/d/9/B"},"text":"Pub. L. 97–248, § 201(d)(9)(B)","children":[],"tail":", substituted “Cross references” for “Cross reference” in heading, designated existing provisions as par. (1), and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/a/30"},"text":"Pub. L. 94–455, § 1901(a)(30)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1954-08-16"},"text":"August 16, 1954","children":[],"tail":"” for “the date on which this title is enacted” after “ends after”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a)(3), (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4208ffc9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4208ffca-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" applicable to amounts paid or incurred in taxable years beginning after "},{"tag":"date","attrib":{"date":"2024-12-31"},"text":"Dec. 31, 2024","children":[],"tail":", except amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70302/b/1/C/ii"},"text":"section 70302(b)(1)(C)(ii) of Pub. L. 119–21","children":[],"tail":" shall apply to property disposed, retired, or abandoned after "},{"tag":"date","attrib":{"date":"2025-05-12"},"text":"May 12, 2025","children":[],"tail":", subject to election for retroactive application by certain small businesses and election to deduct certain unamortized amounts paid or incurred in taxable years beginning before "},{"tag":"date","attrib":{"date":"2025-01-01"},"text":"Jan. 1, 2025","children":[],"tail":", see section 70302(e), (f) of "},{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s174A"},"text":"section 174A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4208ffcb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment; Applicability of Change in Method of Accounting","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13206/b"},"text":"Pub. L. 115–97, title I, § 13206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2112"},"text":"131 Stat. 2112","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/97/tI/s13206/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendments made by subsection (a) [amending this section] shall be treated as a change in method of accounting for purposes of section 481 of the Internal Revenue Code of 1986 and—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such change shall be treated as initiated by the taxpayer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such change shall be treated as made with the consent of the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such change shall be applied only on a cut-off basis for any research or experimental expenditures paid or incurred in taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"December 31, 2021","children":[],"tail":", and no adjustments under section 481(a) shall be made.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag