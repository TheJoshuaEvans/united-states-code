{"tag":"section","attrib":{"id":"id4531681b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2043"},"text":null,"children":[{"tag":"num","attrib":{"value":"2043"},"text":"§ 2043.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers for insufficient consideration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4531681c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2043/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any one of the transfers, trusts, interests, rights, or powers enumerated and described in sections 2035 to 2038, inclusive, and section 2041 is made, created, exercised, or relinquished for a consideration in money or money’s worth, but is not a bona fide sale for an adequate and full consideration in money or money’s worth, there shall be included in the gross estate only the excess of the fair market value at the time of death of the property otherwise to be included on account of such transaction, over the value of the consideration received therefor by the decedent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4531681d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2043/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marital rights not treated as consideration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4531681e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2043/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, a relinquishment or promised relinquishment of dower or curtesy, or of a statutory estate created in lieu of dower or curtesy, or of other marital rights in the decedent’s property or estate, shall not be considered to any extent a consideration “in money or money’s worth”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4531681f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2043/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 2053 (relating to expenses, indebtedness, and taxes), a transfer of property which satisfies the requirements of paragraph (1) of section 2516 (relating to certain property settlements) shall be considered to be made for an adequate and full consideration in money or money’s worth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45316820-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/388"},"text":"68A Stat. 388","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s425/a/1"},"text":"Pub. L. 98–369, div. A, title IV, § 425(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/803"},"text":"98 Stat. 803","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45316821-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45316822-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45316823-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" amended subsec. (b) generally, designating existing provisions as par. (1) and adding par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45316824-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45316825-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s425/c/1"},"text":"Pub. L. 98–369, div. A, title IV, § 425(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/804"},"text":"98 Stat. 804","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tIV/s425/c/1"},"text":"“The amendments made by subsection (a) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s2053"},"text":"section 2053 of this title","children":[],"tail":"] shall apply to estates of decedents dying after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
