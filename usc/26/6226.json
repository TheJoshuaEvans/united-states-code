{"tag":"section","attrib":{"id":"id46bfa96a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226"},"text":null,"children":[{"tag":"num","attrib":{"value":"6226"},"text":"§ 6226.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative to payment of imputed underpayment by partnership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46bfa96b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the partnership—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46bfa96c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 45 days after the date of the notice of final partnership adjustment, elects the application of this section with respect to an imputed underpayment, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bfa96d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at such time and in such manner as the Secretary may provide, furnishes to each partner of the partnership for the reviewed year and to the Secretary a statement of the partner’s share of any adjustment to a partnership-related item (as determined in the notice of final partnership adjustment),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"section 6225 shall not apply with respect to such underpayment (and no assessment of tax, levy, or proceeding in any court for the collection of such underpayment shall be made against such partnership) and each such partner shall take such adjustment into account as provided in subsection (b). The election under paragraph (1) shall be made in such manner as the Secretary may provide and, once made, shall be revocable only with the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bfa96e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments taken into account by partner","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46bfa96f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax imposed in year of statement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (4), each partner’s tax imposed by chapter 1 for the taxable year which includes the date the statement was furnished under subsection (a) shall be adjusted by the aggregate of the correction amounts determined under paragraph (2) for the taxable years referred to therein.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bfa970-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The correction amounts determined under this paragraph are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46bfa971-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the taxable year of the partner which includes the end of the reviewed year, the amount by which the tax imposed under chapter 1 would increase or decrease if the partner’s share of the adjustments described in subsection (a) were taken into account for such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bfa972-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any taxable year after the taxable year referred to in subparagraph (A) and before the taxable year referred to in paragraph (1), the amount by which the tax imposed under chapter 1 would increase or decrease by reason of the adjustment to tax attributes under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bfa973-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of tax attributes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any tax attribute which would have been affected if the adjustments described in subsection (a) were taken into account for the taxable year referred to in paragraph (2)(A) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46bfa974-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any taxable year referred to in paragraph (2)(B), be appropriately adjusted for purposes of applying such paragraph, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bfa975-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any subsequent taxable year, be appropriately adjusted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bfa976-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of partnerships and S corporations in tiered structures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46bfa977-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a partner which receives a statement under subsection (a)(2) is a partnership or an S corporation, such partner shall, with respect to the partner’s share of the adjustment—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46bfa978-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file with the Secretary a partnership adjustment tracking report which includes such information as the Secretary may require, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46bfa979-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id46bfa97a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/b/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish statements under rules similar to the rules of subsection (a)(2), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id46bfa97b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/b/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if no such statements are furnished, compute and pay an imputed underpayment under rules similar to the rules of section 6225 (other than paragraphs (2), (7), and (9) of subsection (c) thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bfa97c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Due date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), with respect to a partner’s share of the adjustment, the partnership adjustment tracking report shall be filed, and the imputed underpayment shall be paid or statements shall be furnished, not later than the due date for the return for the adjustment year of the audited partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bfa97d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership payment of tax if elected out of subchapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a partnership which has elected the application of section 6221(b) with respect to the taxable year of the partnership which includes the end of the reviewed year of the audited partnership, this paragraph shall apply notwithstanding such election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bfa97e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audited partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the term “audited partnership” means, with respect to any partner described in subparagraph (A), the partnership in the chain of ownership originally electing the application of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bfa97f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of trusts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such rules as may be necessary with respect to trusts which receive a statement under subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bfa980-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties and interest","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46bfa981-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsections (a) and (b), any penalties, additions to tax, or additional amount shall be determined as provided under section 6221 and the partners of the partnership for the reviewed year shall be liable for any such penalty, addition to tax, or additional amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bfa982-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an imputed underpayment with respect to which the application of this section is elected, or which is described in subsection (b)(4)(A)(ii)(I), interest shall be determined—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46bfa983-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the partner level,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bfa984-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the due date of the return for the taxable year to which the increase is attributable (determined by taking into account any increases attributable to a change in tax attributes for a taxable year under subsection (b)(2)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bfa985-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the underpayment rate under section 6621(a)(2), determined by substituting “5 percentage points” for “3 percentage points” in subparagraph (B) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bfa986-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6226/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the time period within which a partnership may file a petition for a readjustment, see section 6234(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46bfa987-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/74/tXI/s1101/c/1"},"text":"Pub. L. 114–74, title XI, § 1101(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/630"},"text":"129 Stat. 630","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tIV/s411/b/1"},"text":"Pub. L. 114–113, div. Q, title IV, § 411(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3122"},"text":"129 Stat. 3122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tII"},"text":"Pub. L. 115–141, div. U, title II","children":[],"tail":", §§ 201(c)(4), 204, 206(d), (e), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1173"},"text":"132 Stat. 1173","children":[],"tail":", 1176, 1178.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46bfa988-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46bfa989-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46bfa98a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6226, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIV/s402/a"},"text":"Pub. L. 97–248, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/653"},"text":"96 Stat. 653","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tIII/s306/c/1/A"},"text":"Pub. L. 97–448, title III, § 306(c)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2406"},"text":"96 Stat. 2406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/b/2"},"text":"Pub. L. 102–572, title IX, § 902(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXII"},"text":"Pub. L. 105–34, title XII","children":[],"tail":", §§ 1238(b)(1), 1239(b), 1240(a), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1026-1028"},"text":"111 Stat. 1026–1028","children":[],"tail":", related to judicial review of final partnership administrative adjustments, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/74/tXI/s1101/a"},"text":"Pub. L. 114–74, title XI, § 1101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/625"},"text":"129 Stat. 625","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46bfa98b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/d"},"text":"Pub. L. 115–141, § 206(d)","children":[],"tail":", inserted “(and no assessment of tax, levy, or proceeding in any court for the collection of such underpayment shall be made against such partnership)” after “section 6225 shall not apply with respect to such underpayment” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s201/c/4"},"text":"Pub. L. 115–141, § 201(c)(4)","children":[],"tail":", substituted “any adjustment to a partnership-related item” for “any adjustment to income, gain, loss, deduction, or credit”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/e/2"},"text":"Pub. L. 115–141, § 206(e)(2)","children":[],"tail":", substituted “correction amounts” for “adjustment amounts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/e/1"},"text":"Pub. L. 115–141, § 206(e)(1)","children":[],"tail":", substituted “adjusted” for “increased”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s204/b/1"},"text":"Pub. L. 115–141, § 204(b)(1)","children":[],"tail":", substituted “Except as provided in paragraph (4), each partner’s” for “Each partner’s”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/e/5"},"text":"Pub. L. 115–141, § 206(e)(5)","children":[],"tail":", substituted “Correction amounts” for “Adjustment amounts” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/e/3"},"text":"Pub. L. 115–141, § 206(e)(3)","children":[],"tail":", substituted “increase or decrease” for “increase” in subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/e/2"},"text":"Pub. L. 115–141, § 206(e)(2)","children":[],"tail":", substituted “correction amounts” for “adjustment amounts” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s206/e/4"},"text":"Pub. L. 115–141, § 206(e)(4)","children":[],"tail":", substituted “and” for “plus” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s204/a"},"text":"Pub. L. 115–141, § 204(a)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s204/b/2"},"text":"Pub. L. 115–141, § 204(b)(2)","children":[],"tail":", inserted “or which is described in subsection (b)(4)(A)(ii)(I),” after “is elected,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/