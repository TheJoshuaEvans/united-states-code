{"tag":"section","attrib":{"id":"id46164aa5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D"},"text":null,"children":[{"tag":"num","attrib":{"value":"5000D"},"text":"§ 5000D.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated drugs during noncompliance periods","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46164aa6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby imposed on the sale by the manufacturer, producer, or importer of any designated drug during a day described in subsection (b) a tax in an amount such that the applicable percentage is equal to the ratio of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46164aa7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such tax, divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46164aa8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of such tax and the price for which so sold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46164aa9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance periods","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A day is described in this subsection with respect to a designated drug if it is a day during one of the following periods:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46164aaa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The period beginning on the March 1st (or, in the case of initial price applicability year 2026, the October 2nd) immediately following the date on which such drug is included on the list published under section 1192(a) of the Social Security Act and ending on the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46164aab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first date on which the manufacturer of such designated drug has in place an agreement described in section 1193(a) of such Act with respect to such drug, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46164aac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that the Secretary of Health and Human Services has made a determination described in section 1192(c)(1) of such Act with respect to such designated drug.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46164aad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The period beginning on the November 2nd immediately following the March 1st described in paragraph (1) (or, in the case of initial price applicability year 2026, the August 2nd immediately following the October 2nd described in such paragraph) and ending on the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46164aae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first date on which the manufacturer of such designated drug and the Secretary of Health and Human Services have agreed to a maximum fair price under an agreement described in section 1193(a) of the Social Security Act, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46164aaf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that the Secretary of Health and Human Services has made a determination described in section 1192(c)(1) of such Act with respect to such designated drug.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46164ab0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of any designated drug which is a selected drug (as defined in section 1192(c) of the Social Security Act) that the Secretary of Health and Human Services has selected for renegotiation under section 1194(f) of such Act, the period beginning on the November 2nd of the year that begins 2 years prior to the first initial price applicability year of the price applicability period for which the maximum fair price established pursuant to such renegotiation applies and ending on the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46164ab1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first date on which the manufacturer of such designated drug has agreed to a renegotiated maximum fair price under such agreement, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46164ab2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that the Secretary of Health and Human Services has made a determination described in section 1192(c)(1) of such Act with respect to such designated drug.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46164ab3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to information that is required to be submitted to the Secretary of Health and Human Services under an agreement described in section 1193(a) of the Social Security Act, the period beginning on the date on which such Secretary certifies that such information is overdue and ending on the date that such information is so submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46164ab4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46164ab5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A day shall not be taken into account as a day during a period described in subsection (b) if such day is also a day during the period—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46164ab6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" beginning on the first date on which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46164ab7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the notice of terminations of all applicable agreements of the manufacturer have been received by the Secretary of Health and Human Services, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46164ab8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" none of the drugs of the manufacturer of the designated drug are covered by an agreement under section 1860D–14A or 1860D–14C of the Social Security Act, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46164ab9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ending on the last day of February following the earlier of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46164aba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first day after the date described in subparagraph (A) on which the manufacturer enters into any subsequent applicable agreement, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46164abb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first date any drug of the manufacturer of the designated drug is covered by an agreement under section 1860D–14A or 1860D–14C of the Social Security Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46164abc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “applicable agreement” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46164abd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An agreement under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46164abe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Medicare coverage gap discount program under section 1860D–14A of the Social Security Act, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46164abf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manufacturer discount program under section 1860D–14C of such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46164ac0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A rebate agreement described in section 1927(b) of such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46164ac1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable percentage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “applicable percentage” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46164ac2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of sales of a designated drug during the first 90 days described in subsection (b) with respect to such drug, 65 percent,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46164ac3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of sales of such drug during the 91st day through the 180th day described in subsection (b) with respect to such drug, 75 percent,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46164ac4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of sales of such drug during the 181st day through the 270th day described in subsection (b) with respect to such drug, 85 percent, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46164ac5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of sales of such drug during any subsequent day, 95 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46164ac6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46164ac7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated drug","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “designated drug” means any negotiation-eligible drug (as defined in section 1192(d) of the Social Security Act) included on the list published under section 1192(a) of such Act which is manufactured or produced in the United States or entered into the United States for consumption, use, or warehousing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46164ac8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” has the meaning given such term by section 4612(a)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46164ac9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “initial price applicability year”, “price applicability period”, and “maximum fair price” have the meaning given such terms in section 1191 of the Social Security Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46164aca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46164acb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with rules for possessions of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of paragraphs (2) and (4) of section 4132(c) shall apply for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46164acc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Anti-abuse rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a sale which was timed for the purpose of avoiding the tax imposed by this section, the Secretary may treat such sale as occurring during a day described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46164acd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of section 4662(e) (other than section 4662(e)(2)(A)(ii)(II)) shall apply for purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46164ace-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000D/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations and other guidance as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46164acf-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s11003/a"},"text":"Pub. L. 117–169, title I, § 11003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1862"},"text":"136 Stat. 1862","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46164ad0-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46164ad1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id46164ad2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Sections 1191 to 1194 of the Act are classified to sections 1320f to 1320f–3, respectively, of Title 42, The Public Health and Welfare. Sections 1860D–14A and 1860D–14C of the Act are classified to sections 1395w–114a and 1395w–114c, respectively, of Title 42. Section 1927 of the Act is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396r–8"},"text":"section 1396r–8 of Title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46164ad3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46164ad4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s11003/d"},"text":"Pub. L. 117–169, title I, § 11003(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1864"},"text":"136 Stat. 1864","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/169/tI/s11003/d"},"text":"“The amendments made by this section [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s275"},"text":"section 275 of this title","children":[],"tail":"] shall apply to sales after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
