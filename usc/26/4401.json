{"tag":"section","attrib":{"id":"id45d5e5e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4401"},"text":null,"children":[{"tag":"num","attrib":{"value":"4401"},"text":"§ 4401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45d5e5e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4401/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wagers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d5e5e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4401/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State authorized wagers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be imposed on any wager authorized under the law of the State in which accepted an excise tax equal to 0.25 percent of the amount of such wager.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e5e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4401/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unauthorized wagers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be imposed on any wager not described in paragraph (1) an excise tax equal to 2 percent of the amount of such wager.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d5e5e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4401/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of wager","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the amount of any wager for the purposes of this subchapter, all charges incident to the placing of such wager shall be included; except that if the taxpayer establishes, in accordance with regulations prescribed by the Secretary, that an amount equal to the tax imposed by this subchapter has been collected as a separate charge from the person placing such wager, the amount so collected shall be excluded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d5e5e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4401/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons liable for tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each person who is engaged in the business of accepting wagers shall be liable for and shall pay the tax under this subchapter on all wagers placed with him. Each person who conducts any wagering pool or lottery shall be liable for and shall pay the tax under this subchapter on all wagers placed in such pool or lottery. Any person required to register under section 4412 who receives wagers for or on behalf of another person without having registered under section 4412 the name and place of residence of such other person shall be liable for and shall pay the tax under this subchapter on all such wagers received by him.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d5e5e9-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/525"},"text":"68A Stat. 525","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tI/s151/a"},"text":"Pub. L. 85–859, title I, § 151(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1304"},"text":"72 Stat. 1304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/499/s3/a"},"text":"Pub. L. 93–499, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-29"},"text":"Oct. 29, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1550"},"text":"88 Stat. 1550","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/362/tI/s109/a"},"text":"Pub. L. 97–362, title I, § 109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-25"},"text":"Oct. 25, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1731"},"text":"96 Stat. 1731","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45d5e5ea-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45d5e5eb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45d5e5ec-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/362"},"text":"Pub. L. 97–362","children":[],"tail":" substituted provision that there shall be imposed on any wager authorized under the law of the State in which accepted an excise tax equal to 0.25 percent of the amount of such wager and that there shall be imposed on any other wager an excise tax equal to 2 percent of the amount of such wager for provision that there be imposed on wagers, as defined in section 4421, an excise tax equal to 2 percent of the amount thereof."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/499"},"text":"Pub. L. 93–499","children":[],"tail":" substituted “2 percent” for “10 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" made all persons required to register under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4412"},"text":"section 4412 of this title","children":[],"tail":" who receive wagers for or on behalf of another person without having registered under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4412"},"text":"section 4412 of this title","children":[],"tail":" the name and place of residence of such other person liable for the tax on all such wagers received by them."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45d5e5ed-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45d5e5ee-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/362/tI/s109/c/1"},"text":"Pub. L. 97–362, title I, § 109(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-25"},"text":"Oct. 25, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1731"},"text":"96 Stat. 1731","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/362/tI/s109/c/1"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1983-01-01"},"text":"January 1, 1983","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45d5e5ef-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/499/s3/d/1"},"text":"Pub. L. 93–499, § 3(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-29"},"text":"Oct. 29, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1551"},"text":"88 Stat. 1551","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/499/s3/d/1"},"text":"“The amendments made by this section [enacting section 4424 and amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4411"},"text":"section 4411 of this title","children":[],"tail":"] take effect on "},{"tag":"date","attrib":{"date":"1974-12-01"},"text":"December 1, 1974","children":[],"tail":", and shall apply only with respect to wagers placed on or after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45d5e5f0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tI/s151/b"},"text":"Pub. L. 85–859, title I, § 151(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1304"},"text":"72 Stat. 1304","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/85/859/tI/s151/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply with respect to wagers received after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
