{"tag":"section","attrib":{"id":"id441a53e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s835"},"text":null,"children":[{"tag":"num","attrib":{"value":"835"},"text":"§ 835.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election by reciprocal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id441a53e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s835/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, any mutual insurance company which is an interinsurer or reciprocal underwriter (hereinafter in this section referred to as a “reciprocal”) subject to the taxes imposed by section 831(a) may, under regulations prescribed by the Secretary, elect to be subject to the limitation provided in subsection (b). Such election shall be effective for the taxable year for which made and for all succeeding taxable years, and shall not be revoked except with the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id441a53e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s835/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The deduction for amounts paid or incurred in the taxable year to the attorney-in-fact by a reciprocal making the election provided in subsection (a) shall be limited to, but in no case increased by, the deductions of the attorney-in-fact allocable, in accordance with regulations prescribed by the Secretary, to the income received by the attorney-in-fact from the reciprocal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id441a53e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s835/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An election may not be made by a reciprocal under subsection (a) unless the attorney-in-fact of such reciprocal—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id441a53e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s835/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to the tax imposed by section 11;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441a53e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s835/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consents in such manner as the Secretary shall prescribe by regulations to make available such information as may be required during the period in which the election provided in subsection (a) is in effect, under regulations prescribed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441a53ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s835/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reports the income received from the reciprocal and the deductions allocable thereto under the same method of accounting under which the reciprocal reports deductions for amounts paid to the attorney-in-fact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441a53eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s835/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files its return on the calendar year basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id441a53ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s835/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reciprocal electing to be subject to the limitation provided in subsection (b) shall be credited with so much of the tax paid by the attorney-in-fact as is attributable, under regulations prescribed by the Secretary, to the income received by the attorney-in-fact from the reciprocal in such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id441a53ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s835/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits of graduated rates denied","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any increase in the taxable income of a reciprocal attributable to the limits provided in subsection (b) shall be taxed at the highest rate of tax specified in section 11(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id441a53ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s835/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment for refund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If for any taxable year an attorney-in-fact is allowed a credit or refund for taxes paid with respect to which credit or refund to the reciprocal resulted under subsection (d), the taxes of such reciprocal for such taxable year shall be properly adjusted under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id441a53ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s835/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxes of attorney-in-fact unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall increase or decrease the taxes imposed by this chapter on the income of the attorney-in-fact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id441a53f0-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/834/s8/c"},"text":"Pub. L. 87–834, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-16"},"text":"Oct. 16, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/996"},"text":"76 Stat. 996","children":[],"tail":", § 826; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tIII/s301/b/10"},"text":"Pub. L. 95–600, title III, § 301(b)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2822"},"text":"92 Stat. 2822","children":[],"tail":"; renumbered § 835 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tX/s1024/a/3"},"text":"Pub. L. 99–514, title X, § 1024(a)(3)","children":[],"tail":", (c)(9), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2405"},"text":"100 Stat. 2405","children":[],"tail":", 2407; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1010/f/2"},"text":"Pub. L. 100–647, title I, § 1010(f)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3454"},"text":"102 Stat. 3454","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id441a53f1-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id441a53f2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id441a53f3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1010/f/2"},"text":"Pub. L. 100–647, § 1010(f)(2)","children":[],"tail":", substituted “section 831(a)” for “section 821(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1010/f/3"},"text":"Pub. L. 100–647, § 1010(f)(3)","children":[],"tail":", substituted “subsection (d)” for “subsection (e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1024/a/3"},"text":"Pub. L. 99–514, § 1024(a)(3)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s826"},"text":"section 826 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1024/c/9/A"},"text":"Pub. L. 99–514, § 1024(c)(9)(A)","children":[],"tail":", redesignated subsec. (e) as (d) and struck out former subsec. (d), special rule, which read as follows: “In applying section 824(d)(1)(D), any amount which was added to the protection against loss account by reason of an election under this section shall be treated as having been added by reason of section 824(a)(1)(A).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1024/c/9"},"text":"Pub. L. 99–514, § 1024(c)(9)","children":[],"tail":", redesignated subsec. (f) as (e), substituted “Benefits of graduated rates” for “Surtax exemption” in heading, and amended text generally. Prior to amendment, text read as follows: “Any increase in taxable income of a reciprocal attributable to the limitation provided in subsection (b) shall be taxed without regard to the surtax exemption provided in section 821(a)(2).” Former subsec. (e) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1024/c/9/A"},"text":"Pub. L. 99–514, § 1024(c)(9)(A)","children":[],"tail":", redesignated subsecs. (f) to (h) as (e) to (g), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" substituted “the tax imposed by section 11” for “the taxes imposed by section 11(b) and (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (b), (c)(2), (e), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id441a53f4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id441a53f5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id441cc3f6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1024/e"},"text":"section 1024(e) of Pub. L. 99–514","children":[],"tail":", set out 