{"tag":"section","attrib":{"id":"id45d856cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4475"},"text":null,"children":[{"tag":"num","attrib":{"value":"4475"},"text":"§ 4475.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45d856ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4475/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on any remittance transfer a tax equal to 1 percent of the amount of such transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d856cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4475/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d856d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4475/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by this section with respect to any remittance transfer shall be paid by the sender with respect to such transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d856d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4475/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The remittance transfer provider with respect to any remittance transfer shall collect the amount of the tax imposed under subsection (a) with respect to such transfer from the sender and remit such tax quarterly to the Secretary at such time and in such manner as provided by the Secretary,","children":[{"tag":"ref","attrib":{"idref":"fn002236"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002236"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should be a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d856d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4475/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secondary liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where any tax imposed by subsection (a) is not paid at the time the transfer is made, then to the extent that such tax is not collected, such tax shall be paid by the remittance transfer provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d856d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4475/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax limited to cash and similar instruments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed under subsection (a) shall apply only to any remittance transfer for which the sender provides cash, a money order, a cashier’s check, or any other similar physical instrument (as determined by the Secretary) to the remittance transfer provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d856d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4475/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplication to certain noncash remittance transfers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to any remittance transfer for which the funds being transferred are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d856d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4475/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" withdrawn from an account held in or by a financial institution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45d856d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4475/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is described in subparagraphs (A) through (H) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5312/a/2"},"text":"section 5312(a)(2) of title 31","children":[],"tail":", United States Code, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d856d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4475/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is subject to the requirements under subchapter II of chapter 53 of such title, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d856d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4475/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funded with a debit card or a credit card which is issued in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d856d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4475/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d856da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4475/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “remittance transfer”, “remittance transfer provider”, and “sender” shall each have the respective meanings given such terms by section 919(g) of the Electronic Fund Transfer Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693"},"text":"15 U.S.C. 1693","children":[],"tail":null},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–1(g))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d856db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4475/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit card","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “credit card” has the same meaning given such term under section 920(c)(3) of the Electronic Fund Transfer Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693"},"text":"15 U.S.C. 1693","children":[],"tail":null},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–2(c)(3))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d856dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4475/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debit card","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “debit card” has the same meaning given such term under section 920(c)(2) of the Electronic Fund Transfer Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693"},"text":"15 U.S.C. 1693","children":[],"tail":null},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–2(c)(2)), without regard to subparagraph (B) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d856dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4475/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of anti-conduit rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 7701(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), with respect to any multiple-party arrangements involving the sender, a remittance transfer shall be treated as a financing transaction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d856de-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70604/a"},"text":"Pub. L. 119–21, title VII, § 70604(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/285"},"text":"139 Stat. 285","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45d856df-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45d856e0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45d856e1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70604/c"},"text":"Pub. L. 119–21, title VII, § 70604(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/286"},"text":"139 Stat. 286","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70604/c"},"text":"“The amendments made by this section [enacting this subchapter] shall apply to transfers made after ","children":[{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
