{"tag":"section","attrib":{"id":"id4501a637-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1399"},"text":null,"children":[{"tag":"num","attrib":{"value":"1399"},"text":"§ 1399.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No separate taxable entities for partnerships, corporations, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except in any case to which section 1398 applies, no separate taxable entity shall result from the commencement of a case under title 11 of the United States Code.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4501a638-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/589/s3/a/1"},"text":"Pub. L. 96–589, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3400"},"text":"94 Stat. 3400","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
