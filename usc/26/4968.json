{"tag":"section","attrib":{"id":"id45f4e086-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968"},"text":null,"children":[{"tag":"num","attrib":{"value":"4968"},"text":"§ 4968.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excise tax based on investment income of private colleges and universities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45f4e087-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax imposed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on each applicable educational institution for the taxable year a tax equal to the applicable percentage of the net investment income of such institution for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f4e088-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable percentage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “applicable percentage” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f4e089-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1.4 percent in the case of an institution with a student adjusted endowment of at least $500,000, and not in excess of $750,000,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e08a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 percent in the case of an institution with a student adjusted endowment in excess of $750,000, and not in excess of $2,000,000, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e08b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 8 percent in the case of an institution with a student adjusted endowment in excess of $2,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f4e08c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable educational institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the term “applicable educational institution” means an eligible educational institution (as defined in section 25A(f)(2))—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f4e08d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which had at least 3,000 tuition-paying students during the preceding taxable year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e08e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 50 percent of the tuition-paying students of which are located in the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e08f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the student adjusted endowment of which is at least $500,000, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e090-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is not described in the first sentence of section 511(a)(2)(B) (relating to State colleges and universities).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f4e091-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student adjusted endowment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “student adjusted endowment” means, with respect to any institution for any taxable year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f4e092-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate fair market value of the assets of such institution (determined as of the end of the preceding taxable year), other than those assets which are used directly in carrying out the institution’s exempt purpose, divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e093-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of students of such institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f4e094-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of number of students","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsections (c) and (d), the number of students of an institution (including for purposes of determining the number of students at a particular location) shall be based on the daily average number of full-time students attending such institution (with part-time students taken into account on a full-time student equivalent basis).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f4e095-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net investment income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f4e096-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Net investment income shall be determined under rules similar to the rules of section 4940(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e097-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Override of certain regulatory exceptions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f4e098-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student loan interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Net investment income shall be determined by taking into account any interest income from a student loan made by the applicable educational institution (or any related organization) as gross investment income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f4e099-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally-subsidized royalty income","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45f4e09a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Net investment income shall be determined by taking into account any Federally-subsidized royalty income as gross investment income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f4e09b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally-subsidized royalty income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subparagraph—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id45f4e09c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/f/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federally-subsidized royalty income” means any otherwise-regulatory-exempt royalty income if any Federal funds were used in the research, development, or creation of the patent, copyright, or other intellectual or intangible property from which such royalty income is derived.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id45f4e09d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/f/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Otherwise-regulatory-exempt royalty income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subparagraph, the term “otherwise-regulatory-exempt royalty income” means royalty income which (but for this subparagraph) would not be taken into account as gross investment income by reason of being derived from patents, copyrights, or other intellectual or intangible property which resulted from the work of students or faculty members in their capacities as such with the applicable educational institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id45f4e09e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/f/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal funds” includes any grant made by, and any payment made under any contract with, any Federal agency to the applicable educational institution, any related organization, or any student or faculty member referred to in subclause (II).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f4e09f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assets and net investment income of related organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f4e0a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsections (d) and (f), assets and net investment income of any related organization with respect to an educational institution shall be treated as assets and net investment income, respectively, of the educational institution, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f4e0a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no such amount shall be taken into account with respect to more than 1 educational institution, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f4e0a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless such organization is controlled by such institution or is described in section 509(a)(3) with respect to such institution for the taxable year, assets and net investment income which are not intended or available for the use or benefit of the educational institution shall not be taken into account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e0a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “related organization” means, with respect to an educational institution, any organization which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f4e0a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" controls, or is controlled by, such institution,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f4e0a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is controlled by 1 or more persons which also control such institution, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f4e0a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a supported organization (as defined in section 509(f)(3)), or an organization described in section 509(a)(3), during the taxable year with respect to such institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f4e0a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4968/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations or other guidance as may be necessary to prevent avoidance of the tax under this section, including regulations or other guidance to prevent avoidance of such tax through the restructuring of endowment funds or other arrangements designed to reduce or eliminate the value of net investment income or assets subject to the tax imposed by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45f4e0a8-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13701/a"},"text":"Pub. L. 115–97, title I, § 13701(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2167"},"text":"131 Stat. 2167","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dD/tII/s41109/a"},"text":"Pub. L. 115–123, div. D, title II, § 41109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/159"},"text":"132 Stat. 159","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70415/a"},"text":"Pub. L. 119–21, title VII, § 70415(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/221"},"text":"139 Stat. 221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45f4e0a9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45f4e0aa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45f4e0ab-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) to (d) relating to tax imposed, applicable educational institution, net investment income, and assets and net investment income of related organizations, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s41109/a/1"},"text":"Pub. L. 115–123, § 41109(a)(1)","children":[],"tail":", inserted “tuition-paying” after “500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s41109/a/2"},"text":"Pub. L. 115–123, § 41109(a)(2)","children":[],"tail":", inserted “tuition-paying” after “50 percent of the”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45f4e0ac-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45f4e0ad-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70415/c"},"text":"Pub. L. 119–21, title VII, § 70415(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/223"},"text":"139 Stat. 223","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70415/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6033"},"text":"section 6033 of this title","children":[],"tail":"] shall apply to taxable years beginning after "},{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45f4e0ae-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/dD/tII/s41109/b"},"text":"Pub. L. 115–123, div. D, title II, § 41109(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/159"},"text":"132 Stat. 159","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/123/dD/tII/s41109/b"},"text":"“The amendments made by this section [amending this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45f4e0af-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13701/c"},"text":"Pub. L. 115–97, title I, § 13701(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2168"},"text":"131 Stat. 2168","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/97/tI/s13701/c"},"text":"“The amendments made by this section [enacting this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
