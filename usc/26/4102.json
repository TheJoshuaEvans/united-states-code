{"tag":"section","attrib":{"id":"id45bba7b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4102"},"text":null,"children":[{"tag":"num","attrib":{"value":"4102"},"text":"§ 4102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection of records by local officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary, records required to be kept with respect to taxes under this part shall be open to inspection by such officers of a State, or a political subdivision of any such State, as shall be charged with the enforcement or collection of any tax on any taxable fuel (as defined in section 4083).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id45bba7b8-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/484"},"text":"68A Stat. 484","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXII/s1202/c/1"},"text":"Pub. L. 94–455, title XII, § 1202(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1686"},"text":"90 Stat. 1686","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/424/tV/s515/b/9"},"text":"Pub. L. 97–424, title V, § 515(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-06"},"text":"Jan. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2182"},"text":"96 Stat. 2182","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13242/d/2"},"text":"Pub. L. 103–66, title XIII, § 13242(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/522"},"text":"107 Stat. 522","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45bba7b9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45bba7ba-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45bba7bb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" substituted “any taxable fuel (as defined in section 4083)” for “gasoline”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/424"},"text":"Pub. L. 97–424","children":[],"tail":" struck out “or lubricating oils” after “gasoline”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “returns, etc.” after “Inspection of records”, “or his delegate” after “Secretary”, “and returns, reports, and statements with respect to such taxes filed with the Secretary or his delegate” after “under this part”, substituted “or a political subdivision of any such State” for “or, Territory or political subdivision thereof or the District of Columbia” after “of any State”, and struck out provision relating to availability and fee for certified copies of statements, returns, or reports filed in Secretary’s office."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45bba7bc-3a70-11f1-a967-d35dac11796a"},"text":null,"childre