{"tag":"section","attrib":{"id":"id47477866-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7269"},"text":null,"children":[{"tag":"num","attrib":{"value":"7269"},"text":"§ 7269.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to produce records","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever fails to comply with any duty imposed upon him by section 6018, 6036 (in the case of an executor), or 6075(a), or, having in his possession or control any record, file, or paper, containing or supposed to contain any information concerning the estate of the decedent, or, having in his possession or control any property comprised in the gross estate of the decedent, fails to exhibit the same upon request to the Secretary who desires to examine the same in the performance of his duties under chapter 11 (relating to estate taxes), shall be liable to a penalty of not exceeding $500, to be recovered, with costs of suit, in a civil action in the name of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id47477867-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/865"},"text":"68A Stat. 865","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47477868-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47477869-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4747786a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
