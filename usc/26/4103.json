{"tag":"section","attrib":{"id":"id45bba7c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4103"},"text":null,"children":[{"tag":"num","attrib":{"value":"4103"},"text":"§ 4103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain additional persons liable for tax where willful failure to pay","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In any case in which there is a willful failure to pay the tax imposed by section 4041(a)(1) or 4081, each person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45bba7c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4103/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is an officer, employee, or agent of the taxpayer who is under a duty to assure the payment of such tax and who willfully fails to perform such duty, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45bba7c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4103/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who willfully causes the taxpayer to fail to pay such tax,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be jointly and severally liable with the taxpayer for the tax to which such failure relates.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45bba7c3-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11212/c"},"text":"Pub. L. 101–508, title XI, § 11212(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-431"},"text":"104 Stat. 1388–431","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/