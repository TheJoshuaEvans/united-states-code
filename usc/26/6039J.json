{"tag":"section","attrib":{"id":"id466c3344-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039J"},"text":null,"children":[{"tag":"num","attrib":{"value":"6039J"},"text":"§ 6039J.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information reporting with respect to Commodity Credit Corporation transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id466c3345-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039J/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation, through the Secretary of Agriculture, shall make a return, according to the forms and regulations prescribed by the Secretary of the Treasury, setting forth any market gain realized by a taxpayer during the taxable year in relation to the repayment of a loan issued by the Commodity Credit Corporation, without regard to the manner in which such loan was repaid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id466c3346-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039J/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements to be furnished to persons with respect to whom information is required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall furnish to each person whose name is required to be set forth in a return required under subsection (a) a written statement showing the amount of market gain reported in such return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id466c3347-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXV/s15353/a"},"text":"Pub. L. 110–234, title XV, § 15353(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1526"},"text":"122 Stat. 1526","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XV, § 15353(a), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2288.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id466c3348-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id466c3349-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id466c334a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id466c334b-3a70-11f1-a967-d35dac11796a"},"text":null,"chi