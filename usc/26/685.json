{"tag":"section","attrib":{"id":"id43f90f7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s685"},"text":null,"children":[{"tag":"num","attrib":{"value":"685"},"text":"§ 685.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of funeral trusts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43f90f7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s685/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a qualified funeral trust—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43f90f7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s685/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparts B, C, D, and E shall not apply, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f90f7d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s685/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no deduction shall be allowed by section 642(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f90f7e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s685/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified funeral trust","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “qualified funeral trust” means any trust (other than a foreign trust) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43f90f7f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s685/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trust arises as a result of a contract with a person engaged in the trade or business of providing funeral or burial services or property necessary to provide such services,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f90f80-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s685/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sole purpose of the trust is to hold, invest, and reinvest funds in the trust and to use such funds solely to make payments for such services or property for the benefit of the beneficiaries of the trust,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f90f81-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s685/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the only beneficiaries of such trust are individuals with respect to whom such services or property are to be provided at their death under contracts described in paragraph (1),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f90f82-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s685/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the only contributions to the trust are contributions by or for the benefit of such beneficiaries,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f90f83-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s685/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trustee elects the application of this subsection, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f90f84-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s685/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trust would (but for the election described in paragraph (5)) be treated as owned under subpart E by the purchasers of the contracts described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A trust shall not fail to be treated as meeting the requirement of paragraph (6) by reason of the death of an individual but only during the 60-day period beginning on the date of such death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f90f85-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s685/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of rate schedule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 1(e) shall be applied to each qualified funeral trust by treating each beneficiary’s interest in each such trust as a separate trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f90f86-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s685/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of amounts refunded to purchaser on cancellation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No gain or loss shall be recognized to a purchaser of a contract described in subsection (b)(1) by reason of any payment from such trust to such purchaser by reason of cancellation of such contract. If any payment referred to in the preceding sentence consists of property other than money, the basis of such property in the hands of such purchaser shall be the same as the trust’s basis in such property immediately before the payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f90f87-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s685/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simplified reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prescribe rules for simplified reporting of all trusts having a single trustee and of trusts terminated during the year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43f90f88-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIII/s1309/a"},"text":"Pub. L. 105–34, title XIII, § 1309(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1042"},"text":"111 Stat. 1042","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tVI/s6013/b"},"text":"Pub. L. 105–206, title VI, § 6013(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/820"},"text":"112 Stat. 820","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/317/s9/a"},"text":"Pub. L. 110–317, § 9(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-08-29"},"text":"Aug. 29, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3530"},"text":"122 Stat. 3530","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43f90f89-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43f90f8a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43f90f8b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsecs. (c) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/317"},"text":"Pub. L. 110–317","children":[],"tail":" redesignated subsecs. (d) to (f) as (c) to (e), respectively, and struck out former subsec. (c), which related to dollar limitation on contributions to qualified funeral trusts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6013/b/1"},"text":"Pub. L. 105–206, § 6013(b)(1)","children":[],"tail":", inserted concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6013/b/2"},"text":"Pub. L. 105–206, § 6013(b)(2)","children":[],"tail":", inserted “and of trusts terminated during the year” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43f90f8c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43f90f8d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/317/s9/c"},"text":"Pub. L. 110–317, § 9(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-29"},"text":"Aug. 29, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3530"},"text":"122 Stat. 3530","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/317/s9/c"},"text":"“The amendments made by this section [amending this section] shall apply to taxable years beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-08-29"},"text":"Aug. 29, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43f90f8e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Taxpayer Relief Act of 1997, "},{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6024"},"text":"section 6024 of Pub. L. 105–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id43f90f8f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIII/s1309/c"},"text":"Pub. L. 105–34, title XIII, § 1309(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1043"},"text":"111 Stat. 1043","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tXIII/s1309/c"},"text":"“The amendments made by this section [enacting this section] shall apply to taxable years ending after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
