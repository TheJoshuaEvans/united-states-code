{"tag":"section","attrib":{"id":"id46118f72-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982"},"text":null,"children":[{"tag":"num","attrib":{"value":"4982"},"text":"§ 4982.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excise tax on undistributed income of regulated investment companies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46118f73-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby imposed a tax on every regulated investment company for each calendar year equal to 4 percent of the excess (if any) of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46118f74-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the required distribution for such calendar year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118f75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distributed amount for such calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46118f76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46118f77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “required distribution” means, with respect to any calendar year, the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118f78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 98 percent of the regulated investment company’s ordinary income for such calendar year, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118f79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 98.2 percent of the regulated investment company’s capital gain net income for the 1-year period ending on October 31 of such calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118f7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase by prior year shortfall","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount determined under paragraph (1) for any calendar year shall be increased by the excess (if any) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118f7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grossed up required distribution for the preceding calendar year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118f7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distributed amount for such preceding calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118f7d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grossed up required distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The grossed up required distribution for any calendar year is the required distribution for such year determined—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118f7e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the application of paragraph (2) to such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118f7f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “100 percent” for each percentage set forth in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46118f80-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributed amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46118f81-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “distributed amount” means, with respect to any calendar year, the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118f82-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deduction for dividends paid (as defined in section 561) during such calendar year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118f83-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount on which tax is imposed under subsection (b)(1) or (b)(3)(A) of section 852 for any taxable year ending in such calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118f84-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase by prior year overdistribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount determined under paragraph (1) for any calendar year shall be increased by the excess (if any) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118f85-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distributed amount for the preceding calendar year (determined with the application of this paragraph to such preceding calendar year), over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118f86-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grossed up required distribution for such preceding calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118f87-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of dividends paid","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the dividends paid during any calendar year shall be determined without regard to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118f88-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of section 855, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118f89-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any exempt-interest dividend as defined in section 852(b)(5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118f8a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for estimated tax payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118f8b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a regulated investment company which elects the application of this paragraph for any calendar year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46118f8c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distributed amount with respect to such company for such calendar year shall be increased by the amount on which qualified estimated tax payments are made by such company during such calendar year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46118f8d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distributed amount with respect to such company for the following calendar year shall be reduced by the amount of such increase.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118f8e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified estimated tax payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the term “qualified estimated tax payments” means, with respect to any calendar year, payments of estimated tax of a tax described in paragraph (1)(B) for any taxable year which begins (but does not end) in such calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46118f8f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for payment of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by this section for any calendar year shall be paid on or before March 15 of the following calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46118f90-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46118f91-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ordinary income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “ordinary income” means the investment company taxable income (as defined in section 852(b)(2)) determined—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118f92-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to subparagraphs (A) and (D) of section 852(b)(2),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118f93-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by not taking into account any gain or loss from the sale or exchange of a capital asset, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118f94-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by treating the calendar year as the company’s taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118f95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital gain net income","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118f96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the term “capital gain net income” has the meaning given such term by section 1222(9) (determined by treating the 1-year period ending on October 31 of any calendar year as the company’s taxable year).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118f97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction by net ordinary loss for calendar year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount determined under subparagraph (A) shall be reduced (but not below the net capital gain) by the amount of the company’s net ordinary loss for the calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118f98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46118f99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net capital gain","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “net capital gain” has the meaning given such term by section 1222(11) (determined by treating the 1-year period ending on October 31 of the calendar year as the company’s taxable year).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46118f9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net ordinary loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The net ordinary loss for the calendar year is the amount which would be the net operating loss of the company for the calendar year if the amount of such loss were determined in the same manner as ordinary income is determined under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118f9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of deficiency distributions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any deficiency dividend (as defined in section 860(f))—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118f9c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dividend shall be taken into account when paid without regard to section 860, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118f9d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any income giving rise to the adjustment shall be treated as arising when the dividend is paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118f9e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to use taxable year in certain cases","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118f9f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46118fa0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxable year of the regulated investment company ends with the month of November or December, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46118fa1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such company makes an election under this paragraph,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"subsection (b)(1)(B) and paragraph (2) of this subsection shall be applied by taking into account the company’s taxable year in lieu of the 1-year period ending on October 31 of the calendar year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118fa2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election revocable only with consent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under this paragraph, once made, may be revoked only with the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118fa3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of specified gains and losses after October 31 of calendar year","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118fa4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any specified gain or specified loss which (but for this paragraph) would be properly taken into account for the portion of the calendar year after October 31 shall be treated as arising on January 1 of the following calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118fa5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified gains and losses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46118fa6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified gain","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “specified gain” means ordinary gain from the sale, exchange, or other disposition of property (including the termination of a position with respect to such property). Such term shall include any foreign currency gain attributable to a section 988 transaction (within the meaning of section 988) and any amount includible in gross income under section 1296(a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46118fa7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “specified loss” means ordinary loss from the sale, exchange, or other disposition of property (including the termination of a position with respect to such property). Such term shall include any foreign currency loss attributable to a section 988 transaction (within the meaning of section 988) and any amount allowable as a deduction under section 1296(a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118fa8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for companies electing to use the taxable year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any company making an election under paragraph (4), subparagraph (A) shall be applied by substituting the last day of the company’s taxable year for October 31.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118fa9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of mark to market gain","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118faa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determining a regulated investment company’s ordinary income, notwithstanding paragraph (1)(C), each specified mark to market provision shall be applied as if such company’s taxable year ended on October 31. In the case of a company making an election under paragraph (4), the preceding sentence shall be applied by substituting the last day of the company’s taxable year for October 31.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118fab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified mark to market provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the term “specified mark to market provision” means sections 1256 and 1296 and any other provision of this title (or regulations thereunder) which treats property as disposed of on the last day of the taxable year or which determines income by reference to the value of an item on the last day of the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118fac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elective deferral of certain ordinary losses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in regulations prescribed by the Secretary, in the case of a regulated investment company which has a taxable year other than the calendar year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118fad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such company may elect to determine its ordinary income and net ordinary loss (as defined in paragraph (2)(C)(ii)) for the calendar year without regard to any portion of any net ordinary loss (determined without regard to specified gains and losses taken into account under paragraph (5)) which is attributable to the portion of such calendar year which is after the beginning of the taxable year which begins in such calendar year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118fae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/e/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount of net ordinary loss not taken into account for a calendar year by reason of subparagraph (A) shall be treated as arising on the 1st day of the following calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46118faf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain regulated investment companies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply to any regulated investment company for any calendar year if at all times during such calendar year each shareholder in such company was—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46118fb0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trust described in section 401(a) and exempt from tax under section 501(a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118fb1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a segregated asset account of a life insurance company held in connection with variable contracts (as defined in section 817(d)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118fb2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other tax-exempt entity whose ownership of beneficial interests in the company would not preclude the application of section 817(h)(4), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118fb3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4982/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another regulated investment company described in this subsection.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of the preceding sentence, any shares attributable to an investment in the regulated investment company (not exceeding $250,000) made in connection with the organization of such company shall not be taken into account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46118fb4-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s651/a"},"text":"Pub. L. 99–514, title VI, § 651(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2294"},"text":"100 Stat. 2294","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10104/b/1"},"text":"Pub. L. 100–203, title X, § 10104(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-387"},"text":"101 Stat. 1330–387","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006"},"text":"Pub. L. 100–647, title I, § 1006","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), (5), (6), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3413"},"text":"102 Stat. 3413","children":[],"tail":", 3414; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7204/a/1"},"text":"Pub. L. 101–239, title VII, § 7204(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2334"},"text":"103 Stat. 2334","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXI/s1122/c/1"},"text":"Pub. L. 105–34, title XI, § 1122(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/976"},"text":"111 Stat. 976","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/325/tIV"},"text":"Pub. L. 111–325, title IV","children":[],"tail":", §§ 401(a), 402(a), 403(a), 404(a), "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3552-3554"},"text":"124 Stat. 3552–3554","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII"},"text":"Pub. L. 113–295, div. A, title II","children":[],"tail":", §§ 205(d), 220(s), "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4026"},"text":"128 Stat. 4026","children":[],"tail":", 4036.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46118fb5-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46118fb6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46118fb7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (e)(6)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s205/d/1"},"text":"Pub. L. 113–295, § 205(d)(1)","children":[],"tail":", inserted “or which determines income by reference to the value of an item on the last day of the taxable year” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(7)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s205/d/2"},"text":"Pub. L. 113–295, § 205(d)(2)","children":[],"tail":", substituted “such company may elect to determine its ordinary income and net ordinary loss (as defined in paragraph (2)(C)(ii)) for the calendar year without regard to any portion of any net ordinary loss” for “such company may elect to determine its ordinary income for the calendar year without regard to any net ordinary loss”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s220/s"},"text":"Pub. L. 113–295, § 220(s)","children":[],"tail":", inserted comma at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325/s404/a"},"text":"Pub. L. 111–325, § 404(a)","children":[],"tail":", substituted “98.2 percent” for “98 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325/s403/a"},"text":"Pub. L. 111–325, § 403(a)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(5) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325/s402/a"},"text":"Pub. L. 111–325, § 402(a)","children":[],"tail":", added pars. (5) to (7) and struck out former pars. (5) and (6) which related to treatment of foreign currency gains and losses after October 31 of calendar year and treatment of gain recognized under section 1296, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325/s401/a/1"},"text":"Pub. L. 111–325, § 401(a)(1)","children":[],"tail":", struck out “either” before dash at end of introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325/s401/a/2"},"text":"Pub. L. 111–325, § 401(a)(2)","children":[],"tail":"–(4), added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (e)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" substituted “98 percent” for “97 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006"},"text":"Pub. L. 100–647, § 1006","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), amended par. (2) generally. Prior to amendment, par. (2) read as follows: “The term ‘capital gain net income’ has the meaning given to such term by section 1222(9) (determined by treating the 1-year period ending on October 31 of any calendar year as the company’s taxable year).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006"},"text":"Pub. L. 100–647, § 1006","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(5), added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006"},"text":"Pub. L. 100–647, § 1006","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(6), added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" substituted “98 percent” for “90 percent”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46118fb8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46118fb9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s205/d"},"text":"section 205(d) of Pub. L. 113–295","children":[],"tail":" effective as if included in the provision of the Regulated Investment Company Modernization Act of 