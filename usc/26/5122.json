{"tag":"section","attrib":{"id":"id46295d55-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5122"},"text":null,"children":[{"tag":"num","attrib":{"value":"5122"},"text":"§ 5122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping by retail dealers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46295d56-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every retail dealer in liquors and every retail dealer in beer shall provide and keep in his place of business a record in book form of all distilled spirits, wines, and beer received, showing the quantity thereof and from whom and the dates received, or shall keep all invoices of, and bills for, all distilled spirits, wines, and beer received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46295d57-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dispositions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When he deems it necessary for law enforcement purposes or the protection of the revenue, the Secretary may by regulations require retail dealers in liquors and retail dealers in beer to keep records of the disposition of distilled spirits, wines, or beer, in such form or manner and of such quantities as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46295d58-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5122/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retail dealers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46295d59-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5122/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retail dealer in liquors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “retail dealer in liquors” means any dealer (other than a retail dealer in beer or a limited retail dealer) who sells, or offers for sale, distilled spirits, wines, or beer, to any person other than a dealer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46295d5a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5122/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retail dealer in beer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “retail dealer in beer” means any dealer (other than a limited retail dealer) who sells, or offers for sale, beer, but not distilled spirits or wines, to any person other than a dealer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46295d5b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5122/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited retail dealer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “limited retail dealer” means any fraternal, civic, church, labor, charitable, benevolent, or ex-servicemen’s organization making sales of distilled spirits, wine or beer on the occasion of any kind of entertainment, dance, picnic, bazaar, or festival held by it, or any person making sales of distilled spirits, wine or beer to the members, guests, or patrons of bona fide fairs, reunions, picnics, carnivals, or other similar outings, if such organization or person is not otherwise engaged in business as a dealer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46295d5c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5122/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dealer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “dealer” has the meaning given such term by section 5121(c)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46295d5d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5122/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions relating to the preservation and inspection of records, and entry of premises for inspection, see section 5123.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46295d5e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1345"},"text":"72 Stat. 1345","children":[],"tail":", § 5124; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; renumbered § 5122 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11125/b/6"},"text":"Pub. L. 109–59, title XI, § 11125(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1955"},"text":"119 Stat. 1955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46295d5f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46295d60-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46295d61-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5122, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1344"},"text":"72 Stat. 1344","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1905/a/10"},"text":"Pub. L. 94–455, title XIX, § 1905(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"re