{"tag":"section","attrib":{"id":"id42981ff1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s275"},"text":null,"children":[{"tag":"num","attrib":{"value":"275"},"text":"§ 275.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42981ff2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s275/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No deduction shall be allowed for the following taxes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42981ff3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s275/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Federal income taxes, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42981ff4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s275/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax imposed by section 3101 (relating to the tax on employees under the Federal Insurance Contributions Act);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42981ff5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s275/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxes imposed by sections 3201 and 3211 (relating to the taxes on railroad employees and railroad employee representatives); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42981ff6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s275/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax withheld at source on wages under section 3402.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42981ff7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s275/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal war profits and excess profits taxes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42981ff8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s275/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Estate, inheritance, legacy, succession, and gift taxes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42981ff9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s275/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Income, war profits, and excess profits taxes imposed by the authority of any foreign country or possession of the United States if the taxpayer chooses to take to any extent the benefits of section 901.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42981ffa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s275/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Taxes on real property, to the extent that section 164(d) requires such taxes to be treated as imposed on another taxpayer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42981ffb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s275/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Taxes imposed by chapters 37, 41, 42, 43, 44, 45, 46, 50A, and 54.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Paragraph (1) shall not apply to any taxes to the extent such taxes are allowable as a deduction under section 164(f).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42981ffc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s275/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For disallowance of certain other taxes, see section 164(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id42981ffd-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s207/b/3/A"},"text":"Pub. L. 88–272, title II, § 207(b)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/42"},"text":"78 Stat. 42","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/406/tII/s1016/a/1"},"text":"Pub. L. 93–406, title II, § 1016(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/929"},"text":"88 Stat. 929","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIII/s1307/d/2/A"},"text":"Pub. L. 94–455, title XIII, § 1307(d)(2)(A)","children":[],"tail":", title XVI, § 1605(b)(1), title XIX, § 1901(a)(39), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1727"},"text":"