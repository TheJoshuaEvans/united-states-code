{"tag":"section","attrib":{"id":"id4517297f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446"},"text":null,"children":[{"tag":"num","attrib":{"value":"1446"},"text":"§ 1446.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding of tax on foreign partners’ share of effectively connected income","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45172980-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45172981-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership has effectively connected taxable income for any taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45172982-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any portion of such income is allocable under section 704 to a foreign partner,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such partnership shall pay a withholding tax under this section at such time and in such manner as the Secretary shall by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45172983-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of withholding tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45172984-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the withholding tax payable by any partnership under subsection (a) shall be equal to the applicable percentage of the effectively connected taxable income of the partnership which is allocable under section 704 to foreign partners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45172985-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable percentage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the term “applicable percentage” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45172986-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the highest rate of tax specified in section 1 in the case of the portion of the effectively connected taxable income which is allocable under section 704 to foreign partners who are not corporations, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45172987-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the highest rate of tax specified in section 11(b) in the case of the portion of the effectively connected taxable income which is allocable under section 704 to foreign partners which are corporations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45172988-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effectively connected taxable income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “effectively connected taxable income” means the taxable income of the partnership which is effectively connected (or treated as effectively connected) with the conduct of a trade or business in the United States computed with the following adjustments:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45172989-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) of section 703(a) shall not apply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4517298a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The partnership shall be allowed a deduction for depletion with respect to oil and gas wells but the amount of such deduction shall be determined without regard to sections 613 and 613A.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4517298b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall not be taken into account any item of income, gain, loss, or deduction to the extent allocable under section 704 to any partner who is not a foreign partner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4517298c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of foreign partners","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4517298d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each foreign partner of a partnership shall be allowed a credit under section 33 for such partner’s share of the withholding tax paid by the partnership under this section. Such credit shall be allowed for the partner’s taxable year in which (or with which) the partnership taxable year (for which such tax was paid) ends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4517298e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit treated as distributed to partner","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in regulations, a foreign partner’s share of any withholding tax paid by the partnership under this section shall be treated as distributed to such partner by such partnership on the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4517298f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the day on which such tax was paid by the partnership, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45172990-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the last day of the partnership’s taxable year for which such tax was paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45172991-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign partner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “foreign partner” means any partner who is not a United States person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45172992-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for withholding on dispositions of partnership interests","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45172993-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in this subsection, if any portion of the gain (if any) on any disposition of an interest in a partnership would be treated under section 864(c)(8) as effectively connected with the conduct of a trade or business within the United States, the transferee shall be required to deduct and withhold a tax equal to 10 percent of the amount realized on the disposition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45172994-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception if nonforeign affidavit furnished","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45172995-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall be required to deduct and withhold any amount under paragraph (1) with respect to any disposition if the transferor furnishes to the transferee an affidavit by the transferor stating, under penalty of perjury, the transferor’s United States taxpayer identification number and that the transferor is not a foreign person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45172996-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False affidavit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraph (A) shall not apply to any disposition if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45172997-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transferee has actual knowledge that the affidavit is false, or the transferee receives a notice (as described in section 1445(d)) from a transferor’s agent or transferee’s agent that such affidavit or statement is false, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45172998-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary by regulations requires the transferee to furnish a copy of such affidavit or statement to the Secretary and the transferee fails to furnish a copy of such affidavit or statement to the Secretary at such time and in such manner as required by such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45172999-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules for agents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rules of section 1445(d) shall apply to a transferor’s agent or transferee’s agent with respect to any affidavit described in subparagraph (A) in the same manner as such rules apply with respect to the disposition of a United States real property interest under such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4517299a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary to prescribe reduced amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of the transferor or transferee, the Secretary may prescribe a reduced amount to be withheld under this section if the Secretary determines that to substitute such reduced amount will not jeopardize the collection of the tax imposed under this title with respect to gain treated under section 864(c)(8) as effectively connected with the conduct of a trade or business with in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4517299b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership to withhold amounts not withheld by the transferee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a transferee fails to withhold any amount required to be withheld under paragraph (1), the partnership shall be required to deduct and withhold from distributions to the transferee a tax in an amount equal to the amount the transferee failed to withhold (plus interest under this title on such amount).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4517299c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any term used in this subsection which is also used under section 1445 shall have the same meaning as when used in such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4517299d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations or other guidance as may be necessary to carry out the purposes of this subsection, including regulations providing for exceptions from the provisions of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4517299e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to carry out the purposes of this section, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4517299f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations providing for the application of this section in the case of publicly traded partnerships, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id451729a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" regulations providing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id451729a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, for purposes of section 6655, the withholding tax imposed under this section shall be treated as a tax imposed by section 11 and any partnership required to pay such tax shall be treated as a corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id451729a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1446/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate adjustments in applying section 6655 with respect to such withholding tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id451729a3-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1246/a"},"text":"Pub. L. 99–514, title XII, § 1246(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2582"},"text":"100 Stat. 2582","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/s/1/A"},"text":"Pub. L. 100–647, title I, § 1012(s)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3526"},"text":"102 Stat. 3526","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7811/i/6"},"text":"Pub. L. 101–239, title VII, § 7811(i)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2410"},"text":"103 Stat. 2410","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI"},"text":"Pub. L. 115–97, title I","children":[],"tail":", §§ 13001(b)(3)(D), 13501(b), "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2098"},"text":"131 Stat. 2098","children":[],"tail":", 2139; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/199"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(199)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1193"},"text":"132 Stat. 1193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id451729a4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id451729a5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id451729a6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “Withholding of tax” for “Withholding tax” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13001/b/3/D"},"text":"Pub. L. 115–97, § 13001(b)(3)(D)","children":[],"tail":", substituted “section 11(b)” for “section 11(b)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13501/b"},"text":"Pub. L. 115–97, § 13501(b)","children":[],"tail":", added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7811/i/6/A"},"text":"Pub. L. 101–239, § 7811(i)(6)(A)","children":[],"tail":", substituted “section 11(b)(1)” for “section 11(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7811/i/6/B"},"text":"Pub. L. 101–239, § 7811(i)(6)(B)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “A foreign partner’s share of any withholding tax paid by the partnership under this section shall be treated as distributed to such partner by such partnership on the last day of the partnership’s taxable year (for which such tax was paid).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7811/i/6/C"},"text":"Pub. L. 101–239, § 7811(i)(6)(C)","children":[],"tail":", amended subsec. (f) generally. Prior to amendment, subsec. (f) read as follows: “The Secretary shall prescribe such regulations as may be necessary to carry out the purposes of this section, including regulations providing for the application of this section in the case of publicly traded partnerships.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" amended section generally, substituting provisions relating to withholding tax on foreign partners’ share of effectively connected income for provisions which related to withholding tax on amounts paid by partnerships to foreign partners."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id451729a7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id451729a8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Dat