{"tag":"section","attrib":{"id":"id4669c17e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039"},"text":null,"children":[{"tag":"num","attrib":{"value":"6039"},"text":"§ 6039.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns required in connection with certain options","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4669c17f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every corporation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4669c180-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which in any calendar year transfers to any person a share of stock pursuant to such person’s exercise of an incentive stock option, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c181-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which in any calendar year records (or has by its agent recorded) a transfer of the legal title of a share of stock acquired by the transferor pursuant to his exercise of an option described in section 423(c) (relating to special rule where option price is between 85 percent and 100 percent of value of stock),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall, for such calendar year, make a return at such time and in such manner, and setting forth such information, as the Secretary may by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4669c182-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements to be furnished to persons with respect to whom information is reported","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every corporation making a return under subsection (a) shall furnish to each person whose name is set forth in such return a written statement setting forth such information as the Secretary may by regulations prescribe. The written statement required under the preceding sentence shall be furnished to such person on or before January 31 of the year following the calendar year for which the return under subsection (a) was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4669c183-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4669c184-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment by employer to be determinative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any option which the corporation treats as an incentive stock option or an option granted under an employee stock purchase plan shall be deemed to be such an option.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c185-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsection (a)(2) applies only to first transfer described therein","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A statement is required by reason of a transfer described in subsection (a)(2) of a share only with respect to the first transfer of such share by the person who exercised the option.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c186-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any corporation which transfers any share of stock pursuant to the exercise of any option described in subsection (a)(2) shall identify such stock in a manner adequate to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4669c187-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For definition of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4669c188-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “incentive stock option”, see section 422(b), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c189-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “employee stock purchase plan”, see section 423(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4669c18a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s221/b/1"},"text":"Pub. L. 88–272, title II, § 221(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/73"},"text":"78 Stat. 73","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/167/s7/a"},"text":"Pub. L. 96–167, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-29"},"text":"Dec. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1276"},"text":"93 Stat. 1276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tII/s251/b/5"},"text":"Pub. L. 97–34, title II, § 251(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/259"},"text":"95 Stat. 259","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11801/c/9/J"},"text":"Pub. L. 101–508, title XI, § 11801(c)(9)(J)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-526"},"text":"104 Stat. 1388–526","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tVI/s6023/20"},"text":"Pub. L. 105–206, title VI, § 6023(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/825"},"text":"112 Stat. 825","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s403/a"},"text":"Pub. L. 109–432, div. A, title IV, § 403(a)","children":[],"tail":", (b), (c)(3), (4), "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2954"},"text":"120 Stat. 2954","children":[],"tail":", 2955; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/259"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(259)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1196"},"text":"132 Stat. 1196","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4669c18b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4669c18c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4669c18d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6039 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6040"},"text":"section 6040 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4669c18e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “the term ‘employee stock purchase plan’ see section 423(b).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s403/c/3"},"text":"Pub. L. 109–432, § 403(c)(3)","children":[],"tail":", substituted “Returns” for “Information” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s403/a"},"text":"Pub. L. 109–432, § 403(a)","children":[],"tail":", (c)(4), substituted “Requirement of reporting” for “Furnishing of information” in heading and amended concluding provisions generally. Prior to amendment, concluding provisions read as follows: “shall (on or before January 31 of the following calendar year) furnish to such person a written statement in such manner and setting forth such information as the Secretary may by regulations prescribe.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s403/b"},"text":"Pub. L. 109–432, § 403(b)","children":[],"tail":", added subsec. (b) and redesignated former subsecs. (b) and (c) as (c) and (d), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" inserted “to any person” after “transfers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11801/c/9/J/i"},"text":"Pub. L. 101–508, § 11801(c)(9)(J)(i)","children":[],"tail":", added pars. (1) and (2) and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) which in any calendar year transfers a share of stock to any person pursuant to such person’s exercise of a qualified stock option, an incentive stock option, or a restricted stock option, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) which in any calendar year records (or has by its agent recorded) a transfer of the legal title of a share of stock—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) acquired by the transfer or pursuant to his exercise of an option described in section 423(c) (relating to special rule where option price is between 85 percent and 100 percent of value of stock), or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) acquired by the transferor pursuant to his exercise of a restricted stock option described in section 424(c)(1) (relating to options under which option price is between 85 percent and 95 percent of value of stock),”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11801/c/9/J/ii"},"text":"Pub. L. 101–508, § 11801(c)(9)(J)(ii)","children":[],"tail":", substituted “an incentive stock option or an” for “a qualified stock option, incentive stock option, a restricted stock option, or an”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11801/c/9/J/iii"},"text":"Pub. L. 101–508, § 11801(c)(9)(J)(iii)","children":[],"tail":", amended subsec. (c) generally, striking out references for definitions of “qualified stock option” and “restricted stock option”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s251/b/5/A"},"text":"Pub. L. 97–34, § 251(b)(5)(A)","children":[],"tail":", inserted “, an incentive stock option,” after “qualified stock option”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s251/b/5/B"},"text":"Pub. L. 97–34, § 251(b)(5)(B)","children":[],"tail":", inserted “incentive stock option,” after “qualified stock option,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s251/b/5/C"},"text":"Pub. L. 97–34, § 251(b)(5)(C)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/167"},"text":"Pub. L. 96–167","children":[],"tail":" substituted “Furnishing of information” for “Requirement of reporting” in heading, and in closing par. substituted provisions relating to the furnishing, on or before Jan. 31 of the following calendar year, a written statement in such manner and setting forth such information, as prescribed by regulation for provisions prescribing the making of a return at such time and in such manner as prescribed by regulation, determining qualified stock options, restricted stock options or options granted under an employee stock purchase plan to be options under the provisions of this section, and restricting the necessity of a return only to the first transfer of such share."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/167"},"text":"Pub. L. 96–167","children":[],"tail":" added subsec. (b). Former subsec. (b), requiring every corporation making a return to furnish each person named in the return a written statement setting forth such information as prescribed by regulation, and requiring such statement to be furnished before January 31 of the year following the calendar year for which the return was made, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/167"},"text":"Pub. L. 96–167","children":[],"tail":" redesignated subsec. (d) as (c). Former subsec. (c), requiring any corporation transferring any share of stock pursuant to the exercise of an option described in subsec. (a)(2) to identify such stock, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/167"},"text":"Pub. L. 96–167","children":[],"tail":" redesignated subsec. (d) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4669c18f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4669c190-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s403/d"},"text":"Pub. L. 109–432, div. A, title IV, § 403(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2955"},"text":"120 Stat. 2955","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/432/dA/tIV/s403/d"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6724"},"text":"section 6724 of this title","children":[],"tail":"] shall apply to calendar years beginning after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4669c191-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" applicable with respect to options granted on or after "},{"tag":"date","attrib":{"date":"1976-01-01"},"text":"Jan. 1, 1976","children":[],"tail":", and exercised on or after "},{"tag":"date","attrib":{"date":"1981-01-01"},"text":"Jan. 1, 1981","children":[],"tail":", or outstanding on "},{"tag":"date","attrib":{"date":"1981-01-01"},"text":"Jan. 1, 1981","children":[],"tail":", or granted on or after "},{"tag":"date","attrib":{"date":"1976-01-01"},"text":"Jan. 1, 1976","children":[],"tail":", and outstanding "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/s251/c"},"text":"section 251(c) of Pub. L. 97–34","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s422"},"text":"section 422 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4669c192-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/167"},"text":"Pub. L. 96–167","children":[],"tail":" applicable with respect to calendar years beginning after 1979, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/167/s7/c"},"text":"section 7(c) of Pub. L. 96–167","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6652"},"text":"section 6652 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4669c193-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to stock transferred pursuant to options exercised on or after ","children":[{"tag":"date","attrib":{"date":"1964-01-01"},"text":"Jan. 1, 1964","children":[],"tail":", See "},{"tag":"ref","attrib":{"href":"/us/pl/88/272/s221/e"},"text":"section 221(e) of Pub. L. 88–272","children":[],"tail":", set out as an Effective Date of 1964 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s421"},"text":"section 421 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id4669c194-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that nothing in amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" be construed to affect treatment of certain transactions occurring, property acquired, or items of income, loss, deduction, or credit taken into account prior to "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", for purposes of determining liability for tax for periods ending after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11821/b"},"text":"section 11821(b) of Pub. L. 101–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s45K"},"text":"section 45K of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
