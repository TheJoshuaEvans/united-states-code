{"tag":"section","attrib":{"id":"id45f02533-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955"},"text":null,"children":[{"tag":"num","attrib":{"value":"4955"},"text":"§ 4955.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxes on political expenditures of section 501(c)(3) organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45f02534-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial taxes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f02535-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On the organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on each political expenditure by a section 501(c)(3) organization a tax equal to 10 percent of the amount thereof. The tax imposed by this paragraph shall be paid by the organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f02536-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On the management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on the agreement of any organization manager to the making of any expenditure, knowing that it is a political expenditure, a tax equal to 2½ percent of the amount thereof, unless such agreement is not willful and is due to reasonable cause. The tax imposed by this paragraph shall be paid by any organization manager who agreed to the making of the expenditure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f02537-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional taxes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f02538-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On the organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which an initial tax is imposed by subsection (a)(1) on a political expenditure and such expenditure is not corrected within the taxable period, there is hereby imposed a tax equal to 100 percent of the amount of the expenditure. The tax imposed by this paragraph shall be paid by the organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f02539-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On the management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which an additional tax is imposed by paragraph (1), if an organization manager refused to agree to part or all of the correction, there is hereby imposed a tax equal to 50 percent of the amount of the political expenditure. The tax imposed by this paragraph shall be paid by any organization manager who refused to agree to part or all of the correction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f0253a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsections (a) and (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f0253b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint and several liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If more than 1 person is liable under subsection (a)(2) or (b)(2) with respect to the making of a political expenditure, all such persons shall be jointly and severally liable under such subsection with respect to such expenditure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f0253c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit for management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any 1 political expenditure, the maximum amount of the tax imposed by subsection (a)(2) shall not exceed $5,000, and the maximum amount of the tax imposed by subsection (b)(2) shall not exceed $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f0253d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Political expenditure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f0253e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “political expenditure” means any amount paid or incurred by a section 501(c)(3) organization in any participation in, or intervention in (including the publication or distribution of statements), any political campaign on behalf of (or in opposition to) any candidate for public office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f0253f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain other expenditures included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an organization which is formed primarily for purposes of promoting the candidacy (or prospective candidacy) of an individual for public office (or which is effectively controlled by a candidate or prospective candidate and which is availed of primarily for such purposes), the term “political expenditure” includes any of the following amounts paid or incurred by the organization:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f02540-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts paid or incurred to such individual for speeches or other services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f02541-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Travel expenses of such individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f02542-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expenses of conducting polls, surveys, or other studies, or preparing papers or other materials, for use by such individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f02543-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expenses of advertising, publicity, and fundraising for such individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f02544-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other expense which has the primary effect of promoting public recognition, or otherwise primarily accruing to the benefit, of such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f02545-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with sections 4945 and 4958","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If tax is imposed under this section with respect to any political expenditure, such expenditure shall not be treated as a taxable expenditure for purposes of section 4945 or an excess benefit for purposes of section 4958.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f02546-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f02547-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 501(c)(3) organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “section 501(c)(3) organization” means any organization which (without regard to any political expenditure) would be described in section 501(c)(3) and exempt from taxation under section 501(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f02548-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization manager","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “organization manager” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f02549-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any officer, director, or trustee of the organization (or individual having powers or responsibilities similar to those of officers, directors, or trustees of the organization), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f0254a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any expenditure, any employee of the organization having authority or responsibility with respect to such expenditure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f0254b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “correction” and “correct” mean, with respect to any political expenditure, recovering part or all of the expenditure to the extent recovery is possible, establishment of safeguards to prevent future political expenditures, and where full recovery is not possible, such additional corrective action as is prescribed by the Secretary by regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f0254c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “taxable period” means, with respect to any political expenditure, the period beginning with the date on which the political expenditure occurs and ending on the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f0254d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of mailing a notice of deficiency under section 6212 with respect to the tax imposed by subsection (a)(1), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f0254e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4955/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which tax imposed by subsection (a)(1) is assessed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45f0254f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10712/a"},"text":"Pub. L. 100–203, title X, § 10712(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-465"},"text":"101 Stat. 1330–465","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/168/tXIII/s1311/c/1"},"text":"Pub. L. 104–168, title XIII, § 1311(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1478"},"text":"110 Stat. 1478","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45f02550-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45f02551-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45f02552-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168"},"text":"Pub. L. 104–168","children":[],"tail":" substituted “sections 4945 and 4958” for “section 4945” in heading and inserted “or an excess benefit for purposes of section 4958” before period at end of text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45f02553-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45f02554-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/tXIII/s1311/d/1"},"text":"Pub. L. 104–168, title XIII, § 1311(d)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1478"},"text":"110 Stat. 1478","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/168/tXIII/s1311/d/1"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4958"},"text":"section 4958 of this title","children":[],"tail":" and amending this section and sections 4963, 6213, 7422, and 7454 of this title] (other than subsection (b)) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s501"},"text":"section 501 of this title","children":[],"tail":"] shall apply to excess benefit transactions occurring on or after "},{"tag":"date","attrib":{"date":"1995-09-14"},"text":"September 14, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Binding contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments referred to in paragraph (1) shall not apply to any benefit arising from a transaction pursuant to any written contract which was binding on ","children":[{"tag":"date","attrib":{"date":"1995-09-13"},"text":"September 13, 1995","children":[],"tail":", and at all times thereafter before such transaction occurred.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45f02555-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10712/d"},"text":"Pub. L. 100–203, title X, § 10712(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-468"},"text":"101 Stat. 1330–468","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/203/tX/s10712/d"},"text":"“The amendments made by this section [enacting this section and amending sections 4962, 4963, 6213, 6501, 6503, 6684, 7422, and 7454 of this title] shall apply to taxable years beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
