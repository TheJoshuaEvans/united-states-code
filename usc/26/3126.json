{"tag":"section","attrib":{"id":"id456aa0fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3126"},"text":null,"children":[{"tag":"num","attrib":{"value":"3126"},"text":"§ 3126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return and payment by governmental em­ployer","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If the employer is a State or political subdivision thereof, or an agency or instrumentality of any one or more of the foregoing, the return of the amount deducted and withheld upon any wages under section 3101 and the amount of the tax imposed by section 3111 may be made by any officer or employee of such State or political subdivision or such agency or instrumentality, as the case may be, having control of the payment of such wages, or appropriately designated for that purpose.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id456aa0ff-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIX/s9002/a/1"},"text":"Pub. L. 99–509, title IX, § 9002(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1970"},"text":"100 Stat. 1970","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id456aa100-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id456aa101-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id456aa102-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3126 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3128"},"text":"section 3128 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id456aa103-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id456aa104-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section, except as otherwise provided, effective with respect to payments due with respect to wages paid after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", including wages paid after such date by a State (or political subdivision thereof) that modified its agreement pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s418/e/2"},"text":"section 418(e)(2) of Title 42","children":[],"tail":", The Public Health and Welfare, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/s9002/d"},"text":"section 9002(d) of Pub. L. 99–509","children":[],"tail":", set out as an Effective Date of 1986 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s418"},"text":"section 418 of Title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
