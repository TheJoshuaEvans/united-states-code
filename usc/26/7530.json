{"tag":"section","attrib":{"id":"id4774c888-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530"},"text":null,"children":[{"tag":"num","attrib":{"value":"7530"},"text":"§ 7530.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of earned income tax credit to possessions of the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4774c889-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Puerto Rico","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4774c88a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to calendar year 2021 and each calendar year thereafter, the Secretary shall, except as otherwise provided in this subsection, make payments to Puerto Rico equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4774c88b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specified matching amount for such calendar year, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c88c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of calendar years 2021 through 2025, the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4774c88d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expenditures made by Puerto Rico during such calendar year for education efforts with respect to individual taxpayers and tax return preparers relating to the earned income tax credit, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4774c88e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4774c88f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to reform earned income tax credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not make any payments under paragraph (1) with respect to any calendar year unless Puerto Rico has in effect an earned income tax credit for taxable years beginning in or with such calendar year which (relative to the earned income tax credit which was in effect for taxable years beginning in or with calendar year 2019) increases the percentage of earned income which is allowed as a credit for each group of individuals with respect to which such percentage is separately stated or determined in a manner designed to substantially increase workforce participation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4774c890-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified matching amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4774c891-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “specified matching amount” means, with respect to any calendar year, the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4774c892-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the excess (if any) of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4774c893-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost to Puerto Rico of the earned income tax credit for taxable years beginning in or with such calendar year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4774c894-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the base amount for such calendar year, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4774c895-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product of 3, multiplied by the base amount for such calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c896-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Base amount","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4774c897-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Base amount for 2021","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of calendar year 2021, the term “base amount” means the greater of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4774c898-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost to Puerto Rico of the earned income tax credit for taxable years beginning in or with calendar year 2019 (rounded to the nearest multiple of $1,000,000), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4774c899-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $200,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4774c89a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any calendar year after 2021, the term “base amount” means the dollar amount determined under clause (i) increased by an amount equal to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4774c89b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dollar amount, multiplied by—","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4774c89c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost-of-living adjustment determined under section 1(f)(3) for such calendar year, determined by substituting “calendar year 2020” for “calendar year 2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" Any amount determined under this clause shall be rounded to the nearest multiple of $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4774c89d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules related to payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4774c89e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make payments under paragraph (1) for any calendar year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4774c89f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after receipt of such information as the Secretary may require to determine such payments, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4774c8a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in clause (i), within a reasonable period of time before the due date for individual income tax returns (as determined under the laws of Puerto Rico) for taxable years which began on the first day of such calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c8a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require the reporting of such information as the Secretary may require to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c8a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of cost of earned income tax credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the cost to Puerto Rico of the earned income tax credit shall be determined by the Secretary on the basis of the laws of Puerto Rico and shall include reductions in revenues received by Puerto Rico by reason of such credit and refunds attributable to such credit, but shall not include any administrative costs with respect to such credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4774c8a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Possessions with mirror code tax systems","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4774c8a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to calendar year 2021 and each calendar year thereafter, the Secretary shall, except as otherwise provided in this subsection, make payments to the Virgin Islands, Guam, and the Commonwealth of the Northern Mariana Islands equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4774c8a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost to such possession of the earned income tax credit for taxable years beginning in or with such calendar year, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c8a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of calendar years 2021 through 2025, the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4774c8a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expenditures made by such possession during such calendar year for education efforts with respect to individual taxpayers and tax return preparers relating to such earned income tax credit, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4774c8a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4774c8a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of certain rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of subparagraphs (A), (B), and (C) of subsection (a)(4) shall apply for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4774c8aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" American Samoa","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4774c8ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to calendar year 2021 and each calendar year thereafter, the Secretary shall, except as otherwise provided in this subsection, make payments to American Samoa equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4774c8ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4774c8ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost to American Samoa of the earned income tax credit for taxable years beginning in or with such calendar year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4774c8ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $16,000,000, plus","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c8af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of calendar years 2021 through 2025, the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4774c8b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expenditures made by American Samoa during such calendar year for education efforts with respect to individual taxpayers and tax return preparers relating to such earned income tax credit, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4774c8b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4774c8b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to enact and maintain an earned income tax credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not make any payments under paragraph (1) with respect to any calendar year unless American Samoa has in effect an earned income tax credit for taxable years beginning in or with such calendar year which allows a refundable tax credit to individuals on the basis of the taxpayer’s earned income which is designed to substantially increase workforce participation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4774c8b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any calendar year after 2021, the $16,000,000 amount in paragraph (1)(A)(ii) shall be increased by an amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4774c8b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dollar amount, multiplied by—","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c8b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost-of-living adjustment determined under section 1(f)(3) for such calendar year, determined by substituting “calendar year 2020” for “calendar year 2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any increase determined under this clause shall be rounded to the nearest multiple of $100,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4774c8b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of certain rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of subparagraphs (A), (B), and (C) of subsection (a)(4) shall apply for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4774c8b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7530/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1324"},"text":"section 1324 of title 31","children":[],"tail":", United States Code, the payments under this section shall be treated in the same manner as a refund due from a credit provision referred to in subsection (b)(2) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4774c8b8-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIX/s9625/a"},"text":"Pub. L. 117–2, title IX, § 9625(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/155"},"text":"135 Stat. 155","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
