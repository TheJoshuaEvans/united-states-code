ib":{"href":"/us/pl/94/455/tXIX/s1903/a/8"},"text":"Pub. L. 94–455, title XIX, § 1903(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1807"},"text":"90 Stat. 1807","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tVII/s741/b"},"text":"Pub. L. 97–34, title VII, § 741(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/347"},"text":"95 Stat. 347","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/76/tII"},"text":"Pub. L. 98–76, title II","children":[],"tail":", §§ 211(c), 223, "},{"tag":"date","attrib":{"date":"1983-08-12"},"text":"Aug. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/419"},"text":"97 Stat. 419","children":[],"tail":", 421; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tV/s5125/b"},"text":"Pub. L. 101–508, title V, § 5125(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-285"},"text":"104 Stat. 1388–285","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/90/tII"},"text":"Pub. L. 107–90, title II","children":[],"tail":", §§ 203(a), 204(b), "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/891"},"text":"115 Stat. 891","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/100/B"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(100)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4052"},"text":"128 Stat. 4052","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4571cd61-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4571cd62-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4571cd63-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) consisted of pars. (1) and (2) establishing the tier 2 tax and its applicable percentage."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/90/s204/b"},"text":"Pub. L. 107–90, § 204(b)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a), which related to imposition of tier 1 and 2 taxes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/90/s204/b"},"text":"Pub. L. 107–90, § 204(b)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/90/s203/a"},"text":"Pub. L. 107–90, § 203(a)","children":[],"tail":", struck out subsec. (b) which read as follows: “In addition to other taxes, there is hereby imposed on the income of each employee representative a tax at a rate equal to the rate of excise tax imposed on every employer, provided for in section 3221(c), for each man-hour for which compensation is paid to him for services rendered as an employee representative.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/90/s204/b"},"text":"Pub. L. 107–90, § 204(b)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted “applicable” for “following” before “percentage of the” and provision defining the term “applicable percentage” for provision specifying that in the case of compensation received during 1985 the rate of tax was 14.10 percent, for 1986 or 1987 the rate was 14.30 percent, for 1988 or 1989 the rate was 15.02 percent, and for 1990 or thereafter the rate was 15.30 percent."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/76/s223"},"text":"Pub. L. 98–76, § 223","children":[],"tail":", substituted provisions imposing a two tiered tax on each employee representative equal to the percentage of the compensation received during any calendar year by such employee representative for services rendered as is set out in accompanying tables, for provisions that had imposed on each employee representative a tax equal to 12.75 percent plus the sum of the rates of tax imposed with respect to wages by sections 3101(a), 3101(b), 3111(a), and 3111(b) of so much of the compensation paid in any calendar month to such employee representative for services rendered by him as was not in excess of an amount equal to one-twelfth of the current maximum annual taxable “wage” as defined in section 3121 for any month."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/76/s211/c"},"text":"Pub. L. 98–76, § 211(c)","children":[],"tail":", substituted “12.75 percent” for “11.75 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" substituted “11.75” for “9.5”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted “3111(a), and 3111(b)” for “3111(a), 3111(b)”, struck out “of the Internal Revenue Code of 1954” before “of so much of the compensation”, “after "},{"tag":"date","attrib":{"date":"1973-09-30"},"text":"September 30, 1973","children":[],"tail":",” after “rendered by him”, “of the Internal Revenue Code of 1954” after “as defined in section 3121”, and “after "},{"tag":"date","attrib":{"date":"1973-09-30"},"text":"September 30, 1973","children":[],"tail":"” after “for any month”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/93"},"text":"Pub. L. 94–93","children":[],"tail":" inserted “in any calendar month” after “compensation paid”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/69"},"text":"Pub. L. 93–69","children":[],"tail":" substituted new tax rate provisions on income of employee representatives for services rendered after "},{"tag":"date","attrib":{"date":"1973-09-30"},"text":"Sept. 30, 1973","children":[],"tail":", for former provisions which prescribed 12½, 13, 14, 14½, and 15 percent on income for services rendered after "},{"tag":"date","attrib":{"date":"1965-09-30"},"text":"Sept. 30, 1965","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-12-31"},"text":"Dec. 31, 1965","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-12-31"},"text":"Dec. 31, 1966","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-31"},"text":"Dec. 31, 1967","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1968-12-31"},"text":"Dec. 31, 1968","children":[],"tail":", respectively, as is not in excess of (i) $450, or (ii) an amount equal to one-twelfth of the current maximum annual taxable “wages” as defined in section 3121 of the Internal Revenue Code of 1954, whichever is greater, for any month after "},{"tag":"date","attrib":{"date":"1965-09-30"},"text":"September 30, 1965","children":[],"tail":": "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the rate of tax imposed by this section shall be increased, with respect to compensation paid for services rendered after "},{"tag":"date","attrib":{"date":"1965-09-30"},"text":"September 30, 1965","children":[],"tail":", by a number of percentage points (including fractional points) equal at any given time to twice the number of percentage points (including fractional points) by which the rate of the tax imposed with respect to wages by section 3101(a) plus the rate imposed by section 3101(b) at such time exceeds 2¾ percent (the rate provided by paragraph (2) of section 3101 as amended by the Social Security Amendments of 1956)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/215"},"text":"Pub. L. 91–215","children":[],"tail":" substituted the rate of excise tax imposed on every employer under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3221/c"},"text":"section 3221(c) of this title","children":[],"tail":" for a flat 2-cents per man hour tax as the rate for additional taxes imposed on the income of employee representatives for each man hour of compensation paid."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/700"},"text":"Pub. L. 89–700","children":[],"tail":" substituted “rendered after "},{"tag":"date","attrib":{"date":"1965-09-30"},"text":"September 30, 1965","children":[],"tail":"” for “rendered after "},{"tag":"date","attrib":{"date":"1964-12-31"},"text":"December 31, 1964","children":[],"tail":"”, and “(i) $450, or (ii) an amount equal to one-twelfth of the current maximum annual taxable ‘wages’ as defined in section 3121 of the Internal Revenue Code of 1954, whichever is greater, for any month after "},{"tag":"date","attrib":{"date":"1965-09-30"},"text":"September 30, 1965","children":[],"tail":"” for “$400 for any calendar month before the calendar month next following the month in which this provision was amended in 1963, or $450 for any calendar month after the month in which this provision was so amended and before the calendar month next following the calendar month in which this provision was amended in 1965, or (i) $450, or (ii) an amount equal to one-twelfth of the current maximum annual taxable ‘wages’ as defined in section 3121 of the Internal Revenue Code of 1954, whichever is greater, for any month after the month in which this provision was so amended”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/699/s301/b"},"text":"Pub. L. 89–699, § 301(b)","children":[],"tail":", (d), designated existing provisions as subsec. (a), and substituted “14 percent” for “13½ percent” in subd. (3), “14½ percent” for “14 percent” in subd. (4), and “15 percent” for “14½ percent” in subd. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/699/s301/d"},"text":"Pub. L. 89–699, § 301(d)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/212"},"text":"Pub. L. 89–212","children":[],"tail":" substituted pars. (1) to (5) for former pars. (1) and (2) which imposed a tax equal to 13½ percent of so much of the compensation paid to such employee representative for services rendered by him after the month in which this provision was amended in 1959, and before "},{"tag":"date","attrib":{"date":"1962-01-01"},"text":"Jan. 1, 1962","children":[],"tail":", and 14½ percent of so much of the compensation paid to such employee representative for services rendered by him after "},{"tag":"date","attrib":{"date":"1961-12-31"},"text":"Dec. 31, 1961","children":[],"tail":", and inserted “and before the calendar month next following the calendar month in which this provision was amended in 1965, or (i) $450, or (ii) an amount equal to one-twelfth of the current maximum annual taxable ‘wages’ as defined in section 3121, whichever is greater, for any month after the month in which this provision was so amended”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/97"},"text":"Pub. L. 89–97","children":[],"tail":" substituted “the rate of the tax imposed with respect to wages by section 3101(a) at such time exceeds 2¾ percent (the rate provided by paragraph (2) of section 3101 as amended by the Social Security Amendments of 1956)” for “the rate of the tax imposed with respect to wages by section 3101 at such time exceeds the rate provided by paragraph (2) of such section 3101 as amended by the Social Security Amendments of 1956” and inserted “plus the rate imposed by section 3101(b)” after “section 3101(a)”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/133"},"text":"Pub. L. 88–133","children":[],"tail":" limited the existing taxable compensation base of $400 to any calendar month before Nov. 1963 and increased such base to $450 for any calendar month after Oct. 1963."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/28"},"text":"Pub. L. 86–28","children":[],"tail":" increased the tax from 12½ percent of the compensation not in excess of $350 for any calendar month to 13½ percent of the compensation not in excess of $400 for any calendar month for services rendered before "},{"tag":"date","attrib":{"date":"1962-01-01"},"text":"Jan. 1, 1962","children":[],"tail":", and to 14½ percent for services rendered after "},{"tag":"date","attrib":{"date":"1961-12-31"},"text":"Dec. 31, 1961","children":[],"tail":", and required an increase in the rate of tax with respect to compensation paid for services rendered after "},{"tag":"date","attrib":{"date":"1964-12-31"},"text":"December 31, 1964","children":[],"tail":", by a number of percentage points equal at any given time to twice the number of percentage points by which the rate of tax imposed by "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3101"},"text":"section 3101 of this title","children":[],"tail":" at such time exceeds the rate provided by par. (2) of such section 3101 as amended by the Social Security Amendments of 1956."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-08-31"},"text":"Aug. 31, 1954","children":[],"tail":", substituted “$350” for “$300”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4571cd64-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4571cd65-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/b"},"text":"section 221(b) of Pub. L. 113–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAme