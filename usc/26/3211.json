{"tag":"section","attrib":{"id":"id4571cd5c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3211"},"text":null,"children":[{"tag":"num","attrib":{"value":"3211"},"text":"§ 3211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4571cd5d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3211/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tier 1 tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to other taxes, there is hereby imposed on the income of each employee representative a tax equal to the applicable percentage of the compensation received during any calendar year by such employee representative for services rendered by such employee representative. For purposes of the preceding sentence, the term “applicable percentage” means the percentage equal to the sum of the rates of tax in effect under subsections (a) and (b) of section 3101 and subsections (a) and (b) of section 3111 for the calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4571cd5e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3211/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tier 2 tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to other taxes, there is hereby imposed on the income of each employee representative a tax equal to the percentage determined under section 3241 for any calendar year of the compensation received during such calendar year by such employee representative for services rendered by such employee representative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4571cd5f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3211/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For application of different contribution bases with respect to the taxes imposed by subsections (a) and (b), see section 3231(e)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4571cd60-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/432"},"text":"68A Stat. 432","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-31/ch1164"},"text":"Aug. 31, 1954, ch. 1164","children":[],"tail":", pt. II, § 206(a), "},{"tag":"ref","attrib":{"href":"/us/stat/68/1040"},"text":"68 Stat. 1040","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/28"},"text":"Pub. L. 86–28","children":[],"tail":", pt. II, § 201(c), "},{"tag":"date","attrib":{"date":"1959-05-19"},"text":"May 19, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/29"},"text":"73 Stat. 29","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/133/tII/s201"},"text":"Pub. L. 88–133, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-10-05"},"text":"Oct. 5, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/221"},"text":"77 Stat. 221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/97/tI"},"text":"Pub. L. 89–97, title I","children":[],"tail":", §§ 105(b)(2), 111(c)(2), "},{"tag":"date","attrib":{"date":"1965-07-30"},"text":"July 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":