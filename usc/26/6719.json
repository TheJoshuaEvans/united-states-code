{"tag":"section","attrib":{"id":"id4736d5fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6719"},"text":null,"children":[{"tag":"num","attrib":{"value":"6719"},"text":"§ 6719.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to register or reregister","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4736d5fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6719/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to register or reregister","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person who is required to register or reregister under section 4101 and fails to do so shall pay a penalty in addition to the tax (if any).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d5fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6719/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the penalty under subsection (a) shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4736d5fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6719/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000 for each initial failure to register or reregister, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d5fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6719/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000 for each day thereafter such person fails to register or reregister.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d5ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6719/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable cause exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed under this section with respect to any failure if it is shown that such failure is due to reasonable cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4736d600-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s863/c/1"},"text":"Pub. L. 108–357, title VIII, § 863(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1620"},"text":"118 Stat. 1620","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11164/b/1"},"text":"Pub. L. 109–59, title XI, § 11164(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1975"},"text":"119 Stat. 1975","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4736d601-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4736d602-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4736d603-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","at