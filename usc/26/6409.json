{"tag":"section","attrib":{"id":"id46dc323e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6409"},"text":null,"children":[{"tag":"num","attrib":{"value":"6409"},"text":"§ 6409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refunds disregarded in the administration of Federal programs and federally assisted programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, any refund (or advance payment with respect to a refundable credit) made to any individual under this title shall not be taken into account as income, and shall not be taken into account as resources for a period of 12 months from receipt, for purposes of determining the eligibility of such individual (or any other individual) for benefits or assistance (or the amount or extent of benefits or assistance) under any Federal program or under any State or local program financed in whole or in part with Federal funds.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id46dc323f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312/tVII/s728/a"},"text":"Pub. L. 111–312, title VII, § 728(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-17"},"text":"Dec. 17, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3317"},"text":"124 Stat. 3317","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/tI/s103/d"},"text":"Pub. L. 112–240, title I, § 103(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2320"},"text":"126 Stat. 2320","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46dc3240-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46dc3241-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46dc3242-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/240"},"text":"Pub. L. 112–240","children":[],"tail":" amended section generally. Prior to amendment, section related to refunds disregarded in the administration of Federal programs and federally assisted programs and provided that the provisions were inapplicable to any amount received after "},{"tag":"date","attrib":{"date":"2012-12-31"},"text":"Dec. 31, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46dc3243-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46dc3244-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/240"},"text":"Pub. L. 112–240","children":[],"tail":" applicable to amounts received after "},{"tag":"date","attrib":{"date":"2012-12-31"},"text":"Dec. 31, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/s103/e/2"},"text":"section 103(e)(2) of Pub. L. 112–240","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s24"},"text":"section 24 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46dc3245-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312/tVII/s728/c"},"text":"Pub. L. 111–312, title VII, § 728(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-17"},"text":"Dec. 17, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3317"},"text":"124 Stat. 3317","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/312/tVII/s728/c"},"text":"“The amendments made by this section [enacting this section] shall apply to amounts received after ","children":[{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
