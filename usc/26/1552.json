{"tag":"section","attrib":{"id":"id451e5612-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1552"},"text":null,"children":[{"tag":"num","attrib":{"value":"1552"},"text":"§ 1552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Earnings and profits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id451e5613-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1552/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to regulations prescribed by the Secretary the earnings and profits of each member of an affiliated group required to be included in a consolidated return for such group filed for a taxable year shall be determined by allocating the tax liability of the group for such year among the members of the group in accord with whichever of the following methods the group shall elect in its first consolidated return filed for such a taxable year:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id451e5614-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1552/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The tax liability shall be apportioned among the members of the group in accordance with the ratio which that portion of the consolidated taxable income attributable to each member of the group having taxable income bears to the consolidated taxable income.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id451e5615-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1552/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The tax liability of the group shall be allocated to the several members of the group on the basis of the percentage of the total tax which the tax of such member if computed on a separate return would bear to the total amount of the taxes for all members of the group so computed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id451e5616-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1552/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The tax liability of the group (excluding the tax increases arising from the consolidation) shall be allocated on the basis of the contribution of each member of the group to the consolidated taxable income of the group. Any tax increases arising from the consolidation shall be distributed to the several members in direct proportion to the reduction in tax liability resulting to such members from the filing of the consolidated return as measured by the difference between their tax liabilities determined on a separate return basis and their tax liabilities based on their contributions to the consolidated taxable income.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id451e5617-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1552/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The tax liability of the group shall be allocated in accord with any other method selected by the group with the approval of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id451e5618-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1552/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to elect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If no election is made in such first return, the tax liability shall be allocated among the several members of the group pursuant to the method prescribed in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id451e5619-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/371"},"text":"68A Stat. 371","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s234/b/8"},"text":"Pub. L. 88–272, title II, § 234(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/116"},"text":"78 Stat. 116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1901(a)(159), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1790"},"text":"90 Stat. 1790","children":[],"tail":", 1834.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id451e561a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id451e561b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id451e561c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 1901(a)(159), 1906(b)(13)(A), struck out “beginning after "},{"tag":"date","attrib":{"date":"1953-12-31"},"text":"December 31, 1953","children":[],"tail":", and ending after the date of enactment of this title” after “group filed for a taxable year”, and “or his delegate” after “Secretary” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272"},"text":"Pub. L. 88–272","children":[],"tail":" struck out “(determined without regard to the 2 percent increase provided by section 1503(a))”, before “based on their contributions”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id451e561d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id451e561e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/a/159"},"text":"section 1901(a)(159) of Pub. L. 94–455","children":[],"tail":" applicable with respect to taxable years beginning after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"Dec. 31, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/d"},"text":"section 1901(d) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id451e561f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1964 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272"},"text":"Pub. L. 88–272","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1963-12-31"},"text":"Dec. 31, 1963","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/88/272/s234/c"},"text":"section 234(c) of Pub. L. 88–272","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1503"},"text":"section 1503 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
