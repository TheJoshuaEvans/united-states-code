{"tag":"section","attrib":{"id":"id44003c0d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s723"},"text":null,"children":[{"tag":"num","attrib":{"value":"723"},"text":"§ 723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis of property contributed to partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The basis of property contributed to a partnership by a partner shall be the adjusted basis of such property to the contributing partner at the time of the contribution increased by the amount (if any) of gain recognized under section 721(b) to the contributing partner at such time.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id44003c0e-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/245"},"text":"68A Stat. 245","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXXI/s2131/c"},"text":"Pub. L. 94–455, title XXI, § 2131(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1924"},"text":"90 Stat. 1924","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII/s722/f/1"},"text":"Pub. L. 98–369, div. A, title VII, § 722(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/974"},"text":"98 Stat. 974","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44003c0f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44003c10-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"headi