{"tag":"section","attrib":{"id":"id413275ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s68"},"text":null,"children":[{"tag":"num","attrib":{"value":"68"},"text":"§ 68.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overall limitation on itemized deductions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id413275cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s68/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an individual, the amount of the itemized deductions otherwise allowable for the taxable year (determined without regard to this section) shall be reduced by ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"37","children":[],"tail":" of the lesser of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id413275d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s68/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount of itemized deductions, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id413275d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s68/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" so much of the taxable income of the taxpayer for the taxable year (determined without regard to this section and increased by such amount of itemized deductions) as exceeds the dollar amount at which the 37 percent rate bracket under section 1 begins with respect to the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id413275d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s68/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall be applied after the application of any other limitation on the allowance of any itemized deduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id413275d3-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11103/a"},"text":"Pub. L. 101–508, title XI, § 11103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-406"},"text":"104 Stat. 1388–406","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII"},"text":"Pub. L. 103–66, title XIII","children":[],"tail":", §§ 13201(b)(3)(E), 13204, "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/459"},"text":"107 Stat. 459","children":[],"tail":", 462; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dJ/tIV/s4004/b/2"},"text":"Pub. L. 105–277, div. J, title IV, § 4004(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-911"},"text":"112 Stat. 2681–911","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tI/s103/a"},"text":"Pub. L. 107–16, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/44"},"text":"115 Stat. 44","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/tI/s101/b/2/A"},"text":"Pub. L. 112–240, title I, § 101(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2316"},"text":"126 Stat. 2316","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI"},"text":"Pub. L. 115–97, title I","children":[],"tail":", §§ 11002(d)(2), 11046(a), "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2061"},"text":"131 Stat. 2061","children":[],"tail":", 2088; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/33"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(33)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1186"},"text":"132 Stat. 1186","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70111/a"},"text":"Pub. L. 119–21, title VII, § 70111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/164"},"text":"139 Stat. 164","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id413275d4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id413275d5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inflation Adjusted Items for Certain Years","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For inflation adjustment of certain items in this section, see Revenue Procedures listed in a table under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id413275d6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id413275d7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) to (f) relating, respectively, to general rule, applicable amount, exception for certain itemized deductions, coordination with other limitations, exception for estates and trusts, and this section not applying to any taxable year beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2026-01-01"},"text":"Jan. 1, 2026","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “shall be” for “shall be shall be” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s11002/d/2"},"text":"Pub. L. 115–97, § 11002(d)(2)","children":[],"tail":", substituted “1(f)(3)(A)(ii)” for “1(f)(3)(B)” and “2016” for “1992”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s11046/a"},"text":"Pub. L. 115–97, § 11046(a)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/240/s101/b/2/A/i"},"text":"Pub. L. 112–240, § 101(b)(2)(A)(i)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—For purposes of this section, the term ‘applicable amount’ means $100,000 ($50,000 in the case of a separate return by a married individual within the meaning of section 7703)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Inflation adjustments","children":[],"tail":".—In the case of any taxable year beginning in a calendar year after 1991, each dollar amount contained in paragraph (1) shall be increased by an amount equal to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) such dollar amount, multiplied by","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the cost-of-living adjustment determined under section 1(f)(3) for the calendar year in which the taxable year begins, by substituting ‘calendar year 1990’ for ‘calendar year 1992’ in subparagraph (B) thereof.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/240/s101/b/2/A/ii"},"text":"Pub. L. 112–240, § 101(b)(2)(A)(ii)","children":[],"tail":", struck out subsecs. (f) and (g), which related to phaseout of limitation and termination of applicability of section, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16"},"text":"Pub. L. 107–16","children":[],"tail":" added subsecs. (f) and (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" substituted “for casualty or theft losses described in paragraph (2) or (3) of section 165(c) or for losses described in section 165(d)” for “for losses described in subsection (c)(3) or (d) of section 165”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13201/b/3/E"},"text":"Pub. L. 103–66, § 13201(b)(3)(E)","children":[],"tail":", substituted “1992” for “1989”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13204"},"text":"Pub. L. 103–66, § 13204","children":[],"tail":", struck out heading and text of subsec. (f). Text read as follows: “This section shall not apply to any taxable year beginning after "},{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4134bfc8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4134bfc9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70111/c"},"text":"Pub. L. 119–21, title VII, § 70111(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/165"},"text":"139 Stat. 165","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70111/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s199A"},"text":"section 199A of this title","children":[],"tail":"] shall apply to taxable ye