{"tag":"section","attrib":{"id":"id46543d99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5881"},"text":null,"children":[{"tag":"num","attrib":{"value":"5881"},"text":"§ 5881.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greenmail","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46543d9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5881/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on any person who receives greenmail a tax equal to 50 percent of gain or other income of such person by reason of such receipt.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46543d9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5881/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greenmail","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “greenmail” means any consideration transferred by a corporation (or any person acting in concert with such corporation) to directly or indirectly acquire stock of such corporation from any shareholder if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46543d9c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5881/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such shareholder held such stock (as determined under section 1223) for less than 2 years before entering into the agreement to make the transfer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46543d9d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5881/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at some time during the 2-year period ending on the date of such acquisition—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46543d9e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5881/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such shareholder,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46543d9f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5881/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person acting in concert with such shareholder, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46543da0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5881/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who is related to such shareholder or person described in subparagraph (B),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"made or threatened to make a public tender offer for stock of such corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46543da1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5881/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such acquisition is pursuant to an offer which was not made on the same terms to all shareholders.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of the preceding sentence, payments made in connection with, or in transactions related to, an acquisition shall be treated as paid in such acquisition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46543da2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5881/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46543da3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5881/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public tender offer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “public tender offer” means any offer to purchase or otherwise acquire stock or assets in a corporation if such offer was or would be required to be filed or registered with any Federal or State agency regulating securities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46543da4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5881/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person is related to another person if the relationship between such persons would result in the disallowance of losses under section 267 or 707(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46543da5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5881/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax applies whether or not amount recognized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by this section shall apply whether or not the gain or other income referred to in subsection (a) is recognized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46543da6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5881/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of the deficiency procedures of subtitle F, any tax imposed by this section shall be treated as a tax imposed by subtitle A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46543da7-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10228/a"},"text":"Pub. L. 100–203, title X, § 10228(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-417"},"text":"101 Stat. 1330–417","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tII/s2004"},"text":"Pub. L. 100–647, title II, § 2004","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1)(A), (B)(i), (C), (2), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3608"},"text":"102 Stat. 3608","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46543da8-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46543da9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46543daa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004"},"text":"Pub. L. 100–647, § 2004","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1)(A), substituted “gain or other income of such person by reason of such receipt” for “gain realized by such person on such receipt”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004"},"text":"Pub. L. 100–647, § 2004","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1)(B)(i), substituted “a corporation (or any person acting in concert with such corporation) to directly or indirectly acquire stock of such corporation” for “a corporation to directly or indirectly acquire its stock”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004"},"text":"Pub. L. 100–647, § 2004","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1)(C), substituted “amount” for “gain” in heading and inserted “or other income” after “the gain” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004"},"text":"Pub. L. 100–647, § 2004","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(2), added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46543dab-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46543dac-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 2004(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1)(A), (C), (2) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Revenue Act of 1987, "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX"},"text":"Pub. L. 100–203, title X","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/u"},"text":"section 2004(u) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s56"},"text":"section 56 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tII/s2004"},"text":"Pub. L. 100–647, title II, § 2004","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1)(B)(ii), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3608"},"text":"102 Stat. 3608","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/stat/102/3608"},"text":"“The amendment made by clause (i) [amending this section] shall apply to transactions occurring on or after ","children":[{"tag":"date","attrib":{"date":"1988-03-31"},"text":"March 31, 1988","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46543dad-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10228/d"},"text":"Pub. L. 100–203, title X, § 10228(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-418"},"text":"101 Stat. 1330–418","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/203/tX/s10228/d"},"text":"“The amendments made by this section [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s275"},"text":"section 275 of this title","children":[],"tail":"] shall apply to consideration received after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":"] in taxable years ending after such date; except that such amendments shall not apply in the case of any acquisition pursuant to a written binding contract in effect on "},{"tag":"date","attrib":{"date":"1987-12-15"},"text":"December 15, 1987","children":[],"tail":", and at all times thereafter before the acquisition.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
