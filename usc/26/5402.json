{"tag":"section","attrib":{"id":"id463c7029-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5402"},"text":null,"children":[{"tag":"num","attrib":{"value":"5402"},"text":"§ 5402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id463c702a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Brewery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The brewery shall consist of the land and buildings described in the brewer’s notice. The continuity of the brewery must be unbroken except where separated by public passageways, streets, highways, waterways, or carrier rights-of-way, or partitions; and if parts of the brewery are so separated they must abut on the dividing medium and be adjacent to each other. Notwithstanding the preceding sentence, facilities under the control of the brewer for case packing, loading, or storing which are located within reasonable proximity to the brewery packaging facilities may be approved by the Secretary as a part of the brewery if the revenue will not be jeopardized thereby.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id463c702b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Brewer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For definition of brewer, see section 5052(d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id463c702c-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href"