{"tag":"section","attrib":{"id":"id4742bd4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7205"},"text":null,"children":[{"tag":"num","attrib":{"value":"7205"},"text":"§ 7205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraudulent withholding exemption certificate or failure to supply information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4742bd4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding on wages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual required to supply information to his employer under section 3402 who willfully supplies false or fraudulent information, or who willfully fails to supply information thereunder which would require an increase in the tax to be withheld under section 3402, shall, in addition to any other penalty provided by law, upon conviction thereof, be fined not more than $1,000, or imprisoned not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4742bd50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Backup withholding on interest and dividends","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any individual willfully makes a false certification under paragraph (1) or (2)(C) of section 3406(d), then such individual shall, in addition to any other penalty provided by law, upon conviction thereof, be fined not more than $1,000, or imprisoned not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4742bd51-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/852"},"text":"68A Stat. 852","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/368/tI/s101/e/5"},"text":"Pub. L. 89–368, title I, § 101(e)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-15"},"text":"Mar. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/62"},"text":"80 Stat. 62","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tVII/s721/b"},"text":"Pub. L. 97–34, title VII, § 721(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/341"},"text":"95 Stat. 341","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII"},"text":"Pub. L. 97–248, title III","children":[],"tail":", §§ 306(b), 308(a), "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/588"},"text":"96 Stat. 588","children":[],"tail":", 591; "},{"tag":"ref","attrib":{"href":"/us/pl/98/67/tI"},"text":"Pub. L. 98–67, title I","children":[],"tail":", §§ 102(a), 107(b), "},{"tag":"date","attrib":{"date":"1983-08-05"},"text":"Aug. 5, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/369"},"text":"97 Stat. 369","children":[],"tail":", 382; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s159/a"},"text":"Pub. L. 98–369, div. A, title I, § 159(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/696"},"text":"98 Stat. 696","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7711/b/2"},"text":"Pub. L. 101–239, title VII, § 7711(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2393"},"text":"103 Stat. 2393","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4742bd52-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4742bd53-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4742bd54-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “If any individual willfully makes—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) any false certification or affirmation on any statement required by a payor in order to meet the due diligence requirements of section 6676(b), or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) a false certification under paragraph (1) or (2)(C) of section 3406(d),","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"then such individual shall, in addition to any other penalty provided by law, upon conviction thereof, be fined not more than $1,000, or imprisoned not more than 1 year, or both.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" in subsecs. (a) and (b) substituted “in addition to” for “in lieu of” and struck out reference to penalty under section 6682 after “penalty provided by law”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/67"},"text":"Pub. L. 98–67","children":[],"tail":" designated existing provisions as subsec. (a), added subsec. (b), and repealed amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":". See 1982 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" provided that, applicable to payments of interest, dividends, and patronage dividends paid or credited after "},{"tag":"date","attrib":{"date":"1983-06-30"},"text":"June 30, 1983","children":[],"tail":", this section is amended by designating the existing provisions as subsec. (a) with a heading of “Withholding on wages”, and by adding a new subsec. (b). Section 102(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/98/67/tI"},"text":"Pub. L. 98–67, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-05"},"text":"Aug. 5, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/369"},"text":"97 Stat. 369","children":[],"tail":", repealed subtitle A (§§ 301–308) of title III of "},{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" as of the close of "},{"tag":"date","attrib":{"date":"1983-06-30"},"text":"June 30, 1983","children":[],"tail":", and provided that the Internal Revenue Code of 1954 [now 1986] [this title] shall be applied and administered (subject to certain exceptions) as if such subtitle A (and the amendments made by such subtitle A) had not been enacted. Subsec. (b), referred to above, read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":" ","children":[{"tag":"b","attrib":{},"text":"“(b) Withholding of interest and dividends","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Any person who—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) willfully files an exemption certificate with any payor under section 3452(f)(1)(A), which is known by him to be fraudulent or to be false as to any material matter, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) is required to furnish notice under section 3452(f)(1)(B), and willfully fails to furnish such notice in the manner and at the time required pursuant to section 3452(f)(1)(B) or the regulations prescribed thereunder,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"shall, in lieu of any penalty otherwise provided, upon conviction thereof, be fined not more than $500, or imprisoned not more than 1 year, or both.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" substituted “$1,000” for “$500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/368"},"text":"Pub. L. 89–368","children":[],"tail":" substituted “section 3402” and “any other penalty provided by law (except the penalty provided by section 6682)” for “section 3402(f)” and “any penalty otherwise provided” respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4742bd55-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4742bd56-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" applicable to returns and statements the due date for which (determined without regard to extensions) is after "},{"tag":"date","attrib":{"date":"1989-12-31"},"text":"Dec. 31, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7711/c"},"text":"section 7711(c) of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6721"},"text":"section 6721 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4742bd57-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s159/b"},"text":"Pub. L. 98–369, div. A, title I, § 159(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/696"},"text":"98 Stat. 696","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tI/s159/b"},"text":"“The amendments made by this section [amending this section] shall apply to actions and failures to act occurring after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4742bd58-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/67/s107/b"},"text":"section 107(b) of Pub. L. 98–67","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1983-08-05"},"text":"Aug. 5, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/67/s110/c"},"text":"section 110(c) of Pub. L. 98–67","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s31"},"text":"section 31 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4742bd59-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" applicable to acts and failures to act after "},{"tag":"date","attrib":{"date":"1981-12-31"},"text":"Dec. 31, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/s721/d"},"text":"section 721(d) of Pub. L. 97–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6682"},"text":"section 6682 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
