{"tag":"section","attrib":{"id":"id45d5e63e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4424"},"text":null,"children":[{"tag":"num","attrib":{"value":"4424"},"text":"§ 4424.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of wagering tax information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45d5e63f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4424/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section, neither the Secretary nor any other officer or employee of the Treasury Department may divulge or make known in any manner whatever to any person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d5e640-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4424/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any original, copy, or abstract of any return, payment, or registration made pursuant to this chapter,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e641-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4424/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any record required for making any such return, payment, or registration, which the Secretary is permitted by the taxpayer to examine or which is produced pursuant to section 7602, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e642-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4424/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information come at by the exploitation of any such return, payment, registration, or record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d5e643-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4424/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible disclosure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A disclosure otherwise prohibited by subsection (a) may be made in connection with the administration or civil or criminal enforcement of any tax imposed by this title. However, any document or information so disclosed may not be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d5e644-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4424/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" divulged or made known in any manner whatever by any officer or employee of the United States to any person except in connection with the administration or civil or criminal enforcement of this title, nor","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e645-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4424/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used, directly or indirectly, in any criminal prosecution for any offense occurring before the date of enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d5e646-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4424/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of documents possessed by taxpayer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except in connection with the administration or civil or criminal enforcement of any tax imposed by this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d5e647-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4424/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any stamp denoting payment of the special tax under this chapter,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e648-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4424/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any original, copy, or abstract possessed by a taxpayer of any return, payment, or registration made by such taxpayer pursuant to this chapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e649-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4424/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information come at by the exploitation of any such document,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall not be used against such taxpayer in any criminal proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d5e64a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4424/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection by committees of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 6103(f) shall apply with respect to any return, payment, or registration made pursuant to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d5e64b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/499/s3/c/1"},"text":"Pub. L. 93–499, § 3(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-29"},"text":"Oct. 29, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1550"},"text":"88 Stat. 1550","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXII/s1202/h/6"},"text":"Pub. L. 94–455, title XII, § 1202(h)(6)","children":[],"tail":", title XIX, § 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1688"},"text":"90 Stat. 1688","children":[],"tail":", 1834.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45d5e64c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45d5e64d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45d5e64e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1202/h/6"},"text":"Pub. L. 94–455, § 1202(h)(6)","children":[],"tail":", substituted “6103(f)” for “6103(d)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45d5e64f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45d5e650-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1202/h/6"},"text":"section 1202(h)(6) of Pub. L. 94–455","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1977-01-01"},"text":"Jan. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1202/i"},"text":"section 1202(i) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6103"},"text":"section 6103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45d5e651-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1974-12-01"},"text":"Dec. 1, 1974","children":[],"tail":", and applicable only with respect to wagers placed on or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/93/499/s3/d/1"},"text":"section 3(d)(1) of Pub. L. 93–499","children":[],"tail":", set out as an Effective Date of 1974 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4401"},"text":"section 4401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
