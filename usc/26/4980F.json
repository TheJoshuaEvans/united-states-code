{"tag":"section","attrib":{"id":"id460f1eca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F"},"text":null,"children":[{"tag":"num","attrib":{"value":"4980F"},"text":"§ 4980F.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure of applicable plans reducing benefit accruals to satisfy notice requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id460f1ecb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed a tax on the failure of any applicable pension plan to meet the requirements of subsection (e) with respect to any applicable individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460f1ecc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460f1ecd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the tax imposed by subsection (a) on any failure with respect to any applicable individual shall be $100 for each day in the noncompliance period with respect to such failure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1ece-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “noncompliance period” means, with respect to any failure, the period beginning on the date the failure first occurs and ending on the date the notice to which the failure relates is provided or the failure is otherwise corrected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460f1ecf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on amount of tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460f1ed0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax not to apply where failure not discovered and reasonable diligence exercised","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No tax shall be imposed by subsection (a) on any failure during any period for which it is established to the satisfaction of the Secretary that any person subject to liability for the tax under subsection (d) did not know that the failure existed and exercised reasonable diligence to meet the requirements of subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1ed1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax not to apply to failures corrected within 30 days","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No tax shall be imposed by subsection (a) on any failure if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460f1ed2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person subject to liability for the tax under subsection (d) exercised reasonable diligence to meet the requirements of subsection (e), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1ed3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person provides the notice described in subsection (e) during the 30-day period beginning on the first date such person knew, or exercising reasonable diligence would have known, that such failure existed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1ed4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overall limitation for unintentional failures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460f1ed5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the person subject to liability for tax under subsection (d) exercised reasonable diligence to meet the requirements of subsection (e), the tax imposed by subsection (a) for failures during the taxable year of the employer (or, in the case of a multiemployer plan, the taxable year of the trust forming part of the plan) shall not exceed $500,000. For purposes of the preceding sentence, all multiemployer plans of which the same trust forms a part shall be treated as 1 plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1ed6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable years in the case of certain controlled groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, if all persons who are treated as a single employer for purposes of this section do not have the same taxable year, the taxable years taken into account shall be determined under principles similar to the principles of section 1561.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1ed7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a failure which is due to reasonable cause and not to willful neglect, the Secretary may waive part or all of the tax imposed by subsection (a) to the extent that the payment of such tax would be excessive or otherwise inequitable relative to the failure involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460f1ed8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following shall be liable for the tax imposed by subsection (a):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460f1ed9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a plan other than a multiemployer plan, the employer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1eda-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a multiemployer plan, the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460f1edb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice requirements for plans significantly reducing benefit accruals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460f1edc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an applicable pension plan is amended to provide for a significant reduction in the rate of future benefit accrual, the plan administrator shall provide the notice described in paragraph (2) to each applicable individual (and to each employee organization representing applicable individuals) and to each employer who has an obligation to contribute to the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1edd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notice required by paragraph (1) shall be written in a manner calculated to be understood by the average plan participant and shall provide sufficient information (as determined in accordance with regulations prescribed by the Secretary) to allow applicable individuals to understand the effect of the plan amendment. The Secretary may provide a simplified form of notice for, or exempt from any notice requirement, a plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460f1ede-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has fewer than 100 participants who have accrued a benefit under the plan, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1edf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which offers participants the option to choose between the new benefit formula and the old benefit formula.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1ee0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in regulations, the notice required by paragraph (1) shall be provided within a reasonable time before the effective date of the plan amendment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1ee1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any notice under paragraph (1) may be provided to a person designated, in writing, by the person to which it would otherwise be provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1ee2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice before adoption of amendment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A plan shall not be treated as failing to meet the requirements of paragraph (1) merely because notice is provided before the adoption of the plan amendment if no material modification of the amendment occurs before the amendment is adopted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460f1ee3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460f1ee4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable individual” means, with respect to any plan amendment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460f1ee5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each participant in the plan, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1ee6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any beneficiary who is an alternate payee (within the meaning of section 414(p)(8)) under an applicable qualified domestic relations order (within the meaning of section 414(p)(1)(A)),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"whose rate of future benefit accrual under the plan may reasonably be expected to be significantly reduced by such plan amendment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1ee7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable pension plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable pension plan” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460f1ee8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any defined benefit plan described in section 401(a) which includes a trust exempt from tax under section 501(a), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1ee9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual account plan which is subject to the funding standards of section 412.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term shall not include a governmental plan (within the meaning of section 414(d)) or a church plan (within the meaning of section 414(e)) with respect to which the election provided by section 410(d) has not been made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1eea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early retirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A plan amendment which eliminates or reduces any early retirement benefit or retirement-type subsidy (within the meaning of section 411(d)(6)(B)(i)) shall be treated as having the effect of reducing the rate of future benefit accrual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460f1eeb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980F/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New technologies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may by regulations allow any notice under subsection (e) to be provided by using new technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id460f1eec-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/tVI/s659/a/1"},"text":"Pub. L. 107–16, title VI, § 659(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/137"},"text":"115 Stat. 137","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/147/tIV/s411/u/1"},"text":"Pub. L. 107–147, title IV, § 411(u)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-09"},"text":"Mar. 9, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/51"},"text":"116 Stat. 51","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tV/s502/c/2"},"text":"Pub. L. 109–280, title V, § 502(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/941"},"text":"120 Stat. 941","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id460f1eed-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id460f1eee-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id460f1eef-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" inserted “and to each employer who has an obligation to contribute to the plan” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147/s411/u/1/A"},"text":"Pub. L. 107–147, § 411(u)(1)(A)","children":[],"tail":", substituted “the notice described in paragraph (2)” for “written notice”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147/s411/u/1/B"},"text":"Pub. L. 107–147, § 411(u)(1)(B)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “any defined benefit plan, or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147/s411/u/1/C"},"text":"Pub. L. 107–147, § 411(u)(1)(C)","children":[],"tail":", struck out “significantly” before “reduces” and before “reducing”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id460f1ef0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id460f1ef1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tV/s502/d"},"text":"Pub. L. 109–280, title V, § 502(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/941"},"text":"120 Stat. 941","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/280/tV/s502/d"},"text":"“The amendments made by this section [amending this section and sections 1021, 1054, and 1132 of Title 29, Labor] shall apply to plan years beginning after ","children":[{"tag":"date","attrib":{"date":"2007-12-31"},"text":"December 31, 2007","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id460f1ef2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147"},"text":"Pub. L. 107–147","children":[],"tail":" effective as if included in the provisions of the Economic Growth and Tax Relief Reconciliation Act of 2001, "},{"tag":"ref","attrib":{"href":"/us/pl/107/16"},"text":"Pub. L. 107–16","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/147/s411/x"},"text":"section 411(x) of Pub. L. 107–147","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s25B"},"text":"section 25B of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id460f1ef3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/tVI/s659/c"},"text":"Pub. L. 107–16, title VI, § 659(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/141"},"text":"115 Stat. 141","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/147/tIV/s411/u/3"},"text":"Pub. L. 107–147, title IV, § 411(u)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-09"},"text":"Mar. 9, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/52"},"text":"116 Stat. 52","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/147/tIV/s411/u/3"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1054"},"text":"section 1054 of Title 29","children":[],"tail":", Labor] shall apply to plan amendments taking effect on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Until such time as the Secretary of the Treasury issues regulations under sections 4980F(e)(2) and (3) of the Internal Revenue Code of 1986, and section 204(h) of the Employee Retirement Income Security Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1054/h"},"text":"29 U.S.C. 1054(h)","children":[],"tail":"], as added by the amendments made by this section, a plan shall be treated as meeting the requirements of such sections if it makes a good faith effort to comply with such requirements."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special notice rule.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The period for providing any notice required by the amendments made by this section shall not end before the date which is 3 months after the date of the enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reasonable notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section shall not apply to any plan amendment taking effect on or after the date of the enactment of this Act if, before ","children":[{"tag":"date","attrib":{"date":"2001-04-25"},"text":"April 25, 2001","children":[],"tail":", notice was provided to participants and beneficiaries adversely affected by the plan amendment (and their representatives) which was reasonably expected to notify them of the nature and effective date of the plan amendment.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
