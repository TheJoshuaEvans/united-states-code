{"tag":"section","attrib":{"id":"id41810ad2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139G"},"text":null,"children":[{"tag":"num","attrib":{"value":"139G"},"text":"§ 139G.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignments to Alaska Native Settlement Trusts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id41810ad3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139G/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a Native Corporation, gross income shall not include the value of any payments that would otherwise be made, or treated as being made, to such Native Corporation pursuant to, or as required by, any provision of the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.), including any payment that would otherwise be made to a Village Corporation pursuant to section 7(j) of the Alaska Native Claims Settlement Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1606/j"},"text":"43 U.S.C. 1606(j)","children":[],"tail":"), provided that any such payments—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id41810ad4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139G/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are assigned in writing to a Settlement Trust, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810ad5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139G/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were not received by such Native Corporation prior to the assignment described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41810ad6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139G/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion in gross income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a Settlement Trust which has been assigned payments described in subsection (a), gross income shall include such payments when received by such Settlement Trust pursuant to the assignment and shall have the same character as if such payments were received by the Native Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41810ad7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139G/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount and scope of assignment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount and scope of any assignment under subsection (a) shall be described with reasonable particularity and may either be in a percentage of one or more such payments or in a fixed dollar amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41810ad8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139G/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of assignment; revocability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any assignment under subsection (a) shall specify—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41810ad9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139G/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a duration either in perpetuity or for a period of time, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810ada-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139G/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether such assignment is revocable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41810adb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139G/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on deduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 247, no deduction shall be allowed to a Native Corporation for purposes of any amounts described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41810adc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139G/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the terms “Native Corporation” and “Settlement Trust” have the same meaning given such terms under section 646(h).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id41810add-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13821/a/1"},"text":"Pub. L. 115–97, title I, § 13821(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2178"},"text":"131 Stat. 2178","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id41810ade-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id41810adf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id41810ae0-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Alaska Native Claims Settlement Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203"},"text":"Pub. L. 92–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":", which is classified generally to chapter 33 (§ 1601 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id41810ae1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id41810ae2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13821/a/3"},"text":"Pub. L. 115–97, title I, § 13821(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2178"},"text":"131 Stat. 2178","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/97/tI/s13821/a/3"},"text":"“The amendments made by this subsection [enacting this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2016-12-31"},"text":"December 31, 2016","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
