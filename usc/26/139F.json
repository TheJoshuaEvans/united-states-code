{"tag":"section","attrib":{"id":"id41810ac2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139F"},"text":null,"children":[{"tag":"num","attrib":{"value":"139F"},"text":"§ 139F.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain amounts received by wrongfully incarcerated individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id41810ac3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139F/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion from gross income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any wrongfully incarcerated individual, gross income shall not include any civil damages, restitution, or other monetary award (including compensatory or statutory damages and restitution imposed in a criminal matter) relating to the incarceration of such individual for the covered offense for which such individual was convicted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41810ac4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139F/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wrongfully incarcerated individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “wrongfully incarcerated individual” means an individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41810ac5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139F/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who was convicted of a covered offense,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810ac6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139F/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who served all or part of a sentence of imprisonment relating to that covered offense, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810ac7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139F/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41810ac8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139F/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who was pardoned, granted clemency, or granted amnesty for that covered offense because that individual was innocent of that covered offense, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41810ac9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139F/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id41810aca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139F/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for whom the judgment of conviction for that covered offense was reversed or vacated, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id41810acb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139F/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for whom the indictment, information, or other accusatory instrument for that covered offense was dismissed or who was found not guilty at a new trial after the judgment of conviction for that covered offense was reversed or vacated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41810acc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139F/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered offense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “covered offense” means any criminal offense under Federal or State law, and includes any criminal offense arising from the same course of conduct as that criminal offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id41810acd-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tIII/s304/a"},"text":"Pub. L. 114–113, div. Q, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3087"},"text":"129 Stat. 3087","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id41810ace-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id41810acf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id41810ad0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tIII/s304/c"},"text":"Pub. L. 114–113, div. Q, title III, § 304(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3088"},"text":"129 Stat. 3088","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/113/dQ/tIII/s304/c"},"text":"“The amendments made by this section [enacting this section] shall apply to taxable years beginning before, on, or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id41810ad1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Waiver of Limitations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tIII/s304/d"},"text":"Pub. L. 114–113, div. Q, title III, § 304(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3088"},"text":"129 Stat. 3088","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dD/tII/s41103/a"},"text":"Pub. L. 115–123, div. D, title II, § 41103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/155"},"text":"132 Stat. 155","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/123/dD/tII/s41103/a"},"text":"“If the credit or refund of any overpayment of tax resulting from the application of this Act [probably means this section, enacting this section and provisions set out as a note above] to a period before the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":"] is prevented as of such date by the operation of any law or rule of law (including res judicata), such credit or refund may nevertheless be allowed or made if the claim therefor is filed before the close of the 3-year period beginning on the date of the enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/dD/tII/s41103/b"},"text":"Pub. L. 115–123, div. D, title II, § 41103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/155"},"text":"132 Stat. 155","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/123/dD/tII/s41103/b"},"text":"“The amendment made by this section [amending ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s304/d"},"text":"section 304(d) of Pub. L. 114–113","children":[],"tail":", set out above] shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":"].”"}],"tail":"\n]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
