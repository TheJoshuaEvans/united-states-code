{"tag":"section","attrib":{"id":"id4461e3be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898"},"text":null,"children":[{"tag":"num","attrib":{"value":"898"},"text":"§ 898.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable year of certain foreign corporations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4461e3bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this title, the taxable year of any specified foreign corporation shall be the required year determined under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4461e3c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified foreign corporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4461e3c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “specified foreign corporation” means any foreign corporation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4461e3c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is treated as a controlled foreign corporation for any purpose under subpart F of part III of this subchapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4461e3c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which the ownership requirements of paragraph (2) are met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4461e3c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4461e3c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The ownership requirements of this paragraph are met with respect to any foreign corporation if a United States shareholder owns, on each testing day, more than 50 percent of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4461e3c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total voting power of all classes of stock of such corporation entitled to vote, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4461e3c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total value of all classes of stock of such corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4461e3c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the rules of subsections (a) and (b) of section 958 shall apply in determining ownership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4461e3c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States shareholder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States shareholder” has the meaning given to such term by section 951(b), except that, in the case of a foreign corporation having related person insurance income (as defined in section 953(c)(2)), the Secretary may treat any person as a United States shareholder for purposes of this section if such person is treated as a United States shareholder under section 953(c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4461e3ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of required year","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4461e3cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The required year is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4461e3cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the majority U.S. shareholder year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4461e3cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there is no majority U.S. shareholder year, the taxable year prescribed under regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4461e3ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Majority U.S. shareholder year","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4461e3cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “majority U.S. shareholder year” means the taxable year (if any) which, on each testing day, constituted the taxable year of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4461e3d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each United States shareholder described in subsection (b)(2)(A), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4461e3d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each United States shareholder not described in clause (i) whose stock was treated as owned under subsection (b)(2)(B) by any shareholder described in such clause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4461e3d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testing day","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The testing days shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4461e3d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first day of the corporation’s taxable year (determined without regard to this section), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4461e3d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s898/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the days during such representative period as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4461e3d5-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7401/a"},"text":"Pub. L. 101–239, title VII, § 7401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2355"},"text":"103 Stat. 2355","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIV/s413/c/13"},"text":"Pub. L. 108–357, title IV, § 413(c)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1507"},"text":"118 Stat. 1507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70352/a"},"text":"Pub. L. 119–21, title VII, § 70352(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/208"},"text":"139 Stat. 208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4461e3d6-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4461e3d7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4461e3d8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" redesignated par. (3) as (2) and struck out former par. (2). Prior to amendment, text of par. (2) read as follows: “A specified foreign corporation may elect, in lieu of the taxable year under paragraph (1)(A), a taxable year beginning 1 month earlier than the majority U.S. shareholder year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s413/c/13/A"},"text":"Pub. L. 108–357, § 413(c)(13)(A)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar (A) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) which is—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) treated as a controlled foreign corporation for any purpose under subpart F of part III of this subchapter, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) a foreign personal holding company (as defined in section 552), and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s413/c/13/B"},"text":"Pub. L. 108–357, § 413(c)(13)(B)","children":[],"tail":", struck out “and sections 551(f) and 554, whichever are applicable,” after “section 958”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s413/c/13/C"},"text":"Pub. L. 108–357, § 413(c)(13)(C)","children":[],"tail":", reenacted heading without change, struck out “(A) In general” before “The term”, and struck out heading and text of subpar. (B). Text read as follows: “In the case of any foreign personal holding company (as defined in section 552) which is not a specified foreign corporation by reason of paragraph (1)(A)(i), the term ‘United States shareholder’ means any person who is treated as a United States shareholder under section 551.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s413/c/13/D"},"text":"Pub. L. 108–357, § 413(c)(13)(D)","children":[],"tail":", reenacted heading without change and amended text of subsec. (c) generally, substituting provisions stating general rule and relating to 1-month deferral and majority U.S. shareholder year, consisting of pars. (1) to (3), for provisions stating general rule and relating to 1-month deferral and majority U.S. shareholder year, consisting of par. (1), and provisions relating to required year in the case of a foreign personal holding company, consisting of par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4461e3d9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4461e3da-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70352/b"},"text":"Pub. L. 119–21, title VII, § 70352(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/208"},"text":"139 Stat. 208","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70352/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section] shall apply to taxable years of specified foreign corporations beginning after ","children":[{"tag":"date","attrib":{"date":"2025-11-30"},"text":"November 30, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transition Rule.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a corporation that is a specified foreign corporation as of ","children":[{"tag":"date","attrib":{"date":"2025-11-30"},"text":"November 30, 2025","children":[],"tail":", such corporation’s first taxable year beginning after such date shall end at the same time as the first required year (within the meaning of section 898(c)(1) of the Internal Revenue Code of 1986) ending after such date. If any specified foreign corporation is required by the amendments made by this section to change its taxable year for its first taxable year beginning after "},{"tag":"date","attrib":{"date":"2025-11-30"},"text":"November 30, 2025","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such change shall be treated as initiated by such corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such change shall be treated as having been made with the consent of the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall issue regulations or other guidance for allocating foreign taxes that are paid or accrued in such first taxable year and the succeeding taxable year among such taxable years in the manner the Secretary determines appropriate to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this subsection, the term ‘Secretary’ means the Secretary of the Treasury or the Secretary’s delegate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4461e3db-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" applicable to taxable years of foreign corporations beginning after "},{"tag":"date","attrib":{"date":"2004-12-31"},"text":"Dec. 31, 2004","children":[],"tail":", and to taxable years of United States shareholders with or within which such taxable years of foreign corporations end, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s413/d/1"},"text":"section 413(d)(1) of Pub. L. 108–357","children":[],"tail":", set out as an Effective and Termination Dates of 2004 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4461e3dc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7401/d"},"text":"Pub. L. 101–239, title VII, § 7401(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2357"},"text":"103 Stat. 2357","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tVII/s7401/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s563"},"text":"section 563 of this title","children":[],"tail":"] shall apply to taxable years of foreign corporations beginning after "},{"tag":"date","attrib":{"date":"1989-07-10"},"text":"July 10, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rules","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any foreign corporation is required by the amendments made by this section to change its taxable year for its first taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"1989-07-10"},"text":"July 10, 1989","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such change shall be treated as initiated by the taxpayer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such change shall be treated as having been made with the consent of the Secretary of the Treasury or his delegate, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if, by reason of such change, any United States person is required to include in gross income for 1 taxable year amounts attributable to 2 taxable years of such foreign corporation, the amount which would otherwise be required to be included in gross income for such 1 taxable year by reason of the short taxable year of the foreign corporation resulting from such change shall be included in gross income ratably over the 4-taxable-year period beginning with such 1 taxable year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
