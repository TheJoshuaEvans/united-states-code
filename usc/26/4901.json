{"tag":"section","attrib":{"id":"id45e1cd64-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4901"},"text":null,"children":[{"tag":"num","attrib":{"value":"4901"},"text":"§ 4901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45e1cd65-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition precedent to carrying on certain business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall be engaged in or carry on any trade or business subject to the tax imposed by section 4411 (wagering) until he has paid the special tax therefor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45e1cd66-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All special taxes shall be imposed as of on the first day of July in each year, or on commencing any trade or business on which such tax is imposed. In the former case the tax shall be reckoned for 1 year, and in the latter case it shall be reckoned proportionately, from the first day of the month in which the liability to a special tax commenced, to and including the 30th day of June following.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45e1cd67-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/593"},"text":"68A Stat. 593","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tIV/s405/b"},"text":"Pub. L. 89–44, title IV, § 405(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/149"},"text":"79 Stat. 149","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/513/tIII/s1102/a"},"text":"Pub. L. 91–513, title III, § 1102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1292"},"text":"84 Stat. 1292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1904/a/19"},"text":"Pub. L. 94–455, title XIX, § 1904(a)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1814"},"text":"90 Stat. 1814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tV/s521/c/2"},"text":"Pub. L. 95–600, title V, § 521(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2884"},"text":"92 Stat. 2884","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45e1cd68-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45e1cd69-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45e1cd6a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},