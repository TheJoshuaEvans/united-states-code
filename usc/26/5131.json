{"tag":"section","attrib":{"id":"id46295d7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5131"},"text":null,"children":[{"tag":"num","attrib":{"value":"5131"},"text":"§ 5131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Packaging distilled spirits for industrial uses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46295d7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, at his discretion and under such regulations as he may prescribe, authorize a dealer (as defined in section 5121(c)) engaging in the business of supplying distilled spirits for industrial uses to package distilled spirits, on which the tax has been paid or determined, for such uses in containers of a capacity in excess of 1 wine gallon and not more than 5 wine gallons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46295d7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions relating to containers of distilled spirits, see section 5206.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46295d7d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","at