{"tag":"section","attrib":{"id":"id45d5e601-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4404"},"text":null,"children":[{"tag":"num","attrib":{"value":"4404"},"text":"§ 4404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territorial extent","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The tax imposed by this subchapter shall apply only to wagers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d5e602-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4404/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accepted in the United States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e603-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4404/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" placed by a person who is in the United States","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45d5e604-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4404/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with a person who is a citizen or resident of the United States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d5e605-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4404/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a wagering pool or lottery conducted by a person who is a citizen or resident of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d5e606-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08