{"tag":"section","attrib":{"id":"id45d5e65c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4461"},"text":null,"children":[{"tag":"num","attrib":{"value":"4461"},"text":"§ 4461.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45d5e65d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4461/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed a tax on any port use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d5e65e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4461/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the tax imposed by subsection (a) on any port use shall be an amount equal to 0.125 percent of the value of the commercial cargo involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d5e65f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4461/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability and time of imposition of tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d5e660-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4461/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The tax imposed by subsection (a) shall be paid by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45d5e661-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4461/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of cargo entering the United States, the importer, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45d5e662-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4461/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any other case, the shipper.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e663-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4461/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time of imposition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided by regulations, the tax imposed by subsection (a) shall be imposed at the time of unloading.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d5e664-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXIV/s1402/a"},"text":"Pub. L. 99–662, title XIV, § 1402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4266"},"text":"100 Stat. 4266","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11214/a"},"text":"Pub. L. 101–508, title XI, § 11214(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-436"},"text":"104 Stat. 1388–436","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11116/b"},"text":"Pub. L. 109–59, title XI, § 11116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1951"},"text":"119 Stat. 1951","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45d5e665-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45d5e666-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id45d5e667-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For prior section 4461, see Prior Provisions note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4471"},"text":"section 4471 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45d5e668-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11116/b/1"},"text":"Pub. L. 109–59, § 11116(b)(1)","children":[],"tail":", inserted “or” at end of subpar. (A), redesignated subpar. (C) as (B), and struck out former subpar. (B) which read as follows: “in the case of cargo to be exported from the United States, the exporter, or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11116/b/2"},"text":"Pub. L. 109–59, § 11116(b)(2)","children":[],"tail":", substituted “imposed” for “imposed—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) in the case of cargo to be exported from the United States, at the time of loading, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) in any other case,”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted “0.125 percent” for “0.04 percent”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45d5e669-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45d5e66a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11116/c"},"text":"Pub. L. 109–59, title XI, § 11116(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1951"},"text":"119 Stat. 1951","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/59/tXI/s11116/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4462"},"text":"section 4462 of this title","children":[],"tail":"] shall take effect before, on, and after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2005-08-10