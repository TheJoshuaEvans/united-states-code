ren":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id45d5e66d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXIV/s1403/b"},"text":"Pub. L. 99–662, title XIV, § 1403(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4270"},"text":"100 Stat. 4270","children":[],"tail":", authorized to be appropriated to Department of the Treasury (from fees collected under section 58c(9), (10) of Title 19, Customs Duties) such sums as necessary to pay all expenses of administration incurred by such Department in administering this subchapter for periods to which such fees apply, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s690/c/8"},"text":"Pub. L. 103–182, title VI, § 690(c)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2223"},"text":"107 Stat. 2223","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id45d5e66e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Cargo Diversion","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXIV/s1407"},"text":"Pub. L. 99–662, title XIV, § 1407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4272"},"text":"100 Stat. 4272","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tII/s2002/c"},"text":"Pub. L. 100–647, title II, § 2002(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3597"},"text":"102 Stat. 3597","children":[],"tail":", provided that the Secretary of the Treasury would conduct a study to determine the impact of the port use tax imposed under this section on potential diversions of cargo from particular United States ports to any port in a country contiguous to the United States, and submit the report of the study to Congress not later than "},{"tag":"date","attrib":{"date":"1988-12-01"},"text":"Dec. 1, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
