{"tag":"section","attrib":{"id":"id4736d620-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6720C"},"text":null,"children":[{"tag":"num","attrib":{"value":"6720C"},"text":"§ 6720C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for failure to notify health plan of cessation of eligibility for continuation coverage premium assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4736d621-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6720C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except in the case of a failure described in subsection (b) or (c), any person required to notify a group health plan under section 9501(a)(2)(B) of the American Rescue Plan Act of 2021 who fails to make such a notification at such time and in such manner as the Secretary of Labor may require shall pay a penalty of $250 for each such failure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d622-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6720C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intentional failure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any such failure that is fraudulent, such person shall pay a penalty equal to the greater of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4736d623-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6720C/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d624-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6720C/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 110 percent of the premium assistance provided under section 9501(a)(1)(A) of the American Rescue Plan Act of 2021 after termination of eligibility under such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d625-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6720C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable cause exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed under this section with respect to any failure if it is shown that such failure is due to reasonable cause and not to willful neglect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4736d626-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIX/s9501/b/2/A"},"text":"Pub. L. 117–2, title IX, § 9501(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/137"},"text":"135 Stat. 137","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4736d627-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4736d628-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4736d629-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 9501(a) of the American Rescue Plan Act of 2021, referred to in subsecs. (a) and (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIX/s9501/a"},"text":"section 9501(a) of title IX of Pub. L. 117–2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/127"},"text":"135 Stat. 127","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4980B"},"text":"section 4980B of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4736d62a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6720C, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tIII/s3001/a/13/A"},"text":"Pub. L. 111–5, div. B, title III, § 3001(a)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/464"},"text":"123 Stat. 464","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/144/s3/b/5/D"},"text":"Pub. L. 111–144, § 3(b)(5)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-02"},"text":"Mar. 2, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/45"},"text":"124 Stat. 45","children":[],"tail":", related to penalty for failure to notify health plan of cessation of eligibility for COBRA premium assistance, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/d/7/B"},"text":"Pub. L. 115–141, div. U, title IV, § 401(d)(7)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1212"},"text":"132 Stat. 1212","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
