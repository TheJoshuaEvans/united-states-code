n":[],"tail":", 4053.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4669c1cb-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4669c1cc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4669c1cd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 6039D, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/612/s1/b/1"},"text":"Pub. L. 98–612, § 1(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-31"},"text":"Oct. 31, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3180"},"text":"98 Stat. 3180","children":[],"tail":", also related to returns and records with respect to certain fringe benefits, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1879/d/2"},"text":"Pub. L. 99–514, title XVIII, § 1879(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2906"},"text":"100 Stat. 2906","children":[],"tail":", effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such repeal relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4669c1ce-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/a/108"},"text":"Pub. L. 113–295, § 221(a)(108)","children":[],"tail":", struck out “beginning after "},{"tag":"date","attrib":{"date":"1984-12-31"},"text":"December 31, 1984","children":[],"tail":",” after “during any year” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/a/19/B/vii"},"text":"Pub. L. 113–295, § 221(a)(19)(B)(vii)","children":[],"tail":", struck out “120,” after “106,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" substituted “129, or 137” for “or 129”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted “the employer).” for “the employer)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1011B/a/24"},"text":"Pub. L. 100–647, § 1011B(a)(24)","children":[],"tail":", amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1151/h/3"},"text":"Pub. L. 99–514, § 1151(h)(3)","children":[],"tail":", see 1986 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s3021/a/15/A/ii"},"text":"Pub. L. 100–647, § 3021(a)(15)(A)(ii)","children":[],"tail":", inserted “and special rules” after “Definitions” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s3021/a/15/A/i"},"text":"Pub. L. 100–647, § 3021(a)(15)(A)(i)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1151/h/2"},"text":"Pub. L. 99–514, § 1151(h)(2)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1151/h/3"},"text":"Pub. L. 99–514, § 1151(h)(3)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1011B/a/24"},"text":"Pub. L. 100–647, § 1011B(a)(24)","children":[],"tail":", inserted at end “The Secretary may require returns under this subsection only from a representative group of employers.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1151/h/1"},"text":"Pub. L. 99–514, § 1151(h)(1)","children":[],"tail":", amended subsec. (d) generally. Prior to amendment, par. (1) defined a specified fringe benefit plan as (A) any qualified group legal services plan (as defined in section 120), (B) any cafeteria plan (as defined in section 125), and (C) any educational assistance plan (as defined in section 127), and par. (2) defined “applicable exclusion” as meaning (A) section 120 in the case of a qualified legal group services plan, (B) section 125 in the case of a cafeteria plan, and (C) section 127 in the case of an educational assistance plan."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1879/d/1"},"text":"Pub. L. 99–514, § 1879(d)(1)","children":[],"tail":", in amending subsec. (d) generally, added subpars. (1)(A) and (2)(A). Former subpars. (1)(A) and (B) and (2)(A) and (B) were redesignated as subpars. (1)(B) and (C) and (2)(B) and (C), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statuto