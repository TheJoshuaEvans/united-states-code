{"tag":"section","attrib":{"id":"id4669c1ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039D"},"text":null,"children":[{"tag":"num","attrib":{"value":"6039D"},"text":"§ 6039D.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns and records with respect to certain fringe benefit plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4669c1bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039D/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every employer maintaining a specified fringe benefit plan during any year for any portion of which the applicable exclusion applies, shall file a return (at such time and in such manner as the Secretary shall by regulations prescribe) with respect to such plan showing for such year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4669c1bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039D/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of employees of the employer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c1bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039D/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of employees of the employer eligible to participate under the plan,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c1be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039D/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of employees participating under the plan,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c1bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039D/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total cost of the plan during the year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c1c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039D/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and taxpayer identification number of the employer and the type of business in which the employer is engaged, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c1c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039D/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of highly compensated employees among the employees described in paragraphs (1), (2), and (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4669c1c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039D/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each employer maintaining a specified fringe benefit plan during any year shall keep such records as may be necessary for purposes of determining whether the requirements of the applicable exclusion are met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4669c1c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039D/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional information when required by the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any employer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4669c1c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039D/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who maintains a specified fringe benefit plan during any year for which a return is required under subsection (a), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c1c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039D/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is required by the Secretary to file an additional return for such year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall file such additional return. Such additional return shall be filed at such time and in such manner as the Secretary shall prescribe and shall contain such information as the Secretary shall prescribe. The Secretary may require returns under this subsection only from a representative group of employers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4669c1c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039D/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4669c1c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039D/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified fringe benefit plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “specified fringe benefit plan” means any plan under section 79, 105, 106, 125, 127, 129, or 137.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c1c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039D/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “applicable exclusion” means, with respect to any specified fringe benefit plan, the section specified under paragraph (1) under which benefits under such plan are excludable from gross income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4669c1c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039D/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for multiemployer plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a multiemployer plan, the plan shall be required to provide any information required by this section which the Secretary determines, on the basis of the agreement between the plan and employer, is held by the plan (and not the employer).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4669c1ca-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/611/s1/d/1"},"text":"Pub. L. 98–611, § 1(d)(1)","chil