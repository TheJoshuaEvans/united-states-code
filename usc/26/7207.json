{"tag":"section","attrib":{"id":"id47452d68-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7207"},"text":null,"children":[{"tag":"num","attrib":{"value":"7207"},"text":"§ 7207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraudulent returns, statements, or other documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person who willfully delivers or discloses to the Secretary any list, return, account, statement, or other document, known by him to be fraudulent or to be false as to any material matter, shall be fined not more than $10,000 ($50,000 in the case of a corporation), or imprisoned not more than 1 year, or both. Any person required pursuant to section 6047(b), section 6104(d), or subsection (i) or (j) of section 527 to furnish any information to the Secretary or any other person who willfully furnishes to the Secretary or such other person any information known by him to be fraudulent or to be false as to any material matter shall be fined not more than $10,000 ($50,000 in the case of a corporation), or imprisoned not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id47452d69-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/853"},"text":"68A Stat. 853","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/792/s7/m/3"},"text":"Pub. L. 87–792, § 7(m)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-10"},"text":"Oct. 10, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/831"},"text":"76 Stat. 831","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tI/s101/e/5"},"text":"Pub. L. 91–172, title I, § 101(e)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"da