{"tag":"section","attrib":{"id":"id40da1ccc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R"},"text":null,"children":[{"tag":"num","attrib":{"value":"45R"},"text":"§ 45R.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee health insurance expenses of small employers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40da1ccd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 38, in the case of an eligible small employer, the small employer health insurance credit determined under this section for any taxable year in the credit period is the amount determined under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40da1cce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health insurance credit amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (c), the amount determined under this subsection with respect to any eligible small employer is equal to 50 percent (35 percent in the case of a tax-exempt eligible small employer) of the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40da1ccf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of nonelective contributions the employer made on behalf of its employees during the taxable year under the arrangement described in subsection (d)(4) for premiums for qualified health plans offered by the employer to its employees through an Exchange, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40da1cd0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of nonelective contributions which the employer would have made during the taxable year under the arrangement if each employee taken into account under paragraph (1) had enrolled in a qualified health plan which had a premium equal to the average premium (as determined by the Secretary of Health and Human Services) for the small group market in the rating area in which the employee enrolls for coverage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40da1cd1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Phaseout of credit amount based on number of employees and average wages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the credit determined under subsection (b) without regard to this subsection shall be reduced (but not below zero) by the sum of the following amounts:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40da1cd2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such amount multiplied by a fraction the numerator of which is the total number of full-time equivalent employees of the employer in excess of 10 and the denominator of which is 15.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40da1cd3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such amount multiplied by a fraction the numerator of which is the average annual wages of the employer in excess of the dollar amount in effect under subsection (d)(3)(B) and the denominator of which is such dollar amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40da1cd4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible small employer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40da1cd5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible small employer” means, with respect to any taxable year, an employer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40da1cd6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has no more than 25 full-time equivalent employees for the taxable year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40da1cd7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average annual wages of which do not exceed an amount equal to twice the dollar amount in effect under paragraph (3)(B) for the taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40da1cd8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has in effect an arrangement described in paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40da1cd9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full-time equivalent employees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40da1cda-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “full-time equivalent employees” means a number of employees equal to the number determined by dividing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40da1cdb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of hours of service for which wages were paid by the employer to employees during the taxable year, by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40da1cdc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2,080.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such number shall be rounded to the next lowest whole number if not otherwise a whole number.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40da1cdd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess hours not counted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an employee works in excess of 2,080 hours of service during any taxable year, such excess shall not be taken into account under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40da1cde-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hours of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Labor, shall prescribe such regulations, rules, and guidance as may be necessary to determine the hours of service of an employee, including rules for the application of this paragraph to employees who are not compensated on an hourly basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40da1cdf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Average annual wages","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40da1ce0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The average annual wages of an eligible small employer for any taxable year is the amount determined by dividing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40da1ce1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of wages which were paid by the employer to employees during the taxable year, by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40da1ce2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of full-time equivalent employees of the employee determined under paragraph (2) for the taxable year.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such amount shall be rounded to the next lowest multiple of $1,000 if not otherwise such a multiple.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40da1ce3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dollar amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)(B) and subsection (c)(2)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40da1ce4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2010, 2011, 2012, and 2013","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The dollar amount in effect under this paragraph for taxable years beginning in 2010, 2011, 2012, or 2013 is $25,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40da1ce5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a taxable year beginning in a calendar year after 2013, the dollar amount in effect under this paragraph shall be equal to $25,000, multiplied by the cost-of-living adjustment under section 1(f)(3) for the calendar year, determined by substituting “calendar year 2012” for “calendar year 2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40da1ce6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contribution arrangement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An arrangement is described in this paragraph if it requires an eligible small employer to make a nonelective contribution on behalf of each employee who enrolls in a qualified health plan offered to employees by the employer through an exchange in an amount equal to a uniform percentage (not less than 50 percent) of the premium cost of the qualified health plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8ce7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seasonal worker hours and wages not counted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40dc8ce8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The number of hours of service worked by, and wages paid to, a seasonal worker of an employer shall not be taken into account in determining the full-time equivalent employees and average annual wages of the employer unless the worker works for the employer on more than 120 days during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40dc8ce9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of seasonal worker","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “seasonal worker” means a worker who performs labor or services on a seasonal basis as defined by the Secretary of Labor, including workers covered by section 500.20(s)(1) of title 29, Code of Federal Regulations and retail workers employed exclusively during holiday seasons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40dc8cea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other rules and definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40dc8ceb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40dc8cec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain employees excluded","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “employee” shall not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40dc8ced-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee within the meaning of section 401(c)(1),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40dc8cee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any 2-percent shareholder (as defined in section 1372(b)) of an eligible small business which is an S corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40dc8cef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any 5-percent owner (as defined in section 416(i)(1)(B)(i)) of an eligible small business, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40dc8cf0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/e/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual who bears any of the relationships described in subparagraphs (A) through (G) of section 152(d)(2) to, or is a dependent described in section 152(d)(2)(H) of, an individual described in clause (i), (ii), or (iii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40dc8cf1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leased employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “employee” shall include a leased employee within the meaning of section 414(n).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8cf2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “credit period” means, with respect to any eligible small employer, the 2-consecutive-taxable year period beginning with the 1st taxable year in which the employer (or any predecessor) offers 1 or more qualified health plans to its employees through an Exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8cf3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonelective contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nonelective contribution” means an employer contribution other than an employer contribution pursuant to a salary reduction arrangement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8cf4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wages” has the meaning given such term by section 3121(a) (determined without regard to any dollar limitation contained in such section).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8cf5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregation and other rules made applicable","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40dc8cf6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregation rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All employers treated as a single employer under subsection (b), (c), (m), or (","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of section 414 shall be treated as a single employer for purposes of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40dc8cf7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of subsections (c), (d), and (e) of section 52 shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40dc8cf8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit made available to tax-exempt eligible small employers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40dc8cf9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a tax-exempt eligible small employer, there shall be treated as a credit allowable under subpart C (and not allowable under this subpart) the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40dc8cfa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the credit determined under this section with respect to such employer, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40dc8cfb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the payroll taxes of the employer during the calendar year in which the taxable year begins.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8cfc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax-exempt eligible small employer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “tax-exempt eligible small employer” means an eligible small employer which is any organization described in section 501(c) which is exempt from taxation under section 501(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8cfd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payroll taxes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40dc8cfe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “payroll taxes” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40dc8cff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/f/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts required to be withheld from the employees of the tax-exempt eligible small employer under section 3401(a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40dc8d00-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/f/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts required to be withheld from such employees under section 3101(b), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40dc8d01-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/f/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts of the taxes imposed on the tax-exempt eligible small employer under section 3111(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40dc8d02-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A rule similar to the rule of section 24(d)(2)(C) shall apply for purposes of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40dc8d03-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of section for calendar years 2010, 2011, 2012, and 2013","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any taxable year beginning in 2010, 2011, 2012, or 2013, the following modifications to this section shall apply in determining the amount of the credit under subsection (a):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40dc8d04-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No credit period required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The credit shall be determined without regard to whether the taxable year is in a credit period and for purposes of applying this section to taxable years beginning after 2013, no credit period shall be treated as beginning with a taxable year beginning before 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d05-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of credit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the credit determined under subsection (b) shall be determined—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40dc8d06-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “35 percent (25 percent in the case of a tax-exempt eligible small employer)” for “50 percent (35 percent in the case of a tax-exempt eligible small employer)”,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40dc8d07-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by reference to an eligible small employer’s nonelective contributions for premiums paid for health insurance coverage (within the meaning of section 9832(b)(1)) of an employee, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40dc8d08-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting for the average premium determined under subsection (b)(2) the amount the Secretary of Health and Human Services determines is the average premium for the small group market in the State in which the employer is offering health insurance coverage (or for such area within the State as is specified by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d09-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contribution arrangement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An arrangement shall not fail to meet the requirements of subsection (d)(4) solely because it provides for the offering of insurance outside of an Exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40dc8d0a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurance definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any term used in this section which is also used in the Public Health Service Act or subtitle A of title I of the Patient Protection and Affordable Care Act shall have the meaning given such term by such Act or subtitle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40dc8d0b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45R/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to carry out the provisions of this section, including regulations to prevent the avoidance of the 2-year limit on the credit period through the use of successor entities and the avoidance of the limitations under subsection (c) through the use of multiple entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id40dc8d0c-3a70-11f1-a967-d35dac11796a"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1421/a"},"text":"Pub. L. 111–148, title I, § 1421(a)","children":[],"tail":", title X, § 10105(e)(1), (2), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/237"},"text":"124 Stat. 237","children":[],"tail":", 906; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s11002/d/1/H"},"text":"Pub. L. 115–97, title I, § 11002(d)(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2060"},"text":"131 Stat. 2060","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id40dc8d0d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id40dc8d0e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inflation Adjusted Items for Certain Years","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For inflation adjustment of certain items in this section, see Revenue Procedures listed in a table under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id40dc8d0f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id40dc8d10-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Public Health Service Act, referred to in subsec. (h), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/682"},"text":"58 Stat. 682","children":[],"tail":", which is classified generally to chapter 6A (§ 201 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Patient Protection and Affordable Care Act, referred to in subsec. (h), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/119"},"text":"124 Stat. 119","children":[],"tail":". Subtitle A (§§ 1001 to 1004) of title I of the Act enacted sections 300gg–11 to 300gg–19, 300gg–93, and 300gg–94 of Title 42, The Public Health and Welfare, redesignated sections 300gg–4 to 300gg–7 of Title 42 as sections 300gg–25 to 300gg–28, respectively, of Title 42, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–13"},"text":"section 300gg–13 of Title 42","children":[],"tail":" as "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–9"},"text":"section 300gg–9 of Title 42","children":[],"tail":", amended former sections 300gg–11 and 300gg–12 and sections 300gg–21 to 300gg–23 of Title 42, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–11"},"text":"section 300gg–11 of Title 42","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18001"},"text":"section 18001 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id40dc8d11-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (d)(3)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" substituted “for ‘calendar year 2016’ in subparagraph (A)(ii)” for “for ‘calendar year 1992’ in subparagraph (B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10105/e/1"},"text":"Pub. L. 111–148, § 10105(e)(1)","children":[],"tail":", amended subpar. (B) generally, including dollar amount for taxable years beginning in 2010 in addition to dollar amounts for taxable years beginning in 2011, 2012, and 2013, and subsequent years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10105/e/2"},"text":"Pub. L. 111–148, § 10105(e)(2)","children":[],"tail":", substituted “2010, 2011” for “2011” in heading and in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id40dc8d12-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id40dc8d13-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s11002/e"},"text":"section 11002(e) of Pub. L. 115–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id40dc8d14-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10105/e/5"},"text":"Pub. L. 111–148, title X, § 10105(e)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/907"},"text":"124 Stat. 907","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/148/tX/s10105/e/5"},"text":"“The amendments made by this subsection [amending this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s280C"},"text":"section 280C of this title","children":[],"tail":", and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s38"},"text":"section 38 of this title","children":[],"tail":"] shall take effect as if included in the enactment of section 1421 of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id40dc8d15-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to amounts paid or incurred in taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2009-12-31"},"text":"Dec. 31, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1421/f/1"},"text":"section 1421(f)(1) of Pub. L. 111–148","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
