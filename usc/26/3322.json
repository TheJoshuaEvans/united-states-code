{"tag":"section","attrib":{"id":"id45958220-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3322"},"text":null,"children":[{"tag":"num","attrib":{"value":"3322"},"text":"§ 3322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45958221-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rail employer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the term “rail employer” means any person who is an employer as defined in section 1 of the Railroad Unemployment Insurance Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45958222-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rail wages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the term “rail wages” means, with respect to any calendar month, so much of the remuneration paid during such month which is subject to contributions under section 8(a) of the Railroad Unemployment Insurance Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45958223-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3322/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee representative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the term “employee representative” has the meaning given such term by section 1 of the Railroad Unemployment Insurance Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45958224-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3322/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain rules made applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, rules similar to the rules of section 3307 and 3308 shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45958225-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/76/tII/s231/a"},"text":"Pub. L. 98–76, title II, § 231(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-12"},"text":"Aug. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/427"},"text":"97 Stat. 427","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIII/s13301/d"},"text":"Pub. L. 99–272, title XIII, § 13301(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/327"},"text":"100 Stat. 327","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVII/s7106/a"},"text":"Pub. L. 100–647, title VII, § 7106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3773"},"text":"102 Stat. 3773","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45958226-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45958227-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id45958228-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1 of the Railroad Unemployment Insurance Act, referred to in subsecs. (a) and (c), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s351"},"text":"section 351 of Title 45","children":[],"tail":", Railroads."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8(a) of the Railroad Unemployment Insurance Act, referred to in subsec. (b), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s358/a"},"text":"section 358(a) of Title 45","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45958229-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" amended section generally, substituting present provisions for former provisions relating to taxable period, which had provided, in subsec. (a), for a general rule and, in subsec. (b), for earlier termination if loans to rail unemployment fund repaid."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s13301/d/1"},"text":"Pub. L. 99–272, § 13301(d)(1)","children":[],"tail":", struck out “and before 1990, and” after “1986” in par. (2) and struck out par. (3) relating to the period beginning on "},{"tag":"date","attrib":{"date":"1990-01-01"},"text":"Jan. 1, 1990","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1990-09-30"},"text":"Sept. 30, 1990","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s13301/d/2"},"text":"Pub. L. 99–272, § 13301(d)(2)","children":[],"tail":", substituted “The basic rate under section 3321(c)(1)(A) of the tax imposed by section 3321 shall not apply” for “The tax imposed by this chapter shall not apply” in introductory provision, and inserted “made before "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"October 1, 1985","children":[],"tail":",” in par. (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4595822a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4595822b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" applicable to remuneration paid after "},{"tag":"date","attrib":{"date":"1988-12-31"},"text":"Dec. 31, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s7106/d"},"text":"section 7106(d) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3321"},"text":"section 3321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4595822c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exclusion From Wages and Compensation of Refunds Required From Employers To Compensate for Duplication of Medicare Benefits by Health Care Benefits Provided by Employers","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For purposes of this chapter, the term “rail wages” shall not include the amount of any refund required under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s421"},"text":"section 421 of Pub. L. 100–360","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395b"},"text":"42 U.S.C. 1395b","children":[],"tail":" note, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s10202"},"text":"section 10202 of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395b"},"text":"section 1395b of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
