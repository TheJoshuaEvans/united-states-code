{"tag":"section","attrib":{"id":"id429cdab7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280B"},"text":null,"children":[{"tag":"num","attrib":{"value":"280B"},"text":"§ 280B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demolition of structures","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In the case of the demolition of any structure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id429cdab8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280B/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" no deduction otherwise allowable under this chapter shall be allowed to the owner or lessee of such structure for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id429cdab9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280B/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount expended for such demolition, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id429cdaba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280B/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any loss sustained on account of such demolition; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id429cdabb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280B/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts described in paragraph (1) shall be treated as properly chargeable to capital account with respect to the land on which the demolished structure was located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id429cdabc-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXXI/s2124/b/1"},"text":"Pub. L. 94–455, title XXI, § 2124(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1918"},"text":"90 Stat. 1918","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s701/f/5"},"text":"Pub. L. 95–600, title VII, § 701(f)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2902"},"text":"92 Stat. 2902","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/541/s2/b"},"text":"Pub. L. 96–541, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-17"},"text":"Dec. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3204"},"text":"94 Stat. 3204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tII/s212/d/2/C"},"text":"Pub. L. 97–34, title II, § 212(d)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/239"},"text":"95 Stat. 239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1063/a"},"text":"Pub. L. 98–369, div. A, title X, § 1063(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1047"},"text":"98 Stat. 1047","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id429cdabd-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id429cdabe-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id429cdabf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" struck out “certain historic” before “structures” in section catchline, struck out heading “(a) General rule”, substituted “In the case of the demolition of any structure” for “In the case of the demolition of a certified historic structure (as defined in 48(g)(3)(A))” in text, and struck out subsecs. (b) and (c) which contained provisions relating to a special rule for registered historic districts and to the application of this section, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s212/d/2/C/i"},"text":"Pub. L. 97–34, § 212(d)(2)(C)(i)","children":[],"tail":", substituted “48(g)(3)(A)” for “section 191(d)(1)” in provisions preceding par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s212/d/2/C/ii"},"text":"Pub. L. 97–34, § 212(d)(2)(C)(ii)","children":[],"tail":", substituted “section 48(g)(3)(B)” for “section 191(d)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/541"},"text":"Pub. L. 96–541","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" substituted “registered historic district (as defined in section 191(d)(2))” for “Registered Historic District” and “Secretary of the Interior has certified that such structure is not a certified historic structure, and that such structure is not of historic significance to the district, and if such certification occurs after the beginning of the demolition of such structure, the taxpayer has certified to the Secretary that, at the time of such demolition, he in good faith was not aware of the certification requirement by the Secretary of the Interior” for “Secretary of the Interior has certified, prior to the demolition of such structure, that such structure is not of historic significance to the district”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id429cdac0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id429cdac1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1063/c"},"text":"Pub. L. 98–369, div. A, title X, § 1063(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1047"},"text":"98 Stat. 1047","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1878/h"},"text":"Pub. L. 99–514, title XVIII, § 1878(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2904"},"text":"100 Stat. 2904","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXVIII/s1878/h"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by this section [amending this section] shall apply to taxable years ending after ","children":[{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":", but shall not apply to any demolition (other than of a certified historic structure) commencing before "},{"tag":"date","attrib":{"date":"1984-07-19"},"text":"July 19, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of paragraph (1), if a demolition is delayed until the completion of the replacement structure on the same site, the demolition shall be treated as commencing when construction of the replacement structure commences.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amendments made by this section [amending this section] shall not apply to any demolition commencing before ","children":[{"tag":"date","attrib":{"date":"1984-09-01"},"text":"September 1, 1984","children":[],"tail":", pursuant to a bank headquarters building project if—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on ","children":[{"tag":"date","attrib":{"date":"1984-04-01"},"text":"April 1, 1984","children":[],"tail":", a corporation was retained to advise the bank on the final completion of the project, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on ","children":[{"tag":"date","attrib":{"date":"1984-06-12"},"text":"June 12, 1984","children":[],"tail":", the Comptroller of the Currency approved the project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amendments made by this section shall not apply to the remaining adjusted basis at the time of demolition of any structure if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such structure was used in the manufacture, storage, or distribution of lead alkyl antiknock products and intermediate and related products at facilities located in or near Baton Rouge, Louisiana, and Houston, Texas, owned by the same corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demolition of at least one such structure at the Baton Rouge facility commenced before ","children":[{"tag":"date","attrib":{"date":"1984-01-01"},"text":"January 1, 1984","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id429cdac2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" applicable to expenditures incurred after "},{"tag":"date","attrib":{"date":"1981-12-31"},"text":"Dec. 31, 1981","children":[],"tail":", in taxable years ending after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/s212/e"},"text":"section 212(e) of Pub. L. 97–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s46"},"text":"section 46 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id429cdac3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" effective as if included within the enactment of this section by "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s2124"},"text":"section 2124 of Pub. L. 94–455","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/s701/f/8"},"text":"section 701(f)(8) of Pub. L. 95–600","children":[],"tail":", set out as an Effective and Termination Dates of 1978 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s167"},"text":"section 167 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id429cdac4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXXI/s2124/b/3"},"text":"Pub. L. 94–455, title XXI, § 2124(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1918"},"text":"90 Stat. 1918","children":[],"tail":", which had provided that enactment of this section by subsec. (b) shall apply with respect to demolitions commencing after "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1981-01-01"},"text":"Jan. 1, 1981","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/96/541/s2/e/2"},"text":"Pub. L. 96–541, § 2(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-17"},"text":"Dec. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3205"},"text":"94 Stat. 3205","children":[],"tail":". See subsec. (c) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
