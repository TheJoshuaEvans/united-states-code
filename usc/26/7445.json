{"tag":"section","attrib":{"id":"id47583fe7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7445"},"text":null,"children":[{"tag":"num","attrib":{"value":"7445"},"text":"§ 7445.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offices","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The principal office of the Tax Court shall be in the District of Columbia, but the Tax Court or any of its divisions may sit at any place within the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id47583fe8-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/880"},"text":"68A Stat. 880","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
