{"tag":"section","attrib":{"id":"id445141a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s874"},"text":null,"children":[{"tag":"num","attrib":{"value":"874"},"text":"§ 874.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of deductions and credits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id445141a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s874/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return prerequisite to allowance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A nonresident alien individual shall receive the benefit of the deductions and credits allowed to him in this subtitle only by filing or causing to be filed with the Secretary a true and accurate return, in the manner prescribed in subtitle F (sec. 6001 and following, relating to procedure and administration), including therein all the information which the Secretary may deem necessary for the calculation of such deductions and credits. This subsection shall not be construed to deny the credits provided by sections 31 and 33 for tax withheld at source or the credit provided by section 34 for certain uses of gasoline and special fuels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id445141a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s874/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax withheld at source","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The benefit of the deduction for exemptions under section 151 may, in the discretion of the Secretary, and under regulations prescribed by the Secretary, be received by a non-resident alien individual entitled thereto, by filing a claim therefor with the withholding agent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id445141a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s874/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign tax credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in section 906, a nonresident alien individual shall not be allowed the credits against the tax for taxes of foreign countries and possessions of the United States allowed by section 901.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id445141a6-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/281"},"text":"68A Stat. 281","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tVIII/s809/d/3"},"text":"Pub. L. 89–44, title VIII, § 809(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/167"},"text":"79 Stat. 167","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/tI"},"text":"Pub. L. 89–809, title I","children":[],"tail":", §§ 103(d), 106(a)(3), "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1551"},"text":"80 Stat. 1551","children":[],"tail":", 1569; "},{"tag":"ref","attrib":{"href":"/us/pl/91/258/tII/s207/d/1"},"text":"Pub. L. 91–258, title II, § 207(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-05-21"},"text":"May 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/248"},"text":"84 Stat. 248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/424/tV/s515/b/6/E"},"text":"Pub. L. 97–424, title V, § 515(b)(6)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-06"},"text":"Jan. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2182"},"text":"96 Stat. 2182","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s474/r/19"},"text":"Pub. L. 98–369, div. A, title IV, § 474(r)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/843"},"text":"98 Stat. 843","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id445141a7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id445141a8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id445141a9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted reference to section “33” for “32” and “34” for “39”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/424"},"text":"Pub. L. 97–424","children":[],"tail":" substituted “and special fuels” for “, special fuels, and lubricating oil”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/258"},"text":"Pub. L. 91–258","children":[],"tail":" included provision against construction of subsec. (a) to deny credit provided by section 39 for certain uses of special fuels."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809/s103/d"},"text":"Pub. L. 89–809, § 103(d)","children":[],"tail":", struck out “of his total income received from all sources in the United States” after “true and accurate return”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809/s106/a/3"},"text":"Pub. L. 89–809, § 106(a)(3)","children":[],"tail":", substituted “Foreign tax credit” for “Foreign tax credit not allowed” in heading and inserted reference to an exception provided in section 906."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" inserted “or the credit provided by section 39 for certain uses of gasoline and lubricating oil”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id445141aa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effecti