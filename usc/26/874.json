s2"},"text":"“The amendments made by this subsection [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s906"},"text":"section 906 of this title","children":[],"tail":" and amending this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s901"},"text":"section 901 of this title","children":[],"tail":"] shall apply with respect to taxable years beginning after "},{"tag":"date","attrib":{"date":"1966-12-31"},"text":"Dec. 31, 1966","children":[],"tail":". In applying section 904 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] with respect to section 906 of such Code, no amount may be carried from or to any taxable year beginning before "},{"tag":"date","attrib":{"date":"1967-01-01"},"text":"Jan. 1, 1967","children":[],"tail":", and no such year shall be taken into account.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id445141af-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1965 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" applicable to taxable years beginning on or after "},{"tag":"date","attrib":{"date":"1965-07-01"},"text":"July 1, 1965","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/s809/f"},"text":"section 809(f) of Pub. L. 89–44","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6420"},"text":"section 6420 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
