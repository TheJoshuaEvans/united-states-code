{"tag":"section","attrib":{"id":"id47287e00-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6673"},"text":null,"children":[{"tag":"num","attrib":{"value":"6673"},"text":"§ 6673.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions and costs awarded by courts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47287e01-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6673/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax court proceedings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47287e02-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6673/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures instituted primarily for delay, etc.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever it appears to the Tax Court that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47287e03-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6673/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceedings before it have been instituted or maintained by the taxpayer primarily for delay,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47287e04-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6673/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer’s position in such proceeding is frivolous or groundless, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47287e05-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6673/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer unreasonably failed to pursue available administrative remedies,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Tax Court, in its decision, may require the taxpayer to pay to the United States a penalty not in excess of $25,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47287e06-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6673/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counsel’s liability for excessive costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever it appears to the Tax Court that any attorney or other person admitted to practice before the Tax Court has multiplied the proceedings in any case unreasonably and vexatiously, the Tax Court may require—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47287e07-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6673/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such attorney or other person pay personally the excess costs, expenses, and attorneys’ fees reasonably incurred because of such conduct, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47287e08-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6673/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such attorney is appearing on behalf of the Commissioner of Internal Revenue, that the United States pay such excess costs, expenses, and attorneys’ fees in the same manner as such an award by a district court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47287e09-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6673/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proceedings in other courts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47287e0a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6673/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims under section 7433","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever it appears to the court that the taxpayer’s position in the proceedings before the court instituted or maintained by such taxpayer under section 7433 is frivolous or groundless, the court may require the taxpayer to pay to the United States a penalty not in excess of $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47287e0b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6673/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of sanctions and costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any civil proceeding before any court (other than the Tax Court) which is brought by or against the United States in connection with the determination, collection, or refund of any tax, interest, or penalty under this title, any monetary sanctions, penalties, or costs awarded by the court to the United States may be assessed by the Secretary and, upon notice and demand, may be collected in the same manner as a tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47287e0c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6673/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions and costs awarded by a court of appeals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In connection with any appeal from a proceeding in the Tax Court or a civil proceeding described in paragraph (2), an order of a United States Court of Appeals or the Supreme Court awarding monetary sanctions, penalties or court costs to the United States may be registered in a district court upon filing a certified copy of such order and shall be enforceable as other district court judgments. Any such sanctions, penalties, or costs may be assessed by the Secretary and, upon notice and demand, may be collected in the same manner as a tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47287e0d-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/828"},"text":"68A Stat. 828","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tII/s292/b"},"text":"Pub. L. 97–248, title II, § 292(b)","children":[],"tail":", (d)(2)(A), "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/574"},"text":"96 Stat. 574","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1552/a"},"text":"Pub. L. 99–514, title XV, § 1552(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2753"},"text":"100 Stat. 2753","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6241/b"},"text":"Pub. L. 100–647, title VI, § 6241(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3748"},"text":"102 Stat. 3748","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7731/a"},"text":"Pub. L. 101–239, title VII, § 7731(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2400"},"text":"103 Stat. 2400","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47287e0e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47287e0f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47287e10-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" substituted “Sanctions and costs awarded by courts” for “Damages assessable for instituting proceedings before the Court primarily for delay, etc.” in section catchline and amended text generally, making changes in substance and structure of subsecs. (a) and (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" struck out “Tax” after “before the” in section catchline, designated existing provisions as subsec. (a), and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “, that the taxpayer’s position in such proceeding is frivolous or groundless, or that the taxpayer unreasonably failed to pursue available administrative remedies” for “or that the taxpayer’s position in such proceedings is frivolous or groundless”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s292/d/2/A"},"text":"Pub. L. 97–248, § 292(d)(2)(A)","children":[],"tail":", substituted “primarily for delay, etc.” for “merely for delay” after “Tax Court” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s292/b"},"text":"Pub. L. 97–248, § 292(b)","children":[],"tail":", substituted “or maintained by the taxpayer primarily for delay or that the taxpayer’s position in such proceedings is frivolous or groundless, damages in an amount not in excess of $5,000” for “by the taxpayer merely for delay, damages in an amount not in excess of $500” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47287e11-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47287e12-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7731/d"},"text":"Pub. L. 101–239, title VII, § 7731(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2402"},"text":"103 Stat. 2402","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tVII/s7731/d"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7482"},"text":"section 7482 of this title","children":[],"tail":"] shall apply to positions taken after "},{"tag":"date","attrib":{"date":"1989-12-31"},"text":"December 31, 1989","children":[],"tail":", in proceedings which are pending on, or commenced after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47287e13-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6241/d"},"text":"Pub. L. 100–647, title VI, § 6241(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3749"},"text":"102 Stat. 3749","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tVI/s6241/d"},"text":"“The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7433"},"text":"section 7433 of this title","children":[],"tail":" and amending this section] shall apply to actions by officers or employees of the Internal Revenue Service after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47287e14-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1552/b"},"text":"Pub. L. 99–514, title XV, § 1552(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2753"},"text":"100 Stat. 2753","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXV/s1552/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to proceedings commenced after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47287e15-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" applicable to any action or proceeding in the Tax Court commenced after "},{"tag":"date","attrib":{"date":"1982-12-31"},"text":"Dec. 31, 1982","children":[],"tail":", or pending in the Tax Court on the day 120 days after "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/s292/e/2"},"text":"section 292(e)(2) of Pub. L. 97–248","children":[],"tail":", as amended, set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7430"},"text":"section 7430 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
