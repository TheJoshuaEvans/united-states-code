{"tag":"section","attrib":{"id":"id46bd38fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6222"},"text":null,"children":[{"tag":"num","attrib":{"value":"6222"},"text":"§ 6222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partner’s return must be consistent with partnership return","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46bd38fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6222/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A partner shall, on the partner’s return, treat any partnership-related item in a manner which is consistent with the treatment of such item on the partnership return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bd38ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6222/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underpayment due to inconsistent treatment assessed as math error","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any underpayment of tax by a partner by reason of failing to comply with the requirements of subsection (a) shall be assessed and collected in the same manner as if such underpayment were on account of a mathematical or clerical error appearing on the partner’s return. Paragraph (2) of section 6213(b) shall not apply to any assessment of an underpayment referred to in the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bd3900-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6222/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for notification of inconsistent treatment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46bd3901-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6222/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any item referred to in subsection (a), if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46bd3902-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6222/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46bd3903-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6222/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the partnership has filed a return but the partner’s treatment on the partner’s return is (or may be) inconsistent with the treatment of the item on the partnership return, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46bd3904-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6222/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the partnership has not filed a return, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bd3905-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6222/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the partner files with the Secretary a statement identifying the inconsistency,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"subsections (a) and (b) shall not apply to such item.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bd3906-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6222/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partner receiving incorrect information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A partner shall be treated as having complied with subparagraph (B) of paragraph (1) with respect to an item if the partner—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46bd3907-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6222/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates to the satisfaction of the Secretary that the treatment of the item on the partner’s return is consistent with the treatment of the item on the statement furnished to the partner by the partnership, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bd3908-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6222/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elects to have this paragraph apply with respect to that item.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bd3909-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6222/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final decision on certain positions not binding on partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any final decision with respect to an inconsistent position identified under subsection (c) in a proceeding to which the partnership is not a party shall not be binding on the partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bd390a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6222/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Addition to tax for failure to comply with section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For addition to tax in the case of a partner’s disregard of the requirements of this section, see part II of subchapter A of chapter 68.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46bd390b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/74/tXI/s1101/c/1"},"text":"Pub. L. 114–74, title XI, § 1101(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/626"},"text":"129 Stat. 626","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tII/s201/c/3"},"text":"Pub. L. 115–141, div. U, title II, § 201(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1173"},"text":"132 Stat. 1173","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46bd390c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46bd390d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46bd390e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6222, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIV/s402/a"},"text":"Pub. L. 97–248, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/648"},"text":"96 Stat. 648","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1503/c/1"},"text":"Pub. L. 99–514, title XV, § 1503(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2743"},"text":"100 Stat. 2743","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7721/c/7"},"text":"Pub. L. 101–239, title VII, § 7721(c)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2400"},"text":"103 Stat. 2400","children":[],"tail":", required partner’s return to be consistent with partnership return or Secretary to be notified of inconsistency, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/74/tXI/s1101/a"},"text":"Pub. L. 114–74, title XI, § 1101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/625"},"text":"129 Stat. 625","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46bd390f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows: “A partner shall, on the partner’s return, treat each item of income, gain, loss, deduction, or credit attributable to a partnership in a manner which is consistent with the treatment of such income, gain, loss, deduction, or credit on the partnership return.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46bd3910-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46bd3911-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" effective as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/114/74/s1101"},"text":"section 1101 of Pub. L. 114–74","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/s207"},"text":"section 207 of Pub. L. 115–141","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6031"},"text":"section 6031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46bd3912-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to returns filed for partnership taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/74/s1101/g"},"text":"section 1101(g) of Pub. L. 114–74","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6221"},"text":"section 6221 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
