{"tag":"section","attrib":{"id":"id46bfa9a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6231"},"text":null,"children":[{"tag":"num","attrib":{"value":"6231"},"text":"§ 6231.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of proceedings and adjustment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46bfa9a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6231/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall mail to the partnership and the partnership representative—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46bfa9a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6231/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of any administrative proceeding initiated at the partnership level with respect to an adjustment of any partnership-related item for any partnership taxable year, or any partner’s distributive share thereof,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bfa9a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6231/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of any proposed partnership adjustment resulting from such proceeding, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bfa9aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6231/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of any final partnership adjustment resulting from such proceeding.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any notice of a final partnership adjustment shall be sufficient if mailed to the last known address of the partnership representative or the partnership (even if the partnership has terminated its existence). The first sentence shall apply to any proceeding with respect to an administrative adjustment request filed by a partnership under section 6227.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bfa9ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6231/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of notices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46bfa9ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6231/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of proposed partnership adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any notice of a proposed partnership adjustment shall not be mailed later than the date determined under section 6235 (determined without regard to paragraphs (2) and (3) of subsection (a) thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bfa9ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6231/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of final partnership adjustment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46bfa9ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6231/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except to the extent that the partnership elects to waive the application of this subparagraph, any notice of a final partnership adjustment shall not be mailed earlier than 270 days after the date on which the notice of the proposed partnership adjustment is mailed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bfa9af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6231/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations on adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the period of limitations on making adjustments, see section 6235.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bfa9b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6231/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Further notices restricted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary mails a notice of a final partnership adjustment to any partnership for any partnership taxable year and the partnership files a petition under section 6234 with respect to such notice, in the absence of a showing of fraud, malfeasance, or misrepresentation of a material fact, the Secretary shall not mail another such notice to such partnership with respect to such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bfa9b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6231/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to rescind notice with partnership consent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, with the consent of the partnership, rescind any notice of a partnership adjustment mailed to such partnership. Any notice so rescinded shall not be treated as a notice of a partnership adjustment for purposes of this subchapter, and the taxpayer shall have no right to bring a proceeding under section 6234 with respect to such notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46bfa9b2-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/74/tXI/s1101/c/1"},"text":"Pub. L. 114–74, title XI, § 1101(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/632"},"text":"129 Stat. 632","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tII"},"text":"Pub. L. 115–141, div. U, title II","children":[],"tail":", §§ 201(c)(6), 206(h), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1173"},"text":"132 Stat. 1173","children":[],"tail":", 1179.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46bfa9b3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46bfa9b4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46bfa9b5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag"