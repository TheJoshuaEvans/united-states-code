{"tag":"section","attrib":{"id":"id45a3d971-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3508"},"text":null,"children":[{"tag":"num","attrib":{"value":"3508"},"text":"§ 3508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of real estate agents and direct­ sellers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45a3d972-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this title, in the case of services performed as a qualified real estate agent or as a direct seller—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45a3d973-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3508/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual performing such services shall not be treated as an employee, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a3d974-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3508/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person for whom such services are performed shall not be treated as an employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a3d975-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45a3d976-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3508/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified real estate agent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified real estate agent” means any individual who is a sales person if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45a3d977-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3508/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individual is a licensed real estate agent,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a3d978-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3508/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially all of the remuneration (whether or not paid in cash) for the services performed by such individual as a real estate agent is directly related to sales or other output (including the performance of services) rather than to the number of hours worked, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a3d979-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3508/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the services performed by the individual are performed pursuant to a written contract between such individual and the person for whom the services are performed and such contract provides that the individual will not be treated as an employee with respect to such services for Federal tax purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a3d97a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3508/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct seller","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “direct seller” means any person if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45a3d97b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3508/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45a3d97c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3508/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is engaged in the trade or business of selling (or soliciting the sale of) consumer products to any buyer on a buy-sell basis, a deposit-commission basis, or any similar basis which the Secretary prescribes by regulations, for resale (by the buyer or any other person) in the home or otherwise than in a permanent retail establishment,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45a3d97d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3508/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is engaged in the trade or business of selling (or soliciting the sale of) consumer products in the home or otherwise than in a permanent retail establishment, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45a3d97e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3508/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is engaged in the trade or business of the delivering or distribution of newspapers or shopping news (including any services directly related to such trade or business),","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a3d97f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3508/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially all the remuneration (whether or not paid in cash) for the performance of the services described in subparagraph (A) is directly related to sales or other output (including the performance of services) rather than to the number of hours worked, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a3d980-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3508/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the services performed by the person are performed pursuant to a written contract between such person and the person for whom the services are performed and such contract provides that the person will not be treated as an employee with respect to such services for Federal tax purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a3d981-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3508/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with retirement plans for self-employed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply for purposes of subtitle A to the extent that the individual is treated as an employee under section 401(c)(1) (relating to self-employed individuals).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45a3d982-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tII/s269/a"},"text":"Pub. L. 97–248, title II, § 269(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/551"},"text":"96 Stat. 551","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1118/a"},"text":"Pub. L. 104–188, title I, § 1118(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1764"},"text":"110 Stat. 1764","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45a3d983-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45a3d984-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45a3d985-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" added cl. (iii)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45a3d986-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45a3d987-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/tXI/s1118/b"},"text":"Pub. L. 104–188, title XI, § 1118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1764"},"text":"110 Stat. 1764","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/188/tXI/s1118/b"},"text":"“The amendments made by this section shall apply to services performed after ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45a3d988-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tII/s269/e"},"text":"Pub. L. 97–248, title II, § 269(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/553"},"text":"96 Stat. 553","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/248/tII/s269/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s410"},"text":"section 410 of Title 42","children":[],"tail":", The Public Health and Welfare] shall apply to services performed after "},{"tag":"date","attrib":{"date":"1982-12-31"},"text":"December 31, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsection","children":[],"tail":" (c).—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsection (c) [amending provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3401"},"text":"section 3401 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"1982-07-01"},"text":"July 1, 1982","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id45a3d989-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rules and Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tII/s269/c/3"},"text":"Pub. L. 97–248, title II, § 269(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/553"},"text":"96 Stat. 553","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/248/tII/s269/c/3"},"text":"“Nothing in section 530 of the Revenue Act of 1978 [set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3401"},"text":"section 3401 of this title","children":[],"tail":"] shall be construed to prohibit the implementation of the amendments made by this section [enacting this section, amending "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s410"},"text":"section 410 of Title 42","children":[],"tail":", The Public Health and Welfare, and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3401"},"text":"section 3401 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
