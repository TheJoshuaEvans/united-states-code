{"tag":"section","attrib":{"id":"id4761b6a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7475"},"text":null,"children":[{"tag":"num","attrib":{"value":"7475"},"text":"§ 7475.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Practice fee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4761b6a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7475/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Tax Court is authorized to impose a periodic registration fee on practitioners admitted to practice before such Court. The frequency and amount of such fee shall be determined by the Tax Court, except that such amount may not exceed $30 per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4761b6aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7475/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fees described in subsection (a) shall be available to the Tax Court to employ independent counsel to pursue disciplinary matters and to provide services to pro se taxpayers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4761b6ab-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1553/a"},"text":"Pub. L. 99–514, title XV, § 1553(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2754"},"text":"100 Stat. 2754","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tVIII/s860/a"},"text":"Pub. L. 109–280, title VIII, § 860(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1020"},"text":"120 Stat. 1020","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4761b6ac-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4761b6ad-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4761b6ae-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" inserted “and to provide services to pro se taxpayers” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4761b6af-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4761b6b0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tVIII/s860/b"},"text":"Pub. L. 109–280, title VIII, § 860(b)","children":[],"tail":", "},{"tag":"date","attrib":{"d