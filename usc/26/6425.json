{"tag":"section","attrib":{"id":"id46ecd468-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425"},"text":null,"children":[{"tag":"num","attrib":{"value":"6425"},"text":"§ 6425.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of overpayment of estimated income tax by corporation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46ecd469-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of adjustment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46ecd46a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for filing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A corporation may, after the close of the taxable year and on or before the 15th day of the fourth month thereafter, and before the day on which it files a return for such taxable year, file an application for an adjustment of an overpayment by it of estimated income tax for such taxable year. An application under this subsection shall not constitute a claim for credit or refund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ecd46b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of application, etc.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application under this subsection shall be verified in the manner prescribed by section 6065 in the case of a return of the taxpayer, and shall be filed in the manner and form required by regulations prescribed by the Secretary. The application shall set forth—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46ecd46c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated income tax paid by the corporation during the taxable year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46ecd46d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount which, at the time of filing the application, the corporation estimates as its income tax liability for the taxable year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46ecd46e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the adjustment, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46ecd46f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information for purposes of carrying out the provisions of this section as may be required by such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46ecd470-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of adjustment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46ecd471-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited examination of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within a period of 45 days from the date on which an application for an adjustment is filed under subsection (a), the Secretary shall make, to the extent he deems practicable in such period, a limited examination of the application to discover omissions and errors therein, and shall determine the amount of the adjustment upon the basis of the application and the examination; except that the Secretary may disallow, without further action, any application which he finds contains material omissions or errors which he deems cannot be corrected within such 45 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ecd472-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment credited or refunded","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, within the 45-day period referred to in paragraph (1), may credit the amount of the adjustment against any liability in respect of an internal revenue tax on the part of the corporation and shall refund the remainder to the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ecd473-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No application under this section shall be allowed unless the amount of the adjustment equals or exceeds (A) 10 percent of the amount estimated by the corporation on its application as its income tax liability for the taxable year, and (B) $500.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ecd474-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this title (other than section 6655), any adjustment under this section shall be treated as a reduction, in the estimated income tax paid, made on the day the credit is allowed or the refund is paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46ecd475-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section and section 6655(h) (relating to excessive adjustment)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46ecd476-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “income tax liability” means the excess of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46ecd477-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46ecd478-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax imposed by section 11 or subchapter L of chapter 1, whichever is applicable, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46ecd479-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax imposed by section 55, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46ecd47a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax imposed by section 59A, over","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46ecd47b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the credits against tax provided by part IV of subchapter A of chapter 1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ecd47c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount of an adjustment under this section is equal to the excess of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46ecd47d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated income tax paid by the corporation during the taxable year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46ecd47e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount which, at the time of filing the application, the corporation estimates as its income tax liability for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46ecd47f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6425/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidated returns","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the corporation seeking an adjustment under this section paid its estimated income tax on a consolidated basis or expects to make a consolidated return for the taxable year, this section shall apply only to such extent and subject to such conditions, limitations, and exceptions as the Secretary may by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46ecd480-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/364/tI/s103/d/1"},"text":"Pub. L. 90–364, title I, § 103(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-28"},"text":"June 28, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/262"},"text":"82 Stat. 262","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/tV/s516/b/4/C"},"text":"Pub. L. 99–499, title V, § 516(b)(4)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1771"},"text":"100 Stat. 1771","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVII/s701/d/2"},"text":"Pub. L. 99–514, title VII, § 701(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2342"},"text":"100 Stat. 2342","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10301/b/4"},"text":"Pub. L. 100–203, title X, § 10301(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-429"},"text":"101 Stat. 1330–429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/12/J"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(12)(J)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4039"},"text":"128 Stat. 4039","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/41/tII/s2006/a/2/E"},"text":"Pub. L. 114–41, title II, § 2006(a)(2)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-07-31"},"text":"July 31, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/457"},"text":"129 Stat. 457","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI"},"text":"Pub. L. 115–97, title I","children":[],"tail":", §§ 12001(b)(17), 13001(b)(2)(P), 14401(d)(3), "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2094"},"text":"131 Stat. 2094","children":[],"tail":", 2097, 2233; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/293"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(293)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1198"},"text":"132 Stat. 1198","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s10101/a/4/F"},"text":"Pub. L. 117–169, title I, § 10101(a)(4)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1822"},"text":"136 Stat. 1822","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46ecd481-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46ecd482-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46ecd483-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":" amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the sum of—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the tax imposed by section 11, or subchapter L of chapter 1, whichever is applicable, plus","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the tax imposed by section 59A, over”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":", which directed amendment of subpar. (A) by substituting “the sum” for “The sum”, could not be executed because “The sum” no longer appeared after the amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":". See 2017 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s14401/d/3"},"text":"Pub. L. 115–97, § 14401(d)(3)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “the tax imposed by section 11 or subchapter L of chapter 1, whichever is applicable, over”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13001/b/2/P"},"text":"Pub. L. 115–97, § 13001(b)(2)(P)","children":[],"tail":", struck out “or 1201(a),” after “by section 11”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s12001/b/17"},"text":"Pub. L. 115–97, § 12001(b)(17)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “The sum of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the tax imposed by section 11 or 1201(a), or subchapter L of chapter 1, whichever is applicable, plus","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the tax imposed by section 55, over”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/41"},"text":"Pub. L. 114–41","children":[],"tail":" substituted “fourth month” for “third month”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" inserted “plus” at end of cl. (i), substituted “over” for “plus” at end of cl. (ii), and struck out cl. (iii) which read as follows: “the tax imposed by section 59A, over”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" substituted “section 6655(h)” for “section 6655(g)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" amended subpar. (A) generally, restating existing provisions as cl. (i) and adding cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499"},"text":"Pub. L. 99–499","children":[],"tail":" amended subsec. (c)(1)(A), as amended by the Tax Reform Act of 1986 ("},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":"), by striking out “plus” at end of cl. (i), substituting “plus” for “over” at end of cl. (ii), and adding cl. (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (b), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46ecd484-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}