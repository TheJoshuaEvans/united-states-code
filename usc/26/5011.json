{"tag":"section","attrib":{"id":"id461d760e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5011"},"text":null,"children":[{"tag":"num","attrib":{"value":"5011"},"text":"§ 5011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income tax credit for average cost of carrying excise tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id461d760f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5011/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of section 38, the amount of the distilled spirits credit for any taxable year is the amount equal to the product of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id461d7610-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5011/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id461d7611-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5011/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any eligible wholesaler, the number of cases of bottled distilled spirits—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id461d7612-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5011/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which were bottled in the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id461d7613-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5011/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are purchased by such wholesaler during the taxable year directly from the bottler of such spirits, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id461d7614-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5011/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person which is subject to section 5005 and which is not an eligible wholesaler, the number of cases of bottled distilled spirits which are stored in a warehouse operated by, or on behalf of, a State or political subdivision thereof, or an agency of either, on which title has not passed on an unconditional sale basis, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461d7615-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5011/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average tax-financing cost per case for the most recent calendar year ending before the beginning of such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id461d7616-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5011/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible wholesaler","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “eligible wholesaler” means any person which holds a permit under the Federal Alcohol Administration Act as a wholesaler of distilled spirits which is not a State or political subdivision thereof, or an agency of either.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id461d7617-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5011/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Average tax-financing cost","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id461d7618-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5011/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the average tax-financing cost per case for any calendar year is the amount of interest which would accrue at the deemed financing rate during a 60-day period on an amount equal to the deemed Federal excise tax per case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461d7619-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5011/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deemed financing rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the deemed financing rate for any calendar year is the average of the corporate overpayment rates under paragraph (1) of section 6621(a) (determined without regard to the last sentence of such paragraph) for calendar quarters of such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461d761a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5011/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deemed Federal excise tax per case","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the deemed Federal excise tax per case is $25.68.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id461d761b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5011/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id461d761c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5011/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Case","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “case” means 12 80-proof 750-milliliter bottles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461d761d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5011/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of cases in lot","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The number of cases in any lot of distilled spirits shall be determined by dividing the number of liters in such lot by 9.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id461d761e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11126/a"},"text":"Pub. L. 109–59, title XI, § 11126(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1957"},"text":"119 Stat. 1957","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id461d761f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id461d7620-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id461d7621-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Alcohol Administration Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-29/ch814"},"text":"act Aug. 29, 1935, ch. 814","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/977"},"text":"49 Stat. 977","children":[],"tail":", which is classified generally to subchapter I (§ 201 et seq.) of chapter 8 of Title 27, Intoxicating Liquors. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t27/s201"},"text":"section 201 of Title 27","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id461d7622-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5011, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/604"},"text":"68A Stat. 604","children":[],"tail":", related to abatement, remission, refund and allowance for loss or destruction of distilled spirits, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5012, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/605"},"text":"68A Stat. 605","children":[],"tail":", related to drawback on exportation of distilled spirits, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id461d7623-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id461d7624-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2005-09-30"},"text":"Sept. 30, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11126/d"},"text":"section 11126(d) of Pub. L. 109–59","children":[],"tail":", set out as an Effective Date of 2005 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
