{"tag":"section","attrib":{"id":"id47287e16-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6674"},"text":null,"children":[{"tag":"num","attrib":{"value":"6674"},"text":"§ 6674.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraudulent statement or failure to furnish statement to employee","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to the criminal penalty provided by section 7204, any person required under the provisions of section 6051 or 6053(b) to furnish a statement to an employee who willfully furnishes a false or fraudulent statement, or who willfully fails to furnish a statement in the manner, at the time, and showing the information required under section 6051 or 6053(b), or regulations prescribed thereunder, shall for each such failure be subject to a penalty under this subchapter of $50, which shall be assessed and collected in the same manner as the tax on employers imposed by section 3111.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id472aef17-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/828"},"text":"68A Stat. 828","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/97/tIII/s313/e/2/C"},"text":"Pub. L. 89–97, title III, § 313(e)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-30"},"text":"July 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/385"},"text":"79 Stat. 385","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id472aef18-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id472aef19-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id472aef1a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/97"},"text":"Pub. L. 89–97","children":[],"tail":" substituted “6051 or 6053(b)” for “6051” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id472aef1b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id472aef1c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1965 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/97/s313"},"text":"section 313 of Pub. L. 89–97","children":[],"tail":" applicable only with respect to tips received by employees after 1965, see "},{"tag":"ref","attrib":{"href":"/us/pl/89/97/s313/f"},"text":"section 313(f) of Pub. L. 89–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6053"},"text":"section 6053 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
