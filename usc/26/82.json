{"tag":"section","attrib":{"id":"id4145887a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s82"},"text":null,"children":[{"tag":"num","attrib":{"value":"82"},"text":"§ 82.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of moving expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided in section 132(a)(6), there shall be included in gross income (as compensation for services) any amount received or accrued, directly or indirectly, by an individual as a payment for or reimbursement of expenses of moving from one residence to another residence which is attributable to employment or self-employment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4145887b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tII/s231/b"},"text":"Pub. L. 91–172, title II, § 231(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/579"},"text":"83 Stat. 579","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13213/d/3/A"},"text":"Pub. L. 103–66, title XIII, § 13213(d)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/474"},"text":"107 Stat. 474","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/34"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(34)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1186"},"text":"132 Stat. 1186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4145887c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4145887d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4145887e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “of moving expenses” for “for expenses of moving” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" substituted “Except as provided in section 132(a)(6), there shall” for “There shall”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4145887f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41458880-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" applicable to reimbursements or other payments in respect of expenses incurred after "},{"tag":"date","attrib":{"date":"1993-12-31"},"text":"Dec. 31, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13213/e"},"text":"section 13213(e) of Pub. L. 103–66","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s62"},"text":"section 62 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id41458881-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1969-12-31"},"text":"December 31, 1969","children":[],"tail":", except that it does not apply to moving expenses paid or incurred before "},{"tag":"date","attrib":{"date":"1970-07-01"},"text":"July 1, 1970","children":[],"tail":", in connection with the commencement of work by the taxpayer as an employee at a new principal place of work of which the taxpayer had been notified by his employer on or before "},{"tag":"date","attrib":{"date":"1969-12-19"},"text":"December 19, 1969","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/s231/d"},"text":"section 231(d) of Pub. L. 91–172","children":[],"tail":", set out as an Effective Date of 1969 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s217"},"text":"section 217 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id41458882-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Moving Expenses of Members of the Uniformed Services","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Withholding, reporting, inclusion within adjusted gross income, and deduction for reimbursement for moving expenses of members of the uniformed services, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/490/s2"},"text":"section 2 of Pub. L. 93–490","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-26"},"text":"Oct. 26, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1466"},"text":"88 Stat. 1466","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s217"},"text":"section 217 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
