{"tag":"section","attrib":{"id":"id46e81979-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418"},"text":null,"children":[{"tag":"num","attrib":{"value":"6418"},"text":"§ 6418.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of certain credits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46e8197a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an eligible taxpayer which elects to transfer all (or any portion specified in the election) of an eligible credit determined with respect to such taxpayer for any taxable year to a taxpayer (referred to in this section as the “transferee taxpayer”) which is not related (within the meaning of section 267(b) or 707(b)(1)) to the eligible taxpayer, the transferee taxpayer specified in such election (and not the eligible taxpayer) shall be treated as the taxpayer for purposes of this title with respect to such credit (or such portion thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46e8197b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of payments made in connection with transfer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any amount paid by a transferee taxpayer to an eligible taxpayer as consideration for a transfer described in subsection (a), such consideration—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46e8197c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be required to be paid in cash,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e8197d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be includible in gross income of the eligible taxpayer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e8197e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the transferee taxpayer, shall not be deductible under this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46e8197f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to partnerships and S corporations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46e81980-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any eligible credit determined with respect to any facility or property held directly by a partnership or S corporation, if such partnership or S corporation makes an election under subsection (a) (in such manner as the Secretary may provide) with respect to such credit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46e81981-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount received as consideration for a transfer described in such subsection shall be treated as tax exempt income for purposes of sections 705 and 1366, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46e81982-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partner’s distributive share of such tax exempt income shall be based on such partner’s distributive share of the otherwise eligible credit for each taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e81983-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with application at partner or shareholder level","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any facility or property held directly by a partnership or S corporation, no election by any partner or shareholder shall be allowed under subsection (a) with respect to any eligible credit determined with respect to such facility or property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46e81984-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable year in which credit taken into account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any credit (or portion thereof) with respect to which an election is made under subsection (a), such credit shall be taken into account in the first taxable year of the transferee taxpayer ending with, or after, the taxable year of the eligible taxpayer with respect to which the credit was determined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46e81985-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on election","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46e81986-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under subsection (a) to transfer any portion of an eligible credit shall be made not later than the due date (including extensions of time) for the return of tax for the taxable year for which the credit is determined, but in no event earlier than 180 days after the date of the enactment of this section. Any such election, once made, shall be irrevocable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e81987-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No additional transfers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No election may be made under subsection (a) by a transferee taxpayer with respect to any portion of an eligible credit which has been previously transferred to such taxpayer pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46e81988-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46e81989-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible credit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46e8198a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible credit” means each of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46e8198b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" So much of the credit for alternative fuel vehicle refueling property allowed under section 30C which, pursuant to subsection (d)(1) of such section, is treated as a credit listed in section 38(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46e8198c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The renewable electricity production credit determined under section 45(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46e8198d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The credit for carbon oxide sequestration determined under section 45Q(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46e8198e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The zero-emission nuclear power production credit determined under section 45U(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46e8198f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The clean hydrogen production credit determined under section 45V(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46e81990-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The advanced manufacturing production credit determined under section 45X(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46e81991-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The clean electricity production credit determined under section 45Y(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46e81992-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f/1/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The clean fuel production credit determined under section 45Z(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46e81993-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f/1/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The energy credit determined under section 48.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46e81994-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f/1/A/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The qualifying advanced energy project credit determined under section 48C.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46e81995-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f/1/A/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The clean electricity investment credit determined under section 48E.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46e81996-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f/1/A/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" So much of the biodiesel fuels credit determined under section 40A which consists of the small agri-biodiesel producer credit determined under subsection (b)(4) of such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46e81997-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election for certain credits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any eligible credit described in clause (ii), (iii), (v), or (vii) of subparagraph (A), an election under subsection (a) shall be made—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46e81998-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" separately with respect to each facility for which such credit is determined, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46e81999-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each taxable year during the 10-year period beginning on the date such facility was originally placed in service (or, in the case of the credit described in clause (iii), for each year during the 12-year period beginning on the date the carbon capture equipment was originally placed in service at such facility).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46e8199a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for business credit carryforwards or carrybacks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible credit” shall not include any business credit carryforward or business credit carryback determined under section 39.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e8199b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible taxpayer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible taxpayer” means any taxpayer which is not described in section 6417(d)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46e8199c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46e8199d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of, and prior to, any transfer of any portion of an eligible credit pursuant to subsection (a), the Secretary may require such information (including, in such form or manner as is determined appropriate by the Secretary, such information returns) or registration as the Secretary deems necessary for purposes of preventing duplication, fraud, improper payments, or excessive payments under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e8199e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excessive credit transfer","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46e8199f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any portion of an eligible credit which is transferred to a transferee taxpayer pursuant to subsection (a) which the Secretary determines constitutes an excessive credit transfer, the tax imposed on the transferee taxpayer by chapter 1 (regardless of whether such entity would otherwise be subject to tax under such chapter) for the taxable year in which such determination is made shall be increased by an amount equal to the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46e819a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/g/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such excessive credit transfer, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46e819a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/g/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 20 percent of such excessive credit transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46e819a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable cause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A)(ii) shall not apply if the transferee taxpayer demonstrates to the satisfaction of the Secretary that the excessive credit transfer resulted from reasonable cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46e819a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excessive credit transfer defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph, the term “excessive credit transfer” means, with respect to a facility or property for which an election is made under subsection (a) for any taxable year, an amount equal to the excess of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46e819a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/g/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the eligible credit claimed by the transferee taxpayer with respect to such facility or property for such taxable year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46e819a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/g/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such credit which, without application of this section, would be otherwise allowable under this title with respect to such facility or property for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e819a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis reduction; notification of recapture","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any election under subsection (a) with respect to any portion of an eligible credit described in clauses (ix) through (xi) of subsection (f)(1)(A)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46e819a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (c) of section 50 shall apply to the applicable investment credit property (as defined in subsection (a)(7) of such section) as if such eligible credit was allowed to the eligible taxpayer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46e819a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if, during any taxable year, the applicable investment credit property (as defined in subsection (a)(7) of section 50) is disposed of, or otherwise ceases to be investment credit property with respect to the eligible taxpayer, before the close of the recapture period (as described in subsection (a)(1) of such section)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46e819a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/g/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such eligible taxpayer shall provide notice of such occurrence to the transferee taxpayer (in such form and manner as the Secretary shall prescribe), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46e819aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/g/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transferee taxpayer shall provide notice of the recapture amount (as defined in subsection (c)(2) of such section), if any, to the eligible taxpayer (in such form and manner as the Secretary shall prescribe).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e819ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on election or transfer with respect to progress expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply with respect to any amount of an eligible credit which is allowed pursuant to rules similar to the rules of subsections (c)(4) and (d) of section 46 (as in effect on the day before the date of the enactment of the Revenue Reconciliation Act of 1990).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e819ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on transfer of credits to specified foreign entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any eligible credit described in clause (iii), (iv), (vi), (vii), (viii), or (xi) of subsection (f)(1)(A), an eligible taxpayer may not elect to transfer any portion of such credit to a taxpayer that is a specified foreign entity (as defined in section 7701(a)(51)(B)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46e819ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6418/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue such regulations or other guidance as may be necessary to carry out the purposes of this section, including regulations or other guidance providing rules for determining a partner’s distributive share of the tax exempt income described in subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46e819ae-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s13801/b"},"text":"Pub. L. 117–169, title I, § 13801(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2009"},"text":"136 Stat. 2009","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII"},"text":"Pub. L. 119–21, title VII","children":[],"tail":", §§ 70512(h), 70513(b)(3)(B)(ii), 70521(j)(2), "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/267"},"text":"139 Stat. 267","children":[],"tail":", 272, 279.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46e819af-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46e819b0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail