{"tag":"section","attrib":{"id":"id474c5977-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7405"},"text":null,"children":[{"tag":"num","attrib":{"value":"7405"},"text":"§ 7405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action for recovery of erroneous refunds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id474c5978-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refunds after limitation period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any portion of a tax imposed by this title, refund of which is erroneously made, within the meaning of section 6514, may be recovered by civil action brought in the name of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id474c5979-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refunds otherwise erroneous","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any portion of a tax imposed by this title which has been erroneously refunded (if such refund would not be considered as erroneous under section 6514) may be recovered by civil action brought in the name of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id474c597a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7405/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provision relating to interest on erroneous refunds, see section 6602.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id474c597b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7405/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periods of limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For periods of limitations on actions under this section, see section 6532(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id474c597c-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/874"},"text":"68A Stat. 874","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
