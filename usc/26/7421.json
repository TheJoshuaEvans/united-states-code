{"tag":"section","attrib":{"id":"id474c59c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7421"},"text":null,"children":[{"tag":"num","attrib":{"value":"7421"},"text":"§ 7421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of suits to restrain assessment or collection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id474c59c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7421/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in sections 6015(e), 6212(a) and (c), 6213(a), 6232(c), 6330(e)(1), 6331(i), 6672(c), 6694(c), 7426(a) and (b)(1), 7429(b), and 7436, no suit for the purpose of restraining the assessment or collection of any tax shall be maintained in any court by any person, whether or not such person is the person against whom such tax was assessed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id474c59c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7421/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of transferee or fiduciary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No suit shall be maintained in any court for the purpose of restraining the assessment or collection (pursuant to the provisions of chapter 71) of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id474c59c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7421/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the liability, at law or in equity, of a transferee of property of a taxpayer in respect of any internal revenue tax, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474c59c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7421/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the liability of a fiduciary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3713/b"},"text":"section 3713(b) of title 31","children":[],"tail":", United States Code, in respect of any such tax."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id474c59c5-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/876"},"text":"68A Stat. 876","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/719/tI/s110/c"},"text":"Pub. L. 89–719, title I, § 110(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1144"},"text":"80 Stat. 1144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXII/s1204/c/11"},"text":"Pub. L. 94–455, title XII, § 1204(c)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1699"},"text":"90 Stat. 1699","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/628/s9/b/1"},"text":"Pub. L. 95–628, § 9(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3633"},"text":"92 Stat. 3633","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s3/f/13"},"text":"Pub. L. 97–258, § 3(f)(13)","children":[],"tail":", "},{"ta