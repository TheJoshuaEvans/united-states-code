. 105–277","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" applicable to any liability for tax arising after "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", and any liability for tax arising on or before such date but remaining unpaid as of such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3201/g/1"},"text":"section 3201(g)(1) of Pub. L. 105–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6015"},"text":"section 6015 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id474c59cc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1222/b/1"},"text":"section 1222(b)(1) of Pub. L. 105–34","children":[],"tail":" applicable to partnership taxable years beginning after "},{"tag":"date","attrib":{"date":"1997-12-31"},"text":"Dec. 31, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1226"},"text":"section 1226 of Pub. L. 105–34","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6011"},"text":"section 6011 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1239/e/3"},"text":"section 1239(e)(3) of Pub. L. 105–34","children":[],"tail":" applicable to partnership taxable years ending after "},{"tag":"date","attrib":{"d