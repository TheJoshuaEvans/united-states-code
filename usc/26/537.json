{"tag":"section","attrib":{"id":"id43ce083a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s537"},"text":null,"children":[{"tag":"num","attrib":{"value":"537"},"text":"§ 537.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable needs of the business","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43ce083b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s537/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, the term “reasonable needs of the business” includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43ce083c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s537/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasonably anticipated needs of the business,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43ce083d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s537/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the section 303 redemption needs of the business, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43ce083e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s537/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the excess business holdings redemption needs of the business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43ce083f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s537/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43ce0840-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s537/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 303 redemption needs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “section 303 redemption needs” means, with respect to the taxable year of the corporation in which a shareholder of the corporation died or any taxable year thereafter, the amount needed (or reasonably anticipated to be needed) to make a redemption of stock included in the gross estate of the decedent (but not in excess of the maximum amount of stock to which section 303(a) may apply).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43ce0841-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s537/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess business holdings redemption needs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “excess business holdings redemption needs” means the amount needed (or reasonably anticipated to be needed) to redeem from a private foundation stock which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43ce0842-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s537/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such foundation held on ","children":[{"tag":"date","attrib":{"date":"1969-05-26"},"text":"May 26, 1969","children":[],"tail":" (or which was received by such foundation pursuant to a will or irrevocable trust to which section 4943(c)(5) applies), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43ce0843-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s537/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constituted excess business holdings on ","children":[{"tag":"date","attrib":{"date":"1969-05-26"},"text":"May 26, 1969","children":[],"tail":", or would have constituted excess business holdings as of such date if there were taken into account (i) stock received pursuant to a will or trust described in subparagraph (A), and (ii) the reduction in the total outstanding stock of the corporation which would have resulted solely from the redemption of stock held by the private foundation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43ce0844-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s537/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligations incurred to make redemptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying paragraphs (1) and (2), the discharge of any obligation incurred to make a redemption described in such paragraphs shall be treated as the making of such redemption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43ce0845-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s537/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Product liability loss reserves","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The accumulation of reasonable amounts for the payment of reasonably anticipated product liability losses (as defined in section 172(f) (as in effect before the date of enactment of the Tax Cuts and Jobs Act)), as determined under regulations prescribed by the Secretary, shall be treated as accumulated for the reasonably anticipated needs of the business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43ce0846-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s537/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No inference as to prior taxable years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The application of this part to any taxable year before the first taxable year specified in paragraph (1) shall be made without regard to the fact that distributions in redemption coming within the terms of such paragraphs were subsequently made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43ce0847-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/182"},"text":"68A Stat. 182","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIX/s906/a"},"text":"Pub. L. 91–172, title IX, § 906(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/714"},"text":"83 Stat. 714","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1901/a/75"},"text":"Pub. L. 94–455, title XIX, § 1901(a)(75)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1777"},"text":"90 Stat. 1777","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tIII/s371/c"},"text":"Pub. L. 95–600, title III, § 371(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2859"},"text":"92 Stat. 2859","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1704/t/33"},"text":"Pub. L. 104–188, title I, § 1704(t)(33)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1889"},"text":"110 Stat. 1889","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13302/c/2/B"},"text":"Pub. L. 115–97, title I, § 13302(c)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2123"},"text":"131 Stat. 2123","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43ce0848-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43ce0849-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id43ce084a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 172(f), referred to in subsec. (b)(4), was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13302/c/2/A"},"text":"Pub. L. 115–97, title I, § 13302(c)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2122"},"text":"131 Stat. 2122","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of the Tax Cuts and Jobs Act, referred to in subsec. (b)(4), probably means the date of enactment of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":". Prior versions of the bill that was enacted into law as "},{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" included such Short Title, but it was not enacted as part of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43ce084b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" inserted “(as in effect before the date of enactment of the Tax Cuts and Jobs Act)” after “as defined in section 172(f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" substituted “section 172(f)” for “section 172(i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" added par. (4) and redesignated former par. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/a/75/A"},"text":"Pub. L. 94–455, § 1901(a)(75)(A)","children":[],"tail":", struck out “with respect to taxable years of the corporation ending after "},{"tag":"date","attrib":{"date":"1969-05-26"},"text":"May 26, 1969","children":[],"tail":"” after “ ‘redemption needs’ means”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/a/75/B"},"text":"Pub. L. 94–455, § 1901(a)(75)(B)","children":[],"tail":", struck out “or (2)” after “paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" designated existing provisions as subsec. (a)(1) and added subsecs. (a)(2), (3) and (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43ce084c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43ce084d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" applicable to net operating losses arising in taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13302/e"},"text":"section 13302(e) of Pub. L. 115–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s172"},"text":"section 172 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4