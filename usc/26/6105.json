{"tag":"section","attrib":{"id":"id46a56ae2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6105"},"text":null,"children":[{"tag":"num","attrib":{"value":"6105"},"text":"§ 6105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of information arising under treaty obligations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46a56ae3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Tax convention information shall not be disclosed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46a56ae4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46a56ae5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the disclosure of tax convention information to persons or authorities (including courts and administrative bodies) which are entitled to such disclosure pursuant to a tax convention,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46a56ae6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any generally applicable procedural rules regarding applications for relief under a tax convention,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46a56ae7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6105/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the disclosure of tax convention information on the same terms as return information may be disclosed under paragraph (3)(C) or (7) of section 6103(i), except that in the case of tax convention information provided by a foreign government, no disclosure may be made under this paragraph without the written consent of the foreign government, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46a56ae8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6105/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any case not described in paragraph (1), (2), or (3), to the disclosure of any tax convention information not relating to a particular taxpayer if the Secretary determines, after consultation with each other party to the tax convention, that such disclosure would not impair tax administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46a56ae9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46a56aea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax convention information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “tax convention information” means any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46a56aeb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6105/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agreement entered into with the competent authority of one or more foreign governments pursuant to a tax convention,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46a56aec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6105/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" application for relief under a tax convention,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46a56aed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6105/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" background information related to such agreement or application,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46a56aee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6105/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" document implementing such agreement, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46a56aef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6105/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other information exchanged pursuant to a tax convention which is treated as confidential or secret under the tax convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46a56af0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax convention","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “tax convention” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46a56af1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6105/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any income tax or gift and estate tax convention, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46a56af2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6105/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other convention or bilateral agreement (including multilateral conventions and agreements and any agreement with a possession of the United States) providing for the avoidance of double taxation, the prevention of fiscal evasion, nondiscrimination with respect to taxes, the exchange of tax relevant information with the United States, or mutual assistance in tax matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46a56af3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For penalties for the unauthorized disclosure of tax convention information which is return or return information, see sections 7213, 7213A, and 7431.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46a56af4-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s304/b/1"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 304(b)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–633; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/134/tII/s201/c/9"},"text":"Pub. L. 107–134, title II, § 201(c)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2444"},"text":"115 Stat. 2444","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/147/tIV/s417/18"},"text":"Pub. L. 107–147, title IV, § 417(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-09"},"text":"Mar. 9, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/56"},"text":"116 Stat. 56","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46a56af5-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46a56af6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46a56af7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6105, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/755"},"text":"68A Stat. 755","children":[],"tail":", authorized the Secretary or his delegate to compile, beginning after "},{"tag":"date","attrib":{"note":"1941-06-31"},"text":"June 31, 1941","children":[],"tail":", all cases in which relief from excess profits tax has been allowed, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/a/7"},"text":"Pub. L. 94–455, title XIX, § 1906(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1824"},"text":"90 Stat. 1824","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46a56af8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/134/s201/c/9/A"},"text":"Pub. L. 107–134, § 201(c)(9)(A)","children":[],"tail":", struck out “or” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/134/s201/c/9/D"},"text":"Pub. L. 107–134, § 201(c)(9)(D)","children":[],"tail":", added par. (3). Former par. (3) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/134/s201/c/9/B"},"text":"Pub. L. 107–134, § 201(c)(9)(B)","children":[],"tail":", substituted “paragraph (1), (2), or (3)” for “paragraphs (1) or (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/134/s201/c/9/C"},"text":"Pub. L. 107–134, § 201(c)(9)(C)","children":[],"tail":", redesignated par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147"},"text":"Pub. L. 107–147","children":[],"tail":" struck out “any” after subpar. designation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46a56af9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46a56afa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/134"},"text":"Pub. L. 107–134","children":[],"tail":" applicable to disclosures made on or after "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/134/s201/d"},"text":"section 201(d) of Pub. L. 107–134","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6103"},"text":"section 6103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
