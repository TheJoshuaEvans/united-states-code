{"tag":"section","attrib":{"id":"id44d6c534-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273"},"text":null,"children":[{"tag":"num","attrib":{"value":"1273"},"text":"§ 1273.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount of original issue discount","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44d6c535-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subpart—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d6c536-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “original issue discount” means the excess (if any) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d6c537-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the stated redemption price at maturity, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d6c538-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issue price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d6c539-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stated redemption price at maturity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “stated redemption price at maturity” means the amount fixed by the last modification of the purchase agreement and includes interest and other amounts payable at that time (other than any interest based on a fixed rate, and payable unconditionally at fixed periodic intervals of 1 year or less during the entire term of the debt instrument).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d6c53a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ¼ of 1 percent de minimis rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the original issue discount determined under paragraph (1) is less than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d6c53b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ¼ of 1 percent of the stated redemption price at maturity, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d6c53c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of complete years to maturity,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then the original issue discount shall be treated as zero.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d6c53d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issue price","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subpart—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d6c53e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publicly offered debt instruments not issued for property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any issue of debt instruments—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d6c53f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publicly offered, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d6c540-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not issued for property,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the issue price is the initial offering price to the public (excluding bond houses and brokers) at which price a substantial amount of such debt instruments was sold.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d6c541-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other debt instruments not issued for property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any issue of debt instruments not issued for property and not publicly offered, the issue price of each such instrument is the price paid by the first buyer of such debt instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d6c542-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debt instruments issued for property where there is public trading","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a debt instrument which is issued for property and which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d6c543-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is part of an issue a portion of which is traded on an established securities market, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d6c544-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44d6c545-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is issued for stock or securities which are traded on an established securities market, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d6c546-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent provided in regulations, is issued for property (other than stock or securities) of a kind regularly traded on an established market,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the issue price of such debt instrument shall be the fair market value of such property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d6c547-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other cases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except in any case—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d6c548-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which paragraph (1), (2), or (3) of this subsection applies, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d93649-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which section 1274 applies,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the issue price of a debt instrument which is issued for property shall be the stated redemption price at maturity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d9364a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying this subsection, the term “property” includes services and the right to use property, but such term does not include money.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d9364b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for applying subsection (b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d9364c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial offering price; price paid by the first buyer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “initial offering price” and “price paid by the first buyer” include the aggregate payments made by the purchaser under the purchase agreement, including modifications thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d9364d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of investment units","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any debt instrument and an option, security, or other property issued together as an investment unit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d9364e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issue price for such unit shall be determined in accordance with the rules of this subsection and subsection (b) as if it were a debt instrument,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d9364f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issue price determined for such unit shall be allocated to each element of such unit on the basis of the relationship of the fair market value of such element to the fair market value of all elements in such unit, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d93650-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1273/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issue price of any debt instrument included in such unit shall be the portion of the issue price of the unit allocated to the debt instrument under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44d93651-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s41/a"},"text":"Pub. L. 98–369, div. A, title I, § 41(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/536"},"text":"98 Stat. 536","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1803/a/10"},"text":"Pub. L. 99–514, title XVIII, § 1803(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2794"},"text":"100 Stat. 2794","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44d93652-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44d93653-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44d93654-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" amended subpar. (B) generally, designating existing provisions as cl. (i) and adding cl. (ii)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44d93655-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44d93656-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44d93657-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years ending after ","children":[{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s44"},"text":"section 44 of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1271"},"text":"section 1271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id44d93658-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1800–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
