d the subsequent amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/110/172"},"text":"Pub. L. 110–172","children":[],"tail":". See 2007 Amendment note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11125/b/5/A"},"text":"Pub. L. 109–59, § 11125(b)(5)(A)","children":[],"tail":", transferred "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5114"},"text":"section 5114 of this title","children":[],"tail":" to this subpart so as to appear after subpart analysis."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11125/b/5/B/ii"},"text":"Pub. L. 109–59, § 11125(b)(5)(B)(ii)","children":[],"tail":", added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11125/b/5/C"},"text":"Pub. L. 109–59, § 11125(b)(5)(C)","children":[],"tail":", substituted “section 5123” for “section 5146”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 1905(c)(1), 1906(b)(13)(A), struck out “or Territory” after “a State”, “Territories” after “States,”, and “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46295d52-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"ta