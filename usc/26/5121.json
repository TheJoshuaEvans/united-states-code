{"tag":"section","attrib":{"id":"id4626ec3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5121"},"text":null,"children":[{"tag":"num","attrib":{"value":"5121"},"text":"§ 5121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping by wholesale dealers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4626ec40-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4626ec41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5121/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distilled spirits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every wholesale dealer in liquors who sells distilled spirits to other dealers shall keep daily a record of distilled spirits received and disposed of by him, in such form and at such place and containing such information, and shall submit correct summaries of such records to the Secretary at such time and in such form and manner, as the Secretary shall by regulations prescribe. Such dealer shall also submit correct extracts from or copies of such records, at such time and in such form and manner as the Secretary may by regulations prescribe; however, the Secretary may on application by such dealer, in accordance with such regulations, relieve him from this requirement until further notice, whenever the Secretary deems that the submission of such extracts or copies serves no useful purpose in law enforcement or in protection of the revenue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4626ec42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5121/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wines and beer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every wholesale dealer in liquors and every wholesale dealer in beer shall provide and keep, at such place as the Secretary shall by regulations prescribe, a record in book form of all wines and beer received, showing the quantities thereof and from whom and the dates received, or shall keep all invoices of, and bills for, all wines and beer received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4626ec43-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption of States, political subdivisions, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provision of subsection (a) shall not apply to a State, to a political subdivision of a State, to the District of Columbia, or to liquor stores operated by any of them, if they maintain and make available for inspection by internal revenue officers such records as will enable such officers to trace all distilled spirits, wines, and beer received, and all distilled spirits disposed of by them. Such States, subdivisions, District, or liquor stores shall, upon the request of the Secretary, furnish him such transcripts, summaries and copies of their records with respect to distilled spirits as he shall require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4626ec44-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5121/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wholesale dealers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4626ec45-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5121/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wholesale dealer in liquors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wholesale dealer in liquors” means any dealer (other than a wholesale dealer in beer) who sells, or offers for sale, distilled spirits, wines, or beer, to another dealer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4626ec46-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5121/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wholesale dealer in beer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wholesale dealer in beer” means any dealer who sells, or offers for sale, beer, but not distilled spirits or wines, to another dealer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4626ec47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5121/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dealer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “dealer” means any person who sells, or offers for sale, any distilled spirits, wines, or beer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4626ec48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5121/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumption in case of sale of 20 wine gallons or more","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sale, or offer for sale, of distilled spirits, wines, or beer, in quantities of 20 wine gallons or more to the same person at the same time, shall be presumptive evidence that the person making such sale, or offer for sale, is engaged in or carrying on the business of a wholesale dealer in liquors or a wholesale dealer in beer, as the case may be. Such presumption may be overcome by evidence satisfactorily showing that such sale, or offer for sale, was made to a person other than a dealer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4626ec49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5121/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4626ec4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5121/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions requiring proprietors of distilled spirits plants to keep records and submit reports of receipts and dispositions of distilled spirits, see section 5207.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4626ec4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5121/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For penalty for violation of subsection (a), see section 5603.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4626ec4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5121/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions relating to the preservation and inspection of records, and entry of premises for inspection, see section 5123.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4626ec4d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1342"},"text":"72 Stat. 1342","children":[],"tail":", § 5114; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1905(c)(1), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1823"},"text":"90 Stat. 1823","children":[],"tail":", 1834; renumbered § 5121 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11125/b/5"},"text":"Pub. L. 109–59, title XI, § 11125(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1954"},"text":"119 Stat. 1954","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/172/s11/a/31"},"text":"Pub. L. 110–172, § 11(a)(31)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-29"},"text":"Dec. 29, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2487"},"text":"121 Stat. 2487","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4626ec4e-