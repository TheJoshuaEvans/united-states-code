7","children":[],"tail":", of any stripped tax-exempt obligation or stripped coupon from such an obligation."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If—","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"“(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person held any obligation or coupon in stripped form on ","children":[{"tag":"date","attrib":{"date":"1987-06-10"},"text":"June 10, 1987","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"“(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such obligation or coupon was held by such person on such date for sale in the ordinary course of such person’s trade or business,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the amendment made by subparagraph (A) shall not apply to any sale of such obligation or coupon by such person and shall not apply to any such obligation or coupon while held by another person who purchased such obligation or coupon from the person referred to in subclause (I).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44e03ae1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1803/a/13/B"},"text":"section 1803(a)(13)(B) of Pub. L. 99–514","children":[],"tail":" applicable to obligations acquired after "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","chil