31"},"text":"Dec. 31, 1975","children":[],"tail":", and to taxable years of United States shareholders within which or with which such taxable years of such corporations end, see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1021/c"},"text":"section 1021(c) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s956"},"text":"section 956 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id448a7ad4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1964 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/554"},"text":"Pub. L. 88–554","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1964-08-31"},"text":"Aug. 31, 1964","children":[],"tail":", except that for purposes of sections 302 and 304 of this title, such amendments shall not apply to distributions in payment for stock acquisitions or redemptions, if such acquisitions or redemptions occurred before "},{"tag":"date","attrib":{"date":"1964-08-31"},"text":"Aug. 31, 1964","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/88/554/s4/c"},"text":"section 4(c) of Pub. L. 88–554","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s318"},"text":"section 318 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id448a7ad5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" not to be construed to create any inference with respect to the proper application of any provision of this title with respect to taxable years beginning before the taxable years to which such amendment applies, see "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70353/f"},"text":"section 70353(f) of Pub. L. 119–21","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s951B"},"text":"section 951B of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
