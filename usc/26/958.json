{"tag":"section","attrib":{"id":"id448a7abf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s958"},"text":null,"children":[{"tag":"num","attrib":{"value":"958"},"text":"§ 958.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules for determining stock ownership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id448a7ac0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s958/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct and indirect ownership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id448a7ac1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s958/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subpart (other than section 960), stock owned means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id448a7ac2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s958/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stock owned directly, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id448a7ac3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s958/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stock owned with the application of paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id448a7ac4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s958/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stock ownership through foreign entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (B) of paragraph (1), stock owned, directly or indirectly, by or for a foreign corporation, foreign partnership, or foreign trust or foreign estate (within the meaning of section 7701(a)(31)) shall be considered as being owned proportionately by its shareholders, partners, or beneficiaries. Stock considered to be owned by a person by reason of the application of the preceding sentence shall, for purposes of applying such sentence, be treated as actually owned by such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id448a7ac5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s958/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for mutual insurance companies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of applying paragraph (1) in the case of a foreign mutual insurance company, the term “stock” shall include any certificate entitling the holder to voting power in the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id448a7ac6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s958/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Constructive ownership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of sections 951(b), 954(d)(3), 956(c)(2), and 957, section 318(a) (relating to constructive ownership of stock) shall apply to the extent that the effect is to treat any United States person as a United States shareholder within the meaning of section 951(b), to treat a person as a related person within the meaning of section 954(d)(3), to treat the stock of a domestic corporation as owned by a United States shareholder of the controlled foreign corporation for purposes of section 956(c)(2), or to treat a foreign corporation as a controlled foreign corporation under section 957, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id448a7ac7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s958/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In applying paragraph (1)(A) of section 318(a), stock owned by a nonresident alien individual (other than a foreign trust or foreign estate) shall not be considered as owned by a citizen or by a resident alien individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id448a7ac8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s958/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In applying subparagraphs (A), (B), and (C) of section 318(a)(2), if a partnership, estate, trust, or corporation owns, directly or indirectly, more than 50 percent of the total combined voting power of all classes of stock entitled to vote of a corporation, it shall be considered as owning all the stock entitled to vote.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id448a7ac9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s958/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In applying subparagraph (C) of section 318(a)(2), the phrase “10 percent” shall be substituted for the phrase “50 percent” used in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id448a7aca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s958/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subparagraphs (A), (B), and (C) of section 318(a)(3) shall not be applied so as to consider a United States person as owning stock which is owned by a person who is not a United States person.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Paragraphs (1) and (4) shall not apply for purposes of section 956(c)(2) to treat stock of a domestic corporation as not owned by a United States shareholder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id448a7acb-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/834/s12/a"},"text":"Pub. L. 87–834, § 12(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-16"},"text":"Oct. 16, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1018"},"text":"76 Stat. 1018","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/88/554/s4/b/5"},"text":"Pub. L. 88–554, § 4(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-31"},"text":"Aug. 31, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/763"},"text":"78 Stat. 763","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tX/s1021/b"},"text":"Pub. L. 94–455, title X, § 1021(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1619"},"text":"90 Stat. 1619","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI"},"text":"Pub. L. 104–188, title I","children":[],"tail":", §§ 1703(i)(4), 1704(t)(7), "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1876"},"text":"110 Stat. 1876","children":[],"tail":", 1887; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI"},"text":"Pub. L. 115–97, title I","children":[],"tail":", §§ 14213(a), 14301(c)(31), "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2217"},"text":"131 Stat. 2217","children":[],"tail":", 2224; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70353/a"},"text":"Pub. L. 119–21, title VII, § 70353(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/209"},"text":"139 Stat. 209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id448a7acc-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id448a7acd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id448a7ace-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70353/a/2"},"text":"Pub. L. 119–21, § 70353(a)(2)","children":[],"tail":", substituted “Paragraphs (1) and (4)” for “Paragraph (1)” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70353/a/1"},"text":"Pub. L. 119–21, § 70353(a)(1)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s14301/c/31"},"text":"Pub. L. 115–97, § 14301(c)(31)",