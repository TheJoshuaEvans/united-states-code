a United States shareholder” following subpar. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/554"},"text":"Pub. L. 88–554","children":[],"tail":" redesignated pars. (4) and (5) as (3) and (4), respectively, struck out former par. (3) which related to ownership of stock by a partnership, estate, trust, or corporation for purposes of applying first sentence of subpars. (A) and (B), and subpar. (C)(i) of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s318/a/2"},"text":"section 318(a)(2) of this title","children":[],"tail":", and made amendments throughout subsec. (b) to conform to changes made in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s318"},"text":"section 318 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/88/554"},"text":"Pub. L. 88–554","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id448a7acf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id448a7ad0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" applicable to taxable years of foreign corporations beginning after "},{"tag":"date","attrib":{"date":"2025-12-31"},"text":"Dec. 31, 2025","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70353/d"},"text":"section 70353(d) of Pub. L. 119–21","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/