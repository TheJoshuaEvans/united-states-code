{"tag":"section","attrib":{"id":"id462e18a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5206"},"text":null,"children":[{"tag":"num","attrib":{"value":"5206"},"text":"§ 5206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Containers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id462e18a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5206/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to prescribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall by regulations prescribe the types or kinds of containers which may be used to contain, store, transfer, convey, remove, or withdraw distilled spirits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462e18a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5206/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards of fill","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may by regulations prescribe the standards of fill for approved containers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462e18a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5206/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marking, branding, or identification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Containers of distilled spirits (and cases containing bottles or other containers of such spirits) shall be marked, branded, or identified in such manner as the Secretary shall by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462e18a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5206/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effacement of marks and brands on emptied containers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person who empties, or causes to be emptied, any container of distilled spirits bearing any mark or brand required by law (or regulations pursuant thereto) shall at the time of emptying such container efface and obliterate such mark or brand; except that the Secretary may, by regulations, waive any requirement of this subsection where he determines that no jeopardy to the revenue will be involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462e18aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5206/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall be applicable exclusively with respect to containers of distilled spirits for industrial use, with respect to containers of distilled spirits of a capacity of more than one gallon for other than industrial use, and with respect to cases containing bottles or other containers of distilled spirits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462e18ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5206/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id462e18ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5206/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For other provisions relating to regulation of containers of distilled spirits, see section 5301.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id462e18ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5206/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions relating to labeling containers of distilled spirits of one gallon or less for nonindustrial uses, see section 105(e) of the Federal Alcohol Administration Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t27/s205/e"},"text":"27 U.S.C. 205(e)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id462e18ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5206/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions relating to the marking and branding of containers of distilled spirits by proprietors, see section 5204(c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id462e18af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5206/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For penalties and forfeitures relating to marks and brands, see sections 5604 and 5613.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id462e18b0-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","childre