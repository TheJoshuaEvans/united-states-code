{"tag":"section","attrib":{"id":"id463088f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5213"},"text":null,"children":[{"tag":"num","attrib":{"value":"5213"},"text":"§ 5213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal of distilled spirits from bonded premises on determination of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to the provisions of section 5173, distilled spirits may be withdrawn from the bonded premises of a distilled spirits plant on payment or determination of tax thereon, in approved containers, under such regulations as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id463088f8-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1362"},"text":"72 Stat. 1362","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/27"},"text":"Pub. L. 96–39, title VIII, § 807(a)(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/285"},"text":"93 Stat. 285","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id463088f9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"rol