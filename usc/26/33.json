{"tag":"section","attrib":{"id":"id4086cc36-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s33"},"text":null,"children":[{"tag":"num","attrib":{"value":"33"},"text":"§ 33.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax withheld at source on nonresident aliens and foreign corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be allowed as a credit against the tax imposed by this subtitle the amount of tax withheld at source under subchapter A of chapter 3 (relating to withholding of tax on nonresident aliens and on foreign corporations).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4086cc37-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/13"},"text":"68A Stat. 13","children":[],"tail":", § 32; renumbered § 33 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV"},"text":"Pub. L. 98–369, div. A, title IV","children":[],"tail":", §§ 471(c), 474(j), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/826"},"text":"98 Stat. 826","children":[],"tail":", 832.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4086cc38-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4086cc39-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4086cc3a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children