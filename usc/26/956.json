{"tag":"section","attrib":{"id":"id44880966-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956"},"text":null,"children":[{"tag":"num","attrib":{"value":"956"},"text":"§ 956.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of earnings in United States property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44880967-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any controlled foreign corporation, the amount determined under this section with respect to any United States shareholder for any taxable year is the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44880968-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the excess (if any) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44880969-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such shareholder’s pro rata share of the average of the amounts of United States property held (directly or indirectly) by the controlled foreign corporation as of the close of each quarter of such taxable year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4488096a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of earnings and profits described in section 959(c)(1)(A) with respect to such shareholder, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4488096b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such shareholder’s pro rata share of the applicable earnings of such controlled foreign corporation.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The amount taken into account under paragraph (1) with respect to any property shall be its adjusted basis as determined for purposes of computing earnings and profits, reduced by any liability to which the property is subject.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4488096c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4488096d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable earnings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “applicable earnings” means, with respect to any controlled foreign corporation, the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4488096e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount (not including a deficit) referred to in section 316(a)(1) to the extent such amount was accumulated in prior taxable years, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4488096f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount referred to in section 316(a)(2),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but reduced by distributions made during the taxable year and by earnings and profits described in section 959(c)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44880970-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for U.S. property acquired before corporation is a controlled foreign corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying subsection (a) to any taxable year, there shall be disregarded any item of United States property which was acquired by the controlled foreign corporation before the first day on which such corporation was treated as a controlled foreign corporation. The aggregate amount of property disregarded under the preceding sentence shall not exceed the portion of the applicable earnings of such controlled foreign corporation which were accumulated during periods before such first day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44880971-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule where corporation ceases to be controlled foreign corporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any foreign corporation ceases to be a controlled foreign corporation during any taxable year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44880972-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination of any United States shareholder’s pro rata share shall be made on the basis of stock owned (within the meaning of section 958(a)) by such shareholder on the last day during the taxable year on which the foreign corporation is a controlled foreign corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44880973-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average referred to in subsection (a)(1)(A) for such taxable year shall be determined by only taking into account quarters ending on or before such last day, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44880974-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in determining applicable earnings, the amount taken into account by reason of being described in paragraph (2) of section 316(a) shall be the portion of the amount so described which is allocable (on a pro rata basis) to the part of such year during which the corporation is a controlled foreign corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44880975-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States property defined","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44880976-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the term “United States property” means any property acquired after ","children":[{"tag":"date","attrib":{"date":"1962-12-31"},"text":"December 31, 1962","children":[],"tail":", which is—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44880977-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tangible property located in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44880978-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stock of a domestic corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44880979-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an obligation of a United States person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4488097a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any right to the use in the United States of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4488097b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a patent or copyright,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4488097c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an invention, model, or design (whether or not patented),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4488097d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a secret formula or process, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4488097e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other similar right,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"which is acquired or developed by the controlled foreign corporation for use in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4488097f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the term “United States property” does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44880980-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" obligations of the United States, money, or deposits with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44880981-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any bank (as defined by section 2(c) of the Bank Holding Company Act of 1956 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841/c"},"text":"12 U.S.C. 1841(c)","children":[],"tail":"), without regard to subparagraphs (C) and (G) of paragraph (2) of such section), or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44880982-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any corporation not described in clause (i) with respect to which a bank holding company (as defined by section 2(a) of such Act) or financial holding company (as defined by section 2(p) of such Act) owns directly or indirectly more than 80 percent by vote or value of the stock of such corporation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44880983-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property located in the United States which is purchased in the United States for export to, or use in, foreign countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44880984-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any obligation of a United States person arising in connection with the sale or processing of property if the amount of such obligation outstanding at no time during the taxable year exceeds the amount which would be ordinary and necessary to carry on the trade or business of both the other party to the sale or processing transaction and the United States person had the sale or processing transaction been made between unrelated persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44880985-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any aircraft, railroad rolling stock, vessel, motor vehicle, or container used in the transportation of persons or property in foreign commerce and used predominantly outside the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44880986-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount of assets of an insurance company equivalent to the unearned premiums or reserves ordinary and necessary for the proper conduct of its insurance business attributable to contracts which are contracts described in section 953(e)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44880987-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the stock or obligations of a domestic corporation which is neither a United States shareholder (as defined in section 951(b)) of the controlled foreign corporation, nor a domestic corporation, 25 percent or more of the total combined voting power of which, immediately after the acquisition of any stock in such domestic corporation by the controlled foreign corporation, is owned, or is considered as being owned, by such United States shareholders in the aggregate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44880988-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any movable property (other than a vessel or aircraft) which is used for the purpose of exploring for, developing, removing, or transporting resources from ocean waters or under such waters when used on the Continental Shelf of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44880989-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount of assets of the controlled foreign corporation equal to the earnings and profits accumulated after ","children":[{"tag":"date","attrib":{"date":"1962-12-31"},"text":"December 31, 1962","children":[],"tail":", and excluded from subpart F income under section 952(b);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4488098a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposits of cash or securities made or received on commercial terms in the ordinary course of a United States or foreign person’s business as a dealer in securities or in commodities, but only to the extent such deposits are made or received as collateral or margin for (i) a securities loan, notional principal contract, options contract, forward contract, or futures contract, or (ii) any other financial transaction in which the Secretary determines that it is customary to post collateral or margin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4488098b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an obligation of a United States person to the extent the principal amount of the obligation does not exceed the fair market value of readily marketable securities sold or purchased pursuant to a sale and repurchase agreement or otherwise posted or received as collateral for the obligation in the ordinary course of its business by a United States or foreign person which is a dealer in securities or commodities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4488098c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" securities acquired and held by a controlled foreign corporation in the ordinary course of its business as a dealer in securities if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4488098d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/K/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dealer accounts for the securities as securities held primarily for sale to customers in the ordinary course of business, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4488098e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/K/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dealer disposes of the securities (or such securities mature while held by the dealer) within a period consistent with the holding of securities for sale to customers in the ordinary course of business; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4488098f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an obligation of a United States person which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44880990-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/L/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a domestic corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44880991-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/L/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is not—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id44880992-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/L/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States shareholder (as defined in section 951(b)) of the controlled foreign corporation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44880993-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/2/L/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership, estate, or trust in which the controlled foreign corporation, or any related person (as defined in section 954(d)(3)), is a partner, beneficiary, or trustee immediately after the acquisition of any obligation of such partnership, estate, or trust by the controlled foreign corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of subparagraphs (I), (J), and (K), the term “dealer in securities” has the meaning given such term by section 475(c)(1), and the term “dealer in commodities” has the meaning given such term by section 475(e), except that such term shall include a futures commission merchant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id448a7a94-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain trade or service receivables acquired from related United States persons","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id448a7a95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (2) (other than subparagraph (H) thereof), the term “United States property” includes any trade or service receivable if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id448a7a96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such trade or service receivable is acquired (directly or indirectly) from a related person who is a United States person, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id448a7a97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the obligor under such receivable is a United States person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id448a7a98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the term “trade or service receivable” and “related person” have the respective meanings given to such terms by section 864(d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id448a7a99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pledges and guarantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), a controlled foreign corporation shall, under regulations prescribed by the Secretary, be considered as holding an obligation of a United States person if such controlled foreign corporation is a pledgor or guarantor of such obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id448a7a9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s956/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to carry out the purposes of this section, including regulations to prevent the avoidance of the provisions of this section through reorganizations or otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id448a7a9b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/834/s12/a"},"text":"Pub. L. 87–834, § 12(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-16"},"text":"Oct. 16, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1015"},"text":"76 Stat. 1015","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tX/s1021/a"},"text":"Pub. L. 94–455, title X, § 1021(a)","children":[],"tail":", title XIX, § 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1618"},"text":"90 Stat. 1618","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s123/b"},"text":"Pub. L. 98–369, div. A, title I, § 123(b)","children":[],"tail":", title VIII, § 801(d)(8), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/646"},"text":"98 Stat. 646","children":[],"tail":", 996; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1810/c/1"},"text":"Pub. L. 99–514, title XVIII, § 1810(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2824"},"text":"100 Stat. 2824","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13232/a"},"text":"Pub. L. 103–66, title XIII, § 13232(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/501"},"text":"107 Stat. 501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1501/b/2"},"text":"Pub. L. 104–188, title I, § 1501(b)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1825"},"text":"110 Stat. 1825","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXI/s1173/a"},"text":"Pub. L. 105–34, title XI, § 1173(a)","children":[],"tail":", title XVI, § 1601(e), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/988"},"text":"111 Stat. 988","children":[],"tail":", 1090; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIV/s407/a"},"text":"Pub. L. 108–357, title IV, § 407(a)","children":[],"tail":", (b), title VIII, § 837(a), "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1498"},"text":"118 Stat. 1498","children":[],"tail":", 1499, 1596; "},{"tag":"ref","attrib":{"href":"/us/pl/110/172/s11/g/15/A"},"text":"Pub. L. 110–172, § 11(g)(15)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-29"},"text":"Dec. 29, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2490"},"text":"121 Stat. 2490","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/162"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(162)","children":[],"tail":", (163), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1192"},"text":"132 Stat. 1192","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id448a7a9c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id448a7a9d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id448a7a9e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/162"},"text":"Pub. L. 115–141, § 401(a)(162)","children":[],"tail":", substituted “which are contracts described in section 953(e)(2)” for “which are not contracts described in section 953(a)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/163"},"text":"Pub. L. 115–141, § 401(a)(163)","children":[],"tail":", substituted “provisions” for “provisons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172/s11/g/15/A/ii"},"text":"Pub. L. 110–172, § 11(g)(15)(A)(ii)","children":[],"tail":", substituted “subparagraphs (I), (J), and (K)” for “subparagraphs (J), (K), and (L)” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(I) to (M). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172/s11/g/15/A/i"},"text":"Pub. L. 110–172, § 11(g)(15)(A)(i)","children":[],"tail":", redesignated subpars. (J) to (M) as (I) to (L), respectively, and struck out former subpar. (I) which read as follows: “to the extent provided in regulations prescribed by the Secretary, property which is otherwise United States property which is held by a FSC and which is related to the export activities of such FSC;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s407/b"},"text":"Pub. L. 108–357, § 407(b)","children":[],"tail":", substituted “, (K), and (L)” for “and (K)” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s837/a"},"text":"Pub. L. 108–357, § 837(a)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “obligations of the United States, money, or deposits with persons carrying on the banking business;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(L), (M). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s407/a"},"text":"Pub. L. 108–357, § 407(a)","children":[],"tail":", added subpars. (L) and (M)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1601/e"},"text":"Pub. L. 105–34, § 1601(e)","children":[],"tail":", inserted “to the extent such amount was accumulated in prior taxable years” after “section 316(a)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1173/a"},"text":"Pub. L. 105–34, § 1173(a)","children":[],"tail":", added subpars. (J) and (K) and concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1501/b/2"},"text":"Pub. L. 104–188, § 1501(b)(2)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “For purposes of this section, the term ‘applicable earnings’ has the meaning given to such term by section 956A(b), except that the provisions of such section excluding earnings and profits accumulated in taxable years beginning before "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"October 1, 1993","children":[],"tail":", shall be disregarded.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1501/b/3"},"text":"Pub. L. 104–188, § 1501(b)(3)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “Rules similar to the rules of section 956A(e) shall apply for purposes of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13232/a/2"},"text":"Pub. L. 103–66, § 13232(a)(2)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which consisted of introductory provisions and pars. (1) to (3) setting out general rules for calculating amount of earnings of a controlled foreign corporation invested in United States and pro rata share of the increase for any taxable year in earnings of such a corporation invested in United States property."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13232/a"},"text":"Pub. L. 103–66, § 13232(a)","children":[],"tail":", added subsec. (b) and redesignated former subsecs. (b) and (c) as (c) and (d), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13232/b"},"text":"Pub. L. 103–66, § 13232(b)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" inserted “(other than subparagraph (H) thereof)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(2)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s801/d/8"},"text":"Pub. L. 98–369, § 801(d)(8)","children":[],"tail":", added subpar. (I)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s123/b"},"text":"Pub. L. 98–369, § 123(b)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b)(2)(F) to (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1021/a"},"text":"Pub. L. 94–455, § 1021(a)","children":[],"tail":", added subpars. (F) and (G) and redesignated former subpar. (F) as (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id448a7a9f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id448a7aa0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIV/s407/c"},"text":"Pub. L. 108–357, title IV, § 407(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1499"},"text":"118 Stat. 1499","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tIV/s407/c"},"text":"“The amendments made by this section [amending this section] shall apply to taxable years of foreign corporations beginning after ","children":[{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":", and to taxable ye