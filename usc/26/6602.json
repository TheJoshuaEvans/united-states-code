{"tag":"section","attrib":{"id":"id4710b028-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6602"},"text":null,"children":[{"tag":"num","attrib":{"value":"6602"},"text":"§ 6602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest on erroneous refund recoverable by suit","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any portion of an internal revenue tax (or any interest, assessable penalty, additional amount, or addition to tax) which has been erroneously refunded, and which is recoverable by suit pursuant to section 7405, shall bear interest at the underpayment rate established under section 6621 from the date of the payment of the refund.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4710b029-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/818"},"text":"68A Stat. 818","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/625/s7/a/2/B"},"text":"Pub. L. 93–625, § 7(a)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2115"},"text":"88 Stat. 2115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1511/c/12"},"text":"Pub. L. 99–514, title XV, § 1511(c)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2745"},"text":"100 Stat. 2745","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4710b02a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4710b02b-3a70-11f1-a967-d35dac11796a"}