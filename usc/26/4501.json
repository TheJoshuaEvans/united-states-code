{"tag":"section","attrib":{"id":"id45daa16e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501"},"text":null,"children":[{"tag":"num","attrib":{"value":"4501"},"text":"§ 4501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repurchase of corporate stock","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45daa16f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on each covered corporation a tax equal to 1 percent of the fair market value of any stock of the corporation which is repurchased by such corporation during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45daa170-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “covered corporation” means any domestic corporation the stock of which is traded on an established securities market (within the meaning of section 7704(b)(1)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45daa171-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repurchase","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45daa172-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “repurchase” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45daa173-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a redemption within the meaning of section 317(b) with regard to the stock of a covered corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45daa174-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any transaction determined by the Secretary to be economically similar to a transaction described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45daa175-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of purchases by specified affiliates","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45daa176-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The acquisition of stock of a covered corporation by a specified affiliate of such covered corporation, from a person who is not the covered corporation or a specified affiliate of such covered corporation, shall be treated as a repurchase of the stock of the covered corporation by such covered corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45daa177-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified affiliate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “specified affiliate” means, with respect to any corporation—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45daa178-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any corporation more than 50 percent of the stock of which is owned (by vote or by value), directly or indirectly, by such corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45daa179-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any partnership more than 50 percent of the capital interests or profits interests of which is held, directly or indirectly, by such corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45daa17a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount taken into account under subsection (a) with respect to any stock repurchased by a covered corporation shall be reduced by the fair market value of any stock issued by the covered corporation during the taxable year, including the fair market value of any stock issued or provided to employees of such covered corporation or employees of a specified affiliate of such covered corporation during the taxable year, whether or not such stock is issued or provided in response to the exercise of an option to purchase such stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45daa17b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for acquisition of stock of certain foreign corporations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45daa17c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an acquisition of stock of an applicable foreign corporation by a specified affiliate of such corporation (other than a foreign corporation or a foreign partnership (unless such partnership has a domestic entity as a direct or indirect partner)) from a person who is not the applicable foreign corporation or a specified affiliate of such applicable foreign corporation, for purposes of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45daa17d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such specified affiliate shall be treated as a covered corporation with respect to such acquisition,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45daa17e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such acquisition shall be treated as a repurchase of stock of a covered corporation by such covered corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45daa17f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjustment under subsection (c)(3) shall be determined only with respect to stock issued or provided by such specified affiliate to employees of the specified affiliate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45daa180-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surrogate foreign corporations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a repurchase of stock of a covered surrogate foreign corporation by such covered surrogate foreign corporation, or an acquisition of stock of a covered surrogate foreign corporation by a specified affiliate of such corporation, for purposes of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45daa181-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expatriated entity with respect to such covered surrogate foreign corporation shall be treated as a covered corporation with respect to such repurchase or acquisition,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45daa182-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such repurchase or acquisition shall be treated as a repurchase of stock of a covered corporation by such covered corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45daa183-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjustment under subsection (c)(3) shall be determined only with respect to stock issued or provided by such expatriated entity to employees of the expatriated entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45daa184-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45daa185-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable foreign corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “applicable foreign corporation” means any foreign corporation the stock of which is traded on an established securities market (within the meaning of section 7704(b)(1)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45daa186-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered surrogate foreign corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered surrogate foreign corporation” means any surrogate foreign corporation (as determined under section 7874(a)(2)(B) by substituting “","children":[{"tag":"date","attrib":{"date":"2021-09-20"},"text":"September 20, 2021","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2003-03-04"},"text":"March 4, 2003","children":[],"tail":"” each place it appears) the stock of which is traded on an established securities market (within the meaning of section 7704(b)(1)), but only with respect to taxable years which include any portion of the applicable period with respect to such corporation under section 7874(d)(1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45daa187-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expatriated entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “expatriated entity” has the meaning given such term by section 7874(a)(2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45daa188-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45daa189-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that the repurchase is part of a reorganization (within the meaning of section 368(a)) and no gain or loss is recognized on such repurchase by the shareholder under chapter 1 by reason of such reorganization,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45daa18a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any case in which the stock repurchased is, or an amount of stock equal to the value of the stock repurchased is, contributed to an employer-sponsored retirement plan, employee stock ownership plan, or similar plan,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45daa18b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any case in which the total value of the stock repurchased during the taxable year does not exceed $1,000,000,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45daa18c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under regulations prescribed by the Secretary, in cases in which the repurchase is by a dealer in securities in the ordinary course of business,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45daa18d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to repurchases by a regulated investment company (as defined in section 851) or a real estate investment trust, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45daa18e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that the repurchase is treated as a dividend for purposes of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45daa18f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe such regulations and other guidance as are necessary or appropriate to carry out, and to prevent the avoidance of, the purposes of this section, including regulations and other guidance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45daa190-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent the abuse of the exceptions provided by subsection (e),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45daa191-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address special classes of stock and preferred stock, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45daa192-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4501/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the application of the rules under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45daa193-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s10201/a"},"text":"Pub. L. 117–169, title I, § 10201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1829"},"text":"136 Stat. 1829","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45daa194-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45daa195-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id45daa196-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 4501 to 4503 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11801/a/48"},"text":"Pub. L. 101–508, title XI, § 11801(a)(48)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-522"},"text":"104 Stat. 1388–522","children":[],"tail":". For provisions that nothing in repeal by "},{