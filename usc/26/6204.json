{"tag":"section","attrib":{"id":"id46b60cd9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6204"},"text":null,"children":[{"tag":"num","attrib":{"value":"6204"},"text":"§ 6204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental assessments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46b60cda-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, at any time within the period prescribed for assessment, make a supplemental assessment whenever it is ascertained that any assessment is imperfect or incomplete in any material respect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46b60cdb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For restrictions on assessment of deficiencies in income, estate, gift, and certain excise taxes, see section 6213.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46b60cdc-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/768"},"text":"68A Stat. 768","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/406/tII/s1016/a/27"},"text":"Pub. L. 93–406, title II, § 1016(a)(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-