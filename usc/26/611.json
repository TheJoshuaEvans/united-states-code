{"tag":"section","attrib":{"id":"id43ded12b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s611"},"text":null,"children":[{"tag":"num","attrib":{"value":"611"},"text":"§ 611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of deduction for depletion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43ded12c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of mines, oil and gas wells, other natural deposits, and timber, there shall be allowed as a deduction in computing taxable income a reasonable allowance for depletion and for depreciation of improvements, according to the peculiar conditions in each case; such reasonable allowance in all cases to be made under regulations prescribed by the Secretary. For purposes of this part, the term “mines” includes deposits of waste or residue, the extraction of ores or minerals from which is treated as mining under section 613(c). In any case in which it is ascertained as a result of operations or of development work that the recoverable units are greater or less than the prior estimate thereof, then such prior estimate (but not the basis for depletion) shall be revised and the allowance under this section for subsequent taxable years shall be based on such revised estimate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43ded12d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43ded12e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s611/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a lease, the deduction under this section shall be equitably apportioned between the lessor and lessee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43ded12f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s611/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Life tenant and remainderman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of property held by one person for life with remainder to another person, the deduction under this section shall be computed as if the life tenant were the absolute owner of the property and shall be allowed to the life tenant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43ded130-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s611/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property held in trust","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of property held in trust, the deduction under this section shall be apportioned between the income beneficiaries and the trustee in accordance with the pertinent provisions of the instrument creating the trust, or, in the absence of such provisions, on the basis of the trust income allocable to each.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43ded131-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s611/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property held by estate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an estate, the deduction under this section shall be apportioned between the estate and the heirs, legatees, and devisees on the basis of the income of the estate allocable to each.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43ded132-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s611/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For other rules applicable to depreciation of improvements, see section 167.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43ded133-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/207"},"text":"68A Stat. 207","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s35"},"text":"Pub. L. 85–866, title I, § 35","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1632"},"text":"72 Stat. 1632","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43ded134-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43ded135-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43ded136-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866"},"text":"Pub. L. 85–866","children":[],"tail":" substituted “devisees” for “devises”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43ded137-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43ded138-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866"},"text":"Pub. L. 85–866","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1953-12-31"},"text":"Dec. 31, 1953","children":[],"tail":", and ending after "},{"tag":"date","attrib":{"date":"1954-08-16"},"text":"Aug. 16, 1954","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/866/s1/c/1"},"text":"section 1(c)(1) of Pub. L. 85–866","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s165"},"text":"section 165 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
