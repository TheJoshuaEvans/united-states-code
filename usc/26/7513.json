{"tag":"section","attrib":{"id":"id476d9d5f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7513"},"text":null,"children":[{"tag":"num","attrib":{"value":"7513"},"text":"§ 7513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reproduction of returns and other documents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id476d9d60-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to have any Federal agency or any person process films or other photoimpressions of any return, document, or other matter, and make reproductions from films or photoimpressions of any return, document, or other matter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id476d9d61-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe regulations which shall provide such safeguards as in the opinion of the Secretary are necessary or appropriate to protect the film, photoimpressions, and reproductions made therefrom, against any unauthorized use, and to protect the information contained therein against any unauthorized disclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id476d9d62-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7513/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For penalty for violation of regulations for safeguarding against unauthorized use of any film or photoimpression, or reproduction made therefrom, and against unauthorized disclosure of information contained therein, see section 7213.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id476d9d63-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s90/a"},"text":"Pub. L. 85–866, title I, § 90(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1666"},"text":"72 Stat. 1666","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXII/s1202/f"},"text":"Pub. L. 94–455, title XII, § 1202(f)","children":[],"tail":", title XIX, § 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1687"},"text":"90 Stat. 1687","children":[],"tail":", 1834.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id476d9d64-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id476d9d65-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id476d9d66-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b"},"text":"Pub. L. 94–455, § 1906(b)","children":[],"tail":" (13)(A), struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1202/f"},"text":"Pub. L. 94–455, § 1202(f)","children":[],"tail":", redesignated subsec. (d) as (c) and struck out former subsec. (c) which related to legal status and evidentiary use of reproductions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id476d9d67-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id476d9d68-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1954-08-17"},"text":"Aug. 17, 1954","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/866/s1/c"},"text":"section 1(c) of Pub. L. 85–866","children":[],"tail":", set out as an Effective Date of 1958 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s165"},"text":"section 165 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
