{"tag":"section","attrib":{"id":"id462e186e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5201"},"text":null,"children":[{"tag":"num","attrib":{"value":"5201"},"text":"§ 5201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation of operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id462e186f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Proprietors of distilled spirits plants shall conduct all operations authorized to be conducted on the premises of such plants under such regulations as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462e1870-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distilled spirits for industrial uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations of the Secretary under this chapter respecting the production, warehousing, denaturing, distribution, sale, export, and use of distilled spirits for industrial purposes shall be such as he deems necessary, advisable, or proper to secure the revenue, to prevent diversion to illegal uses, and to place the distilled spirits industry and other industries using such distilled spirits as a chemical raw material or for other lawful industrial purposes on the highest possible plane of scientific and commercial efficiency and development consistent with the provisions of this chapter. Where nonpotable chemical mixtures containing distilled spirits are produced for transfer to the bonded premises of a distilled spirits plant for completion of processing, the Secretary may waive any provision of this chapter with respect to the production of such mixtures, and the processing of such mixtures on the bonded premises shall be deemed to be production of distilled spirits for purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462e1871-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5201/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hours of operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prescribe regulations relating to hours for distillery operations and to hours for removal of distilled spirits from distilled spirits plants; however, such regulations shall not be more restrictive, as to any operation or function, that the provisions of internal revenue law and regulations relating to such operation or function in effect on the day preceding the effective date of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462e1872-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5201/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of distilled spirits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide by regulations for the addition of tracer elements to distilled spirits to facilitate the enforcement of this chapter. Tracer elements to be added to distilled spirits at any distilled spirits plant under provisions of this subsection shall be of such character and in such quantity as the Secretary may authorize or require, and such as will not impair the quality of the distilled spirits for their intended use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id462e1873-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1357"},"text":"72 Stat. 1357","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/21"},"text":"Pub. L. 96–39, title VIII, § 807(a)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/283"},"text":"93 Stat. 283","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id462e1874-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id462e1875-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id462e1876-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising subsecs. (a) to (c) of this section were contained in prior