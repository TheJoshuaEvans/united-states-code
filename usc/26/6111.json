{"tag":"section","attrib":{"id":"id46aa25ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6111"},"text":null,"children":[{"tag":"num","attrib":{"value":"6111"},"text":"§ 6111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of reportable transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46aa25cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each material advisor with respect to any reportable transaction shall make a return (in such form as the Secretary may prescribe) setting forth—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46aa25cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information identifying and describing the transaction,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46aa25cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information describing any potential tax benefits expected to result from the transaction, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46aa25ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6111/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such return shall be filed not later than the date specified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46aa25cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46aa25d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Material advisor","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46aa25d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6111/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “material advisor” means any person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46aa25d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6111/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who provides any material aid, assistance, or advice with respect to organizing, managing, promoting, selling, implementing, insuring, or carrying out any reportable transaction, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46aa25d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6111/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who directly or indirectly derives gross income in excess of the threshold amount (or such other amount as may be prescribed by the Secretary) for such aid, assistance, or advice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46aa25d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6111/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Threshold amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the threshold amount is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46aa25d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6111/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000 in the case of a reportable transaction substantially all of the tax benefits from which are provided to natural persons, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46aa25d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6111/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250,000 in any other case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46aa25d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reportable transaction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “reportable transaction” has the meaning given to such term by section 6707A(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46aa25d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may prescribe regulations which provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46aa25d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6111/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that only 1 person shall be required to meet the requirements of subsection (a) in cases in which 2 or more persons would otherwise be required to meet such requirements,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46aa25da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6111/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exemptions from the requirements of this section, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46aa25db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6111/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such rules as may be necessary or appropriate to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46aa25dc-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s141/a"},"text":"Pub. L. 98–369, div. A, title I, § 141(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/677"},"text":"98 Stat. 677","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tII/s201/d/13"},"text":"Pub. L. 99–514, title II, § 201(d)(13)","children":[],"tail":", title XV, § 1531(a), title XVIII, § 1899A(54), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2142"},"text":"100 Stat. 2142","children":[],"tail":", 2749, 2961; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1028/a"},"text":"Pub. L. 105–34, title X, § 1028(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/926"},"text":"111 Stat. 926","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s815/a"},"text":"Pub. L. 108–357, title VIII, § 815(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1581"},"text":"118 Stat. 1581","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s412/zz"},"text":"Pub. L. 109–135, title IV, § 412(zz)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2641"},"text":"119 Stat. 2641","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46aa25dd-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46aa25de-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46aa25df-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6111 was renumbered 6116 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46aa25e0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" substituted “aid, assistance, or advice” for “advice or assistance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" amended section catchline and text generally, substituting provisions relating to disclosure of reportable transactions for provisions relating to registration of tax shelters and inclusion of identification numbers on returns."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" added subsec. (d) and redesignated former subsecs. (d) and (e) as (e) and (f), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1531/a"},"text":"Pub. L. 99–514, § 1531(a)","children":[],"tail":", substituted “350 percent” for “200 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s201/d/13"},"text":"Pub. L. 99–514, § 201(d)(13)","children":[],"tail":", substituted “section 465(b)(3)(C)” for “section 168(e)(4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1899A/54"},"text":"Pub. L. 99–514, § 1899A(54)","children":[],"tail":", substituted “subparagraph” for “subpargraph”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46ac96e1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46ac96e2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s815/c"},"text":"Pub. L. 108–357, title VIII, § 815(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1583"},"text":"118 Stat. 1583","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tVIII/s815/c"},"text":"“The amendments made by this section [amending this section and sections 6112 and 6708 of this title] shall apply to transactions with respect to which material aid, assistance, or advice referred to in section 6111(b)(1)(A)(i) of the Internal Revenue Code of 1986 (as added by this section) is provided after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46ac96e3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1028/e"},"text":"Pub. L. 105–34, title X, § 1028(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/928"},"text":"111 Stat. 928","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tX/s1028/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the amendments made by this section [amending this section and sections 6662 and 6707 of this title] shall apply to any tax shelter (as defined in section 6111(d) of the Internal Revenue Code of 1986, as amended by this section) interests in which are offered to potential participants after the Secretary of the Treasury prescribes guidance with respect to meeting requirements added by such amendments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modifications to substantial understatement penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsection (c) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6662"},"text":"section 6662 of this title","children":[],"tail":"] shall apply to items with respect to transactions entered into after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46ac96e4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s201/d/13"},"text":"section 201(d)(13) of Pub. L. 99–514","children":[],"tail":" applicable to property placed in service after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", in taxable years ending after such date, with exceptions, see sections 203 and 204 of "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s168"},"text":"section 168 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s201/d/13"},"text":"section 201(d)(13) of Pub. L. 99–514","children":[],"tail":" not applicable to any property placed in service before "},{"tag":"date","attrib":{"date":"1994-01-01"},"text":"Jan. 1, 1994","children":[],"tail":", if such property placed in service as part of specified rehabilitations, and not applicable to certain additional rehabilitations, see section 251(d)(2), (3) of "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s46"},"text":"section 46 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1531/b"},"text":"Pub. L. 99–514, title XV, § 1531(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2749"},"text":"100 Stat. 2749","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXV/s1531/b"},"text":"“The amendment made by this section [amending this section] shall apply to any tax shelter (within the meaning of section 6111 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] as amended by this section) interests in which are first offered for sale after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46ac96e5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s141/d"},"text":"Pub. L. 98–369, div. A, title I, § 141(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/680"},"text":"98 Stat. 680","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6707"},"text":"section 6707 of this title","children":[],"tail":" and renumbering former section 6111 as "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6112"},"text":"section 6112 of this title","children":[],"tail":"] shall apply to any tax shelter (within the meaning of section 6111 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954], as added by this section) any interest in which is first sold to any investor after "},{"tag":"date","attrib":{"date":"1984-08-31"},"text":"August 31, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Substantial investment test","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of determining whether any investment is a tax shelter by reason of section 6111(c)(1)(B)(iii) of such Code (as added by this section), only offers for sale after ","children":[{"tag":"date","attrib":{"date":"1984-08-31"},"text":"August 31, 1984","children":[],"tail":", shall be taken into account."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Furnishing of shelter identification number for interests sold before ","children":[{"tag":"date","attrib":{"date":"1984-09-01"},"text":"september 1, 1984","children":[],"tail":null}],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to interests sold before ","children":[{"tag":"date","attrib":{"date":"1984-09-01"},"text":"September 1, 1984","children":[],"tail":", any liability to act under paragraph (1) of section 6111(b) of such Code (as added by this section) which would (but for this sentence) arise before such date shall be deemed to arise on "},{"tag":"date","attrib":{"date":"1984-12-31"},"text":"December 31, 1984","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
