{"tag":"section","attrib":{"id":"id45d12ad1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4263"},"text":null,"children":[{"tag":"num","attrib":{"value":"4263"},"text":"§ 4263.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45d12ad2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4263/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments made outside the United States for prepaid orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the payment upon which tax is imposed by section 4261 is made outside the United States for a prepaid order, exchange order, or similar order, the person furnishing the initial transportation pursuant to such order shall collect the amount of the tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d12ad3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4263/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax deducted upon refunds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person who refunds any amount with respect to a ticket or order which was purchased without payment of the tax imposed by section 4261 shall deduct from the amount refundable, to the extent available, any tax due under such section as a result of the use of a portion of the transportation purchased in connection with such ticket or order, and shall report to the Secretary the amount of any such tax remaining uncollected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d12ad4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4263/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where any tax imposed by section 4261 is not paid at the time payment for transportation is made, then, under regulations prescribed by the Secretary, to the extent that such tax is not collected under any other provision of this subchapter, such tax shall be paid by the carrier providing the initial segment of such transportation which begins or ends in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d12ad5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4263/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by section 4261 shall apply to any amount paid within the United States for transportation of any person by air unless the taxpayer establishes, pursuant to regulations prescribed by the Secretary, at the time of payment for the transportation, that the transportation is not transportation in respect of which tax is imposed by section 4261.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d12ad6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4263/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Round trips","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying this subchapter to a round trip, such round trip shall be considered to consist of transportation from the point of departure to the destination, and of separate transportation thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d12ad7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4263/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation outside the northern portion of the Western Hemisphere","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying this subchapter to transportation any part of which is outside the northern portion of the Western Hemisphere, if the route of such transportation leaves and reenters the northern portion of the Western Hemisphere, such transportation shall be considered to consist of transportation to a point outside such northern portion, and of separate transportation thereafter. For purposes of this subsection, the term “northern portion of the Western Hemisphere” means the area lying west of the 30th meridian west of Greenwich, east of the international dateline, and north of the Equator, but not including any country of South America.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d12ad8-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-07-25/ch725/s4/a"},"text":"July 25, 1956, ch. 725, § 4(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/645"},"text":"70 Stat. 645","children":[],"tail":", § 4264; amended "},{"tag":"ref","attrib":{"href":"/us/pl/87/508/s5/b"},"text":"Pub. L. 87–508, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-06-28"},"text":"June 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/117"},"text":"76 Stat. 117","children":[],"tail":"; renumbered § 4263, "},{"tag":"ref","attrib":{"href":"/us/pl/91/258/tII/s205/c/2"},"text":"Pub. L. 91–258, title II, § 205(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-05-21"},"text":"May 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/242"},"text":"84 Stat. 242","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1031/c/3"},"text":"Pub. L. 105–34, title X, § 1031(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/932"},"text":"111 Stat. 932","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45d12ad9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45d12ada-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id45d12adb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4263, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/506"},"text":"68A Stat. 506","children":[],"tail":", § 4263, formerly § 4262; renumbered § 4263 and amended "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-25/ch725/s2"},"text":"July 25, 1956, ch. 725, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/644"},"text":"70 Stat. 644","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-07/ch1024/s1"},"text":"Aug. 7, 1956, ch. 1024, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1077"},"text":"70 Stat. 1077","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1957-06-29"},"text":"June 29, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/74"},"text":"Pub. L. 85–74","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/243"},"text":"71 Stat. 243","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tI/s134"},"text":"Pub. L. 85–859, title I, § 134","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1292"},"text":"72 Stat. 1292","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1962-06-28"},"text":"June 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/508/s5/b"},"text":"Pub. L. 87–508, § 5(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/117"},"text":"76 Stat. 117","children":[],"tail":", provided for exemptions, subsecs. (a) to (d) relating to commutation travel, etc., certain organizations; members of the Armed Forces, and small aircraft on nonestablished lines, respectively, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/91/258/tII/s205/c/1"},"text":"Pub. L. 91–258, title II, § 205(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-05-21"},"text":"May 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/242"},"text":"84 Stat. 242","children":[],"tail":", effective on "},{"tag":"date","attrib":{"date":"1970-07-01"},"text":"July 1, 1970","children":[],"tail":", as provided in "},{"tag":"ref","attrib":{"href":"/us/pl/91/258/s211/a"},"text":"section 211(a) of Pub. L. 91–258","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4041"},"text":"section 4041 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45d12adc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" substituted “subchapter, such tax shall be paid by the carrier providing the initial segment of such transportation which begins or ends in the United States.” for “subchapter—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) such tax shall be paid by the person paying for the transportation or by the person using the transportation;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) such tax shall be paid within such time as the Secretary shall prescribe by regulations after whichever of the following first occurs:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the rights to the transportation expire; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the time when the transportation becomes subject to tax; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) payment of such tax shall be made to the Secretary, to the person to whom the payment for transportation was made, or, in the case of transportation other than transportation described in section 4262(a)(1), to any person furnishing any portion of such transportation.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/508"},"text":"Pub. L. 87–508","children":[],"tail":" provided for payment of tax, in the case of transportation other than transportation described in section 4262(a)(1), to any person furnishing any portion of the transportation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/508"},"text":"Pub. L. 87–508","children":[],"tail":" inserted “by air” after “transportation of any person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/508"},"text":"Pub. L. 87–508","children":[],"tail":" substituted “subchapter” for “part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/508"},"text":"Pub. L. 87–508","children":[],"tail":" substituted “subchapter” for “part”, struck out par. (1) designation for provision respecting transportation outside the northern portion of the Western Hemisphere and par. (2) prohibiting consideration as a stop at a port within the United States a stop at an intermediate port at which vessel is not authorized to discharge and take on passengers."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45d12add-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45d12ade-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" applicable to transportation beginning on or after "},{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", with special rule for applicability to amounts paid before "},{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1031/e/2"},"text":"section 1031(e)(2) of Pub. L. 105–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4261"},"text":"section 4261 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45d12adf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1962 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/508/s5/b"},"text":"Pub. L. 87–508, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-06-28"},"text":"June 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/115"},"text":"76 Stat. 115","children":[],"tail":", provided that the amendment made by that section is effective with respect to transportation beginning after "},{"tag":"date","attrib":{"date":"1962-11-15"},"text":"Nov. 15, 1962","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45d12ae0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to amounts paid on or after first day of first month which begins more than sixty days after ","children":[{"tag":"date","attrib":{"date":"1956-07-25"},"text":"July 25, 1956","children":[],"tail":", for transportation commencing on or after such first day, see section 6 of act "},{"tag":"date","attrib":{"date":"1956-07-25"},"text":"July 25, 1956","children":[],"tail":", set out as an Effective Date of 1956 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4261"},"text":"section 4261 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
