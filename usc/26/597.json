{"tag":"section","attrib":{"id":"id43ded104-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s597"},"text":null,"children":[{"tag":"num","attrib":{"value":"597"},"text":"§ 597.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of transactions in which Federal financial assistance provided","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43ded105-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s597/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The treatment for purposes of this chapter of any transaction in which Federal financial assistance is provided with respect to a bank or domestic building and loan association shall be determined under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43ded106-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s597/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principles used in prescribing regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43ded107-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s597/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of taxable asset acquisitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any acquisition of assets to which section 381(a) does not apply, the regulations prescribed under subsection (a) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43ded108-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s597/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that Federal financial assistance shall be properly taken into account by the institution from which the assets were acquired, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43ded109-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s597/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the proper method of allocating basis among the assets so acquired (including rights to receive Federal financial assistance).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43ded10a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s597/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any transaction not described in paragraph (1), the regulations prescribed under subsection (a) shall provide for the proper treatment of Federal financial assistance and appropriate adjustments to basis or other tax attributes in connection with such assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43ded10b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s597/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of double benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No regulations prescribed under this section shall permit the utilization of any deduction (or other tax benefit) if such amount was in effect reimbursed by nontaxable Federal financial assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43ded10c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s597/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal financial assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “Federal financial assistance” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43ded10d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s597/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any money or other property provided with respect to a domestic building and loan association by the Federal Savings and Loan Insurance Corporation or the Resolution Trust Corporation pursuant to section 406(f) of the National Housing Act (or under any other similar provision of law), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43ded10e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s597/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any money or other property provided with respect to a bank or domestic building and loan association by the Federal Deposit Insurance Corporation pursuant to section 11(f) or 13(c) of the Federal Deposit Insurance Act (or under any other similar provision of law),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"regardless of whether any note or other instrument is issued in exchange therefor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43ded10f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s597/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic building and loan association","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “domestic building and loan association” has the meaning given such term by section 7701(a)(19) without regard to subparagraph (C) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43ded110-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/tII/s244/a"},"text":"Pub. L. 97–34, title II, § 244(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/255"},"text":"95 Stat. 255","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tIX/s904/b/1"},"text":"Pub. L. 99–514, title IX, § 904(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2385"},"text":"100 Stat. 2385","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tIV/s4012/b/2/A"},"text":"Pub. L. 100–647, title IV, § 4012(b)(2)(A)","children":[],"tail":"–(D)(i), (c)(1), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3657"},"text":"102 Stat. 3657","children":[],"tail":", 3658; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXIV/s1401/a/3/A"},"text":"Pub. L. 101–73, title XIV, § 1401(a)(3)(A)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/548"},"text":"103 Stat. 548","children":[],"tail":", 549; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7841/e/1"},"text":"Pub. L. 101–239, title VII, § 7841(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2429"},"text":"103 Stat. 2429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11704/a/7"},"text":"Pub. L. 101–508, title XI, § 11704(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-518"},"text":"104 Stat. 1388–518","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/b/25"},"text":"Pub. L. 115–141, div. U, title IV, § 401(b)(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1203"},"text":"132 Stat. 1203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43ded111-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43ded112-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id43ded113-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 406 of the National Housing Act, referred to in subsec. (c)(1), which was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1729"},"text":"section 1729 of Title 12","children":[],"tail":", Banks and Banking, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIV/s407"},"text":"Pub. L. 101–73, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/363"},"text":"103 Stat. 363","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 11(f) and 13(c) of the Federal Deposit Insurance Act, referred to in subsec. (c)(2), are classified to sections 1821(f) and 1823(c), respectively, of Title 12.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43ded114-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" struck out “or section 21A of the Federal Home Loan Bank Act” after “National Housing Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted “For purposes of” for “The purposes of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s1401/b/1"},"text":"Pub. L. 101–73, § 1401(b)(1)","children":[],"tail":", repealed amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s904/b/1"},"text":"Pub. L. 99–514, § 904(b)(1)","children":[],"tail":", see 1986 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s1401/a/3/A"},"text":"Pub. L. 101–73, § 1401(a)(3)(A)","children":[],"tail":", amended section generally, substituting present provisions for former provisions which contained section catchline that read “FSLIC or FDIC financial assistance” and which provided: in subsec. (a) for an exclusion from gross income; in subsec. (b) for no reduction in basis of assets; in subsec. (c) for a reduction of tax attributes by 50 percent of amounts excludable under subsection (a); and in subsec. (d) for a definition of “domestic building and loan association”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" substituted “in connection with such assistance” for “to reflect such treatment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s4012/b/2/D/i"},"text":"Pub. L. 100–647, § 4012(b)(2)(D)(i)","children":[],"tail":", substituted “FSLIC or FDIC” for “FSLIC” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s4012/b/2/A"},"text":"Pub. L. 100–647, § 4012(b)(2)(A)","children":[],"tail":", inserted at end “Gross income of a bank does not include any amount of money or other property received from the Federal Deposit Insurance Corporation pursuant to sections 13(c), 15(c)(1), and 15(c)(2) of the Federal Deposit Insurance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1821/f"},"text":"12 U.S.C. 1821(f)","children":[],"tail":" and 1823(c)(1) and (c)(2)), regardless of whether any note or other instrument is issued in exchange therefor.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s4012/b/2/C"},"text":"Pub. L. 100–647, § 4012(b)(2)(C)","children":[],"tail":", substituted “association or bank” for “association”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s4012/c/1"},"text":"Pub. L. 100–647, § 4012(c)(1)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s4012/b/2/B"},"text":"Pub. L. 100–647, § 4012(b)(2)(B)","children":[],"tail":", which directed amendment of section 597(b), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s4012/c/1"},"text":"section 4012(c)(1) of Pub. L. 100–647","children":[],"tail":", by adding at the end thereof subsec. (d), was executed by adding subsec. (d) at the end of section 597, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s4012/c/1"},"text":"section 4012(c)(1) of Pub. L. 100–647","children":[],"tail":", as the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s904/b/1"},"text":"Pub. L. 99–514, § 904(b)(1)","children":[],"tail":", (c)(2)(A), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tIV/s4012/a/2"},"text":"Pub. L. 100–647, title IV, § 4012(a)(2)","children":[],"tail":", which (applicable to transfers after "},{"tag":"date","attrib":{"date":"1989-12-31"},"text":"Dec. 31, 1989","children":[],"tail":", in taxable years ending after such date, with exceptions) directed repeal of this section, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/s1401/b/1"},"text":"Pub. L. 101–73, § 1401(b)(1)","children":[],"tail":", (c)(4), eff. "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", and I.R.C. of 1986 applicable as if the amendments made by such section had not been enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43ded115-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43ded116-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7841/e/2"},"text":"Pub. L. 101–239, title VII, § 7841(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2429"},"text":"103 Stat. 2429","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tVII/s7841/e/2"},"text":"“The amendment made by this subsection [amending this section] shall apply as if included in the amendments made by section 1401 of the Financial Institutions Reform, Recovery, and Enforcement Act of 1989 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXIV/s1401/c/3"},"text":"Pub. L. 101–73, title XIV, § 1401(c)(3)","children":[],"tail":"–(5), "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/550"},"text":"103 Stat. 550","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/73/tXIV/s1401/c/3"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsection","children":[],"tail":" (a)(3).—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsection (a)(3) [amending this section and repealing provisions set out below] shall apply to any amount received or accrued by the financial institution on or after ","children":[{"tag":"date","attrib":{"date":"1989-05-10"},"text":"May 10, 1989","children":[],"tail":", except that such amendments shall not apply to transfers on or after such date pursuant to an acquisition to which the amendment made by subsection (a)(1) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s368"},"text":"section 368 of this title","children":[],"tail":"] does not apply."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interim rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of any payment pursuant to a transaction on or after ","children":[{"tag":"date","attrib":{"date":"1989-05-10"},"text":"May 10, 1989","children":[],"tail":", and before the date on which the Secretary of the Treasury (or his delegate) takes action in exercise of his regulatory authority under section 597 of the Internal Revenue Code of 1986 (as amended by subsection (a)(3)), the taxpayer may rely on the legislative history for the amendments made by subsection (a)(3) in determining the proper treatment of such payment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsection","children":[],"tail":" (b)(1).—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of subsection (b)(1) [set out below] shall take effect on the date of the enactment of the Tax Reform Act of 1986 [","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsection","children":[],"tail":" (b)(2).—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by subsection (b)(2) [amending provisions set out below] shall take effect on the date of the enactment of the Technical and Miscellaneous Revenue Act of 1988 [","children":[{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43ded117-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tIV/s4012/b/2/E"},"text":"Pub. L. 100–647, title IV, § 4012(b)(2)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3658"},"text":"102 Stat. 3658","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tIV/s4012/b/2/E"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendments made by this paragraph [amending this section] shall apply to any transfer—","children":[],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":"], and before "},{"tag":"date","attrib":{"date":"1990-01-01"},"text":"January 1, 1990","children":[],"tail":", unless such transfer is pursuant to an acquisition occurring on or before such date of enactment, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after ","children":[{"tag":"date","attrib":{"date":"1989-12-31"},"text":"December 31, 1989","children":[],"tail":", if such transfer is pursuant to an acquisition occurring after such date of enactment and before "},{"tag":"date","attrib":{"date":"1990-01-01"},"text":"January 1, 1990","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tIV/s4012/c/3"},"text":"Pub. L. 100–647, title IV, § 4012(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3660"},"text":"102 Stat. 3660","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXIV/s1401/b/2"},"text":"Pub. L. 101–73, title XIV, § 1401(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/549"},"text":"103 Stat. 549","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/73/tXIV/s1401/b/2"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":""},"text":null,"children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“The amendments made by this subsection [amending this section and provisions set out below] shall apply to any transfer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{}