{"tag":"section","attrib":{"id":"id42936534-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s272"},"text":null,"children":[{"tag":"num","attrib":{"value":"272"},"text":"§ 272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of coal or domestic iron ore","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where the disposal of coal or iron ore is covered by section 631, no deduction shall be allowed for expenditures attributable to the making and administering of the contract under which such disposition occurs and to the preservation of the economic interest retained under such contract, except that if in any taxable year such expenditures plus the adjusted depletion basis of the coal or iron ore disposed of in such taxable year exceed the amount realized under such contract, such excess, to the extent not availed of as a reduction of gain under section 1231, shall be a loss deductible under section 165(a). This section shall not apply to any taxable year during which there is no income under the contract.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id42936535-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/82"},"text":"68A Stat. 82","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s227/a/3"},"text":"Pub. L. 88–272, title II, § 227(a)(3)","children":[],"tail":", (b)(3), "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/98"},"text":"78 Stat. 98","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id42936536-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id42936537-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id42936538-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1964—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272"},"text":"Pub. L. 88–272","children":[],"tail":" inserted “or domestic iron ore” in section catchline, and “or iron ore” wherever appearing in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id42936539-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4293653a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1964 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s227/c"},"text":"Pub. L. 88–272, title II, § 227(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/98"},"text":"78 Stat. 98","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/88/272/tII/s227/c"},"text":"“The amendments made by this section [amending this section and sections 631, 1016, 1231, and 1402 and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s411"},"text":"section 411 of Title 42","children":[],"tail":", The Public Health and Welfare] shall apply with respect to amounts received or accrued in taxable years beginning after "},{"tag":"date","attrib":{"date":"1963-12-31"},"text":"December 31, 1963","children":[],"tail":", attributable to iron ore mined in such taxable years.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
