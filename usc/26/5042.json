{"tag":"section","attrib":{"id":"id461fe7a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5042"},"text":null,"children":[{"tag":"num","attrib":{"value":"5042"},"text":"§ 5042.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id461fe7a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5042/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax-free production","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id461fe7a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5042/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cider","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to regulations prescribed by the Secretary, the noneffervescent product of the normal alcoholic fermentation of apple juice only, which is produced at a place other than a bonded wine cellar and without the use of preservative methods or materials, and which is sold or offered for sale as cider and not as wine or as a substitute for wine, shall not be subject to tax as wine nor to the provisions of subchapter F.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461fe7a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5042/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wine for personal or family use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to regulations prescribed by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id461fe7a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5042/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any adult may, without payment of tax, produce wine for personal or family use and not for sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id461fe7a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5042/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The aggregate amount of wine exempt from tax under this paragraph with respect to any household shall not exceed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id461fe7a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5042/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 200 gallons per calendar year if there are 2 or more adults in such household, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id461fe7a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5042/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 gallons per calendar year if there is only 1 adult in such household.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id461fe7a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5042/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adults","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the term “adult” means an individual who has attained 18 years of age, or the minimum age (if any) established by law applicable in the locality in which the household is situated at which wine may be sold to individuals, whichever is greater.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461fe7a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5042/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Experimental wine","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to regulations prescribed by the Secretary, any scientific university, college of learning, or institution of scientific research may produce, receive, blend, treat, and store wine, without payment of tax, for experimental or research use but not for consumption (other than organoleptical tests) or sale, and may receive such wine spirits without payment of tax as may be necessary for such production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id461fe7aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5042/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id461fe7ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5042/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions relating to exemption of tax on losses of wine (including losses by theft or authorized destruction), see section 5370.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461fe7ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5042/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions exempting from tax samples of wine, see section 5372.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461fe7ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5042/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For provisions authorizing withdrawals of wine free of tax or without payment of tax, see section 5362.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id461fe7ae-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1331"},"text":"72 Stat. 1331","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/458/s2/a"},"text":"Pub. L. 95–458, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-14"},"text":"Oct. 14, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1255"},"text":"92 Stat. 1255","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id461fe7af-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id461fe7b0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id461fe7b1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5042, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/610"},"text":"68A Stat. 610","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id461fe7b2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/458"},"text":"Pub. L. 95–458","children":[],"tail":" substituted in heading “Wine for personal or family use” for “Family wine” and in text provision permitting an adult to produce 200 gallons of wine per calendar year if there are 2 or more adults in the household or 100 gallons of wine per calendar year if there is one adult in the household for provision which permitted the duly registered head of any family to produce an amount of wine not exceeding 200 gallons of wine per annum."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(1) to (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id461fe7b3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id461fe7b4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/458/s2/c"},"text":"Pub. L. 95–458, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-14"},"text":"Oct. 14, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1257"},"text":"92 Stat. 1257","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/458/s2/c"},"text":"“The amendments made by this section [amending this section and sections 5051, 5053, 5054, 5092, 5222, and 5674 of this title] shall take effect on the first day of the first calendar month which begins more than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1978-10-14"},"text":"Oct. 14, 1978","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
