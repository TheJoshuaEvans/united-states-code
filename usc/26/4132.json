ury or death through the Vaccine Injury Compensation Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deliveries","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of paragraph (1) and section 4131 of the Internal Revenue Code of 1986, in the case of sales on or before the effective date described in such paragraph for which delivery is made after such date, the delivery date shall be considered the sale date.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45be1847-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s408/c"},"text":"Pub. L. 109–432, div. A, title IV, § 408(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2962"},"text":"120 Stat. 2962","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/432/dA/tIV/s408/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sales, etc","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section] shall apply to sales and uses on or after the first day of the first month which begins more than 4 weeks after the date of t