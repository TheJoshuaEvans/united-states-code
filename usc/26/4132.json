{"tag":"section","attrib":{"id":"id45be181d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132"},"text":null,"children":[{"tag":"num","attrib":{"value":"4132"},"text":"§ 4132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45be181e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions relating to taxable vaccines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45be181f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable vaccine","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “taxable vaccine” means any of the following vaccines which are manufactured or produced in the United States or entered into the United States for consumption, use, or warehousing:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45be1820-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vaccine containing diphtheria toxoid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45be1821-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vaccine containing tetanus toxoid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45be1822-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vaccine containing pertussis bacteria, extracted or partial cell bacteria, or specific pertussis antigens.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45be1823-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vaccine against measles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45be1824-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vaccine against mumps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45be1825-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vaccine against rubella.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45be1826-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vaccine containing polio virus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45be1827-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any HIB vaccine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45be1828-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vaccine against hepatitis A.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45be1829-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vaccine against hepatitis B.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45be182a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vaccine against chicken pox.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45be182b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vaccine against rotavirus gastroenteritis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45be182c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any conjugate vaccine against streptococcus pneumoniae.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45be182d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/1/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any trivalent vaccine against influenza or any other vaccine against seasonal influenza.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45be182e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/1/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any meningococcal vaccine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45be182f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/1/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vaccine against the human papillomavirus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45be1830-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vaccine","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “vaccine” means any substance designed to be administered to a human being for the prevention of 1 or more diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45be1831-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” has the meaning given such term by section 4612(a)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45be1832-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “importer” means the person entering the vaccine for consumption, use, or warehousing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45be1833-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit or refund where vaccine returned to manufacturer, etc., or destroyed","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45be1834-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Secretary, whenever any vaccine on which tax was imposed by section 4131 is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45be1835-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" returned (other than for resale) to the person who paid such tax, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45be1836-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" destroyed,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary shall abate such tax or allow a credit, or pay a refund (without interest), to such person equal to the tax paid under section 4131 with respect to such vaccine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45be1837-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claim must be filed within 6 months","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall apply to any returned or destroyed vaccine only with respect to claims filed within 6 months after the date the vaccine is returned or destroyed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45be1838-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition of allowance of credit or refund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No credit or refund shall be allowed or made under paragraph (1) with respect to any vaccine unless the person who paid the tax establishes that he—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45be1839-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has repaid or agreed to repay the amount of the tax to the ultimate purchaser of the vaccine, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45be183a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has obtained the written consent of such purchaser to the allowance of the credit or the making of the refund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45be183b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax imposed only once","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No tax shall be imposed by section 4131 on the sale of any vaccine if tax was imposed by section 4131 on any prior sale of such vaccine and such tax is not abated, credited, or refunded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45be183c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45be183d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain uses treated as sales","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any manufacturer, producer, or importer of a vaccine which uses such vaccine before it is sold shall be liable for the tax imposed by section 4131 in the same manner as if such vaccine were sold by such manufacturer, producer, or importer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45be183e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of vaccines shipped to United States possessions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 4221(a)(2) shall not apply to any vaccine shipped to a possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45be183f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fractional part of a dose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a fraction of a dose, the tax imposed by section 4131 shall be the same fraction of the amount of such tax imposed by a whole dose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45be1840-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4132/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of revenues from Puerto Rico and the Virgin Islands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of subsections (a)(3) and (b)(3) of section 7652 shall not apply to any tax imposed by section 4131.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45be1841-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tIX/s9201/a"},"text":"Pub. L. 100–203, title IX, § 9201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-329"},"text":"101 Stat. 1330–329","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tII/s2006/a"},"text":"Pub. L. 100–647, title II, § 2006(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3612"},"text":"102 Stat. 3612","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tIX/s904/b"},"text":"Pub. L. 105–34, title IX, § 904(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/873"},"text":"111 Stat. 873","children":[],"tail":", 874; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tXV/s1503/a"},"text":"Pub. L. 105–277, div. C, title XV, § 1503(a)","children":[],"tail":", div. J, title III, § 3002(a), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-741"},"text":"112 Stat. 2681–741","children":[],"tail":", 2681–905; "},{"tag":"ref","attrib":{"href":"/us/pl/106/170/tV/s523/a/1"},"text":"Pub. L. 106–170, title V, § 523(a)(1)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1999-12-17"},"text":"Dec. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1927"},"text":"113 Stat. 1927","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII"},"text":"Pub. L. 108–357, title VIII","children":[],"tail":", §§ 889(a), 890(a), "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1643"},"text":"118 Stat. 1643","children":[],"tail":", 1644; "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s408/a"},"text":"Pub. L. 109–432, div. A, title IV, § 408(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2962"},"text":"120 Stat. 2962","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/15/s1/a"},"text":"Pub. L. 113–15, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-06-25"},"text":"June 25, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/476"},"text":"127 Stat. 476","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45be1842-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45be1843-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45be1844-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(1)(N). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/15"},"text":"Pub. L. 113–15","children":[],"tail":" inserted “or any other vaccine against seasonal influenza” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1)(O), (P). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" added subpars. (O) and (P)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(1)(I) to (M). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s889/a"},"text":"Pub. L. 108–357, § 889(a)","children":[],"tail":", added subpar. (I) and redesignated former subpars. (I) to (L) as (J) to (M), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(N). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s890/a"},"text":"Pub. L. 108–357, § 890(a)","children":[],"tail":", added subpar. (N)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(1)(K). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/170/s523/b/1"},"text":"Pub. L. 106–170, § 523(b)(1)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1503/a"},"text":"Pub. L. 105–277, § 1503(a)","children":[],"tail":". See 1998 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(L). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/170/s523/a/1"},"text":"Pub. L. 106–170, § 523(a)(1)","children":[],"tail":", added subpar. (L)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1)(K). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s3002/a"},"text":"Pub. L. 105–277, § 3002(a)","children":[],"tail":", added a subpar. (K) identical to that added by "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1503/a"},"text":"Pub. L. 105–277, § 1503(a)","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1503/a"},"text":"Pub. L. 105–277, § 1503(a)","children":[],"tail":", which directed amendment of section 4132(1) by adding a new subpar. (K) at the end, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/170/s523/b/1"},"text":"Pub. L. 106–170, § 523(b)(1)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s904/b"},"text":"Pub. L. 105–34, § 904(b)","children":[],"tail":", amended heading and text of par. (1) generally. Prior to amendment, text read as follows: “The term ‘taxable vaccine’ means any vaccine—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) which is listed in the table contained in section 4131(b)(1), and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) which is manufactured or produced in the United States or entered into the United States for consumption, use, or warehousing.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s904/c"},"text":"Pub. L. 105–34, § 904(c)","children":[],"tail":", redesignated pars. (6) to (8) as (2) to (4), respectively, and struck out former pars. (2) to (5) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) DPT ","children":[{"tag":"inline","attrib":{},"text":"vaccine","children":[],"tail":".—The term ‘DPT vaccine’ means any vaccine containing pertussis bacteria, extracted or partial cell bacteria, or specific pertussis antigens."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) DT ","children":[{"tag":"inline","attrib":{},"text":"vaccine","children":[],"tail":".—The term ‘DT vaccine’ means any vaccine (other than a DPT vaccine) containing diphtheria toxoid or tetanus toxoid."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) MMR ","children":[{"tag":"inline","attrib":{},"text":"vaccine","children":[],"tail":".—The term ‘MMR vaccine’ means any vaccine against measles, mumps, or rubella. Not more than 1 tax shall be imposed by section 4131 on any MMR vaccine by reason of being a vaccine against more than 1 of measles, mumps, or rubella."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) ","children":[{"tag":"inline","attrib":{},"text":"Polio vaccine","children":[],"tail":".—The term ‘polio vaccine’ means any vaccine containing polio virus.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" added pars. (1) and (2) and redesignated former pars. (1) and (2) as (3) and (4), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45be1845-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","a