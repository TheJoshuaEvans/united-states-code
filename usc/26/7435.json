{"tag":"section","attrib":{"id":"id4755cf5c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7435"},"text":null,"children":[{"tag":"num","attrib":{"value":"7435"},"text":"§ 7435.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil damages for unauthorized enticement of information disclosure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4755cf5d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7435/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any officer or employee of the United States intentionally compromises the determination or collection of any tax due from an attorney, certified public accountant, or enrolled agent representing a taxpayer in exchange for information conveyed by the taxpayer to the attorney, certified public accountant, or enrolled agent for purposes of obtaining advice concerning the taxpayer’s tax liability, such taxpayer may bring a civil action for damages against the United States in a district court of the United States. Such civil action shall be the exclusive remedy for recovering damages resulting from such actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cf5e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7435/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Damages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any action brought under subsection (a), upon a finding of liability on the part of the defendant, the defendant shall be liable to the plaintiff in an amount equal to the lesser of $500,000 or the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4755cf5f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7435/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actual, direct economic damages sustained by the plaintiff as a proximate result of the information disclosure, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4755cf60-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7435/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of the action.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Damages shall not include the taxpayer’s liability for any civil or criminal penalties, or other losses attributable to incarceration or the imposition of other criminal sanctions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cf61-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7435/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Claims pursuant to this section shall be payable out of funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1304"},"text":"section 1304 of title 31","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cf62-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7435/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period for bringing action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, an action to enforce liability created under this section may be brought without regard to the amount in controversy and may be brought only within 2 years after the date the actions creating such liability would have been discovered by exercise of reasonable care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cf63-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7435/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory stay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon a certification by the Commissioner or the Commissioner’s delegate that there is an ongoing investigation or prosecution of the taxpayer, the district court before which an action under this section is pending shall stay all proceedings with respect to such action pending the conclusion of the investigation or prosecution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cf64-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7435/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crime-fraud exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to information conveyed to an attorney, certified public accountant, or enrolled agent for the purpose of perpetrating a fraud or crime.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4755cf65-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/tXII/s1203/a"},"text":"Pub. L. 104–168, title XII, § 1203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1470"},"text":"110 Stat. 1470","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4755cf66-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4755cf67-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4755cf68-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7435 was renumbered 7437 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4755cf69-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4755cf6a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/tXII/s1203/c"},"text":"Pub. L. 104–168, title XII, § 1203(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1471"},"text":"110 Stat. 1471","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/168/tXII/s1203/c"},"text":"“The amendments made by this section [enacting this section and renumbering former section 7435 as 7436 of this title] shall apply to actions after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
