{"tag":"section","attrib":{"id":"id43fdcab0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707"},"text":null,"children":[{"tag":"num","attrib":{"value":"707"},"text":"§ 707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transactions between partner and partnership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43fdcab1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partner not acting in capacity as partner","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43fdcab2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a partner engages in a transaction with a partnership other than in his capacity as a member of such partnership, the transaction shall, except as otherwise provided in this section, be considered as occurring between the partnership and one who is not a partner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fdcab3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of payments to partners for property or services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43fdcab4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain services and transfers of property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43fdcab5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partner performs services for a partnership or transfers property to a partnership,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43fdcab6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a related direct or indirect allocation and distribution to such partner, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43fdcab7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the performance of such services (or such transfer) and the allocation and distribution, when viewed together, are properly characterized as a transaction occurring between the partnership and a partner acting other than in his capacity as a member of the partnership,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such allocation and distribution shall be treated as a transaction described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43fdcab8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain property transfers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43fdcab9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a direct or indirect transfer of money or other property by a partner to a partnership,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43fdcaba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a related direct or indirect transfer of money or other property by the partnership to such partner (or another partner), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43fdcabb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfers described in clauses (i) and (ii), when viewed together, are properly characterized as a sale or exchange of property,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such transfers shall be treated either as a transaction described in paragraph (1) or as a transaction between 2 or more partners acting other than in their capacity as members of the partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43fdcabc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain sales or exchanges of property with respect to controlled partnerships","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43fdcabd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Losses disallowed","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No deduction shall be allowed in respect of losses from sales or exchanges of property (other than an interest in the partnership), directly or indirectly, between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43fdcabe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership and a person owning, directly or indirectly, more than 50 percent of the capital interest, or the profits interest, in such partnership, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43fdcabf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two partnerships in which the same persons own, directly or indirectly, more than 50 percent of the capital interests or profits interests.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In the case of a subsequent sale or exchange by a transferee described in this paragraph, section 267(d) shall be applicable as if the loss were disallowed under section 267(a)(1). For purposes of section 267(a)(2), partnerships described in subparagraph (B) of this paragraph shall be treated as persons specified in section 267(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fdcac0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gains treated as ordinary income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a sale or exchange, directly or indirectly, of property, which in the hands of the transferee, is property other than a capital asset as defined in section 1221—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43fdcac1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between a partnership and a person owning, directly or indirectly, more than 50 percent of the capital interest, or profits interest, in such partnership, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43fdcac2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between two partnerships in which the same persons own, directly or indirectly, more than 50 percent of the capital interests or profits interests,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"any gain recognized shall be considered as ordinary income.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fdcac3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership of a capital or profits interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraphs (1) and (2) of this subsection, the ownership of a capital or profits interest in a partnership shall be determined in accordance with the rules for constructive ownership of stock provided in section 267(c) other than paragraph (3) of such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43fdcac4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s707/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guaranteed payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent determined without regard to the income of the partnership, payments to a partner for services or the use of capital shall be considered as made to one who is not a member of the partnership, but only for the purposes of section 61(a) (relating to gross income) and, subject to section 263, for purposes of section 162(a) (relating to trade or business expenses).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44003bc5-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/243"},"text":"68A Stat. 243","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tII/s213/b/3"},"text":"Pub. L. 94–455, title II, § 213(b)(3)","children":[],"tail":", title XIX, § 1901(b)(3)(C), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1547"},"text":"90 Stat. 1547","children":[],"tail":", 1792; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s73/a"},"text":"Pub. L. 98–369, div. A, title I, § 73(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/591"},"text":"98 Stat. 591","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s642/a/2"},"text":"Pub. L. 99–514, title VI, § 642(a)(2)","children":[],"tail":", title XVIII, §§ 1805(b), 1812(c)(3)(A), (B), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2284"},"text":"100 Stat. 2284","children":[],"tail":", 2810, 2834; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70602/a"},"text":"Pub. L. 119–21, title VII, § 70602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/284"},"text":"139 Stat. 284","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44003bc6-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44003bc7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44003bc8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “Except as provided” for “Under regulations prescribed” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(2)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1805/b"},"text":"Pub. L. 99–514, § 1805(b)","children":[],"tail":", substituted “sale or exchange of property” for “sale of property”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1812/c/3/B"},"text":"Pub. L. 99–514, § 1812(c)(3)(B)","children":[],"tail":", inserted at end “For purposes of section 267(a)(2), partnerships described in subparagraph (B) of this paragraph shall be treated as persons specified in section 267(b).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1812/c/3/A"},"text":"Pub. L. 99–514, § 1812(c)(3)(A)","children":[],"tail":", substituted “a person” for “a partner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1812/c/3/A"},"text":"Pub. L. 99–514, § 1812(c)(3)(A)","children":[],"tail":", substituted “a person” for “a partner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s642/a/2"},"text":"Pub. L. 99–514, § 642(a)(2)","children":[],"tail":", substituted “50 percent” for “80 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s642/a/2"},"text":"Pub. L. 99–514, § 642(a)(2)","children":[],"tail":", substituted “50 percent” for “80 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/b/3/C"},"text":"Pub. L. 94–455, § 1901(b)(3)(C)","children":[],"tail":", substituted “as ordinary income” for “as gain from the sale or exchange of property other than a capital asset”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s213/b/3"},"text":"Pub. L. 94–455, § 213(b)(3)","children":[],"tail":", substituted “and, subject to section 263, for purposes of section 162(a)” for “and section 162(a)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44003bc9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44003bca-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70602/b"},"text":"Pub. L. 119–21, title VII, § 70602(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/284"},"text":"139 Stat. 284","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70602/b"},"text":"“The amendment made by this section [amending this section] shall apply to services performed, and property transferred, after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44003bcb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s642/a/2"},"text":"section 642(a)(2) of Pub. L. 99–514","children":[],"tail":" applicable to sales after "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", in taxable years ending after such date, but not applicable to sales made after "},{"tag":"date","attrib":{"date":"1986-08-14"},"text":"Aug. 14, 1986","children":[],"tail":", which are made pursuant to a binding contract in effect on "},{"tag":"date","attrib":{"date":"1986-08-14"},"text":"Aug. 14, 1986","children":[],"tail":", and at all times thereafter, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s642/c"},"text":"section 642(c) of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1239"},"text":"section 1239 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by sections 1805(b) and 1812(c)(3)(B) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1812/c/3/A"},"text":"Pub. L. 99–514, title XVIII, § 1812(c)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2834"},"text":"100 Stat. 2834","children":[],"tail":", provided that the amendment made by that section is effective with respect to sales or exchanges after "},{"tag":"date","attrib":{"date":"1985-09-27"},"text":"Sept. 27, 1985","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44003bcc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s73/b"},"text":"Pub. L. 98–369, div. A, title I, § 73(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/592"},"text":"98 Stat. 592","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amendment made by subsection (a) [amending this section] shall apply—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of arrangements described in section 707(a)(2)(A) of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] (as amended by subsection (a)), to services performed or property transferred after ","children":[{"tag":"date","attrib":{"date":"1984-02-29"},"text":"February 29, 1984","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of transfers described in section 707(a)(2)(B) of such Code (as so amended), to property transferred after ","children":[{"tag":"date","attrib":{"date":"1984-03-31"},"text":"March 31, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Binding contract exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by subsection (a) shall not apply to a transfer of property described in section 707(a)(2)(B)(i) if such transfer is pursuant to a binding contract in effect on ","children":[{"tag":"date","attrib":{"date":"1984-03-31"},"text":"March 31, 1984","children":[],"tail":", and at all times thereafter before the transfer."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for certain transfers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amendment made by subsection (a) shall not apply to a transfer of property described in section 707(a)(2)(B)(i) that is made before ","children":[{"tag":"date","attrib":{"date":"1984-12-31"},"text":"December 31, 1984","children":[],"tail":", if—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such transfer was proposed in a written private offering memorandum circulated before ","children":[{"tag":"date","attrib":{"date":"1984-02-28"},"text":"February 28, 1984","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"