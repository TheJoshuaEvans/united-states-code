of 1964 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s221/e"},"text":"Pub. L. 88–272, title II, § 221(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/75"},"text":"78 Stat. 75","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraphs (2) and (3), the amendments made by this section [enacting sections 422 to 425 and 6039, amending this section, sections 402, 691, 6652, 6678, and the analysis preceding sections 401 and 6031, and renumbering section 3039 as 3040 of this title] shall apply to taxable years ending after ","children":[{"tag":"date","attrib":{"date":"1963-12-31"},"text":"December 31, 1963","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by paragraphs (1) and (3) of subsection (b) [enacting section 3039, renumbering former section 3039 as 3040, and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6678"},"text":"section 6678 of this title","children":[],"tail":"] and paragraph (2) of section 6652(a) of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] (as am