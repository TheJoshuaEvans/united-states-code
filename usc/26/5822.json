{"tag":"section","attrib":{"id":"id4651f3e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5822"},"text":null,"children":[{"tag":"num","attrib":{"value":"5822"},"text":"§ 5822.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Making","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person shall make a firearm unless he has (a) filed with the Secretary a written application, in duplicate, to make and register the firearm on the form prescribed by the Secretary; (b) paid any tax payable on the making and such payment is evidenced by the proper stamp affixed to the original application form; (c) identified the firearm to be made in the application form in such manner as the Secretary may by regulations prescribe; (d) identified himself in the application form in such manner as the Secretary may by regulations prescribe, except that, if such person is an individual, the identification must include his fingerprints and his photograph; and (e) obtained the approval of the Secretary to make and register the firearm and the application form shows such approval. Applications shall be denied if the making or possession of the firearm would place the person making the firearm in violation of law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4651f3e5-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/618/tII/s201"},"text":"Pub. L. 90–618, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1228"},"text":"82 Stat. 1228","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4651f3e6-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4651f3e7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4651f3e8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5831, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/724"},"text":"68A Stat. 724","children":[],"tail":", made a cross reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4181"},"text":"section 4181 of this title","children":[],"tail":" relating to an excise tax on pistols, revolvers, and firearms, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/90/618/tII/s201"},"text":"Pub. L. 90–618, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1227"},"text":"82 Stat. 1227","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4651f3e9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
