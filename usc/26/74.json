{"tag":"section","attrib":{"id":"id414317e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s74"},"text":null,"children":[{"tag":"num","attrib":{"value":"74"},"text":"§ 74.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prizes and awards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id414317e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s74/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section or in section 117 (relating to qualified scholarships), gross income includes amounts received as prizes and awards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id414317e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s74/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain prizes and awards transferred to charities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Gross income does not include amounts received as prizes and awards made primarily in recognition of religious, charitable, scientific, educational, artistic, literary, or civic achievement, but only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id414317e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s74/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient was selected without any action on his part to enter the contest or proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id414317e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s74/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient is not required to render substantial future services as a condition to receiving the prize or award; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id414317e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s74/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prize or award is transferred by the payor to a governmental unit or organization described in paragraph (1) or (2) of section 170(c) pursuant to a designation made by the recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id414317e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s74/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain employee achievement awards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id414317e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s74/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross income shall not include the value of an employee achievement award (as defined in section 274(j)) received by the taxpayer if the cost to the employer of the employee achievement award does not exceed the amount allowable as a deduction to the employer for the cost of the employee achievement award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id414317e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s74/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess deduction award","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the cost to the employer of the employee achievement award received by the taxpayer exceeds the amount allowable as a deduction to the employer, then gross income includes the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id414317e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s74/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the portion of the cost to the employer of the award that is not allowable as a deduction to the employer (but not in excess of the value of the award), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id414317ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s74/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount by which the value of the award exceeds the amount allowable as a deduction to the employer.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The remaining portion of the value of such award shall not be included in the gross income of the recipient.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id414317eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s74/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of tax-exempt employers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an employer exempt from taxation under this subtitle, any reference in this subsection to the amount allowable as a deduction to the employer shall be treated as a reference to the amount which would be allowable as a deduction to the employer if the employer were not exempt from taxation under this subtitle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id414317ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s74/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions excluding certain de minimis fringes from gross income, see section 132(e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id414317ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s74/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for Olympic and Paralympic medals and prizes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id414317ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s74/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross income shall not include the value of any medal awarded in, or any prize money received from the United States Olympic Committee on account of, competition in the Olympic Games or Paralympic Games.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id414317ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s74/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation based on adjusted gross income","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id414317f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s74/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to any taxpayer for any taxable year if the adjusted gross income (determined without regard to this subsection) of such taxpayer for such taxable year exceeds $1,000,000 (half of such amount in the case of a married individual filing a separate return).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id414317f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s74/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of sections 85(c), 86, 135, 137, 219, 221, and 469, adjusted gross income shall be determined after the application of paragraph (1) and before the application of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id414317f2-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/24"},"text":"68A Stat. 24","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tI"},"text":"Pub. L. 99–514, title I","children":[],"tail":", §§ 122(a)(1), 123(b)(1), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2109"},"text":"100 Stat. 2109","children":[],"tail":", 2113; "},{"tag":"ref","attrib":{"href":"/us/pl/114/239/s2/a"},"text":"Pub. L. 114–239, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-10-07"},"text":"Oct. 7, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/973"},"text":"130 Stat. 973","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13305/b/1"},"text":"Pub. L. 115–97, title I, § 13305(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2126"},"text":"131 Stat. 2126","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/tI/s104/b/2/B"},"text":"Pub. L. 116–260, div. EE, title I, § 104(b)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3041"},"text":"134 Stat. 3041","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIX/s9042/b/1"},"text":"Pub. L. 117–2, title IX, § 9042(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/122"},"text":"135 Stat. 122","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id414317f3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id414317f4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id414317f5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Pub. L. 117–2","children":[],"tail":" inserted “85(c),” before “86”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" struck out “222,” after “221,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" struck out “199,” after “137,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/239"},"text":"Pub. L. 114–239","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s123/b/1"},"text":"Pub. L. 99–514, § 123(b)(1)","children":[],"tail":", which directed that subsec. (a) be amended by substituting “(relating to qualified scholarships)” for “(relating to scholarship and fellowship grants)”, was executed by making the substitution for “(relating to scholarships and fellowship grants)” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s122/a/1/A"},"text":"Pub. L. 99–514, § 122(a)(1)(A)","children":[],"tail":", substituted “Except as otherwise provided in this section or” for “Except as provided in subsection (b) and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s122/a/1/B"},"text":"Pub. L. 99–514, § 122(a)(1)(B)","children":[],"tail":", (C), inserted “for certain prizes and awards transferred to charities” in heading and added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s122/a/1/D"},"text":"Pub. L. 99–514, § 122(a)(1)(D)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id414317f6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id414317f7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"References to the United States Olympic Committee deemed to refer to the United States Olympic and Paralympic Committee, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s220502/c"},"text":"section 220502(c) of Title 36","children":[],"tail":", Patriotic and National Observances, Ceremonies, and Organizations."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id414317f8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIX/s9042/c"},"text":"Pub. L. 117–2, title IX, § 9042(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/122"},"text":"135 Stat. 122","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/2/tIX/s9042/c"},"text":"“The amendments made by this section [amending this section and sections 85, 86, 135, 137, 219, 221, 222, and 469 of this title] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2019-12-31"},"text":"December 31, 2019","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id414317f9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/s104/c"},"text":"section 104(c) of div. EE of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s25A"},"text":"section 25A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id414317fa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13305/c"},"text":"Pub. L. 115–97, title I, § 13305(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2126"},"text":"131 Stat. 2126","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dT/s101/c"},"text":"Pub. L. 115–141, div. T, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1156"},"text":"132 Stat. 1156","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/141/dT/s101/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the amendments made by this section [amending this section and sections 86, 135, 137, 170, 172, 219, 221, 222, 246, 469, 613, and 613A of this title and repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s199"},"text":"section 199 of this title","children":[],"tail":"] shall apply to taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transition rule for qualified payments of patrons of cooperatives.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section shall not apply to a qualified payment received by a taxpayer from a specified agricultural or horticultural cooperative in a taxable year of the taxpayer beginning after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":", which is attributable to qualified production activities income with respect to which a deduction is allowable to the cooperative under section 199 of the Internal Revenue Code of 1986 (as in effect before the amendments made by this section) for a taxable year of the cooperative beginning before "},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":". Any term used in this subparagraph which is also used in section 199 of such Code (as so in effect) shall have the same meaning as when used in such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination with section 199a","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No deduction shall be allowed under section 199A of such Code for any qualified payment to which subparagraph (A) applies.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" to "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13305/c"},"text":"section 13305(c) of Pub. L. 115–97","children":[],"tail":", set out above, effective as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13305"},"text":"section 13305 of Pub. L. 115–97","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/s101/d"},"text":"section 101(d) of Pub. L. 115–141","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s62"},"text":"section 62 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id414317fb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/239/s2/b"},"text":"Pub. L. 114–239, § 2(b)","children"