{"tag":"section","attrib":{"id":"id47404b7f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6905"},"text":null,"children":[{"tag":"num","attrib":{"value":"6905"},"text":"§ 6905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discharge of executor from personal liability for decedent’s income and gift taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47404b80-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discharge of liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of liability of a decedent for taxes imposed by subtitle A or by chapter 12, if the executor makes written application (filed after the return with respect to such taxes is made and filed in such manner and such form as may be prescribed by regulations of the Secretary) for release from personal liability for such taxes, the Secretary may notify the executor of the amount of such taxes. The executor, upon payment of the amount of which he is notified, or 9 months after receipt of the application if no notification is made by the Secretary before such date, shall be discharged from personal liability for any deficiency in such tax thereafter found to be due, and shall be entitled to a receipt or writing showing such discharge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47404b81-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of executor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “executor” means the executor or administrator of the decedent appointed, qualified, and acting within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47404b82-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For discharge of executor from personal liability for taxes imposed under chapter 11, see section 2204.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47404b83-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614/tI/s101/e/1"},"text":"Pub. L. 91–614, title I, § 101(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1837"},"text":"84 Stat. 1837","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/614/tI/s101/f"},"text":"Pub. L. 91–614, title I, § 101(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1838"},"text":"84 Stat. 1838","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47404b84-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47404b85-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47404b86-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614/s101/f"},"text":"Pub. L. 91–614, § 101(f)","children":[],"tail":", substituted “9 months” for “1 year”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47404b87-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47404b88-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614/tI/s101/f"},"text":"Pub. L. 91–614, title I, § 101(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1838"},"text":"84 Stat. 1838","children":[],"tail":", provided that the amendment made by that section is effective with respect to the estates of decedents dying after "},{"tag":"date","attrib":{"date":"1973-12-31"},"text":"Dec. 31, 1973","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47404b89-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective with respect to decedents dying after ","children":[{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/614/s101/j"},"text":"section 101(j) of Pub. L. 91–614","children":[],"tail":", set out as an Effective Date of 1970 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2032"},"text":"section 2032 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
