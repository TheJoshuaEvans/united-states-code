{"tag":"section","attrib":{"id":"id45682fe5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3124"},"text":null,"children":[{"tag":"num","attrib":{"value":"3124"},"text":"§ 3124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estimate of revenue reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary at intervals of not longer than 3 years shall estimate the reduction in the amount of taxes collected under this chapter by reason of the operation of section 3121(b)(9) and shall include such estimate in his annual report.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id45682fe6-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/429"},"text":"68A Stat. 429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-01/ch1206"},"text":"Sept. 1, 1954, ch. 1206","children":[],"tail":", title II, § 205(b), "},{"tag":"ref","attrib":{"href":"/us/stat/68/1091"},"text":"68 Stat. 1091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45682fe7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45682fe8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"ta