ear” for “calendar quarters”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614"},"text":"Pub. L. 91–614","children":[],"tail":" substituted “calendar quarter” for “calendar year”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45420a44-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45420a45-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" applicable with respect to gifts made after "},{"tag":"date","attrib":{"date":"1981-12-31"},"text":"Dec. 31, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/s442/e"},"text":"section 442(e) of Pub. L. 97–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2501"},"text":"section 2501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45420a46-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614"},"text":"Pub. L. 91–614","children":[],"tail":" applicable